    {
      "type": "object",
      "properties": {
        "type": {
          "const": "stream-meta"
        },
        "agent": {
          "type": "string",
          "description": "Agent identifier"
        },
        "timestamp": {
          "type": "integer",
          "description": "Unix timestamp ms"
        },
        "correlation_id": {
          "type": "string",
          "description": "Links action to observation"
        },
        "provenance": {
          "type": "object",
          "properties": {
            "confidence": {
              "type": "string",
              "enum": [
                "confirmed",
                "inferred",
                "estimated",
                "ml_generated",
                "unknown"
              ]
            },
            "source": {
              "type": "string",
              "enum": [
                "cdp",
                "mcp",
                "extension",
                "user",
                "system",
                "other"
              ]
            },
            "timestamp_ms": {
              "type": "integer"
            }
          }
        },
        "stream_id": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "single",
            "multi",
            "collab"
          ],
          "description": "Stream mode. Determines which primitives are required."
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "capabilities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "capabilities": {
          "type": "object",
          "description": "Self-describing capabilities manifest. Maps agent_id -> task_key -> description.",
          "properties": {
            "instruction": {
              "type": "string"
            },
            "index": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "$docs": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      },
      "required": [
        "stream_id",
        "agents",
        "mode"
      ]
    },
