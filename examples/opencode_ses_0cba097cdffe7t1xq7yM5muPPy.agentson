                \n                \n                    \n                    \n                    \n                        Close\n                        \n        \n\n                    \n                    \n\n                    \n                    Menu\n\n                    \n                    \n                    \n                        \n        \n\n                        Back\n                    \n                    \n                \n\n                \n                \n                    \n                    \n        \n\n                    Previous items\n                    \n                \n                \n                    \n                    \n        \n\n                    Next items\n                    \n                \n\n                \n                \n\n                \n                    \n                    \n                        European Commission / Data protection\n                    \n\n                    \n                                        \n                        \n                            Topics\n                        \n                        \n                            \n                                \n        \n\n                            \n                        \n                        \n                            \n                                                                \n                                    Data protection\n                                \n                                                            \n                        \n                    \n                    \n                                        \n                                                Archives\n                                            \n                                    \n            \n        \n    \n    \n\n\n\n        \n        \n                \n            \n                \n                \n                                    \n                \n            \n        \n                \n        \n            \n                \n\n                    \n                    \n                    \n\n                    \n                        \n                        \n    \n    \n    \n    \n        \n            \n                Overview\n                                     \n        \n\n \n                    Guidelines\n                                            \n        \n\n        Guidelines on the right to \"data portability\" (wp242rev.01)\n\n        \n            \n            \n                \n            \n            \n\n            \n                        \n\n            \n                \n                \n                    \n                        \n                                                    \n                                Date: \n27/10/2017\n                            \n                                                                    \n                \n                \n\n                \n                                \n                    Guidelines on the right to \"data portability\", wp242rev.01_en \n\nAvailable language versions\nAnnex - available language versions \n\n                \n                                \n\n                \n                                \n\n                \n                                \n            \n        \n    \n\n\n\n    \n    \n    \n        \n        \n                        Related Article29\n            \n                                                Data protection\n                                \n                \n                \n                    \n                        \n                            \n                        \n                        Loading\n                    \n                \n            \n                    \n    \n        \n\n    \n    \n                        \n\n                    \n                \n            \n        \n        \n\n        \n        \n        \n            \n        \n\n    \n        \n            \n                \n        \n                    \n                \n            \n                    \n                This service is managed by the Directorate-General for \"Communications Networks, Content and Technology\"\n            \n            \n\n            \n            \n                \n        \n        Policies\n    \n        \n                    \n                Cookies\n        \n\n\n            \n                    \n                Privacy statement\n        \n\n\n            \n                    \n                Accessibility statement\n        \n\n\n            \n                    \n                Legal notice\n        \n\n\n            \n            \n\n            \n            \n                \n        \n        About Us\n    \n        \n                    \n                Directorate-General CONNECT",
      "status": "success",
