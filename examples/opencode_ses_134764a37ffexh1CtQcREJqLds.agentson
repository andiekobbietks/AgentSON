      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\cognitive-taxonomy-vscode-ext\\\\src\\\\dataFlow.ts\"}",
      "output": "<path>C:\\Users\\LLM-Test\\Documents\\cognitive-taxonomy-vscode-ext\\src\\dataFlow.ts</path>\n<type>file</type>\n<content>\n1: import { ASTNode, TaxonomyCategory, CATEGORIES } from './astClassifier';\n2: \n3: // ─── Data Flow View Types ───────────────────────────────────────────────\n4: \n5: export type DataFlowView = 'ascii' | 'mini' | 'mermaid' | 'svg';\n6: \n7: // ─── ASCII Arrows (Simplest) ────────────────────────────────────────────\n8: \n9: export function generateAsciiFlow(nodes: ASTNode[]): string {\n10:     if (nodes.length === 0) return '';\n11:     \n12:     const parts = nodes.map(node => {\n13:         const name = node.name || node.type;\n14:         return name;\n15:     });\n16:     \n17:     return parts.join(' → ');\n18: }\n19: \n20: // ─── Mini Diagram (Developer) ───────────────────────────────────────────\n21: \n22: export function generateMiniDiagram(nodes: ASTNode[]): string {\n23:     if (nodes.length === 0) return '';\n24:     \n25:     const lines = [];\n26:     const boxWidth = 14;\n27:     const arrow = '───▶';\n28:     \n29:     // Build first row\n30:     let topBorder = '┌';\n31:     let middle = '│';\n32:     let bottomBorder = '└';\n33:     \n34:     nodes.forEach((node, i) => {\n35:         const name = (node.name || node.type).substring(0, boxWidth - 2).padEnd(boxWidth - 2);\n36:         topBorder += '─'.repeat(boxWidth) + '┐';\n37:         middle += name + '│';\n38:         bottomBorder += '─'.repeat(boxWidth) + '┘';\n39:         \n40:         if (i < nodes.length - 1) {\n41:             topBorder += '    ';\n42:             middle += arrow;\n43:             bottomBorder += '    ';\n44:         }\n45:     });\n46:     \n47:     lines.push(topBorder);\n48:     lines.push(middle);\n49:     lines.push(bottomBorder);\n50:     \n51:     return lines.join('\\n');\n52: }\n53: \n54: // ─── Mermaid Diagram (Rich) ─────────────────────────────────────────────\n55: \n56: export function generateMermaidDiagram(nodes: ASTNode[]): string {\n57:     if (nodes.length === 0) return '';\n58:     \n59:     const lines = ['graph LR'];\n60:     \n61:     nodes.forEach((node, i) => {\n62:         const id = `node${i}`;\n63:         const name = node.name || node.type;\n64:         const category = node.type === 'function' ? 'orange' : \n65:                         node.type === 'class' ? 'blue' : \n66:                         node.type === 'import' ? 'green' : 'orange';\n67:         \n68:         // Define node\n69:         lines.push(`    ${id}[\"${name}\"]`);\n70:         \n71:         // Style node\n72:         const color = CATEGORIES[category]?.colour || '#808080';\n73:         lines.push(`    style ${id} fill:${color},stroke:#333,stroke-width:2px,color:white`);\n74:         \n75:         // Connect to next node\n76:         if (i < nodes.length - 1) {\n77:             const nextId = `node${i + 1}`;\n78:             lines.push(`    ${id} --> ${nextId}`);\n79:         }\n80:     });\n81:     \n82:     return lines.join('\\n');\n83: }\n84: \n85: // ─── SVG Arrows (Best Visual) ───────────────────────────────────────────\n86: \n87: export function generateSvgFlow(nodes: ASTNode[]): string {\n88:     if (nodes.length === 0) return '';\n89:     \n90:     const nodeWidth = 120;\n91:     const nodeHeight = 40;\n92:     const gap = 50;\n93:     const padding = 20;\n94:     \n95:     const totalWidth = nodes.length * (nodeWidth + gap) - gap + padding * 2;\n96:     const totalHeight = nodeHeight + padding * 2;\n97:     \n98:     let svg = `<svg width=\"${totalWidth}\" height=\"${totalHeight}\" xmlns=\"http://www.w3.org/2000/svg\">`;\n99:     \n100:     // Add arrow marker definition\n101:     svg += `\n102:     <defs>\n103:         <marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"7\" refX=\"9\" refY=\"3.5\" orient=\"auto\">\n104:             <polygon points=\"0 0, 10 3.5, 0 7\" fill=\"#666\"/>\n105:         </marker>\n106:     </defs>`;\n107:     \n108:     nodes.forEach((node, i) => {\n109:         const x = padding + i * (nodeWidth + gap);\n110:         const y = padding;\n111:         const category = node.type === 'function' ? 'orange' : \n112:                         node.type === 'class' ? 'blue' : \n113:                         node.type === 'import' ? 'green' : 'orange';\n114:         const color = CATEGORIES[category]?.colour || '#808080';\n115:         const name = (node.name || node.type).substring(0, 12);\n116:         \n117:         // Draw node rectangle\n118:         svg += `<rect x=\"${x}\" y=\"${y}\" width=\"${nodeWidth}\" height=\"${nodeHeight}\" fill=\"${color}\" rx=\"5\" ry=\"5\"/>`;\n119:         \n120:         // Draw node text\n121:         svg += `<text x=\"${x + nodeWidth/2}\" y=\"${y + nodeHeight/2 + 5}\" text-anchor=\"middle\" fill=\"white\" font-family=\"monospace\" font-size=\"12\">${name}</text>`;\n122:         \n123:         // Draw arrow to next node\n124:         if (i < nodes.length - 1) {\n125:             const arrowX1 = x + nodeWidth;\n126:             const arrowX2 = x + nodeWidth + gap;\n127:             const arrowY = y + nodeHeight / 2;\n128:             \n129:             svg += `<line x1=\"${arrowX1}\" y1=\"${arrowY}\" x2=\"${arrowX2}\" y2=\"${arrowY}\" stroke=\"#666\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"/>`;\n130:         }\n131:     });\n132:     \n133:     svg += '</svg>';\n134:     return svg;\n135: }\n136: \n137: // ─── Smart Format Selection ─────────────────────────────────────────────\n138: \n139: export function getBestHoverFormat(): DataFlowView {\n140:     // VS Code hover markdown doesn't render inline SVG well\n141:     // Use ASCII for hover, let sidebar handle SVG\n142:     return 'ascii';\n143: }\n144: \n145: export function getBestSidebarFormat(): DataFlowView {\n146:     return 'svg';\n147: }\n148: \n149: // ─── Main Generator ─────────────────────────────────────────────────────\n150: \n151: export function generateDataFlow(nodes: ASTNode[], view: DataFlowView): string {\n152:     switch (view) {\n153:         case 'ascii':\n154:             return generateAsciiFlow(nodes);\n155:         case 'mini':\n156:             return generateMiniDiagram(nodes);\n157:         case 'mermaid':\n158:             return generateMermaidDiagram(nodes);\n159:         case 'svg':\n160:             return generateSvgFlow(nodes);\n161:         default:\n162:             return generateAsciiFlow(nodes);\n163:     }\n164: }\n165: \n166: // ─── Get Flow Nodes from Code ───────────────────────────────────────────\n167: \n168: export function extractFlowNodes(code: string, currentLine: number): ASTNode[] {\n169:     const lines = code.split('\\n');\n170:     const nodes: ASTNode[] = [];\n171:     \n172:     // Find function calls and assignments in nearby lines\n173:     for (let i = Math.max(0, currentLine - 5); i <= Math.min(lines.length - 1, currentLine + 5); i++) {\n174:         const line = lines[i].trim();\n175:         \n176:         // Match function calls\n177:         const funcMatch = line.match(/(\\w+)\\s*\\(/);\n178:         if (funcMatch) {\n179:             nodes.push({\n180:                 type: 'function',\n181:                 name: funcMatch[1],\n182:                 value: line,\n183:                 children: [],\n184:                 startLine: i,\n185:                 endLine: i,\n186:                 startCol: 0,\n187:                 endCol: line.length\n188:             });\n189:         }\n190:         \n191:         // Match assignments\n192:         const assignMatch = line.match(/(\\w+)\\s*=/);\n193:         if (assignMatch && !funcMatch) {\n194:             nodes.push({\n195:                 type: 'variable',\n196:                 name: assignMatch[1],\n197:                 value: line,\n198:                 children: [],\n199:                 startLine: i,\n200:                 endLine: i,\n201:                 startCol: 0,\n202:                 endCol: line.length\n203:             });\n204:         }\n205:     }\n206:     \n207:     return nodes;\n208: }\n209: \n210: // ─── Format Flow for Tooltip ────────────────────────────────────────────\n211: \n212: export function formatFlowForTooltip(\n213:     nodes: ASTNode[], \n214:     view: DataFlowView,\n215:     currentLine: number\n216: ): string {\n217:     const flow = generateDataFlow(nodes, view);\n218:     \n219:     let tooltip = `**DATA FLOW** (${view.toUpperCase()} view)\\n\\n`;\n220:     \n221:     switch (view) {\n222:         case 'ascii':\n223:             tooltip += `\\`${flow}\\`\\n\\n`;\n224:             break;\n225:         case 'mini':\n226:             tooltip += `\\`\\`\\`\\n${flow}\\n\\`\\`\\`\\n\\n`;\n227:             break;\n228:         case 'mermaid':\n229:             tooltip += `\\`\\`\\`mermaid\\n${flow}\\n\\`\\`\\`\\n\\n`;\n230:             break;\n231:         case 'svg':\n232:             tooltip += `*See visual diagram in panel*\\n\\n`;\n233:             break;\n234:     }\n235:     \n236:     // Add context\n237:     const currentNode = nodes.find(n => n.startLine === currentLine);\n238:     if (currentNode) {\n239:         const nodeIndex = nodes.indexOf(currentNode);\n240:         if (nodeIndex > 0) {\n241:             tooltip += `⬅️ Comes from: ${nodes[nodeIndex - 1].name || nodes[nodeIndex - 1].type}\\n`;\n242:         }\n243:         if (nodeIndex < nodes.length - 1) {\n244:             tooltip += `➡️ Goes to: ${nodes[nodeIndex + 1].name || nodes[nodeIndex + 1].type}\\n`;\n245:         }\n246:     }\n247:     \n248:     return tooltip;\n249: }\n\n(End of file - total 249 lines)\n</content>",
