      "output": "<path>C:\\Users\\LLM-Test\\Documents\\cognitive-taxonomy-vscode-ext\\src\\tooltipGenerator.ts</path>\n<type>file</type>\n<content>\n1: import { ASTNode, TaxonomyCategory, CATEGORIES } from './astClassifier';\n2: \n3: // ─── Tooltip Templates (Plain English) ───────────────────────────────────\n4: \n5: interface TooltipTemplate {\n6:     category: string;\n7:     nodeType: string;\n8:     explanation: string;\n9:     why: string;\n10:     matters: string;\n11:     missing: string;\n12:     example: string;\n13:     context?: string;\n14: }\n15: \n16: const TOOLTIP_TEMPLATES: TooltipTemplate[] = [\n17:     // BLUE (Blueprint) — \"What the code needs to remember\"\n18:     {\n19:         category: 'blue',\n20:         nodeType: 'class',\n21:         explanation: 'This line CREATES a thing the code needs to remember.',\n22:         why: 'A class is like a recipe card — it says what info this thing holds.',\n23:         matters: 'Without it, the code would forget what data it needs.',\n24:         missing: 'The code would have nowhere to store this information.',\n25:         example: 'class User:\\n    name: str\\n    age: int'\n26:     },\n27:     {\n28:         category: 'blue',\n29:         nodeType: 'decorator',\n30:         explanation: 'This line ADDS A LABEL to the code below.',\n31:         why: 'A decorator is like a sticky note — it tells Python something extra about the code.',\n32:         matters: 'Without it, you\\'d have to write the same thing over and over.',\n33:         missing: 'The code would still work, but it would be much longer and messier.',\n34:         example: '@dataclass\\nclass Config:\\n    debug: bool = False'\n35:     },\n36:     {\n37:         category: 'blue',\n38:         nodeType: 'field',\n39:         explanation: 'This line SAYS WHAT INFO this thing holds.',\n40:         why: 'Fields are like the items on a shopping list — they say what\\'s inside.',\n41:         matters: 'Without them, you wouldn\\'t know what data this thing has.',\n42:         missing: 'You\\'d have to read every part of the code to find out what data exists.',\n43:         example: 'class User:\\n    name: str'\n44:     },\n45:     \n46:     // GREEN (Plumbing) — \"Bringing things from outside\"\n47:     {\n48:         category: 'green',\n49:         nodeType: 'import',\n50:         explanation: 'This line BRINGS IN a tool from outside.',\n51:         why: 'An import is like ordering a delivery — it brings something you didn\\'t make yourself.',\n52:         matters: 'Without it, the code would try to use tools it doesn\\'t have.',\n53:         missing: 'The code would crash — Python would say \"I don\\'t know what this tool is.\"',\n54:         example: 'import pandas as pd'\n55:     },\n56:     {\n57:         category: 'green',\n58:         nodeType: 'import',\n59:         explanation: 'This line BRINGS IN a tool from outside.',\n60:         why: 'This tool helps the code do something special — like working with tables or maths.',\n61:         matters: 'Without it, the code couldn\\'t do the special thing this tool does.',\n62:         missing: 'The code would crash when it tries to use this tool.',\n63:         example: 'import numpy as np',\n64:         context: 'pandas|numpy|matplotlib|scipy'\n65:     },\n66:     {\n67:         category: 'green',\n68:         nodeType: 'import',\n69:         explanation: 'This line BRINGS IN a tool from outside.',\n70:         why: 'This tool helps the code talk to other systems — like databases or websites.',\n71:         matters: 'Without it, the code couldn\\'t connect to anything outside itself.',\n72:         missing: 'The code would crash when it tries to connect to the outside world.',\n73:         example: 'from flask import Flask',\n74:         context: 'flask|django|fastapi|sqlalchemy|requests'\n75:     },\n76:     {\n77:         category: 'green',\n78:         nodeType: 'comment',\n79:         explanation: 'This line is a NOTE for other developers.',\n80:         why: 'Comments explain WHY the code exists, not just WHAT it does.',\n81:         matters: 'Without notes, other developers have to guess what the code is for.',\n82:         missing: 'Other developers would be confused about what this code does.',\n83:         example: '# This handles user login'\n84:     },\n85:     {\n86:         category: 'green',\n87:         nodeType: 'assignment',\n88:         explanation: 'This line SETS UP something the code needs.',\n89:         why: 'This is like plugging in a machine — it gets something ready to use.',\n90:         matters: 'Without it, the code wouldn\\'t have the tools it needs to work.',\n91:         missing: 'The code would crash when it tries to use this tool.',\n92:         example: 'app = Flask(__name__)',\n93:         context: 'app|db|engine|router|config|settings'\n94:     },\n95:     \n96:     // ORANGE (Transaction) — \"What the code actually does\"\n97:     {\n98:         category: 'orange',\n99:         nodeType: 'function',\n100:         explanation: 'This line DOES SOMETHING — it takes input and gives output.',\n101:         why: 'A function is like a machine — you put something in, something comes out.',\n102:         matters: 'Functions are where the actual work happens. Clear functions = easy to understand.',\n103:         missing: 'The code would be one giant block — impossible to test or fix.',\n104:         example: 'def process_data(items):\\n    return [transform(x) for x in items]'\n105:     },\n106:     {\n107:         category: 'orange',\n108:         nodeType: 'function',\n109:         explanation: 'This line GOES AND GETS something without changing it.',\n110:         why: 'This is a read-only operation — it looks but doesn\\'t touch.',\n111:         matters: 'Reading is safe — it can\\'t break anything.',\n112:         missing: 'The code would have no way to get the information it needs.',\n113:         example: 'def get_user(user_id):\\n    return db.query(User).get(user_id)',\n114:         context: 'get|fetch|query|read|list|find|search'\n115:     },\n116:     {\n117:         category: 'orange',\n118:         nodeType: 'function',\n119:         explanation: 'This line CHANGES something.',\n120:         why: 'This is a write operation — it creates, updates, or deletes.',\n121:         matters: 'Writing is dangerous — it can break things if done wrong.',\n122:         missing: 'The code couldn\\'t save or update anything.',\n123:         example: 'def create_user(data):\\n    user = User(**data)\\n    db.add(user)',\n124:         context: 'add|create|insert|write|save|update|delete|remove|set'\n125:     },\n126:     {\n127:         category: 'orange',\n128:         nodeType: 'function',\n129:         explanation: 'This line CHECKS if something is allowed.',\n130:         why: 'Validation is like a bouncer — it stops bad data from getting in.',\n131:         matters: 'Without checks, bad data enters the system and causes problems later.',\n132:         missing: 'Bad data would sneak in and cause crashes or wrong answers.',\n133:         example: 'def validate_email(email):\\n    return \"@\" in email',\n134:         context: 'validate|check|verify|assert|ensure'\n135:     },\n136:     {\n137:         category: 'orange',\n138:         nodeType: 'function',\n139:         explanation: 'This line CHANGES something from one form to another.',\n140:         why: 'Transforming is like翻译 — it converts data so other parts can understand it.',\n141:         matters: 'Without transformation, different parts of the code can\\'t talk to each other.',\n142:         missing: 'The code would crash because it\\'s trying to use the wrong type of data.',\n143:         example: 'def parse_json(text):\\n    return json.loads(text)',\n144:         context: 'convert|transform|parse|format|encode|decode'\n145:     },\n146:     {\n147:         category: 'orange',\n148:         nodeType: 'control',\n149:         explanation: 'This line MAKES A DECISION — do this or do that.',\n150:         why: 'An if statement is like a fork in the road — it decides which way to go.',\n151:         matters: 'Decisions are how the code handles different situations.',\n152:         missing: 'The code would always do the same thing, no matter what.',\n153:         example: 'if user.is_active:\\n    process(user)'\n154:     },\n155:     {\n156:         category: 'orange',\n157:         nodeType: 'control',\n158:         explanation: 'This line REPEATS something for each item.',\n159:         why: 'A loop is like an assembly line — it does the same thing to each item.',\n160:         matters: 'Loops save you from writing the same code over and over.',\n161:         missing: 'You\\'d have to write separate code for every single item.',\n162:         example: 'for item in items:\\n    process(item)',\n163:         context: 'for|while'\n164:     },\n165:     {\n166:         category: 'orange',\n167:         nodeType: 'control',\n168:         explanation: 'This line MANAGES something while it\\'s being used.',\n169:         why: 'A context manager is like a librarian — it makes sure things get put back.',\n170:         matters: 'Without it, resources might not get cleaned up properly.',\n171:         missing: 'Files might stay open, connections might leak, memory might run out.',\n172:         example: 'with open(\"file.txt\") as f:\\n    data = f.read()'\n173:     },\n174:     {\n175:         category: 'orange',\n176:         nodeType: 'try',\n177:         explanation: 'This line TRIES something and catches errors if it fails.',\n178:         why: 'Try/except is like a safety net — it catches problems before they crash the program.',\n179:         matters: 'Without it, one small error would crash the entire program.',\n180:         missing: 'The program would crash on the first error it encounters.',\n181:         example: 'try:\\n    result = divide(a, b)\\nexcept ZeroDivisionError:\\n    result = 0'\n182:     },\n183:     {\n184:         category: 'orange',\n185:         nodeType: 'exception',\n186:         explanation: 'This line STOPS THE PROGRAM with an error message.',\n187:         why: 'Raising an exception is like pulling the fire alarm — it stops everything and says \"something is wrong.\"',\n188:         matters: 'Without exceptions, the program would keep running with bad data.',\n189:         missing: 'The program would continue in a broken state, causing more problems.',\n190:         example: 'raise ValueError(\"Invalid input\")'\n191:     },\n192:     {\n193:         category: 'orange',\n194:         nodeType: 'assignment',\n195:         explanation: 'This line SAVES a result for later.',\n196:         why: 'An assignment is like writing something down — it remembers the answer.',\n197:         matters: 'Without saving results, the code would have to recalculate everything.',\n198:         missing: 'The code would forget the answer and have to start over.',\n199:         example: 'price = calculate_price(option)'\n200:     },\n201:     {\n202:         category: 'orange',\n203:         nodeType: 'expression',\n204:         explanation: 'This line DOES A CALCULATION.',\n205:         why: 'An expression is like a maths problem — it works out an answer.',\n206:         matters: 'Calculations are where the actual work happens.',\n207:         missing: 'The code couldn\\'t work out any answers.',\n208:         example: 'total = price * quantity'\n209:     },\n210:     {\n211:         category: 'orange',\n212:         nodeType: 'return',\n213:         explanation: 'This line GIVES BACK the answer.',\n214:         why: 'A return statement is like a waiter bringing your food — it delivers the result.',\n215:         matters: 'Without return, the function\\'s answer would be lost.',\n216:         missing: 'The function would do all its work but never give you the answer.',\n217:         example: 'return price * quantity'\n218:     },\n219:     \n220:     // RED (Constraint) — \"Rules that must never be broken\"\n221:     {\n222:         category: 'red',\n223:         nodeType: 'function',\n224:         explanation: 'This line CHECKS if something follows the rules.',\n225:         why: 'Validation is like a security guard — it stops bad things from getting in.',\n226:         matters: 'Without rules, the system would accept anything — even things that break it.',\n227:         missing: 'Bad data would enter the system and cause crashes or wrong answers.',\n228:         example: 'def validate_price(price):\\n    if price < 0:\\n        raise ValueError(\"Price must be positive\")',\n229:         context: 'validate|check|verify|assert|ensure'\n230:     },\n231:     {\n232:         category: 'red',\n233:         nodeType: 'control',\n234:         explanation: 'This line CHECKS IF A RULE IS BEING FOLLOWED.',\n235:         why: 'An if statement inside validation is like a double-check — it makes sure the rules are followed.',\n236:         matters: 'Without these checks, the system would accept invalid data.',\n237:         missing: 'Bad data would enter the system unchecked.',\n238:         example: 'if price < 0:\\n    raise ValueError(\"Price must be positive\")'\n239:     },\n240:     {\n241:         category: 'red',\n242:         nodeType: 'exception',\n243:         explanation: 'This line STOPS THE PROGRAM when a rule is broken.',\n244:         why: 'Raising an error is like sounding an alarm — it stops everything when something is wrong.',\n245:         matters: 'Without errors, the program would keep running with bad data.',\n246:         missing: 'The program would continue in a broken state.',\n247:         example: 'raise ValueError(\"Price must be positive\")'\n248:     },\n249:     \n250:     // PURPLE (Pedagogy) — \"Notes for yourself later\"\n251:     {\n252:         category: 'purple',\n253:         nodeType: 'docstring',\n254:         explanation: 'This line EXPLAINS what the code does.',\n255:         why: 'A docstring is like a label on a box — it tells you what\\'s inside without opening it.',\n256:         matters: 'Without documentation, other developers have to read every line to understand.',\n257:         missing: 'Other developers would be confused about what this code does.',\n258:         example: '\"\"\"Calculate the price of an option.\"\"\"'\n259:     },\n260:     {\n261:         category: 'purple',\n262:         nodeType: 'comment',\n263:         explanation: 'This line is a NOTE for other developers.',\n264:         why: 'Comments explain WHY the code exists, not just WHAT it does.',\n265:         matters: 'Without notes, other developers have to guess what the code is for.',\n266:         missing: 'Other developers would be confused about what this code does.',\n267:         example: '# This handles user login'\n268:     },\n269:     {\n270:         category: 'purple',\n271:         nodeType: 'todo',\n272:         explanation: 'This line is a REMINDER to do something later.',\n273:         why: 'TODOs are like sticky notes — they remind you of things that still need doing.',\n274:         matters: 'Without reminders, you might forget important tasks.',\n275:         missing: 'You might forget to do this later.',\n276:         example: '# TODO: Add error handling'\n277:     }\n278: ];\n279: \n280: // ─── Fallback Template ───────────────────────────────────────────────────\n281: \n282: const FALLBACK_TEMPLATE: TooltipTemplate = {\n283:     category: 'orange',\n284:     nodeType: 'default',\n285:     explanation: 'This line DOES SOMETHING in the code.',\n286:     why: 'Every line has a job — this one is part of the work being done.',\n287:     matters: 'Understanding each line helps you see the bigger picture.',\n288:     missing: 'The code would be missing a piece of the puzzle.',\n289:     example: ''\n290: };\n291: \n292: // ─── Tooltip Generator ───────────────────────────────────────────────────\n293: \n294: export class TooltipGenerator {\n295:     private enableAI: boolean;\n296:     \n297:     constructor(enableAI: boolean = false) {\n298:         this.enableAI = enableAI;\n299:     }\n300:     \n301:     generateTooltip(node: ASTNode, category: TaxonomyCategory): string {\n302:         const template = this.findTemplate(node, category);\n303:         return this.formatTooltip(template, node, category);\n304:     }\n305:     \n306:     private findTemplate(node: ASTNode, category: TaxonomyCategory): TooltipTemplate {\n307:         // Find matching template\n308:         for (const template of TOOLTIP_TEMPLATES) {\n309:             if (template.category === category.id) {\n310:                 if (template.nodeType === node.type || template.nodeType === 'default') {\n311:                     // Check context if specified\n312:                     if (template.context) {\n313:                         const contexts = template.context.split('|');\n314:                         const nodeValue = (node.value || node.name || '').toLowerCase();\n315:                         if (contexts.some(ctx => nodeValue.includes(ctx))) {\n316:                             return template;\n317:                         }\n318:                     } else {\n319:                         return template;\n320:                     }\n321:                 }\n322:             }\n323:         }\n324:         \n325:         // Try to find any template for this category\n326:         for (const template of TOOLTIP_TEMPLATES) {\n327:             if (template.category === category.id) {\n328:                 return template;\n329:             }\n330:         }\n331:         \n332:         return FALLBACK_TEMPLATE;\n333:     }\n334:     \n335:     private formatTooltip(template: TooltipTemplate, node: ASTNode, category: TaxonomyCategory): string {\n336:         const nodeName = node.name || node.value || 'code';\n337:         \n338:         let tooltip = '';\n339:         \n340:         // Category emoji\n341:         const emoji = category.id === 'blue' ? '🔵' :\n342:                      category.id === 'green' ? '🟢' :\n343:                      category.id === 'orange' ? '🟠' :\n344:                      category.id === 'red' ? '🔴' : '🟣';\n345:         \n346:         // WHAT (plain English)\n347:         tooltip += `${emoji} ${template.explanation}\\n\\n`;\n348:         \n349:         // WHY (plain English)\n350:         tooltip += `**WHY?** ${template.why}\\n\\n`;\n351:         \n352:         // SO WHAT (plain English)\n353:         tooltip += `**WHY IT MATTERS?** ${template.matters}\\n\\n`;\n354:         \n355:         // IF MISSING (plain English)\n356:         tooltip += `**IF THIS WERE MISSING:** ${template.missing}\\n\\n`;\n357:         \n358:         // Example if available\n359:         if (template.example) {\n360:             tooltip += `**Example:**\\n`;\n361:             tooltip += `~~~python\\n${template.example}\\n~~~\\n`;\n362:         }\n363:         \n364:         return tooltip;\n365:     }\n366: }\n367: \n368: // ─── Format Tooltip as Markdown ──────────────────────────────────────────\n369: \n370: export function formatTooltipMarkdown(tooltip: string, lineText: string): string {\n371:     // The tooltip is already formatted with markdown\n372:     // Just add the line context at the top\n373:     const trimmedLine = lineText.trim();\n374:     const linePreview = trimmedLine.length > 60 ? trimmedLine.substring(0, 60) + '...' : trimmedLine;\n375:     \n376:     return `\\`${linePreview}\\`\\n\\n${tooltip}`;\n377: }\n\n(End of file - total 377 lines)\n</content>",
