      "output": "<path>C:\\Users\\LLM-Test\\.antigravity-ide\\extensions\\cognitive-taxonomy-antigravity-0.0.1-universal\\package.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"name\": \"cognitive-taxonomy-protocol\",\n3:   \"displayName\": \"Cognitive Taxonomy Protocol\",\n4:   \"description\": \"Five-colour architectural taxonomy with hover tooltips. Shifts code comprehension from System 2 (linear reading) to System 1 (pattern recognition).\",\n5:   \"version\": \"0.0.1\",\n6:   \"engines\": { \"vscode\": \"^1.85.0\" },\n7:   \"categories\": [\"Programming Languages\", \"Visualization\", \"Education\"],\n8:   \"activationEvents\": [\"onLanguage:python\"],\n9:   \"main\": \"./out/extension.js\",\n10:   \"contributes\": {\n11:     \"commands\": [\n12:       {\n13:         \"command\": \"cognitiveTaxonomy.toggle\",\n14:         \"title\": \"Cognitive Taxonomy: Toggle View\"\n15:       },\n16:       {\n17:         \"command\": \"cognitiveTaxonomy.showMetrics\",\n18:         \"title\": \"Cognitive Taxonomy: Show Metrics\"\n19:       },\n20:       {\n21:         \"command\": \"cognitiveTaxonomy.refreshSidebar\",\n22:         \"title\": \"Cognitive Taxonomy: Refresh Sidebar\"\n23:       },\n24:       {\n25:         \"command\": \"cognitiveTaxonomy.toggleDataFlow\",\n26:         \"title\": \"Cognitive Taxonomy: Toggle Data Flow View\"\n27:       }\n28:     ],\n29:     \"keybindings\": [\n30:       {\n31:         \"command\": \"cognitiveTaxonomy.toggle\",\n32:         \"key\": \"ctrl+shift+t\",\n33:         \"mac\": \"cmd+shift+t\"\n34:       },\n35:       {\n36:         \"command\": \"cognitiveTaxonomy.toggleDataFlow\",\n37:         \"key\": \"ctrl+shift+f\",\n38:         \"mac\": \"cmd+shift+f\"\n39:       }\n40:     ],\n41:     \"viewsContainers\": {\n42:       \"activitybar\": [\n43:         {\n44:           \"id\": \"cognitiveTaxonomy\",\n45:           \"title\": \"Cognitive Taxonomy\",\n46:           \"icon\": \"$(graph)\"\n47:         }\n48:       ]\n49:   