      "output": "<path>C:\\Users\\LLM-Test\\Documents\\cognitive-taxonomy-vscode-ext\\src\\astClassifier.ts</path>\n<type>file</type>\n<content>\n1: import * as vscode from 'vscode';\n2: \n3: // ─── AST Node Types ──────────────────────────────────────────────────────\n4: \n5: export interface ASTNode {\n6:     type: string;\n7:     name?: string;\n8:     value?: string;\n9:     children: ASTNode[];\n10:     startLine: number;\n11:     endLine: number;\n12:     startCol: number;\n13:     endCol: number;\n14:     parent?: ASTNode;\n15:     context?: string;\n16: }\n17: \n18: // ─── Taxonomy Categories ────────────────────────────────────────────────\n19: \n20: export interface TaxonomyCategory {\n21:     id: string;\n22:     label: string;\n23:     colour: string;\n24:     bgAlpha: string;\n25:     explanation: string;\n26: }\n27: \n28: export const CATEGORIES: Record<string, TaxonomyCategory> = {\n29:     blue: {\n30:         id: 'blue',\n31:         label: 'BLUEPRINT',\n32:         colour: '#3b82f6',\n33:         bgAlpha: 'rgba(59,130,246,0.10)',\n34:         explanation: 'What the code needs to remember. Like furniture in a house.'\n35:     },\n36:     green: {\n37:         id: 'green',\n38:         label: 'PLUMBING',\n39:         colour: '#10b981',\n40:         bgAlpha: 'rgba(16,185,129,0.10)',\n41:         explanation: 'Bringing things from outside. Like a delivery truck.'\n42:     },\n43:     orange: {\n44:         id: 'orange',\n45:         label: 'TRANSACTION',\n46:         colour: '#f97316',\n47:         bgAlpha: 'rgba(249,115,22,0.10)',\n48:         explanation: 'What the code actually does. Like people cooking and cleaning.'\n49:     },\n50:     red: {\n51:         id: 'red',\n52:         label: 'CONSTRAINT',\n53:         colour: '#ef4444',\n54:         bgAlpha: 'rgba(239,68,68,0.10)',\n55:         explanation: 'Rules that must never be broken. Like locks on doors.'\n56:     },\n57:     purple: {\n58:         id: 'purple',\n59:         label: 'PEDAGOGY',\n60:         colour: '#a855f7',\n61:         bgAlpha: 'rgba(168,85,247,0.10)',\n62:         explanation: 'Notes for yourself later. Like labels on boxes.'\n63:     }\n64: };\n65: \n66: // ─── Simple Python Parser ────────────────────────────────────────────────\n67: \n68: export class PythonParser {\n69:     private lines: string[];\n70:     private indentStack: number[] = [];\n71:     private currentIndent: number = 0;\n72: \n73:     constructor(code: string) {\n74:         this.lines = code.split('\\n');\n75:     }\n76: \n77:     parse(): ASTNode[] {\n78:         const nodes: ASTNode[] = [];\n79:         let i = 0;\n80: \n81:         while (i < this.lines.length) {\n82:             const line = this.lines[i];\n83:             const trimmed = line.trim();\n84: \n85:             // Skip empty lines and comments\n86:             if (trimmed.length === 0 || trimmed.startsWith('#')) {\n87:                 i++;\n88:                 continue;\n89:             }\n90: \n91:             // Calculate indentation\n92:             const indent = line.length - line.trimStart().length;\n93: \n94:             // Update indent stack\n95:             while (this.indentStack.length > 0 && indent <= this.indentStack[this.indentStack.length - 1]) {\n96:                 this.indentStack.pop();\n97:             }\n98: \n99:             // Parse the line\n100:             const node = this.parseLine(trimmed, i, indent);\n101:             if (node) {\n102:                 nodes.push(node);\n103:             }\n104: \n105:             i++;\n106:         }\n107: \n108:         return nodes;\n109:     }\n110: \n111:     private parseLine(line: string, lineNumber: number, indent: number): ASTNode | null {\n112:         // Empty line\n113:         if (line.length === 0) return null;\n114: \n115:         // Comment\n116:         if (line.startsWith('#')) {\n117:             return {\n118:                 type: 'comment',\n119:                 value: line,\n120:                 children: [],\n121:                 startLine: lineNumber,\n122:                 endLine: lineNumber,\n123:                 startCol: 0,\n124:                 endCol: line.length\n125:             };\n126:         }\n127: \n128:         // Docstring\n129:         if (line.startsWith('\"\"\"') || line.startsWith(\"'''\")) {\n130:             return {\n131:                 type: 'docstring',\n132:                 value: line,\n133:                 children: [],\n134:                 startLine: lineNumber,\n135:                 endLine: lineNumber,\n136:                 startCol: 0,\n137:                 endCol: line.length\n138:             };\n139:         }\n140: \n141:         // Import statement\n142:         if (/^(from|import)\\s/.test(line)) {\n143:             return {\n144:                 type: 'import',\n145:                 value: line,\n146:                 children: [],\n147:                 startLine: lineNumber,\n148:                 endLine: lineNumber,\n149:                 startCol: 0,\n150:                 endCol: line.length\n151:             };\n152:         }\n153: \n154:         // Decorator\n155:         if (line.startsWith('@')) {\n156:             return {\n157:                 type: 'decorator',\n158:                 value: line,\n159:                 children: [],\n160:                 startLine: lineNumber,\n161:                 endLine: lineNumber,\n162:                 startCol: 0,\n163:                 endCol: line.length\n164:             };\n165:         }\n166: \n167:         // Class definition\n168:         if (/^class\\s/.test(line)) {\n169:             const match = line.match(/class\\s+(\\w+)/);\n170:             const name = match ? match[1] : 'ClassName';\n171:             return {\n172:                 type: 'class',\n173:                 name: name,\n174:                 value: line,\n175:                 children: [],\n176:                 startLine: lineNumber,\n177:                 endLine: lineNumber,\n178:                 startCol: 0,\n179:                 endCol: line.length\n180:             };\n181:         }\n182: \n183:         // Function definition\n184:         if (/^\\s*(async\\s+)?def\\s/.test(line)) {\n185:             const match = line.match(/def\\s+(\\w+)/);\n186:             const name = match ? match[1] : 'func';\n187:             return {\n188:                 type: 'function',\n189:                 name: name,\n190:                 value: line,\n191:                 children: [],\n192:                 startLine: lineNumber,\n193:                 endLine: lineNumber,\n194:                 startCol: 0,\n195:                 endCol: line.length\n196:             };\n197:         }\n198: \n199:         // Assert or raise\n200:         if (/^\\s*(assert|raise)\\s/.test(line)) {\n201:             return {\n202:                 type: 'constraint',\n203:                 value: line,\n204:                 children: [],\n205:                 startLine: lineNumber,\n206:                 endLine: lineNumber,\n207:                 startCol: 0,\n208:                 endCol: line.length\n209:             };\n210:         }\n211: \n212:         // Control flow\n213:         if (/^\\s*(if|elif|else|for|while|with|try|except|finally)\\b/.test(line)) {\n214:             return {\n215:                 type: 'control',\n216:                 value: line,\n217:                 children: [],\n218:                 startLine: lineNumber,\n219:                 endLine: lineNumber,\n220:                 startCol: 0,\n221:                 endCol: line.length\n222:             };\n223:         }\n224: \n225:         // Return statement\n226:         if (/^\\s*return\\s/.test(line)) {\n227:             return {\n228:                 type: 'return',\n229:                 value: line,\n230:                 children: [],\n231:                 startLine: lineNumber,\n232:                 endLine: lineNumber,\n233:                 startCol: 0,\n234:                 endCol: line.length\n235:             };\n236:         }\n237: \n238:         // Constant assignment (uppercase variable = value)\n239:         if (/^[A-Z][A-Z_0-9]+\\s*=/.test(line)) {\n240:             return {\n241:                 type: 'constant',\n242:                 value: line,\n243:                 children: [],\n244:                 startLine: lineNumber,\n245:                 endLine: lineNumber,\n246:                 startCol: 0,\n247:                 endCol: line.length\n248:             };\n249:         }\n250: \n251:         // Self assignment\n252:         if (/^\\s*self\\.\\w+\\s*=/.test(line)) {\n253:             return {\n254:                 type: 'state',\n255:                 value: line,\n256:                 children: [],\n257:                 startLine: lineNumber,\n258:                 endLine: lineNumber,\n259:                 startCol: 0,\n260:                 endCol: line.length\n261:             };\n262:         }\n263: \n264:         // General assignment\n265:         if (/^\\s*\\w+\\s*=/.test(line)) {\n266:             return {\n267:                 type: 'assignment',\n268:                 value: line,\n269:                 children: [],\n270:                 startLine: lineNumber,\n271:                 endLine: lineNumber,\n272:                 startCol: 0,\n273:                 endCol: line.length\n274:             };\n275:         }\n276: \n277:         // Default: executable statement\n278:         return {\n279:             type: 'statement',\n280:             value: line,\n281:             children: [],\n282:             startLine: lineNumber,\n283:             endLine: lineNumber,\n284:             startCol: 0,\n285:             endCol: line.length\n286:         };\n287:     }\n288: }\n289: \n290: // ─── AST Classifier ──────────────────────────────────────────────────────\n291: \n292: export interface ClassifiedNode {\n293:     category: TaxonomyCategory;\n294:     explanation: string;\n295:     example: string;\n296:     node: ASTNode;\n297: }\n298: \n299: export class ASTClassifier {\n300:     private parseCache: Map<string, ASTNode[]> = new Map();\n301: \n302:     classifyCode(code: string): Map<number, ClassifiedNode> {\n303:         const parser = new PythonParser(code);\n304:         const nodes = parser.parse();\n305:         const result = new Map<number, ClassifiedNode>();\n306: \n307:         for (const node of nodes) {\n308:             const classified = this.classifyNode(node);\n309:             if (classified) {\n310:                 result.set(node.startLine, classified);\n311:             }\n312:         }\n313: \n314:         return result;\n315:     }\n316: \n317:     private classifyNode(node: ASTNode): ClassifiedNode | null {\n318:         switch (node.type) {\n319:             case 'comment':\n320:                 return this.classifyComment(node);\n321:             case 'docstring':\n322:                 return this.classifyDocstring(node);\n323:             case 'import':\n324:                 return this.classifyImport(node);\n325:             case 'decorator':\n326:                 return this.classifyDecorator(node);\n327:             case 'class':\n328:                 return this.classifyClass(node);\n329:             case 'function':\n330:                 return this.classifyFunction(node);\n331:             case 'constraint':\n332:                 return this.classifyConstraint(node);\n333:             case 'control':\n334:                 return this.classifyControl(node);\n335:             case 'return':\n336:                 return this.classifyReturn(node);\n337:             case 'constant':\n338:                 return this.classifyConstant(node);\n339:             case 'state':\n340:                 return this.classifyState(node);\n341:             case 'assignment':\n342:                 return this.classifyAssignment(node);\n343:             case 'statement':\n344:                 return this.classifyStatement(node);\n345:             default:\n346:                 return null;\n347:         }\n348:     }\n349: \n350:     private classifyComment(node: ASTNode): ClassifiedNode {\n351:         const value = node.value || '';\n352:         \n353:         // Check for pedagogy markers\n354:         if (/\\b(wjec|unit\\s*\\d|scaffold|mark|grade|assessment|section\\s*4\\.\\d|criteria|exemplary|competent|exploratory|rad)\\b/i.test(value)) {\n355:             return {\n356:                 category: CATEGORIES.purple,\n357:                 explanation: `Assessment instruction: ${value.replace(/^#\\s*/, '')}`,\n358:                 example: 'Marking criteria: Section 4.3 — OOP',\n359:                 node: node\n360:             };\n361:         }\n362: \n363:         // Regular comment\n364:         return {\n365:             category: CATEGORIES.green,\n366:             explanation: `Comment: ${value.replace(/^#\\s*/, '').substring(0, 80)}`,\n367:             example: '',\n368:             node: node\n369:         };\n370:     }\n371: \n372:     private classifyDocstring(node: ASTNode): ClassifiedNode {\n373:         return {\n374:             category: CATEGORIES.purple,\n375:             explanation: `Docstring: documents the purpose of the function or class below.`,\n376:             example: '',\n377:             node: node\n378:         };\n379:     }\n380: \n381:     private classifyImport(node: ASTNode): ClassifiedNode {\n382:         const value = node.value || '';\n383:         let context = 'External dependency.';\n384:         \n385:         if (/flask|django|fastapi/i.test(value)) {\n386:             context = 'Web framework.';\n387:         } else if (/sqlalchemy|sqlite|psycopg|mysql/i.test(value)) {\n388:             context = 'Database ORM.';\n389:         } else if (/pandas|numpy|matplotlib/i.test(value)) {\n390:             context = 'Data science library.';\n391:         } else if (/dataclasses|typing/i.test(value)) {\n392:             context = 'Type system infrastructure.';\n393:         }\n394: \n395:         return {\n396:             category: CATEGORIES.green,\n397:             explanation: `Import: brings in external infrastructure. ${context}`,\n398:             example: '',\n399:             node: node\n400:         };\n401:     }\n402: \n403:     private classifyDecorator(node: ASTNode): ClassifiedNode {\n404:         const value = node.value || '';\n405:         let context = 'Modifies behaviour of the decorated element.';\n406:         \n407:         if (/dataclass/.test(value)) {\n408:             context = 'Auto-generates __init__, __repr__, __eq__ from fields.';\n409:         } else if (/route/.test(value)) {\n410:             context = 'Maps HTTP endpoint to handler function.';\n411:         } else if (/staticmethod|classmethod/.test(value)) {\n412:             context = 'Changes method invocation semantics.';\n413:         }\n414: \n415:         return {\n416:             category: CATEGORIES.blue,\n417:             explanation: `Decorator: annotation that modifies the class or function below. ${context}`,\n418:             example: '',\n419:             node: node\n420:         };\n421:     }\n422: \n423:     private classifyClass(node: ASTNode): ClassifiedNode {\n424:         const name = node.name || 'ClassName';\n425:         const value = node.value || '';\n426:         const parentMatch = value.match(/\\((.+)\\)/);\n427:         const parent = parentMatch ? parentMatch[1] : '';\n428: \n429:         return {\n430:             category: CATEGORIES.blue,\n431:             explanation: `Defines the ${name} class${parent ? ` (inherits from ${parent})` : ''} — a data structure that describes what an entity IS.`,\n432:             example: `class ${name}:\\n    field: type`,\n433:             node: node\n434:         };\n435:     }\n436: \n437:     private classifyFunction(node: ASTNode): ClassifiedNode {\n438:         const name = node.name || 'func';\n439:         const value = node.value || '';\n440:         \n441:         // Extract return type if present\n442:         const returnTypeMatch = value.match(/->\\s*(\\w+)/);\n443:         const returnType = returnTypeMatch ? returnTypeMatch[1] : '';\n444: \n445:         // Special case for __init__\n446:         if (name === '__init__') {\n447:             return {\n448:                 category: CATEGORIES.orange,\n449:                 explanation: `Constructor: initialises the object's state. This is the BEGINNING of the data flow lifecycle.`,\n450:                 example: 'def __init__(self):\\n    self.state = initial_value',\n451:                 node: node\n452:             };\n453:         }\n454: \n455:         // Classify based on function name\n456:         let context = 'Processes data flow from input to output.';\n457:         \n458:         if (/get|fetch|query|read|list|find|search/i.test(name)) {\n459:             context = 'READ path — retrieves data without mutation.';\n460:         } else if (/add|create|insert|write|save|update|delete|remove|set/i.test(name)) {\n461:             context = 'WRITE path — mutates state.';\n462:         } else if (/validate|check|verify|assert|ensure/i.test(name)) {\n463:             context = 'VALIDATION — checks constraints before execution.';\n464:         } else if (/convert|transform|parse|format|encode|decode/i.test(name)) {\n465:             context = 'TRANSFORM — changes data representation.';\n466:         }\n467: \n468:         return {\n469:             category: CATEGORIES.orange,\n470:             explanation: `Method \"${name}\": ${context}${returnType ? ` Returns ${returnType}.` : ''}`,\n471:             example: '',\n472:             node: node\n473:         };\n474:     }\n475: \n476:     private classifyConstraint(node: ASTNode): ClassifiedNode {\n477:         const value = node.value || '';\n478:         let context = 'Enforcement.';\n479:         \n480:         if (/assert/.test(value)) {\n481:             context = 'Validates a condition. Fails with AssertionError if violated.';\n482:         } else if (/raise/.test(value)) {\n483:             context = 'Raises an exception. Signals a runtime error to the caller.';\n484:         }\n485: \n486:         return {\n487:             category: CATEGORIES.red,\n488:             explanation: `${context} This is a governance checkpoint.`,\n489:             example: 'assert condition, \"Error message\"',\n490:             node: node\n491:         };\n492:     }\n493: \n494:     private classifyControl(node: ASTNode): ClassifiedNode {\n495:         const value = node.value || '';\n496:         let context = 'Control flow.';\n497:         \n498:         if (/if|elif/.test(value)) {\n499:             context = 'Branching — decides which path the data follows.';\n500:         } else if (/for|while/.test(value)) {\n501:             context = 'Iteration — repeats data processing over a collection.';\n502:         } else if (/with/.test(value)) {\n503:             context = 'Context manager — manages resource lifecycle.';\n504:         } else if (/try|except/.test(value)) {\n505:             context = 'Error handling — catches failures in data flow.';\n506:         }\n507: \n508:         return {\n509:             category: CATEGORIES.orange,\n510:             explanation: context,\n511:             example: '',\n512:             node: node\n513:         };\n514:     }\n515: \n516:     private classifyReturn(node: ASTNode): ClassifiedNode {\n517:         return {\n518:             category: CATEGORIES.orange,\n519:             explanation: `Return: sends data back to the caller. This is the OUTPUT path of data flow.`,\n520:             example: '',\n521:             node: node\n522:         };\n523:     }\n524: \n525:     private classifyConstant(node: ASTNode): ClassifiedNode {\n526:         const value = node.value || '';\n527:         const match = value.match(/^([A-Z][A-Z_0-9]+)\\s*=\\s*(.+)/);\n528:         const constName = match ? match[1] : '';\n529:         const constValue = match ? match[2] : '';\n530: \n531:         return {\n532:             category: CATEGORIES.red,\n533:             explanation: `Hard constraint: ${constName} = ${constValue}. This is a governance limit — not logic, not data, but a rule that CANNOT be exceeded.`,\n534:             example: `${constName} = ${constValue}\\n# Enforced with assert or guard clause`,\n535:             node: node\n536:         };\n537:     }\n538: \n539:     private classifyState(node: ASTNode): ClassifiedNode {\n540:         return {\n541:             category: CATEGORIES.orange,\n542:             explanation: `State mutation: writes a value to the object's internal state. The data is being stored for later use.`,\n543:             example: '',\n544:             node: node\n545:         };\n546:     }\n547: \n548:     private classifyAssignment(node: ASTNode): ClassifiedNode {\n549:         const value = node.value || '';\n550:         const match = value.match(/^\\s*(\\w+)/);\n551:         const varName = match ? match[1] : '';\n552: \n553:         // Check if it looks like infrastructure setup\n554:         if (/^(app|db|engine|router|config|settings)/.test(varName)) {\n555:             return {\n556:                 category: CATEGORIES.green,\n557:                 explanation: `Infrastructure setup: initialises ${varName} — a system component that other parts depend on.`,\n558:                 example: '',\n559:                 node: node\n560:             };\n561:         }\n562: \n563:         return {\n564:             category: CATEGORIES.orange,\n565:             explanation: `Assignment: stores a computed value. The data flows from the right-hand expression into the variable.`,\n566:             example: '',\n567:             node: node\n568:         };\n569:     }\n570: \n571:     private classifyStatement(node: ASTNode): ClassifiedNode {\n572:         return {\n573:             category: CATEGORIES.orange,\n574:             explanation: `Executable statement: processes data or controls program flow.`,\n575:             example: '',\n576:             node: node\n577:         };\n578:     }\n579: }\n580: \n581: // ─── Cognitive Load Calculator ──────────────────────────────────────────\n582: \n583: export interface CognitiveLoadMetrics {\n584:     totalLines: number;\n585:     blueprintLines: number;\n586:     plumbingLines: number;\n587:     transactionLines: number;\n588:     constraintLines: number;\n589:     pedagogyLines: number;\n590:     complexityScore: number;\n591:     balanceScore: number;\n592:     overallLoad: 'low' | 'medium' | 'high' | 'critical';\n593: }\n594: \n595: export function calculateCognitiveLoad(classified: Map<number, ClassifiedNode>): CognitiveLoadMetrics {\n596:     const metrics: CognitiveLoadMetrics = {\n597:         totalLines: 0,\n598:         blueprintLines: 0,\n599:         plumbingLines: 0,\n600:         transactionLines: 0,\n601:         constraintLines: 0,\n602:         pedagogyLines: 0,\n603:         complexityScore: 0,\n604:         balanceScore: 0,\n605:         overallLoad: 'low'\n606:     };\n607: \n608:     // Count lines by category\n609:     for (const [, node] of classified) {\n610:         metrics.totalLines++;\n611:         \n612:         switch (node.category.id) {\n613:             case 'blue':\n614:                 metrics.blueprintLines++;\n615:                 break;\n616:             case 'green':\n617:                 metrics.plumbingLines++;\n618:                 break;\n619:             case 'orange':\n620:                 metrics.transactionLines++;\n621:                 break;\n622:             case 'red':\n623:                 metrics.constraintLines++;\n624:                 break;\n625:             case 'purple':\n626:                 metrics.pedagogyLines++;\n627:                 break;\n628:         }\n629:     }\n630: \n631:     // Calculate complexity score (0-100)\n632:     // Based on ratio of transaction lines (orange) to total\n633:     if (metrics.totalLines > 0) {\n634:         const orangeRatio = metrics.transactionLines / metrics.totalLines;\n635:         metrics.complexityScore = Math.round(orangeRatio * 100);\n636:     }\n637: \n638:     // Calculate balance score (0-100)\n639:     // Based on even distribution across categories\n640:     const expectedPerCategory = metrics.totalLines / 5;\n641:     let balanceDeviation = 0;\n642:     \n643:     balanceDeviation += Math.abs(metrics.blueprintLines - expectedPerCategory);\n644:     balanceDeviation += Math.abs(metrics.plumbingLines - expectedPerCategory);\n645:     balanceDeviation += Math.abs(metrics.transactionLines - expectedPerCategory);\n646:     balanceDeviation += Math.abs(metrics.constraintLines - expectedPerCategory);\n647:     balanceDeviation += Math.abs(metrics.pedagogyLines - expectedPerCategory);\n648:     \n649:     if (metrics.totalLines > 0) {\n650:         const maxDeviation = metrics.totalLines * 2; // Maximum possible deviation\n651:         metrics.balanceScore = Math.round((1 - balanceDeviation / maxDeviation) * 100);\n652:     }\n653: \n654:     // Determine overall load\n655:     if (metrics.complexityScore > 80) {\n656:         metrics.overallLoad = 'critical';\n657:     } else if (metrics.complexityScore > 60) {\n658:         metrics.overallLoad = 'high';\n659:     } else if (metrics.complexityScore > 40) {\n660:         metrics.overallLoad = 'medium';\n661:     } else {\n662:         metrics.overallLoad = 'low';\n663:     }\n664: \n665:     return metrics;\n666: }\n\n(End of file - total 666 lines)\n</content>",
