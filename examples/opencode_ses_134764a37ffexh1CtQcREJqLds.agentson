      "type": "action",
      "tool": "read",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\cognitive-taxonomy-proof.html\"}",
      "output": "<path>C:\\Users\\LLM-Test\\Documents\\cognitive-taxonomy-proof.html</path>\n<type>file</type>\n<content>\n1: <!DOCTYPE html>\n2: <html lang=\"en\">\n3: <head>\n4: <meta charset=\"UTF-8\">\n5: <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n6: <title>Cognitive Taxonomy Protocol — Python Proof of Concept</title>\n7: <style>\n8:   :root {\n9:     --blue: #3b82f6;\n10:     --blue-bg: #1e3a5f;\n11:     --green: #10b981;\n12:     --green-bg: #0d3b2e;\n13:     --orange: #f97316;\n14:     --orange-bg: #4a2c0a;\n15:     --red: #ef4444;\n16:     --red-bg: #4a1515;\n17:     --purple: #a855f7;\n18:     --purple-bg: #2d1b4e;\n19:     --bg: #0f0f0f;\n20:     --text: #e0e0e0;\n21:     --muted: #888;\n22:     --border: #2a2a2a;\n23:   }\n24: \n25:   * { margin: 0; padding: 0; box-sizing: border-box; }\n26: \n27:   body {\n28:     background: var(--bg);\n29:     color: var(--text);\n30:     font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n31:     line-height: 1.6;\n32:   }\n33: \n34:   .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }\n35: \n36:   h1 {\n37:     font-size: 2.2rem;\n38:     margin-bottom: 0.5rem;\n39:     background: linear-gradient(135deg, var(--blue), var(--green), var(--orange), var(--red), var(--purple));\n40:     -webkit-background-clip: text;\n41:     -webkit-text-fill-color: transparent;\n42:     background-clip: text;\n43:   }\n44: \n45:   .subtitle {\n46:     color: var(--muted);\n47:     font-size: 1.1rem;\n48:     margin-bottom: 2rem;\n49:   }\n50: \n51:   .section {\n52:     margin-bottom: 3rem;\n53:   }\n54: \n55:   .section h2 {\n56:     font-size: 1.4rem;\n57:     margin-bottom: 1rem;\n58:     padding-bottom: 0.5rem;\n59:     border-bottom: 1px solid var(--border);\n60:   }\n61: \n62:   .section h3 {\n63:     font-size: 1.1rem;\n64:     margin-bottom: 0.75rem;\n65:     color: var(--muted);\n66:   }\n67: \n68:   /* Legend */\n69:   .legend {\n70:     display: flex;\n71:     flex-wrap: wrap;\n72:     gap: 1rem;\n73:     margin-bottom: 2rem;\n74:     padding: 1.5rem;\n75:     background: #1a1a1a;\n76:     border-radius: 8px;\n77:     border: 1px solid var(--border);\n78:   }\n79: \n80:   .legend-item {\n81:     display: flex;\n82:     align-items: center;\n83:     gap: 0.5rem;\n84:     font-size: 0.9rem;\n85:   }\n86: \n87:   .legend-dot {\n88:     width: 14px;\n89:     height: 14px;\n90:     border-radius: 3px;\n91:   }\n92: \n93:   /* Code blocks */\n94:   .code-comparison {\n95:     display: grid;\n96:     grid-template-columns: 1fr 1fr;\n97:     gap: 1.5rem;\n98:     margin-bottom: 2rem;\n99:   }\n100: \n101:   @media (max-width: 768px) {\n102:     .code-comparison { grid-template-columns: 1fr; }\n103:   }\n104: \n105:   .code-panel {\n106:     border-radius: 8px;\n107:     overflow: hidden;\n108:     border: 1px solid var(--border);\n109:   }\n110: \n111:   .code-panel-header {\n112:     padding: 0.75rem 1rem;\n113:     font-size: 0.85rem;\n114:     font-weight: 600;\n115:     text-transform: uppercase;\n116:     letter-spacing: 0.05em;\n117:   }\n118: \n119:   .code-panel-header.traditional {\n120:     background: #1a1a1a;\n121:     color: #888;\n122:   }\n123: \n124:   .code-panel-header.taxonomy {\n125:     background: linear-gradient(135deg, var(--blue-bg), var(--green-bg), var(--orange-bg), var(--red-bg), var(--purple-bg));\n126:     color: #fff;\n127:   }\n128: \n129:   .code-block {\n130:     padding: 1rem;\n131:     font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;\n132:     font-size: 0.82rem;\n133:     line-height: 1.7;\n134:     overflow-x: auto;\n135:     background: #111;\n136:   }\n137: \n138:   .code-block pre {\n139:     margin: 0;\n140:     white-space: pre;\n141:   }\n142: \n143:   /* Traditional syntax highlighting */\n144:   .trad .kw { color: #c586c0; }\n145:   .trad .fn { color: #dcdcaa; }\n146:   .trad .str { color: #ce9178; }\n147:   .trad .num { color: #b5cea8; }\n148:   .trad .cm { color: #6a9955; }\n149:   .trad .cls { color: #4ec9b0; }\n150:   .trad .dec { color: #d7ba7d; }\n151:   .trad .op { color: #d4d4d4; }\n152:   .trad .param { color: #9cdcfe; }\n153: \n154:   /* Taxonomy colouring */\n155:   .tax-blue { background: rgba(59, 130, 246, 0.15); border-left: 3px solid var(--blue); padding-left: 8px; display: block; }\n156:   .tax-green { background: rgba(16, 185, 129, 0.15); border-left: 3px solid var(--green); padding-left: 8px; display: block; }\n157:   .tax-orange { background: rgba(249, 115, 22, 0.15); border-left: 3px solid var(--orange); padding-left: 8px; display: block; }\n158:   .tax-red { background: rgba(239, 68, 68, 0.15); border-left: 3px solid var(--red); padding-left: 8px; display: block; }\n159:   .tax-purple { background: rgba(168, 85, 247, 0.15); border-left: 3px solid var(--purple); padding-left: 8px; display: block; }\n160: \n161:   .tax-blue .tax-label::before { content: \"BLUE \"; color: var(--blue); font-size: 0.7rem; font-weight: 700; }\n162:   .tax-green .tax-label::before { content: \"GREEN \"; color: var(--green); font-size: 0.7rem; font-weight: 700; }\n163:   .tax-orange .tax-label::before { content: \"ORANGE \"; color: var(--orange); font-size: 0.7rem; font-weight: 700; }\n164:   .tax-red .tax-label::before { content: \"RED \"; color: var(--red); font-size: 0.7rem; font-weight: 700; }\n165:   .tax-purple .tax-label::before { content: \"PURPLE \"; color: var(--purple); font-size: 0.7rem; font-weight: 700; }\n166: \n167:   .tax-label {\n168:     display: block;\n169:     margin-bottom: 2px;\n170:   }\n171: \n172:   /* Jupyter notebook */\n173:   .jupyter {\n174:     background: #1a1a1a;\n175:     border-radius: 8px;\n176:     border: 1px solid var(--border);\n177:     overflow: hidden;\n178:   }\n179: \n180:   .jupyter-header {\n181:     padding: 0.75rem 1rem;\n182:     background: #111;\n183:     border-bottom: 1px solid var(--border);\n184:     font-size: 0.85rem;\n185:     color: var(--muted);\n186:     display: flex;\n187:     align-items: center;\n188:     gap: 0.5rem;\n189:   }\n190: \n191:   .jupyter-header .dot { width: 10px; height: 10px; border-radius: 50%; }\n192: \n193:   .jupyter-cell {\n194:     border-bottom: 1px solid var(--border);\n195:     display: flex;\n196:   }\n197: \n198:   .cell-input {\n199:     flex: 1;\n200:     padding: 1rem;\n201:     font-family: 'JetBrains Mono', 'Fira Code', monospace;\n202:     font-size: 0.82rem;\n203:     line-height: 1.7;\n204:     background: #111;\n205:   }\n206: \n207:   .cell-input pre { margin: 0; white-space: pre; }\n208: \n209:   .cell-exec {\n210:     width: 60px;\n211:     display: flex;\n212:     align-items: center;\n213:     justify-content: center;\n214:     font-size: 0.7rem;\n215:     color: var(--muted);\n216:     border-left: 1px solid var(--border);\n217:     background: #0d0d0d;\n218:   }\n219: \n220:   .cell-exec.executed { color: var(--green); }\n221: \n222:   /* Cognitive load meter */\n223:   .load-meter {\n224:     padding: 1.5rem;\n225:     background: #1a1a1a;\n226:     border-radius: 8px;\n227:     border: 1px solid var(--border);\n228:     margin-bottom: 2rem;\n229:   }\n230: \n231:   .load-bar {\n232:     height: 24px;\n233:     background: #222;\n234:     border-radius: 4px;\n235:     overflow: hidden;\n236:     margin-top: 0.75rem;\n237:   }\n238: \n239:   .load-fill {\n240:     height: 100%;\n241:     border-radius: 4px;\n242:     transition: width 0.8s ease;\n243:   }\n244: \n245:   .load-fill.traditional { background: linear-gradient(90deg, #ef4444, #f97316); }\n246:   .load-fill.taxonomy { background: linear-gradient(90deg, #10b981, #3b82f6); }\n247: \n248:   .load-label {\n249:     display: flex;\n250:     justify-content: space-between;\n251:     font-size: 0.85rem;\n252:     color: var(--muted);\n253:   }\n254: \n255:   /* Stats */\n256:   .stats {\n257:     display: grid;\n258:     grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n259:     gap: 1rem;\n260:     margin-bottom: 2rem;\n261:   }\n262: \n263:   .stat-card {\n264:     background: #1a1a1a;\n265:     border-radius: 8px;\n266:     border: 1px solid var(--border);\n267:     padding: 1.5rem;\n268:     text-align: center;\n269:   }\n270: \n271:   .stat-value {\n272:     font-size: 2rem;\n273:     font-weight: 700;\n274:     margin-bottom: 0.25rem;\n275:   }\n276: \n277:   .stat-value.blue { color: var(--blue); }\n278:   .stat-value.green { color: var(--green); }\n279:   .stat-value.orange { color: var(--orange); }\n280:   .stat-value.red { color: var(--red); }\n281:   .stat-value.purple { color: var(--purple); }\n282: \n283:   .stat-label {\n284:     font-size: 0.85rem;\n285:     color: var(--muted);\n286:   }\n287: \n288:   /* References */\n289:   .refs {\n290:     background: #1a1a1a;\n291:     border-radius: 8px;\n292:     border: 1px solid var(--border);\n293:     padding: 1.5rem;\n294:   }\n295: \n296:   .refs h3 { margin-bottom: 1rem; }\n297:   .refs ol { padding-left: 1.5rem; }\n298:   .refs li { margin-bottom: 0.5rem; font-size: 0.9rem; color: var(--muted); }\n299:   .refs cite { color: var(--text); font-style: normal; }\n300: \n301:   /* Toggle */\n302:   .toggle-container {\n303:     display: flex;\n304:     align-items: center;\n305:     gap: 1rem;\n306:     margin-bottom: 1.5rem;\n307:     padding: 1rem;\n308:     background: #1a1a1a;\n309:     border-radius: 8px;\n310:     border: 1px solid var(--border);\n311:   }\n312: \n313:   .toggle {\n314:     position: relative;\n315:     width: 50px;\n316:     height: 26px;\n317:     background: #333;\n318:     border-radius: 13px;\n319:     cursor: pointer;\n320:     transition: background 0.3s;\n321:   }\n322: \n323:   .toggle.active { background: var(--green); }\n324: \n325:   .toggle-knob {\n326:     position: absolute;\n327:     top: 3px;\n328:     left: 3px;\n329:     width: 20px;\n330:     height: 20px;\n331:     background: #fff;\n332:     border-radius: 50%;\n333:     transition: transform 0.3s;\n334:   }\n335: \n336:   .toggle.active .toggle-knob { transform: translateX(24px); }\n337: \n338:   .toggle-label { font-size: 0.9rem; }\n339: \n340:   /* Interactive cell highlight */\n341:   .jupyter-cell:hover { background: rgba(255,255,255,0.02); }\n342: \n343:   .cell-type-badge {\n344:     display: inline-block;\n345:     padding: 2px 8px;\n346:     border-radius: 3px;\n347:     font-size: 0.7rem;\n348:     font-weight: 600;\n349:     margin-left: 0.5rem;\n350:   }\n351: \n352:   .badge-blue { background: rgba(59,130,246,0.2); color: var(--blue); }\n353:   .badge-green { background: rgba(16,185,129,0.2); color: var(--green); }\n354:   .badge-orange { background: rgba(249,115,22,0.2); color: var(--orange); }\n355:   .badge-red { background: rgba(239,68,68,0.2); color: var(--red); }\n356:   .badge-purple { background: rgba(168,85,247,0.2); color: var(--purple); }\n357: </style>\n358: </head>\n359: <body>\n360: \n361: <div class=\"container\">\n362:   <h1>Cognitive Taxonomy Protocol</h1>\n363:   <p class=\"subtitle\">A five-colour architectural taxonomy that shifts code comprehension from System 2 (linear reading) to System 1 (spatial pattern recognition). Applied to Python and Jupyter notebooks.</p>\n364: \n365:   <!-- Legend -->\n366:   <div class=\"section\">\n367:     <h2>The Five-Colour Standard</h2>\n368:     <div class=\"legend\">\n369:       <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background: var(--blue);\"></div> <strong>Blueprint</strong> — What are we building?</div>\n370:       <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background: var(--green);\"></div> <strong>Plumbing</strong> — How does it connect?</div>\n371:       <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background: var(--orange);\"></div> <strong>Transaction</strong> — How does data flow?</div>\n372:       <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background: var(--red);\"></div> <strong>Core Protocol</strong> — What are the hard constraints?</div>\n373:       <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background: var(--purple);\"></div> <strong>Pedagogy</strong> — How is this assessed?</div>\n374:     </div>\n375:   </div>\n376: \n377:   <!-- Example 1: Python Class -->\n378:   <div class=\"section\">\n379:     <h2>Example 1: Python Class — Bookshop Inventory</h2>\n380: \n381:     <div class=\"code-comparison\">\n382:       <div class=\"code-panel\">\n383:         <div class=\"code-panel-header traditional\">Traditional Syntax Highlighting</div>\n384:         <div class=\"code-block\">\n385: <pre class=\"trad\"><span class=\"kw\">from</span> <span class=\"fn\">dataclasses</span> <span class=\"kw\">import</span> dataclass\n386: <span class=\"kw\">from</span> <span class=\"fn\">typing</span> <span class=\"kw\">import</span> List, Optional\n387: \n388: <span class=\"dec\">@dataclass</span>\n389: <span class=\"kw\">class</span> <span class=\"cls\">Book</span>:\n390:     <span class=\"param\">title</span>: <span class=\"cls\">str</span>\n391:     <span class=\"param\">author</span>: <span class=\"cls\">str</span>\n392:     <span class=\"param\">price</span>: <span class=\"cls\">float</span>\n393:     <span class=\"param\">stock</span>: <span class=\"cls\">int</span>\n394: \n395: <span class=\"kw\">class</span> <span class=\"cls\">Inventory</span>:\n396:     <span class=\"kw\">MAX_ITEMS</span> = <span class=\"num\">1000</span>\n397: \n398:     <span class=\"kw\">def</span> <span class=\"fn\">__init__</span>(<span class=\"param\">self</span>):\n399:         <span class=\"param\">self</span>.<span class=\"param\">books</span>: List[<span class=\"cls\">Book</span>] = []\n400: \n401:     <span class=\"kw\">def</span> <span class=\"fn\">add_book</span>(<span class=\"param\">self</span>, <span class=\"param\">book</span>: <span class=\"cls\">Book</span>) -> <span class=\"cls\">bool</span>:\n402:         <span class=\"kw\">if</span> <span class=\"fn\">len</span>(<span class=\"param\">self</span>.<span class=\"param\">books</span>) >= <span class=\"kw\">self</span>.<span class=\"kw\">MAX_ITEMS</span>:\n403:             <span class=\"kw\">return</span> <span class=\"num\">False</span>\n404:         <span class=\"param\">self</span>.<span class=\"param\">books</span>.<span class=\"fn\">append</span>(<span class=\"param\">book</span>)\n405:         <span class=\"kw\">return</span> <span class=\"num\">True</span>\n406: \n407:     <span class=\"kw\">def</span> <span class=\"fn\">get_by_author</span>(<span class=\"param\">self</span>, <span class=\"param\">author</span>: <span class=\"cls\">str</span>) -> List[<span class=\"cls\">Book</span>]:\n408:         <span class=\"kw\">return</span> [<span class=\"param\">b</span> <span class=\"kw\">for</span> <span class=\"param\">b</span> <span class=\"kw\">in</span> <span class=\"param\">self</span>.<span class=\"param\">books</span> <span class=\"kw\">if</span> <span class=\"param\">b</span>.<span class=\"param\">author</span> == <span class=\"param\">author</span>]</pre>\n409:         </div>\n410:       </div>\n411: \n412:       <div class=\"code-panel\">\n413:         <div class=\"code-panel-header taxonomy\">Cognitive Taxonomy Protocol</div>\n414:         <div class=\"code-block\">\n415: <pre><span class=\"tax-green\"><span class=\"tax-label\"></span><span style=\"color:#6a9955\">from dataclasses import dataclass</span>\n416: <span style=\"color:#6a9955\">from typing import List, Optional</span></span>\n417: <span class=\"tax-purple\"><span class=\"tax-label\"></span><span style=\"color:#ce9178\"># WJEC Unit 4: Students must define at least two classes</span>\n418: <span style=\"color:#ce9178\"># Scaffold: exemplary — student can extend independently</span></span>\n419: <span class=\"tax-blue\"><span class=\"tax-label\"></span><span style=\"color:#4ec9b0\">@dataclass</span>\n420: <span style=\"color:#4ec9b0\">class Book:</span>\n421: <span style=\"color:#4ec9b0\">    title: str</span>\n422: <span style=\"color:#4ec9b0\">    author: str</span>\n423: <span style=\"color:#4ec9b0\">    price: float</span>\n424: <span style=\"color:#4ec9b0\">    stock: int</span></span>\n425: <span class=\"tax-blue\"><span class=\"tax-label\"></span><span style=\"color:#4ec9b0\">class Inventory:</span></span>\n426: <span class=\"tax-red\"><span class=\"tax-label\"></span>    <span style=\"color:#b5cea8\">MAX_ITEMS = 1000</span></span>\n427: <span class=\"tax-orange\"><span class=\"tax-label\"></span>    <span style=\"color:#c586c0\">def</span> <span style=\"color:#dcdcaa\">__init__</span>(<span style=\"color:#9cdcfe\">self</span>):\n428:         <span style=\"color:#9cdcfe\">self</span>.<span style=\"color:#9cdcfe\">books</span>: List[Book] = []</span>\n429: <span class=\"tax-orange\"><span class=\"tax-label\"></span>    <span style=\"color:#c586c0\">def</span> <span style=\"color:#dcdcaa\">add_book</span>(<span style=\"color:#9cdcfe\">self</span>, <span style=\"color:#9cdcfe\">book</span>: Book) -> bool:\n430:         <span style=\"color:#c586c0\">if</span> <span style=\"color:#dcdcaa\">len</span>(<span style=\"color:#9cdcfe\">self</span>.<span style=\"color:#9cdcfe\">books</span>) >= <span style=\"color:#9cdcfe\">self</span>.MAX_ITEMS:\n431:             <span style=\"color:#c586c0\">return</span> False\n432:         <span style=\"color:#9cdcfe\">self</span>.<span style=\"color:#9cdcfe\">books</span>.<span style=\"color:#dcdcaa\">append</span>(<span style=\"color:#9cdcfe\">book</span>)\n433:         <span style=\"color:#c586c0\">return</span> True</span>\n434: <span class=\"tax-orange\"><span class=\"tax-label\"></span>    <span style=\"color:#c586c0\">def</span> <span style=\"color:#dcdcaa\">get_by_author</span>(<span style=\"color:#9cdcfe\">self</span>, <span style=\"color:#9cdcfe\">author</span>: str) -> List[Book]:\n435:         <span style=\"color:#c586c0\">return</span> [<span style=\"color:#9cdcfe\">b</span> <span style=\"color:#c586c0\">for</span> <span style=\"color:#9cdcfe\">b</span> <span style=\"color:#c586c0\">in</span> <span style=\"color:#9cdcfe\">self</span>.<span style=\"color:#9cdcfe\">books</span> <span style=\"color:#c586c0\">if</span> <span style=\"color:#9cdcfe\">b</span>.<span style=\"color:#9cdcfe\">author</span> == <span style=\"color:#9cdcfe\">author</span>]</span></pre>\n436:         </div>\n437:       </div>\n438:     </div>\n439: \n440:     <p style=\"color: var(--muted); font-size: 0.9rem;\">Left: 6+ colours for lexical tokens (keywords, strings, variables). Right: 5 colours for <strong>architectural meaning</strong>. The blue block is immediately recognisable as \"what we're building.\" The orange block is immediately recognisable as \"how data flows.\" You don't read the text — you see the pattern.</p>\n441:   </div>\n442: \n443:   <!-- Cognitive Load Meter -->\n444:   <div class=\"section\">\n445:     <h2>Cognitive Load Comparison</h2>\n446:     <div class=\"load-meter\">\n447:       <div class=\"load-label\"><span>Traditional Syntax Highlighting</span><span>System 2 (linear reading)</span></div>\n448:       <div class=\"load-bar\"><div class=\"load-fill traditional\" style=\"width: 78%;\"></div></div>\n449:     </div>\n450:     <div class=\"load-meter\">\n451:       <div class=\"load-label\"><span>Cognitive Taxonomy Protocol</span><span>System 1 (pattern recognition)</span></div>\n452:       <div class=\"load-bar\"><div class=\"load-fill taxonomy\" style=\"width: 35%;\"></div></div>\n453:     </div>\n454:     <p style=\"color: var(--muted); font-size: 0.85rem; margin-top: 0.75rem;\">Estimated cognitive load based on Asenov et al. (2016) findings: richer visualizations reduce comprehension time by up to 75%. The 5-colour taxonomy reduces the number of visual categories from 8-12 (traditional) to exactly 5, staying within Miller's 7±2 working memory limit.</p>\n455:   </div>\n456: \n457:   <!-- Stats -->\n458:   <div class=\"section\">\n459:     <h2>Category Distribution — Example 1</h2>\n460:     <div class=\"stats\">\n461:       <div class=\"stat-card\">\n462:         <div class=\"stat-value blue\">18%</div>\n463:         <div class=\"stat-label\">Blueprint (Blue)</div>\n464:       </div>\n465:       <div class=\"stat-card\">\n466:         <div class=\"stat-value green\">12%</div>\n467:         <div class=\"stat-label\">Plumbing (Green)</div>\n468:       </div>\n469:       <div class=\"stat-card\">\n470:         <div class=\"stat-value orange\">45%</div>\n471:         <div class=\"stat-label\">Transaction (Orange)</div>\n472:       </div>\n473:       <div class=\"stat-card\">\n474:         <div class=\"stat-value red\">6%</div>\n475:         <div class=\"stat-label\">Core Protocol (Red)</div>\n476:       </div>\n477:       <div class=\"stat-card\">\n478:         <div class=\"stat-value purple\">6%</div>\n479:         <div class=\"stat-label\">Pedagogy (Purple)</div>\n480:       </div>\n481:     </div>\n482:   </div>\n483: \n484:   <!-- Example 2: Jupyter Notebook -->\n485:   <div class=\"section\">\n486:     <h2>Example 2: Jupyter Notebook — Data Analysis</h2>\n487: \n488:     <div class=\"jupyter\">\n489:       <div class=\"jupyter-header\">\n490:         <div class=\"dot\" style=\"background: #f97316;\"></div>\n491:         bookshop_analysis.ipynb\n492:         <span style=\"margin-left: auto; font-size: 0.75rem;\">Python 3 (ipykernel)</span>\n493:       </div>\n494: \n495:       <!-- Cell 1: Imports -->\n496:       <div class=\"jupyter-cell\">\n497:         <div class=\"cell-input\" style=\"border-left: 3px solid var(--green);\">\n498: <pre><span style=\"color:#6a9955\"># Cell 1: Setup</span>\n499: <span style=\"color:#c586c0\">import</span> <span style=\"color:#dcdcaa\">pandas</span> <span style=\"color:#c586c0\">as</span> <span style=\"color:#dcdcaa\">pd</span>\n500: <span style=\"color:#c586c0\">import</span> <span style=\"color:#dcdcaa\">matplotlib.pyplot</span> <span style=\"color:#c586c0\">as</span> <span style=\"color:#dcdcaa\">plt</span>\n501: <span style=\"color:#c586c0\">from</span> <span style=\"color:#dcdcaa\">sqlalchemy</span> <span style=\"color:#c586c0\">import</span> <span style=\"color:#dcdcaa\">create_engine</span>\n502: \n503: <span style=\"color:#9cdcfe\">engine</span> = <span style=\"color:#dcdcaa\">create_engine</span>(<span style=\"color:#ce9178\">\"sqlite:///bookshop.db\"</span>)</pre>\n504:         </div>\n505:         <div class=\"cell-exec executed\">In [1]</div>\n506:       </div>\n507: \n508:       <!-- Cell 2: Blueprint -->\n509:       <div class=\"jupyter-cell\">\n510:         <div class=\"cell-input\" style=\"border-left: 3px solid var(--blue);\">\n511: <pre><span style=\"color:#6a9955\"># Cell 2: Schema Definition</span>\n512: <span style=\"color:#c586c0\">class</span> <span style=\"color:#4ec9b0\">BookRecord</span>:\n513:     <span style=\"color:#c586c0\">def</span> <span style=\"color:#dcdcaa\">__init__</span>(<span style=\"color:#9cdcfe\">self</span>, <span style=\"color:#9cdcfe\">title</span>, <span style=\"color:#9cdcfe\">author</span>, <span style=\"color:#9cdcfe\">price</span>, <span style=\"color:#9cdcfe\">sold</span>):\n514:         <span style=\"color:#9cdcfe\">self</span>.title = <span style=\"color:#9cdcfe\">title</span>\n515:         <span style=\"color:#9cdcfe\">self</span>.author = <span style=\"color:#9cdcfe\">author</span>\n516:         <span style=\"color:#9cdcfe\">self</span>.price = <span style=\"color:#9cdcfe\">price</span>\n517:         <span style=\"color:#9cdcfe\">self</span>.sold = <span style=\"color:#9cdcfe\">sold</span>\n518: \n519: <span style=\"color:#6a9955\"># Column types for the database</span>\n520: <span style=\"color:#9cdcfe\">COLUMNS</span> = {<span style=\"color:#ce9178\">\"title\"</span>: <span style=\"color:#4ec9b0\">str</span>, <span style=\"color:#ce9178\">\"author\"</span>: <span style=\"color:#4ec9b0\">str</span>, <span style=\"color:#ce9178\">\"price\"</span>: <span style=\"color:#4ec9b0\">float</span>, <span style=\"color:#ce9178\">\"sold\"</span>: <span style=\"color:#4ec9b0\">int</span>}</pre>\n521:         </div>\n522:         <div class=\"cell-exec executed\">In [2]</div>\n523:       </div>\n524: \n525:       <!-- Cell 3: Transaction -->\n526:       <div class=\"jupyter-cell\">\n527:         <div class=\"cell-input\" style=\"border-left: 3px solid var(--orange);\">\n528: <pre><span style=\"color:#6a9955\"># Cell 3: Query and Transform</span>\n529: <span style=\"color:#9cdcfe\">df</span> = <span style=\"color:#dcdcaa\">pd.read_sql</span>(<span style=\"color:#ce9178\">\"SELECT * FROM books\"</span>, <span style=\"color:#9cdcfe\">engine</span>)\n530: <span style=\"color:#9cdcfe\">df</span>[<span style=\"color:#ce9178\">\"revenue\"</span>] = <span style=\"color:#9cdcfe\">df</span>.price * <span style=\"color:#9cdcfe\">df</span>.sold\n531: <span style=\"color:#9cdcfe\">top_authors</span> = <span style=\"color:#9cdcfe\">df</span>.<span style=\"color:#dcdcaa\">groupby</span>(<span style=\"color:#ce9178\">\"author\"</span>).revenue.<span style=\"color:#dcdcaa\">sum</span>().<span style=\"color:#dcdcaa\">nlargest</span>(<span style=\"color:#b5cea8\">5</span>)</pre>\n532:         </div>\n533:         <div class=\"cell-exec executed\">In [3]</div>\n534:       </div>\n535: \n536:       <!-- Cell 4: Transaction (visualisation) -->\n537:       <div class=\"jupyter-cell\">\n538:         <div class=\"cell-input\" style=\"border-left: 3px solid var(--orange);\">\n539: <pre><span style=\"color:#6a9955\"># Cell 4: Visualise</span>\n540: <span style=\"color:#9cdcfe\">top_authors</span>.<span style=\"color:#dcdcaa\">plot</span>(<span style=\"color:#9cdcfe\">kind</span>=<span style=\"color:#ce9178\">\"barh\"</span>, <span style=\"color:#9cdcfe\">figsize</span>=(<span style=\"color:#b5cea8\">10</span>, <span style=\"color:#b5cea8\">6</span>))\n541: <span style=\"color:#dcdcaa\">plt.title</span>(<span style=\"color:#ce9178\">\"Top 5 Authors by Revenue\"</span>)\n542: <span style=\"color:#dcdcaa\">plt.xlabel</span>(<span style=\"color:#ce9178\">\"Revenue (£)\"</span>)\n543: <span style=\"color:#dcdcaa\">plt.tight_layout</span>()\n544: <span style=\"color:#dcdcaa\">plt.show</span>()</pre>\n545:         </div>\n546:         <div class=\"cell-exec executed\">In [4]</div>\n547:       </div>\n548: \n549:       <!-- Cell 5: Core Protocol -->\n550:       <div class=\"jupyter-cell\">\n551:         <div class=\"cell-input\" style=\"border-left: 3px solid var(--red);\">\n552: <pre><span style=\"color:#6a9955\"># Cell 5: Budget Governance</span>\n553: <span style=\"color:#b5cea8\">MAX_QUERY_TIME</span> = <span style=\"color:#b5cea8\">5.0</span>  <span style=\"color:#6a9955\"># seconds</span>\n554: <span style=\"color:#b5cea8\">MAX_ROWS</span> = <span style=\"color:#b5cea8\">10000</span>\n555: <span style=\"color:#b5cea8\">COST_PER_QUERY</span> = <span style=\"color:#b5cea8\">0.002</span>  <span style=\"color:#6a9955\"># £</span>\n556: \n557: <span style=\"color:#c586c0\">assert</span> <span style=\"color:#dcdcaa\">len</span>(<span style=\"color:#9cdcfe\">df</span>) <= <span style=\"color:#b5cea8\">MAX_ROWS</span>, <span style=\"color:#ce9178\">\"Query exceeds row limit\"</span></pre>\n558:         </div>\n559:         <div class=\"cell-exec executed\">In [5]</div>\n560:       </div>\n561: \n562:       <!-- Cell 6: Pedagogy -->\n563:       <div class=\"jupyter-cell\">\n564:         <div class=\"cell-input\" style=\"border-left: 3px solid var(--purple);\">\n565: <pre><span style=\"color:#6a9955\"># %% [markdown]</span>\n566: <span style=\"color:#ce9178\"># Assessment Notes</span>\n567: <span style=\"color:#ce9178\">## WJEC Unit 4 — Section 4.2 (SQL DDL)</span>\n568: <span style=\"color:#ce9178\">- **Scaffold level**: exemplary</span>\n569: <span style=\"color:#ce9178\">- **Marks awarded for**: correct JOIN, WHERE clause, aggregation</span>\n570: <span style=\"color:#ce9178\">- **Evidence**: This notebook demonstrates data retrieval</span>\n571: <span style=\"color:#ce9178\">  and transformation using pandas + SQLAlchemy</span></pre>\n572:         </div>\n573:         <div class=\"cell-exec\">In [6]</div>\n574:       </div>\n575:     </div>\n576: \n577:     <p style=\"color: var(--muted); font-size: 0.9rem; margin-top: 1rem;\">Each cell has a colour-coded border: green (plumbing), blue (blueprint), orange (transaction), red (core protocol), purple (pedagogy). At a glance, you see: \"setup → define → query → visualise → govern → assess.\" You never need to read the code to understand the architecture.</p>\n578:   </div>\n579: \n580:   <!-- Example 3: Flask API -->\n581:   <div class=\"section\">\n582:     <h2>Example 3: Flask API — Full Stack</h2>\n583: \n584:     <div class=\"code-comparison\">\n585:       <div class=\"code-panel\">\n586:         <div class=\"code-panel-header traditional\">Traditional</div>\n587:         <div class=\"code-block\">\n588: <pre class=\"trad\"><span class=\"kw\">from</span> <span class=\"fn\">flask</span> <span class=\"kw\">import</span> Flask, jsonify, request\n589: <span class=\"kw\">from</span> <span class=\"fn\">flask_sqlalchemy</span> <span class=\"kw\">import</span> SQLAlchemy\n590: \n591: <span class=\"param\">app</span> = <span class=\"cls\">Flask</span>(<span class=\"param\">__name__</span>)\n592: <span class=\"param\">app</span>.config[<span class=\"str\">\"SQLALCHEMY_DATABASE_URI\"</span>] = <span class=\"str\">\"sqlite:///books.db\"</span>\n593: <span class=\"param\">db</span> = <span class=\"cls\">SQLAlchemy</span>(<span class=\"param\">app</span>)\n594: \n595: <span class=\"kw\">class</span> <span class=\"cls\">Book</span>(<span class=\"param\">db</span>.Model):\n596:     <span class=\"param\">id</span> = <span class=\"param\">db</span>.Column(<span class=\"cls\">db.Integer</span>, primary_key=<span class=\"num\">True</span>)\n597:     <span class=\"param\">title</span> = <span class=\"param\">db</span>.Column(<span class=\"cls\">db.String</span>(<span class=\"num\">100</span>))\n598:     <span class=\"param\">price</span> = <span class=\"param\">db</span>.Column(<span class=\"cls\">db.Float</span>)\n599: \n600: <span class=\"kw\">@</span><span class=\"param\">app</span>.<span class=\"fn\">route</span>(<span class=\"str\">\"/api/books\"</span>)\n601: <span class=\"kw\">def</span> <span class=\"fn\">get_books</span>():\n602:     <span class=\"param\">books</span> = <span class=\"cls\">Book</span>.<span class=\"fn\">query</span>.<span class=\"fn\">all</span>()\n603:     <span class=\"kw\">return</span> <span class=\"fn\">jsonify</span>([{\n604:         <span class=\"str\">\"title\"</span>: <span class=\"param\">b</span>.title,\n605:         <span class=\"str\">\"price\"</span>: <span class=\"param\">b</span>.price\n606:     } <span class=\"kw\">for</span> <span class=\"param\">b</span> <span class=\"kw\">in</span> <span class=\"param\">books</span>])\n607: \n608: <span class=\"kw\">@</span><span class=\"param\">app</span>.<span class=\"fn\">route</span>(<span class=\"str\">\"/api/books\"</span>, methods=[<span class=\"str\">\"POST\"</span>])\n609: <span class=\"kw\">def</span> <span class=\"fn\">add_book</span>():\n610:     <span class=\"param\">data</span> = <span class=\"param\">request</span>.<span class=\"fn\">get_json</span>()\n611:     <span class=\"param\">book</span> = <span class=\"cls\">Book</span>(title=<span class=\"param\">data</span>[<span class=\"str\">\"title\"</span>], price=<span class=\"param\">data</span>[<span class=\"str\">\"price\"</span>])\n612:     <span class=\"param\">db</span>.session.<span class=\"fn\">add</span>(<span class=\"param\">book</span>)\n613:     <span class=\"param\">db</span>.session.<span class=\"fn\">commit</span>()\n614:     <span class=\"kw\">return</span> <span class=\"fn\">jsonify</span>({<span class=\"str\">\"ok\"</span>: <span class=\"num\">True</span>})</pre>\n615:         </div>\n616:       </div>\n617: \n618:       <div class=\"code-panel\">\n619:         <div class=\"code-panel-header taxonomy\">Taxonomy</div>\n620:         <div class=\"code-block\">\n621: <pre><span class=\"tax-green\"><span class=\"tax-label\"></span><span style=\"color:#6a9955\">from flask import Flask, jsonify, request</span>\n622: <span style=\"color:#6a9955\">from flask_sqlalchemy import SQLAlchemy</span>\n623: \n624: <span style=\"color:#6a9955\">app</span> = <span style=\"color:#4ec9b0\">Flask</span>(__name__)\n625: <span style=\"color:#6a9955\">app.config[\"SQLALCHEMY_DATABASE_URI\"] = \"sqlite:///books.db\"</span>\n626: <span style=\"color:#6a9955\">db = <span style=\"color:#4ec9b0\">SQLAlchemy</span>(app)</span></span>\n627: \n628: <span class=\"tax-blue\"><span class=\"tax-label\"></span><span style=\"color:#c586c0\">class</span> <span style=\"color:#4ec9b0\">Book</span>(db.Model):\n629:     <span style=\"color:#9cdcfe\">id</span> = db.Column(db.Integer, primary_key=True)\n630:     <span style=\"color:#9cdcfe\">title</span> = db.Column(db.String(100))\n631:     <span style=\"color:#9cdcfe\">price</span> = db.Column(db.Float)</span>\n632: \n633: <span class=\"tax-orange\"><span class=\"tax-label\"></span><span style=\"color:#c586c0\">@</span><span style=\"color:#9cdcfe\">app</span>.<span style=\"color:#dcdcaa\">route</span>(\"/api/books\")\n634: <span style=\"color:#c586c0\">def</span> <span style=\"color:#dcdcaa\">get_books</span>():\n635:     <span style=\"color:#9cdcfe\">books</span> = Book.query.all()\n636:     <span style=\"color:#c586c0\">return</span> jsonify([{\n637:         \"title\": <span style=\"color:#9cdcfe\">b</span>.title,\n638:         \"price\": <span style=\"color:#9cdcfe\">b</span>.price\n639:     } <span style=\"color:#c586c0\">for</span> <span style=\"color:#9cdcfe\">b</span> <span style=\"color:#c586c0\">in</span> <span style=\"color:#9cdcfe\">books</span>])</span>\n640: \n641: <span class=\"tax-orange\"><span class=\"tax-label\"></span><span style=\"color:#c586c0\">@</span><span style=\"color:#9cdcfe\">app</span>.<span style=\"color:#dcdcaa\">route</span>(\"/api/books\", methods=[\"POST\"])\n642: <span style=\"color:#c586c0\">def</span> <span style=\"color:#dcdcaa\">add_book</span>():\n643:     <span style=\"color:#9cdcfe\">data</span> = request.get_json()\n644:     <span style=\"color:#9cdcfe\">book</span> = Book(title=data[\"title\"], price=data[\"price\"])\n645:     db.session.add(<span style=\"color:#9cdcfe\">book</span>)\n646:     db.session.commit()\n647:     <span style=\"color:#c586c0\">return</span> jsonify({\"ok\": True})</span></pre>\n648:         </div>\n649:       </div>\n650:     </div>\n651:   </div>\n652: \n653:   <!-- Interactive Toggle Demo -->\n654:   <div class=\"section\">\n655:     <h2>Interactive: Toggle Between Views</h2>\n656: \n657:     <div class=\"toggle-container\">\n658:       <div class=\"toggle\" id=\"toggle\" onclick=\"toggleView()\">\n659:         <div class=\"toggle-knob\"></div>\n660:       </div>\n661:       <span class=\"toggle-label\" id=\"toggleLabel\">Traditional Syntax Highlighting</span>\n662:     </div>\n663: \n664:     <div class=\"code-comparison\">\n665:       <div class=\"code-panel\" style=\"grid-column: 1 / -1;\">\n666:         <div class=\"code-block\" id=\"interactiveCode\">\n667: <pre id=\"codeTraditional\"><span class=\"trad\"><span class=\"kw\">import</span> <span class=\"fn\">sqlite3</span>\n668: <span class=\"kw\">from</span> <span class=\"fn\">flask</span> <span class=\"kw\">import</span> Flask, request, jsonify\n669: \n670: <span class=\"param\">app</span> = <span class=\"cls\">Flask</span>(<span class=\"param\">__name__</span>)\n671: <span class=\"param\">DB_PATH</span> = <span class=\"str\">\"bookshop.db\"</span>\n672: <span class=\"param\">MAX_CONNECTIONS</span> = <span class=\"num\">10</span>\n673: \n674: <span class=\"kw\">class</span> <span class=\"cls\">Database</span>:\n675:     <span class=\"kw\">def</span> <span class=\"fn\">__init__</span>(<span class=\"param\">self</span>, <span class=\"param\">path</span>: <span class=\"cls\">str</span>):\n676:         <span class=\"param\">self</span>.<span class=\"param\">path</span> = <span class=\"param\">path</span>\n677: \n678:     <span class=\"kw\">def</span> <span class=\"fn\">connect</span>(<span class=\"param\">self</span>):\n679:         <span class=\"kw\">return</span> <span class=\"fn\">sqlite3</span>.<span class=\"fn\">connect</span>(<span class=\"param\">self</span>.<span class=\"param\">path</span>)\n680: \n681: <span class=\"param\">db</span> = <span class=\"cls\">Database</span>(<span class=\"param\">DB_PATH</span>)\n682: \n683: <span class=\"kw\">@</span><span class=\"param\">app</span>.<span class=\"fn\">route</span>(<span class=\"str\">\"/books\"</span>)\n684: <span class=\"kw\">def</span> <span class=\"fn\">list_books</span>():\n685:     <span class=\"param\">conn</span> = <span class=\"param\">db</span>.<span class=\"fn\">connect</span>()\n686:     <span class=\"param\">rows</span> = <span class=\"param\">conn</span>.<span class=\"fn\">execute</span>(<span class=\"str\">\"SELECT * FROM books\"</span>).<span class=\"fn\">fetchall</span>()\n687:     <span class=\"param\">conn</span>.<span class=\"fn\">close</span>()\n688:     <span class=\"kw\">return</span> <span class=\"fn\">jsonify</span>(<span class=\"param\">rows</span>)\n689: \n690: <span class=\"kw\">@</span><span class=\"param\">app</span>.<span class=\"fn\">route</span>(<span class=\"str\">\"/books\"</span>, methods=[<span class=\"str\">\"POST\"</span>])\n691: <span class=\"kw\">def</span> <span class=\"fn\">create_book</span>():\n692:     <span class=\"param\">data</span> = <span class=\"param\">request</span>.<span class=\"fn\">get_json</span>()\n693:     <span class=\"param\">conn</span> = <span class=\"param\">db</span>.<span class=\"fn\">connect</span>()\n694:     <span class=\"param\">conn</span>.<span class=\"fn\">execute</span>(\n695:         <span class=\"str\">\"INSERT INTO books (title, price) VALUES (?, ?)\"</span>,\n696:         (<span class=\"param\">data</span>[<span class=\"str\">\"title\"</span>], <span class=\"param\">data</span>[<span class=\"str\">\"price\"</span>])\n697:     )\n698:     <span class=\"param\">conn</span>.<span class=\"fn\">commit</span>()\n699:     <span class=\"param\">conn</span>.<span class=\"fn\">close</span>()\n700:     <span class=\"kw\">return</span> <span class=\"fn\">jsonify</span>({<span class=\"str\">\"ok\"</span>: <span class=\"num\">True</span>})</span></pre>\n701: \n702: <pre id=\"codeTaxonomy\" style=\"display:none;\"><span class=\"tax-green\"><span class=\"tax-label\"></span><span style=\"color:#6a9955\">import sqlite3</span>\n703: <span style=\"color:#6a9955\">from flask import Flask, request, jsonify</span>\n704: \n705: <span style=\"color:#6a9955\">app</span> = <span style=\"color:#4ec9b0\">Flask</span>(__name__)\n706: <span style=\"color:#6a9955\">DB_PATH = \"bookshop.db\"</span></span>\n707: <span class=\"tax-red\"><span class=\"tax-label\"></span>  <span style=\"color:#b5cea8\">MAX_CONNECTIONS = 10</span></span>\n708: <span class=\"tax-blue\"><span class=\"tax-label\"></span><span style=\"color:#c586c0\">class</span> <span style=\"color:#4ec9b0\">Database</span>:\n709:     <span style=\"color:#c586c0\">def</span> <span style=\"color:#dcdcaa\">__init__</span>(<span style=\"color:#9cdcfe\">self</span>, <span style=\"color:#9cdcfe\">path</span>: str):\n710:         <span style=\"color:#9cdcfe\">self</span>.path = <span style=\"color:#9cdcfe\">path</span>\n711: \n712:     <span style=\"color:#c586c0\">def</span> <span style=\"color:#dcdcaa\">connect</span>(<span style=\"color:#9cdcfe\">self</span>):\n713:         <span style=\"color:#c586c0\">return</span> sqlite3.connect(<span style=\"color:#9cdcfe\">self</span>.path)</span>\n714: <span class=\"tax-green\"><span class=\"tax-label\"></span><span style=\"color:#6a9955\">db</span> = <span style=\"color:#4ec9b0\">Database</span>(DB_PATH)</span>\n715: <span class=\"tax-orange\"><span class=\"tax-label\"></span><span style=\"color:#c586c0\">@</span><span style=\"color:#9cdcfe\">app</span>.<span style=\"color:#dcdcaa\">route</span>(\"/books\")\n716: <span style=\"color:#c586c0\">def</span> <span style=\"color:#dcdcaa\">list_books</span>():\n717:     <span style=\"color:#9cdcfe\">conn</span> = <span style=\"color:#9cdcfe\">db</span>.connect()\n718:     <span style=\"color:#9cdcfe\">rows</span> = conn.execute(\"SELECT * FROM books\").fetchall()\n719:     conn.close()\n720:     <span style=\"color:#c586c0\">return</span> jsonify(<span style=\"color:#9cdcfe\">rows</span>)</span>\n721: <span class=\"tax-orange\"><span class=\"tax-label\"></span><span style=\"color:#c586c0\">@</span><span style=\"color:#9cdcfe\">app</span>.<span style=\"color:#dcdcaa\">route</span>(\"/books\", methods=[\"POST\"])\n722: <span style=\"color:#c586c0\">def</span> <span style=\"color:#dcdcaa\">create_book</span>():\n723:     <span style=\"color:#9cdcfe\">data</span> = request.get_json()\n724:     <span style=\"color:#9cdcfe\">conn</span> = <span style=\"color:#9cdcfe\">db</span>.connect()\n725:     conn.execute(\n726:         \"INSERT INTO books (title, price) VALUES (?, ?)\",\n727:         (data[\"title\"], data[\"price\"])\n728:     )\n729:     conn.commit()\n730:     conn.close()\n731:     <span style=\"color:#c586c0\">return</span> jsonify({\"ok\": True})</span></pre>\n732:         </div>\n733:       </div>\n734:     </div>\n735:   </div>\n736: \n737:   <!-- References -->\n738:   <div class=\"section\">\n739:     <h2>Research References</h2>\n740:     <div class=\"refs\">\n741:       <ol>\n742:         <li><cite>Kahneman, D.</cite> (2011). <em>Thinking, Fast and Slow</em>. Farrar, Straus and Giroux. \"System 1 operates automatically and cannot be turned off... System 2 is capacity-limited, requiring effort and attention.\"</li>\n743:         <li><cite>Sarkar, A.</cite> (2015). \"The impact of syntax colouring on program comprehension.\" <em>PPIG 2015</em>, Bournemouth, UK. \"Syntax highlighting significantly reduces task completion time, but the magnitude of this effect decreases as programming experience increases.\"</li>\n744:         <li><cite>Asenov, D., Hilliges, O., Müller, P.</cite> (2016). \"The Effect of Richer Visualizations on Code Comprehension.\" <em>CHI 2016</em>, ETH Zurich. \"Richer code visualizations reduce the time necessary to answer questions about code features by up to 75%.\"</li>\n745:         <li><cite>Fakhoury, S. et al.</cite> (2018). \"The Effect of Poor Source Code Lexicon and Readability on Developers' Cognitive Load.\" <em>ICPC 2018</em>. \"The presence of linguistic antipatterns in source code significantly increases the developers' cognitive load.\" (139 citations)</li>\n746:         <li><cite>Miller, G.A.</cite> (1956). \"The Magical Number Seven, Plus or Minus Two.\" <em>Psychological Review</em>, 63(2), 81–97. Working memory capacity: 7±2 chunks.</li>\n747:         <li><cite>Sweller, J.</cite> (1988). \"Cognitive Load During Problem Solving: Effects on Learning.\" <em>Cognitive Science</em>, 12(2), 257–285. Foundational Cognitive Load Theory.</li>\n748:         <li><cite>MITRE ATT&CK</cite> (2015–present). \"A globally accessible knowledge base of adversary tactics and techniques.\" Demonstrates that taxonomy-based visual compression transforms analyst comprehension from linear log reading to spatial pattern recognition.</li>\n749:         <li><cite>zakirullin/cognitive-load</cite> (GitHub, 2,400+ stars). \"The average person can hold roughly four chunks in working memory. Once the cognitive load reaches this threshold, it becomes much harder to understand things.\"</li>\n750:       </ol>\n751:     </div>\n752:   </div>\n753: \n754: </div>\n755: \n756: <script>\n757: function toggleView() {\n758:   const toggle = document.getElementById('toggle');\n759:   const label = document.getElementById('toggleLabel');\n760:   const trad = document.getElementById('codeTraditional');\n761:   const tax = document.getElementById('codeTaxonomy');\n762: \n763:   toggle.classList.toggle('active');\n764: \n765:   if (toggle.classList.contains('active')) {\n766:     label.textContent = 'Cognitive Taxonomy Protocol';\n767:     label.style.color = '#10b981';\n768:     trad.style.display = 'none';\n769:     tax.style.display = 'block';\n770:   } else {\n771:     label.textContent = 'Traditional Syntax Highlighting';\n772:     label.style.color = '#888';\n773:     trad.style.display = 'block';\n774:     tax.style.display = 'none';\n775:   }\n776: }\n777: </script>\n778: \n779: </body>\n780: </html>\n\n(End of file - total 780 lines)\n</content>",
