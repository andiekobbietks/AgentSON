      "code": "{\"todos\": [{\"content\": \"Create site directory structure and global CSS with design tokens\", \"status\": \"in_progress\", \"priority\": \"high\"}, {\"content\": \"Build index.html (homepage with live taxonomy demo)\", \"status\": \"pending\", \"priority\": \"high\"}, {\"content\": \"Build extensions.html (both extensions with install guides)\", \"status\": \"pending\", \"priority\": \"high\"}, {\"content\": \"Build research.html (theory and references)\", \"status\": \"pending\", \"priority\": \"medium\"}, {\"content\": \"Build install.html (detailed install guide)\", \"status\": \"pending\", \"priority\": \"medium\"}, {\"content\": \"Create shared nav.js and site.js\", \"status\": \"pending\", \"priority\": \"high\"}, {\"content\": \"Add Netlify config and README\", \"status\": \"pending\", \"priority\": \"medium\"}]}",
