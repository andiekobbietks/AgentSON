      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\cognitive-taxonomy-vscode-ext\\\\src\\\\sidebarProvider.ts\"}",
      "output": "<path>C:\\Users\\LLM-Test\\Documents\\cognitive-taxonomy-vscode-ext\\src\\sidebarProvider.ts</path>\n<type>file</type>\n<content>\n1: import * as vscode from 'vscode';\n2: import { ASTClassifier, ClassifiedNode, CATEGORIES, calculateCognitiveLoad, CognitiveLoadMetrics } from './astClassifier';\n3: import { TooltipGenerator } from './tooltipGenerator';\n4: import { DataFlowView, generateDataFlow, extractFlowNodes } from './dataFlow';\n5: \n6: // ─── Sidebar Panel Provider ─────────────────────────────────────────────\n7: \n8: export class TaxonomySidebarProvider implements vscode.WebviewViewProvider {\n9:     public static readonly viewType = 'cognitiveTaxonomy.sidebar';\n10:     private _view?: vscode.WebviewView;\n11:     private classifier: ASTClassifier = new ASTClassifier();\n12:     private tooltipGenerator: TooltipGenerator = new TooltipGenerator(true);\n13:     private currentMetrics: CognitiveLoadMetrics | null = null;\n14:     private currentClassified: Map<number, ClassifiedNode> = new Map();\n15:     private currentCode: string = '';\n16:     private currentDataFlowView: DataFlowView = 'ascii';\n17: \n18:     constructor(\n19:         private readonly _extensionUri: vscode.Uri,\n20:     ) { }\n21: \n22:     public resolveWebviewView(\n23:         webviewView: vscode.WebviewView,\n24:         context: vscode.WebviewViewResolveContext,\n25:         _token: vscode.CancellationToken,\n26:     ) {\n27:         this._view = webviewView;\n28: \n29:         webviewView.webview.options = {\n30:             enableScripts: true,\n31:             localResourceRoots: [this._extensionUri]\n32:         };\n33: \n34:         webviewView.webview.html = this._getHtmlForWebview(webviewView.webview);\n35: \n36:         // Listen for messages from the sidebar\n37:         webviewView.webview.onDidReceiveMessage(\n38:             message => {\n39:                 switch (message.type) {\n40:                     case 'jumpToLine':\n41:                         this.jumpToLine(message.lineNumber);\n42:                         break;\n43:                     case 'filterCategory':\n44:                         this.filterByCategory(message.category);\n45:                         break;\n46:                     case 'toggleSection':\n47:                         this.toggleSection(message.section);\n48:                         break;\n49:                     case 'changeDataFlowView':\n50:                         this.changeDataFlowView(message.view);\n51:                         break;\n52:                 }\n53:             },\n54:             undefined,\n55:             []\n56:         );\n57:     }\n58: \n59:     public updateMetrics(metrics: CognitiveLoadMetrics, classified: Map<number, ClassifiedNode>, code: string) {\n60:         this.currentMetrics = metrics;\n61:         this.currentClassified = classified;\n62:         this.currentCode = code;\n63:         this.refreshSidebar();\n64:     }\n65: \n66:     public setDataFlowView(view: DataFlowView) {\n67:         this.currentDataFlowView = view;\n68:         this.refreshSidebar();\n69:     }\n70: \n71:     private refreshSidebar() {\n72:         if (this._view) {\n73:             const flowNodes = extractFlowNodes(this.currentCode, 0);\n74:             this._view.webview.postMessage({\n75:                 type: 'update',\n76:                 metrics: this.currentMetrics,\n77:                 classified: this.formatClassifiedForWebview(),\n78:                 flowDiagram: generateDataFlow(flowNodes, this.currentDataFlowView),\n79:                 dataFlowView: this.currentDataFlowView\n80:             });\n81:         }\n82:     }\n83: \n84:     private formatClassifiedForWebview(): any[] {\n85:         const result: any[] = [];\n86:         for (const [lineNumber, node] of this.currentClassified) {\n87:             result.push({\n88:                 lineNumber,\n89:                 category: node.category.id,\n90:                 categoryLabel: node.category.label,\n91:                 explanation: node.explanation,\n92:                 nodeType: node.node.type\n93:             });\n94:         }\n95:         return result;\n96:     }\n97: \n98:     private jumpToLine(lineNumber: number) {\n99:         const editor = vscode.window.activeTextEditor;\n100:         if (editor) {\n101:             const position = new vscode.Position(lineNumber, 0);\n102:             editor.selection = new vscode.Selection(position, position);\n103:             editor.revealRange(new vscode.Range(position, position), vscode.TextEditorRevealType.InCenter);\n104:         }\n105:     }\n106: \n107:     private filterByCategory(category: string) {\n108:         // Send filter message to webview\n109:         this._view?.webview.postMessage({\n110:             type: 'filter',\n111:             category: category\n112:         });\n113:     }\n114: \n115:     private toggleSection(section: string) {\n116:         this._view?.webview.postMessage({\n117:             type: 'toggleSection',\n118:             section: section\n119:         });\n120:     }\n121: \n122:     private changeDataFlowView(view: DataFlowView) {\n123:         this.currentDataFlowView = view;\n124:         this.refreshSidebar();\n125:     }\n126: \n127:     private _getHtmlForWebview(webview: vscode.Webview) {\n128:         const nonce = getNonce();\n129: \n130:         return `<!DOCTYPE html>\n131:             <html lang=\"en\">\n132:             <head>\n133:                 <meta charset=\"UTF-8\">\n134:                 <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n135:                 <meta http-equiv=\"Content-Security-Policy\" content=\"default-src 'none'; style-src ${webview.cspSource} 'unsafe-inline'; script-src 'nonce-${nonce}';\">\n136:                 <title>Cognitive Taxonomy</title>\n137:                 <style>\n138:                     * {\n139:                         box-sizing: border-box;\n140:                     }\n141:                     body {\n142:                         padding: 0;\n143:                         margin: 0;\n144:                         font-family: var(--vscode-font-family);\n145:                         font-size: var(--vscode-font-size);\n146:                         color: var(--vscode-foreground);\n147:                         background: var(--vscode-sideBar-background);\n148:                     }\n149:                     \n150:                     /* ─── Visual-Spatial Memory ──────────────────────── */\n151:                     .spatial-layout {\n152:                         display: grid;\n153:                         grid-template-columns: 1fr 1fr 1fr;\n154:                         grid-template-rows: auto auto;\n155:                         gap: 4px;\n156:                         padding: 8px;\n157:                         background: var(--vscode-editor-background);\n158:                         border-radius: 4px;\n159:                     }\n160:                     .spatial-cell {\n161:                         display: flex;\n162:                         align-items: center;\n163:                         justify-content: center;\n164:                         padding: 6px 4px;\n165:                         border-radius: 4px;\n166:                         cursor: pointer;\n167:                         transition: all 0.2s ease;\n168:                     }\n169:                     .spatial-cell:hover {\n170:                         background: var(--vscode-list-hoverBackground);\n171:                     }\n172:                     .spatial-cell.active {\n173:                         background: var(--vscode-list-activeSelectionBackground);\n174:                     }\n175:                     .spatial-cell.blue { grid-column: 1; grid-row: 1; border-left: 3px solid #3b82f6; }\n176:                     .spatial-cell.green { grid-column: 1; grid-row: 2; border-left: 3px solid #10b981; }\n177:                     .spatial-cell.orange { grid-column: 2; grid-row: 1 / span 2; border-left: 3px solid #f97316; }\n178:                     .spatial-cell.red { grid-column: 3; grid-row: 1; border-left: 3px solid #ef4444; }\n179:                     .spatial-cell.purple { grid-column: 3; grid-row: 2; border-left: 3px solid #a855f7; }\n180:                     .spatial-label {\n181:                         font-size: 10px;\n182:                         font-weight: bold;\n183:                         color: var(--vscode-foreground);\n184:                     }\n185:                     .spatial-count {\n186:                         font-size: 9px;\n187:                         color: var(--vscode-descriptionForeground);\n188:                         margin-left: 4px;\n189:                     }\n190:                     \n191:                     /* ─── Scores Section ─────────────────────────────── */\n192:                     .scores-section {\n193:                         padding: 12px;\n194:                         border-bottom: 1px solid var(--vscode-sideBarSectionHeader-border);\n195:                     }\n196:                     .score-row {\n197:                         display: flex;\n198:                         align-items: center;\n199:                         margin-bottom: 8px;\n200:                     }\n201:                     .score-label {\n202:                         width: 100px;\n203:                         font-size: 11px;\n204:                         color: var(--vscode-descriptionForeground);\n205:                     }\n206:                     .score-bar-container {\n207:                         flex: 1;\n208:                         height: 8px;\n209:                         background: var(--vscode-editor-inactiveSelectionBackground);\n210:                         border-radius: 4px;\n211:                         overflow: hidden;\n212:                         margin: 0 8px;\n213:                     }\n214:                     .score-bar {\n215:                         height: 100%;\n216:                         border-radius: 4px;\n217:                         transition: width 0.3s ease;\n218:                     }\n219:                     .score-value {\n220:                         width: 45px;\n221:                         text-align: right;\n222:                         font-weight: bold;\n223:                         font-size: 11px;\n224:                     }\n225:                     .score-good { color: #10b981; }\n226:                     .score-warning { color: #f97316; }\n227:                     .score-critical { color: #ef4444; }\n228:                     \n229:                     /* ─── Collapsible Section ───────────────────────── */\n230:                     .section {\n231:                         border-bottom: 1px solid var(--vscode-sideBarSectionHeader-border);\n232:                     }\n233:                     .section-header {\n234:                         display: flex;\n235:                         align-items: center;\n236:                         padding: 8px 12px;\n237:                         cursor: pointer;\n238:                         user-select: none;\n239:                         background: var(--vscode-sideBarSectionHeader-background);\n240:                     }\n241:                     .section-header:hover {\n242:                         background: var(--vscode-list-hoverBackground);\n243:                     }\n244:                     .section-chevron {\n245:                         margin-right: 8px;\n246:                         transition: transform 0.2s;\n247:                         font-size: 10px;\n248:                     }\n249:                     .section-chevron.collapsed {\n250:                         transform: rotate(-90deg);\n251:                     }\n252:                     .section-title {\n253:                         flex: 1;\n254:                         font-weight: 600;\n255:                         font-size: 11px;\n256:                         text-transform: uppercase;\n257:                         letter-spacing: 0.5px;\n258:                     }\n259:                     .section-count {\n260:                         background: var(--vscode-badge-background);\n261:                         color: var(--vscode-badge-foreground);\n262:                         padding: 2px 6px;\n263:                         border-radius: 10px;\n264:                         font-size: 10px;\n265:                         font-weight: bold;\n266:                     }\n267:                     .section-content {\n268:                         padding: 8px 12px;\n269:                     }\n270:                     .section-content.collapsed {\n271:                         display: none;\n272:                     }\n273:                     \n274:                     /* ─── Category List ─────────────────────────────── */\n275:                     .category-item {\n276:                         display: flex;\n277:                         align-items: center;\n278:                         padding: 6px 8px;\n279:                         margin-bottom: 4px;\n280:                         border-radius: 4px;\n281:                         cursor: pointer;\n282:                         transition: background 0.15s;\n283:                     }\n284:                     .category-item:hover {\n285:                         background: var(--vscode-list-hoverBackground);\n286:                     }\n287:                     .category-item.active {\n288:                         background: var(--vscode-list-activeSelectionBackground);\n289:                     }\n290:                     .category-dot {\n291:                         width: 12px;\n292:                         height: 12px;\n293:                         border-radius: 50%;\n294:                         margin-right: 10px;\n295:                         flex-shrink: 0;\n296:                     }\n297:                     .category-name {\n298:                         flex: 1;\n299:                         font-size: 12px;\n300:                     }\n301:                     .category-bar {\n302:                         width: 60px;\n303:                         height: 6px;\n304:                         background: var(--vscode-editor-inactiveSelectionBackground);\n305:                         border-radius: 3px;\n306:                         overflow: hidden;\n307:                         margin: 0 8px;\n308:                     }\n309:                     .category-bar-fill {\n310:                         height: 100%;\n311:                         border-radius: 3px;\n312:                     }\n313:                     .category-count {\n314:                         font-size: 11px;\n315:                         color: var(--vscode-descriptionForeground);\n316:                         width: 25px;\n317:                         text-align: right;\n318:                     }\n319:                     .category-percent {\n320:                         font-size: 10px;\n321:                         color: var(--vscode-descriptionForeground);\n322:                         width: 35px;\n323:                         text-align: right;\n324:                     }\n325:                     \n326:                     /* ─── Issue List ────────────────────────────────── */\n327:                     .issue-item {\n328:                         display: flex;\n329:                         align-items: flex-start;\n330:                         padding: 8px;\n331:                         margin-bottom: 6px;\n332:                         background: var(--vscode-editor-inactiveSelectionBackground);\n333:                         border-radius: 4px;\n334:                         border-left: 3px solid #f97316;\n335:                         cursor: pointer;\n336:                     }\n337:                     .issue-item:hover {\n338:                         background: var(--vscode-list-hoverBackground);\n339:                     }\n340:                     .issue-icon {\n341:                         margin-right: 8px;\n342:                         font-size: 14px;\n343:                     }\n344:                     .issue-content {\n345:                         flex: 1;\n346:                     }\n347:                     .issue-line {\n348:                         font-weight: bold;\n349:                         font-size: 11px;\n350:                         color: #f97316;\n351:                     }\n352:                     .issue-message {\n353:                         font-size: 11px;\n354:                         color: var(--vscode-descriptionForeground);\n355:                         margin-top: 2px;\n356:                     }\n357:                     \n358:                     /* ─── Flow Diagram ──────────────────────────────── */\n359:                     .flow-controls {\n360:                         display: flex;\n361:                         gap: 4px;\n362:                         margin-bottom: 8px;\n363:                     }\n364:                     .flow-btn {\n365:                         padding: 4px 8px;\n366:                         border: 1px solid var(--vscode-button-border);\n367:                         background: var(--vscode-button-background);\n368:                         color: var(--vscode-button-foreground);\n369:                         border-radius: 4px;\n370:                         cursor: pointer;\n371:                         font-size: 10px;\n372:                     }\n373:                     .flow-btn.active {\n374:                         background: var(--vscode-button-background);\n375:                         border-color: var(--vscode-focusBorder);\n376:                     }\n377:                     .flow-btn:hover {\n378:                         background: var(--vscode-button-hoverBackground);\n379:                     }\n380:                     .flow-diagram {\n381:                         font-family: var(--vscode-editor-font-family);\n382:                         font-size: 11px;\n383:                         line-height: 1.4;\n384:                         padding: 8px;\n385:                         background: var(--vscode-editor-background);\n386:                         border-radius: 4px;\n387:                         overflow-x: auto;\n388:                         white-space: pre;\n389:                     }\n390:                     .flow-diagram svg {\n391:                         display: block;\n392:                     }\n393:                     .flow-diagram svg .node-rect {\n394:                         cursor: pointer;\n395:                         transition: all 0.2s ease;\n396:                     }\n397:                     .flow-diagram svg .node-rect:hover {\n398:                         filter: brightness(1.3);\n399:                         stroke-width: 2;\n400:                     }\n401:                     .flow-diagram svg .node-text {\n402:                         pointer-events: none;\n403:                         user-select: none;\n404:                     }\n405:                     \n406:                     /* ─── Line List ─────────────────────────────────── */\n407:                     .line-filter {\n408:                         display: flex;\n409:                         gap: 4px;\n410:                         margin-bottom: 8px;\n411:                         flex-wrap: wrap;\n412:                     }\n413:                     .filter-btn {\n414:                         padding: 3px 8px;\n415:                         border: 1px solid var(--vscode-button-border);\n416:                         background: transparent;\n417:                         color: var(--vscode-descriptionForeground);\n418:                         border-radius: 12px;\n419:                         cursor: pointer;\n420:                         font-size: 10px;\n421:                     }\n422:                     .filter-btn.active {\n423:                         background: var(--vscode-button-background);\n424:                         color: var(--vscode-button-foreground);\n425:                     }\n426:                     .filter-btn:hover {\n427:                         background: var(--vscode-list-hoverBackground);\n428:                     }\n429:                     .line-list {\n430:                         max-height: 200px;\n431:                         overflow-y: auto;\n432:                     }\n433:                     .line-item {\n434:                         display: flex;\n435:                         align-items: center;\n436:                         padding: 4px 6px;\n437:                         border-bottom: 1px solid var(--vscode-editor-inactiveSelectionBackground);\n438:                         cursor: pointer;\n439:                         font-size: 11px;\n440:                     }\n441:                     .line-item:hover {\n442:                         background: var(--vscode-list-hoverBackground);\n443:                     }\n444:                     .line-num {\n445:                         width: 30px;\n446:                         color: var(--vscode-descriptionForeground);\n447:                         font-family: var(--vscode-editor-font-family);\n448:                     }\n449:                     .line-dot {\n450:                         width: 8px;\n451:                         height: 8px;\n452:                         border-radius: 50%;\n453:                         margin-right: 8px;\n454:                         flex-shrink: 0;\n455:                     }\n456:                     .line-text {\n457:                         flex: 1;\n458:                         overflow: hidden;\n459:                         text-overflow: ellipsis;\n460:                         white-space: nowrap;\n461:                         color: var(--vscode-descriptionForeground);\n462:                     }\n463:                     \n464:                     /* ─── Glossary ──────────────────────────────────── */\n465:                     .glossary-item {\n466:                         padding: 6px 8px;\n467:                         border-bottom: 1px solid var(--vscode-sideBarSectionHeader-border);\n468:                     }\n469:                     .glossary-item:last-child {\n470:                         border-bottom: none;\n471:                     }\n472:                     .glossary-term {\n473:                         font-weight: bold;\n474:                         font-size: 11px;\n475:                         color: var(--vscode-foreground);\n476:                         display: flex;\n477:                         align-items: center;\n478:                         gap: 6px;\n479:                     }\n480:                     .glossary-dot {\n481:                         width: 8px;\n482:                         height: 8px;\n483:                         border-radius: 50%;\n484:                         flex-shrink: 0;\n485:                     }\n486:                     .glossary-def {\n487:                         font-size: 10px;\n488:                         color: var(--vscode-descriptionForeground);\n489:                         margin-top: 2px;\n490:                         line-height: 1.4;\n491:                     }\n492:                     .glossary-divider {\n493:                         height: 1px;\n494:                         background: var(--vscode-sideBarSectionHeader-border);\n495:                         margin: 4px 8px;\n496:                     }\n497:                     \n498:                     /* ─── Quick Reference ────────────────────────────── */\n499:                     .ref-group {\n500:                         padding: 6px 8px;\n501:                         border-bottom: 1px solid var(--vscode-sideBarSectionHeader-border);\n502:                     }\n503:                     .ref-group:last-child {\n504:                         border-bottom: none;\n505:                     }\n506:                     .ref-title {\n507:                         font-weight: bold;\n508:                         font-size: 10px;\n509:                         color: var(--vscode-descriptionForeground);\n510:                         text-transform: uppercase;\n511:                         margin-bottom: 4px;\n512:                     }\n513:                     .ref-item {\n514:                         font-size: 11px;\n515:                         color: var(--vscode-foreground);\n516:                         padding: 2px 0;\n517:                         display: flex;\n518:                         align-items: center;\n519:                         gap: 6px;\n520:                     }\n521:                     .ref-dot {\n522:                         width: 6px;\n523:                         height: 6px;\n524:                         border-radius: 50%;\n525:                         flex-shrink: 0;\n526:                     }\n527:                     .ref-item kbd {\n528:                         background: var(--vscode-editor-background);\n529:                         border: 1px solid var(--vscode-widget-border);\n530:                         border-radius: 3px;\n531:                         padding: 1px 4px;\n532:                         font-family: var(--vscode-editor-font-family);\n533:                         font-size: 10px;\n534:                         color: var(--vscode-foreground);\n535:                     }\n536:                     \n537:                     /* ─── Code Smells ────────────────────────────────── */\n538:                     .smell-item {\n539:                         display: flex;\n540:                         align-items: flex-start;\n541:                         padding: 6px 8px;\n542:                         border-bottom: 1px solid var(--vscode-sideBarSectionHeader-border);\n543:                         cursor: pointer;\n544:                     }\n545:                     .smell-item:hover {\n546:                         background: var(--vscode-list-hoverBackground);\n547:                     }\n548:                     .smell-item:last-child {\n549:                         border-bottom: none;\n550:                     }\n551:                     .smell-icon {\n552:                         margin-right: 8px;\n553:                         font-size: 12px;\n554:                     }\n555:                     .smell-content {\n556:                         flex: 1;\n557:                     }\n558:                     .smell-type {\n559:                         font-weight: bold;\n560:                         font-size: 11px;\n561:                         color: var(--vscode-foreground);\n562:                     }\n563:                     .smell-line {\n564:                         font-size: 10px;\n565:                         color: var(--vscode-descriptionForeground);\n566:                     }\n567:                     .smell-desc {\n568:                         font-size: 10px;\n569:                         color: var(--vscode-descriptionForeground);\n570:                         margin-top: 2px;\n571:                     }\n572:                 </style>\n573:             </head>\n574:             <body>\n575:                 <div id=\"app\">\n576:                     <!-- Scores Section -->\n577:                     <div class=\"scores-section\" id=\"scores-section\">\n578:                         <div class=\"score-row\">\n579:                             <span class=\"score-label\">Maintainability</span>\n580:                             <div class=\"score-bar-container\">\n581:                                 <div class=\"score-bar\" id=\"maintainability-bar\" style=\"width: 0%; background: #10b981;\"></div>\n582:                             </div>\n583:                             <span class=\"score-value\" id=\"maintainability-value\">--/100</span>\n584:                         </div>\n585:                         <div class=\"score-row\">\n586:                             <span class=\"score-label\">Balance</span>\n587:                             <div class=\"score-bar-container\">\n588:                                 <div class=\"score-bar\" id=\"balance-bar\" style=\"width: 0%; background: #f97316;\"></div>\n589:                             </div>\n590:                             <span class=\"score-value\" id=\"balance-value\">--/100</span>\n591:                         </div>\n592:                         <div id=\"plain-english-summary\" style=\"margin-top: 8px; padding: 8px; background: var(--vscode-editor-background); border-radius: 4px; font-size: 11px; color: var(--vscode-foreground);\"></div>\n593:                     </div>\n594:                     \n595:                     <!-- Visual-Spatial Layout -->\n596:                     <div class=\"section\">\n597:                         <div class=\"section-header\" onclick=\"toggleSection('spatial')\">\n598:                             <span class=\"section-chevron\" id=\"spatial-chevron\">▼</span>\n599:                             <span class=\"section-title\">Architecture Map</span>\n600:                         </div>\n601:                         <div class=\"section-content\" id=\"spatial-content\">\n602:                             <div class=\"spatial-layout\" id=\"spatial-layout\">\n603:                                 <div class=\"spatial-cell blue\" onclick=\"filterLines('blue')\">\n604:                                     <span class=\"spatial-label\">Blueprint</span>\n605:                                     <span class=\"spatial-count\" id=\"spatial-blue\">0</span>\n606:                                 </div>\n607:                                 <div class=\"spatial-cell orange\" onclick=\"filterLines('orange')\">\n608:                                     <span class=\"spatial-label\">Transaction</span>\n609:                                     <span class=\"spatial-count\" id=\"spatial-orange\">0</span>\n610:                                 </div>\n611:                                 <div class=\"spatial-cell red\" onclick=\"filterLines('red')\">\n612:                                     <span class=\"spatial-label\">Constraint</span>\n613:                                     <span class=\"spatial-count\" id=\"spatial-red\">0</span>\n614:                                 </div>\n615:                                 <div class=\"spatial-cell green\" onclick=\"filterLines('green')\">\n616:                                     <span class=\"spatial-label\">Plumbing</span>\n617:                                     <span class=\"spatial-count\" id=\"spatial-green\">0</span>\n618:                                 </div>\n619:                                 <div class=\"spatial-cell purple\" onclick=\"filterLines('purple')\">\n620:                                     <span class=\"spatial-label\">Pedagogy</span>\n621:                                     <span class=\"spatial-count\" id=\"spatial-purple\">0</span>\n622:                                 </div>\n623:                             </div>\n624:                         </div>\n625:                     </div>\n626:                     \n627:                     <!-- Categories Section -->\n628:                     <div class=\"section\">\n629:                         <div class=\"section-header\" onclick=\"toggleSection('categories')\">\n630:                             <span class=\"section-chevron\" id=\"categories-chevron\">▼</span>\n631:                             <span class=\"section-title\">Categories</span>\n632:                             <span class=\"section-count\" id=\"categories-count\">5</span>\n633:                         </div>\n634:                         <div class=\"section-content\" id=\"categories-content\">\n635:                             <div id=\"categories-list\"></div>\n636:                         </div>\n637:                     </div>\n638:                     \n639:                     <!-- Issues Section -->\n640:                     <div class=\"section\">\n641:                         <div class=\"section-header\" onclick=\"toggleSection('issues')\">\n642:                             <span class=\"section-chevron\" id=\"issues-chevron\">▼</span>\n643:                             <span class=\"section-title\">Issues</span>\n644:                             <span class=\"section-count\" id=\"issues-count\">0</span>\n645:                         </div>\n646:                         <div class=\"section-content\" id=\"issues-content\">\n647:                             <div id=\"issues-list\"></div>\n648:                         </div>\n649:                     </div>\n650:                     \n651:                     <!-- Flow Section -->\n652:                     <div class=\"section\">\n653:                         <div class=\"section-header\" onclick=\"toggleSection('flow')\">\n654:                             <span class=\"section-chevron\" id=\"flow-chevron\">▼</span>\n655:                             <span class=\"section-title\">Data Flow</span>\n656:                         </div>\n657:                         <div class=\"section-content\" id=\"flow-content\">\n658:                             <div class=\"flow-controls\">\n659:                                 <button class=\"flow-btn active\" onclick=\"changeFlowView('ascii')\">ASCII</button>\n660:                                 <button class=\"flow-btn\" onclick=\"changeFlowView('mini')\">Mini</button>\n661:                                 <button class=\"flow-btn\" onclick=\"changeFlowView('mermaid')\">Mermaid</button>\n662:                                 <button class=\"flow-btn\" onclick=\"changeFlowView('svg')\">SVG</button>\n663:                             </div>\n664:                             <div class=\"flow-diagram\" id=\"flow-diagram\">No flow data</div>\n665:                         </div>\n666:                     </div>\n667:                     \n668:                     <!-- Lines Section -->\n669:                     <div class=\"section\">\n670:                         <div class=\"section-header\" onclick=\"toggleSection('lines')\">\n671:                             <span class=\"section-chevron\" id=\"lines-chevron\">▼</span>\n672:                             <span class=\"section-title\">Lines</span>\n673:                             <span class=\"section-count\" id=\"lines-count\">0</span>\n674:                         </div>\n675:                         <div class=\"section-content\" id=\"lines-content\">\n676:                             <div class=\"line-filter\" id=\"line-filter\">\n677:                                 <button class=\"filter-btn active\" onclick=\"filterLines('all')\">All</button>\n678:                                 <button class=\"filter-btn\" onclick=\"filterLines('blue')\" style=\"border-color: #3b82f6;\">🔵</button>\n679:                                 <button class=\"filter-btn\" onclick=\"filterLines('green')\" style=\"border-color: #10b981;\">🟢</button>\n680:                                 <button class=\"filter-btn\" onclick=\"filterLines('orange')\" style=\"border-color: #f97316;\">🟠</button>\n681:                                 <button class=\"filter-btn\" onclick=\"filterLines('red')\" style=\"border-color: #ef4444;\">🔴</button>\n682:                                 <button class=\"filter-btn\" onclick=\"filterLines('purple')\" style=\"border-color: #a855f7;\">🟣</button>\n683:                             </div>\n684:                             <div class=\"line-list\" id=\"line-list\"></div>\n685:                         </div>\n686:                     </div>\n687:                     \n688:                     <!-- Code Smells Section -->\n689:                     <div class=\"section\">\n690:                         <div class=\"section-header\" onclick=\"toggleSection('smells')\">\n691:                             <span class=\"section-chevron\" id=\"smells-chevron\">▼</span>\n692:                             <span class=\"section-title\">Code Smells</span>\n693:                             <span class=\"section-count\" id=\"smells-count\">0</span>\n694:                         </div>\n695:                         <div class=\"section-content\" id=\"smells-content\">\n696:                             <div id=\"smells-list\"></div>\n697:                         </div>\n698:                     </div>\n699:                     \n700:                     <!-- Glossary Section -->\n701:                     <div class=\"section\">\n702:                         <div class=\"section-header\" onclick=\"toggleSection('glossary')\">\n703:                             <span class=\"section-chevron\" id=\"glossary-chevron\">▶</span>\n704:                             <span class=\"section-title\">Glossary</span>\n705:                         </div>\n706:                         <div class=\"section-content collapsed\" id=\"glossary-content\">\n707:                             <div class=\"glossary-item\">\n708:                                 <div class=\"glossary-term\"><span class=\"glossary-dot\" style=\"background: #3b82f6;\"></span> Blueprint (🔵)</div>\n709:                                 <div class=\"glossary-def\">What the code needs to remember. Like furniture in a house.</div>\n710:                             </div>\n711:                             <div class=\"glossary-item\">\n712:                                 <div class=\"glossary-term\"><span class=\"glossary-dot\" style=\"background: #10b981;\"></span> Plumbing (🟢)</div>\n713:                                 <div class=\"glossary-def\">Bringing things from outside. Like a delivery truck.</div>\n714:                             </div>\n715:                             <div class=\"glossary-item\">\n716:                                 <div class=\"glossary-term\"><span class=\"glossary-dot\" style=\"background: #f97316;\"></span> Transaction (🟠)</div>\n717:                                 <div class=\"glossary-def\">What the code actually does. Like people cooking and cleaning.</div>\n718:                             </div>\n719:                             <div class=\"glossary-item\">\n720:                                 <div class=\"glossary-term\"><span class=\"glossary-dot\" style=\"background: #ef4444;\"></span> Constraint (🔴)</div>\n721:                                 <div class=\"glossary-def\">Rules that must never be broken. Like locks on doors.</div>\n722:                             </div>\n723:                             <div class=\"glossary-item\">\n724:                                 <div class=\"glossary-term\"><span class=\"glossary-dot\" style=\"background: #a855f7;\"></span> Pedagogy (🟣)</div>\n725:                                 <div class=\"glossary-def\">Notes for yourself later. Like labels on boxes.</div>\n726:                             </div>\n727:                             <div class=\"glossary-divider\"></div>\n728:                             <div class=\"glossary-item\">\n729:                                 <div class=\"glossary-term\">Magic Number</div>\n730:                                 <div class=\"glossary-def\">A number with no explanation. Fix: give it a name.</div>\n731:                             </div>\n732:                             <div class=\"glossary-item\">\n733:                                 <div class=\"glossary-term\">Cognitive Load</div>\n734:                                 <div class=\"glossary-def\">How busy the code is. Low = easy. High = too much.</div>\n735:                             </div>\n736:                             <div class=\"glossary-item\">\n737:                                 <div class=\"glossary-term\">Data Flow</div>\n738:                                 <div class=\"glossary-def\">How data moves through the code.</div>\n739:                             </div>\n740:                             <div class=\"glossary-item\">\n741:                                 <div class=\"glossary-term\">Balance Score</div>\n742:                                 <div class=\"glossary-def\">How evenly code is spread across categories.</div>\n743:                             </div>\n744:                             <div class=\"glossary-item\">\n745:                                 <div class=\"glossary-term\">Architecture</div>\n746:                                 <div class=\"glossary-def\">How the code is organised into parts.</div>\n747:                             </div>\n748:                         </div>\n749:                     </div>\n750:                     \n751:                     <!-- Quick Reference Section -->\n752:                     <div class=\"section\">\n753:                         <div class=\"section-header\" onclick=\"toggleSection('reference')\">\n754:                             <span class=\"section-chevron\" id=\"reference-chevron\">▶</span>\n755:                             <span class=\"section-title\">Quick Reference</span>\n756:                         </div>\n757:                         <div class=\"section-content collapsed\" id=\"reference-content\">\n758:                             <div class=\"ref-group\">\n759:                                 <div class=\"ref-title\">Keyboard Shortcuts</div>\n760:                                 <div class=\"ref-item\"><kbd>Ctrl+Shift+T</kbd> Toggle taxonomy</div>\n761:                                 <div class=\"ref-item\"><kbd>Ctrl+Shift+F</kbd> Toggle data flow</div>\n762:                             </div>\n763:                             <div class=\"ref-group\">\n764:                                 <div class=\"ref-title\">Colour Meanings</div>\n765:                                 <div class=\"ref-item\"><span class=\"ref-dot\" style=\"background: #3b82f6;\"></span> Blue = Memory / data</div>\n766:                                 <div class=\"ref-item\"><span class=\"ref-dot\" style=\"background: #10b981;\"></span> Green = Imports / tools</div>\n767:                                 <div class=\"ref-item\"><span class=\"ref-dot\" style=\"background: #f97316;\"></span> Orange = Logic / actions</div>\n768:                                 <div class=\"ref-item\"><span class=\"ref-dot\" style=\"background: #ef4444;\"></span> Red = Rules / validation</div>\n769:                                 <div class=\"ref-item\"><span class=\"ref-dot\" style=\"background: #a855f7;\"></span> Purple = Notes / docs</div>\n770:                             </div>\n771:                             <div class=\"ref-group\">\n772:                                 <div class=\"ref-title\">Scores</div>\n773:                                 <div class=\"ref-item\">🟢 Low = easy to understand</div>\n774:                                 <div class=\"ref-item\">🟡 Medium = a bit complex</div>\n775:                                 <div class=\"ref-item\">🔴 High = very complicated</div>\n776:                             </div>\n777:                         </div>\n778:                     </div>\n779:                 </div>\n780:                 \n781:                 <script nonce=\"${nonce}\">\n782:                     const vscode = acquireVsCodeApi();\n783:                     let allLines = [];\n784:                     let currentFilter = 'all';\n785:                     let collapsedSections = {};\n786:                     \n787:                     // ─── Message Handler ───────────────────────────────\n788:                     window.addEventListener('message', event => {\n789:                         const message = event.data;\n790:                         switch (message.type) {\n791:                             case 'update':\n792:                                 updateUI(message.metrics, message.classified, message.flowDiagram, message.dataFlowView);\n793:                                 break;\n794:                             case 'filter':\n795:                                 filterLines(message.category);\n796:                                 break;\n797:                             case 'toggleSection':\n798:                                 toggleSection(message.section);\n799:                                 break;\n800:                         }\n801:                     });\n802:                     \n803:                     // ─── Update UI ─────────────────────────────────────\n804:                     function updateUI(metrics, classified, flowDiagram, dataFlowView) {\n805:                         allLines = classified || [];\n806:                         \n807:                         if (metrics) {\n808:                             updateScores(metrics);\n809:                             updateCategories(metrics);\n810:                             updateIssues(allLines);\n811:                             updateCodeSmells(allLines, metrics);\n812:                             updateFlowDiagram(flowDiagram, dataFlowView, allLines);\n813:                             updateLineList(allLines);\n814:                         }\n815:                     }\n816:                     \n817:                     // ─── Scores ────────────────────────────────────────\n818:                     function updateScores(metrics) {\n819:                         const maintainability = Math.round((metrics.balanceScore * 0.4 + (100 - metrics.complexityScore) * 0.3 + 30 * 0.3));\n820:                         const balance = metrics.balanceScore;\n821:                         \n822:                         // Maintainability\n823:                         const mBar = document.getElementById('maintainability-bar');\n824:                         const mVal = document.getElementById('maintainability-value');\n825:                         mBar.style.width = maintainability + '%';\n826:                         mBar.style.background = maintainability >= 70 ? '#10b981' : maintainability >= 50 ? '#f97316' : '#ef4444';\n827:                         mVal.textContent = maintainability + '/100';\n828:                         mVal.className = 'score-value ' + (maintainability >= 70 ? 'score-good' : maintainability >= 50 ? 'score-warning' : 'score-critical');\n829:                         \n830:                         // Balance\n831:                         const bBar = document.getElementById('balance-bar');\n832:                         const bVal = document.getElementById('balance-value');\n833:                         bBar.style.width = balance + '%';\n834:                         bBar.style.background = balance >= 70 ? '#10b981' : balance >= 50 ? '#f97316' : '#ef4444';\n835:                         bVal.textContent = balance + '/100';\n836:                         bVal.className = 'score-value ' + (balance >= 70 ? 'score-good' : balance >= 50 ? 'score-warning' : 'score-critical');\n837:                         \n838:                         // Plain English summary\n839:                         updatePlainEnglishSummary(metrics, maintainability, balance);\n840:                     }\n841:                     \n842:                     function updatePlainEnglishSummary(metrics, maintainability, balance) {\n843:                         const summary = document.getElementById('plain-english-summary');\n844:                         \n845:                         // Overall message\n846:                         let overall = '';\n847:                         if (maintainability >= 70) {\n848:                             overall = '🟢 Easy to understand';\n849:                         } else if (maintainability >= 50) {\n850:                             overall = '🟡 A bit complicated';\n851:                         } else {\n852:                             overall = '🔴 Very complicated';\n853:                         }\n854:                         \n855:                         // Balance message\n856:                         let balanceMsg = '';\n857:                         if (balance >= 70) {\n858:                             balanceMsg = 'Good mix of code types';\n859:                         } else if (balance >= 50) {\n860:                             balanceMsg = 'Mostly one type of code';\n861:                         } else {\n862:                             balanceMsg = 'Very unbalanced — mostly one type';\n863:                         }\n864:                         \n865:                         // What this code is\n866:                         const total = metrics.totalLines || 1;\n867:                         const orangePercent = Math.round((metrics.transactionLines / total) * 100);\n868:                         let codeType = '';\n869:                         if (orangePercent > 70) {\n870:                             codeType = 'This code is mostly DOING things (calculations, logic).';\n871:                         } else if (metrics.blueprintLines > metrics.transactionLines) {\n872:                             codeType = 'This code is mostly DEFINING things (data structures).';\n873:                         } else if (metrics.plumbingLines > metrics.transactionLines) {\n874:                             codeType = 'This code is mostly CONNECTING things (imports, setup).';\n875:                         } else {\n876:                             codeType = 'This code has a mix of defining, connecting, and doing.';\n877:                         }\n878:                         \n879:                         // Missing things\n880:                         const missing = [];\n881:                         if (metrics.constraintLines < 5) {\n882:                             missing.push('few rules/checks');\n883:                         }\n884:                         if (metrics.pedagogyLines < 5) {\n885:                             missing.push('few notes/docs');\n886:                         }\n887:                         if (metrics.blueprintLines < 3) {\n888:                             missing.push('few data definitions');\n889:                         }\n890:                         \n891:                         let missingMsg = '';\n892:                         if (missing.length > 0) {\n893:                             missingMsg = '⚠️ Might be missing: ' + missing.join(', ');\n894:                         } else {\n895:                             missingMsg = '✅ Has a good mix of all types';\n896:                         }\n897:                         \n898:                         summary.innerHTML = \\`\n899:                             <div style=\"margin-bottom: 4px;\"><strong>\\${overall}</strong> — \\${balanceMsg}</div>\n900:                             <div style=\"margin-bottom: 4px; color: var(--vscode-descriptionForeground);\">\\${codeType}</div>\n901:                             <div style=\"color: var(--vscode-descriptionForeground);\">\\${missingMsg}</div>\n902:                         \\`;\n903:                     }\n904:                     \n905:                     // ─── Categories ────────────────────────────────────\n906:                     function updateCategories(metrics) {\n907:                         const categories = [\n908:                             { id: 'blue', name: 'BLUE', label: 'Blueprint', count: metrics.blueprintLines, color: '#3b82f6' },\n909:                             { id: 'green', name: 'GREEN', label: 'Plumbing', count: metrics.plumbingLines, color: '#10b981' },\n910:                             { id: 'orange', name: 'ORANGE', label: 'Transaction', count: metrics.transactionLines, color: '#f97316' },\n911:                             { id: 'red', name: 'RED', label: 'Constraint', count: metrics.constraintLines, color: '#ef4444' },\n912:                             { id: 'purple', name: 'PURPLE', label: 'Pedagogy', count: metrics.pedagogyLines, color: '#a855f7' }\n913:                         ];\n914:                         \n915:                         const total = metrics.totalLines || 1;\n916:                         const maxCount = Math.max(...categories.map(c => c.count));\n917:                         \n918:                         const html = categories.map(cat => {\n919:                             const percent = Math.round((cat.count / total) * 100);\n920:                             const barWidth = maxCount > 0 ? (cat.count / maxCount) * 100 : 0;\n921:                             return \\`\n922:                                 <div class=\"category-item\" onclick=\"filterLines('\\${cat.id}')\">\n923:                                     <div class=\"category-dot\" style=\"background: \\${cat.color};\"></div>\n924:                                     <span class=\"category-name\">\\${cat.name}</span>\n925:                                     <div class=\"category-bar\">\n926:                                         <div class=\"category-bar-fill\" style=\"width: \\${barWidth}%; background: \\${cat.color};\"></div>\n927:                                     </div>\n928:                                     <span class=\"category-count\">\\${cat.count}</span>\n929:                                     <span class=\"category-percent\">\\${percent}%</span>\n930:                                 </div>\n931:                             \\`;\n932:                         }).join('');\n933:                         \n934:                         document.getElementById('categories-list').innerHTML = html;\n935:                         document.getElementById('categories-count').textContent = categories.length;\n936:                         \n937:                         // Update spatial layout counts\n938:                         document.getElementById('spatial-blue').textContent = metrics.blueprintLines;\n939:                         document.getElementById('spatial-green').textContent = metrics.plumbingLines;\n940:                         document.getElementById('spatial-orange').textContent = metrics.transactionLines;\n941:                         document.getElementById('spatial-red').textContent = metrics.constraintLines;\n942:                         document.getElementById('spatial-purple').textContent = metrics.pedagogyLines;\n943:                     }\n944:                     \n945:                     // ─── Issues ────────────────────────────────────────\n946:                     function updateIssues(lines) {\n947:                         const issues = [];\n948:                         \n949:                         lines.forEach(line => {\n950:                             // Check for missing constraints\n951:                             if (line.category === 'orange' && line.nodeType === 'function') {\n952:                                 // Simple heuristic: if function has no red nearby\n953:                                 issues.push({\n954:                                     line: line.lineNumber,\n955:                                     message: 'Function may need validation',\n956:                                     icon: '⚠️'\n957:                                 });\n958:                             }\n959:                         });\n960:                         \n961:                         // Limit to 5 issues\n962:                         const displayIssues = issues.slice(0, 5);\n963:                         \n964:                         const html = displayIssues.length > 0 \n965:                             ? displayIssues.map(issue => \\`\n966:                                 <div class=\"issue-item\" onclick=\"jumpToLine(\\${issue.line})\">\n967:                                     <span class=\"issue-icon\">\\${issue.icon}</span>\n968:                                     <div class=\"issue-content\">\n969:                                         <div class=\"issue-line\">L\\${issue.line + 1}</div>\n970:                                         <div class=\"issue-message\">\\${issue.message}</div>\n971:                                     </div>\n972:                                 </div>\n973:                             \\`).join('')\n974:                             : '<div style=\"color: var(--vscode-descriptionForeground); font-size: 11px; padding: 8px;\">No issues detected</div>';\n975:                         \n976:                         document.getElementById('issues-list').innerHTML = html;\n977:                         document.getElementById('issues-count').textContent = displayIssues.length;\n978:                     }\n979:                     \n\n(Output capped at 50 KB. Showing lines 1-979. Use offset=980 to continue.)\n</content>",
      "status": "success",
