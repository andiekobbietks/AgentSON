      "output": "<path>C:\\Users\\LLM-Test\\Documents\\agentsong\\cli\\main.py</path>\n<type>file</type>\n<content>\n350: \n351: def render_html(data: dict) -> str:\n352:     \"\"\"Render AgentSON data as HTML.\"\"\"\n353:     md = render_markdown(data)\n354:     # Simple HTML wrapping - in production, use a proper markdown parser\n355:     return f\"\"\"<!DOCTYPE html>\n356: <html>\n357: <head>\n358:     <meta charset=\"UTF-8\">\n359:     <title>Agent Session: {data.get('id', 'Unknown')}</title>\n360:     <style>\n361:         body {{ font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; line-height: 1.6; }}\n362:         pre {{ background: #f5f5f5; padding: 12px; border-radius: 4px; overflow-x: auto; }}\n363:         blockquote {{ border-left: 4px solid #ddd; margin: 0; padding: 0 16px; color: #666; }}\n364:         h1, h2, h3 {{ color: #333; }}\n365:         hr {{ border: none; border-top: 1px solid #eee; margin: 20px 0; }}\n366:     </style>\n367: </head>\n368: <body>\n369: <pre>{md}</pre>\n370: </body>\n371: </html>\"\"\"\n372: \n373: \n374: def cmd_import(args):\n375:     \"\"\"Import sessions from external formats.\"\"\"\n376:     if args.format == \"chatgpt\":\n377:         from importers.chatgpt import import_chatgpt\n378:         \n379:         output_dir = Path(args.output)\n\n(Showing lines 350-379 of 572. Use offset=380 to continue.)\n</content>",
