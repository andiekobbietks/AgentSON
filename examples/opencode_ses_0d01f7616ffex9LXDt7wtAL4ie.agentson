      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\agentsong\\\\docs\\\\index.html\"}",
      "output": "<path>C:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\index.html</path>\n<type>file</type>\n<content>\n1: <!DOCTYPE html>\n2: <html lang=\"en\">\n3: <head>\n4:     <meta charset=\"UTF-8\">\n5:     <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n6:     <title>AgentSON — Your AI history. Your hardware. Your choice.</title>\n7:     <meta name=\"description\" content=\"A vendor-neutral format for AI agent sessions. Capture, replay, and fine-tune on your own data — across any tool, any hardware, forever.\">\n8:     <style>\n9:         :root {\n10:             --bg: #0a0a0f;\n11:             --surface: #12121a;\n12:             --surface-2: #1a1a26;\n13:             --border: #2a2a3a;\n14:             --text: #e0e0e8;\n15:             --text-muted: #8888a0;\n16:             --accent: #00d4ff;\n17:             --accent-dim: rgba(0, 212, 255, 0.12);\n18:             --accent-glow: rgba(0, 212, 255, 0.25);\n19:             --success: #00ff88;\n20:             --warning: #ffaa00;\n21:             --error: #ff4444;\n22:             --amber: #ffb000;\n23:         }\n24: \n25:         * { box-sizing: border-box; margin: 0; padding: 0; }\n26: \n27:         body {\n28:             font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n29:             background: var(--bg);\n30:             color: var(--text);\n31:             line-height: 1.6;\n32:         }\n33: \n34:         /* ── Nav ── */\n35:         nav {\n36:             position: sticky;\n37:             top: 0;\n38:             z-index: 100;\n39:             background: rgba(10, 10, 15, 0.85);\n40:             backdrop-filter: blur(12px);\n41:             border-bottom: 1px solid var(--border);\n42:             padding: 0.75rem 2rem;\n43:             display: flex;\n44:             justify-content: space-between;\n45:             align-items: center;\n46:         }\n47: \n48:         .nav-brand {\n49:             font-weight: 700;\n50:             font-size: 1.1rem;\n51:             color: var(--accent);\n52:             text-decoration: none;\n53:         }\n54: \n55:         .nav-links { display: flex; gap: 1.5rem; align-items: center; }\n56: \n57:         .nav-links a {\n58:             color: var(--text-muted);\n59:             text-decoration: none;\n60:             font-size: 0.9rem;\n61:             transition: color 0.2s;\n62:         }\n63: \n64:         .nav-links a:hover { color: var(--accent); }\n65: \n66:         .nav-links .gh-link {\n67:             display: inline-flex;\n68:             align-items: center;\n69:             gap: 0.4rem;\n70:             padding: 0.35rem 0.8rem;\n71:             border: 1px solid var(--border);\n72:             border-radius: 6px;\n73:             font-size: 0.85rem;\n74:         }\n75: \n76:         .nav-links .gh-link:hover { border-color: var(--accent); }\n77: \n78:         .nav-links .star-btn {\n79:             background: var(--accent);\n80:             color: #000;\n81:             border: none;\n82:             padding: 0.35rem 0.8rem;\n83:             border-radius: 6px;\n84:             font-weight: 600;\n85:             font-size: 0.85rem;\n86:             cursor: pointer;\n87:             text-decoration: none;\n88:         }\n89: \n90:         /* ── Hero ── */\n91:         .hero {\n92:             text-align: center;\n93:             padding: 5rem 2rem 4rem;\n94:             max-width: 800px;\n95:             margin: 0 auto;\n96:         }\n97: \n98:         .hero-badge {\n99:             display: inline-block;\n100:             padding: 0.3rem 0.9rem;\n101:             background: var(--accent-dim);\n102:             border: 1px solid var(--accent);\n103:             border-radius: 20px;\n104:             font-size: 0.8rem;\n105:             color: var(--accent);\n106:             margin-bottom: 1.5rem;\n107:             letter-spacing: 0.05em;\n108:         }\n109: \n110:         .hero h1 {\n111:             font-size: clamp(2rem, 5vw, 3.2rem);\n112:             font-weight: 700;\n113:             line-height: 1.2;\n114:             margin-bottom: 1rem;\n115:         }\n116: \n117:         .hero h1 .accent { color: var(--accent); }\n118: \n119:         .hero .subtitle {\n120:             font-size: 1.15rem;\n121:             color: var(--text-muted);\n122:             max-width: 600px;\n123:             margin: 0 auto 2rem;\n124:         }\n125: \n126:         .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }\n127: \n128:         .btn {\n129:             display: inline-block;\n130:             padding: 0.7rem 1.5rem;\n131:             border-radius: 8px;\n132:             font-weight: 600;\n133:             font-size: 0.95rem;\n134:             text-decoration: none;\n135:             transition: all 0.2s;\n136:             cursor: pointer;\n137:         }\n138: \n139:         .btn-primary { background: var(--accent); color: #000; }\n140:         .btn-primary:hover { background: #33ddff; }\n141: \n142:         .btn-outline { border: 1px solid var(--border); color: var(--text); }\n143:         .btn-outline:hover { border-color: var(--accent); color: var(--accent); }\n144: \n145:         /* ── Section ── */\n146:         section {\n147:             padding: 4rem 2rem;\n148:             max-width: 1100px;\n149:             margin: 0 auto;\n150:         }\n151: \n152:         section + section { border-top: 1px solid var(--border); }\n153: \n154:         .section-label {\n155:             font-size: 0.75rem;\n156:             text-transform: uppercase;\n157:             letter-spacing: 0.1em;\n158:             color: var(--accent);\n159:             margin-bottom: 0.5rem;\n160:         }\n161: \n162:         h2 {\n163:             font-size: 2rem;\n164:             font-weight: 700;\n165:             margin-bottom: 1rem;\n166:         }\n167: \n168:         h3 { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.75rem; }\n169: \n170:         .muted { color: var(--text-muted); }\n171: \n172:         /* ── Problem section ── */\n173:         .problem-grid {\n174:             display: grid;\n175:             grid-template-columns: 1fr 1fr;\n176:             gap: 2rem;\n177:             margin-top: 2rem;\n178:         }\n179: \n180:         .problem-card {\n181:             background: var(--surface);\n182:             border: 1px solid var(--border);\n183:             border-radius: 12px;\n184:             padding: 1.5rem;\n185:         }\n186: \n187:         .problem-card h3 { font-size: 1rem; }\n188: \n189:         .problem-card .icon {\n190:             font-size: 1.5rem;\n191:             margin-bottom: 0.75rem;\n192:         }\n193: \n194:         /* ── Three Layers ── */\n195:         .layers-grid {\n196:             display: grid;\n197:             grid-template-columns: repeat(3, 1fr);\n198:             gap: 1.5rem;\n199:             margin-top: 2rem;\n200:         }\n201: \n202:         .layer-card {\n203:             background: var(--surface);\n204:             border: 1px solid var(--border);\n205:             border-radius: 12px;\n206:             padding: 1.5rem;\n207:             text-align: center;\n208:         }\n209: \n210:         .layer-card .layer-num {\n211:             display: inline-block;\n212:             width: 2rem;\n213:             height: 2rem;\n214:             line-height: 2rem;\n215:             border-radius: 50%;\n216:             background: var(--accent-dim);\n217:             color: var(--accent);\n218:             font-weight: 700;\n219:             font-size: 0.85rem;\n220:             margin-bottom: 0.75rem;\n221:         }\n222: \n223:         .layer-card h3 { font-size: 1.1rem; }\n224:         .layer-card .layer-desc { color: var(--text-muted); font-size: 0.9rem; }\n225: \n226:         .layer-card .version-badge {\n227:             display: inline-block;\n228:             padding: 0.15rem 0.5rem;\n229:             background: var(--accent-dim);\n230:             border-radius: 4px;\n231:             font-size: 0.7rem;\n232:             color: var(--accent);\n233:             margin-top: 0.5rem;\n234:         }\n235: \n236:         /* ── Benchmarks ── */\n237:         .bench-grid {\n238:             display: grid;\n239:             grid-template-columns: repeat(4, 1fr);\n240:             gap: 1rem;\n241:             margin-top: 2rem;\n242:         }\n243: \n244:         .bench-card {\n245:             background: var(--surface);\n246:             border: 1px solid var(--border);\n247:             border-radius: 12px;\n248:             padding: 1.25rem;\n249:             text-align: center;\n250:         }\n251: \n252:         .bench-card .bench-value {\n253:             font-size: 1.8rem;\n254:             font-weight: 700;\n255:             color: var(--accent);\n256:             line-height: 1;\n257:         }\n258: \n259:         .bench-card .bench-label {\n260:             font-size: 0.75rem;\n261:             color: var(--text-muted);\n262:             margin-top: 0.25rem;\n263:         }\n264: \n265:         .bench-card .bench-detail {\n266:             font-size: 0.8rem;\n267:             color: var(--text-muted);\n268:             margin-top: 0.5rem;\n269:             border-top: 1px solid var(--border);\n270:             padding-top: 0.5rem;\n271:         }\n272: \n273:         /* ── Hardware ── */\n274:         .hw-grid {\n275:             display: grid;\n276:             grid-template-columns: repeat(3, 1fr);\n277:             gap: 1.5rem;\n278:             margin-top: 2rem;\n279:         }\n280: \n281:         .hw-card {\n282:             background: var(--surface);\n283:             border: 1px solid var(--border);\n284:             border-radius: 12px;\n285:             padding: 1.5rem;\n286:         }\n287: \n288:         .hw-card h3 { font-size: 1rem; margin-bottom: 0.5rem; }\n289: \n290:         .hw-card .hw-price {\n291:             font-size: 1.5rem;\n292:             font-weight: 700;\n293:             color: var(--accent);\n294:         }\n295: \n296:         .hw-card .hw-meta {\n297:             font-size: 0.8rem;\n298:             color: var(--text-muted);\n299:             margin-top: 0.5rem;\n300:         }\n301: \n302:         .hw-card .hw-score {\n303:             display: inline-block;\n304:             padding: 0.2rem 0.6rem;\n305:             background: var(--accent-dim);\n306:             border-radius: 4px;\n307:             font-size: 0.75rem;\n308:             color: var(--accent);\n309:             margin-top: 0.75rem;\n310:         }\n311: \n312:         .hw-card .btn { margin-top: 1rem; width: 100%; text-align: center; }\n313: \n314:         /* ── Why ── */\n315:         .why-grid {\n316:             display: grid;\n317:             grid-template-columns: repeat(3, 1fr);\n318:             gap: 1.5rem;\n319:             margin-top: 2rem;\n320:         }\n321: \n322:         .why-card {\n323:             background: var(--surface);\n324:             border: 1px solid var(--border);\n325:             border-radius: 12px;\n326:             padding: 1.5rem;\n327:         }\n328: \n329:         .why-card .icon { font-size: 1.5rem; margin-bottom: 0.75rem; }\n330:         .why-card h3 { font-size: 1rem; }\n331:         .why-card p { color: var(--text-muted); font-size: 0.9rem; }\n332: \n333:         /* ── CTA ── */\n334:         .cta {\n335:             text-align: center;\n336:             padding: 4rem 2rem;\n337:             background: var(--surface);\n338:             border-top: 1px solid var(--border);\n339:         }\n340: \n341:         .cta h2 { margin-bottom: 0.5rem; }\n342:         .cta .subtitle { color: var(--text-muted); margin-bottom: 2rem; }\n343: \n344:         /* ── Footer ── */\n345:         footer {\n346:             text-align: center;\n347:             padding: 2rem;\n348:             border-top: 1px solid var(--border);\n349:             color: var(--text-muted);\n350:             font-size: 0.8rem;\n351:         }\n352: \n353:         footer a { color: var(--accent); text-decoration: none; }\n354:         footer a:hover { text-decoration: underline; }\n355: \n356:         .footer-grid {\n357:             display: grid;\n358:             grid-template-columns: repeat(3, 1fr);\n359:             gap: 2rem;\n360:             max-width: 800px;\n361:             margin: 0 auto 2rem;\n362:             text-align: left;\n363:         }\n364: \n365:         .footer-grid h4 {\n366:             font-size: 0.85rem;\n367:             margin-bottom: 0.75rem;\n368:             color: var(--text);\n369:         }\n370: \n371:         .footer-grid a {\n372:             display: block;\n373:             color: var(--text-muted);\n374:             font-size: 0.8rem;\n375:             margin-bottom: 0.4rem;\n376:         }\n377: \n378:         /* ── Responsive ── */\n379:         @media (max-width: 768px) {\n380:             .layers-grid, .hw-grid, .why-grid, .footer-grid { grid-template-columns: 1fr; }\n381:             .bench-grid { grid-template-columns: repeat(2, 1fr); }\n382:             .problem-grid { grid-template-columns: 1fr; }\n383:             nav { padding: 0.75rem 1rem; }\n384:             .nav-links { gap: 0.75rem; }\n385:             section { padding: 3rem 1.5rem; }\n386:         }\n387:     </style>\n388: </head>\n389: <body>\n390: \n391: <!-- ── Nav ── -->\n392: <nav>\n393:     <a href=\"#\" class=\"nav-brand\">.agentson</a>\n394:     <div class=\"nav-links\">\n395:         <a href=\"#benchmarks\">Benchmarks</a>\n396:         <a href=\"#hardware\">Buy hardware</a>\n397:         <a href=\"https://github.com/andiekobbietks/AgentSON\" class=\"gh-link\" target=\"_blank\" rel=\"noopener\">GitHub ↗</a>\n398:         <a href=\"https://github.com/andiekobbietks/AgentSON#quick-start\" class=\"star-btn\" target=\"_blank\" rel=\"noopener\">Install</a>\n399:         <a href=\"https://github.com/andiekobbietks/AgentSON\" class=\"star-btn\" target=\"_blank\" rel=\"noopener\">Star ★</a>\n400:     </div>\n401: </nav>\n402: \n403: <!-- ── Hero ── -->\n404: <div class=\"hero\">\n405:     <span class=\"hero-badge\">v0.1 · MIT licensed · Built solo from Cardiff</span>\n406:     <h1>Your AI history.<br>Your hardware.<br>Your <span class=\"accent\">choice</span>.</h1>\n407:     <p class=\"subtitle\">A vendor-neutral format for AI agent sessions. Capture, replay, and fine-tune on your own data — across any tool, any hardware, forever.</p>\n408:     <div class=\"hero-actions\">\n409:         <a href=\"https://github.com/andiekobbietks/AgentSON#quick-start\" class=\"btn btn-primary\" target=\"_blank\" rel=\"noopener\">See benchmarks →</a>\n410:         <a href=\"#hardware\" class=\"btn btn-outline\">Buy the right hardware</a>\n411:         <a href=\"https://github.com/andiekobbietks/AgentSON/blob/master/spec/v1.json\" class=\"btn btn-outline\" target=\"_blank\" rel=\"noopener\">Read the spec</a>\n412:     </div>\n413: </div>\n414: \n415: <!-- ── The Problem ── -->\n416: <section id=\"problem\">\n417:     <div class=\"section-label\">The problem</div>\n418:     <h2>Your AI sessions are trapped.</h2>\n419:     <div class=\"problem-grid\">\n420:         <div class=\"problem-card\">\n421:             <div class=\"icon\">🔒</div>\n422:             <h3>Vendor lock-in</h3>\n423:             <p class=\"muted\">Every AI coding agent stores session data in its own proprietary SQLite database. 21 tables here, 20 there. No standard. No portability. Your data belongs to whoever built the tool.</p>\n424:         </div>\n425:         <div class=\"problem-card\">\n426:             <div class=\"icon\">Format churn</div>\n427:             <h3>Formats change without warning</h3>\n428:             <p class=\"muted\">Chrome removed the export button in version 149. Sessions are still in your profile — but locked in a JSON blob no other tool can read. Your AI history now belongs to a vendor who can change the format at any commit.</p>\n429:         </div>\n430:         <div class=\"problem-card\">\n431:             <div class=\"icon\">Can't train</div>\n432:             <h3>No path from transcript to adapter</h3>\n433:             <p class=\"muted\">You have hundreds of useful sessions. But there's no way to turn them into training data. No standard export. No fine-tuning pipeline. Your best work dies with the tool.</p>\n434:         </div>\n435:         <div class=\"problem-card\">\n436:             <div class=\"icon\">Hardware trap</div>\n437:             <h3>Vendor marketing picks your machine</h3>\n438:             <p class=\"muted\">They sell you \"AI capability\" based on what they can ship, not what you need. You end up paying for cloud GPUs when a £95 Raspberry Pi could run the same adapter.</p>\n439:         </div>\n440:     </div>\n441: </section>\n442: \n443: <!-- ── Three Layers ── -->\n444: <section id=\"layers\">\n445:     <div class=\"section-label\">One format, three layers</div>\n446:     <h2>Same data, any hardware.</h2>\n447:     <p class=\"muted\" style=\"max-width: 600px; margin-bottom: 1rem;\">Same corpus, any hardware. One format that travels from your laptop to a Pi to an RTX 4090 — no conversion, no cloud, no account.</p>\n448:     <div class=\"layers-grid\">\n449:         <div class=\"layer-card\">\n450:             <div class=\"layer-num\">1</div>\n451:             <h3>Format</h3>\n452:             <p class=\"layer-desc\">Portable transcript — typed JSON schema capturing user-query, thought, action, answer, side-effect, context. Works across Cursor, Claude, DevTools, AI Studio. Vendor-neutral. MIT.</p>\n453:             <span class=\"version-badge\">v0.1</span>\n454:         </div>\n455:         <div class=\"layer-card\">\n456:             <div class=\"layer-num\">2</div>\n457:             <h3>Train</h3>\n458:             <p class=\"layer-desc\">Edge fine-tuning — same corpus fine-tunes on Unsloth (GPU), Olive + ONNX (NPU/CPU), or Google Colab (no GPU). Adapters are 50–200 MB. Sync between devices. Federate without sharing data.</p>\n459:         </div>\n460:         <div class=\"layer-card\">\n461:             <div class=\"layer-num\">3</div>\n462:             <h3>Deploy</h3>\n463:             <p class=\"layer-desc\">Run anywhere — adapter + ONNX INT4 → runs on RTX 4090, M3 Max, Snapdragon X Elite, Raspberry Pi 5, or your browser. Live community-submitted numbers for each. No subscription. No cloud.</p>\n464:         </div>\n465:     </div>\n466: </section>\n467: \n468: <!-- ── Benchmarks ── -->\n469: <section id=\"benchmarks\">\n470:     <div class=\"section-label\">Benchmarks</div>\n471:     <h2>Real numbers from real machines</h2>\n472:     <p class=\"muted\" style=\"margin-bottom: 0.5rem;\">All numbers community-submitted. <a href=\"https://github.com/andiekobbietks/AgentSON\" style=\"color: var(--accent);\">Submit yours →</a></p>\n473:     <div class=\"bench-grid\">\n474:         <div class=\"bench-card\">\n475:             <div class=\"bench-value\">18 min</div>\n476:             <div class=\"bench-label\">Fastest training</div>\n477:             <div class=\"bench-detail\">RTX 4090 · Llama-3.2 3B QLoRA</div>\n478:         </div>\n479:         <div class=\"bench-card\">\n480:             <div class=\"bench-value\">195 tok/s</div>\n481:             <div class=\"bench-label\">Fastest inference</div>\n482:             <div class=\"bench-detail\">RTX 4090 · Llama-3.2 3B INT4</div>\n483:         </div>\n484:         <div class=\"bench-card\">\n485:             <div class=\"bench-value\">6.2 tok/s</div>\n486:             <div class=\"bench-label\">Works on legacy</div>\n487:             <div class=\"bench-detail\">GTX 1050 · 2017 laptop</div>\n488:         </div>\n489:         <div class=\"bench-card\">\n490:             <div class=\"bench-value\">2.3 tok/s</div>\n491:             <div class=\"bench-label\">Edge champion</div>\n492:             <div class=\"bench-detail\">Pi 5 · £95 · 7W</div>\n493:         </div>\n494:     </div>\n495: </section>\n496: \n497: <!-- ── Hardware ── -->\n498: <section id=\"hardware\">\n499:     <div class=\"section-label\">Hardware advisor</div>\n500:     <h2>Buy the right machine</h2>\n501:     <p class=\"muted\" style=\"max-width: 650px; margin-bottom: 0.5rem;\">We benchmark, score repairability, calculate 5-year TCO, and recommend honestly. Affiliate commissions fund the project — never buy placement.</p>\n502:     <div class=\"hw-grid\">\n503:         <div class=\"hw-card\">\n504:             <h3>Framework Laptop 13</h3>\n505:             <p class=\"hw-meta\">AMD Ryzen AI 9 · 10/10 repairability</p>\n506:             <div class=\"hw-price\">£1,399</div>\n507:             <div class=\"hw-meta\">AI workload: Phi-4-mini NPU</div>\n508:             <div class=\"hw-meta\">5-yr TCO: £1,679</div>\n509:             <span class=\"hw-score\">10/10</span>\n510:             <a href=\"https://frame.work\" class=\"btn btn-outline\" target=\"_blank\" rel=\"noopener\" style=\"display: block; text-align: center; margin-top: 1rem;\">View</a>\n511:         </div>\n512:         <div class=\"hw-card\">\n513:             <h3>Refurb RTX 3090 desktop</h3>\n514:             <p class=\"hw-meta\">CeX/eBay · modular PSU</p>\n515:             <div class=\"hw-price\">£800</div>\n516:             <div class=\"hw-meta\">AI workload: Best $/perf</div>\n517:             <div class=\"hw-meta\">5-yr TCO: £3,406</div>\n518:             <span class=\"hw-score\">10/10</span>\n519:             <a href=\"https://www.ebay.co.uk\" class=\"btn btn-outline\" target=\"_blank\" rel=\"noopener\" style=\"display: block; text-align: center; margin-top: 1rem;\">View</a>\n520:         </div>\n521:         <div class=\"hw-card\">\n522:             <h3>Raspberry Pi 5 + AI HAT+</h3>\n523:             <p class=\"hw-meta\">£95 · 7W · edge</p>\n524:             <div class=\"hw-price\">£95</div>\n525:             <div class=\"hw-meta\">AI workload: Phi-3-mini</div>\n526:             <div class=\"hw-meta\">5-yr TCO: £155</div>\n527:             <span class=\"hw-score\">10/10</span>\n528:             <a href=\"https://www.raspberrypi.com\" class=\"btn btn-outline\" target=\"_blank\" rel=\"noopener\" style=\"display: block; text-align: center; margin-top: 1rem;\">View</a>\n529:         </div>\n530:     </div>\n531: </section>\n532: \n533: <!-- ── Why ── -->\n534: <section id=\"why\">\n535:     <div class=\"section-label\">Why this exists</div>\n536:     <h2>The portability layer the AI coding ecosystem needs</h2>\n537:     <div class=\"why-grid\">\n538:         <div class=\"why-card\">\n539:             <div class=\"icon\">Solo developers</div>\n540:             <h3>Don't lose your sessions</h3>\n541:             <p>Don't lose your AI sessions when a tool updates. Search across years of help. Train a personal adapter. Run on the laptop you already have — even the old one.</p>\n542:         </div>\n543:         <div class=\"why-card\">\n544:             <div class=\"icon\">Teams</div>\n545:             <h3>Onboarding that actually works</h3>\n546:             <p>Onboard new devs with \"here's how we actually work.\" Audit AI-generated code. Share successful workflows. Compliance trail for SOC2/HIPAA/GDPR.</p>\n547:         </div>\n548:         <div class=\"why-card\">\n549:             <div class=\"icon\">Industry</div>\n550:             <h3>Open alternative to vendor lock-in</h3>\n551:             <p>An open alternative to vendor lock-in. The portability layer the AI coding ecosystem needs. No VC, no telemetry, MIT licensed, vendor-neutral.</p>\n552:         </div>\n553:     </div>\n554: </section>\n555: \n556: <!-- ── CTA ── -->\n557: <div class=\"cta\">\n558:     <h2>Ready to take your AI history with you?</h2>\n559:     <p class=\"muted\">Three commands. No cloud. No account. Your data, your hardware, forever.</p>\n560:     <div class=\"hero-actions\" style=\"margin-top: 1.5rem;\">\n561:         <a href=\"https://github.com/andiekobbietks/AgentSON#quick-start\" class=\"btn btn-primary\" target=\"_blank\" rel=\"noopener\">Install AgentSON</a>\n562:         <a href=\"#benchmarks\" class=\"btn btn-outline\">See benchmarks</a>\n563:     </div>\n564: </div>\n565: \n566: <!-- ── Footer ── -->\n567: <footer>\n568:     <div class=\"footer-grid\">\n569:         <div>\n570:             <h4>.agentson</h4>\n571:             <p class=\"muted\" style=\"font-size: 0.8rem;\">Portable format for AI agent transcripts. Built by Andie Kobbie in Cardiff, Wales.</p>\n572:         </div>\n573:         <div>\n574:             <h4>Project</h4>\n575:             <a href=\"#benchmarks\">Benchmarks</a>\n576:             <a href=\"#hardware\">Hardware advisor</a>\n577:             <a href=\"https://github.com/andiekobbietks/AgentSON/blob/master/spec/v1.json\" target=\"_blank\" rel=\"noopener\">Spec (v1)</a>\n578:             <a href=\"https://github.com/andiekobbietks/AgentSON\" target=\"_blank\" rel=\"noopener\">GitHub</a>\n579:         </div>\n580:         <div>\n581:             <h4>Learn</h4>\n582:             <a href=\"https://github.com/andiekobbietks/AgentSON#quick-start\" target=\"_blank\" rel=\"noopener\">Quickstart</a>\n583:             <a href=\"dev/\">Dev docs</a>\n584:             <a href=\"https://github.com/andiekobbietks/AgentSON/discussions\" target=\"_blank\" rel=\"noopener\">Discussions</a>\n585:             <a href=\"#\">Affiliate policy</a>\n586:         </div>\n587:     </div>\n588:     <p style=\"margin-top: 1rem;\">Affiliate disclosure: Links to retailers may earn a small commission at no cost to you. Funds the open-source `.agentson` project. We never promote anything that doesn't benchmark well on our matrix. Repairability scores sourced from iFixit. MIT license · v0.1 · 2026</p>\n589: </footer>\n590: \n591: </body>\n592: </html>\n\n(End of file - total 592 lines)\n</content>",
