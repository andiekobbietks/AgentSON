      "output": "<path>C:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\index.html</path>\n<type>file</type>\n<content>\n1: <!DOCTYPE html>\n2: <html lang=\"en\">\n3: <head>\n4:     <meta charset=\"UTF-8\">\n5:     <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n6:     <title>SOPs — AgentSON</title>\n7:     <style>\n8:         :root {\n9:             --bg: #0d1117;\n10:             --surface: #161b22;\n11:             --border: #30363d;\n12:             --text: #c9d1d9;\n13:             --text-muted: #8b949e;\n14:             --accent: #58a6ff;\n15:         }\n16:         * { margin: 0; padding: 0; box-sizing: border-box; }\n17:         body {\n18:             font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n19:             background: var(--bg);\n20:             color: var(--text);\n21:             line-height: 1.6;\n22:         }\n23:         .container { max-width: 900px; margin: 0 auto; padding: 20px; }\n24:         header { padding: 40px 0; border-bottom: 1px solid var(--border); }\n25:         h1 { font-size: 32px; }\n26:         h1 span { color: var(--accent); }\n27:         .back { color: var(--accent); text-decoration: none; }\n28:         .back:hover { text-decoration: underline; }\n29:         .sop-list { margin-top: 30px; }\n30:         .sop {\n31:             background: var(--surface);\n32:             border: 1px solid var(--border);\n33:             border-radius: 8px;\n34:             padding: 20px;\n35:             margin-bottom: 15px;\n36:             display: flex;\n37:             justify-content: space-between;\n38:             align-items: center;\n39:         }\n40:         .sop h3 { font-size: 16px; }\n41:         .sop p { color: var(--text-muted); font-size: 14px; }\n42:         .sop a {\n43:             color: var(--accent);\n44:             text-decoration: none;\n45:             padding: 8px 16px;\n46:             border: 1px solid var(--accent);\n47:             border-radius: 6px;\n48:             font-size: 14px;\n49:         }\n50:         .sop a:hover { background: var(--accent); color: #000; }\n51:     </style>\n52: </head>\n53: <body>\n54:     <div class=\"container\">\n55:         <header>\n56:             <a href=\"../\" class=\"back\">← Back to AgentSON</a>\n57:             <h1 style=\"margin-top: 20px;\">Standard Operating Procedures</h1>\n58:             <p style=\"color: var(--text-muted);\">14 SOPs for diabetes monitoring and AI session management</p>\n59:         </header>\n60:         <div class=\"sop-list\">\n61:             <div class=\"sop\">\n62:                 <div>\n63:                     <h3>SOP-001</h3>\n64:                     <p>Reading FreeStyle Libre 2 Sensor</p>\n65:                 </div>\n66:                 <a href=\"SOP-001-Reading-FreeStyle-Libre-2-Sensor.md\">View</a>\n67:             </div>\n68:             <div class=\"sop\">\n69:                 <div>\n70:                     <h3>SOP-002</h3>\n71:                     <p>Converting Libre Data to AgentSON</p>\n72:                 </div>\n73:                 <a href=\"SOP-002-Converting-Libre-Data-to-AgentSON.md\">View</a>\n74:             </div>\n75:             <div class=\"sop\">\n76:                 <div>\n77:                     <h3>SOP-003</h3>\n78:                     <p>Viewing Glucose Data in Browser</p>\n79:                 </div>\n80:                 <a href=\"SOP-003-Viewing-Glucose-Data-in-Browser.md\">View</a>\n81:             </div>\n82:             <div class=\"sop\">\n83:                 <div>\n84:                     <h3>SOP-004</h3>\n85:                     <p>Exporting AI Sessions</p>\n86:                 </div>\n87:                 <a href=\"SOP-004-Exporting-AI-Sessions.md\">View</a>\n88:             </div>\n89:             <div class=\"sop\">\n90:                 <div>\n91:                     <h3>SOP-005</h3>\n92:                     <p>Searching AI Sessions</p>\n93:                 </div>\n94:                 <a href=\"SOP-005-Searching-AI-Sessions.md\">View</a>\n95:             </div>\n96:             <div class=\"sop\">\n97:                 <div>\n98:                     <h3>SOP-006</h3>\n99:                     <p>Sharing Data with Doctors</p>\n100:                 </div>\n101:                 <a href=\"SOP-006-Sharing-Data-with-Doctors.md\">View</a>\n102:             </div>\n103:             <div class=\"sop\">\n104:                 <div>\n105:                     <h3>SOP-007</h3>\n106:                     <p>Setting Up Nightscout Server</p>\n107:                 </div>\n108:                 <a href=\"SOP-007-Setting-Up-Nightscout-Server.md\">View</a>\n109:             </div>\n110:             <div class=\"sop\">\n111:                 <div>\n112:                     <h3>SOP-008</h3>\n113:                     <p>WhatsApp Bot Setup</p>\n114:                 </div>\n115:                 <a href=\"SOP-008-WhatsApp-Bot-Setup.md\">View</a>\n116:             </div>\n117:             <div class=\"sop\">\n118:                 <div>\n119:                     <h3>SOP-009</h3>\n120:                     <p>TV Dashboard Setup</p>\n121:                 </div>\n122:                 <a href=\"SOP-009-TV-Dashboard-Setup.md\">View</a>\n123:             </div>\n124:             <div class=\"sop\">\n125:                 <div>\n126:                     <h3>SOP-010</h3>\n127:                     <p>Setting Up MedGemma / HAI-DEF</p>\n128:                 </div>\n129:                 <a href=\"SOP-010-Setting-Up-MedGemma-HAI-DEF.md\">View</a>\n130:             </div>\n131:             <div class=\"sop\">\n132:                 <div>\n133:                     <h3>SOP-011</h3>\n134:                     <p>Fine-tuning MedGemma on Glucose Data</p>\n135:                 </div>\n136:                 <a href=\"SOP-011-Fine-tuning-MedGemma-on-Glucose-Data.md\">View</a>\n137:             </div>\n138:             <div class=\"sop\">\n139:                 <div>\n140:                     <h3>SOP-012</h3>\n141:       