      "output": "<path>C:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\dev\\index.html</path>\n<type>file</type>\n<content>\n1: <!DOCTYPE html>\n2: <html lang=\"en\">\n3: <head>\n4:     <meta charset=\"UTF-8\">\n5:     <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n6:     <title>AgentSON — Dev Docs</title>\n7:     <style>\n8:         :root {\n9:             --bg: #0d1117;\n10:             --surface: #161b22;\n11:             --border: #30363d;\n12:             --text: #c9d1d9;\n13:             --text-muted: #8b949e;\n14:             --accent: #58a6ff;\n15:             --success: #3fb950;\n16:             --warning: #d29922;\n17:             --error: #f85149;\n18:         }\n19: \n20:         * { margin: 0; padding: 0; box-sizing: border-box; }\n21: \n22:         body {\n23:             font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n24:             background: var(--bg);\n25:             color: var(--text);\n26:             line-height: 1.6;\n27:         }\n28: \n29:         .container { max-width: 1200px; margin: 0 auto; padding: 20px; }\n30: \n31:         header {\n32:             text-align: center;\n33:             padding: 60px 20px;\n34:             border-bottom: 1px solid var(--border);\n35:         }\n36: \n37:         h1 { font-size: 48px; margin-bottom: 10px; }\n38:         h1 span { color: var(--accent); }\n39: \n40:         .tagline {\n41:             font-size: 20px;\n42:             color: var(--text-muted);\n43:             margin-bottom: 30px;\n44:         }\n45: \n46:         .badge {\n47:             display: inline-block;\n48:             padding: 8px 16px;\n49:             background: var(--accent);\n50:             color: #000;\n51:             border-radius: 20px;\n52:             font-weight: 600;\n53:             margin: 5px;\n54:         }\n55: \n56:         section { padding: 60px 20px; border-bottom: 1px solid var(--border); }\n57: \n58:         h2 { font-size: 32px; margin-bottom: 20px; color: var(--accent); }\n59:         h3 { font-size: 24px; margin-bottom: 15px; }\n60: \n61:         .grid {\n62:             display: grid;\n63:             grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n64:             gap: 20px;\n65:             margin-top: 30px;\n66:         }\n67: \n68:         .card {\n69:             background: var(--surface);\n70:             border: 1px solid var(--border);\n71:             border-radius: 8px;\n72:             padding: 24px;\n73:         }\n74: \n75:         .card h3 { color: var(--text); font-size: 18px; }\n76:         .card p { color: var(--text-muted); font-size: 14px; }\n77: \n78:         .status {\n79:             display: inline-block;\n80:             padding: 4px 8px;\n81:             border-radius: 4px;\n82:             font-size: 12px;\n83:             font-weight: 600;\n84:         }\n85: \n86:         .status-done { background: var(--success); color: #000; }\n87:         .status-progress { background: var(--warning); color: #000; }\n88:         .status-planned { background: var(--text-muted); color: #000; }\n89: \n90:         pre {\n91:             background: var(--bg);\n92:             padding: 16px;\n93:             border-radius: 8px;\n94:             overflow-x: auto;\n95:             margin: 20px 0;\n96:             border: 1px solid var(--border);\n97:         }\n98: \n99:         code {\n100:             font-family: 'SF Mono', Monaco, monospace;\n101:             font-size: 14px;\n102:         }\n103: \n104:         .btn {\n105:             display: inline-block;\n106:             padding: 12px 24px;\n107:             background: var(--accent);\n108:             color: #000;\n109:             text-decoration: none;\n110:             border-radius: 6px;\n111:             font-weight: 600;\n112:             margin: 10px 5px;\n113:         }\n114: \n115:         .btn:hover { opacity: 0.9; }\n116: \n117:         .btn-outline {\n118:             background: transparent;\n119:             border: 1px solid var(--accent);\n120:             color: var(--accent);\n121:         }\n122: \n123:         .stats {\n124:             display: flex;\n125:             justify-content: center;\n126:             gap: 40px;\n127:             margin-top: 30px;\n128:         }\n129: \n130:         .stat { text-align: center; }\n131:         .stat-value { font-size: 36px; font-weight: 700; color: var(--accent); }\n132:         .stat-label { font-size: 14px; color: var(--text-muted); }\n133: \n134:         footer {\n135:             text-align: center;\n136:             padding: 40px 20px;\n137:             color: var(--text-muted);\n138:             font-size: 14px;\n139:         }\n140: \n141:         @media (max-width: 768px) {\n142:             h1 { font-size: 32px; }\n143:             .stats { flex-direction: column; gap: 20px; }\n144:         }\n145:     </style>\n146: </head>\n147: <body>\n148:     <nav style=\"background:#161b22;padding:10px 20px;border-bottom:1px solid #30363d;text-align:center;\">\n149:         <a href=\"../\" style=\"color:#58a6ff;text-decoration:none;margin-right:20px;\">← Back to AgentSON</a>\n150:         <span style=\"color:#8b949e;\">Dev Docs</span>\n151:     </nav>\n152:     <header>\n153:         <h1><span>Agent</span>SON</h1>\n154:         <p class=\"tagline\">Agent + JSON — Yet Another JSON, but metadata-rich and built for the agentic era.</p>\n155:         <div>\n156:             <span class=\"badge\">Open Source</span>\n157:             <span class=\"badge\">Free Forever</span>\n158:             <span class=\"badge\">NHS Ready</span>\n159:         </div>\n160:         <div style=\"margin-top: 30px;\">\n161:             <a href=\"https://github.com/andiekobbietks/AgentSON\" class=\"btn\">GitHub</a>\n162:             <a href=\"viewer/\" class=\"btn btn-outline\">Launch Viewer</a>\n163:             <a href=\"sops/\" class=\"btn btn-outline\">SOPs</a>\n164:         </div>\n165:     </header>\n166: \n167:     <section>\n168:         <h2>The Problem</h2>\n169:         <p>Every AI coding agent stores session data in its own proprietary SQLite database. There is no standard format, no export API, and no way to move context between tools.</p>\n170:         <div class=\"grid\">\n171:             <div class=\"card\">\n172:                 <h3>opencode</h3>\n173:                 <p>21 tables, custom schema, no export API</p>\n174:             </div>\n175:             <div class=\"card\">\n176:                 <h3>MiniMax</h3>\n177:                 <p>20 tables, different schema, no portability</p>\n178:             </div>\n179:             <div class=\"card\">\n180:                 <h3>Antigravity IDE</h3>\n181:                 <p>7 tables, protobuf blobs, no standardization</p>\n182:             </div>\n183:         </div>\n184:     </section>\n185: \n186:     <section>\n187:         <h2>The Solution</h2>\n188:         <p>AgentSON provides a vendor-neutral format for agent session capture.</p>\n189:         <div class=\"grid\">\n190:             <div class=\"card\">\n191:                 <h3>✅ Specification</h3>\n192:                 <p>JSON Schema for agent session data</p>\n193:                 <span class=\"status status-done\">Done</span>\n194:             </div>\n195:             <div class=\"card\">\n196:                 <h3>✅ Readers</h3>\n197:                 <p>SQLite parsers for opencode, MiniMax, Antigravity</p>\n198:                 <span class=\"status status-done\">Done</span>\n199:             </div>\n200:             <div class=\"card\">\n201:                 <h3>✅ CLI</h3>\n202:                 <p>Export, search, render, push/pull</p>\n203:                 <span class=\"status status-done\">Done</span>\n204:             </div>\n205:             <div class=\"card\">\n206:                 <h3>✅ Web Viewer</h3>\n207:                 <p>Drag & drop visualization</p>\n208:                 <span class=\"status status-done\">Done</span>\n209:             </div>\n210:             <div class=\"card\">\n211:                 <h3>✅ Glucose Reader</h3>\n212:                 <p>FreeStyle Libre 2 CSV → AgentSON</p>\n213:                 <span class=\"status status-done\">Done</span>\n214:             </div>\n215:             <div class=\"card\">\n216:                 <h3>✅ SOPs</h3>\n217:                 <p>14 Standard Operating Procedures</p>\n218:                 <span class=\"status status-done\">Done</span>\n219:             </div>\n220:         </div>\n221:     </section>\n222: \n223:     <section>\n224:         <h2>Quick Start</h2>\n225:         <pre><code># List sessions\n226: python cli/main.py list --tool opencode\n227: \n228: # Export a session\n229: python cli/main.py export --tool opencode --session ses_xxx\n230: \n231: # Export glucose data\n232: python cli/main.py export --tool libre --input libre_data.csv\n233: \n234: # Push to Supabase\n235: python cli/main.py push session.AgentSON\n236: \n237: # Pull from Supabase\n238: python cli/main.py pull --search \"nightscout\"</code></pre>\n239:     </section>\n240: \n241:     <section>\n242:         <h2>Supported Tools</h2>\n243:         <div class=\"grid\">\n244:             <div class=\"card\">\n245:                 <h3>opencode</h3>\n246:                 <p>✅ Working</p>\n247:                 <span class=\"status status-done\">Done</span>\n248:             </div>\n249:             <div class=\"card\">\n250:                 <h3>MiniMax</h3>\n251:                 <p>✅ Working</p>\n252:                 <span class=\"status status-done\">Done</span>\n253:             </div>\n254:             <div class=\"card\">\n255:                 <h3>Antigravity IDE</h3>\n256:                 <p>✅ Working</p>\n257:                 <span class=\"status status-done\">Done</span>\n258:             </div>\n259:             <div class=\"card\">\n260:                 <h3>FreeStyle Libre 2</h3>\n261:                 <p>✅ Working</p>\n262:                 <span class=\"status status-done\">Done</span>\n263:             </div>\n264:             <div class=\"card\">\n265:                 <h3>Cursor</h3>\n266:                 <p>🔜 Planned</p>\n267:                 <span class=\"status status-planned\">Planned</span>\n268:             </div>\n269:             <div class=\"card\">\n270:                 <h3>Claude Code</h3>\n271:                 <p>🔜 Planned</p>\n272:                 <span class=\"status status-planned\">Planned</span>\n273:             </div>\n274:         </div>\n275:     </section>\n276: \n277:     <section>\n278:         <h2>Diabetes Monitoring</h2>\n279:         <p>AgentSON powers real-time glucose monitoring for carers and clinicians.</p>\n280:         <div class=\"stats\">\n281:             <div class=\"stat\">\n282:                 <div class=\"stat-value\">571</div>\n283:                 <div class=\"stat-label\">Glucose Readings</div>\n284:             </div>\n285:             <div class=\"stat\">\n286:                 <div class=\"stat-value\">9.33</div>\n287:                 <div class=\"stat-label\">Avg mmol/L</div>\n288:             </div>\n289:             <div class=\"stat\">\n290:                 <div class=\"stat-value\">60.6%</div>\n291:                 <div class=\"stat-label\">Time in Range</div>\n292:             </div>\n293:             <div class=\"stat\">\n294:                 <div class=\"stat-value\">14</div>\n295:                 <div class=\"stat-label\">SOPs Written</div>\n296:             </div>\n297:         </div>\n298:     </section>\n299: \n300:     <section>\n301:         <h2>SOPs (Standard Operating Procedures)</h2>\n302:         <div class=\"grid\">\n303:             <div class=\"card\">\n304:                 <h3>SOP-001</h3>\n305:                 <p>Reading FreeStyle Libre 2 Sensor</p>\n306:             </div>\n307:             <div class=\"card\">\n308:                 <h3>SOP-002</h3>\n309:                 <p>Converting Libre Data to AgentSON</p>\n310:             </div>\n311:             <div class=\"card\">\n312:                 <h3>SOP-003</h3>\n313:                 <p>Viewing Glucose Data in Browser</p>\n314:             </div>\n315:             <div class=\"card\">\n316:                 <h3>SOP-004</h3>\n317:                 <p>Exporting AI Sessions</p>\n318:             </div>\n319:             <div class=\"card\">\n320:                 <h3>SOP-005</h3>\n321:                 <p>Searching AI Sessions</p>\n322:             </div>\n323:             <div class=\"card\">\n324:                 <h3>SOP-006</h3>\n325:                 <p>Sharing Data with Doctors</p>\n326:             </div>\n327:             <div class=\"card\">\n328:                 <h3>SOP-007</h3>\n329:                 <p>Setting Up Nightscout Server</p>\n330:             </div>\n331:             <div class=\"card\">\n332:                 <h3>SOP-008</h3>\n333:                 <p>WhatsApp Bot Setup</p>\n334:             </div>\n335:             <div class=\"card\">\n336:                 <h3>SOP-009</h3>\n337:                 <p>TV Dashboard Setup</p>\n338:             </div>\n339:             <div class=\"card\">\n340:                 <h3>SOP-010</h3>\n341:                 <p>Setting Up MedGemma/HAI-DEF</p>\n342:             </div>\n343:             <div class=\"card\">\n344:                 <h3>SOP-011</h3>\n345:                 <p>Fine-tuning MedGemma on Glucose Data</p>\n346:             </div>\n347:             <div class=\"card\">\n348:                 <h3>SOP-012</h3>\n349:                 <p>Setting Up Juggluco on Mother's Phone</p>\n350:             </div>\n351:             <div class=\"card\">\n352:                 <h3>SOP-013</h3>\n353:                 <p>NHS FHIR Integration</p>\n354:             </div>\n355:             <div class=\"card\">\n356:                 <h3>SOP-014</h3>\n357:                 <p>West Africa Voice Alerts</p>\n358:             </div>\n359:         </div>\n360:     </section>\n361: \n362:     <section>\n363:         <h2>The Stack</h2>\n364:         <pre><code>DATA COLLECTION:\n365: ├── Juggluco (mother's phone)\n366: ├── FreeStyle Libre 2 (sensor)\n367: └── Manual entry (CHWs in West Africa)\n368: \n369: DATA STORAGE:\n370: ├── Nightscout (self-hosted)\n371: ├── AgentSON (.AgentSON files)\n372: └── Supabase (optional cloud)\n373: \n374: AI/ML:\n375: ├── MedGemma (Google HAI-DEF)\n376: ├── Fine-tuned glucose model\n377: └── MedASR (speech-to-text)\n378: \n379: ALERTS:\n380: ├── WhatsApp (whatsapp-web.js)\n381: ├── SMS (Africa's Talking)\n382: ├── Voice (Coqui TTS)\n383: └── TV Dashboard\n384: \n385: CLINICAL:\n386: ├── NHS FHIR (intu)\n387: ├── EMIS/SystmOne (when available)\n388: └── GP reports (HTML/PDF)\n389: \n390: DEVELOPER TOOLS:\n391: ├── Backstage (documentation portal)\n392: ├── AgentSON (session portability)\n393: └── GitHub (version control)</code></pre>\n394:     </section>\n395: \n396:     <section>\n397:         <h2>Cost</h2>\n398:         <div class=\"grid\">\n399:             <div class=\"card\">\n400:                 <h3>Build Cost</h3>\n401:                 <p style=\"font-size: 36px; color: var(--success);\">£0</p>\n402:                 <p>All open source, free tools</p>\n403:             </div>\n404:             <div class=\"card\">\n405:                 <h3>Running Cost</h3>\n406:                 <p style=\"font-size: 36px; color: var(--success);\">£2-5/month</p>\n407:                 <p>Electricity only</p>\n408:             </div>\n409:             <div class=\"card\">\n410:                 <h3>NHS Equivalent</h3>\n411:                 <p style=\"font-size: 36px; color: var(--error);\">£50-200/month</p>\n412:                 <p>Proprietary systems</p>\n413:             </div>\n414:         </div>\n415:     </section>\n416: \n417:     <section>\n418:         <h2>Get Started</h2>\n419:         <div style=\"text-align: center;\">\n420:             <a href=\"https://github.com/andiekobbietks/AgentSON\" class=\"btn\">View on GitHub</a>\n421:             <a href=\"viewer/\" class=\"btn btn-outline\">Launch Web Viewer</a>\n422:             <a href=\"sops/\" class=\"btn btn-outline\">Read SOPs</a>\n423:         </div>\n424:     </section>\n425: \n426:     <footer>\n427:         <p>AgentSON — Agent + JSON</p>\n428:         <p>Built with ❤️ for carers, clinicians, and communities.</p>\n429:         <p>© 2026 Andrea Enning (AndieKobbieTech)</p>\n430:     </footer>\n431: </body>\n432: </html>\n\n(End of file - total 432 lines)\n</content>",
