      "output": "<path>C:\\Users\\LLM-Test\\Documents\\agentsong\\viewers\\web\\index.html</path>\n<type>file</type>\n<content>\n1: <!DOCTYPE html>\n2: <html lang=\"en\">\n3: <head>\n4:     <meta charset=\"UTF-8\">\n5:     <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n6:     <title>AgentSON Viewer</title>\n7:     <style>\n8:         :root {\n9:             --bg: #0d1117;\n10:             --surface: #161b22;\n11:             --border: #30363d;\n12:             --text: #c9d1d9;\n13:             --text-muted: #8b949e;\n14:             --accent: #58a6ff;\n15:             --success: #3fb950;\n16:             --warning: #d29922;\n17:             --error: #f85149;\n18:         }\n19: \n20:         * {\n21:             margin: 0;\n22:             padding: 0;\n23:             box-sizing: border-box;\n24:         }\n25: \n26:         body {\n27:             font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n28:             background: var(--bg);\n29:             color: var(--text);\n30:             line-height: 1.6;\n31:         }\n32: \n33:         .container {\n34:             max-width: 1200px;\n35:             margin: 0 auto;\n36:             padding: 20px;\n37:         }\n38: \n39:         header {\n40:             border-bottom: 1px solid var(--border);\n41:             padding: 20px 0;\n42:             margin-bottom: 20px;\n43:         }\n44: \n45:         h1 {\n46:             font-size: 24px;\n47:             font-weight: 600;\n48:         }\n49: \n50:         h1 span {\n51:             color: var(--accent);\n52:         }\n53: \n54:         .drop-zone {\n55:             border: 2px dashed var(--border);\n56:             border-radius: 8px;\n57:             padding: 40px;\n58:             text-align: center;\n59:             margin-bottom: 20px;\n60:             cursor: pointer;\n61:             transition: border-color 0.2s;\n62:         }\n63: \n64:         .drop-zone:hover,\n65:         .drop-zone.dragover {\n66:             border-color: var(--accent);\n67:         }\n68: \n69:         .drop-zone p {\n70:             color: var(--text-muted);\n71:             margin-bottom: 10px;\n72:         }\n73: \n74:         .session-info {\n75:             background: var(--surface);\n76:             border: 1px solid var(--border);\n77:             border-radius: 8px;\n78:             padding: 16px;\n79:             margin-bottom: 20px;\n80:         }\n81: \n82:         .session-info h2 {\n83:             font-size: 16px;\n84:             margin-bottom: 12px;\n85:         }\n86: \n87:         .meta-grid {\n88:             display: grid;\n89:             grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n90:             gap: 12px;\n91:         }\n92: \n93:         .meta-item {\n94:             font-size: 14px;\n95:         }\n96: \n97:         .meta-item .label {\n98:             color: var(--text-muted);\n99:         }\n100: \n101:         .entries {\n102:             display: flex;\n103:             flex-direction: column;\n104:             gap: 12px;\n105:         }\n106: \n107:         .entry {\n108:             background: var(--surface);\n109:             border: 1px solid var(--border);\n110:             border-radius: 8px;\n111:             padding: 16px;\n112:         }\n113: \n114:         .entry-header {\n115:             display: flex;\n116:             align-items: center;\n117:             gap: 8px;\n118:             margin-bottom: 8px;\n119:         }\n120: \n121:         .entry-type {\n122:             font-size: 12px;\n123:             padding: 2px 8px;\n124:             border-radius: 4px;\n125:             font-weight: 500;\n126:         }\n127: \n128:         .type-user-query { background: var(--accent); color: #000; }\n129:         .type-thought { background: var(--warning); color: #000; }\n130:         .type-action { background: var(--success); color: #000; }\n131:         .type-answer { background: var(--text-muted); color: #000; }\n132:         .type-side-effect { background: var(--error); color: #fff; }\n133:         .type-context { background: #8957e5; color: #fff; }\n134:         .type-tool { background: #3fb950; color: #000; }\n135: \n136:         .entry-content {\n137:             font-size: 14px;\n138:             white-space: pre-wrap;\n139:             word-break: break-word;\n140:         }\n141: \n142:         .entry-content code {\n143:             background: var(--bg);\n144:             padding: 2px 6px;\n145:             border-radius: 4px;\n146:             font-family: 'SF Mono', Monaco, monospace;\n147:             font-size: 13px;\n148:         }\n149: \n150:         .entry-content pre {\n151:             background: var(--bg);\n152:             padding: 12px;\n153:             border-radius: 4px;\n154:             overflow-x: auto;\n155:             margin-top: 8px;\n156:         }\n157: \n158:         .entry-content pre code {\n159:             padding: 0;\n160:             background: none;\n161:         }\n162: \n163:         .metrics {\n164:             display: flex;\n165:             gap: 16px;\n166:             flex-wrap: wrap;\n167:             margin-top: 12px;\n168:             padding-top: 12px;\n169:             border-top: 1px solid var(--border);\n170:             font-size: 13px;\n171:             color: var(--text-muted);\n172:         }\n173: \n174:         .no-session {\n175:             text-align: center;\n176:             padding: 40px;\n177:             color: var(--text-muted);\n178:         }\n179: \n180:         #fileInput {\n181:             display: none;\n182:         }\n183:     </style>\n184: </head>\n185: <body>\n186:     <div class=\"container\">\n187:         <header>\n188:             <h1><span>Agent</span>SON Viewer</h1>\n189:         </header>\n190: \n191:         <div class=\"drop-zone\" id=\"dropZone\">\n192:             <p>Drag & drop an <strong>.AgentSON</strong> file here</p>\n193:             <p>or click to select</p>\n194:             <input type=\"file\" id=\"fileInput\" accept=\".json,.AgentSON,.agentson\">\n195:         </div>\n196: \n197:         <div id=\"content\">\n198:             <div class=\"no-session\">\n199:                 No session loaded. Drop a file to begin.\n200:             </div>\n201:         </div>\n202:     </div>\n203: \n204:     <script>\n205:         const dropZone = document.getElementById('dropZone');\n206:         const fileInput = document.getElementById('fileInput');\n207:         const content = document.getElementById('content');\n208: \n209:         dropZone.addEventListener('click', () => fileInput.click());\n210: \n211:         dropZone.addEventListener('dragover', (e) => {\n212:             e.preventDefault();\n213:             dropZone.classList.add('dragover');\n214:         });\n215: \n216:         dropZone.addEventListener('dragleave', () => {\n217:             dropZone.classList.remove('dragover');\n218:         });\n219: \n220:         dropZone.addEventListener('drop', (e) => {\n221:             e.preventDefault();\n222:             dropZone.classList.remove('dragover');\n223:             const file = e.dataTransfer.files[0];\n224:             if (file) readFile(file);\n225:         });\n226: \n227:         fileInput.addEventListener('change', (e) => {\n228:             const file = e.target.files[0];\n229:             if (file) readFile(file);\n230:         });\n231: \n232:         function readFile(file) {\n233:             const reader = new FileReader();\n234:             reader.onload = (e) => {\n235:                 try {\n236:                     const data = JSON.parse(e.target.result);\n237:                     renderSession(data);\n238:                 } catch (err) {\n239:                     content.innerHTML = `<div class=\"no-session\">Error parsing file: ${err.message}</div>`;\n240:                 }\n241:             };\n242:             reader.readAsText(file);\n243:         }\n244: \n245:         function renderSession(data) {\n246:             const tool = data.tool || {};\n247:             const agent = data.agent || {};\n248:             const entries = data.entries || [];\n249:             const metrics = data.metrics || {};\n250: \n251:             let html = `\n252:                 <div class=\"session-info\">\n253:                     <h2>Session: ${data.id || 'Unknown'}</h2>\n254:                     <div class=\"meta-grid\">\n255:                         <div class=\"meta-item\">\n256:                             <span class=\"label\">Tool:</span> ${tool.name || 'Unknown'}\n257:                         </div>\n258:                         <div class=\"meta-item\">\n259:                             <span class=\"label\">Agent:</span> ${agent.name || 'Unknown'}\n260:                         </div>\n261:                         <div class=\"meta-item\">\n262:                             <span class=\"label\">Model:</span> ${agent.model || 'Unknown'}\n263:                         </div>\n264:                         <div class=\"meta-item\">\n265:                             <span class=\"label\">Started:</span> ${data.started_at || 'Unknown'}\n266:                         </div>\n267:                         <div class=\"meta-item\">\n268:                             <span class=\"label\">Entries:</span> ${entries.length}\n269:                         </div>\n270:                     </div>\n271:                 </div>\n272:                 <div class=\"entries\">\n273:             `;\n274: \n275:             for (const entry of entries) {\n276:                 const type = entry.type || entry.role || 'unknown';\n277:                 const typeClass = `type-${type.replace(/[^a-z-]/g, '-')}`;\n278:                 \n279:                 let content = '';\n280:                 if (entry.text) {\n281:                     content += escapeHtml(entry.text);\n282:                 }\n283:                 if (entry.code) {\n284:                     content += `<pre><code>${escapeHtml(entry.code)}</code></pre>`;\n285:                 }\n286:                 if (entry.output) {\n287:                     content += `<div class=\"label\">Output:</div><pre><code>${escapeHtml(entry.output)}</code></pre>`;\n288:                 }\n289:                 if (entry.query) {\n290:                     content += escapeHtml(entry.query);\n291:                 }\n292: \n293:                 html += `\n294:                     <div class=\"entry\">\n295:                         <div class=\"entry-header\">\n296:                             <span class=\"entry-type ${typeClass}\">${type}</span>\n297:                         </div>\n298:                         <div class=\"entry-content\">${content || '<em>No content</em>'}</div>\n299:                     </div>\n300:                 `;\n301:             }\n302: \n303:             html += '</div>';\n304: \n305:             if (metrics.total_tokens || metrics.cost) {\n306:                 html += `\n307:                     <div class=\"metrics\">\n308:                         ${metrics.total_tokens ? `<span>Tokens: ${metrics.total_tokens.toLocaleString()}</span>` : ''}\n309:                         ${metrics.cost ? `<span>Cost: $${metrics.cost.toFixed(4)}</span>` : ''}\n310:                         ${metrics.total_turns ? `<span>Turns: ${metrics.total_turns}</span>` : ''}\n311:                         ${metrics.total_tool_calls ? `<span>Tool Calls: ${metrics.total_tool_calls}</span>` : ''}\n312:                     </div>\n313:                 `;\n314:             }\n315: \n316:             content.innerHTML = html;\n317:         }\n318: \n319:         function escapeHtml(text) {\n320:             const div = document.createElement('div');\n321:             div.textContent = text;\n322:             return div.innerHTML;\n323:         }\n324:     </script>\n325: </body>\n326: </html>\n\n(End of file - total 326 lines)\n</content>",
