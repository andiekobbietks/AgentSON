      "code": "{\"command\": \"Add-Type -TypeDefinition @\\\"\\nusing System;\\nusing System.Runtime.InteropServices;\\n\\npublic class SettingsBroadcaster {\\n    [DllImport(\\\"user32.dll\\\", SetLastError = true, CharSet = CharSet.Auto)]\\n    public static extern IntPtr SendMessageTimeout(IntPtr hWnd, uint Msg, IntPtr wParam, string lParam, uint fuFlags, uint uTimeout, out IntPtr lpdwResult);\\n\\n    public static void Broadcast() {\\n        IntPtr result;\\n        SendMessageTimeout((IntPtr)0xFFFF, 0x001A, IntPtr.Zero, \\\"Accessibility\\\", 0, 5000, out result);\\n        SendMessageTimeout((IntPtr)0xFFFF, 0x001A, IntPtr.Zero, \\\"WindowMetrics\\\", 0, 5000, out result);\\n    }\\n}\\n\\\"@ -ErrorAction Stop\\n\\n[SettingsBroadcaster]::Broadcast()\\nWrite-Output \\\"Settings broadcast sent\\\"\", \"description\": \"Broadcast WM_SETTINGCHANGE to apply settings live\"}",
