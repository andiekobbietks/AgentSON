      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"Get-Process | Where-Object { $_.Name -like \\\"*Narrator*\\\" -or $_.Name -like \\\"*narrator*\\\" -or $_.Name -like \\\"*magnif*\\\" -or $_.Name -like \\\"*osk*\\\" -or $_.Name -like \\\"*magnify*\\\" } | Select-Object Name, Id\", \"description\": \"Check for Narrator or Magnifier\"}",
