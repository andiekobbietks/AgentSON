      "output": "<path>C:\\Users\\LLM-Test\\Documents\\store.ts</path>\n<type>file</type>\n<content>\n1: // Store Component - React/Frappe UI inspired implementation\n2: \n3: import { defineModel } from 'vue'\n4: import { computed } from 'vue'\n5: \n6: export const Store = {\n7:   install(app) {\n8:     app.component('Store', {\n9:       props: {\n10:         // IS_PRODUCTION toggles the API gateway boundary.\n11:         // Portal has CSRF cookies too, so we use that as the real-api gate.\n12:         isProduction: { type: Boolean, default: false },\n13:         \n14:         // Events store configuration\n15:         eventsConfig: {\n16:           type: Object,\n17:           default: () => ({\n18:             endpoint: 'fg_companion.api.get_events',\n19:             method: 'GET',\n20:             params: {}\n21:           })\n22:         },\n23:         \n24:         // Raven DMs store configuration  \n25:         ravenDMsConfig: {\n26:           type: Object,\n27:           default: () => ({\n28:             channelsEndpoint: 'raven_channel.get_all_channels',\n29:             messageEndpoint: 'raven_message.send_message',\n30:             createDMEndpoint: 'raven_channel.create_direct_message_channel'\n31:           })\n32:         },\n33:         \n34:         // LMS Courses store configuration\n35:         lmsCoursesConfig: {\n36:           type: Object,\n37:           default: () => ({\n38:             endpoint: 'lms.utils.get_courses',\n39:             method: 'GET'\n40:           })\n41:         }\n42:       },\n43:       \n44:       setup(props, { emit }) {\n45:         // Event store state\n46:         const events = defineModel('events', {\n47:           default: [],\n48:           set(value) {\n49:             emit('update:events', value)\n50:           }\n51:         })\n52:         \n53:         // Raven DMs state\n54:         const ravenDMs = defineModel('ravenDMs', {\n55:           default: [],\n56:           set(value) {\n57:             emit('update:ravenDMs', value)\n58:           }\n59:         })\n60:         \n61:         // LMS Courses state\n62:         const lmsCourses = defineModel('lmsCourses', {\n63:           default: [],\n64:           set(value) {\n65:             emit('update:lmsCourses', value)\n66:           }\n67:         })\n68:         \n69:         // Loading states\n70:         const loadingEvents = defineModel('loadingEvents', false)\n71:         const loadingRavenDMs = defineModel('loadingRavenDMs', false)\n72:         const loadingLmsCourses = defineModel('loadingLmsCourses', false)\n73:         \n74:         // Error states\n75:         const eventsError = defineModel('eventsError', null)\n76:         const ravenDMsError = defineModel('ravenDMsError', null)\n77:         const lmsCoursesError = defineModel('lmsCoursesError', null)\n78:         \n79:         // API endpoint helpers based on IS_PRODUCTION\n80:         const apiEndpoint = computed(() => {\n81:           return props.isProduction ? '/api' : '/portal-api'\n82:         })\n83:         \n84:         const realApiEndpoint = computed(() => {\n85:           return props.isProduction ? '/api' : '/portal-api/csrf'\n86:         })\n87:         \n88:         // Events API methods\n89:         const fetchEvents = async () => {\n90:           loadingEvents.value = true\n91:           eventsError.value = null\n92:           \n93:           try {\n94:             const response = await fetch(`${realApiEndpoint.value}/${props.eventsConfig.endpoint}`, {\n95:               method: props.eventsConfig.method,\n96:               headers: {\n97:                 'Content-Type': 'application/json',\n98:                 'X-CSRF-Token': getCsrfToken()\n99:               },\n100:               body: JSON.stringify(props.eventsConfig.params)\n101:             })\n102:             \n103:             if (!response.ok) {\n104:               throw new Error(`HTTP error! status: ${response.status}`)\n105:             }\n106:             \n107:             const data = await response.json()\n108:             events.value = data\n109:             return data\n110:           } catch (error) {\n111:             eventsError.value = error\n112:             emit('error:events', error)\n113:             throw error\n114:           } finally {\n115:             loadingEvents.value = false\n116:           }\n117:         }\n118:         \n119:         // Raven DMs API methods\n120:         const fetchRavenDMs = async () => {\n121:           loadingRavenDMs.value = true\n122:           ravenDMsError.value = null\n123:           \n124:           try {\n125:             const [channelsResponse, messagesResponse] = await Promise.all([\n126:               fetch(`${realApiEndpoint.value}/${props.ravenDMsConfig.channelsEndpoint}`, {\n127:                 method: 'GET',\n128:                 headers: {\n129:                   'Content-Type': 'application/json',\n130:                   'X-CSRF-Token': getCsrfToken()\n131:                 }\n132:               }),\n133:               fetch(`${realApiEndpoint.value}/${props.ravenDMsConfig.messageEndpoint}`, {\n134:                 method: 'GET',\n135:                 headers: {\n136:                   'Content-Type': 'application/json',\n137:                   'X-CSRF-Token': getCsrfToken()\n138:                 }\n139:               })\n140:             ])\n141:             \n142:             const channelsData = await channelsResponse.json()\n143:             const messagesData = await messagesResponse.json()\n144:             \n145:             // Merge and convert to unified format\n146:             const unifiedDMs = channelsData.map(channel => {\n147:               const lastMessage = messagesData.find(msg => msg.channel === channel.id) || null\n148:               return {\n149:                 id: channel.id,\n150:                 name: channel.name,\n151:                 participants: channel.participants || [],\n152:                 lastMessage: lastMessage ? {\n153:                   id: lastMessage.id,\n154:                   content: lastMessage.content,\n155:                   timestamp: lastMessage.timestamp,\n156:                   sender: lastMessage.sender,\n157:                   type: lastMessage.type\n158:                 } : null,\n159:                 unreadCount: channel.unreadCount || 0,\n160:                 createdAt: channel.creation_time,\n161:                 updatedAt: channel.last_message_time\n162:               }\n163:             })\n164:             \n165:             ravenDMs.value = unifiedDMs\n166:             return unifiedDMs\n167:           } catch (error) {\n168:             ravenDMsError.value = error\n169:             emit('error:ravenDMs', error)\n170:             throw error\n171:           } finally {\n172:             loadingRavenDMs.value = false\n173:           }\n174:         }\n175:         \n176:         // Open or create DM with a specific user\n177:         const openOrCreateDMWithUser = async (userId, userName) => {\n178:           loadingRavenDMs.value = true\n179:           ravenDMsError.value = null\n180:           \n181:           try {\n182:             const response = await fetch(`${realApiEndpoint.value}/${props.ravenDMsConfig.createDMEndpoint}`, {\n183:               method: 'POST',\n184:               headers: {\n185:                 'Content-Type': 'application/json',\n186:                 'X-CSRF-Token': getCsrfToken()\n187:               },\n188:               body: JSON.stringify({\n189:                 user_id: userId,\n190:                 user_name: userName\n191:               })\n192:             })\n193:             \n194:             if (!response.ok) {\n195:               throw new Error(`HTTP error! status: ${response.status}`)\n196:             }\n197:             \n198:             const data = await response.json()\n199:             \n200:             // Check if DM already exists\n201:             const existingDM = ravenDMs.value.find(dm => \n202:               dm.participants.includes(userId) || (dm.name === userName)\n203:             )\n204:             \n205:             if (existingDM) {\n206:               return existingDM\n207:             }\n208:             \n209:             // Create new DM entry\n210:             const newDM = {\n211:               id: data.channel_id,\n212:               name: userName,\n213:               participants: [userId],\n214:               lastMessage: null,\n215:               unreadCount: 0,\n216:               createdAt: new Date().toISOString(),\n217:               updatedAt: new Date().toISOString()\n218:             }\n219:             \n220:             ravenDMs.value = [newDM, ...ravenDMs.value]\n221:             return newDM\n222:           } catch (error) {\n223:             ravenDMsError.value = error\n224:             emit('error:ravenDMs', error)\n225:             throw error\n226:           } finally {\n227:             loadingRavenDMs.value = false\n228:           }\n229:         }\n230:         \n231:         // LMS Courses API methods\n232:         const fetchLmsCourses = async () => {\n233:           loadingLmsCourses.value = true\n234:           lmsCoursesError.value = null\n235:           \n236:           try {\n237:             const response = await fetch(`${realApiEndpoint.value}/${props.lmsCoursesConfig.endpoint}`, {\n238:               method: props.lmsCoursesConfig.method,\n239:               headers: {\n240:                 'Content-Type': 'application/json',\n241:                 'X-CSRF-Token': getCsrfToken()\n242:               }\n243:             })\n244:             \n245:             if (!response.ok) {\n246:               throw new Error(`HTTP error! status: ${response.status}`)\n247:             }\n248:             \n249:             const data = await response.json()\n250:             lmsCourses.value = data\n251:             return data\n252:           } catch (error) {\n253:             lmsCoursesError.value = error\n254:             emit('error:lmsCourses', error)\n255:             throw error\n256:           } finally {\n257:             loadingLmsCourses.value = false\n258:           }\n259:         }\n260:         \n261:         // Utility function to get CSRF token\n262:         const getCsrfToken = () => {\n263:           const token = document.querySelector('meta[name=\"csrf-token\"]')\n264:           return token ? token.getAttribute('content') : ''\n265:         }\n266:         \n267:         // Public API exposed to parent\n268:         defineExpose({\n269:           fetchEvents,\n270:           fetchRavenDMs,\n271:           openOrCreateDMWithUser,\n272:           fetchLmsCourses,\n273:           // Getters for reactive state\n274:           get events() { return events.value },\n275:           get ravenDMs() { return ravenDMs.value },\n276:           get lmsCourses() { return lmsCourses.value },\n277:           get loadingEvents() { return loadingEvents.value },\n278:           get loadingRavenDMs() { return loadingRavenDMs.value },\n279:           get loadingLmsCourses() { return loadingLmsCourses.value },\n280:           get eventsError() { return eventsError.value },\n281:           get ravenDMsError() { return ravenDMsError.value },\n282:           get lmsCoursesError() { return lmsCoursesError.value }\n283:         })\n284:         \n285:         return {\n286:           // Reactive state\n287:           events,\n288:           ravenDMs,\n289:           lmsCourses,\n290:           loadingEvents,\n291:           loadingRavenDMs,\n292:           loadingLmsCourses,\n293:           eventsError,\n294:           ravenDMsError,\n295:           lmsCoursesError\n296:         }\n297:       }\n298:     })\n299:   }\n300: }\n\n(End of file - total 300 lines)\n</content>",
