      "output": "<path>C:\\Users\\LLM-Test\\Documents\\StoreTest.vue</path>\n<type>file</type>\n<content>\n1: // Test component to verify store.ts functionality\n2: <template>\n3:   <div class=\"store-test\">\n4:     <h2>Store Component Test</h2>\n5:     \n6:     <!-- Events Section -->\n7:     <div class=\"section\">\n8:       <h3>Events Store</h3>\n9:       <button \n10:         @click=\"loadEvents\" \n11:         :disabled=\"loadingEvents\"\n12:         data-slot=\"trigger\"\n13:         data-variant=\"solid\"\n14:       >\n15:         {{ loadingEvents ? 'Loading...' : 'Load Events' }}\n16:       </button>\n17:       \n18:       <div v-if=\"eventsError\" data-slot=\"error\" data-variant=\"subtle\" data-theme=\"red\">\n19:         Error: {{ eventsError.message }}\n20:       </div>\n21:       \n22:       <div v-if=\"events && events.length > 0\">\n23:         <div \n24:           v-for=\"event in events\" \n25:           :key=\"event.id\"\n26:           data-slot=\"item\"\n27:           :data-variant=\"getEventVariant(event.type)\"\n28:         >\n29:           <div>{{ event.title }}</div>\n30:           <div>{{ event.description }}</div>\n31:           <div>{{ event.timestamp }}</div>\n32:         </div>\n33:       </div>\n34:     </div>\n35:     \n36:     <!-- Raven DMs Section -->\n37:     <div class=\"section\">\n38:       <h3>Raven DMs Store</h3>\n39:       <button \n40:         @click=\"loadRavenDMs\" \n41:         :disabled=\"loadingRavenDMs\"\n42:         data-slot=\"trigger\"\n43:         data-variant=\"outline\"\n44:       >\n45:         {{ loadingRavenDMs ? 'Loading...' : 'Load DMs' }}\n46:       </button>\n47:       \n48:       <div v-if=\"ravenDMsError\" data-slot=\"error\" data-variant=\"subtle\" data-theme=\"red\">\n49:         Error: {{ ravenDMsError.message }}\n50:       </div>\n51:       \n52:       <div v-if=\"ravenDMs && ravenDMs.length > 0\">\n53:         <div \n54:           v-for=\"dm in ravenDMs\" \n55:           :key=\"dm.id\"\n56:           data-slot=\"item\"\n57:           :data-variant=\"getDMVariant(dm.lastMessage)\"\n58:         >\n59:           <div>{{ dm.name }}</div>\n60:           <div v-if=\"dm.lastMessage\">\n61:             <span class=\"sender\">{{ dm.lastMessage.sender }}:</span>\n62:             <span class=\"content\">{{ dm.lastMessage.content }}</span>\n63:           </div>\n64:           <div v-else>No messages</div>\n65:           <div class=\"unread-count\" v-if=\"dm.unreadCount > 0\">\n66:             {{ dm.unreadCount }} unread\n67:           </div>\n68:         </div>\n69:       </div>\n70:     </div>\n71:     \n72:     <!-- LMS Courses Section -->\n73:     <div class=\"section\">\n74:       <h3>LMS Courses Store</h3>\n75:       <button \n76:         @click=\"loadLmsCourses\" \n77:         :disabled=\"loadingLmsCourses\"\n78:         data-slot=\"trigger\"\n79:         data-variant=\"ghost\"\n80:       >\n81:         {{ loadingLmsCourses ? 'Loading...' : 'Load Courses' }}\n82:       </button>\n83:       \n84:       <div v-if=\"lmsCoursesError\" data-slot=\"error\" data-variant=\"subtle\" data-theme=\"red\">\n85:         Error: {{ lmsCoursesError.message }}\n86:       </div>\n87:       \n88:       <div v-if=\"lmsCourses && lmsCourses.length > 0\">\n89:         <div \n90:           v-for=\"course in lmsCourses\" \n91:           :key=\"course.id\"\n92:           data-slot=\"item\"\n93:           :data-variant=\"getCourseVariant(course.status)\"\n94:         >\n95:           <div>{{ course.name }}</div>\n96:           <div>{{ course.description }}</div>\n97:           <div>{{ course.instructor }}</div>\n98:           <div class=\"status\" :data-variant=\"getCourseStatusVariant(course.status)\">\n99:             {{ course.status }}\n100:           </div>\n101:         </div>\n102:       </div>\n103:     </div>\n104:     \n105:     <!-- Create DM Section -->\n106:     <div class=\"section\">\n107:       <h3>Create DM with User</h3>\n108:       <div class=\"form-group\">\n109:         <input \n110:           v-model=\"newUserId\" \n111:           placeholder=\"User ID\"\n112:           data-slot=\"input\"\n113:         />\n114:         <input \n115:           v-model=\"newUserName\" \n116:           placeholder=\"User Name\"\n117:           data-slot=\"input\"\n118:         />\n119:         <button \n120:           @click=\"createDMWithUser\"\n121:           :disabled=\"loadingRavenDMs\"\n122:           data-slot=\"trigger\"\n123:           data-variant=\"solid\"\n124:           data-theme=\"blue\"\n125:         >\n126:           Create DM\n127:         </button>\n128:       </div>\n129:     </div>\n130:   </div>\n131: </template>\n132: \n133: <script setup>\n134: import { Store } from './store.ts'\n135: \n136: export default {\n137:   components: {\n138:     Store\n139:   },\n140:   setup() {\n141:     const {\n142:       events,\n143:       ravenDMs,\n144:       lmsCourses,\n145:       loadingEvents,\n146:       loadingRavenDMs,\n147:       loadingLmsCourses,\n148:       eventsError,\n149:       ravenDMsError,\n150:       lmsCoursesError,\n151:       fetchEvents,\n152:       fetchRavenDMs,\n153:       openOrCreateDMWithUser,\n154:       fetchLmsCourses\n155:     } = useStore()\n156:     \n157:     const newUserId = ref('')\n158:     const newUserName = ref('')\n159:     \n160:     const loadEvents = async () => {\n161:       await fetchEvents()\n162:     }\n163:     \n164:     const loadRavenDMs = async () => {\n165:       await fetchRavenDMs()\n166:     }\n167:     \n168:     const loadLmsCourses = async () => {\n169:       await fetchLmsCourses()\n170:     }\n171:     \n172:     const createDMWithUser = async () => {\n173:       if (!newUserId.value || !newUserName.value) return\n174:       \n175:       await openOrCreateDMWithUser(newUserId.value, newUserName.value)\n176:       \n177:       // Reset form\n178:       newUserId.value = ''\n179:       newUserName.value = ''\n180:     }\n181:     \n182:     const getEventVariant = (type) => {\n183:       const variants = {\n184:         'system': 'solid',\n185:         'user': 'outline',\n186:         'team': 'subtle',\n187:         'default': 'ghost'\n188:       }\n189:       return variants[type] || variants.default\n190:     }\n191:     \n192:     const getDMVariant = (lastMessage) => {\n193:       return lastMessage ? 'solid' : 'outline'\n194:     }\n195:     \n196:     const getCourseVariant = (status) => {\n197:       const variants = {\n198:         'enrolled': 'solid',\n199:         'completed': 'outline',\n200:         'in_progress': 'subtle',\n201:         'archived': 'ghost'\n202:       }\n203:       return variants[status] || variants.default\n204:     }\n205:     \n206:     const getCourseStatusVariant = (status) => {\n207:       const colors = {\n208:         'enrolled': 'blue',\n209:         'completed': 'green',\n210:         'in_progress': 'yellow',\n211:         'archived': 'gray'\n212:       }\n213:       return colors[status] || colors.default\n214:     }\n215:     \n216:     return {\n217:       events,\n218:       ravenDMs,\n219:       lmsCourses,\n220:       loadingEvents,\n221:       loadingRavenDMs,\n222:       loadingLmsCourses,\n223:       eventsError,\n224:       ravenDMsError,\n225:       lmsCoursesError,\n226:       loadEvents,\n227:       loadRavenDMs,\n228:       loadLmsCourses,\n229:       createDMWithUser,\n230:       newUserId,\n231:       newUserName,\n232:       getEventVariant,\n233:       getDMVariant,\n234:       getCourseVariant,\n235:       getCourseStatusVariant\n236:     }\n237:   }\n238: }\n239: </script>\n240: \n241: <style scoped>\n242: .store-test {\n243:   padding: 2rem;\n244:   max-width: 1200px;\n245:   margin: 0 auto;\n246:   font-family: system-ui, sans-serif;\n247: }\n248: \n249: .section {\n250:   margin-bottom: 2rem;\n251:   padding: 1.5rem;\n252:   border: 1px solid #e0e0e0;\n253:   border-radius: 8px;\n254:   background-color: #f9f9f9;\n255: }\n256: \n257: h2, h3 {\n258:   color: #333;\n259:   margin-bottom: 1rem;\n260: }\n261: \n262: button {\n263:   padding: 0.75rem 1.5rem;\n264:   margin: 0.5rem;\n265:   border: none;\n266:   border-radius: 4px;\n267:   cursor: pointer;\n268:   transition: all 0.2s ease;\n269: }\n270: \n271: button:disabled {\n272:   opacity: 0.6;\n273:   cursor: not-allowed;\n274: }\n275: \n276: .form-group {\n277:   display: flex;\n278:   gap: 1rem;\n279:   margin: 1rem 0;\n280:   flex-wrap: wrap;\n281: }\n282: \n283: .form-group input {\n284:   padding: 0.75rem;\n285:   border: 1px solid #ddd;\n286:   border-radius: 4px;\n287:   font-size: 1rem;\n288: }\n289: \n290: .error {\n291:   color: #dc3545;\n292:   padding: 1rem;\n293:   border-radius: 4px;\n294:   margin: 1rem 0;\n295:   background-color: #ffebee;\n296: }\n297: \n298: .item {\n299:   padding: 1rem;\n300:   margin: 0.5rem 0;\n301:   border-bottom: 1px solid #eee;\n302: }\n303: \n304: .item:last-child {\n305:   border-bottom: none;\n306: }\n307: \n308: .sender {\n309:   font-weight: bold;\n310:   color: #0066cc;\n311: }\n312: \n313: .unread-count {\n314:   color: #dc3545;\n315:   font-weight: bold;\n316:   font-size: 0.9rem;\n317: }\n318: \n319: .status {\n320:   display: inline-block;\n321:   padding: 0.25rem 0.75rem;\n322:   border-radius: 12px;\n323:   font-size: 0.85rem;\n324:   font-weight: 500;\n325: }\n326: </style>\n\n(End of file - total 326 lines)\n</content>",
