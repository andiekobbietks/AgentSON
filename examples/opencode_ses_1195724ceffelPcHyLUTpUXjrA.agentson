      "code": "{\"content\": \"// FG Companion Store - Frappe UI compliant implementation\\n\\nimport { \\n  useCall, \\n  toast, \\n  dialog,\\n  computed\\n} from 'frappe-ui'\\n\\nexport const FGCompanionStore = {\\n  setup() {\\n    // Use Frappe UI's useCall for data fetching\\n    // Events store\\n    const { \\n      data: events, \\n      execute: fetchEvents, \\n      loading: loadingEvents, \\n      error: eventsError \\n    } = useCall('fg_companion.api.get_events', {\\n      lazy: true\\n    })\\n    \\n    // Raven DMs store - combined channels + messages\\n    const {\\n      data: ravenDMs,\\n      execute: fetchRavenDMs,\\n      loading: loadingRavenDMs,\\n      error: ravenDMsError\\n    } = useCall('raven_channel.get_all_channels', {\\n      lazy: true\\n    })\\n    \\n    // LMS Courses store\\n    const {\\n      data: lmsCourses,\\n      execute: fetchLmsCourses,\\n      loading: loadingLmsCourses,\\n      error: lmsCoursesError\\n    } = useCall('lms.utils.get_courses', {\\n      lazy: true\\n    })\\n    \\n    // Custom method for creating DMs using Frappe UI's dialog\\n    const openOrCreateDMWithUser = async (userId, userName) => {\\n      try {\\n        // Use Frappe UI's dialog for loading state\\n        return await dialog.loading(\\n          async () => {\\n            const { data } = await useCall('raven_channel.create_direct_message_channel', {\\n              method: 'POST',\\n              params: {\\n                user_id: userId,\\n                user_name: userName\\n              }\\n            })\\n            \\n            // Refresh DMs list\\n            await fetchRavenDMs()\\n            \\n            return data\\n          },\\n          `Creating DM with ${userName}...`\\n        )\\n      } catch (error) {\\n        toast.error(`Failed to create DM with ${userName}: ${error.message}`)\\n        throw error\\n      }\\n    }\\n    \\n    // Public API using Frappe UI patterns\\n    return {\\n      // State - reactive from Frappe UI useCall\\n      events,\\n      ravenDMs,\\n      lmsCourses,\\n      loadingEvents,\\n      loadingRavenDMs,\\n      loadingLmsCourses,\\n      eventsError,\\n      ravenDMsError,\\n      lmsCoursesError,\\n      \\n      // Methods - Frappe UI imperative patterns\\n      loadEvents: async () => {\\n        try {\\n          return await fetchEvents()\\n        } catch (error) {\\n          toast.error(`Failed to load events: ${error.message}`)\\n          throw error\\n        }\\n      },\\n      \\n      loadRavenDMs: async () => {\\n        try {\\n          return await fetchRavenDMs()\\n        } catch (error) {\\n          toast.error(`Failed to load DMs: ${error.message}`)\\n          throw error\\n        }\\n      },\\n      \\n      loadLmsCourses: async () => {\\n        try {\\n          return await fetchLmsCourses()\\n        } catch (error) {\\n          toast.error(`Failed to load courses: ${error.message}`)\\n          throw error\\n        }\\n      },\\n      \\n      createDMWithUser: openOrCreateDMWithUser\\n    }\\n  }\\n}\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\FGCompanionStore.ts\"}",
