    {
      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"# Clear HuggingFace cache\\n$hfPath = \\\"$env:LOCALAPPDATA\\\\huggingface\\\"\\nif (Test-Path $hfPath) {\\n    $size = (Get-ChildItem -Path $hfPath -Recurse -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum\\n    Get-ChildItem -Path $hfPath -Recurse -File -ErrorAction SilentlyContinue | Remove-Item -Force -ErrorAction SilentlyContinue\\n    Write-Host \\\"Cleared HuggingFace cache: $([math]::Round($size/1MB,0)) MB\\\" -ForegroundColor Green\\n}\\n\\n# Clear Playwright browsers\\n$pwPath = \\\"$env:LOCALAPPDATA\\\\ms-playwright\\\"\\nif (Test-Path $pwPath) {\\n    $size = (Get-ChildItem -Path $pwPath -Recurse -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum\\n    Get-ChildItem -Path $pwPath -Recurse -Directory -ErrorAction SilentlyContinue | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue\\n    Write-Host \\\"Cleared Playwright browsers: $([math]::Round($size/1MB,0)) MB\\\" -ForegroundColor Green\\n}\\n\\n# Clear npm cache\\n$npmPath = \\\"$env:LOCALAPPDATA\\\\npm-cache\\\"\\nif (Test-Path $npmPath) {\\n    $size = (Get-ChildItem -Path $npmPath -Recurse -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum\\n    Remove-Item -Path $npmPath -Recurse -Force -ErrorAction SilentlyContinue\\n    Write-Host \\\"Cleared npm cache: $([math]::Round($size/1MB,0)) MB\\\" -ForegroundColor Green\\n}\\n\\n# Clear pip cache\\n$pipPath = \\\"$env:LOCALAPPDATA\\\\pip\\\"\\nif (Test-Path $pipPath) {\\n    $size = (Get-ChildItem -Path $pipPath -Recurse -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum\\n    Remove-Item -Path $pipPath -Recurse -Force -ErrorAction SilentlyContinue\\n    Write-Host \\\"Cleared pip cache: $([math]::Round($size/1MB,0)) MB\\\" -ForegroundColor Green\\n}\\n\\n# Final status\\n$disk = Get-WmiObject Win32_LogicalDisk -Filter \\\"DeviceID='C:'\\\"\\n$newFreeGB = [math]::Round($disk.FreeSpace / 1GB, 2)\\n$newPct = [math]::Round($disk.FreeSpace / $disk.Size * 100, 1)\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"FINAL C: drive: $newFreeGB GB free ($newPct%)\\\" -ForegroundColor Cyan\\n\", \"description\": \"Clear remaining caches for more space\"}",
