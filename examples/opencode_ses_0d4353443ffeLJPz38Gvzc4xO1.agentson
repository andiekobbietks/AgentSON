      "code": "{\"command\": \"python -c \\\"\\nimport psutil\\nimport json\\n\\n# CPU temperatures (if available)\\ntry:\\n    temps = psutil.sensors_temperatures()\\n    if temps:\\n        for name, entries in temps.items():\\n            for entry in entries:\\n                print(f'{name}: {entry.current}\\u00b0C (high={entry.high}, critical={entry.critical})')\\n    else:\\n        print('Temperature sensors: Not available via psutil')\\nexcept Exception as e:\\n    print(f'Temperature check: {e}')\\n\\nprint()\\n\\n# CPU usage\\ncpu_pct = psutil.cpu_percent(interval=1)\\ncpu_freq = psutil.cpu_freq()\\nprint(f'CPU Usage: {cpu_pct}%')\\nif cpu_freq:\\n    print(f'CPU Freq: {cpu_freq.current:.0f} MHz (min={cpu_freq.min}, max={cpu_freq.max})')\\n\\n# Memory\\nmem = psutil.virtual_memory()\\nprint(f'RAM: {mem.percent}% used ({mem.used/(1024**3):.1f}GB / {mem.total/(1024**3):.1f}GB)')\\n\\n# Disk\\nfor part in psutil.disk_partitions():\\n    try:\\n        usage = psutil.disk_usage(part.mountpoint)\\n        if usage.total > 0:\\n            print(f'Disk {part.mountpoint}: {usage.percent}% used ({usage.free/(1024**3):.2f}GB free of {usage.total/(1024**3):.1f}GB)')\\n    except:\\n        pass\\n\\n# Battery\\ntry:\\n    bat = psutil.sensors_battery()\\n    if bat:\\n        print(f'Battery: {bat.percent}% - Charging: {bat.power_plugged}')\\nexcept:\\n    print('Battery: Not available')\\n\\\"\\n\", \"description\": \"Run Python system health check with psutil\"}",
