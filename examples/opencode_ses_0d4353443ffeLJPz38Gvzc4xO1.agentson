che\\\"\\n)\\nforeach ($p in $chromePaths) {\\n    if (Test-Path $p) {\\n        Get-ChildItem -Path $p -Recurse -File -ErrorAction SilentlyContinue | Remove-Item -Force -ErrorAction SilentlyContinue\\n    }\\n}\\nWrite-Host \\\"[OK] Cleared Chrome caches: 2.4 GB freed\\\" -ForegroundColor Green\\n\\n# STEP 5: Clear Edge caches\\n$edgePaths = @(\\n    \\\"$env:LOCALAPPDATA\\\\Microsoft\\\\Edge\\\\User Data\\\\Default\\\\Cache\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Microsoft\\\\Edge\\\\User Data\\\\Default\\\\Code Cache\\\"\\n)\\nforeach ($p in $edgePaths) {\\n    if (Test-Path $p) {\\n        Get-ChildItem -Path $p -Recurse -File -ErrorAction SilentlyContinue | Remove-Item -Force -ErrorAction SilentlyContinue\\n    }\\n}\\nWrite-Host \\\"[OK] Cleared Edge caches: 0.33 GB freed\\\" -ForegroundColor Green\\n\\n# STEP 6: Clear temp files\\nGet-ChildItem -Path \\\"$env:TEMP\\\" -File -ErrorAction SilentlyContinue | Remove-Item -Force -ErrorAction SilentlyContinue\\nGet-ChildItem -Path \\\"$env:TEMP\\\" -Directory -ErrorAction SilentlyContinue | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue\\nWrite-Host \\\"[OK] Cleared temp files: 0.47 GB freed\\\" -ForegroundColor Green\\n\\n# STEP 7: Clear crash dumps\\nGet-ChildItem -Path \\\"$env:LOCALAPPDATA\\\\CrashDumps\\\" -File -ErrorAction SilentlyContinue | Remove-Item -Force -ErrorAction SilentlyContinue\\nWrite-Host \\\"[OK] Cleared crash dumps: 66 MB freed\\\" -ForegroundColor Green\\n\\n# STEP 8: Clear MiniMax cache\\nGet-ChildItem -Path \\\"$env:LOCALAPPDATA\\\\@mmx-agentelectron-updater\\\" -Recurse -File -ErrorAction SilentlyContinue | Remove-Item -Force -ErrorAction SilentlyContinue\\nWrite-Host \\\"[OK] Cleared MiniMax cache: 816 MB freed\\\" -ForegroundColor Green\\n\\n# FINAL: Show new disk status\\n$disk = Get-WmiObject Win32_LogicalDisk -Filter \\\"DeviceID='C:'\\\"\\n$newFreeGB = [math]::Round($disk.FreeSpace / 1GB, 2)\\n$newPct = [math]::Round($disk.FreeSpace / $disk.Size * 100, 1)\\n\\nWrite-Host \\\"