      "type": "action",
      "tool": "write",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\temp_monitor.py\", \"content\": \"import psutil\\nimport time\\nimport os\\n\\ndef get_cpu_temp_wmi():\\n    \\\"\\\"\\\"Try to get CPU temp via WMI\\\"\\\"\\\"\\n    try:\\n        import wmi\\n        w = wmi.WMI(namespace=\\\"root\\\\\\\\OpenHardwareMonitor\\\")\\n        sensors = w.Sensor()\\n        temps = {}\\n        for sensor in sensors:\\n            if sensor.SensorType == \\\"Temperature\\\":\\n                temps[sensor.Name] = float(sensor.Value)\\n        return temps\\n    except:\\n        return None\\n\\ndef get_gpu_temp():\\n    \\\"\\\"\\\"Get GPU temp via nvidia-smi\\\"\\\"\\\"\\n    try:\\n        import subprocess\\n        result = subprocess.run(\\n            [\\\"nvidia-smi\\\", \\\"--query-gpu=temperature.gpu\\\", \\\"--format=csv,noheader,nounits\\\"],\\n            capture_output=True, text=True, timeout=5\\n        )\\n        if result.returncode == 0:\\n            return float(result.stdout.strip())\\n    except:\\n        pass\\n    return None\\n\\ndef main():\\n    print(\\\"=\\\" * 60)\\n    print(\\\"  PC Temperature & Health Monitor (No Stress Test)\\\")\\n    print(\\\"=\\\" * 60)\\n    print()\\n\\n    # CPU info\\n    cpu_name = \\\"Unknown\\\"\\n    try:\\n        import wmi\\n        w = wmi.WMI()\\n        for proc in w.Win32_Processor():\\n            cpu_name = proc.Name\\n            break\\n    except:\\n        pass\\n\\n    print(f\\\"CPU: {cpu_name}\\\")\\n    print(f\\\"Logical CPUs: {psutil.cpu_count(logical=True)}\\\")\\n    print()\\n\\n    readings = 0\\n    max_readings = 30  # 30 seconds of monitoring\\n\\n    try:\\n        while readings < max_readings:\\n            os.system('cls' if os.name == 'nt' else 'clear')\\n\\n            print(\\\"=\\\" * 60)\\n            print(\\\"  PC Temperature & Health Monitor (No Stress Test)\\\")\\n            print(\\\"=\\\" * 60)\\n            print(f\\\"  Sample {readings + 1}/{max_readings} | Press Ctrl+C to stop\\\")\\n            print()\\n\\n            # CPU usage and frequency\\n            cpu_pct = psutil.cpu_percent(interval=0.5)\\n            cpu_freq = psutil.cpu_freq()\\n            print(f\\\"  CPU Usage:    {cpu_pct:5.1f}%\\\")\\n            if cpu_freq:\\n                print(f\\\"  CPU Freq:     {cpu_freq.current:.0f} MHz\\\")\\n\\n            # Memory\\n            mem = psutil.virtual_memory()\\n            print(f\\\"  RAM Usage:    {mem.percent:5.1f}% ({mem.used/(1024**3):.1f} / {mem.total/(1024**3):.1f} GB)\\\")\\n\\n            # Disk\\n            disk = psutil.disk_usage(\\\"C:\\\\\\\\\\\")\\n            print(f\\\"  C: Drive:     {disk.percent:5.1f}% used ({disk.free/(1024**3):.2f} GB free)\\\")\\n\\n            # GPU temperature\\n            gpu_temp = get_gpu_temp()\\n            if gpu_temp is not None:\\n                status = \\\"OK\\\" if gpu_temp < 80 else \\\"WARM\\\" if gpu_temp < 90 else \\\"HOT\\\"\\n                print(f\\\"  GPU Temp:     {gpu_temp:.0f}\\u00b0C [{status}]\\\")\\n\\n            # Temperatures via OpenHardwareMonitor (if installed)\\n            ohm_temps = get_cpu_temp_wmi()\\n            if ohm_temps:\\n                print()\\n                print(\\\"  Component Temperatures (OpenHardwareMonitor):\\\")\\n                for name, temp in sorted(ohm_temps.items()):\\n                    status = \\\"OK\\\" if temp < 70 else \\\"WARM\\\" if temp < 85 else \\\"HOT\\\"\\n                    print(f\\\"    {name:30s}: {temp:5.1f}\\u00b0C [{status}]\\\")\\n            else:\\n                print()\\n                print(\\\"  Tip: Install OpenHardwareMonitor for detailed temps\\\")\\n                print(\\\"       https://openhardwaremonitor.org/\\\")\\n\\n            # Fan speed (if available via OHM)\\n            if ohm_temps:\\n                try:\\n                    import wmi\\n                    w = wmi.WMI(namespace=\\\"root\\\\\\\\OpenHardwareMonitor\\\")\\n                    fans = w.Sensor()\\n                    fan_speeds = [(s.Name, s.Value) for s in fans if s.SensorType == \\\"Fan\\\"]\\n                    if fan_speeds:\\n                        print()\\n                        print(\\\"  Fan Speeds:\\\")\\n                        for name, speed in fan_speeds:\\n                            print(f\\\"    {name:30s}: {speed:.0f} RPM\\\")\\n                except:\\n                    pass\\n\\n            print()\\n            print(\\\"  Recommendations based on current readings:\\\")\\n            if gpu_temp and gpu_temp > 75:\\n                print(\\\"  * GPU running warm at idle - clean vents / check thermal paste\\\")\\n            if mem.percent > 60:\\n                print(\\\"  * RAM usage high - check for memory-leaking apps\\\")\\n            if disk.percent > 95:\\n                print(\\\"  * CRITICAL: Disk nearly full - free up space immediately!\\\")\\n            elif disk.percent > 90:\\n                print(\\\"  * WARNING: Disk getting full - clean up storage\\\")\\n\\n            readings += 1\\n            time.sleep(1)\\n\\n    except KeyboardInterrupt:\\n        print(\\\"\\\\n\\\\nMonitoring stopped.\\\")\\n\\n    print(\\\"\\\\n\\\" + \\\"=\\\" * 60)\\n    print(\\\"  HEALTH SUMMARY\\\")\\n    print(\\\"=\\\" * 60)\\n\\n    # Final health check\\n    disk = psutil.disk_usage(\\\"C:\\\\\\\\\\\")\\n    mem = psutil.virtual_memory()\\n    gpu = get_gpu_temp()\\n\\n    issues = []\\n    if disk.percent > 95:\\n        issues.append(\\\"CRITICAL: C: drive is critically full. Free space immediately.\\\")\\n    elif disk.percent > 90:\\n        issues.append(\\\"WARNING: C: drive is getting full.\\\")\\n\\n    if mem.percent > 80:\\n        issues.append(\\\"WARNING: RAM usage is high.\\\")\\n\\n    if gpu and gpu > 80:\\n        issues.append(\\\"WARNING: GPU temperature is high.\\\")\\n\\n    if not issues:\\n        print(\\\"  All monitored metrics look OK.\\\")\\n    else:\\n        for issue in issues:\\n            print(f\\\"  * {issue}\\\")\\n\\n    print()\\n    print(\\\"  For BSOD (WHEA) prevention:\\\")\\n    print(\\\"  1. Free disk space (aim for 15-20% free)\\\")\\n    print(\\\"  2. Update NVIDIA driver to v32.0.15.8183+\\\")\\n    print(\\\"  3. Update BIOS via HP Support Assistant\\\")\\n    print(\\\"  4. Clean laptop vents with compressed air\\\")\\n    print(\\\"=\\\" * 60)\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n\"}",
