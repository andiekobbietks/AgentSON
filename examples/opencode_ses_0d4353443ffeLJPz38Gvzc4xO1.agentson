    {
      "type": "thought",
      "text": "Good, now let me also create a script to safely clean up the Downloads folder by identifying the most obvious junk files (duplicate installers, incomplete downloads, etc.).",
      "timestamp": 1783147040886
    },
    {
      "type": "action",
      "tool": "write",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\cleanup_downloads.ps1\", \"content\": \"# Downloads Folder Cleanup - Identifies safe-to-delete files\\n# Run this first to SEE what can be deleted, then confirm\\n\\nWrite-Host \\\"=============================================\\\" -ForegroundColor Cyan\\nWrite-Host \\\"  Downloads Folder Analysis\\\" -ForegroundColor Cyan\\nWrite-Host \\\"=============================================\\\" -ForegroundColor Cyan\\nWrite-Host \\\"\\\"\\n\\n$downloads = \\\"$env:USERPROFILE\\\\Downloads\\\"\\n$files = Get-ChildItem -Path $downloads -File -ErrorAction SilentlyContinue\\n\\n$categorized = @()\\n$totalSize = 0\\n\\nforeach ($f in $files) {\\n    $sizeMB = [math]::Round($f.Length / 1MB, 1)\\n    $totalSize += $f.Length\\n    \\n    $category = \\\"Keep\\\"\\n    $reason = \\\"\\\"\\n    \\n    # Incomplete Chrome downloads\\n    if ($f.Name -match '\\\\.crdownload$') {\\n        $category = \\\"DELETE\\\"\\n        $reason = \\\"Incomplete download (Chrome temp file)\\\"\\n    }\\n    # Duplicate installers\\n    elseif ($f.Name -match 'MiniMax.*Setup.*\\\\.exe$') {\\n        $category = \\\"DELETE\\\"\\n        $reason = \\\"Duplicate installer (keep latest version only)\\\"\\n    }\\n    # Duplicate AI Studio zips\\n    elseif ($f.Name -match 'Google AI Studio.*\\\\.zip$') {\\n        $category = \\\"DELETE\\\"\\n        $reason = \\\"Duplicate zip (multiple versions downloaded)\\\"\\n    }\\n    # Old large zips\\n    elseif ($f.Name -match 'iotbox.*\\\\.zip$' -and $sizeMB -gt 500) {\\n        $category = \\\"REVIEW\\\"\\n        $reason = \\\"Large zip - check if still needed\\\"\\n    }\\n    # Large video files\\n    elseif ($f.Name -match '\\\\.(mp4|avi|mkv|mov)$' -and $sizeMB -gt 100) {\\n        $category = \\\"REVIEW\\\"\\n        $reason = \\\"Large video - move to D: or delete if watched\\\"\\n    }\\n    # Large PDFs\\n    elseif ($f.Name -match '\\\\.pdf$' -and $sizeMB -gt 100) {\\n        $category = \\\"REVIEW\\\"\\n        $reason = \\\"Large PDF - check if needed\\\"\\n    }\\n    \\n    $categorized += [PSCustomObject]@{\\n        Name = $f.Name\\n        SizeMB = $sizeMB\\n        Category = $category\\n        Reason = $reason\\n        LastWrite = $f.LastWriteTime.ToString(\\\"yyyy-MM-dd\\\")\\n    }\\n}\\n\\n# Sort by category then size\\n$delete = $categorized | Where-Object { $_.Category -eq \\\"DELETE\\\" } | Sort-Object SizeMB -Descending\\n$review = $categorized | Where-Object { $_.Category -eq \\\"REVIEW\\\" } | Sort-Object SizeMB -Descending\\n$keep = $categorized | Where-Object { $_.Category -eq \\\"Keep\\\" } | Sort-Object SizeMB -Descending\\n\\nWrite-Host \\\"=== SAFE TO DELETE (no questions asked) ===\\\" -ForegroundColor Red\\n$deleteTotal = 0\\nforeach ($f in $delete) {\\n    Write-Host \\\"  $($f.SizeMB) MB - $($f.Name)\\\" -ForegroundColor Gray\\n    Write-Host \\\"    Reason: $($f.Reason)\\\" -ForegroundColor DarkGray\\n    $deleteTotal += $f.SizeMB\\n}\\nWrite-Host \\\"  Subtotal: $([math]::Round($deleteTotal/1024, 2)) GB\\\" -ForegroundColor Red\\nWrite-Host \\\"\\\"\\n\\nWrite-Host \\\"=== REVIEW (check if you still need these) ===\\\" -ForegroundColor Yellow\\n$reviewTotal = 0\\nforeach ($f in $review) {\\n    Write-Host \\\"  $($f.SizeMB) MB - $($f.Name) (modified: $($f.LastWrite))\\\" -ForegroundColor Gray\\n    Write-Host \\\"    Reason: $($f.Reason)\\\" -ForegroundColor DarkGray\\n    $reviewTotal += $f.SizeMB\\n}\\nWrite-Host \\\"  Subtotal: $([math]::Round($reviewTotal/1024, 2)) GB\\\" -ForegroundColor Yellow\\nWrite-Host \\\"\\\"\\n\\nWrite-Host \\\"=== KEEP (likely important) ===\\\" -ForegroundColor Green\\nWrite-Host \\\"  $($keep.Count) files worth $([math]::Round(($keep | Measure-Object -Property SizeMB -Sum).Sum/1024, 2)) GB\\\" -ForegroundColor Green\\nWrite-Host \\\"\\\"\\n\\nWrite-Host \\\"=============================================\\\" -ForegroundColor Cyan\\nWrite-Host \\\"  TOTAL IN DOWNLOADS: $([math]::Round($totalSize/1GB, 2)) GB\\\" -ForegroundColor Cyan\\nWrite-Host \\\"  SAFE TO DELETE NOW: $([math]::Round($deleteTotal/1024, 2)) GB\\\" -ForegroundColor Red\\nWrite-Host \\\"  REVIEW NEEDED:      $([math]::Round($reviewTotal/1024, 2)) GB\\\" -ForegroundColor Yellow\\nWrite-Host \\\"=============================================\\\" -ForegroundColor Cyan\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"To delete the safe files, run:\\\" -ForegroundColor White\\nWrite-Host '  .\\\\cleanup_downloads.ps1 -Execute' -ForegroundColor Cyan\\nWrite-Host \\\"\\\"\\n\\n# If -Execute flag is passed, actually delete\\nif ($args -contains '-Execute') {\\n    Write-Host \\\"EXECUTING CLEANUP...\\\" -ForegroundColor Red\\n    foreach ($f in $delete) {\\n        $path = Join-Path $downloads $f.Name\\n        if (Test-Path $path) {\\n            Remove-Item -Path $path -Force -ErrorAction SilentlyContinue\\n            Write-Host \\\"  Deleted: $($f.Name)\\\" -ForegroundColor DarkRed\\n        }\\n    }\\n    \\n    # Also delete incomplete Chrome downloads\\n    Get-ChildItem -Path $downloads -Filter \\\"*.crdownload\\\" -ErrorAction SilentlyContinue | Remove-Item -Force\\n    \\n    Write-Host \\\"\\\"\\n    Write-Host \\\"DONE! Deleted $([math]::Round($deleteTotal/1024, 2)) GB of safe files.\\\" -ForegroundColor Green\\n    \\n    # Show new space\\n    $disk = Get-WmiObject Win32_LogicalDisk -Filter \\\"DeviceID='C:'\\\"\\n    Write-Host \\\"C: drive now: $([math]::Round($disk.FreeSpace/1GB, 2)) GB free ($([math]::Round($disk.FreeSpace/$disk.Size*100, 1))%)\\\" -ForegroundColor Yellow\\n}\\n\"}",
      "output": "Wrote file successfully.",
      "status": "success",
      "timestamp": 1783147049815
