      "code": "{\"command\": \"# Count duplicate installers\\n$installers = Get-ChildItem -Path \\\"$env:USERPROFILE\\\\Downloads\\\" -Filter \\\"MiniMax*Setup*.exe\\\" -ErrorAction SilentlyContinue\\nWrite-Host \\\"MiniMax installers (duplicates): $($installers.Count) files\\\" -ForegroundColor Yellow\\n$installers | Sort-Object Length -Descending | ForEach-Object { Write-Host \\\"  $([math]::Round($_.Length/1MB,1)) MB - $($_.Name) (modified: $($_.LastWriteTime.ToString('yyyy-MM-dd')))\\\" -ForegroundColor Gray }\\n\\n$aiStudio = Get-ChildItem -Path \\\"$env:USERPROFILE\\\\Downloads\\\" -Filter \\\"Google AI Studio*.zip\\\" -ErrorAction SilentlyContinue\\nWrite-Host \\\"`nGoogle AI Studio zips (duplicates): $($aiStudio.Count) files\\\" -ForegroundColor Yellow\\n$aiStudio | Sort-Object Length -Descending | ForEach-Object { Write-Host \\\"  $([math]::Round($_.Length/1MB,1)) MB - $($_.Name)\\\" -ForegroundColor Gray }\\n\", \"description\": \"Count duplicate installers and zips\"}",
      "output": "MiniMax installers (duplicates): 3 files\n  402 MB - MiniMax Code Setup 3.0.35.exe (modified: 2026-06-03)\n  400.5 MB - MiniMax Agent Setup 3.0.29.exe (modified: 2026-05-21)\n  366.8 MB - MiniMax Agent Setup 3.0.25.exe (modified: 2026-05-14)\n\nGoogle AI Studio zips (duplicates): 4 files\n  2047.3 MB - Google AI Studio-20260623T104922Z-3-001.zip\n  2012.5 MB - Google AI Studio-20260623T104922Z-3-003.zip\n  1828.1 MB - Google AI Studio-20260623T104743Z-3-001.zip\n  1753.1 MB - Google AI Studio-20260623T104922Z-3-005.zip\n",
