    {
      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"# Sum up all safe-to-delete caches\\n$chromeCache = @(\\n    \\\"$env:LOCALAPPDATA\\\\Google\\\\Chrome\\\\User Data\\\\Default\\\\Cache\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Google\\\\Chrome\\\\User Data\\\\Default\\\\Code Cache\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Google\\\\Chrome\\\\User Data\\\\Default\\\\Service Worker\\\\CacheStorage\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Google\\\\Chrome\\\\User Data\\\\Default\\\\Service Worker\\\\ScriptCache\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Google\\\\Chrome\\\\User Data\\\\Default\\\\GPUCache\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Google\\\\Chrome\\\\User Data\\\\Profile 1\\\\Cache\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Google\\\\Chrome\\\\User Data\\\\Profile 1\\\\Code Cache\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Google\\\\Chrome\\\\User Data\\\\Profile 1\\\\GPUCache\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Google\\\\Chrome\\\\User Data\\\\ShaderCache\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Microsoft\\\\Edge\\\\User Data\\\\Default\\\\Cache\\\",\\n    \\\"$env:LOCALAPPDATA\\\\Microsoft\\\\Edge\\\\User Data\\\\Default\\\\Code Cache\\\"\\n)\\n\\n$totalMB = 0\\nforeach ($p in $chromeCache) {\\n    if (Test-Path $p) {\\n        $size = (Get-ChildItem -Path $p -Recurse -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum\\n        $totalMB += [math]::Round($size / 1MB, 1)\\n    }\\n}\\n\\n$tempSize = (Get-ChildItem -Path \\\"$env:TEMP\\\" -Recurse -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum\\n$tempMB = [math]::Round($tempSize / 1MB, 1)\\n\\n$downloadsSize = (Get-ChildItem -Path \\\"$env:USERPROFILE\\\\Downloads\\\" -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum\\n$downloadsMB = [math]::Round($downloadsSize / 1MB, 1)\\n\\n$crashDumps = (Get-ChildItem -Path \\\"$env:LOCALAPPDATA\\\\CrashDumps\\\" -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum\\n$crashMB = [math]::Round($crashDumps / 1MB, 1)\\n\\n$installerMSI = (Get-ChildItem -Path \\\"C:\\\\Windows\\\\Installer\\\" -File -Filter \\\"*.msi\\\" -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum\\n$installerMB = [math]::Round($installerMSI / 1MB, 1)\\n\\n$mmxPath = \\\"$env:LOCALAPPDATA\\\\@mmx-agentelectron-updater\\\"\\nif (Test-Path $mmxPath) {\\n    $mmxSize = (Get-ChildItem -Path $mmxPath -Recurse -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum\\n    $mmxMB = [math]::Round($mmxSize / 1MB, 1)\\n} else { $mmxMB = 0 }\\n\\nWrite-Host \\\"=============================================\\\" -ForegroundColor Cyan\\nWrite-Host \\\"  SAFE-TO-DELETE SPACE BREAKDOWN\\\" -ForegroundColor Cyan\\nWrite-Host \\\"=============================================\\\" -ForegroundColor Cyan\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"  Chrome Caches (both profiles):  $totalMB MB\\\" -ForegroundColor Green\\nWrite-Host \\\"  Edge Caches:                    ~330 MB\\\" -ForegroundColor Green\\nWrite-Host \\\"  Windows Temp:                   $tempMB MB\\\" -ForegroundColor Green\\nWrite-Host \\\"  Crash Dumps:                    $crashMB MB\\\" -ForegroundColor Green\\nWrite-Host \\\"  MiniMax Agent Cache:            $mmxMB MB\\\" -ForegroundColor Green\\nWrite-Host \\\"  Downloads Folder:               $downloadsMB MB  <-- BIGGEST TARGET\\\" -ForegroundColor Red\\nWrite-Host \\\"\\\"\\n$totalAll = $totalMB + 330 + $tempMB + $crashMB + $mmxMB + $downloadsMB\\nWrite-Host \\\"  TOTAL RECLAIMABLE:              $([math]::Round($totalAll/1024, 2)) GB\\\" -ForegroundColor Yellow\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"  Current C: free space:          3.32 GB (0.7%)\\\" -ForegroundColor Red\\nWrite-Host \\\"  After cleanup (est.):           $([math]::Round(3.32 + $totalAll/1024, 2)) GB ($([math]::Round((3.32 + $totalAll/1024) / 474 * 100, 1))%)\\\" -ForegroundColor Green\\nWrite-Host \\\"=============================================\\\" -ForegroundColor Cyan\\n\", \"description\": \"Calculate total reclaimable space\"}",
      "output": "=============================================\n  SAFE-TO-DELETE SPACE BREAKDOWN\n=============================================\n\n  Chrome Caches (both profiles):  2081.4 MB\n  Edge Caches:                    ~330 MB\n  Windows Temp:                   465.3 MB\n  Crash Dumps:                    66 MB\n  MiniMax Agent Cache:            815.6 MB\n  Downloads Folder:               21286.7 MB  <-- BIGGEST TARGET\n\n  TOTAL RECLAIMABLE:              24.46 GB\n\n  Current C: free space:          3.32 GB (0.7%)\n  After cleanup (est.):           27.78 GB (5.9%)\n=============================================\n",
      "status": "success",
