      "text": "Here are the complete contents of all 6 Vue component files:\n\n---\n\n## 1. `PostCard.vue` (85 lines)\n\n```vue\n<template>\n  <RouterLink\n    :to=\"`/posts/${post.id}`\"\n    class=\"group block rounded-xl bg-card border border-border p-5 transition-all hover:border-border-strong hover:shadow-md\"\n  >\n    <div class=\"flex items-start gap-3\">\n      <AppAvatar :user-id=\"post.author_id\" :size=\"36\" />\n      <div class=\"flex-1 min-w-0\">\n        <div\n          class=\"flex items-center gap-1.5 flex-wrap text-[12px] text-muted-foreground leading-tight\"\n        >\n          <span class=\"font-semibold text-foreground text-[13px]\">{{ author?.full_name }}</span>\n          <template v-if=\"showSpace && project\">\n            <span aria-hidden>·</span>\n            <span\n              >in\n              <span class=\"text-foreground/80\">{{ project.icon }} {{ project.title }}</span></span\n            >\n          </template>\n          <span aria-hidden>·</span>\n          <span>{{ timeAgo(post.created_at) }}</span>\n          <span\n            v-if=\"post.pinned_at\"\n            class=\"inline-flex items-center gap-1 text-primary-soft-foreground ml-1\"\n            >📌 Pinned</span\n          >\n          <SentimentBadge v-if=\"sent\" :sentiment=\"sent\" />\n        </div>\n\n        <h3 class=\"mt-1.5 text-[16px] font-semibold leading-snug text-foreground\">\n          {{ post.title }}\n        </h3>\n        <div\n          class=\"mt-1 text-[14px] leading-relaxed text-secondary-foreground line-clamp-2\"\n          v-html=\"post.content\"\n        />\n\n        <div\n          class=\"mt-3 pt-3 border-t border-border/70 flex items-center gap-5 text-[12px] text-muted-foreground\"\n        >\n          <span class=\"inline-flex items-center gap-1.5\">❤ {{ reactionCount }}</span>\n          <span class=\"inline-flex items-center gap-1.5\"\n            >💬 {{ post.comments_count }}\n            {{ post.comments_count === 1 ? \"comment\" : \"comments\" }}</span\n          >\n          <span v-if=\"reactionCount > 0\" class=\"text-[14px] leading-none\">{{ topEmojis }}</span>\n        </div>\n      </div>\n    </div>\n  </RouterLink>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from \"vue\";\nimport { RouterLink } from \"vue-router\";\nimport type { GPDiscussion } from \"@/mock-data/types\";\nimport { getProject, getUser, mockSentiment, getAISettings, getReactionsFor } from \"@/data/store\";\nimport AppAvatar from \"./AppAvatar.vue\";\nimport SentimentBadge from \"./SentimentBadge.vue\";\n\nconst props = defineProps<{\n  post: GPDiscussion;\n  showSpace?: boolean;\n}>();\n\nconst project = computed(() => getProject(props.post.project));\nconst author = computed(() => getUser(props.post.author_id));\nconst ai = getAISettings();\nconst sent = computed(() => (ai.enable_sentiment ? mockSentiment(props.post.content) : null));\nconst reactions = computed(() => getReactionsFor(\"GP Discussion\", props.post.id));\nconst reactionCount = computed(() => reactions.value.length);\nconst topEmojis = computed(() =>\n  [...new Set(reactions.value.map((r) => r.emoji))].slice(0, 3).join(\" \"),\n);\n\nfunction timeAgo(iso: string) {\n  const diff = Date.now() - new Date(iso).getTime();\n  const mins = Math.floor(diff / 60000);\n  if (mins < 1) return \"just now\";\n  if (mins < 60) return `${mins}m`;\n  const hrs = Math.floor(mins / 60);\n  if (hrs < 24) return `${hrs}h`;\n  return `${Math.floor(hrs / 24)}d`;\n}\n</script>\n```\n\n---\n\n## 2. `NewPostModal.vue` (133 lines)\n\n```vue\n<template>\n  <Teleport to=\"body\">\n    <div\n      v-if=\"open\"\n      class=\"fixed inset-0 z-50 bg-foreground/30 flex items-start justify-center pt-[10vh] px-4\"\n      @click=\"emit('close')\"\n    >\n      <div\n        class=\"w-full max-w-[680px] bg-card rounded-2xl shadow-2xl overflow-hidden flex flex-col\"\n        @click.stop\n      >\n        <header class=\"flex items-center justify-between px-6 py-4 border-b border-border\">\n          <h2 class=\"text-[16px] font-semibold\">New post</h2>\n          <button\n            class=\"size-8 rounded-md flex items-center justify-center text-muted-foreground hover:bg-secondary\"\n            aria-label=\"Close\"\n            @click=\"emit('close')\"\n          >\n            ✕\n          </button>\n        </header>\n\n        <div class=\"px-6 pt-5\">\n          <input\n            v-model=\"title\"\n            placeholder=\"Post title\"\n            autofocus\n            class=\"w-full bg-transparent text-[20px] font-semibold outline-none placeholder:text-muted-foreground/60\"\n          />\n        </div>\n\n        <textarea\n          v-model=\"body\"\n          placeholder=\"Share something kind. Ask a question. It's safe here.\"\n          :rows=\"8\"\n          class=\"px-6 pt-3 pb-4 w-full bg-transparent text-[15px] leading-relaxed outline-none resize-none placeholder:text-muted-foreground/60\"\n        />\n\n        <div\n          class=\"px-3 h-9 border-t border-border bg-background flex items-center gap-0.5 text-muted-foreground\"\n        >\n          <button\n            v-for=\"sym in ['B', 'I', '🔗', '🖼']\"\n            :key=\"sym\"\n            type=\"button\"\n            class=\"size-7 rounded-md flex items-center justify-center hover:bg-secondary hover:text-foreground text-[11px] font-bold\"\n          >\n            {{ sym }}\n          </button>\n        </div>\n\n        <footer class=\"px-6 py-3 border-t border-border flex items-center gap-3\">\n          <label class=\"text-[12px] text-muted-foreground\">Space</label>\n          <select\n            v-model=\"spaceId\"\n            class=\"h-8 px-2 rounded-md border border-border bg-background text-[13px] outline-none focus:border-primary\"\n          >\n            <option v-for=\"p in projects\" :key=\"p.id\" :value=\"p.id\">\n              {{ p.icon }} {{ p.title }}\n            </option>\n          </select>\n          <div class=\"ml-auto flex items-center gap-2\">\n            <button\n              class=\"h-8 px-3 rounded-full text-[13px] font-semibold text-muted-foreground hover:bg-secondary\"\n              @click=\"emit('close')\"\n            >\n              Cancel\n            </button>\n            <button\n              :disabled=\"!title.trim() || !body.trim()\"\n              class=\"h-8 px-5 rounded-full text-[13px] font-semibold bg-primary text-primary-foreground hover:opacity-90 disabled:opacity-40\"\n              @click=\"submit\"\n            >\n              Publish\n            </button>\n          </div>\n        </footer>\n      </div>\n    </div>\n  </Teleport>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, watch } from \"vue\";\nimport { useRouter } from \"vue-router\";\nimport { createDiscussion, getProjects } from \"@/data/store\";\n\nconst props = defineProps<{\n  open: boolean;\n  defaultSpaceId?: string;\n}>();\nconst emit = defineEmits<{ close: [] }>();\n\nconst router = useRouter();\nconst projects = getProjects();\nconst title = ref(\"\");\nconst body = ref(\"\");\nconst spaceId = ref(props.defaultSpaceId ?? projects[0]?.id);\n\nwatch(\n  () => props.open,\n  (v) => {\n    if (v) {\n      title.value = \"\";\n      body.value = \"\";\n      spaceId.value = props.defaultSpaceId ?? projects[0]?.id;\n    }\n  },\n);\n\nfunction onKey(e: KeyboardEvent) {\n  if (e.key === \"Escape\") emit(\"close\");\n}\n\nwatch(\n  () => props.open,\n  (v) => {\n    if (v) document.addEventListener(\"keydown\", onKey);\n    else document.removeEventListener(\"keydown\", onKey);\n  },\n);\n\nfunction submit() {\n  if (!title.value.trim() || !body.value.trim() || !spaceId.value) return;\n  const d = createDiscussion({\n    project: spaceId.value,\n    title: title.value,\n    content: `<p>${body.value.replace(/\\n\\n+/g, \"</p><p>\").replace(/\\n/g, \"<br/>\")}</p>`,\n  });\n  emit(\"close\");\n  router.push(`/posts/${d.id}`);\n}\n</script>\n```\n\n---\n\n## 3. `SentimentBadge.vue` (17 lines)\n\n```vue\n<template>\n  <span\n    v-if=\"sentiment.label === 'Needs Attention'\"\n    class=\"inline-flex items-center gap-1 rounded-full bg-flag/30 px-2 py-0.5 text-[11px] font-semibold text-flag-foreground\"\n    title=\"Mocked for this prototype — production version uses an ONNX sentiment model triggered from a Frappe doc_event.\"\n  >\n    ⚠ Flagged for check-in\n  </span>\n</template>\n\n<script setup lang=\"ts\">\nimport type { SentimentLabel } from \"@/mock-data/types\";\n\ndefineProps<{\n  sentiment: { label: SentimentLabel; score: number };\n}>();\n</script>\n```\n\n---\n\n## 4. `AppAvatar.vue` (32 lines)\n\n```vue\n<template>\n  <span\n    class=\"inline-flex items-center justify-center rounded-full font-semibold text-foreground shrink-0\"\n    :class=\"className\"\n    :style=\"{\n      width: `${size}px`,\n      height: `${size}px`,\n      background: bg,\n      fontSize: `${Math.round(size * 0.42)}px`,\n    }\"\n    :aria-label=\"u?.full_name\"\n  >\n    {{ initial }}\n  </span>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from \"vue\";\nimport { getUser } from \"@/data/store\";\n\nconst props = defineProps<{\n  userId: string;\n  size?: number;\n  class?: string;\n}>();\n\nconst size = computed(() => props.size ?? 36);\nconst className = computed(() => props.class ?? \"\");\nconst u = computed(() => getUser(props.userId));\nconst bg = computed(() => u.value?.image_background_color || \"#ede9fe\");\nconst initial = computed(() => (u.value?.full_name || \"?\").charAt(0).toUpperCase());\n</script>\n```\n\n---\n\n## 5. `SidebarItem.vue` (25 lines)\n\n```vue\n<template>\n  <RouterLink\n    :to=\"to\"\n    class=\"h-8 px-2 rounded-md flex items-center gap-2 text-[13px] transition-colors\"\n    :class=\"\n      active\n        ? 'bg-primary-soft text-primary-soft-foreground font-semibold'\n        : 'text-secondary-foreground hover:bg-secondary'\n    \"\n  >\n    <span class=\"text-base leading-none\">{{ icon }}</span>\n    <span class=\"truncate\">{{ label }}</span>\n  </RouterLink>\n</template>\n\n<script setup lang=\"ts\">\nimport { RouterLink } from \"vue-router\";\n\ndefineProps<{\n  to: string;\n  label: string;\n  active: boolean;\n  icon: string;\n}>();\n</script>\n```\n\n---\n\n## 6. `Toggle.vue` (23 lines)\n\n```vue\n<template>\n  <div class=\"flex items-center justify-between py-2 border-b border-border last:border-0\">\n    <span class=\"text-[14px]\">{{ label }}</span>\n    <button\n      type=\"button\"\n      role=\"switch\"\n      :aria-checked=\"value\"\n      class=\"relative h-5 w-9 rounded-full transition-colors\"\n      :class=\"value ? 'bg-primary' : 'bg-secondary'\"\n      @click=\"emit('change', !value)\"\n    >\n      <span\n        class=\"absolute top-0.5 size-4 rounded-full bg-card shadow transition-transform\"\n        :class=\"value ? 'translate-x-[18px]' : 'translate-x-0.5'\"\n      />\n    </button>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefineProps<{ label: string; value: boolean }>();\nconst emit = defineEmits<{ change: [v: boolean] }>();\n</script>\n```\n\nAll 6 files have been returned in full.",
