    {
      "type": "action",
      "tool": "write",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\karaoke_catalogue_builder.py\", \"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"\\nProfessional Karaoke Catalogue System\\nFor corporate event performers (Lancome-level quality)\\n\\\"\\\"\\\"\\n\\nimport os\\nimport json\\nimport sqlite3\\nimport subprocess\\nfrom pathlib import Path\\nfrom datetime import datetime\\nimport hashlib\\n\\nFFMPEG = r\\\"C:\\\\Users\\\\LLM-Test\\\\ffmpeg\\\\ffmpeg-master-latest-win64-gpl\\\\bin\\\\ffmpeg.exe\\\"\\nFFPROBE = r\\\"C:\\\\Users\\\\LLM-Test\\\\ffmpeg\\\\ffmpeg-master-latest-win64-gpl\\\\bin\\\\ffprobe.exe\\\"\\n\\nclass KaraokeCatalogue:\\n    \\\"\\\"\\\"\\n    Professional karaoke catalogue for event performers\\n    - Instant search\\n    - Netflix-quality standardization\\n    - Corporate event ready\\n    \\\"\\\"\\\"\\n    \\n    def __init__(self, catalogue_path=None):\\n        if catalogue_path is None:\\n            catalogue_path = Path.home() / \\\"Documents\\\" / \\\"Anna_Karaoke_Catalogue\\\"\\n        \\n        self.catalogue_path = Path(catalogue_path)\\n        self.catalogue_path.mkdir(exist_ok=True)\\n        \\n        self.db_path = self.catalogue_path / \\\"catalogue.db\\\"\\n        self.init_database()\\n        \\n    def init_database(self):\\n        \\\"\\\"\\\"Initialize SQLite database for catalogue\\\"\\\"\\\"\\n        conn = sqlite3.connect(self.db_path)\\n        c = conn.cursor()\\n        \\n        c.execute('''\\n            CREATE TABLE IF NOT EXISTS songs (\\n                id INTEGER PRIMARY KEY AUTOINCREMENT,\\n                title TEXT NOT NULL,\\n                artist TEXT NOT NULL,\\n                album TEXT,\\n                genre TEXT,\\n                key TEXT,\\n                tempo TEXT,\\n                duration_seconds REAL,\\n                duration_display TEXT,\\n                original_file TEXT,\\n                processed_file TEXT,\\n                file_hash TEXT UNIQUE,\\n                loudness_lufs REAL,\\n                true_peak_dbtp REAL,\\n                video_codec TEXT,\\n                video_quality_vmaf REAL,\\n                resolution TEXT,\\n                fps REAL,\\n                file_size_mb REAL,\\n                status TEXT DEFAULT 'pending',\\n                tags TEXT,\\n                notes TEXT,\\n                date_added TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\\n                date_processed TIMESTAMP,\\n                last_played TIMESTAMP,\\n                play_count INTEGER DEFAULT 0\\n            )\\n        ''')\\n        \\n        c.execute('''\\n            CREATE TABLE IF NOT EXISTS events (\\n                id INTEGER PRIMARY KEY AUTOINCREMENT,\\n                event_name TEXT NOT NULL,\\n                client TEXT,\\n                venue TEXT,\\n                event_date TIMESTAMP,\\n                songs_played TEXT,\\n                notes TEXT\\n            )\\n        ''')\\n        \\n        c.execute('CREATE INDEX IF NOT EXISTS idx_artist ON songs(artist)')\\n        c.execute('CREATE INDEX IF NOT EXISTS idx_title ON songs(title)')\\n        c.execute('CREATE INDEX IF NOT EXISTS idx_status ON songs(status)')\\n        \\n        conn.commit()\\n        conn.close()\\n    \\n    def scan_directory(self, directory):\\n        \\\"\\\"\\\"Scan directory for video/audio files\\\"\\\"\\\"\\n        directory = Path(directory)\\n        supported = {'.mp4', '.mkv', '.avi', '.mov', '.wav', '.mp3', '.m4a', '.opus', '.flac'}\\n        \\n        files = []\\n        for ext in supported:\\n            files.extend(directory.rglob(f\\\"*{ext}\\\"))\\n        \\n        return files\\n    \\n    def get_media_info(self, filepath):\\n        \\\"\\\"\\\"Get detailed media information\\\"\\\"\\\"\\n        cmd = [\\n            FFPROBE,\\n            \\\"-v\\\", \\\"quiet\\\",\\n            \\\"-print_format\\\", \\\"json\\\",\\n            \\\"-show_format\\\",\\n            \\\"-show_streams\\\",\\n            str(filepath)\\n        ]\\n        \\n        result = subprocess.run(cmd, capture_output=True, text=True)\\n        return json.loads(result.stdout)\\n    \\n    def calculate_file_hash(self, filepath):\\n        \\\"\\\"\\\"Calculate unique hash for file\\\"\\\"\\\"\\n        hasher = hashlib.md5()\\n        with open(filepath, 'rb') as f:\\n            for chunk in iter(lambda: f.read(8192), b''):\\n                hasher.update(chunk)\\n        return hasher.hexdigest()\\n    \\n    def measure_loudness(self, filepath):\\n        \\\"\\\"\\\"Measure audio loudness\\\"\\\"\\\"\\n        cmd = [\\n            FFMPEG,\\n            \\\"-i\\\", str(filepath),\\n            \\\"-af\\\", \\\"ebur128=peak=true\\\",\\n            \\\"-f\\\", \\\"null\\\",\\n            \\\"-\\\"\\n        ]\\n        \\n        result = subprocess.run(cmd, capture_output=True, text=True)\\n        \\n        measurements = {'lufs': -27, 'true_peak': -2}\\n        \\n        for line in result.stderr.split('\\\\n'):\\n            if 'Integrated loudness' in line:\\n                try:\\n                    measurements['lufs'] = float(line.split(':')[1].strip().replace(' LUFS', ''))\\n                except:\\n                    pass\\n            elif 'True peak' in line:\\n                try:\\n                    measurements['true_peak'] = float(line.split(':')[1].strip().replace(' dBTP', ''))\\n                except:\\n                    pass\\n        \\n        return measurements\\n    \\n    def extract_metadata_from_filename(self, filename):\\n        \\\"\\\"\\\"Try to extract artist - title from filename\\\"\\\"\\\"\\n        name = Path(filename).stem\\n        \\n        # Common patterns: \\\"Artist - Title\\\", \\\"Title - Artist\\\"\\n        separators = [' - ', ' \\u2013 ', ' feat ', ' ft ', ' featuring ']\\n        \\n        for sep in separators:\\n            if sep in name:\\n                parts = name.split(sep, 1)\\n                # Assume Artist - Title format\\n                return parts[0].strip(), parts[1].strip()\\n        \\n        return \\\"Unknown Artist\\\", name\\n    \\n    def add_to_catalogue(self, filepath, auto_process=False):\\n        \\\"\\\"\\\"Add song to catalogue\\\"\\\"\\\"\\n        filepath = Path(filepath)\\n        \\n        if not filepath.exists():\\n            print(f\\\"File not found: {filepath}\\\")\\n            return None\\n        \\n        # Check for duplicate\\n        file_hash = self.calculate_file_hash(filepath)\\n        \\n        conn = sqlite3.connect(self.db_path)\\n        c = conn.cursor()\\n        \\n        c.execute(\\\"SELECT id FROM songs WHERE file_hash = ?\\\", (file_hash,))\\n        if c.fetchone():\\n            print(f\\\"Already in catalogue: {filepath.name}\\\")\\n            conn.close()\\n            return None\\n        \\n        # Get metadata\\n        artist, title = self.extract_metadata_from_filename(filepath.name)\\n        info = self.get_media_info(filepath)\\n        \\n        # Extract video info\\n        duration = float(info.get('format', {}).get('duration', 0))\\n        size_mb = int(info.get('format', {}).get('size', 0)) / (1024*1024)\\n        \\n        video_codec = None\\n        resolution = None\\n        fps = None\\n        \\n        for stream in info.get('streams', []):\\n            if stream.get('codec_type') == 'video':\\n                video_codec = stream.get('codec_name')\\n                resolution = f\\\"{stream.get('width')}x{stream.get('height')}\\\"\\n                fps_str = stream.get('r_frame_rate', '30/1')\\n                if '/' in fps_str:\\n                    num, den = fps_str.split('/')\\n                    fps = float(num) / float(den) if float(den) > 0 else 30\\n                else:\\n                    fps = float(fps_str)\\n        \\n        # Measure loudness\\n        loudness = self.measure_loudness(filepath)\\n        \\n        # Duration display\\n        mins = int(duration // 60)\\n        secs = int(duration % 60)\\n        duration_display = f\\\"{mins}:{secs:02d}\\\"\\n        \\n        # Insert into database\\n        c.execute('''\\n            INSERT INTO songs (\\n                title, artist, duration_seconds, duration_display,\\n                original_file, file_hash, loudness_lufs, true_peak_dbtp,\\n                video_codec, resolution, fps, file_size_mb, status\\n            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\\n        ''', (\\n            title, artist, duration, duration_display,\\n            str(filepath), file_hash, loudness['lufs'], loudness['true_peak'],\\n            video_codec, resolution, fps, size_mb, 'raw'\\n        ))\\n        \\n        conn.commit()\\n        song_id = c.lastrowid\\n        conn.close()\\n        \\n        print(f\\\"Added: {artist} - {title} ({duration_display})\\\")\\n        \\n        if auto_process:\\n            self.process_song(song_id)\\n        \\n        return song_id\\n    \\n    def search(self, query):\\n        \\\"\\\"\\\"Instant search by artist, title, or tags\\\"\\\"\\\"\\n        conn = sqlite3.connect(self.db_path)\\n        c = conn.cursor()\\n        \\n        search_term = f\\\"%{query}%\\\"\\n        \\n        c.execute('''\\n            SELECT id, title, artist, duration_display, status, loudness_lufs\\n            FROM songs \\n            WHERE title LIKE ? OR artist LIKE ? OR tags LIKE ?\\n            ORDER BY artist, title\\n        ''', (search_term, search_term, search_term))\\n        \\n        results = c.fetchall()\\n        conn.close()\\n        \\n        return results\\n    \\n    def process_song(self, song_id, target_lufs=-27, target_tp=-2):\\n        \\\"\\\"\\\"Process song to Netflix broadcast standard\\\"\\\"\\\"\\n        conn = sqlite3.connect(self.db_path)\\n        c = conn.cursor()\\n        \\n        c.execute(\\\"SELECT * FROM songs WHERE id = ?\\\", (song_id,))\\n        song = c.fetchone()\\n        \\n        if not song:\\n            print(f\\\"Song ID {song_id} not found\\\")\\n            return False\\n        \\n        original_file = Path(song[11])  # original_file column\\n        \\n        if not original_file.exists():\\n            print(f\\\"File not found: {original_file}\\\")\\n            return False\\n        \\n        print(f\\\"\\\\nProcessing: {song[2]} - {song[1]}\\\")\\n        print(f\\\"  Original: {song[13]:.1f} LUFS, {song[14]:.1f} dBTP\\\")\\n        \\n        # Output paths\\n        processed_dir = self.catalogue_path / \\\"processed\\\"\\n        processed_dir.mkdir(exist_ok=True)\\n        \\n        stem = original_file.stem\\n        output_wav = processed_dir / f\\\"{stem}_27LUFS.wav\\\"\\n        output_mp4 = processed_dir / f\\\"{stem}_NETFLIX.mp4\\\"\\n        \\n        # Step 1: Convert to WAV for processing\\n        temp_wav = processed_dir / f\\\"{stem}_temp.wav\\\"\\n        \\n        cmd = [\\n            FFMPEG,\\n            \\\"-i\\\", str(original_file),\\n            \\\"-acodec\\\", \\\"pcm_s16le\\\",\\n            \\\"-ar\\\", \\\"48000\\\",\\n            \\\"-ac\\\", \\\"2\\\",\\n            str(temp_wav),\\n            \\\"-y\\\"\\n        ]\\n        subprocess.run(cmd, check=True, capture_output=True)\\n        \\n        # Step 2: Measure current loudness\\n        cmd = [\\n            FFMPEG,\\n            \\\"-i\\\", str(temp_wav),\\n            \\\"-af\\\", \\\"loudnorm=I=-27:TP=-2:LRA=11:print_format=json\\\",\\n            \\\"-f\\\", \\\"null\\\",\\n            \\\"-\\\"\\n        ]\\n        result = subprocess.run(cmd, capture_output=True, text=True)\\n        \\n        # Parse JSON\\n        try:\\n            json_start = result.stderr.find('{')\\n            json_end = result.stderr.rfind('}') + 1\\n            json_str = result.stderr[json_start:json_end]\\n            norm_data = json.loads(json_str)\\n        except:\\n            norm_data = {\\n                'input_i': song[13],\\n                'input_tp': song[14],\\n                'input_lra': 7,\\n                'input_thresh': -37\\n            }\\n        \\n        # Step 3: Apply Netflix normalization\\n        filter_str = (\\n            f\\\"loudnorm=I={target_lufs}:TP={target_tp}:LRA=11:\\\"\\n            f\\\"measured_I={norm_data.get('input_i', -27)}:\\\"\\n            f\\\"measured_TP={norm_data.get('input_tp', -2)}:\\\"\\n            f\\\"measured_LRA={norm_data.get('input_lra', 7)}:\\\"\\n            f\\\"measured_thresh={norm_data.get('input_thresh', -37)}:\\\"\\n            f\\\"linear=true\\\"\\n        )\\n        \\n        cmd = [\\n            FFMPEG,\\n            \\\"-i\\\", str(temp_wav),\\n            \\\"-af\\\", filter_str,\\n            \\\"-ar\\\", \\\"48000\\\",\\n            \\\"-ac\\\", \\\"2\\\",\\n            str(output_wav),\\n            \\\"-y\\\"\\n        ]\\n        subprocess.run(cmd, check=True, capture_output=True)\\n        \\n        # Step 4: Check if video file - encode with H.265\\n        video_exts = {'.mp4', '.mkv', '.avi', '.mov'}\\n        \\n        if original_file.suffix.lower() in video_exts:\\n            # Extract video and re-encode\\n            temp_video = processed_dir / f\\\"{stem}_video.mp4\\\"\\n            \\n            cmd = [\\n                FFMPEG,\\n                \\\"-i\\\", str(original_file),\\n                \\\"-an\\\",\\n                \\\"-c:v\\\", \\\"libx265\\\",\\n                \\\"-crf\\\", \\\"20\\\",\\n                \\\"-preset\\\", \\\"slow\\\",\\n                \\\"-pix_fmt\\\", \\\"yuv420p\\\",\\n                str(temp_video),\\n                \\\"-y\\\"\\n            ]\\n            subprocess.run(cmd, check=True, capture_output=True)\\n            \\n            # Mux with normalized audio\\n            cmd = [\\n                FFMPEG,\\n                \\\"-i\\\", str(temp_video),\\n                \\\"-i\\\", str(output_wav),\\n                \\\"-c:v\\\", \\\"copy\\\",\\n                \\\"-c:a\\\", \\\"aac\\\",\\n                \\\"-b:a\\\", \\\"256k\\\",\\n                \\\"-map\\\", \\\"0:v:0\\\",\\n                \\\"-map\\\", \\\"1:a:0\\\",\\n                \\\"-movflags\\\", \\\"+faststart\\\",\\n                str(output_mp4),\\n                \\\"-y\\\"\\n            ]\\n            subprocess.run(cmd, check=True, capture_output=True)\\n            \\n            # Cleanup\\n            temp_video.unlink(missing_ok=True)\\n        else:\\n            # Audio only - save as AAC\\n            output_mp4 = processed_dir / f\\\"{stem}_NETFLIX.m4a\\\"\\n            \\n            cmd = [\\n                FFMPEG,\\n                \\\"-i\\\", str(output_wav),\\n                \\\"-c:a\\\", \\\"aac\\\",\\n                \\\"-b:a\\\", \\\"256k\\\",\\n                \\\"-ar\\\", \\\"48000\\\",\\n                str(output_mp4),\\n                \\\"-y\\\"\\n            ]\\n            subprocess.run(cmd, check=True, capture_output=True)\\n        \\n        # Cleanup temp\\n        temp_wav.unlink(missing_ok=True)\\n        \\n        # Measure final loudness\\n        final_loudness = self.measure_loudness(output_mp4)\\n        \\n        # Update database\\n        c.execute('''\\n            UPDATE songs SET\\n                processed_file = ?,\\n                loudness_lufs = ?,\\n                true_peak_dbtp = ?,\\n                status = 'processed',\\n                date_processed = ?\\n            WHERE id = ?\\n        ''', (\\n            str(output_mp4),\\n            final_loudness['lufs'],\\n            final_loudness['true_peak'],\\n            datetime.now().isoformat(),\\n            song_id\\n        ))\\n        \\n        conn.commit()\\n        conn.close()\\n        \\n        print(f\\\"  Final: {final_loudness['lufs']:.1f} LUFS, {final_loudness['true_peak']:.1f} dBTP\\\")\\n        print(f\\\"  Saved: {output_mp4.name}\\\")\\n        \\n        return True\\n    \\n    def process_all_pending(self):\\n        \\\"\\\"\\\"Process all pending songs to Netflix standard\\\"\\\"\\\"\\n        conn = sqlite3.connect(self.db_path)\\n        c = conn.cursor()\\n        \\n        c.execute(\\\"SELECT id, title, artist FROM songs WHERE status = 'raw'\\\")\\n        pending = c.fetchall()\\n        conn.close()\\n        \\n        print(f\\\"\\\\nProcessing {len(pending)} songs to Netflix standard...\\\\n\\\")\\n        \\n        for song_id, title, artist in pending:\\n            self.process_song(song_id)\\n        \\n        print(f\\\"\\\\nComplete! {len(pending)} songs processed.\\\")\\n    \\n    def generate_playlist(self, event_name, song_ids):\\n        \\\"\\\"\\\"Generate playlist for event\\\"\\\"\\\"\\n        conn = sqlite3.connect(self.db_path)\\n        c = conn.cursor()\\n        \\n        playlist = []\\n        total_duration = 0\\n        \\n        for song_id in song_ids:\\n            c.execute('''\\n                SELECT title, artist, duration_seconds, duration_display, processed_file\\n                FROM songs WHERE id = ?\\n            ''', (song_id,))\\n            \\n            song = c.fetchone()\\n            if song:\\n                playlist.append({\\n                    'id': song_id,\\n                    'title': song[0],\\n                    'artist': song[1],\\n                    'duration': song[2],\\n                    'duration_display': song[3],\\n                    'file': song[4]\\n                })\\n                total_duration += song[2]\\n        \\n        # Save playlist\\n        playlist_file = self.catalogue_path / f\\\"playlist_{event_name}_{datetime.now().strftime('%Y%m%d')}.json\\\"\\n        \\n        with open(playlist_file, 'w') as f:\\n            json.dump({\\n                'event': event_name,\\n                'created': datetime.now().isoformat(),\\n                'total_songs': len(playlist),\\n                'total_duration': f\\\"{int(total_duration//60)}:{int(total_duration%60):02d}\\\",\\n                'songs': playlist\\n            }, f, indent=2)\\n        \\n        conn.close()\\n        \\n        print(f\\\"\\\\nPlaylist: {event_name}\\\")\\n        print(f\\\"Songs: {len(playlist)}\\\")\\n        print(f\\\"Duration: {int(total_duration//60)}:{int(total_duration%60):02d}\\\")\\n        print(f\\\"Saved: {playlist_file}\\\")\\n        \\n        return playlist_file\\n    \\n    def get_stats(self):\\n        \\\"\\\"\\\"Get catalogue statistics\\\"\\\"\\\"\\n        conn = sqlite3.connect(self.db_path)\\n        c = conn.cursor()\\n        \\n        stats = {}\\n        \\n        c.execute(\\\"SELECT COUNT(*) FROM songs\\\")\\n        stats['total_songs'] = c.fetchone()[0]\\n        \\n        c.execute(\\\"SELECT COUNT(*) FROM songs WHERE status = 'processed'\\\")\\n        stats['processed'] = c.fetchone()[0]\\n        \\n        c.execute(\\\"SELECT COUNT(*) FROM songs WHERE status = 'raw'\\\")\\n        stats['pending'] = c.fetchone()[0]\\n        \\n        c.execute(\\\"SELECT SUM(duration_seconds) FROM songs\\\")\\n        total_secs = c.fetchone()[0] or 0\\n        stats['total_duration'] = f\\\"{int(total_secs//3600)}h {int((total_secs%3600)//60)}m\\\"\\n        \\n        c.execute(\\\"SELECT SUM(file_size_mb) FROM songs\\\")\\n        stats['total_size_gb'] = round((c.fetchone()[0] or 0) / 1024, 1)\\n        \\n        c.execute(\\\"SELECT DISTINCT artist FROM songs ORDER BY artist\\\")\\n        stats['artists'] = [row[0] for row in c.fetchall()]\\n        \\n        conn.close()\\n        \\n        return stats\\n    \\n    def search_for_event(self, query):\\n        \\\"\\\"\\\"Quick search for live event requests\\\"\\\"\\\"\\n        results = self.search(query)\\n        \\n        print(f\\\"\\\\nSearch: '{query}'\\\")\\n        print(\\\"-\\\" * 60)\\n        \\n        if results:\\n            for song in results:\\n                status_icon = \\\"[OK]\\\" if song[4] == 'processed' else \\\"[--]\\\"\\n                print(f\\\"{status_icon} {song[2]} - {song[1]} ({song[3]}) [{song[5]:.0f} LUFS]\\\")\\n        else:\\n            print(\\\"No matches found.\\\")\\n        \\n        return results\\n\\n\\ndef main():\\n    \\\"\\\"\\\"Main entry point\\\"\\\"\\\"\\n    catalogue = KaraokeCatalogue()\\n    \\n    print(\\\"\\\\n\\\" + \\\"=\\\"*60)\\n    print(\\\"PROFESSIONAL KARAOKE CATALOGUE\\\")\\n    print(\\\"For Corporate Event Performers\\\")\\n    print(\\\"=\\\"*60)\\n    \\n    while True:\\n        print(\\\"\\\\nOptions:\\\")\\n        print(\\\"1. Scan directory for new songs\\\")\\n        print(\\\"2. Process all pending songs (Netflix standard)\\\")\\n        print(\\\"3. Search catalogue\\\")\\n        print(\\\"4. View statistics\\\")\\n        print(\\\"5. Generate event playlist\\\")\\n        print(\\\"6. Exit\\\")\\n        \\n        choice = input(\\\"\\\\nChoice (1-6): \\\").strip()\\n        \\n        if choice == \\\"1\\\":\\n            dir_path = input(\\\"\\\\nEnter directory path: \\\").strip()\\n            if os.path.exists(dir_path):\\n                files = catalogue.scan_directory(dir_path)\\n                print(f\\\"\\\\nFound {len(files)} files\\\")\\n                \\n                for f in files[:10]:  # Show first 10\\n                    catalogue.add_to_catalogue(f)\\n                \\n                if len(files) > 10:\\n                    print(f\\\"... and {len(files)-10} more\\\")\\n            else:\\n                print(\\\"Directory not found\\\")\\n        \\n        elif choice == \\\"2\\\":\\n            catalogue.process_all_pending()\\n        \\n        elif choice == \\\"3\\\":\\n            query = input(\\\"\\\\nSearch (artist or title): \\\").strip()\\n            catalogue.search_for_event(query)\\n        \\n        elif choice == \\\"4\\\":\\n            stats = catalogue.get_stats()\\n            print(f\\\"\\\\nCatalogue Statistics:\\\")\\n            print(f\\\"  Total Songs: {stats['total_songs']}\\\")\\n            print(f\\\"  Processed: {stats['processed']}\\\")\\n            print(f\\\"  Pending: {stats['pending']}\\\")\\n            print(f\\\"  Total Duration: {stats['total_duration']}\\\")\\n            print(f\\\"  Total Size: {stats['total_size_gb']} GB\\\")\\n            print(f\\\"  Artists: {len(stats['artists'])}\\\")\\n        \\n        elif choice == \\\"5\\\":\\n            event_name = input(\\\"\\\\nEvent name: \\\").strip()\\n            query = input(\\\"Search songs (or 'all'): \\\").strip()\\n            \\n            if query.lower() == 'all':\\n                conn = sqlite3.connect(catalogue.db_path)\\n                c = conn.cursor()\\n                c.execute(\\\"SELECT id FROM songs WHERE status = 'processed'\\\")\\n                song_ids = [row[0] for row in c.fetchall()]\\n                conn.close()\\n            else:\\n                results = catalogue.search(query)\\n                song_ids = [r[0] for r in results]\\n            \\n            if song_ids:\\n                catalogue.generate_playlist(event_name, song_ids)\\n            else:\\n                print(\\\"No songs found\\\")\\n        \\n        elif choice == \\\"6\\\":\\n            print(\\\"\\\\nGoodbye!\\\")\\n            break\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\"}",
