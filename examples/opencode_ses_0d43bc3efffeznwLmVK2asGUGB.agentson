  # Presence boost\\n                audio[:, ch] = signal.lfilter(b_peak, a_peak, audio[:, ch])\\n                # Low pass filter\\n                audio[:, ch] = signal.filtfilt(b_low, a_low, audio[:, ch])\\n        else:\\n            audio = signal.filtfilt(b_high, a_high, audio)\\n            audio = signal.lfilter(b_peak, a_peak, audio)\\n            audio = signal.filtfilt(b_low, a_low, audio)\\n    \\n    return audio\"}",
