    {
      "type": "action",
      "tool": "write",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\process_karaoke.py\", \"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"\\nProfessional Karaoke Track Processor\\nConverts and enhances karaoke tracks for studio-quality playback\\n\\\"\\\"\\\"\\n\\nimport os\\nimport sys\\nimport subprocess\\nimport numpy as np\\nfrom scipy import signal\\nfrom scipy.io import wavfile\\nimport warnings\\nwarnings.filterwarnings('ignore')\\n\\n# ffmpeg path\\nFFMPEG_PATH = r\\\"C:\\\\Users\\\\LLM-Test\\\\ffmpeg\\\\ffmpeg-master-latest-win64-gpl\\\\bin\\\\ffmpeg.exe\\\"\\nFFPROBE_PATH = r\\\"C:\\\\Users\\\\LLM-Test\\\\ffmpeg\\\\ffmpeg-master-latest-win64-gpl\\\\bin\\\\ffprobe.exe\\\"\\n\\ndef get_audio_info(filepath):\\n    \\\"\\\"\\\"Get audio file information using ffprobe\\\"\\\"\\\"\\n    cmd = [\\n        FFPROBE_PATH,\\n        \\\"-v\\\", \\\"quiet\\\",\\n        \\\"-print_format\\\", \\\"json\\\",\\n        \\\"-show_format\\\",\\n        \\\"-show_streams\\\",\\n        filepath\\n    ]\\n    result = subprocess.run(cmd, capture_output=True, text=True)\\n    import json\\n    return json.loads(result.stdout)\\n\\ndef convert_opus_to_wav(input_path, output_path):\\n    \\\"\\\"\\\"Convert Opus to WAV using ffmpeg\\\"\\\"\\\"\\n    cmd = [\\n        FFMPEG_PATH,\\n        \\\"-i\\\", input_path,\\n        \\\"-acodec\\\", \\\"pcm_s16le\\\",\\n        \\\"-ar\\\", \\\"48000\\\",\\n        \\\"-ac\\\", \\\"2\\\",\\n        output_path,\\n        \\\"-y\\\"\\n    ]\\n    subprocess.run(cmd, check=True, capture_output=True)\\n    print(f\\\"Converted to WAV: {output_path}\\\")\\n\\ndef normalize_audio(audio, target_db=-3):\\n    \\\"\\\"\\\"Normalize audio to target dB level\\\"\\\"\\\"\\n    # Calculate current RMS\\n    rms = np.sqrt(np.mean(audio**2))\\n    if rms == 0:\\n        return audio\\n    \\n    current_db = 20 * np.log10(rms)\\n    gain_db = target_db - current_db\\n    gain = 10 ** (gain_db / 20)\\n    return audio * gain\\n\\ndef apply_eq(audio, sample_rate, eq_type=\\\"piano\\\"):\\n    \\\"\\\"\\\"Apply equalization to enhance the audio\\\"\\\"\\\"\\n    nyquist = sample_rate / 2\\n    \\n    if eq_type == \\\"piano\\\":\\n        # Enhance piano frequencies (200Hz - 4kHz)\\n        # Low cut at 80Hz to remove rumble\\n        b_high, a_high = signal.butter(2, 80 / nyquist, btype='high')\\n        audio = signal.filtfilt(b_high, a_high, audio)\\n        \\n        # Boost presence (2-5kHz)\\n        center_freq = 3000\\n        Q = 1.5\\n        gain = 3  # dB\\n        w0 = center_freq / nyquist\\n        b_peak, a_peak = signal.iirpeak(w0, Q)\\n        audio = signal.lfilter(b_peak, a_peak, audio)\\n        \\n        # Gentle high cut at 12kHz to reduce harshness\\n        b_low, a_low = signal.butter(2, 12000 / nyquist, btype='low')\\n        audio = signal.filtfilt(b_low, a_low, audio)\\n    \\n    return audio\\n\\ndef apply_compression(audio, threshold_db=-20, ratio=4, attack_ms=10, release_ms=100, sample_rate=48000):\\n    \\\"\\\"\\\"Apply dynamic range compression\\\"\\\"\\\"\\n    threshold = 10 ** (threshold_db / 20)\\n    \\n    attack_samples = int(attack_ms * sample_rate / 1000)\\n    release_samples = int(release_ms * sample_rate / 1000)\\n    \\n    # Simple envelope follower\\n    envelope = np.zeros_like(audio)\\n    env_value = 0\\n    \\n    for i in range(len(audio)):\\n        abs_val = abs(audio[i])\\n        \\n        if abs_val > env_value:\\n            # Attack\\n            coeff = 1 - np.exp(-1 / attack_samples)\\n        else:\\n            # Release\\n            coeff = 1 - np.exp(-1 / release_samples)\\n        \\n        env_value = env_value + coeff * (abs_val - env_value)\\n        envelope[i] = env_value\\n    \\n    # Calculate gain reduction\\n    gain = np.ones_like(audio)\\n    mask = envelope > threshold\\n    gain[mask] = (threshold + (envelope[mask] - threshold) / ratio) / envelope[mask]\\n    \\n    return audio * gain\\n\\ndef apply_stereo_width(audio, width=1.2):\\n    \\\"\\\"\\\"Enhance stereo width slightly\\\"\\\"\\\"\\n    if audio.ndim == 2 and audio.shape[1] == 2:\\n        left = audio[:, 0]\\n        right = audio[:, 1]\\n        \\n        mid = (left + right) / 2\\n        side = (left - right) / 2\\n        \\n        side *= width\\n        \\n        left_out = mid + side\\n        right_out = mid - side\\n        \\n        return np.column_stack([left_out, right_out])\\n    return audio\\n\\ndef apply_reverb(audio, sample_rate, decay=0.3, predelay_ms=20):\\n    \\\"\\\"\\\"Apply subtle studio reverb\\\"\\\"\\\"\\n    # Simple convolution reverb with early reflections\\n    predelay_samples = int(predelay_ms * sample_rate / 1000)\\n    \\n    # Create impulse response\\n    ir_length = int(0.5 * sample_rate)  # 500ms reverb tail\\n    ir = np.zeros(ir_length)\\n    \\n    # Early reflections\\n    early_times = [0.02, 0.04, 0.08, 0.12, 0.16]\\n    for t in early_times:\\n        idx = int(t * sample_rate)\\n        if idx < ir_length:\\n            ir[idx] = decay * (1 - t / 0.5)\\n    \\n    # Late reflections (exponential decay)\\n    late_start = int(0.2 * sample_rate)\\n    for i in range(late_start, ir_length):\\n        t = i / sample_rate\\n        ir[i] = decay * np.exp(-3 * t) * np.random.uniform(-1, 1)\\n    \\n    # Normalize IR\\n    ir = ir / np.max(np.abs(ir))\\n    \\n    # Convolve with audio\\n    if audio.ndim == 2:\\n        # Process each channel\\n        left = signal.fftconvolve(audio[:, 0], ir, mode='full')[:len(audio[:, 0])]\\n        right = signal.fftconvolve(audio[:, 1], ir, mode='full')[:len(audio[:, 1])]\\n        reverb_audio = np.column_stack([left, right])\\n    else:\\n        reverb_audio = signal.fftconvolve(audio, ir, mode='full')[:len(audio)]\\n    \\n    # Mix dry and wet signals (30% reverb, 70% dry)\\n    return 0.7 * audio + 0.3 * reverb_audio\\n\\ndef process_karaoke(input_path, output_path):\\n    \\\"\\\"\\\"Main processing function\\\"\\\"\\\"\\n    print(f\\\"Processing: {input_path}\\\")\\n    \\n    # Step 1: Convert Opus to WAV\\n    temp_wav = input_path.rsplit('.', 1)[0] + '_temp.wav'\\n    convert_opus_to_wav(input_path, temp_wav)\\n    \\n    # Step 2: Read WAV file\\n    print(\\\"Reading audio...\\\")\\n    sample_rate, audio = wavfile.read(temp_wav)\\n    \\n    # Convert to float\\n    if audio.dtype == np.int16:\\n        audio = audio.astype(np.float32) / 32768.0\\n    elif audio.dtype == np.int32:\\n        audio = audio.astype(np.float32) / 2147483648.0\\n    \\n    # Ensure stereo\\n    if audio.ndim == 1:\\n        audio = np.column_stack([audio, audio])\\n    \\n    print(f\\\"Audio info: {len(audio)/sample_rate:.2f} seconds, {sample_rate} Hz, {audio.shape[1]} channels\\\")\\n    \\n    # Step 3: Apply processing chain\\n    print(\\\"Applying EQ...\\\")\\n    audio = apply_eq(audio, sample_rate, \\\"piano\\\")\\n    \\n    print(\\\"Applying compression...\\\")\\n    audio = apply_compression(audio, threshold_db=-18, ratio=3, attack_ms=10, release_ms=150, sample_rate=sample_rate)\\n    \\n    print(\\\"Normalizing levels...\\\")\\n    audio = normalize_audio(audio, target_db=-3)\\n    \\n    print(\\\"Enhancing stereo width...\\\")\\n    audio = apply_stereo_width(audio, width=1.15)\\n    \\n    print(\\\"Applying subtle reverb...\\\")\\n    audio = apply_reverb(audio, sample_rate, decay=0.25, predelay_ms=15)\\n    \\n    # Final normalization\\n    audio = normalize_audio(audio, target_db=-1)\\n    \\n    # Clip to prevent distortion\\n    audio = np.clip(audio, -1.0, 1.0)\\n    \\n    # Step 4: Convert back to 16-bit for WAV\\n    audio_16bit = (audio * 32767).astype(np.int16)\\n    \\n    # Step 5: Save processed audio\\n    print(f\\\"Saving processed audio: {output_path}\\\")\\n    wavfile.write(output_path, sample_rate, audio_16bit)\\n    \\n    # Cleanup temp file\\n    if os.path.exists(temp_wav):\\n        os.remove(temp_wav)\\n    \\n    print(\\\"Processing complete!\\\")\\n    return output_path\\n\\ndef main():\\n    # Input and output paths\\n    input_file = r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Alicia Keys - Girl On Fire Karaoke SLOWER Acoustic Piano Instrumental Cover Lyrics LOWER KEY\\\\Alicia Keys - Girl On Fire Karaoke SLOWER Acoustic Piano Instrumental Cover Lyrics LOWER KEY (160kbit_Opus).opus\\\"\\n    output_file = r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Alicia_Keys_Girl_On_Fire_Karaoke_Studio_Quality.wav\\\"\\n    \\n    # Process the karaoke track\\n    process_karaoke(input_file, output_file)\\n    \\n    # Also save as high-quality MP3 for Bluetooth playback\\n    mp3_output = r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Alicia_Keys_Girl_On_Fire_Karaoke_Studio_Quality.mp3\\\"\\n    cmd = [\\n        FFMPEG_PATH,\\n        \\\"-i\\\", output_file,\\n        \\\"-codec:a\\\", \\\"libmp3lame\\\",\\n        \\\"-b:a\\\", \\\"320k\\\",\\n        \\\"-ar\\\", \\\"48000\\\",\\n        mp3_output,\\n        \\\"-y\\\"\\n    ]\\n    subprocess.run(cmd, check=True, capture_output=True)\\n    print(f\\\"MP3 version saved: {mp3_output}\\\")\\n    \\n    # Print summary\\n    print(\\\"\\\\n\\\" + \\\"=\\\"*60)\\n    print(\\\"PROCESSING COMPLETE!\\\")\\n    print(\\\"=\\\"*60)\\n    print(f\\\"Input:  {input_file}\\\")\\n    print(f\\\"WAV:    {output_file}\\\")\\n    print(f\\\"MP3:    {mp3_output}\\\")\\n    print(\\\"\\\\nFiles processed with studio-quality enhancements:\\\")\\n    print(\\\"  - EQ optimized for acoustic piano\\\")\\n    print(\\\"  - Dynamic range compression\\\")\\n    print(\\\"  - Stereo width enhancement\\\")\\n    print(\\\"  - Subtle studio reverb\\\")\\n    print(\\\"  - Professional level normalization\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\"}",
