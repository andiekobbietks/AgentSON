      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\process_karaoke.py\", \"oldString\": \"def apply_compression(audio, threshold_db=-20, ratio=4, attack_ms=10, release_ms=100, sample_rate=48000):\\n    \\\"\\\"\\\"Apply dynamic range compression\\\"\\\"\\\"\\n    threshold = 10 ** (threshold_db / 20)\\n    \\n    attack_samples = int(attack_ms * sample_rate / 1000)\\n    release_samples = int(release_ms * sample_rate / 1000)\\n    \\n    # Simple envelope follower\\n    envelope = np.zeros_like(audio)\\n    env_value = 0\\n    \\n    for i in range(len(audio)):\\n        abs_val = abs(audio[i])\\n        \\n        if abs_val > env_value:\\n            # Attack\\n            coeff = 1 - np.exp(-1 / attack_samples)\\n        else:\\n            # Release\\n            coeff = 1 - np.exp(-1 / release_samples)\\n        \\n        env_value = env_value + coeff * (abs_val - env_value)\\n        envelope[i] = env_value\\n    \\n    # Calculate gain reduction\\n    gain = np.ones_like(audio)\\n    mask = envelope > threshold\\n    gain[mask] = (threshold + (envelope[mask] - threshold) / ratio) / envelope[mask]\\n    \\n    return audio * gain\", \"newString\": \"def apply_compression(audio, threshold_db=-20, ratio=4, attack_ms=10, release_ms=100, sample_rate=48000):\\n    \\\"\\\"\\\"Apply dynamic range compression\\\"\\\"\\\"\\n    threshold = 10 ** (threshold_db / 20)\\n    \\n    attack_samples = int(attack_ms * sample_rate / 1000)\\n    release_samples = int(release_ms * sample_rate / 1000)\\n    \\n    # Handle stereo audio\\n    if audio.ndim == 2:\\n        compressed = np.zeros_like(audio)\\n        for ch in range(audio.shape[1]):\\n            channel = audio[:, ch]\\n            envelope = np.zeros_like(channel)\\n            env_value = 0\\n            \\n            for i in range(len(channel)):\\n                abs_val = abs(channel[i])\\n                \\n                if abs_val > env_value:\\n                    coeff = 1 - np.exp(-1 / attack_samples)\\n                else:\\n                    coeff = 1 - np.exp(-1 / release_samples)\\n                \\n                env_value = env_value + coeff * (abs_val - env_value)\\n                envelope[i] = env_value\\n            \\n            gain = np.ones_like(channel)\\n            mask = envelope > threshold\\n            gain[mask] = (threshold + (envelope[mask] - threshold) / ratio) / envelope[mask]\\n            compressed[:, ch] = channel * gain\\n        \\n        return compressed\\n    else:\\n        envelope = np.zeros_like(audio)\\n        env_value = 0\\n        \\n        for i in range(len(audio)):\\n            abs_val = abs(audio[i])\\n            \\n            if abs_val > env_value:\\n                coeff = 1 - np.exp(-1 / attack_samples)\\n            else:\\n                coeff = 1 - np.exp(-1 / release_samples)\\n            \\n            env_value = env_value + coeff * (abs_val - env_value)\\n            envelope[i] = env_value\\n        \\n        gain = np.ones_like(audio)\\n        mask = envelope > threshold\\n        gain[mask] = (threshold + (envelope[mask] - threshold) / ratio) / envelope[mask]\\n        \\n        return audio * gain\"}",
      "output": "Edit applied successfully.",
      "status": "success",
