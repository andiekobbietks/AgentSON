      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\auto_karaoke_processor.py\", \"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"\\nAutomated Karaoke Download & Processing System\\nDownloads best quality audio and processes to studio quality\\nWorks with JDownloader or standalone with yt-dlp\\n\\\"\\\"\\\"\\n\\nimport os\\nimport sys\\nimport subprocess\\nimport json\\nimport re\\nfrom pathlib import Path\\nimport numpy as np\\nfrom scipy import signal\\nfrom scipy.io import wavfile\\nimport warnings\\nwarnings.filterwarnings('ignore')\\n\\n# Paths\\nFFMPEG_PATH = r\\\"C:\\\\Users\\\\LLM-Test\\\\ffmpeg\\\\ffmpeg-master-latest-win64-gpl\\\\bin\\\\ffmpeg.exe\\\"\\nFFPROBE_PATH = r\\\"C:\\\\Users\\\\LLM-Test\\\\ffmpeg\\\\ffmpeg-master-latest-win64-gpl\\\\bin\\\\ffprobe.exe\\\"\\nDOWNLOAD_DIR = Path.home() / \\\"Downloads\\\"\\nJDOWNLOADER_DIR = Path.home() / \\\"AppData\\\" / \\\"Local\\\" / \\\"JDownloader 2\\\"\\n\\nclass KaraokeProcessor:\\n    def __init__(self):\\n        self.ffmpeg = FFMPEG_PATH\\n        self.ffprobe = FFPROBE_PATH\\n        \\n    def get_audio_info(self, filepath):\\n        \\\"\\\"\\\"Get audio file information\\\"\\\"\\\"\\n        cmd = [\\n            self.ffprobe,\\n            \\\"-v\\\", \\\"quiet\\\",\\n            \\\"-print_format\\\", \\\"json\\\",\\n            \\\"-show_format\\\",\\n            \\\"-show_streams\\\",\\n            str(filepath)\\n        ]\\n        result = subprocess.run(cmd, capture_output=True, text=True)\\n        return json.loads(result.stdout)\\n    \\n    def download_with_ytdlp(self, url, output_dir=None):\\n        \\\"\\\"\\\"Download best quality audio using yt-dlp\\\"\\\"\\\"\\n        if output_dir is None:\\n            output_dir = DOWNLOAD_DIR / \\\"Karaoke_Downloads\\\"\\n            output_dir.mkdir(exist_ok=True)\\n        \\n        print(f\\\"Downloading from: {url}\\\")\\n        print(f\\\"Output directory: {output_dir}\\\")\\n        \\n        # yt-dlp command for best audio quality\\n        cmd = [\\n            \\\"yt-dlp\\\",\\n            \\\"--extract-audio\\\",\\n            \\\"--audio-format\\\", \\\"m4a\\\",  # AAC format (iPhone native)\\n            \\\"--audio-quality\\\", \\\"0\\\",   # Best quality\\n            \\\"--output\\\", str(output_dir / \\\"%(title)s.%(ext)s\\\"),\\n            \\\"--no-overwrites\\\",\\n            url\\n        ]\\n        \\n        result = subprocess.run(cmd, capture_output=True, text=True)\\n        \\n        if result.returncode == 0:\\n            print(\\\"Download successful!\\\")\\n            # Find the downloaded file\\n            for file in output_dir.glob(\\\"*.m4a\\\"):\\n                if file.stat().st_mtime > (subprocess.time.time() - 60):\\n                    return file\\n        else:\\n            print(f\\\"Download error: {result.stderr}\\\")\\n            return None\\n    \\n    def download_with_jdownloader(self, url):\\n        \\\"\\\"\\\"\\n        Add link to JDownloader for download\\n        Note: JDownloader must be running for this to work\\n        \\\"\\\"\\\"\\n        print(f\\\"Adding to JDownloader: {url}\\\")\\n        print(\\\"Please ensure JDownloader 2 is running!\\\")\\n        \\n        # JDownloader can be controlled via its API or command line\\n        # For simplicity, we'll create a .dlc file or use the clipboard method\\n        \\n        # Create a simple text file with the link\\n        link_file = DOWNLOAD_DIR / \\\"jd_links.txt\\\"\\n        with open(link_file, 'w') as f:\\n            f.write(url)\\n        \\n        print(f\\\"Link saved to: {link_file}\\\")\\n        print(\\\"Open JDownloader and paste the link, or use LinkGrabber\\\")\\n        \\n        return link_file\\n    \\n    def find_jdownloader_downloads(self):\\n        \\\"\\\"\\\"Find recently downloaded files from JDownloader\\\"\\\"\\\"\\n        jd_download_dirs = [\\n            DOWNLOAD_DIR,\\n            Path.home() / \\\"Downloads\\\" / \\\"JDownloader\\\",\\n            DOWNLOAD_DIR / \\\"jd:packagename\\\"\\n        ]\\n        \\n        recent_files = []\\n        for dir_path in jd_download_dirs:\\n            if dir_path.exists():\\n                for ext in ['*.m4a', '*.opus', '*.mp3', '*.wav', '*.flac']:\\n                    recent_files.extend(dir_path.glob(ext))\\n        \\n        # Sort by modification time (newest first)\\n        recent_files.sort(key=lambda x: x.stat().st_mtime, reverse=True)\\n        \\n        return recent_files[:10]  # Return last 10 files\\n    \\n    def process_audio(self, input_path, output_dir=None):\\n        \\\"\\\"\\\"Process audio file with studio effects\\\"\\\"\\\"\\n        input_path = Path(input_path)\\n        \\n        if output_dir is None:\\n            output_dir = DOWNLOAD_DIR / \\\"Processed_Karaoke\\\"\\n            output_dir.mkdir(exist_ok=True)\\n        \\n        print(f\\\"\\\\nProcessing: {input_path.name}\\\")\\n        \\n        # Step 1: Convert to WAV for processing\\n        temp_wav = output_dir / f\\\"{input_path.stem}_temp.wav\\\"\\n        \\n        cmd = [\\n            self.ffmpeg,\\n            \\\"-i\\\", str(input_path),\\n            \\\"-acodec\\\", \\\"pcm_s16le\\\",\\n            \\\"-ar\\\", \\\"48000\\\",\\n            \\\"-ac\\\", \\\"2\\\",\\n            str(temp_wav),\\n            \\\"-y\\\"\\n        ]\\n        subprocess.run(cmd, check=True, capture_output=True)\\n        \\n        # Step 2: Read WAV\\n        sample_rate, audio = wavfile.read(str(temp_wav))\\n        \\n        # Convert to float\\n        if audio.dtype == np.int16:\\n            audio = audio.astype(np.float32) / 32768.0\\n        elif audio.dtype == np.int32:\\n            audio = audio.astype(np.float32) / 2147483648.0\\n        \\n        # Ensure stereo\\n        if audio.ndim == 1:\\n            audio = np.column_stack([audio, audio])\\n        \\n        print(f\\\"  Audio: {len(audio)/sample_rate:.1f}s, {sample_rate}Hz\\\")\\n        \\n        # Step 3: Apply processing\\n        print(\\\"  Applying EQ...\\\")\\n        audio = self._apply_eq(audio, sample_rate)\\n        \\n        print(\\\"  Applying compression...\\\")\\n        audio = self._apply_compression(audio, sample_rate)\\n        \\n        print(\\\"  Normalizing...\\\")\\n        audio = self._normalize(audio, target_db=-3)\\n        \\n        print(\\\"  Enhancing stereo...\\\")\\n        audio = self._stereo_enhance(audio, width=1.15)\\n        \\n        print(\\\"  Adding reverb...\\\")\\n        audio = self._apply_reverb(audio, sample_rate)\\n        \\n        # Final normalization\\n        audio = self._normalize(audio, target_db=-1)\\n        audio = np.clip(audio, -1.0, 1.0)\\n        \\n        # Step 4: Save as WAV (lossless)\\n        audio_16bit = (audio * 32767).astype(np.int16)\\n        wav_output = output_dir / f\\\"{input_path.stem}_Studio.wav\\\"\\n        wavfile.write(str(wav_output), sample_rate, audio_16bit)\\n        \\n        # Step 5: Save as AAC (iPhone native)\\n        aac_output = output_dir / f\\\"{input_path.stem}_Studio.m4a\\\"\\n        cmd = [\\n            self.ffmpeg,\\n            \\\"-i\\\", str(wav_output),\\n            \\\"-codec:a\\\", \\\"aac\\\",\\n            \\\"-b:a\\\", \\\"256k\\\",\\n            \\\"-ar\\\", \\\"48000\\\",\\n            str(aac_output),\\n            \\\"-y\\\"\\n        ]\\n        subprocess.run(cmd, check=True, capture_output=True)\\n        \\n        # Step 6: Save as MP3 (320kbps for compatibility)\\n        mp3_output = output_dir / f\\\"{input_path.stem}_Studio.mp3\\\"\\n        cmd = [\\n            self.ffmpeg,\\n            \\\"-i\\\", str(wav_output),\\n            \\\"-codec:a\\\", \\\"libmp3lame\\\",\\n            \\\"-b:a\\\", \\\"320k\\\",\\n            \\\"-ar\\\", \\\"48000\\\",\\n            str(mp3_output),\\n            \\\"-y\\\"\\n        ]\\n        subprocess.run(cmd, check=True, capture_output=True)\\n        \\n        # Cleanup temp file\\n        temp_wav.unlink(missing_ok=True)\\n        \\n        print(f\\\"\\\\n  \\u2705 Processed files saved:\\\")\\n        print(f\\\"     WAV (lossless): {wav_output}\\\")\\n        print(f\\\"     AAC (iPhone):   {aac_output}\\\")\\n        print(f\\\"     MP3 (320kbps):  {mp3_output}\\\")\\n        \\n        return {\\n            'wav': wav_output,\\n            'aac': aac_output,\\n            'mp3': mp3_output\\n        }\\n    \\n    def _apply_eq(self, audio, sample_rate):\\n        \\\"\\\"\\\"Apply EQ optimized for piano\\\"\\\"\\\"\\n        nyquist = sample_rate / 2\\n        \\n        # High pass at 80Hz\\n        b_high, a_high = signal.butter(2, 80 / nyquist, btype='high')\\n        \\n        # Presence boost at 3kHz\\n        w0 = 3000 / nyquist\\n        b_peak, a_peak = signal.iirpeak(w0, 1.5)\\n        \\n        # Low pass at 12kHz\\n        b_low, a_low = signal.butter(2, 12000 / nyquist, btype='low')\\n        \\n        # Apply to each channel\\n        for ch in range(audio.shape[1]):\\n            audio[:, ch] = signal.filtfilt(b_high, a_high, audio[:, ch])\\n            audio[:, ch] = signal.lfilter(b_peak, a_peak, audio[:, ch])\\n            audio[:, ch] = signal.filtfilt(b_low, a_low, audio[:, ch])\\n        \\n        return audio\\n    \\n    def _apply_compression(self, audio, sample_rate, threshold_db=-18, ratio=3):\\n        \\\"\\\"\\\"Apply dynamic range compression\\\"\\\"\\\"\\n        threshold = 10 ** (threshold_db / 20)\\n        attack_samples = int(0.01 * sample_rate)  # 10ms\\n        release_samples = int(0.15 * sample_rate)  # 150ms\\n        \\n        compressed = np.zeros_like(audio)\\n        \\n        for ch in range(audio.shape[1]):\\n            channel = audio[:, ch]\\n            envelope = np.zeros_like(channel)\\n            env_value = 0\\n            \\n            for i in range(len(channel)):\\n                abs_val = abs(channel[i])\\n                coeff = 1 - np.exp(-1 / (attack_samples if abs_val > env_value else release_samples))\\n                env_value += coeff * (abs_val - env_value)\\n                envelope[i] = env_value\\n            \\n            gain = np.ones_like(channel)\\n            mask = envelope > threshold\\n            gain[mask] = (threshold + (envelope[mask] - threshold) / ratio) / envelope[mask]\\n            compressed[:, ch] = channel * gain\\n        \\n        return compressed\\n    \\n    def _normalize(self, audio, target_db=-3):\\n        \\\"\\\"\\\"Normalize audio levels\\\"\\\"\\\"\\n        rms = np.sqrt(np.mean(audio**2))\\n        if rms == 0:\\n            return audio\\n        \\n        current_db = 20 * np.log10(rms)\\n        gain_db = target_db - current_db\\n        gain = 10 ** (gain_db / 20)\\n        return audio * gain\\n    \\n    def _stereo_enhance(self, audio, width=1.15):\\n        \\\"\\\"\\\"Enhance stereo width\\\"\\\"\\\"\\n        if audio.ndim == 2 and audio.shape[1] == 2:\\n            left = audio[:, 0]\\n            right = audio[:, 1]\\n            \\n            mid = (left + right) / 2\\n            side = (left - right) / 2\\n            \\n            side *= width\\n            \\n            left_out = mid + side\\n            right_out = mid - side\\n            \\n            return np.column_stack([left_out, right_out])\\n        return audio\\n    \\n    def _apply_reverb(self, audio, sample_rate, decay=0.25):\\n        \\\"\\\"\\\"Apply subtle studio reverb\\\"\\\"\\\"\\n        # Create impulse response\\n        ir_length = int(0.5 * sample_rate)\\n        ir = np.zeros(ir_length)\\n        \\n        # Early reflections\\n        for t in [0.02, 0.04, 0.08, 0.12, 0.16]:\\n            idx = int(t * sample_rate)\\n            if idx < ir_length:\\n                ir[idx] = decay * (1 - t / 0.5)\\n        \\n        # Late reflections\\n        for i in range(int(0.2 * sample_rate), ir_length):\\n            t = i / sample_rate\\n            ir[i] = decay * np.exp(-3 * t) * np.random.uniform(-1, 1)\\n        \\n        ir = ir / np.max(np.abs(ir))\\n        \\n        # Convolve\\n        if audio.ndim == 2:\\n            left = signal.fftconvolve(audio[:, 0], ir, mode='full')[:len(audio[:, 0])]\\n            right = signal.fftconvolve(audio[:, 1], ir, mode='full')[:len(audio[:, 1])]\\n            reverb = np.column_stack([left, right])\\n        else:\\n            reverb = signal.fftconvolve(audio, ir, mode='full')[:len(audio)]\\n        \\n        return 0.7 * audio + 0.3 * reverb\\n\\n\\ndef main():\\n    \\\"\\\"\\\"Main workflow\\\"\\\"\\\"\\n    processor = KaraokeProcessor()\\n    \\n    print(\\\"=\\\" * 60)\\n    print(\\\"KARAOKE STUDIO PROCESSOR\\\")\\n    print(\\\"For Anna Enning's Performance\\\")\\n    print(\\\"=\\\" * 60)\\n    \\n    # Check if we have a URL or existing file\\n    if len(sys.argv) > 1:\\n        source = sys.argv[1]\\n    else:\\n        print(\\\"\\\\nOptions:\\\")\\n        print(\\\"1. Process existing file\\\")\\n        print(\\\"2. Download and process from YouTube\\\")\\n        print(\\\"3. Find JDownloader downloads\\\")\\n        \\n        choice = input(\\\"\\\\nEnter choice (1-3): \\\").strip()\\n        \\n        if choice == \\\"1\\\":\\n            source = input(\\\"Enter path to audio file: \\\").strip()\\n            if not os.path.exists(source):\\n                print(\\\"File not found!\\\")\\n                return\\n        elif choice == \\\"2\\\":\\n            source = input(\\\"Enter YouTube URL: \\\").strip()\\n        elif choice == \\\"3\\\":\\n            print(\\\"\\\\nSearching for recent downloads...\\\")\\n            files = processor.find_jdownloader_downloads()\\n            if files:\\n                print(\\\"\\\\nRecent audio files found:\\\")\\n                for i, f in enumerate(files[:5], 1):\\n                    print(f\\\"  {i}. {f.name}\\\")\\n                \\n                file_choice = input(\\\"\\\\nSelect file number (or 0 to cancel): \\\").strip()\\n                if file_choice.isdigit() and 1 <= int(file_choice) <= len(files):\\n                    source = files[int(file_choice) - 1]\\n                else:\\n                    print(\\\"Cancelled.\\\")\\n                    return\\n            else:\\n                print(\\\"No recent audio files found.\\\")\\n                return\\n        else:\\n            print(\\\"Invalid choice!\\\")\\n            return\\n    \\n    # Process based on source type\\n    if isinstance(source, str) and (source.startswith(\\\"http\\\") or source.startswith(\\\"www\\\")):\\n        # YouTube URL - download first\\n        print(f\\\"\\\\nDownloading from: {source}\\\")\\n        downloaded = processor.download_with_ytdlp(source)\\n        if downloaded:\\n            processor.process_audio(downloaded)\\n        else:\\n            print(\\\"Download failed!\\\")\\n    else:\\n        # Existing file\\n        processor.process_audio(source)\\n    \\n    print(\\\"\\\\n\\\" + \\\"=\\\" * 60)\\n    print(\\\"COMPLETE!\\\")\\n    print(\\\"=\\\" * 60)\\n    print(\\\"\\\\nFor iPhone playback:\\\")\\n    print(\\\"  - Use the .m4a file (native AAC)\\\")\\n    print(\\\"  - Or use the .wav file (lossless)\\\")\\n    print(\\\"\\\\nFor Bluetooth speakers:\\\")\\n    print(\\\"  - Use the .mp3 file (320kbps)\\\")\\n    print(\\\"  - Ensure 'High Quality' is enabled in Bluetooth settings\\\")\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\"}",
