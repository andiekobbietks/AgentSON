    },
    {
      "type": "action",
      "tool": "todowrite",
      "code": "{\"todos\": [{\"content\": \"Add prosody explainer tooltip on first visit\", \"priority\": \"high\", \"status\": \"in_progress\"}, {\"content\": \"Build onboarding flow for non-technical users (first-visit wizard)\", \"priority\": \"high\", \"status\": \"pending\"}, {\"content\": \"Add WPM guidance recommender based on language level\", \"priority\": \"high\", \"status\": \"pending\"}, {\"content\": \"Build progress tracking across sessions (localStorage stats)\", \"priority\": \"high\", \"status\": \"pending\"}, {\"content\": \"Build teacher/classroom mode route\", \"priority\": \"medium\", \"status\": \"pending\"}, {\"content\": \"Add non-English language support (language selector)\", \"priority\": \"medium\", \"status\": \"pending\"}, {\"content\": \"Expand dialect/voice selection beyond 6 Kokoro voices\", \"priority\": \"medium\", \"status\": \"pending\"}, {\"content\": \"Verify build and push to GitHub\", \"priority\": \"high\", \"status\": \"pending\"}]}",
      "output": "[\n  {\n    \"content\": \"Add prosody explainer tooltip on first visit\",\n    \"status\": \"in_progress\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Build onboarding flow for non-technical users (first-visit wizard)\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Add WPM guidance recommender based on language level\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Build progress tracking across sessions (localStorage stats)\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Build teacher/classroom mode route\",\n    \"status\": \"pending\",\n    \"priority\": \"medium\"\n  },\n  {\n    \"content\": \"Add non-English language support (language selector)\",\n    \"status\": \"pending\",\n    \"priority\": \"medium\"\n  },\n  {\n    \"content\": \"Expand dialect/voice selection beyond 6 Kokoro voices\",\n    \"status\": \"pending\",\n    \"priority\": \"medium\"\n  },\n  {\n    \"content\": \"Verify build and push to GitHub\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  }\n]",
