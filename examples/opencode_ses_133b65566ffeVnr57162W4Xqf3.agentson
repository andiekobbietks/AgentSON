      "type": "action",
      "tool": "read",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\lib\\\\teleprompter\\\\use-syllabus-mirror.ts\"}",
      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\lib\\teleprompter\\use-syllabus-mirror.ts</path>\n<type>file</type>\n<content>\n1: import { useEffect, useMemo, useRef, useState } from \"react\";\n2: import { SyllabusMirror, type ScheduleSnapshot } from \"./syllabus-mirror\";\n3: import type { Sentence, Token } from \"./tokens\";\n4: import { applySentenceDuration, markScheduled, markSpoken } from \"./tokens\";\n5: \n6: /**\n7:  * React adapter around the SyllabusMirror orchestrator. Returns a stable\n8:  * instance plus the latest snapshot, and pipes alignment events back into a\n9:  * setTokens callback so the transcript re-times itself once Kokoro reports\n10:  * the real duration of a sentence.\n11:  */\n12: export function useSyllabusMirror(\n13:   tokens: Token[],\n14:   sentences: Sentence[],\n15:   currentMs: number,\n16:   playing: boolean,\n17:   setTokens: (updater: (prev: Token[]) => Token[]) => void,\n18: ) {\n19:   const orchestratorRef = useRef<SyllabusMirror | null>(null);\n20:   if (!orchestratorRef.current && typeof window !== \"undefined\") {\n21:     orchestratorRef.current = new SyllabusMirror();\n22:   }\n23:   const orch = orchestratorRef.current;\n24:   const [snap, setSnap] = useState<ScheduleSnapshot | null>(\n25:     () => orch?.getSnapshot() ?? null,\n26:   );\n27: \n28:   useEffect(() => {\n29:     if (!orch) return;\n30:     const off1 = orch.onChange(setSnap);\n31:     const off2 = orch.onAlign((sentenceId, measuredMs) => {\n32:       setTokens((prev) => applySentenceDuration(prev, sentenceId, measuredMs));\n33:     });\n34:     const off3 = orch.onScheduled((sentenceId) => {\n35:       setTokens((prev) => markScheduled(prev, sentenceId));\n36:     });\n37:     const off4 = orch.onSpoken((throughMs) => {\n38:       setTokens((prev) => markSpoken(prev, throughMs));\n39:     });\n40:     return () => {\n41:       off1();\n42:       off2();\n43:       off3();\n44:       off4();\n45:     };\n46:   }, [orch, setTokens]);\n47: \n48:   useEffect(() => {\n49:     orch?.setPlaying(playing);\n50:   }, [orch, playing]);\n51: \n52:   useEffect(() => {\n53:     orch?.tick(currentMs, tokens, sentences);\n54:   }, [orch, currentMs, tokens, sentences]);\n55: \n56:   useEffect(() => {\n57:     return () => {\n58:       orch?.dispose();\n59:     };\n60:   }, [orch]);\n61: \n62:   return useMemo(\n63:     () => ({ orchestrator: orch, snapshot: snap }),\n64:     [orch, snap],\n65:   );\n66: }\n\n(End of file - total 66 lines)\n</content>",
