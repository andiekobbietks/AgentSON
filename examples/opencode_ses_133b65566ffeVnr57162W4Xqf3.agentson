      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\Prolector-Google-AI-Studio-prototypee\\src\\App.tsx</path>\n<type>file</type>\n<content>\n1: /**\n2:  * @license\n3:  * SPDX-License-Identifier: Apache-2.0\n4:  */\n5: \n6: import React, { useState, useEffect } from 'react';\n7: import Navbar from './components/Navbar';\n8: import SceneStudio from './components/SceneStudio';\n9: import EbookReader from './components/EbookReader';\n10: import RemotionTimelineStudio from './components/RemotionTimelineStudio';\n11: import EdlSandbox from './components/EdlSandbox';\n12: import SettingsPortal from './components/SettingsPortal';\n13: import { EbookId, LeadCapture } from './types';\n14: \n15: export default function App() {\n16:   const [activeTab, setActiveTab] = useState<'studio' | 'library' | 'teleprompter' | 'edl-sandbox' | 'settings'>('studio');\n17:   const [selectedEbookId, setSelectedEbookId] = useState<EbookId | null>(null);\n18:   \n19:   // Shared persistent leads state list\n20:   const [leads, setLeads] = useState<LeadCapture[]>(() => {\n21:     try {\n22:       const stored = localStorage.getItem('prolector_leads_index');\n23:       return stored ? JSON.parse(stored) : [];\n24:     } catch {\n25:       return [];\n26:     }\n27:   });\n28: \n29:   // Track leads to cache storage\n30:   useEffect(() => {\n31:     localStorage.setItem('prolector_leads_index', JSON.stringify(leads));\n32:   }, [leads]);\n33: \n34:   return (\n35:     <div className=\"min-h-screen bg-[#091a2f] text-[#fafafa] selection:bg-[#f97316] selection:text-slate-950 flex flex-col font-sans\">\n36:       \n37:       {/* Dynamic Brand Navigation bar */}\n38:       <Navbar \n39:         activeTab={activeTab} \n40:         setActiveTab={setActiveTab} \n41:         selectedEbookId={selectedEbookId}\n42:         setSelectedEbookId={setSelectedEbookId}\n43:       />\n44: \n45:       {/* Main Content Router rendering */}\n46:       <div className=\"flex-1\">\n47:         {activeTab === 'studio' && (\n48:           <SceneStudio />\n49:         )}\n50: \n51:         {activeTab === 'library' && (\n52:           <EbookReader \n53:             selectedEbookId={selectedEbookId} \n54:             setSelectedEbookId={setSelectedEbookId}\n55:             leads={leads}\n56:             setLeads={setLeads}\n57:           />\n58:         )}\n59: \n60:         {activeTab === 'teleprompter' && (\n61:           <RemotionTimelineStudio />\n62:         )}\n63: \n64:         {activeTab === 'edl-sandbox' && (\n65:           <EdlSandbox />\n66:         )}\n67: \n68:         {activeTab === 'settings' && (\n69:           <SettingsPortal \n70:             leads={leads} \n71:             setLeads={setLeads}\n72:           />\n73:         )}\n74:       </div>\n75: \n76:     </div>\n77:   );\n78: }\n\n(End of file - total 78 lines)\n</content>",
