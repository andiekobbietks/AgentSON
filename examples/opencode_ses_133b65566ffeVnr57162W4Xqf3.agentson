    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"/**\\n * SessionStats \\u2014 Tracks training progress across sessions.\\n *\\n * Persists to localStorage: total practice time, sessions completed,\\n * streak, average WPM, stumble count, and improvement trends.\\n */\\nexport type SessionRecord = {\\n  id: string;\\n  date: string; // ISO date\\n  durationMs: number;\\n  wpm: number;\\n  wordsSpoken: number;\\n  stumbleCount: number;\\n  scriptPreview: string; // First 100 chars\\n  prosodyOn: boolean;\\n};\\n\\nexport type ProgressStats = {\\n  totalSessions: number;\\n  totalPracticeMs: number;\\n  totalWordsSpoken: number;\\n  totalStumbles: number;\\n  currentStreak: number;\\n  longestStreak: number;\\n  averageWpm: number;\\n  sessions: SessionRecord[];\\n};\\n\\nconst STORAGE_KEY = \\\"prolector.progress.v1\\\";\\n\\nfunction load(): SessionRecord[] {\\n  if (typeof window === \\\"undefined\\\") return [];\\n  try {\\n    const raw = localStorage.getItem(STORAGE_KEY);\\n    return raw ? JSON.parse(raw) : [];\\n  } catch {\\n    return [];\\n  }\\n}\\n\\nfunction save(sessions: SessionRecord[]) {\\n  if (typeof window === \\\"undefined\\\") return;\\n  try {\\n    localStorage.setItem(STORAGE_KEY, JSON.stringify(sessions));\\n  } catch {\\n    // Storage full \\u2014 silently drop oldest.\\n    localStorage.setItem(STORAGE_KEY, JSON.stringify(sessions.slice(-50)));\\n  }\\n}\\n\\nexport function getProgress(): ProgressStats {\\n  const sessions = load();\\n  const totalPracticeMs = sessions.reduce((n, s) => n + s.durationMs, 0);\\n  const totalWordsSpoken = sessions.reduce((n, s) => n + s.wordsSpoken, 0);\\n  const totalStumbles = sessions.reduce((n, s) => n + s.stumbleCount, 0);\\n  const averageWpm =\\n    sessions.length > 0\\n      ? sessions.reduce((n, s) => n + s.wpm, 0) / sessions.length\\n      : 0;\\n\\n  // Streak calculation.\\n  let currentStreak = 0;\\n  let longestStreak = 0;\\n  let streak = 0;\\n  let prevDate = \\\"\\\";\\n  for (const s of [...sessions].sort((a, b) => a.date.localeCompare(b.date))) {\\n    const d = s.date.slice(0, 10);\\n    if (d === prevDate) continue;\\n    if (prevDate === \\\"\\\" || isConsecutiveDay(prevDate, d)) {\\n      streak++;\\n    } else {\\n      streak = 1;\\n    }\\n    prevDate = d;\\n    longestStreak = Math.max(longestStreak, streak);\\n  }\\n  // Current streak counts from today backwards.\\n  const today = new Date().toISOString().slice(0, 10);\\n  const dates = [...new Set(sessions.map((s) => s.date.slice(0, 10)))].sort().reverse();\\n  currentStreak = 0;\\n  let checkDate = today;\\n  for (const d of dates) {\\n    if (d === checkDate || isConsecutiveDay(d, checkDate)) {\\n      currentStreak++;\\n      checkDate = d;\\n    } else {\\n      break;\\n    }\\n  }\\n\\n  return {\\n    totalSessions: sessions.length,\\n    totalPracticeMs,\\n    totalWordsSpoken,\\n    totalStumbles,\\n    currentStreak,\\n    longestStreak,\\n    averageWpm: Math.round(averageWpm),\\n    sessions: sessions.slice(-20), // Last 20 sessions.\\n  };\\n}\\n\\nexport function recordSession(session: Omit<SessionRecord, \\\"id\\\" | \\\"date\\\">) {\\n  const sessions = load();\\n  const record: SessionRecord = {\\n    ...session,\\n    id: `s${Date.now().toString(36)}`,\\n    date: new Date().toISOString(),\\n  };\\n  sessions.push(record);\\n  // Keep last 200 sessions.\\n  save(sessions.slice(-200));\\n  return record;\\n}\\n\\nexport function clearProgress() {\\n  save([]);\\n}\\n\\nfunction isConsecutiveDay(a: string, b: string): boolean {\\n  const da = new Date(a + \\\"T00:00:00\\\");\\n  const db = new Date(b + \\\"T00:00:00\\\");\\n  const diff = Math.abs(db.getTime() - da.getTime());\\n  return diff <= 86400000 * 1.5; // Allow some timezone drift.\\n}\\n\\nexport function formatDuration(ms: number): string {\\n  const totalMin = Math.floor(ms / 60000);\\n  if (totalMin < 1) return \\\"< 1 min\\\";\\n  if (totalMin < 60) return `${totalMin} min`;\\n  const hours = Math.floor(totalMin / 60);\\n  const min = totalMin % 60;\\n  return min > 0 ? `${hours}h ${min}m` : `${hours}h`;\\n}\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\lib\\\\teleprompter\\\\session-stats.ts\"}",
      "output": "Wrote file successfully.",
      "status": "success",
      "timestamp": 1781550724356
    },
    {
      "type": "thought",
      "text": "Now create the ProgressDashboard component.",
      "timestamp": 1781550730705
    },
    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"/**\\n * ProgressDashboard \\u2014 Shows training progress across sessions.\\n *\\n * Displays: streak, total practice time, average WPM, session history,\\n * and improvement trend. Uses localStorage data from session-stats.ts.\\n */\\nimport { useMemo } from \\\"react\\\";\\nimport { getProgress, formatDuration } from \\\"@/lib/teleprompter/session-stats\\\";\\n\\nexport function ProgressDashboard() {\\n  const stats = useMemo(() => getProgress(), []);\\n\\n  const recentSessions = stats.sessions.slice(-7).reverse();\\n  const trendWpm = useMemo(() => {\\n    if (recentSessions.length < 2) return null;\\n    const first = recentSessions[0].wpm;\\n    const last = recentSessions[recentSessions.length - 1].wpm;\\n    return last - first;\\n  }, [recentSessions]);\\n\\n  if (stats.totalSessions === 0) {\\n    return (\\n      <div className=\\\"text-center py-8\\\">\\n        <div className=\\\"text-4xl mb-3\\\">\\ud83d\\udcca</div>\\n        <p className=\\\"text-sm text-muted-foreground\\\">\\n          No sessions recorded yet. Start training to see your progress here.\\n        </p>\\n      </div>\\n    );\\n  }\\n\\n  return (\\n    <div className=\\\"space-y-6\\\">\\n      {/* Summary cards */}\\n      <div className=\\\"grid grid-cols-2 gap-3\\\">\\n        <StatCard\\n          label=\\\"Sessions\\\"\\n          value={String(stats.totalSessions)}\\n          icon=\\\"\\ud83d\\udcdd\\\"\\n        />\\n        <StatCard\\n          label=\\\"Practice Time\\\"\\n          value={formatDuration(stats.totalPracticeMs)}\\n          icon=\\\"\\u23f1\\\"\\n        />\\n        <StatCard\\n          label=\\\"Streak\\\"\\n          value={`${stats.currentStreak} day${stats.currentStreak === 1 ? \\\"\\\" : \\\"s\\\"}`}\\n          icon=\\\"\\ud83d\\udd25\\\"\\n          highlight={stats.currentStreak >= 3}\\n        />\\n        <StatCard\\n          label=\\\"Avg WPM\\\"\\n          value={String(stats.averageWpm)}\\n          icon=\\\"\\ud83c\\udfaf\\\"\\n          sub={trendWpm != null ? `${trendWpm > 0 ? \\\"+\\\" : \\\"\\\"}${trendWpm} trend` : undefined}\\n        />\\n      </div>\\n\\n      {/* Words spoken */}\\n      <div className=\\\"bg-card border border-border rounded p-4 text-center\\\">\\n        <div className=\\\"text-2xl font-display font-bold\\\">\\n          {stats.totalWordsSpoken.toLocaleString()}\\n        </div>\\n        <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n          Total Words Spoken\\n        </div>\\n      </div>\\n\\n      {/* Session history */}\\n      {recentSessions.length > 0 && (\\n        <div>\\n          <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground mb-3\\\">\\n            Recent Sessions\\n          </div>\\n          <div className=\\\"space-y-2\\\">\\n            {recentSessions.map((s) => (\\n              <div\\n                key={s.id}\\n                className=\\\"flex items-center gap-3 text-xs border border-border rounded px-3 py-2\\\"\\n              >\\n                <span className=\\\"text-muted-foreground w-16 shrink-0\\\">\\n                  {new Date(s.date).toLocaleDateString(\\\"en-GB\\\", {\\n                    day: \\\"numeric\\\",\\n                    month: \\\"short\\\",\\n                  })}\\n                </span>\\n                <span className=\\\"font-mono text-foreground w-12\\\">\\n                  {s.wpm} WPM\\n                </span>\\n                <span className=\\\"text-muted-foreground flex-1 truncate\\\">\\n                  {s.scriptPreview}\\u2026\\n                </span>\\n                <span className=\\\"text-muted-foreground\\\">\\n                  {formatDuration(s.durationMs)}\\n                </span>\\n              </div>\\n            ))}\\n          </div>\\n        </div>\\n      )}\\n\\n      {/* Best streak */}\\n      {stats.longestStreak > 1 && (\\n        <div className=\\\"text-center text-xs text-muted-foreground\\\">\\n          Longest streak: {stats.longestStreak} days\\n        </div>\\n      )}\\n    </div>\\n  );\\n}\\n\\nfunction StatCard({\\n  label,\\n  value,\\n  icon,\\n  highlight,\\n  sub,\\n}: {\\n  label: string;\\n  value: string;\\n  icon: string;\\n  highlight?: boolean;\\n  sub?: string;\\n}) {\\n  return (\\n    <div\\n      className={`border rounded p-3 text-center ${\\n        highlight ? \\\"border-primary/40 bg-primary/5\\\" : \\\"border-border\\\"\\n      }`}\\n    >\\n      <div className=\\\"text-lg mb-0.5\\\">{icon}</div>\\n      <div className=\\\"text-lg font-display font-bold\\\">{value}</div>\\n      <div className=\\\"text-[9px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n        {label}\\n      </div>\\n      {sub && (\\n        <div className=\\\"text-[9px] font-mono text-primary mt-0.5\\\">{sub}</div>\\n      )}\\n    </div>\\n  );\\n}\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\components\\\\ProgressDashboard.tsx\"}",
      "output": "Wrote file successfully.",
      "status": "success",
      "timestamp": 1781550744285
    },
    {
      "type": "thought",
      "text": "Now create the teacher/classroom mode route.",
      "timestamp": 1781550752387
    },
    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"/**\\n * WPMGuidance \\u2014 Recommends starting WPM based on language level.\\n *\\n * Shows a visual scale from beginner to broadcast speed, with the\\n * user's recommended zone highlighted. Explains why WPM matters for\\n * each level.\\n */\\n\\nconst LEVELS = [\\n  {\\n    id: \\\"a2\\\",\\n    label: \\\"A2\\\",\\n    range: \\\"80\\u2013100\\\",\\n    start: 90,\\n    target: 100,\\n    description: \\\"Slow and clear. Focus on individual word pronunciation.\\\",\\n    color: \\\"bg-green-500\\\",\\n  },\\n  {\\n    id: \\\"b1\\\",\\n    label: \\\"B1\\\",\\n    range: \\\"100\\u2013120\\\",\\n    start: 100,\\n    target: 120,\\n    description: \\\"Conversational pace. Start connecting words naturally.\\\",\\n    color: \\\"bg-yellow-500\\\",\\n  },\\n  {\\n    id: \\\"b2\\\",\\n    label: \\\"B2\\\",\\n    range: \\\"120\\u2013140\\\",\\n    start: 120,\\n    target: 140,\\n    description: \\\"Fluent pace. Focus on sentence-level rhythm and stress.\\\",\\n    color: \\\"bg-orange-500\\\",\\n  },\\n  {\\n    id: \\\"c1\\\",\\n    label: \\\"C1\\\",\\n    range: \\\"140\\u2013160\\\",\\n    start: 140,\\n    target: 160,\\n    description: \\\"Broadcast pace. Refine nuance, emphasis, and intonation.\\\",\\n    color: \\\"bg-red-400\\\",\\n  },\\n  {\\n    id: \\\"c2\\\",\\n    label: \\\"C2\\\",\\n    range: \\\"160\\u2013180\\\",\\n    start: 160,\\n    target: 180,\\n    description: \\\"Native pace. Master subtle prosodic features.\\\",\\n    color: \\\"bg-purple-500\\\",\\n  },\\n];\\n\\ntype Props = {\\n  currentLevel?: string;\\n  currentWpm?: number;\\n  onSelectWpm?: (wpm: number) => void;\\n};\\n\\nexport function WPMGuidance({ currentLevel, currentWpm, onSelectWpm }: Props) {\\n  return (\\n    <div className=\\\"space-y-4\\\">\\n      <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-primary\\\">\\n        WPM Guide \\u00b7 Words Per Minute\\n      </div>\\n\\n      {/* Visual scale */}\\n      <div className=\\\"relative h-8 bg-card border border-border rounded overflow-hidden\\\">\\n        {LEVELS.map((l, i) => {\\n          const width = 100 / LEVELS.length;\\n          const isActive = l.id === currentLevel;\\n          return (\\n            <div\\n              key={l.id}\\n              className={`absolute top-0 bottom-0 flex items-center justify-center text-[9px] font-mono font-bold transition-all ${\\n                isActive\\n                  ? \\\"bg-primary/20 text-primary z-10\\\"\\n                  : \\\"text-muted-foreground\\\"\\n              }`}\\n              style={{\\n                left: `${i * width}%`,\\n                width: `${width}%`,\\n                borderRight: \\\"1px solid hsl(var(--border))\\\",\\n              }}\\n            >\\n              {l.label}\\n            </div>\\n          );\\n        })}\\n        {/* Current WPM indicator */}\\n        {currentWpm != null && (\\n          <div\\n            className=\\\"absolute top-0 bottom-0 w-0.5 bg-foreground z-20\\\"\\n            style={{\\n              left: `${Math.min(100, Math.max(0, ((currentWpm - 80) / 140) * 100))}%`,\\n            }}\\n          />\\n        )}\\n      </div>\\n\\n      {/* Level details */}\\n      <div className=\\\"space-y-2\\\">\\n        {LEVELS.map((l) => {\\n          const isActive = l.id === currentLevel;\\n          return (\\n            <button\\n              key={l.id}\\n              onClick={() => onSelectWpm?.(l.start)}\\n              className={`w-full text-left flex items-center gap-3 px-3 py-2 border rounded transition-colors ${\\n                isActive\\n                  ? \\\"border-primary bg-primary/5\\\"\\n                  : \\\"border-border hover:border-primary/30\\\"\\n              }`}\\n            >\\n              <div className={`size-2 rounded-full ${l.color} shrink-0`} />\\n              <div className=\\\"flex-1 min-w-0\\\">\\n                <div className=\\\"flex items-center gap-2\\\">\\n                  <span className=\\\"text-xs font-semibold\\\">{l.label}</span>\\n                  <span className=\\\"text-[10px] font-mono text-muted-foreground\\\">\\n                    {l.range} WPM\\n                  </span>\\n                </div>\\n                <p className=\\\"text-[10px] text-muted-foreground truncate\\\">\\n                  {l.description}\\n                </p>\\n              </div>\\n              {isActive && (\\n                <span className=\\\"text-[9px] font-mono text-primary shrink-0\\\">\\n                  CURRENT\\n                </span>\\n              )}\\n            </button>\\n          );\\n        })}\\n      </div>\\n\\n      {/* Context benchmarks */}\\n      <div className=\\\"border-t border-border pt-4\\\">\\n        <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground mb-2\\\">\\n          Real-World Speeds\\n        </div>\\n        <div className=\\\"grid grid-cols-2 gap-2 text-[10px]\\\">\\n          <div className=\\\"text-muted-foreground\\\">\\n            <span className=\\\"text-foreground font-semibold\\\">TED Talk</span>{\\\" \\\"}\\n            110\\u2013130\\n          </div>\\n          <div className=\\\"text-muted-foreground\\\">\\n            <span className=\\\"text-foreground font-semibold\\\">BBC News</span>{\\\" \\\"}\\n            150\\u2013160\\n          </div>\\n          <div className=\\\"text-muted-foreground\\\">\\n            <span className=\\\"text-foreground font-semibold\\\">\\n              Conversational\\n            </span>{\\\" \\\"}\\n            120\\u2013150\\n          </div>\\n          <div className=\\\"text-muted-foreground\\\">\\n            <span className=\\\"text-foreground font-semibold\\\">Audiobook</span>{\\\" \\\"}\\n            150\\u2013160\\n          </div>\\n          <div className=\\\"text-muted-foreground\\\">\\n            <span className=\\\"text-foreground font-semibold\\\">\\n              Italian News\\n            </span>{\\\" \\\"}\\n            160\\u2013180+\\n          </div>\\n          <div className=\\\"text-muted-foreground\\\">\\n            <span className=\\\"text-foreground font-semibold\\\">Sports</span>{\\\" \\\"}\\n            250\\u2013400\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n  );\\n}\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\components\\\\WPMGuidance.tsx\"}",
      "output": "Wrote file successfully.",
      "status": "success",
      "timestamp": 1781550769012
    },
    {
      "type": "thought",
      "text": "Now create the teacher/classroom mode route.",
      "timestamp": 1781550773375
    },
    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"import { createFileRoute, Link } from \\\"@tanstack/react-router\\\";\\nimport { useCallback, useMemo, useState } from \\\"react\\\";\\nimport { SiteNav } from \\\"@/components/SiteNav\\\";\\nimport { SiteFooter } from \\\"@/components/SiteFooter\\\";\\n\\nexport const Route = createFileRoute(\\\"/classroom\\\")({\\n  head: () => ({\\n    meta: [\\n      { title: \\\"Classroom \\u00b7 ProLector\\\" },\\n      {\\n        name: \\\"description\\\",\\n        content:\\n          \\\"Teacher dashboard for managing student progress, assigning scripts, and tracking class-wide prosody improvement.\\\",\\n      },\\n    ],\\n  }),\\n  component: Classroom,\\n});\\n\\ntype Student = {\\n  id: string;\\n  name: string;\\n  level: string;\\n  lastActive: string;\\n  sessions: number;\\n  avgWpm: number;\\n  streak: number;\\n};\\n\\nconst DEMO_STUDENTS: Student[] = [\\n  { id: \\\"1\\\", name: \\\"Maria G.\\\", level: \\\"B2\\\", lastActive: \\\"Today\\\", sessions: 12, avgWpm: 135, streak: 5 },\\n  { id: \\\"2\\\", name: \\\"Luca P.\\\", level: \\\"C1\\\", lastActive: \\\"Yesterday\\\", sessions: 18, avgWpm: 152, streak: 8 },\\n  { id: \\\"3\\\", name: \\\"Yuki T.\\\", level: \\\"B1\\\", lastActive: \\\"2 days ago\\\", sessions: 7, avgWpm: 108, streak: 2 },\\n  { id: \\\"4\\\", name: \\\"Ahmed K.\\\", level: \\\"B2\\\", lastActive: \\\"Today\\\", sessions: 15, avgWpm: 140, streak: 6 },\\n  { id: \\\"5\\\", name: \\\"Sofia R.\\\", level: \\\"A2\\\", lastActive: \\\"3 days ago\\\", sessions: 4, avgWpm: 88, streak: 0 },\\n  { id: \\\"6\\\", name: \\\"Chen W.\\\", level: \\\"C1\\\", lastActive: \\\"Today\\\", sessions: 22, avgWpm: 158, streak: 12 },\\n];\\n\\nconst ASSIGNABLE_SCRIPTS = [\\n  { id: \\\"ted-1\\\", title: \\\"TED Talk: The Power of Vulnerability\\\", wpm: 120, duration: \\\"~14 min\\\" },\\n  { id: \\\"bbc-1\\\", title: \\\"BBC News: Climate Summit Report\\\", wpm: 155, duration: \\\"~3 min\\\" },\\n  { id: \\\"biz-1\\\", title: \\\"Business Presentation: Quarterly Review\\\", wpm: 140, duration: \\\"~8 min\\\" },\\n  { id: \\\"story-1\\\", title: \\\"Story: The Old Man and the Sea (excerpt)\\\", wpm: 150, duration: \\\"~6 min\\\" },\\n  { id: \\\"conv-1\\\", title: \\\"Conversation: Job Interview Practice\\\", wpm: 130, duration: \\\"~5 min\\\" },\\n];\\n\\nfunction Classroom() {\\n  const [selectedStudent, setSelectedStudent] = useState<string | null>(null);\\n  const [showAssign, setShowAssign] = useState(false);\\n\\n  const classStats = useMemo(() => {\\n    const totalSessions = DEMO_STUDENTS.reduce((n, s) => n + s.sessions, 0);\\n    const avgWpm = Math.round(\\n      DEMO_STUDENTS.reduce((n, s) => n + s.avgWpm, 0) / DEMO_STUDENTS.length,\\n    );\\n    const activeToday = DEMO_STUDENTS.filter(\\n      (s) => s.lastActive === \\\"Today\\\",\\n    ).length;\\n    return { totalSessions, avgWpm, activeToday };\\n  }, []);\\n\\n  return (\\n    <div className=\\\"min-h-screen bg-background text-foreground\\\">\\n      <SiteNav />\\n\\n      <div className=\\\"max-w-7xl mx-auto px-6 py-12\\\">\\n        {/* Header */}\\n        <div className=\\\"flex items-center justify-between mb-8\\\">\\n          <div>\\n            <h1 className=\\\"text-3xl font-display font-bold tracking-tight\\\">\\n              Classroom\\n            </h1>\\n            <p className=\\\"text-sm text-muted-foreground mt-1\\\">\\n              Track student progress, assign scripts, and monitor prosody\\n              improvement across your class.\\n            </p>\\n          </div>\\n          <button\\n            onClick={() => setShowAssign(!showAssign)}\\n            className=\\\"bg-primary text-primary-foreground px-5 py-2.5 text-xs font-bold uppercase tracking-widest hover:brightness-110 transition-all\\\"\\n          >\\n            + Assign Script\\n          </button>\\n        </div>\\n\\n        {/* Class overview */}\\n        <div className=\\\"grid grid-cols-3 gap-4 mb-8\\\">\\n          <div className=\\\"border border-border rounded p-4 text-center\\\">\\n            <div className=\\\"text-2xl font-display font-bold\\\">\\n              {DEMO_STUDENTS.length}\\n            </div>\\n            <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n              Students\\n            </div>\\n          </div>\\n          <div className=\\\"border border-border rounded p-4 text-center\\\">\\n            <div className=\\\"text-2xl font-display font-bold\\\">\\n              {classStats.activeToday}\\n            </div>\\n            <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n              Active Today\\n            </div>\\n          </div>\\n          <div className=\\\"border border-border rounded p-4 text-center\\\">\\n            <div className=\\\"text-2xl font-display font-bold\\\">\\n              {classStats.avgWpm}\\n            </div>\\n            <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n              Class Avg WPM\\n            </div>\\n          </div>\\n        </div>\\n\\n        {/* Assign script panel */}\\n        {showAssign && (\\n          <div className=\\\"border border-primary/30 bg-primary/5 rounded p-6 mb-8\\\">\\n            <div className=\\\"flex items-center justify-between mb-4\\\">\\n              <h3 className=\\\"text-sm font-semibold\\\">Assign a Script</h3>\\n              <button\\n                onClick={() => setShowAssign(false)}\\n                className=\\\"text-muted-foreground hover:text-foreground text-xs\\\"\\n              >\\n                Close\\n              </button>\\n            </div>\\n            <div className=\\\"grid md:grid-cols-2 lg:grid-cols-3 gap-3\\\">\\n              {ASSIGNABLE_SCRIPTS.map((s) => (\\n                <div\\n                  key={s.id}\\n                  className=\\\"border border-border rounded p-4 hover:border-primary/30 transition-colors cursor-pointer\\\"\\n                >\\n                  <p className=\\\"text-sm font-semibold mb-1\\\">{s.title}</p>\\n                  <div className=\\\"flex items-center gap-3 text-[10px] font-mono text-muted-foreground\\\">\\n                    <span>{s.wpm} WPM</span>\\n                    <span>{s.duration}</span>\\n                  </div>\\n                </div>\\n              ))}\\n            </div>\\n          </div>\\n        )}\\n\\n        {/* Student list */}\\n        <div className=\\\"border border-border rounded overflow-hidden\\\">\\n          <table className=\\\"w-full text-left\\\">\\n            <thead>\\n              <tr className=\\\"border-b border-border bg-foreground/[0.02]\\\">\\n                <th className=\\\"py-3 px-4 text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n                  Student\\n                </th>\\n                <th className=\\\"py-3 px-4 text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n                  Level\\n                </th>\\n                <th className=\\\"py-3 px-4 text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n                  Sessions\\n                </th>\\n                <th className=\\\"py-3 px-4 text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n                  Avg WPM\\n                </th>\\n                <th className=\\\"py-3 px-4 text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n                  Streak\\n                </th>\\n                <th className=\\\"py-3 px-4 text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n                  Last Active\\n                </th>\\n              </tr>\\n            </thead>\\n            <tbody>\\n              {DEMO_STUDENTS.map((s) => (\\n                <tr\\n                  key={s.id}\\n                  className={`border-b border-border/50 cursor-pointer transition-colors ${\\n                    selectedStudent === s.id\\n                      ? \\\"bg-primary/5\\\"\\n                      : \\\"hover:bg-foreground/5\\\"\\n                  }`}\\n                  onClick={() =>\\n                    setSelectedStudent(\\n                      selectedStudent === s.id ? null : s.id,\\n                    )\\n                  }\\n                >\\n                  <td className=\\\"py-3 px-4 font-semibold text-sm\\\">\\n                    {s.name}\\n                  </td>\\n                  <td className=\\\"py-3 px-4\\\">\\n                    <span\\n                      className={`text-[10px] font-mono px-2 py-0.5 rounded ${\\n                        s.level === \\\"C1\\\"\\n                          ? \\\"bg-purple-500/10 text-purple-500\\\"\\n                          : s.level === \\\"B2\\\"\\n                            ? \\\"bg-orange-500/10 text-orange-500\\\"\\n                            : s.level === \\\"B1\\\"\\n                              ? \\\"bg-yellow-500/10 text-yellow-500\\\"\\n                              : \\\"bg-green-500/10 text-green-500\\\"\\n                      }`}\\n                    >\\n                      {s.level}\\n                    </span>\\n                  </td>\\n                  <td className=\\\"py-3 px-4 text-sm\\\">{s.sessions}</td>\\n                  <td className=\\\"py-3 px-4 font-mono text-sm\\\">{s.avgWpm}</td>\\n                  <td className=\\\"py-3 px-4 text-sm\\\">\\n                    {s.streak > 0 ? (\\n                      <span className=\\\"text-orange-500\\\">\\n                        \\ud83d\\udd25 {s.streak}\\n                      </span>\\n                    ) : (\\n                      <span className=\\\"text-muted-foreground\\\">\\u2014</span>\\n                    )}\\n                  </td>\\n                  <td className=\\\"py-3 px-4 text-xs text-muted-foreground\\\">\\n                    {s.lastActive}\\n                  </td>\\n                </tr>\\n              ))}\\n            </tbody>\\n          </table>\\n        </div>\\n\\n        {/* Info note */}\\n        <p className=\\\"text-[10px] font-mono text-muted-foreground/60 mt-6 text-center\\\">\\n          This is a preview of the Classroom feature. In production, student\\n          data syncs via Cloudflare D1 or Oracle 23ai with real-time updates.\\n        </p>\\n      </div>\\n\\n      <SiteFooter />\\n    </div>\\n  );\\n}\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\routes\\\\classroom.tsx\"}",
