otion/player\": \"^4.0.471\",\n43:     \"@tailwindcss/vite\": \"^4.2.1\",\n44:     \"@tanstack/react-query\": \"^5.83.0\",\n45:     \"@tanstack/react-router\": \"^1.168.25\",\n46:     \"@tanstack/react-start\": \"^1.167.50\",\n47:     \"@tanstack/router-plugin\": \"^1.167.28\",\n48:     \"class-variance-authority\": \"^0.7.1\",\n49:     \"clsx\": \"^2.1.1\",\n50:     \"cmdk\": \"^1.1.1\",\n51:     \"date-fns\": \"^4.1.0\",\n52:     \"embla-carousel-react\": \"^8.6.0\",\n53:     \"input-otp\": \"^1.4.2\",\n54:     \"kokoro-js\": \"^1.2.1\",\n55:     \"lucide-react\": \"^0.575.0\",\n56:     \"mp4box\": \"^2.3.0\",\n57:     \"react\": \"^19.2.0\",\n58:     \"react-day-picker\": \"^9.14.0\",\n59:     \"react-dom\": \"^19.2.0\",\n60:     \"react-hook-form\": \"^7.71.2\",\n61:     \"react-resizable-panels\": \"^4.6.5\",\n62:     \"recharts\": \"^2.15.4\",\n63:     \"remotion\": \"^4.0.471\",\n64:     \"sonner\": \"^2.0.7\",\n65:     \"tailwind-merge\": \"^3.5.0\",\n66:     \"tailwindcss\": \"^4.2.1\",\n67:     \"tw-animate-css\": \"^1.3.4\",\n68:     \"vaul\": \"^1.1.2\",\n69:     \"vite-tsconfig-paths\": \"^6.0.2\",\n70:     \"zod\": \"^3.24.2\"\n71:   },\n72:   \"devDependencies\": {\n73:     \"@eslint/js\": \"^9.32.0\",\n74:     \"@lovable.dev/vite-tanstack-config\": \"^2.1.1\",\n75:     \"@types/dom-webcodecs\": \"^0.1.18\",\n76:     \"@types/node\": \"^22.16.5\",\n77:     \"@types/react\": \"^19.2.0\",\n78:     \"@types/react-dom\": \"^19.2.0\",\n79:     \"@vitejs/plugin-react\": \"^5.0.4\",\n80:     \"eslint\": \"^9.32.0\",\n81:     \"eslint-config-prettier\": \"^10.1.1\",\n82:     \"eslint-plugin-prettier\": \"^5.2.6\",\n83:     \"eslint-plugin-react-hooks\": \"^5.2.0\",\n84:     \"eslint-plugin-react-refresh\": \"^0.4.20\",\n85:     \"globals\": \"^15.15.0\",\n86:     \"nitro\": \"3.0.260429-beta\",\n87:     \"prettier\": \"^3.7.3\",\n88:     \"typescript\": \"^5.8.3\",\n89:     \"typescript-eslint\": \"^8.56.1\",\n90:     \"vite\": \"^7.3.1\"\n91:   }\n92: }\n\n(