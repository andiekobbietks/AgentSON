      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\components\\teleprompter\\EngineStatus.tsx</path>\n<type>file</type>\n<content>\n1: import type { EngineId, ScheduleSnapshot } from \"@/lib/teleprompter/syllabus-mirror\";\n2: import { Tooltip, TooltipContent, TooltipTrigger } from \"@/components/ui/tooltip\";\n3: \n4: const LABELS: Record<EngineId, string> = {\n5:   \"kokoro-q8\": \"Kokoro-82M · q8 (director)\",\n6:   \"kokoro-q4\": \"Kokoro-82M · q4 (latency)\",\n7:   \"web-speech\": \"Web Speech API (fallback)\",\n8:   \"f5-tts\": \"F5-TTS · experimental\",\n9:   \"chatterbox\": \"Chatterbox · experimental\",\n10: };\n11: \n12: const TIPS: Record<EngineId, string> = {\n13:   \"kokoro-q8\": \"82M params, q8 quant. Director voice for long sentences.\",\n14:   \"kokoro-q4\": \"82M params, q4 quant. Latency-first for short cues.\",\n15:   \"web-speech\": \"Native browser TTS. Always-on zero-cost fallback.\",\n16:   \"f5-tts\": \"Roadmap. Loads if f5-tts-web is installed; otherwise errors.\",\n17:   \"chatterbox\": \"Roadmap. Loads if chatterbox-tts-web is installed.\",\n18: };\n19: \n20: type Props = {\n21:   snapshot: ScheduleSnapshot | null;\n22:   onToggle: (id: EngineId, enabled: boolean) => void;\n23: };\n24: \n25: export function EngineStatus({ snapshot, onToggle }: Props) {\n26:   const order: EngineId[] = [\"kokoro-q8\", \"kokoro-q4\", \"web-speech\", \"f5-tts\", \"chatterbox\"];\n27:   if (!snapshot) return <div className=\"space-y-2\" />;\n28:   return (\n29:     <div className=\"space-y-2\">\n30:       {order.map((id) => {\n31:         const e = snapshot.engines[id];\n32:         const dot =\n33:           snapshot.activeEngine === id\n34:             ? \"bg-primary animate-pulse\"\n35:             : e.status === \"ready\"\n36:               ? \"bg-primary/60\"\n37:               : e.status === \"loading\"\n38:                 ? \"bg-yellow-500 animate-pulse\"\n39:                 : e.status === \"error\"\n40:                   ? \"bg-destructive\"\n41:                   : \"bg-muted-foreground/40\";\n42:         return (\n43:           <Tooltip key={id}>\n44:             <TooltipTrigger asChild>\n45:               <div className=\"flex items-center gap-3 border border-border bg-card px-2 py-2\">\n46:                 <span className={`size-2 rounded-full ${dot}`} />\n47:                 <div className=\"flex-1 min-w-0\">\n48:                   <div className=\"text-[10px] font-mono uppercase tracking-widest text-foreground truncate\">\n49:                     {LABELS[id]}\n50:                   </div>\n51:                   <div className=\"text-[10px] font-mono text-muted-foreground truncate\">\n52:                     {e.status}\n53:                     {e.emaRtf != null && ` · RTF ${e.emaRtf.toFixed(2)}`}\n54:                     {e.lastRtf != null && ` · last ${e.lastRtf.toFixed(2)}`}\n55:                     {e.error && ` · ${e.error.slice(0, 40)}`}\n56:                   </div>\n57:                 </div>\n58:                 <input\n59:                   type=\"checkbox\"\n60:                   checked={e.enabled}\n61:                   onChange={(ev) => onToggle(id, ev.target.checked)}\n62:                   className=\"accent-primary\"\n63:                   aria-label={`Enable ${LABELS[id]}`}\n64:                 />\n65:               </div>\n66:             </TooltipTrigger>\n67:             <TooltipContent side=\"left\" className=\"max-w-xs\">\n68:               {TIPS[id]}\n69:             </TooltipContent>\n70:           </Tooltip>\n71:         );\n72:       })}\n73:       <Tooltip>\n74:         <TooltipTrigger asChild>\n75:           <div className=\"text-[10px] font-mono text-muted-foreground pt-1 cursor-help\">\n76:             scheduled {snapshot.scheduled} · buffered {snapshot.buffered} sent\n77:             {snapshot.buffered === 1 ? \"\" : \"s\"} ·{\" \"}\n78:             {(snapshot.bufferedMs / 1000).toFixed(1)}s · lookahead{\" \"}\n79:             {(snapshot.lookaheadMs / 1000).toFixed(1)}s · OPFS{\" \"}\n80:             {snapshot.opfsAvailable ? `(${snapshot.cacheHits} hits)` : \"off\"}\n81:           </div>\n82:         </TooltipTrigger>\n83:         <TooltipContent side=\"left\" className=\"max-w-xs\">\n84:           Sliding window auto-shrinks when RTF climbs over 0.85. OPFS persists\n85:           synthesised audio across sessions.\n86:         </TooltipContent>\n87:       </Tooltip>\n88:     </div>\n89:   );\n90: }\n\n(End of file - total 90 lines)\n</content>",
