    {
      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\components\\\\teleprompter\\\\TranscriptStage.tsx\", \"oldString\": \"  const renderToken = (t: Token) => {\\n    if (t.isBreak)\\n      return (\\n        <span key={t.id} style={{ display: \\\"block\\\", height: \\\"1.2em\\\" }} />\\n      );\\n    const active = t.id === currentTokenId;\\n    const inLoop =\\n      loopRange && t.startMs >= loopRange.startMs && t.endMs <= loopRange.endMs;\\n    return (\\n      <span\\n        key={t.id}\\n        ref={active ? activeRef : undefined}\\n        onClick={(e) => (e.shiftKey ? onTokenShiftClick?.(t) : onTokenClick(t))}\\n        className={`cursor-pointer rounded-sm transition-colors ${\\n          active\\n            ? \\\"bg-primary/25 text-primary\\\"\\n            : t.status === \\\"spoken\\\"\\n              ? \\\"text-muted-foreground\\\"\\n              : \\\"text-foreground hover:bg-primary/10\\\"\\n        } ${inLoop ? \\\"underline decoration-primary/60 decoration-2 underline-offset-4\\\" : \\\"\\\"}`}\\n        style={{ padding: \\\"0 0.05em\\\" }}\\n      >\\n        {t.text}{\\\" \\\"}\\n      </span>\\n    );\\n  };\", \"newString\": \"  const renderToken = (t: Token) => {\\n    if (t.isBreak)\\n      return (\\n        <span key={t.id} style={{ display: \\\"block\\\", height: \\\"1.2em\\\" }} />\\n      );\\n    const active = t.id === currentTokenId;\\n    const inLoop =\\n      loopRange && t.startMs >= loopRange.startMs && t.endMs <= loopRange.endMs;\\n    const wordProsody = prosody?.get(t.id);\\n    const isFlagged =\\n      triageMarkerMs != null &&\\n      t.startMs <= triageMarkerMs &&\\n      t.endMs >= triageMarkerMs;\\n    return (\\n      <span\\n        key={t.id}\\n        ref={active ? activeRef : undefined}\\n        onClick={(e) => (e.shiftKey ? onTokenShiftClick?.(t) : onTokenClick(t))}\\n        className={`cursor-pointer rounded-sm transition-colors relative inline-block ${\\n          active\\n            ? \\\"bg-primary/25 text-primary\\\"\\n            : isFlagged\\n              ? \\\"bg-destructive/15 text-destructive\\\"\\n              : t.status === \\\"spoken\\\"\\n                ? \\\"text-muted-foreground\\\"\\n                : \\\"text-foreground hover:bg-primary/10\\\"\\n        } ${inLoop ? \\\"underline decoration-primary/60 decoration-2 underline-offset-4\\\" : \\\"\\\"}`}\\n        style={{ padding: \\\"0 0.05em\\\" }}\\n      >\\n        {t.text}{\\\" \\\"}\\n        {showProsody && wordProsody && (\\n          <ProsodyVisualizer\\n            prosody={wordProsody}\\n            active={active}\\n            fontSize={fontSize}\\n          />\\n        )}\\n      </span>\\n    );\\n  };\"}",
