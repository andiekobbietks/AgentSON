      "output": "<path>C:\\Users\\LLM-Test\\Documents\\cognitive-taxonomy-vscode-ext\\src\\extension.ts</path>\n<type>file</type>\n<content>\n1: import * as vscode from 'vscode';\n2: import { ASTClassifier, ClassifiedNode, CATEGORIES, calculateCognitiveLoad, CognitiveLoadMetrics } from './astClassifier';\n3: import { TooltipGenerator, formatTooltipMarkdown } from './tooltipGenerator';\n4: import { TaxonomySidebarProvider, MinimapDecorationProvider } from './sidebarProvider';\n5: import { DataFlowView, generateDataFlow, extractFlowNodes, formatFlowForTooltip, getBestHoverFormat } from './dataFlow';\n6: \n7: // ─── State ──────────────────────────────────────────────────────────────\n8: \n9: let isEnabled = false;\n10: let decorationTypes: Map<string, vscode.TextEditorDecorationType> = new Map();\n11: let statusBarItem: vscode.StatusBarItem;\n12: let outputChannel: vscode.OutputChannel;\n13: let classifier: ASTClassifier = new ASTClassifier();\n14: let tooltipGenerator: TooltipGenerator = new TooltipGenerator(true);\n15: let currentMetrics: CognitiveLoadMetrics | null = null;\n16: let currentClassified: Map<number, ClassifiedNode> = new Map();\n17: let sidebarProvider: TaxonomySidebarProvider;\n18: let minimapProvider: MinimapDecorationProvider;\n19: let currentDataFlowView: DataFlowView = 'ascii';\n20: let dataFlowStatusBar: vscode.StatusBarItem;\n21: \n22: // ─── Decoration Types ───────────────────────────────────────────────────\n23: \n24: function createDecorationTypes(): void {\n25:     for (const [id, cat] of Object.entries(CATEGORIES)) {\n26:         const type = vscode.window.createTextEditorDecorationType({\n27:             backgroundColor: cat.bgAlpha,\n28:             borderColor: cat.colour,\n29:             borderStyle: 'solid',\n30:             borderWidth: '0 0 0 3px',\n31:             overviewRulerColor: cat.colour,\n32:             overviewRulerLane: vscode.OverviewRulerLane.Left,\n33:         });\n34:         decorationTypes.set(id, type);\n35:     }\n36: }\n37: \n38: function disposeDecorationTypes(): void {\n39:     for (const type of decorationTypes.values()) {\n40:         type.dispose();\n41:     }\n42:     decorationTypes.clear();\n43: }\n44: \n45: // ─── Apply Decorations ──────────────────────────────────────────────────\n46: \n47: function applyDecorations(editor: vscode.TextEditor): void {\n48:     if (!isEnabled) return;\n49: \n50:     const doc = editor.document;\n51:     const code = doc.getText();\n52:     \n53:     // Parse and classify using AST\n54:     currentClassified = classifier.classifyCode(code);\n55:     \n56:     // Calculate cognitive load metrics\n57:     currentMetrics = calculateCognitiveLoad(currentClassified);\n58:     \n59:     // Update output channel with metrics\n60:     updateOutputChannel(currentMetrics);\n61:     \n62:     // Update sidebar provider\n63:     if (sidebarProvider) {\n64:         sidebarProvider.updateMetrics(currentMetrics, currentClassified, code);\n65:     }\n66:     \n67:     // Update minimap provider\n68:     if (minimapProvider) {\n69:         minimapProvider.updateMinimap(editor);\n70:     }\n71:     \n72:     // Prepare decorations for each category\n73:     const decorations: Map<string, vscode.DecorationOptions[]> = new Map();\n74:     for (const id of Object.keys(CATEGORIES)) {\n75:         decorations.set(id, []);\n76:     }\n77: \n78:     // Apply classifications to decorations\n79:     for (const [lineNumber, node] of currentClassified) {\n80:         if (lineNumber >= doc.lineCount) continue;\n81:         \n82:         const line = doc.lineAt(lineNumber);\n83:         const opts: vscode.DecorationOptions = {\n84:             range: new vscode.Range(lineNumber, 0, lineNumber, line.text.length),\n85:             hoverMessage: createHoverMessage(node, line.text, lineNumber, code)\n86:         };\n87: \n88:         const existing = decorations.get(node.category.id);\n89:         if (existing) {\n90:             existing.push(opts);\n91:         }\n92:     }\n93: \n94:     // Apply decorations to editor\n95:     for (const [id, decs] of decorations) {\n96:         const type = decorationTypes.get(id);\n97:         if (type) {\n98:             editor.setDecorations(type, decs);\n99:         }\n100:     }\n101: }\n102: \n103: function clearDecorations(editor: vscode.TextEditor): void {\n104:     for (const type of decorationTypes.values()) {\n105:         editor.setDecorations(type, []);\n106:     }\n107: }\n108: \n109: // ─── Hover Message ──────────────────────────────────────────────────────\n110: \n111: function createHoverMessage(node: ClassifiedNode, lineText: string, lineNumber: number, code: string): vscode.MarkdownString {\n112:     // Generate tooltip using the generator\n113:     const tooltip = tooltipGenerator.generateTooltip(node.node, node.category);\n114:     \n115:     // Format as markdown\n116:     const markdownText = formatTooltipMarkdown(tooltip, lineText);\n117:     \n118:     // Create VS Code markdown string\n119:     const md = new vscode.MarkdownString();\n120:     md.isTrusted = true;\n121:     md.supportHtml = true;\n122:     md.appendMarkdown(markdownText);\n123:     \n124:     // Add data flow visualization (always ASCII for hover - VS Code can't render SVG in markdown)\n125:     const flowNodes = extractFlowNodes(code, lineNumber);\n126:     if (flowNodes.length > 1) {\n127:         md.appendMarkdown(`---\\n`);\n128:         md.appendMarkdown(formatFlowForTooltip(flowNodes, getBestHoverFormat(), lineNumber));\n129:     }\n130:     \n131:     // Add cognitive load context if available\n132:     if (currentMetrics) {\n133:         md.appendMarkdown(`---\\n`);\n134:         md.appendMarkdown(`**Cognitive Load:** ${currentMetrics.overallLoad.toUpperCase()} (${currentMetrics.complexityScore}/100)\\n\\n`);\n135:         md.appendMarkdown(`**Balance Score:** ${currentMetrics.balanceScore}/100\\n`);\n136:     }\n137: \n138:     return md;\n139: }\n140: \n141: // ─── Output Channel ─────────────────────────────────────────────────────\n142: \n143: function updateOutputChannel(metrics: CognitiveLoadMetrics): void {\n144:     if (!outputChannel) return;\n145:     \n146:     outputChannel.clear();\n147:     outputChannel.appendLine('=== Cognitive Taxonomy Protocol ===');\n148:     outputChannel.appendLine('');\n149:     outputChannel.appendLine(`Total Lines: ${metrics.totalLines}`);\n150:     outputChannel.appendLine('');\n151:     outputChannel.appendLine('Category Breakdown:');\n152:     outputChannel.appendLine(`  BLUE (Blueprint): ${metrics.blueprintLines} lines`);\n153:     outputChannel.appendLine(`  GREEN (Plumbing): ${metrics.plumbingLines} lines`);\n154:     outputChannel.appendLine(`  ORANGE (Transaction): ${metrics.transactionLines} lines`);\n155:     outputChannel.appendLine(`  RED (Constraint): ${metrics.constraintLines} lines`);\n156:     outputChannel.appendLine(`  PURPLE (Pedagogy): ${metrics.pedagogyLines} lines`);\n157:     outputChannel.appendLine('');\n158:     outputChannel.appendLine(`Complexity Score: ${metrics.complexityScore}/100`);\n159:     outputChannel.appendLine(`Balance Score: ${metrics.balanceScore}/100`);\n160:     outputChannel.appendLine(`Overall Load: ${metrics.overallLoad.toUpperCase()}`);\n161:     outputChannel.appendLine('');\n162:     \n163:     // Recommendations\n164:     outputChannel.appendLine('=== Recommendations ===');\n165:     if (metrics.complexityScore > 80) {\n166:         outputChannel.appendLine('⚠️  High complexity detected. Consider refactoring into smaller functions.');\n167:     }\n168:     if (metrics.balanceScore < 50) {\n169:         outputChannel.appendLine('⚠️  Poor balance across categories. Consider adding missing architectural layers.');\n170:     }\n171:     if (metrics.constraintLines === 0 && metrics.totalLines > 10) {\n172:         outputChannel.appendLine('⚠️  No constraints detected. Consider adding validation or error handling.');\n173:     }\n174:     if (metrics.pedagogyLines === 0 && metrics.totalLines > 20) {\n175:         outputChannel.appendLine('⚠️  No documentation detected. Consider adding docstrings or comments.');\n176:     }\n177: }\n178: \n179: // ─── Toggle Command ─────────────────────────────────────────────────────\n180: \n181: function toggleTaxonomy(): void {\n182:     isEnabled = !isEnabled;\n183: \n184:     if (isEnabled) {\n185:         statusBarItem.text = '$(graph) Taxonomy: ON';\n186:         statusBarItem.tooltip = 'Cognitive Taxonomy Protocol is active. Click to disable.';\n187:         statusBarItem.backgroundColor = new vscode.ThemeColor('statusBarItem.warningBackground');\n188:     } else {\n189:         statusBarItem.text = '$(graph) Taxonomy: OFF';\n190:         statusBarItem.tooltip = 'Cognitive Taxonomy Protocol is disabled. Click to enable.';\n191:         statusBarItem.backgroundColor = undefined;\n192:     }\n193: \n194:     const editor = vscode.window.activeTextEditor;\n195:     if (editor) {\n196:         if (isEnabled) {\n197:             applyDecorations(editor);\n198:         } else {\n199:             clearDecorations(editor);\n200:         }\n201:     }\n202: }\n203: \n204: // ─── Data Flow Toggle ──────────────────────────────────────────────────\n205: \n206: const DATA_FLOW_VIEWS: DataFlowView[] = ['ascii', 'mini', 'mermaid', 'svg'];\n207: let currentDataFlowIndex = 0;\n208: \n209: function toggleDataFlowView(): void {\n210:     currentDataFlowIndex = (currentDataFlowIndex + 1) % DATA_FLOW_VIEWS.length;\n211:     currentDataFlowView = DATA_FLOW_VIEWS[currentDataFlowIndex];\n212:     \n213:     // Update status bar\n214:     dataFlowStatusBar.text = `$(arrow-right) Flow: ${currentDataFlowView.toUpperCase()}`;\n215:     dataFlowStatusBar.tooltip = `Data flow view: ${currentDataFlowView}. Click to cycle.`;\n216:     \n217:     // Re-apply decorations to update tooltips\n218:     const editor = vscode.window.activeTextEditor;\n219:     if (editor && isEnabled) {\n220:         applyDecorations(editor);\n221:     }\n222:     \n223:     // Show information message\n224:     const viewNames: Record<DataFlowView, string> = {\n225:         'ascii': 'ASCII Arrows (Simplest)',\n226:         'mini': 'Mini Diagram (Developer)',\n227:         'mermaid': 'Mermaid Diagram (Rich)',\n228:         'svg': 'SVG Arrows (Best Visual)'\n229:     };\n230:     vscode.window.showInformationMessage(`Data flow view: ${viewNames[currentDataFlowView]}`);\n231: }\n232: \n233: // ─── Activation ─────────────────────────────────────────────────────────\n234: \n235: export function activate(context: vscode.ExtensionContext): void {\n236:     // Create decoration types\n237:     createDecorationTypes();\n238: \n239:     // Create output channel\n240:     outputChannel = vscode.window.createOutputChannel('Cognitive Taxonomy');\n241:     context.subscriptions.push(outputChannel);\n242: \n243:     // Create sidebar provider\n244:     sidebarProvider = new TaxonomySidebarProvider(context.extensionUri);\n245:     context.subscriptions.push(\n246:         vscode.window.registerWebviewViewProvider(TaxonomySidebarProvider.viewType, sidebarProvider)\n247:     );\n248: \n249:     // Create minimap provider\n250:     minimapProvider = new MinimapDecorationProvider();\n251:     context.subscriptions.push(minimapProvider);\n252: \n253:     // Status bar item\n254:     statusBarItem = vscode.window.createStatusBarItem(vscode.StatusBarAlignment.Right, 100);\n255:     statusBarItem.command = 'cognitiveTaxonomy.toggle';\n256:     statusBarItem.text = '$(graph) Taxonomy: OFF';\n257:     statusBarItem.tooltip = 'Cognitive Taxonomy Protocol. Click to toggle.';\n258:     statusBarItem.show();\n259:     context.subscriptions.push(statusBarItem);\n260: \n261:     // Data flow status bar item\n262:     dataFlowStatusBar = vscode.window.createStatusBarItem(vscode.StatusBarAlignment.Right, 99);\n263:     dataFlowStatusBar.command = 'cognitiveTaxonomy.toggleDataFlow';\n264:     dataFlowStatusBar.text = `$(arrow-right) Flow: ASCII`;\n265:     dataFlowStatusBar.tooltip = 'Data flow view: ASCII. Click to cycle.';\n266:     dataFlowStatusBar.show();\n267:     context.subscriptions.push(dataFlowStatusBar);\n268: \n269:     // Register toggle command\n270:     context.subscriptions.push(\n271:         vscode.commands.registerCommand('cognitiveTaxonomy.toggle', toggleTaxonomy)\n272:     );\n273: \n274:     // Register data flow toggle command\n275:     context.subscriptions.push(\n276:         vscode.commands.registerCommand('cognitiveTaxonomy.toggleDataFlow', toggleDataFlowView)\n277:     );\n278: \n279:     // Register show metrics command\n280:     context.subscriptions.push(\n281:         vscode.commands.registerCommand('cognitiveTaxonomy.showMetrics', () => {\n282:             if (currentMetrics) {\n283:                 outputChannel.show();\n284:             } else {\n285:                 vscode.window.showInformationMessage('No metrics available. Enable taxonomy first.');\n286:             }\n287:         })\n288:     );\n289: \n290:     // Register refresh sidebar command\n291:     context.subscriptions.push(\n292:         vscode.commands.registerCommand('cognitiveTaxonomy.refreshSidebar', () => {\n293:             if (sidebarProvider && currentMetrics && vscode.window.activeTextEditor) {\n294:                 const code = vscode.window.activeTextEditor.document.getText();\n295:                 sidebarProvider.updateMetrics(currentMetrics, currentClassified, code);\n296:             }\n297:         })\n298:     );\n299: \n300:     // Re-apply decorations when editor changes\n301:     context.subscriptions.push(\n302:         vscode.window.onDidChangeActiveTextEditor(editor => {\n303:             if (editor && isEnabled) {\n304:                 applyDecorations(editor);\n305:             }\n306:         })\n307:     );\n308: \n309:     // Re-apply when document changes\n310:     context.subscriptions.push(\n311:         vscode.workspace.onDidChangeTextDocument(event => {\n312:             const editor = vscode.window.activeTextEditor;\n313:             if (editor && event.document === editor.document && isEnabled) {\n314:                 applyDecorations(editor);\n315:             }\n316:         })\n317:     );\n318: \n319:     // Initial decoration if already enabled\n320:     if (isEnabled && vscode.window.activeTextEditor) {\n321:         applyDecorations(vscode.window.activeTextEditor);\n322:     }\n323: }\n324: \n325: export function deactivate(): void {\n326:     disposeDecorationTypes();\n327: }\n\n(End of file - total 327 lines)\n</content>",
