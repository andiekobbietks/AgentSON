      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\lib\\teleprompter\\syllabus-mirror.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * SyllabusMirror — hybrid TTS orchestrator.\n3:  *\n4:  * Owns a sliding-window of upcoming sentences and routes each one to the\n5:  * cheapest engine that meets the latency budget, using a CPU feedback loop\n6:  * (real-time factor = wallMs / audioMs, EMA-smoothed).\n7:  *\n8:  * Pure TypeScript, no React. Consumers subscribe via the EventTarget API.\n9:  */\n10: import type { Sentence, Token } from \"./tokens\";\n11: import { loadAudio, saveAudio } from \"./opfs-audio-cache\";\n12: \n13: export type EngineId =\n14:   | \"kokoro-q8\"\n15:   | \"kokoro-q4\"\n16:   | \"web-speech\"\n17:   | \"f5-tts\"\n18:   | \"chatterbox\";\n19: \n20: export type EngineState = {\n21:   id: EngineId;\n22:   status: \"idle\" | \"loading\" | \"ready\" | \"error\";\n23:   lastRtf: number | null;\n24:   emaRtf: number | null;\n25:   enabled: boolean;\n26:   error?: string;\n27: };\n28: \n29: export type ScheduleSnapshot = {\n30:   engines: Record<EngineId, EngineState>;\n31:   buffered: number; // sentences ready ahead of playhead\n32:   bufferedMs: number;\n33:   scheduled: number;\n34:   activeSentenceId: string | null;\n35:   activeEngine: EngineId | null;\n36:   lookaheadMs: number;\n37:   cacheHits: number;\n38:   opfsAvailable: boolean;\n39: };\n40: \n41: type Listener = (snap: ScheduleSnapshot) => void;\n42: type AlignListener = (sentenceId: string, measuredMs: number) => void;\n43: type ScheduledListener = (sentenceId: string, engine: EngineId) => void;\n44: type SpokenListener = (throughMs: number) => void;\n45: \n46: const DEFAULT_LOOKAHEAD = 8_000;\n47: const MIN_LOOKAHEAD = 2_500;\n48: const MAX_LOOKAHEAD = 14_000;\n49: \n50: type CachedAudio = {\n51:   sentenceId: string;\n52:   buffer: AudioBuffer;\n53:   engine: EngineId;\n54:   measuredMs: number;\n55: };\n56: \n57: export class SyllabusMirror extends EventTarget {\n58:   private engines: Record<EngineId, EngineState> = {\n59:     \"kokoro-q8\": { id: \"kokoro-q8\", status: \"idle\", lastRtf: null, emaRtf: null, enabled: true },\n60:     \"kokoro-q4\": { id: \"kokoro-q4\", status: \"idle\", lastRtf: null, emaRtf: null, enabled: true },\n61:     \"web-speech\": {\n62:       id: \"web-speech\",\n63:       status: typeof window !== \"undefined\" && \"speechSynthesis\" in window ? \"ready\" : \"idle\",\n64:       lastRtf: 0.05,\n65:       emaRtf: 0.05,\n66:       enabled: true,\n67:     },\n68:     \"f5-tts\": { id: \"f5-tts\", status: \"idle\", lastRtf: null, emaRtf: null, enabled: false },\n69:     \"chatterbox\": { id: \"chatterbox\", status: \"idle\", lastRtf: null, emaRtf: null, enabled: false },\n70:   };\n71: \n72:   private kokoroQ8: any = null;\n73:   private kokoroQ4: any = null;\n74:   private experimental: Partial<Record<EngineId, any>> = {};\n75:   private loadingPromise: Partial<Record<EngineId, Promise<void>>> = {};\n76: \n77:   private cache = new Map<string, CachedAudio>();\n78:   private cacheHits = 0;\n79:   private opfsAvailable =\n80:     typeof navigator !== \"undefined\" &&\n81:     typeof (navigator as any).storage?.getDirectory === \"function\";\n82:   private scheduling = new Set<string>();\n83:   private voice = \"af_heart\";\n84:   private lookaheadMs = DEFAULT_LOOKAHEAD;\n85:   private active = false;\n86:   private currentMs = 0;\n87:   private tokens: Token[] = [];\n88:   private sentences: Sentence[] = [];\n89:   private audioCtx: AudioContext | null = null;\n90:   private activeSource: AudioBufferSourceNode | null = null;\n91:   private nextSource: AudioBufferSourceNode | null = null;\n92:   private nextSentenceId: string | null = null;\n93:   private activeSentenceId: string | null = null;\n94:   private activeEngine: EngineId | null = null;\n95:   private playing = false;\n96:   private lastSpokenMs = 0;\n97:   private forcedEngine = new Map<string, EngineId>();\n98: \n99:   setVoice(v: string) {\n100:     this.voice = v;\n101:     // Invalidate cache: new voice means new audio.\n102:     this.cache.clear();\n103:     this.emit();\n104:   }\n105: \n106:   setEngineEnabled(id: EngineId, enabled: boolean) {\n107:     this.engines[id].enabled = enabled;\n108:     this.emit();\n109:   }\n110: \n111:   setActive(on: boolean) {\n112:     this.active = on;\n113:     if (!on) this.stopAudio();\n114:     this.emit();\n115:   }\n116: \n117:   isActive() {\n118:     return this.active;\n119:   }\n120: \n121:   setPlaying(playing: boolean) {\n122:     this.playing = playing;\n123:     if (!playing) this.stopAudio();\n124:   }\n125: \n126:   /** Called by the React layer when the user scrubs the playhead. */\n127:   notifyScrub() {\n128:     this.stopAudio();\n129:     this.lastSpokenMs = this.currentMs;\n130:   }\n131: \n132:   /** Force a specific engine for one sentence and re-synthesise. */\n133:   async resynthesize(sentenceId: string, engineId: EngineId) {\n134:     this.cache.delete(sentenceId);\n135:     this.forcedEngine.set(sentenceId, engineId);\n136:     const s = this.sentences.find((s) => s.id === sentenceId);\n137:     if (!s) return;\n138:     if (this.activeSentenceId === sentenceId) this.stopAudio();\n139:     await this.synthesize(s, engineId);\n140:   }\n141: \n142:   /** Listen for compact snapshots. */\n143:   onChange(cb: Listener) {\n144:     const handler = (e: Event) => cb((e as CustomEvent<ScheduleSnapshot>).detail);\n145:     this.addEventListener(\"change\", handler);\n146:     return () => this.removeEventListener(\"change\", handler);\n147:   }\n148: \n149:   /** Notified when a sentence's measured TTS duration arrives. */\n150:   onAlign(cb: AlignListener) {\n151:     const handler = (e: Event) => {\n152:       const d = (e as CustomEvent<{ sentenceId: string; measuredMs: number }>).detail;\n153:       cb(d.sentenceId, d.measuredMs);\n154:     };\n155:     this.addEventListener(\"align\", handler);\n156:     return () => this.removeEventListener(\"align\", handler);\n157:   }\n158: \n159:   onScheduled(cb: ScheduledListener) {\n160:     const handler = (e: Event) => {\n161:       const d = (e as CustomEvent<{ sentenceId: string; engine: EngineId }>).detail;\n162:       cb(d.sentenceId, d.engine);\n163:     };\n164:     this.addEventListener(\"scheduled\", handler);\n165:     return () => this.removeEventListener(\"scheduled\", handler);\n166:   }\n167: \n168:   onSpoken(cb: SpokenListener) {\n169:     const handler = (e: Event) => {\n170:       const d = (e as CustomEvent<{ throughMs: number }>).detail;\n171:       cb(d.throughMs);\n172:     };\n173:     this.addEventListener(\"spoken\", handler);\n174:     return () => this.removeEventListener(\"spoken\", handler);\n175:   }\n176: \n177:   /** Called on every animation tick from the React layer. */\n178:   tick(currentMs: number, tokens: Token[], sentences: Sentence[]) {\n179:     const prevMs = this.currentMs;\n180:     this.currentMs = currentMs;\n181:     this.tokens = tokens;\n182:     this.sentences = sentences;\n183:     if (currentMs < prevMs - 250) {\n184:       // Backward scrub.\n185:       this.notifyScrub();\n186:     }\n187:     if (currentMs > this.lastSpokenMs) {\n188:       this.lastSpokenMs = currentMs;\n189:       this.dispatchEvent(\n190:         new CustomEvent(\"spoken\", { detail: { throughMs: currentMs } }),\n191:       );\n192:     }\n193:     if (!this.active) return;\n194:     this.maybeStartActiveSentence();\n195:     this.scheduleAhead();\n196:   }\n197: \n198:   // ── Engine loading ────────────────────────────────────────────────\n199:   private async ensureKokoro(variant: \"q8\" | \"q4\"): Promise<any> {\n200:     const id: EngineId = variant === \"q8\" ? \"kokoro-q8\" : \"kokoro-q4\";\n201:     if (variant === \"q8\" && this.kokoroQ8) return this.kokoroQ8;\n202:     if (variant === \"q4\" && this.kokoroQ4) return this.kokoroQ4;\n203:     if (this.loadingPromise[id]) {\n204:       await this.loadingPromise[id];\n205:       return variant === \"q8\" ? this.kokoroQ8 : this.kokoroQ4;\n206:     }\n207:     this.engines[id].status = \"loading\";\n208:     this.emit();\n209:     const p = (async () => {\n210:       try {\n211:         const { KokoroTTS } = await import(\"kokoro-js\");\n212:         const instance = await KokoroTTS.from_pretrained(\n213:           \"onnx-community/Kokoro-82M-v1.0-ONNX\",\n214:           { dtype: variant, device: \"wasm\" },\n215:         );\n216:         if (variant === \"q8\") this.kokoroQ8 = instance;\n217:         else this.kokoroQ4 = instance;\n218:         this.engines[id].status = \"ready\";\n219:       } catch (err) {\n220:         this.engines[id].status = \"error\";\n221:         this.engines[id].error = err instanceof Error ? err.message : String(err);\n222:       } finally {\n223:         this.loadingPromise[id] = undefined;\n224:         this.emit();\n225:       }\n226:     })();\n227:     this.loadingPromise[id] = p;\n228:     await p;\n229:     return variant === \"q8\" ? this.kokoroQ8 : this.kokoroQ4;\n230:   }\n231: \n232:   /** Experimental engines (F5-TTS, Chatterbox). Browser ports of these\n233:    *  aren't shipped yet — the loader tries dynamic import and marks the\n234:    *  engine as `error` if the package is absent. The slot stays visible so\n235:    *  the UI honestly shows the roadmap. */\n236:   private async ensureExperimental(id: \"f5-tts\" | \"chatterbox\"): Promise<any> {\n237:     if (this.experimental[id]) return this.experimental[id];\n238:     if (this.loadingPromise[id]) {\n239:       await this.loadingPromise[id];\n240:       return this.experimental[id];\n241:     }\n242:     this.engines[id].status = \"loading\";\n243:     this.emit();\n244:     const p = (async () => {\n245:       try {\n246:         // Best-effort dynamic loaders. Falls into the catch when the package\n247:         // isn't installed, which is the expected state in v1.6.\n248:         const pkg = id === \"f5-tts\" ? \"f5-tts-web\" : \"chatterbox-tts-web\";\n249:         // Bypass static analysis — these are opt-in runtime modules.\n250:         const dynImport = new Function(\"p\", \"return import(/* @vite-ignore */ p)\") as (\n251:           p: string,\n252:         ) => Promise<any>;\n253:         const mod = await dynImport(pkg).catch(() => null);\n254:         if (!mod) throw new Error(`${id} runtime not installed`);\n255:         const ctor = (mod as any).default ?? (mod as any).TTS;\n256:         const instance = await ctor.from_pretrained();\n257:         this.experimental[id] = instance;\n258:         this.engines[id].status = \"ready\";\n259:       } catch (err) {\n260:         this.engines[id].status = \"error\";\n261:         this.engines[id].error = err instanceof Error ? err.message : String(err);\n262:       } finally {\n263:         this.loadingPromise[id] = undefined;\n264:         this.emit();\n265:       }\n266:     })();\n267:     this.loadingPromise[id] = p;\n268:     await p;\n269:     return this.experimental[id];\n270:   }\n271: \n272:   /** Pre-load q8 (the default director voice). */\n273:   async warmup() {\n274:     await this.ensureKokoro(\"q8\");\n275:   }\n276: \n277:   // ── Engine routing ────────────────────────────────────────────────\n278:   private pickEngine(sentence: Sentence): EngineId {\n279:     const forced = this.forcedEngine.get(sentence.id);\n280:     if (forced) return forced;\n281:     const words = sentence.text.split(/\\s+/).length;\n282:     const q8 = this.engines[\"kokoro-q8\"];\n283:     const q4 = this.engines[\"kokoro-q4\"];\n284:     const ws = this.engines[\"web-speech\"];\n285:     const f5 = this.engines[\"f5-tts\"];\n286:     const cb = this.engines[\"chatterbox\"];\n287: \n288:     // Opt-in experimental engines come first when enabled & ready.\n289:     if (f5.enabled && f5.status === \"ready\" && words >= 8) return \"f5-tts\";\n290:     if (cb.enabled && cb.status === \"ready\") return \"chatterbox\";\n291: \n292:     // If q8 is healthy and the sentence is meaty, prefer it.\n293:     if (q8.enabled && (q8.emaRtf ?? 0.3) < 0.6 && words >= 8) return \"kokoro-q8\";\n294:     // Short cue or stressed CPU → q4.\n295:     if (q4.enabled && (q4.emaRtf ?? 0.4) < 0.85) return \"kokoro-q4\";\n296:     // Last resort → browser SpeechSynthesis.\n297:     if (ws.enabled && ws.status === \"ready\") return \"web-speech\";\n298:     // Fallback to q8 even if slow.\n299:     return q8.enabled ? \"kokoro-q8\" : \"web-speech\";\n300:   }\n301: \n302:   // ── CPU feedback ──────────────────────────────────────────────────\n303:   private updateRtf(engineId: EngineId, wallMs: number, audioMs: number) {\n304:     if (audioMs <= 0) return;\n305:     const rtf = wallMs / audioMs;\n306:     const eng = this.engines[engineId];\n307:     eng.lastRtf = rtf;\n308:     eng.emaRtf = eng.emaRtf == null ? rtf : eng.emaRtf * 0.7 + rtf * 0.3;\n309:     // Adjust global lookahead.\n310:     if (rtf > 0.85) this.lookaheadMs = Math.max(MIN_LOOKAHEAD, this.lookaheadMs - 1_500);\n311:     else if (rtf < 0.35) this.lookaheadMs = Math.min(MAX_LOOKAHEAD, this.lookaheadMs + 1_000);\n312:     this.emit();\n313:   }\n314: \n315:   // ── Scheduling ────────────────────────────────────────────────────\n316:   private scheduleAhead() {\n317:     const horizon = this.currentMs + this.lookaheadMs;\n318:     for (const s of this.sentences) {\n319:       if (s.endMs < this.currentMs) continue;\n320:       if (s.startMs > horizon) break;\n321:       if (this.cache.has(s.id) || this.scheduling.has(s.id)) continue;\n322:       const engine = this.pickEngine(s);\n323:       this.scheduling.add(s.id);\n324:       this.dispatchEvent(\n325:         new CustomEvent(\"scheduled\", { detail: { sentenceId: s.id, engine } }),\n326:       );\n327:       this.synthesize(s, engine)\n328:         .catch(() => {\n329:           /* engine state already updated */\n330:         })\n331:         .finally(() => {\n332:           this.scheduling.delete(s.id);\n333:           this.emit();\n334:         });\n335:     }\n336:     this.emit();\n337:   }\n338: \n339:   private async synthesize(sentence: Sentence, engineId: EngineId): Promise<void> {\n340:     // OPFS fast path.\n341:     const cached = await loadAudio({\n342:       engineId,\n343:       voice: this.voice,\n344:       text: sentence.text,\n345:     });\n346:     if (cached) {\n347:       this.cacheHits++;\n348:       const ctx = this.ensureCtx();\n349:       const buf = ctx.createBuffer(1, cached.samples.length || 1, cached.sampleRate);\n350:       buf.getChannelData(0).set(cached.samples);\n351:       const measuredMs = (cached.samples.length / cached.sampleRate) * 1000;\n352:       this.cache.set(sentence.id, {\n353:         sentenceId: sentence.id,\n354:         buffer: buf,\n355:         engine: engineId,\n356:         measuredMs,\n357:       });\n358:       this.dispatchEvent(\n359:         new CustomEvent(\"align\", { detail: { sentenceId: sentence.id, measuredMs } }),\n360:       );\n361:       this.emit();\n362:       return;\n363:     }\n364: \n365:     const t0 = performance.now();\n366:     let audioBuffer: AudioBuffer | null = null;\n367:     let measuredMs = 0;\n368:     let pcmSamples: Float32Array | null = null;\n369:     let pcmRate = 0;\n370: \n371:     if (engineId === \"kokoro-q8\" || engineId === \"kokoro-q4\") {\n372:       const variant = engineId === \"kokoro-q8\" ? \"q8\" : \"q4\";\n373:       const tts = await this.ensureKokoro(variant);\n374:       if (!tts) return;\n375:       const result = await tts.generate(sentence.text, { voice: this.voice });\n376:       const sr: number = result.sampling_rate ?? 24000;\n377:       const samples: Float32Array = result.audio ?? new Float32Array();\n378:       measuredMs = (samples.length / sr) * 1000;\n379:       const ctx = this.ensureCtx();\n380:       audioBuffer = ctx.createBuffer(1, samples.length || 1, sr);\n381:       const channel = audioBuffer.getChannelData(0);\n382:       channel.set(samples);\n383:       pcmSamples = samples;\n384:       pcmRate = sr;\n385:     } else if (engineId === \"f5-tts\" || engineId === \"chatterbox\") {\n386:       const inst = await this.ensureExperimental(engineId);\n387:       if (!inst) return;\n388:       const result = await inst.generate(sentence.text, { voice: this.voice });\n389:       const sr: number = result.sampling_rate ?? 24000;\n390:       const samples: Float32Array = result.audio ?? new Float32Array();\n391:       measuredMs = (samples.length / sr) * 1000;\n392:       const ctx = this.ensureCtx();\n393:       audioBuffer = ctx.createBuffer(1, samples.length || 1, sr);\n394:       audioBuffer.getChannelData(0).set(samples);\n395:       pcmSamples = samples;\n396:       pcmRate = sr;\n397:     } else if (engineId === \"web-speech\") {\n398:       // Web Speech doesn't expose PCM, so estimate via WPM (~3.5 chars/word at 160wpm).\n399:       const wordCount = sentence.text.split(/\\s+/).length;\n400:       measuredMs = (wordCount / 160) * 60_000;\n401:       // Build a silent placeholder buffer so timing still aligns; actual speech\n402:       // playback uses speechSynthesis at play time.\n403:       const ctx = this.ensureCtx();\n404:       audioBuffer = ctx.createBuffer(1, Math.max(1, Math.floor((measuredMs / 1000) * ctx.sampleRate)), ctx.sampleRate);\n405:     }\n406: \n407:     const wallMs = performance.now() - t0;\n408:     this.updateRtf(engineId, wallMs, measuredMs);\n409:     if (!audioBuffer) return;\n410:     this.cache.set(sentence.id, { sentenceId: sentence.id, buffer: audioBuffer, engine: engineId, measuredMs });\n411:     this.dispatchEvent(new CustomEvent(\"align\", { detail: { sentenceId: sentence.id, measuredMs } }));\n412:     if (pcmSamples && pcmRate) {\n413:       saveAudio(\n414:         { engineId, voice: this.voice, text: sentence.text },\n415:         pcmSamples,\n416:         pcmRate,\n417:       ).catch(() => undefined);\n418:     }\n419:     this.emit();\n420:   }\n421: \n422:   // ── Playback ──────────────────────────────────────────────────────\n423:   private ensureCtx(): AudioContext {\n424:     if (!this.audioCtx) {\n425:       const Ctor = (window.AudioContext || (window as any).webkitAudioContext) as typeof AudioContext;\n426:       this.audioCtx = new Ctor();\n427:     }\n428:     return this.audioCtx;\n429:   }\n430: \n431:   private maybeStartActiveSentence() {\n432:     if (!this.playing || !this.active) return;\n433:     const s = this.sentences.find((s) => this.currentMs >= s.startMs && this.currentMs < s.endMs);\n434:     if (!s) return;\n435:     if (this.activeSentenceId === s.id) return;\n436:     const cached = this.cache.get(s.id);\n437:     if (!cached) return;\n438:     this.stopAudio();\n439:     this.activeSentenceId = s.id;\n440:     this.activeEngine = cached.engine;\n441:     if (cached.engine === \"web-speech\") {\n442:       try {\n443:         const u = new SpeechSynthesisUtterance(s.text);\n444:         u.rate = 1;\n445:         window.speechSynthesis.speak(u);\n446:       } catch {\n447:         /* ignore */\n448:       }\n449:     } else {\n450:       const ctx = this.ensureCtx();\n451:       const src = ctx.createBufferSource();\n452:       src.buffer = cached.buffer;\n453:       src.connect(ctx.destination);\n454:       const offset = Math.max(0, (this.currentMs - s.startMs) / 1000);\n455:       try {\n456:         src.start(0, offset);\n457:       } catch {\n458:         /* ignore */\n459:       }\n460:       this.activeSource = src;\n461:       // Gapless: pre-schedule the next cached sentence right after this one.\n462:       const idx = this.sentences.findIndex((x) => x.id === s.id);\n463:       const nextS = this.sentences[idx + 1];\n464:       const nextCached = nextS ? this.cache.get(nextS.id) : null;\n465:       if (nextS && nextCached && nextCached.engine !== \"web-speech\") {\n466:         const remaining = (cached.buffer.duration - offset);\n467:         const when = ctx.currentTime + Math.max(0, remaining);\n468:         try {\n469:           const nx = ctx.createBufferSource();\n470:           nx.buffer = nextCached.buffer;\n471:           nx.connect(ctx.destination);\n472:           nx.start(when);\n473:           this.nextSource = nx;\n474:           this.nextSentenceId = nextS.id;\n475:         } catch {\n476:           /* ignore */\n477:         }\n478:       }\n479:     }\n480:     this.emit();\n481:   }\n482: \n483:   private stopAudio() {\n484:     if (this.activeSource) {\n485:       try {\n486:         this.activeSource.stop();\n487:       } catch {\n488:         /* ignore */\n489:       }\n490:       this.activeSource.disconnect();\n491:       this.activeSource = null;\n492:     }\n493:     if (this.nextSource) {\n494:       try {\n495:         this.nextSource.stop();\n496:       } catch {\n497:         /* ignore */\n498:       }\n499:       this.nextSource.disconnect();\n500:       this.nextSource = null;\n501:       this.nextSentenceId = null;\n502:     }\n503:     if (typeof window !== \"undefined\" && \"speechSynthesis\" in window) {\n504:       window.speechSynthesis.cancel();\n505:     }\n506:     this.activeSentenceId = null;\n507:     this.activeEngine = null;\n508:   }\n509: \n510:   // ── Snapshot ──────────────────────────────────────────────────────\n511:   private snapshot(): ScheduleSnapshot {\n512:     let bufferedMs = 0;\n513:     let buffered = 0;\n514:     for (const s of this.sentences) {\n515:       if (s.startMs < this.currentMs) continue;\n516:       if (this.cache.has(s.id)) {\n517:         buffered++;\n518:         bufferedMs += s.endMs - s.startMs;\n519:       }\n520:     }\n521:     return {\n522:       engines: { ...this.engines },\n523:       buffered,\n524:       bufferedMs,\n525:       scheduled: this.scheduling.size,\n526:       activeSentenceId: this.activeSentenceId,\n527:       activeEngine: this.activeEngine,\n528:       lookaheadMs: this.lookaheadMs,\n529:       cacheHits: this.cacheHits,\n530:       opfsAvailable: this.opfsAvailable,\n531:     };\n532:   }\n533: \n534:   private emit() {\n535:     this.dispatchEvent(new CustomEvent(\"change\", { detail: this.snapshot() }));\n536:   }\n537: \n538:   getSnapshot() {\n539:     return this.snapshot();\n540:   }\n541: \n542:   dispose() {\n543:     this.stopAudio();\n544:     this.cache.clear();\n545:     if (this.audioCtx) this.audioCtx.close().catch(() => undefined);\n546:     this.audioCtx = null;\n547:   }\n548: }\n\n(End of file - total 548 lines)\n</content>",
