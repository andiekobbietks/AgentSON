      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\lib\\\\teleprompter\\\\syllabus-mirror.ts\", \"newString\": \"  private pickEngine(sentence: Sentence): EngineId {\\n    const forced = this.forcedEngine.get(sentence.id);\\n    if (forced) return forced;\\n    const words = sentence.text.split(/\\\\s+/).length;\\n    const q8 = this.engines[\\\"kokoro-q8\\\"];\\n    const q4 = this.engines[\\\"kokoro-q4\\\"];\\n    const ws = this.engines[\\\"web-speech\\\"];\\n    const f5 = this.engines[\\\"f5-tts\\\"];\\n    const cb = this.engines[\\\"chatterbox\\\"];\\n    const dg = this.engines[\\\"deepgram-aura\\\"];\\n\\n    // Opt-in experimental engines come first when enabled & ready.\\n    if (f5.enabled && f5.status === \\\"ready\\\" && words >= 8) return \\\"f5-tts\\\";\\n    if (cb.enabled && cb.status === \\\"ready\\\") return \\\"chatterbox\\\";\\n\\n    // Cloud fallback: Deepgram Aura when enabled & ready, prefer for short sentences.\\n    if (dg.enabled && dg.status === \\\"ready\\\" && words < 8) return \\\"deepgram-aura\\\";\\n\\n    // If q8 is healthy and the sentence is meaty, prefer it.\\n    if (q8.enabled && (q8.emaRtf ?? 0.3) < 0.6 && words >= 8) return \\\"kokoro-q8\\\";\\n    // Short cue or stressed CPU \\u2192 q4.\\n    if (q4.enabled && (q4.emaRtf ?? 0.4) < 0.85) return \\\"kokoro-q4\\\";\\n    // Cloud fallback for longer sentences when local is slow.\\n    if (dg.enabled && dg.status === \\\"ready\\\" && (q8.emaRtf ?? 0.3) > 0.7) return \\\"deepgram-aura\\\";\\n    // Last resort \\u2192 browser SpeechSynthesis.\\n    if (ws.enabled && ws.status === \\\"ready\\\") return \\\"web-speech\\\";\\n    // Fallback to q8 even if slow.\\n    return q8.enabled ? \\\"kokoro-q8\\\" : \\\"web-speech\\\";\\n  }\", \"oldString\": \"  private pickEngine(sentence: Sentence): EngineId {\\n    const forced = this.forcedEngine.get(sentence.id);\\n    if (forced) return forced;\\n    const words = sentence.text.split(/\\\\s+/).length;\\n    const q8 = this.engines[\\\"kokoro-q8\\\"];\\n    const q4 = this.engines[\\\"kokoro-q4\\\"];\\n    const ws = this.engines[\\\"web-speech\\\"];\\n    const f5 = this.engines[\\\"f5-tts\\\"];\\n    const cb = this.engines[\\\"chatterbox\\\"];\\n\\n    // Opt-in experimental engines come first when enabled & ready.\\n    if (f5.enabled && f5.status === \\\"ready\\\" && words >= 8) return \\\"f5-tts\\\";\\n    if (cb.enabled && cb.status === \\\"ready\\\") return \\\"chatterbox\\\";\\n\\n    // If q8 is healthy and the sentence is meaty, prefer it.\\n    if (q8.enabled && (q8.emaRtf ?? 0.3) < 0.6 && words >= 8) return \\\"kokoro-q8\\\";\\n    // Short cue or stressed CPU \\u2192 q4.\\n    if (q4.enabled && (q4.emaRtf ?? 0.4) < 0.85) return \\\"kokoro-q4\\\";\\n    // Last resort \\u2192 browser SpeechSynthesis.\\n    if (ws.enabled && ws.status === \\\"ready\\\") return \\\"web-speech\\\";\\n    // Fallback to q8 even if slow.\\n    return q8.enabled ? \\\"kokoro-q8\\\" : \\\"web-speech\\\";\\n  }\"}",
