      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\lib\\\\teleprompter\\\\syllabus-mirror.ts\", \"limit\": 30, \"offset\": 12}",
      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\lib\\teleprompter\\syllabus-mirror.ts</path>\n<type>file</type>\n<content>\n12: \n13: export type EngineId =\n14:   | \"kokoro-q8\"\n15:   | \"kokoro-q4\"\n16:   | \"web-speech\"\n17:   | \"f5-tts\"\n18:   | \"chatterbox\";\n19: \n20: export type EngineState = {\n21:   id: EngineId;\n22:   status: \"idle\" | \"loading\" | \"ready\" | \"error\";\n23:   lastRtf: number | null;\n24:   emaRtf: number | null;\n25:   enabled: boolean;\n26:   error?: string;\n27: };\n28: \n29: export type ScheduleSnapshot = {\n30:   engines: Record<EngineId, EngineState>;\n31:   buffered: number; // sentences ready ahead of playhead\n32:   bufferedMs: number;\n33:   scheduled: number;\n34:   activeSentenceId: string | null;\n35:   activeEngine: EngineId | null;\n36:   lookaheadMs: number;\n37:   cacheHits: number;\n38:   opfsAvailable: boolean;\n39: };\n40: \n41: type Listener = (snap: ScheduleSnapshot) => void;\n\n(Showing lines 12-41 of 548. Use offset=42 to continue.)\n</content>",
