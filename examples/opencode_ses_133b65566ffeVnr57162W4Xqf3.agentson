      "output": "[\n  {\n    \"content\": \"Add Deepgram Aura as cloud fallback engine in SyllabusMirror (6th engine)\",\n    \"status\": \"completed\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Build Score View route — horizontal script layout with continuous pitch contour line\",\n    \"status\": \"in_progress\",\n    \"priority\": \"high\"\n  },\n  {\n    \"content\": \"Wire Score View into navigation and routing\",\n    \"status\": \"pending\",\n    \"priority\": \"medium\"\n  },\n  {\n    \"content\": \"Verify build compiles and push to GitHub\",\n    \"status\": \"pending\",\n    \"priority\": \"high\"\n  }\n]",
