ath.max(MIN_LOOKAHEAD, this.lookaheadMs - 1_500);\n311:     else if (rtf < 0.35) this.lookaheadMs = Math.min(MAX_LOOKAHEAD, this.lookaheadMs + 1_000);\n312:     this.emit();\n313:   }\n314: \n315:   // ── Scheduling ────────────────────────────────────────────────────\n316:   private scheduleAhead() {\n317:     const horizon = this.currentMs + this.lookaheadMs;\n318:     for (const s of this.sentences) {\n319:       if (s.endMs < this.currentMs) continue;\n320:       if (s.startMs > horizon) break;\n321:       if (this.cache.has(s.id) || this.scheduling.has(s.id)) continue;\n322:       const engine = this.pickEngine(s);\n323:       this.scheduling.add(s.id);\n324:       this.dispatchEvent(\n\n(Showing lines 275-324 of 548. Use offset=325 to continue.)\n</content>",
