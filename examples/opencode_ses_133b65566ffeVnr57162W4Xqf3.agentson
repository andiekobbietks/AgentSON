      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\routes\\\\teleprompter.tsx\", \"newString\": \"                    <EngineStatus\\n                      snapshot={snapshot}\\n                      onToggle={(id, en) => orchestrator?.setEngineEnabled(id, en)}\\n                    />\\n                  </section>\\n\\n                  <section className=\\\"border-t border-border pt-6\\\">\\n                    <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-primary mb-3\\\">\\n                      Cloudflare \\u00b7 Deepgram Aura\\n                    </div>\\n                    <p className=\\\"text-[11px] text-muted-foreground leading-relaxed mb-3\\\">\\n                      Free cloud TTS via Workers AI (10K neurons/day). Configure\\n                      credentials to enable the Deepgram Aura engine as a cloud\\n                      fallback.\\n                    </p>\\n                    <div className=\\\"space-y-2\\\">\\n                      <label className=\\\"block text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n                        Account ID\\n                      </label>\\n                      <input\\n                        type=\\\"text\\\"\\n                        value={cfAccountId}\\n                        onChange={(e) => setCfAccountId(e.target.value)}\\n                        placeholder=\\\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\\\"\\n                        className=\\\"w-full bg-card border border-border p-2 text-xs font-mono\\\"\\n                      />\\n                      <label className=\\\"block text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n                        API Token\\n                      </label>\\n                      <input\\n                        type=\\\"password\\\"\\n                        value={cfApiToken}\\n                        onChange={(e) => setCfApiToken(e.target.value)}\\n                        placeholder=\\\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\\\"\\n                        className=\\\"w-full bg-card border border-border p-2 text-xs font-mono\\\"\\n                      />\\n                      <label className=\\\"block text-[10px] font-mono uppercase tracking-widest text-muted-foreground\\\">\\n                        Voice\\n                      </label>\\n                      <select\\n                        value={deepgramVoice}\\n                        onChange={(e) => setDeepgramVoice(e.target.value)}\\n                        className=\\\"w-full bg-card border border-border p-2 text-xs font-mono\\\"\\n                      >\\n                        <option value=\\\"luna\\\">Luna (female, warm)</option>\\n                        <option value=\\\"asteria\\\">Asteria (female, clear)</option>\\n                        <option value=\\\"stella\\\">Stella (female, bright)</option>\\n                        <option value=\\\"athena\\\">Athena (female, authoritative)</option>\\n                        <option value=\\\"hera\\\">Hera (female, mature)</option>\\n                        <option value=\\\"orion\\\">Orion (male, deep)</option>\\n                        <option value=\\\"arcas\\\">Arcas (male, youthful)</option>\\n                        <option value=\\\"perseus\\\">Perseus (male, narrator)</option>\\n                      </select>\\n                    </div>\\n                    {cfAccountId && cfApiToken && (\\n                      <p className=\\\"text-[10px] font-mono text-primary mt-2\\\">\\n                        \\u2713 Credentials saved locally\\n                      </p>\\n                    )}\\n                  </section>\\n\\n                  <section className=\\\"border-t border-border pt-6\\\">\", \"oldString\": \"                    <EngineStatus\\n                      snapshot={snapshot}\\n                      onToggle={(id, en) => orchestrator?.setEngineEnabled(id, en)}\\n                    />\\n                  </section>\\n\\n                  <section className=\\\"border-t border-border pt-6\\\">\"}",
