      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\components\\\\teleprompter\\\\TranscriptStage.tsx\", \"oldString\": \"/** Full-screen scrolling stage. Renders each token as a span so the playhead\\n *  can centre the active token via scrollIntoView. */\\nexport function TranscriptStage({\\n  tokens,\\n  currentTokenId,\\n  fontSize,\\n  mirror,\\n  activeEngine,\\n  loopRange,\\n  onTokenClick,\\n  onTokenShiftClick,\\n  onResynth,\\n}: Props) {\", \"newString\": \"/** Full-screen scrolling stage. Renders each token as a span so the playhead\\n *  can centre the active token via scrollIntoView. */\\nexport function TranscriptStage({\\n  tokens,\\n  currentTokenId,\\n  fontSize,\\n  mirror,\\n  activeEngine,\\n  loopRange,\\n  onTokenClick,\\n  onTokenShiftClick,\\n  onResynth,\\n  prosody,\\n  showProsody = false,\\n  triageMarkerMs,\\n}: Props) {\"}",
      "output": "Edit applied successfully.",
