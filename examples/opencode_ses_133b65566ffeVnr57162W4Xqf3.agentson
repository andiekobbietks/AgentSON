    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"/**\\n * OnboardingFlow \\u2014 First-visit wizard for non-technical users.\\n *\\n * Walks through: what ProLector is, what prosody is, how to use the\\n * teleprompter, and personalized WPM recommendation. Dismissible and\\n * persisted to localStorage.\\n */\\nimport { useCallback, useState } from \\\"react\\\";\\nimport { Link } from \\\"@tanstack/react-router\\\";\\n\\nconst DISMISSED_KEY = \\\"prolector.onboarding.dismissed\\\";\\n\\ntype Step = \\\"welcome\\\" | \\\"what\\\" | \\\"how\\\" | \\\"wpm\\\" | \\\"done\\\";\\n\\nconst LANGUAGES = [\\n  { code: \\\"en\\\", name: \\\"English\\\", flag: \\\"\\ud83c\\uddec\\ud83c\\udde7\\\" },\\n  { code: \\\"it\\\", name: \\\"Italian\\\", flag: \\\"\\ud83c\\uddee\\ud83c\\uddf9\\\" },\\n  { code: \\\"es\\\", name: \\\"Spanish\\\", flag: \\\"\\ud83c\\uddea\\ud83c\\uddf8\\\" },\\n  { code: \\\"fr\\\", name: \\\"French\\\", flag: \\\"\\ud83c\\uddeb\\ud83c\\uddf7\\\" },\\n  { code: \\\"de\\\", name: \\\"German\\\", flag: \\\"\\ud83c\\udde9\\ud83c\\uddea\\\" },\\n  { code: \\\"pt\\\", name: \\\"Portuguese\\\", flag: \\\"\\ud83c\\udde7\\ud83c\\uddf7\\\" },\\n  { code: \\\"ja\\\", name: \\\"Japanese\\\", flag: \\\"\\ud83c\\uddef\\ud83c\\uddf5\\\" },\\n  { code: \\\"zh\\\", name: \\\"Chinese\\\", flag: \\\"\\ud83c\\udde8\\ud83c\\uddf3\\\" },\\n  { code: \\\"ko\\\", name: \\\"Korean\\\", flag: \\\"\\ud83c\\uddf0\\ud83c\\uddf7\\\" },\\n  { code: \\\"ar\\\", name: \\\"Arabic\\\", flag: \\\"\\ud83c\\uddf8\\ud83c\\udde6\\\" },\\n  { code: \\\"hi\\\", name: \\\"Hindi\\\", flag: \\\"\\ud83c\\uddee\\ud83c\\uddf3\\\" },\\n];\\n\\nconst LEVELS = [\\n  { id: \\\"a2\\\", label: \\\"A2 \\u00b7 Elementary\\\", desc: \\\"I can understand sentences on familiar topics\\\" },\\n  { id: \\\"b1\\\", label: \\\"B1 \\u00b7 Intermediate\\\", desc: \\\"I can handle most travel situations\\\" },\\n  { id: \\\"b2\\\", label: \\\"B2 \\u00b7 Upper Intermediate\\\", desc: \\\"I can interact with fluency and spontaneity\\\" },\\n  { id: \\\"c1\\\", label: \\\"C1 \\u00b7 Advanced\\\", desc: \\\"I can use language flexibly for social and professional purposes\\\" },\\n  { id: \\\"c2\\\", label: \\\"C2 \\u00b7 Proficient\\\", desc: \\\"I can understand virtually everything heard or read\\\" },\\n];\\n\\nconst WPM_MAP: Record<string, { start: number; target: number }> = {\\n  a2: { start: 90, target: 120 },\\n  b1: { start: 100, target: 135 },\\n  b2: { start: 110, target: 150 },\\n  c1: { start: 120, target: 160 },\\n  c2: { start: 130, target: 170 },\\n};\\n\\nexport function OnboardingFlow({ onComplete }: { onComplete: () => void }) {\\n  const [step, setStep] = useState<Step>(\\\"welcome\\\");\\n  const [language, setLanguage] = useState(\\\"en\\\");\\n  const [level, setLevel] = useState(\\\"b1\\\");\\n\\n  const finish = useCallback(() => {\\n    localStorage.setItem(DISMISSED_KEY, \\\"true\\\");\\n    localStorage.setItem(\\\"prolector.onboarding.language\\\", language);\\n    localStorage.setItem(\\\"prolector.onboarding.level\\\", level);\\n    const wpm = WPM_MAP[level] ?? WPM_MAP.b1;\\n    localStorage.setItem(\\\"prolector.onboarding.wpm\\\", String(wpm.start));\\n    onComplete();\\n  }, [language, level, onComplete]);\\n\\n  return (\\n    <div className=\\\"fixed inset-0 z-50 bg-background/95 backdrop-blur-sm flex items-center justify-center p-6\\\">\\n      <div className=\\\"max-w-lg w-full bg-card border border-border rounded-lg shadow-2xl overflow-hidden\\\">\\n        {/* Progress bar */}\\n        <div className=\\\"h-1 bg-border\\\">\\n          <div\\n            className=\\\"h-full bg-primary transition-all duration-300\\\"\\n            style={{\\n              width:\\n                step === \\\"welcome\\\"\\n                  ? \\\"0%\\\"\\n                  : step === \\\"what\\\"\\n                    ? \\\"25%\\\"\\n                    : step === \\\"how\\\"\\n                      ? \\\"50%\\\"\\n                      : step === \\\"wpm\\\"\\n                        ? \\\"75%\\\"\\n                        : \\\"100%\\\",\\n            }}\\n          />\\n        </div>\\n\\n        <div className=\\\"p-8\\\">\\n          {/* Step: Welcome */}\\n          {step === \\\"welcome\\\" && (\\n            <div className=\\\"space-y-4\\\">\\n              <h2 className=\\\"text-2xl font-display font-bold tracking-tight\\\">\\n                Welcome to ProLector\\n              </h2>\\n              <p className=\\\"text-muted-foreground leading-relaxed\\\">\\n                A pronunciation trainer that helps you sound more natural in\\n                English. It shows you the \\\"music\\\" of your speech \\u2014 rhythm,\\n                stress, and pitch \\u2014 so you can see what to improve.\\n              </p>\\n              <p className=\\\"text-sm text-muted-foreground\\\">\\n                This takes about 60 seconds. You can skip anytime.\\n              </p>\\n              <button\\n                onClick={() => setStep(\\\"what\\\")}\\n                className=\\\"w-full bg-primary text-primary-foreground py-3 font-bold text-sm uppercase tracking-widest hover:brightness-110 transition-all\\\"\\n              >\\n                Get Started \\u2192\\n              </button>\\n            </div>\\n          )}\\n\\n          {/* Step: What is prosody */}\\n          {step === \\\"what\\\" && (\\n            <div className=\\\"space-y-4\\\">\\n              <h2 className=\\\"text-xl font-display font-bold tracking-tight\\\">\\n                What is prosody?\\n              </h2>\\n              <p className=\\\"text-muted-foreground leading-relaxed\\\">\\n                English has a hidden \\\"score\\\" \\u2014 a pattern of rhythm, stress, and\\n                pitch that native speakers follow without thinking. When you\\n                speak English with the rhythm of your native language, listeners\\n                have to work harder to understand you, even if every word is\\n                correct.\\n              </p>\\n              <div className=\\\"bg-card border border-border rounded p-4 text-sm\\\">\\n                <p className=\\\"text-foreground font-semibold mb-1\\\">Example:</p>\\n                <p className=\\\"text-muted-foreground\\\">\\n                  \\\"I didn't <em>say</em> he stole the money\\\" \\u2014 I'm\\u5426\\u8ba4 he said\\n                  it\\n                </p>\\n                <p className=\\\"text-muted-foreground\\\">\\n                  \\\"I didn't say <em>he</em> stole the money\\\" \\u2014 someone else\\n                  did\\n                </p>\\n                <p className=\\\"text-muted-foreground\\\">\\n                  \\\"I didn't say he stole <em>the</em> money\\\" \\u2014 a different sum\\n                </p>\\n                <p className=\\\"text-xs text-muted-foreground/60 mt-2\\\">\\n                  Same words, different meaning \\u2014 all because of stress.\\n                </p>\\n              </div>\\n              <p className=\\\"text-muted-foreground leading-relaxed\\\">\\n                ProLector makes this score visible so you can train your ear\\n                and mouth together.\\n              </p>\\n              <button\\n                onClick={() => setStep(\\\"how\\\")}\\n                className=\\\"w-full bg-primary text-primary-foreground py-3 font-bold text-sm uppercase tracking-widest hover:brightness-110 transition-all\\\"\\n              >\\n                Next \\u2192\\n              </button>\\n            </div>\\n          )}\\n\\n          {/* Step: How it works */}\\n          {step === \\\"how\\\" && (\\n            <div className=\\\"space-y-4\\\">\\n              <h2 className=\\\"text-xl font-display font-bold tracking-tight\\\">\\n                How it works\\n              </h2>\\n              <div className=\\\"space-y-3\\\">\\n                {[\\n                  {\\n                    n: \\\"1\\\",\\n                    t: \\\"Read the script\\\",\\n                    d: \\\"The teleprompter scrolls at a steady pace. Your eyes stay on the lens marker.\\\",\\n                  },\\n                  {\\n                    n: \\\"2\\\",\\n                    t: \\\"Listen to the AI voice\\\",\\n                    d: \\\"Kokoro reads each sentence with perfect prosody. Your brain absorbs the pattern.\\\",\\n                  },\\n                  {\\n                    n: \\\"3\\\",\\n                    t: \\\"Speak along\\\",\\n                    d: \\\"Shadow the AI \\u2014 say the words as you hear them. Match the rhythm and timing.\\\",\\n                  },\\n                  {\\n                    n: \\\"4\\\",\\n                    t: \\\"See your score\\\",\\n                    d: \\\"The Score View shows pitch, stress, and timing for every word. Compare yours to the model.\\\",\\n                  },\\n                ].map((s) => (\\n                  <div key={s.n} className=\\\"flex gap-3\\\">\\n                    <div className=\\\"size-7 rounded border border-border grid place-items-center text-xs font-mono text-muted-foreground shrink-0\\\">\\n                      {s.n}\\n                    </div>\\n                    <div>\\n                      <p className=\\\"text-sm font-semibold\\\">{s.t}</p>\\n                      <p className=\\\"text-xs text-muted-foreground\\\">{s.d}</p>\\n                    </div>\\n                  </div>\\n                ))}\\n              </div>\\n              <button\\n                onClick={() => setStep(\\\"wpm\\\")}\\n                className=\\\"w-full bg-primary text-primary-foreground py-3 font-bold text-sm uppercase tracking-widest hover:brightness-110 transition-all\\\"\\n              >\\n                Next \\u2192\\n              </button>\\n            </div>\\n          )}\\n\\n          {/* Step: Personalize WPM */}\\n          {step === \\\"wpm\\\" && (\\n            <div className=\\\"space-y-4\\\">\\n              <h2 className=\\\"text-xl font-display font-bold tracking-tight\\\">\\n                Let's personalize your experience\\n              </h2>\\n\\n              <div>\\n                <label className=\\\"text-sm font-semibold block mb-2\\\">\\n                  What's your native language?\\n                </label>\\n                <div className=\\\"grid grid-cols-3 gap-2\\\">\\n                  {LANGUAGES.map((l) => (\\n                    <button\\n                      key={l.code}\\n                      onClick={() => setLanguage(l.code)}\\n                      className={`px-3 py-2 text-xs border rounded transition-colors ${\\n                        language === l.code\\n                          ? \\\"border-primary bg-primary/10 text-primary\\\"\\n                          : \\\"border-border text-muted-foreground hover:border-primary/30\\\"\\n                      }`}\\n                    >\\n                      {l.flag} {l.name}\\n                    </button>\\n                  ))}\\n                </div>\\n              </div>\\n\\n              <div>\\n                <label className=\\\"text-sm font-semibold block mb-2\\\">\\n                  What's your English level?\\n                </label>\\n                <div className=\\\"space-y-2\\\">\\n                  {LEVELS.map((l) => (\\n                    <button\\n                      key={l.id}\\n                      onClick={() => setLevel(l.id)}\\n                      className={`w-full text-left px-4 py-3 border rounded transition-colors ${\\n                        level === l.id\\n                          ? \\\"border-primary bg-primary/10\\\"\\n                          : \\\"border-border hover:border-primary/30\\\"\\n                      }`}\\n                    >\\n                      <span className=\\\"text-sm font-semibold\\\">{l.label}</span>\\n                      <p className=\\\"text-xs text-muted-foreground mt-0.5\\\">\\n                        {l.desc}\\n                      </p>\\n                    </button>\\n                  ))}\\n                </div>\\n              </div>\\n\\n              {level && (\\n                <div className=\\\"bg-primary/5 border border-primary/20 rounded p-4 text-sm\\\">\\n                  <p className=\\\"text-foreground font-semibold\\\">\\n                    Recommended starting pace: {WPM_MAP[level].start} WPM\\n                  </p>\\n                  <p className=\\\"text-muted-foreground text-xs mt-1\\\">\\n                    Target as you improve: {WPM_MAP[level].target} WPM\\n                  </p>\\n                </div>\\n              )}\\n\\n              <button\\n                onClick={finish}\\n                className=\\\"w-full bg-primary text-primary-foreground py-3 font-bold text-sm uppercase tracking-widest hover:brightness-110 transition-all\\\"\\n              >\\n                Start Training \\u2192\\n              </button>\\n            </div>\\n          )}\\n        </div>\\n\\n        {/* Skip link */}\\n        {step !== \\\"done\\\" && (\\n          <div className=\\\"px-8 pb-6 text-center\\\">\\n            <button\\n              onClick={finish}\\n              className=\\\"text-[10px] font-mono text-muted-foreground hover:text-foreground\\\"\\n            >\\n              Skip for now\\n            </button>\\n          </div>\\n        )}\\n      </div>\\n    </div>\\n  );\\n}\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\components\\\\OnboardingFlow.tsx\"}",
      "output": "Wrote file successfully.",
      "status": "success",
      "timestamp": 1781550706793
    },
    {
