      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\lib\\\\teleprompter\\\\syllabus-mirror.ts\", \"newString\": \"    } else if (engineId === \\\"web-speech\\\") {\\n      // Web Speech doesn't expose PCM, so estimate via WPM (~3.5 chars/word at 160wpm).\\n      const wordCount = sentence.text.split(/\\\\s+/).length;\\n      measuredMs = (wordCount / 160) * 60_000;\\n      // Build a silent placeholder buffer so timing still aligns; actual speech\\n      // playback uses speechSynthesis at play time.\\n      const ctx = this.ensureCtx();\\n      audioBuffer = ctx.createBuffer(1, Math.max(1, Math.floor((measuredMs / 1000) * ctx.sampleRate)), ctx.sampleRate);\\n    } else if (engineId === \\\"deepgram-aura\\\") {\\n      // Cloud inference via Cloudflare Workers AI.\\n      if (!this.cfAccountId || !this.cfApiToken) {\\n        this.engines[\\\"deepgram-aura\\\"].status = \\\"error\\\";\\n        this.engines[\\\"deepgram-aura\\\"].error = \\\"Cloudflare credentials not configured\\\";\\n        this.emit();\\n        return;\\n      }\\n      try {\\n        const url = `https://api.cloudflare.com/client/v4/accounts/${this.cfAccountId}/ai/run/@cf/deepgram/aura-1`;\\n        const resp = await fetch(url, {\\n          method: \\\"POST\\\",\\n          headers: {\\n            \\\"Authorization\\\": `Bearer ${this.cfApiToken}`,\\n            \\\"Content-Type\\\": \\\"application/json\\\",\\n          },\\n          body: JSON.stringify({\\n            text: sentence.text,\\n            voice: this.deepgramVoice,\\n          }),\\n        });\\n        if (!resp.ok) {\\n          const err = await resp.text();\\n          this.engines[\\\"deepgram-aura\\\"].status = \\\"error\\\";\\n          this.engines[\\\"deepgram-aura\\\"].error = `HTTP ${resp.status}: ${err}`;\\n          this.emit();\\n          return;\\n        }\\n        // Deepgram Aura returns raw audio bytes (PCM s16le).\\n        const arrayBuf = await resp.arrayBuffer();\\n        const int16 = new Int16Array(arrayBuf);\\n        const float32 = new Float32Array(int16.length);\\n        for (let i = 0; i < int16.length; i++) {\\n          float32[i] = int16[i] / 32768;\\n        }\\n        const sr = 24000; // Deepgram Aura outputs 24kHz\\n        measuredMs = (float32.length / sr) * 1000;\\n        const ctx = this.ensureCtx();\\n        audioBuffer = ctx.createBuffer(1, float32.length || 1, sr);\\n        audioBuffer.getChannelData(0).set(float32);\\n        pcmSamples = float32;\\n        pcmRate = sr;\\n      } catch (err) {\\n        this.engines[\\\"deepgram-aura\\\"].status = \\\"error\\\";\\n        this.engines[\\\"deepgram-aura\\\"].error = err instanceof Error ? err.message : String(err);\\n        this.emit();\\n        return;\\n      }\\n    }\", \"oldString\": \"    } else if (engineId === \\\"web-speech\\\") {\\n      // Web Speech doesn't expose PCM, so estimate via WPM (~3.5 chars/word at 160wpm).\\n      const wordCount = sentence.text.split(/\\\\s+/).length;\\n      measuredMs = (wordCount / 160) * 60_000;\\n      // Build a silent placeholder buffer so timing still aligns; actual speech\\n      // playback uses speechSynthesis at play time.\\n      const ctx = this.ensureCtx();\\n      audioBuffer = ctx.createBuffer(1, Math.max(1, Math.floor((measuredMs / 1000) * ctx.sampleRate)), ctx.sampleRate);\\n    }\"}",
