      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\routes\\\\teleprompter.tsx\"}",
      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\routes\\teleprompter.tsx</path>\n<type>file</type>\n<content>\n1: import { createFileRoute, Link } from \"@tanstack/react-router\";\n2: import { useCallback, useEffect, useMemo, useRef, useState } from \"react\";\n3: import {\n4:   type Token,\n5:   findTokenAtMs,\n6:   retime,\n7:   sentencesOf,\n8:   tokenize,\n9:   totalDurationMs,\n10:   mergeEdit,\n11: } from \"@/lib/teleprompter/tokens\";\n12: import { TranscriptStage } from \"@/components/teleprompter/TranscriptStage\";\n13: import { TranscriptEditor } from \"@/components/teleprompter/TranscriptEditor\";\n14: import { EngineStatus } from \"@/components/teleprompter/EngineStatus\";\n15: import { Coachmark } from \"@/components/teleprompter/Coachmark\";\n16: import { useSyllabusMirror } from \"@/lib/teleprompter/use-syllabus-mirror\";\n17: import {\n18:   Tooltip,\n19:   TooltipContent,\n20:   TooltipTrigger,\n21: } from \"@/components/ui/tooltip\";\n22: import type { EngineId } from \"@/lib/teleprompter/syllabus-mirror\";\n23: \n24: export const Route = createFileRoute(\"/teleprompter\")({\n25:   head: () => ({\n26:     meta: [\n27:       { title: \"Teleprompter · ProLector\" },\n28:       {\n29:         name: \"description\",\n30:         content:\n31:           \"Word-level scrub editor, WPM-locked pacing, and the SyllabusMirror hybrid TTS pipeline — Kokoro-82M routed live by CPU feedback.\",\n32:       },\n33:       { property: \"og:title\", content: \"ProLector Teleprompter\" },\n34:       {\n35:         property: \"og:description\",\n36:         content:\n37:           \"Click any word to scrub. SyllabusMirror routes sentences across Kokoro q8 / q4 / Web Speech using a sliding-window CPU feedback loop.\",\n38:       },\n39:     ],\n40:   }),\n41:   component: Teleprompter,\n42: });\n43: \n44: const DEFAULT_SCRIPT = `Welcome to ProLector. This is the SyllabusMirror engine operating at sub-ten-millisecond latency.\n45: \n46: Your training modules deserve broadcast-grade clarity, so position your eyes directly on the lens marker for perfect engagement.\n47: \n48: We deploy Gemma 4 locally. The model parses your text, injects pacing tags, and forwards every clean sentence to the Remotion frame-sequencer. Nothing leaves your machine.\n49: \n50: Press space to play or pause. Use the up and down arrows to nudge the pace. Press R to reset.`;\n51: \n52: const STORAGE_KEY = \"prolector.teleprompter.v2\";\n53: const LEGACY_KEY = \"prolector.teleprompter.v1\";\n54: \n55: type Settings = {\n56:   script: string;\n57:   wpm: number;\n58:   fontSize: number;\n59:   mirror: boolean;\n60: };\n61: \n62: const DEFAULTS: Settings = {\n63:   script: DEFAULT_SCRIPT,\n64:   wpm: 140,\n65:   fontSize: 52,\n66:   mirror: false,\n67: };\n68: \n69: function loadSettings(): Settings {\n70:   if (typeof window === \"undefined\") return DEFAULTS;\n71:   try {\n72:     const v2 = window.localStorage.getItem(STORAGE_KEY);\n73:     if (v2) return { ...DEFAULTS, ...JSON.parse(v2) };\n74:     const v1 = window.localStorage.getItem(LEGACY_KEY);\n75:     if (v1) {\n76:       // Migrate: v1 was a plain script string.\n77:       const migrated = { ...DEFAULTS, script: v1 };\n78:       window.localStorage.setItem(STORAGE_KEY, JSON.stringify(migrated));\n79:       window.localStorage.removeItem(LEGACY_KEY);\n80:       return migrated;\n81:     }\n82:     return DEFAULTS;\n83:   } catch {\n84:     return DEFAULTS;\n85:   }\n86: }\n87: \n88: function formatTimecode(ms: number) {\n89:   const totalSec = Math.floor(ms / 1000);\n90:   const h = String(Math.floor(totalSec / 3600)).padStart(2, \"0\");\n91:   const m = String(Math.floor((totalSec % 3600) / 60)).padStart(2, \"0\");\n92:   const s = String(totalSec % 60).padStart(2, \"0\");\n93:   const f = String(Math.floor(((ms % 1000) / 1000) * 30)).padStart(2, \"0\");\n94:   return `${h}:${m}:${s}:${f}`;\n95: }\n96: \n97: function Teleprompter() {\n98:   const [settings, setSettings] = useState<Settings>(DEFAULTS);\n99:   const [playing, setPlaying] = useState(false);\n100:   const [editorOpen, setEditorOpen] = useState(true);\n101:   const [currentMs, setCurrentMs] = useState(0);\n102:   const [tokens, setTokens] = useState<Token[]>(() => tokenize(DEFAULTS.script, DEFAULTS.wpm));\n103:   const rafRef = useRef<number | null>(null);\n104:   const lastTickRef = useRef<number | null>(null);\n105:   const [voice, setVoice] = useState(\"af_heart\");\n106: \n107:   // Loop selection\n108:   const [loopAnchor, setLoopAnchor] = useState<number | null>(null);\n109:   const [loopRange, setLoopRange] = useState<{ startMs: number; endMs: number } | null>(null);\n110:   const [loopArmed, setLoopArmed] = useState(false);\n111: \n112:   // hydrate from localStorage\n113:   useEffect(() => {\n114:     const loaded = loadSettings();\n115:     setSettings(loaded);\n116:     setTokens(tokenize(loaded.script, loaded.wpm));\n117:   }, []);\n118: \n119:   useEffect(() => {\n120:     if (typeof window === \"undefined\") return;\n121:     window.localStorage.setItem(STORAGE_KEY, JSON.stringify(settings));\n122:   }, [settings]);\n123: \n124:   const wordCount = useMemo(\n125:     () => settings.script.trim().split(/\\s+/).filter(Boolean).length,\n126:     [settings.script],\n127:   );\n128:   const estDurationSec = wordCount > 0 ? Math.round((wordCount / settings.wpm) * 60) : 0;\n129: \n130:   const sentences = useMemo(() => sentencesOf(tokens), [tokens]);\n131:   const totalMs = useMemo(() => totalDurationMs(tokens), [tokens]);\n132:   const currentToken = useMemo(() => findTokenAtMs(tokens, currentMs), [tokens, currentMs]);\n133: \n134:   // animation loop — advance currentMs in milliseconds\n135:   useEffect(() => {\n136:     if (!playing) {\n137:       if (rafRef.current) cancelAnimationFrame(rafRef.current);\n138:       rafRef.current = null;\n139:       lastTickRef.current = null;\n140:       return;\n141:     }\n142:     const tick = (now: number) => {\n143:       const last = lastTickRef.current ?? now;\n144:       const dt = now - last;\n145:       lastTickRef.current = now;\n146:       setCurrentMs((ms) => {\n147:         const next = ms + dt;\n148:         if (loopArmed && loopRange && next >= loopRange.endMs) {\n149:           return loopRange.startMs;\n150:         }\n151:         if (totalMs > 0 && next >= totalMs) {\n152:           setPlaying(false);\n153:           return totalMs;\n154:         }\n155:         return next;\n156:       });\n157:       rafRef.current = requestAnimationFrame(tick);\n158:     };\n159:     rafRef.current = requestAnimationFrame(tick);\n160:     return () => {\n161:       if (rafRef.current) cancelAnimationFrame(rafRef.current);\n162:     };\n163:   }, [playing, totalMs, loopArmed, loopRange]);\n164: \n165:   const reset = useCallback(() => {\n166:     setPlaying(false);\n167:     setCurrentMs(0);\n168:   }, []);\n169: \n170:   // Re-tokenise on script/WPM changes\n171:   useEffect(() => {\n172:     setTokens((prev) => {\n173:       const prevScript = prev\n174:         .map((t) => (t.isBreak ? \"\\n\\n\" : t.text))\n175:         .join(\" \")\n176:         .replace(/ \\n\\n /g, \"\\n\\n\")\n177:         .trim();\n178:       if (prevScript !== settings.script.trim()) {\n179:         // Diff-preserving merge: keep stable ids + measured timings where possible.\n180:         return mergeEdit(prev, settings.script, settings.wpm);\n181:       }\n182:       return retime(prev, settings.wpm);\n183:     });\n184:   }, [settings.script, settings.wpm]);\n185: \n186:   // SyllabusMirror orchestrator\n187:   const { orchestrator, snapshot } = useSyllabusMirror(\n188:     tokens,\n189:     sentences,\n190:     currentMs,\n191:     playing,\n192:     setTokens,\n193:   );\n194: \n195:   useEffect(() => {\n196:     orchestrator?.setVoice(voice);\n197:   }, [orchestrator, voice]);\n198: \n199:   // keyboard shortcuts\n200:   useEffect(() => {\n201:     const onKey = (e: KeyboardEvent) => {\n202:       const target = e.target as HTMLElement;\n203:       if (target && (target.tagName === \"TEXTAREA\" || target.tagName === \"INPUT\")) return;\n204:       if (e.code === \"Space\") {\n205:         e.preventDefault();\n206:         setPlaying((p) => !p);\n207:       } else if (e.key === \"r\" || e.key === \"R\") {\n208:         reset();\n209:       } else if (e.key === \"ArrowUp\") {\n210:         setSettings((s) => ({ ...s, wpm: Math.min(220, s.wpm + 5) }));\n211:       } else if (e.key === \"ArrowDown\") {\n212:         setSettings((s) => ({ ...s, wpm: Math.max(80, s.wpm - 5) }));\n213:       }\n214:     };\n215:     window.addEventListener(\"keydown\", onKey);\n216:     return () => window.removeEventListener(\"keydown\", onKey);\n217:   }, [reset]);\n218: \n219:   // Live voice mirror master toggle\n220:   const [voiceMirrorOn, setVoiceMirrorOn] = useState(false);\n221:   useEffect(() => {\n222:     if (!orchestrator) return;\n223:     orchestrator.setActive(voiceMirrorOn);\n224:     if (voiceMirrorOn) orchestrator.warmup().catch(() => undefined);\n225:   }, [orchestrator, voiceMirrorOn]);\n226: \n227:   const scrubToToken = useCallback(\n228:     (t: Token) => {\n229:       setCurrentMs(t.startMs);\n230:       orchestrator?.notifyScrub();\n231:     },\n232:     [orchestrator],\n233:   );\n234: \n235:   const handleScrubMs = useCallback(\n236:     (ms: number) => {\n237:       setCurrentMs(ms);\n238:       orchestrator?.notifyScrub();\n239:     },\n240:     [orchestrator],\n241:   );\n242: \n243:   const handleShiftClick = useCallback(\n244:     (t: Token) => {\n245:       if (loopAnchor == null) {\n246:         setLoopAnchor(t.startMs);\n247:       } else {\n248:         const a = loopAnchor;\n249:         const b = t.endMs;\n250:         const startMs = Math.min(a, b);\n251:         const endMs = Math.max(a, b);\n252:         setLoopRange({ startMs, endMs });\n253:         setLoopAnchor(null);\n254:       }\n255:     },\n256:     [loopAnchor],\n257:   );\n258: \n259:   const clearLoop = useCallback(() => {\n260:     setLoopRange(null);\n261:     setLoopAnchor(null);\n262:     setLoopArmed(false);\n263:   }, []);\n264: \n265:   const handleResynth = useCallback(\n266:     (sentenceId: string, engine: EngineId) => {\n267:       orchestrator?.resynthesize(sentenceId, engine);\n268:     },\n269:     [orchestrator],\n270:   );\n271: \n272:   return (\n273:     <div className=\"min-h-screen bg-background text-foreground flex flex-col\">\n274:       {/* Top bar */}\n275:       <div className=\"border-b border-border bg-background/90 backdrop-blur sticky top-0 z-40\">\n276:         <div className=\"max-w-7xl mx-auto px-6 h-14 flex items-center justify-between gap-4\">\n277:           <div className=\"flex items-center gap-6\">\n278:             <Link\n279:               to=\"/\"\n280:               className=\"font-display font-bold tracking-tighter text-lg uppercase italic\"\n281:             >\n282:               ← ProLector\n283:             </Link>\n284:             <span className=\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground hidden md:inline\">\n285:               Teleprompter · SyllabusMirror v1.4\n286:             </span>\n287:           </div>\n288:           <Tooltip>\n289:             <TooltipTrigger asChild>\n290:               <div className=\"flex items-center gap-2 font-mono text-[11px] uppercase tracking-widest cursor-help\">\n291:                 <span className={`size-2 rounded-full ${playing ? \"bg-destructive animate-pulse\" : \"bg-muted-foreground/40\"}`} />\n292:                 <span className={playing ? \"text-destructive\" : \"text-muted-foreground\"}>\n293:                   {playing ? \"REC\" : \"STBY\"} {formatTimecode(currentMs)}\n294:                 </span>\n295:               </div>\n296:             </TooltipTrigger>\n297:             <TooltipContent side=\"bottom\">\n298:               Recording state · SMPTE timecode of the playhead.\n299:             </TooltipContent>\n300:           </Tooltip>\n301:         </div>\n302:       </div>\n303: \n304:       {/* Controls */}\n305:       <div className=\"border-b border-border px-6 py-3\">\n306:         <div className=\"max-w-7xl mx-auto flex flex-wrap items-center gap-4 text-xs font-mono uppercase tracking-widest\">\n307:           <Tooltip>\n308:             <TooltipTrigger asChild>\n309:               <button\n310:                 onClick={() => setPlaying((p) => !p)}\n311:                 className=\"bg-primary text-primary-foreground px-5 py-2 font-bold hover:brightness-110 transition-all\"\n312:               >\n313:                 {playing ? \"■ Pause\" : \"▶ Play\"}\n314:               </button>\n315:             </TooltipTrigger>\n316:             <TooltipContent>Play or pause · Shortcut: Space</TooltipContent>\n317:           </Tooltip>\n318:           <Tooltip>\n319:             <TooltipTrigger asChild>\n320:               <button\n321:                 onClick={reset}\n322:                 className=\"border border-border px-4 py-2 hover:bg-foreground/5 transition-all\"\n323:               >\n324:                 Reset\n325:               </button>\n326:             </TooltipTrigger>\n327:             <TooltipContent>Jump back to 00:00:00:00 · Shortcut: R</TooltipContent>\n328:           </Tooltip>\n329: \n330:           <Tooltip>\n331:             <TooltipTrigger asChild>\n332:               <div className=\"flex items-center gap-2\">\n333:                 <label className=\"text-muted-foreground\">WPM</label>\n334:                 <input\n335:                   type=\"range\"\n336:                   min={80}\n337:                   max={220}\n338:                   value={settings.wpm}\n339:                   onChange={(e) => setSettings((s) => ({ ...s, wpm: Number(e.target.value) }))}\n340:                   className=\"accent-primary\"\n341:                 />\n342:                 <span className=\"w-10 text-right text-foreground\">{settings.wpm}</span>\n343:               </div>\n344:             </TooltipTrigger>\n345:             <TooltipContent>Words per minute · ↑ ↓ nudges ±5 · Rubric 120–160</TooltipContent>\n346:           </Tooltip>\n347: \n348:           <Tooltip>\n349:             <TooltipTrigger asChild>\n350:               <div className=\"flex items-center gap-2\">\n351:                 <label className=\"text-muted-foreground\">Size</label>\n352:                 <input\n353:                   type=\"range\"\n354:                   min={28}\n355:                   max={96}\n356:                   value={settings.fontSize}\n357:                   onChange={(e) => setSettings((s) => ({ ...s, fontSize: Number(e.target.value) }))}\n358:                   className=\"accent-primary\"\n359:                 />\n360:                 <span className=\"w-10 text-right text-foreground\">{settings.fontSize}px</span>\n361:               </div>\n362:             </TooltipTrigger>\n363:             <TooltipContent>Stage font size in pixels.</TooltipContent>\n364:           </Tooltip>\n365: \n366:           <Tooltip>\n367:             <TooltipTrigger asChild>\n368:               <label className=\"flex items-center gap-2 cursor-pointer select-none\">\n369:                 <input\n370:                   type=\"checkbox\"\n371:                   checked={settings.mirror}\n372:                   onChange={(e) => setSettings((s) => ({ ...s, mirror: e.target.checked }))}\n373:                   className=\"accent-primary\"\n374:                 />\n375:                 <span>Mirror</span>\n376:               </label>\n377:             </TooltipTrigger>\n378:             <TooltipContent>Flip horizontally for confidence-monitor glass.</TooltipContent>\n379:           </Tooltip>\n380: \n381:           <Tooltip>\n382:             <TooltipTrigger asChild>\n383:               <span\n384:                 className={`ml-auto px-2 py-1 border cursor-help ${\n385:                   settings.wpm >= 120 && settings.wpm <= 160\n386:                     ? \"border-primary/40 text-primary\"\n387:                     : \"border-border text-muted-foreground\"\n388:                 }`}\n389:               >\n390:                 {settings.wpm >= 120 && settings.wpm <= 160 ? \"Compliant\" : \"Out of rubric\"} · 120–160\n391:               </span>\n392:             </TooltipTrigger>\n393:             <TooltipContent>Green when 120 ≤ WPM ≤ 160 (broadcast rubric).</TooltipContent>\n394:           </Tooltip>\n395:           <span className=\"text-muted-foreground\">\n396:             {wordCount} words · ~{Math.floor(estDurationSec / 60)}:\n397:             {String(estDurationSec % 60).padStart(2, \"0\")}\n398:           </span>\n399: \n400:           <Tooltip>\n401:             <TooltipTrigger asChild>\n402:               <button\n403:                 onClick={() => setEditorOpen((o) => !o)}\n404:                 className=\"border border-border px-4 py-2 hover:bg-foreground/5 transition-all\"\n405:               >\n406:                 {editorOpen ? \"Hide Panel\" : \"Transcript Panel\"}\n407:               </button>\n408:             </TooltipTrigger>\n409:             <TooltipContent>Toggle the right-hand transcript + voice panel.</TooltipContent>\n410:           </Tooltip>\n411:         </div>\n412:       </div>\n413: \n414:       <div className={`flex-1 grid ${editorOpen ? \"lg:grid-cols-[1fr_400px]\" : \"grid-cols-1\"} min-h-0`}>\n415:         {/* Stage */}\n416:         <div className=\"relative\">\n417:           <TranscriptStage\n418:             tokens={tokens}\n419:             currentTokenId={currentToken?.id ?? null}\n420:             fontSize={settings.fontSize}\n421:             mirror={settings.mirror}\n422:             activeEngine={snapshot?.activeEngine ?? null}\n423:             loopRange={loopRange}\n424:             onTokenClick={scrubToToken}\n425:             onTokenShiftClick={handleShiftClick}\n426:             onResynth={handleResynth}\n427:           />\n428:           <Coachmark />\n429:         </div>\n430: \n431:         {/* Side panel */}\n432:         {editorOpen ? (\n433:           <aside className=\"border-l border-border bg-background flex flex-col min-h-0\">\n434:             <div className=\"p-4 flex-1 overflow-y-auto space-y-6\">\n435:               <TranscriptEditor\n436:                 tokens={tokens}\n437:                 currentTokenId={currentToken?.id ?? null}\n438:                 totalMs={totalMs}\n439:                 currentMs={currentMs}\n440:                 loopRange={loopRange}\n441:                 loopArmed={loopArmed}\n442:                 onScrubToToken={scrubToToken}\n443:                 onTokenShiftClick={handleShiftClick}\n444:                 onToggleLoop={() => setLoopArmed((v) => !v)}\n445:                 onClearLoop={clearLoop}\n446:                 onScriptChange={(script) => setSettings((s) => ({ ...s, script }))}\n447:                 onScrubMs={handleScrubMs}\n448:                 onResynth={handleResynth}\n449:               />\n450: \n451:               <section className=\"border-t border-border pt-6\">\n452:                 <div className=\"flex items-center justify-between mb-3\">\n453:                   <div className=\"text-[10px] font-mono uppercase tracking-widest text-primary\">\n454:                     SyllabusMirror · Voice Pipeline\n455:                   </div>\n456:                   <Tooltip>\n457:                     <TooltipTrigger asChild>\n458:                       <label className=\"flex items-center gap-2 text-[10px] font-mono uppercase tracking-widest cursor-pointer\">\n459:                         <input\n460:                           type=\"checkbox\"\n461:                           checked={voiceMirrorOn}\n462:                           onChange={(e) => setVoiceMirrorOn(e.target.checked)}\n463:                           className=\"accent-primary\"\n464:                         />\n465:                         Live\n466:                       </label>\n467:                     </TooltipTrigger>\n468:                     <TooltipContent side=\"left\">\n469:                       Stream audio while the prompter scrolls. Warms up Kokoro\n470:                       on first toggle.\n471:                     </TooltipContent>\n472:                   </Tooltip>\n473:                 </div>\n474:                 <p className=\"text-xs text-muted-foreground leading-relaxed mb-3\">\n475:                   Sliding 8-second window. Sentences are routed to Kokoro q8 (long /\n476:                   director), Kokoro q4 (short / latency-bound), or browser\n477:                   SpeechSynthesis (fallback) based on a live RTF feedback loop.\n478:                 </p>\n479: \n480:                 <label className=\"block text-[10px] font-mono uppercase tracking-widest text-muted-foreground mb-2\">\n481:                   Voice\n482:                 </label>\n483:                 <Tooltip>\n484:                   <TooltipTrigger asChild>\n485:                     <select\n486:                       value={voice}\n487:                       onChange={(e) => setVoice(e.target.value)}\n488:                       className=\"w-full bg-card border border-border p-2 text-sm mb-3\"\n489:                     >\n490:                   <option value=\"af_heart\">af_heart (female, warm)</option>\n491:                   <option value=\"af_bella\">af_bella (female, clear)</option>\n492:                   <option value=\"am_michael\">am_michael (male, narrator)</option>\n493:                   <option value=\"am_adam\">am_adam (male, deep)</option>\n494:                   <option value=\"bf_emma\">bf_emma (British female)</option>\n495:                   <option value=\"bm_george\">bm_george (British male)</option>\n496:                     </select>\n497:                   </TooltipTrigger>\n498:                   <TooltipContent side=\"left\">\n499:                     Kokoro voice id used for all sentences. Changing clears cache.\n500:                   </TooltipContent>\n501:                 </Tooltip>\n502: \n503:                 <EngineStatus\n504:                   snapshot={snapshot}\n505:                   onToggle={(id, en) => orchestrator?.setEngineEnabled(id, en)}\n506:                 />\n507:               </section>\n508: \n509:               <section className=\"border-t border-border pt-6\">\n510:                 <div className=\"text-[10px] font-mono uppercase tracking-widest text-primary mb-3\">\n511:                   Shortcuts\n512:                 </div>\n513:                 <ul className=\"space-y-2 text-xs font-mono text-muted-foreground\">\n514:                   <li><kbd className=\"text-foreground\">Space</kbd> · play / pause</li>\n515:                   <li><kbd className=\"text-foreground\">R</kbd> · reset</li>\n516:                   <li><kbd className=\"text-foreground\">↑ ↓</kbd> · ± 5 WPM</li>\n517:                   <li><kbd className=\"text-foreground\">click</kbd> · scrub to word</li>\n518:                   <li><kbd className=\"text-foreground\">shift+click</kbd> · set loop range</li>\n519:                   <li><kbd className=\"text-foreground\">right-click</kbd> · re-synth menu</li>\n520:                 </ul>\n521:               </section>\n522:             </div>\n523:           </aside>\n524:         ) : null}\n525:       </div>\n526:     </div>\n527:   );\n528: }\n\n(End of file - total 528 lines)\n</content>",
