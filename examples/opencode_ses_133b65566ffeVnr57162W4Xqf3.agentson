      "type": "action",
      "tool": "read",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\lib\\\\teleprompter\\\\syllabus-mirror.ts\", \"limit\": 30, \"offset\": 55}",
      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\lib\\teleprompter\\syllabus-mirror.ts</path>\n<type>file</type>\n<content>\n55: };\n56: \n57: export class SyllabusMirror extends EventTarget {\n58:   private engines: Record<EngineId, EngineState> = {\n59:     \"kokoro-q8\": { id: \"kokoro-q8\", status: \"idle\", lastRtf: null, emaRtf: null, enabled: true },\n60:     \"kokoro-q4\": { id: \"kokoro-q4\", status: \"idle\", lastRtf: null, emaRtf: null, enabled: true },\n61:     \"web-speech\": {\n62:       id: \"web-speech\",\n63:       status: typeof window !== \"undefined\" && \"speechSynthesis\" in window ? \"ready\" : \"idle\",\n64:       lastRtf: 0.05,\n65:       emaRtf: 0.05,\n66:       enabled: true,\n67:     },\n68:     \"f5-tts\": { id: \"f5-tts\", status: \"idle\", lastRtf: null, emaRtf: null, enabled: false },\n69:     \"chatterbox\": { id: \"chatterbox\", status: \"idle\", lastRtf: null, emaRtf: null, enabled: false },\n70:   };\n71: \n72:   private kokoroQ8: any = null;\n73:   private kokoroQ4: any = null;\n74:   private experimental: Partial<Record<EngineId, any>> = {};\n75:   private loadingPromise: Partial<Record<EngineId, Promise<void>>> = {};\n76: \n77:   private cache = new Map<string, CachedAudio>();\n78:   private cacheHits = 0;\n79:   private opfsAvailable =\n80:     typeof navigator !== \"undefined\" &&\n81:     typeof (navigator as any).storage?.getDirectory === \"function\";\n82:   private scheduling = new Set<string>();\n83:   private voice = \"af_heart\";\n84:   private lookaheadMs = DEFAULT_LOOKAHEAD;\n\n(Showing lines 55-84 of 548. Use offset=85 to continue.)\n</content>",
