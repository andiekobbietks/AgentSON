      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\routes\\index.tsx</path>\n<type>file</type>\n<content>\n1: import { createFileRoute } from \"@tanstack/react-router\";\n2: import { Link } from \"@tanstack/react-router\";\n3: import { SiteNav } from \"@/components/SiteNav\";\n4: import { SiteFooter } from \"@/components/SiteFooter\";\n5: \n6: export const Route = createFileRoute(\"/\")({\n7:   head: () => ({\n8:     meta: [\n9:       { title: \"ProLector — The Local-First Pro Workstation\" },\n10:       {\n11:         name: \"description\",\n12:         content:\n13:           \"Instrument-grade teleprompter & non-destructive video editing for professional educators. Local-first, offline-capable, zero-latency.\",\n14:       },\n15:       { property: \"og:title\", content: \"ProLector — Local-First Workstation for Educators\" },\n16:       {\n17:         property: \"og:description\",\n18:         content:\n19:           \"Voice cloning with F5-TTS & Kokoro-82M, Remotion EDL timelines, Git-for-Video collaboration. Runs in your browser.\",\n20:       },\n21:     ],\n22:   }),\n23:   component: Index,\n24: });\n25: \n26: const ttsModels = [\n27:   { name: \"F5-TTS\", arch: \"Flow Matching + DiT\", sample: \"3–10 s\", rtf: \"0.15 / 1.20\", license: \"Permissive\", strength: \"Zero pronunciation drift, breath sim\" },\n28:   { name: \"Chatterbox-Turbo\", arch: \"Acoustic Transf. + CFG\", sample: \"5 s\", rtf: \"0.10 / 0.90\", license: \"MIT\", strength: \"Inline paralinguistic tags\" },\n29:   { name: \"Pocket TTS\", arch: \"Quantized Codec\", sample: \"5 s\", rtf: \"0.10 / 0.40\", license: \"Open Source\", strength: \"Mobile + desktop CPU\" },\n30:   { name: \"Fish Speech 1.5\", arch: \"Dual Autoregressive\", sample: \"10–20 s\", rtf: \"0.30 / 2.50\", license: \"AGPL / Comm\", strength: \"Free-form emotion prompting\" },\n31:   { name: \"ChatTTS\", arch: \"Conversational Transf.\", sample: \"—\", rtf: \"0.20 / 1.10\", license: \"Open Source\", strength: \"Conversational ticks, laughter\" },\n32:   { name: \"XTTS v2\", arch: \"GPT-AR + VITS\", sample: \"6 s\", rtf: \"0.50 / 3.20\", license: \"CPML (Non-Comm)\", strength: \"17+ languages\" },\n33:   { name: \"Kokoro-82M\", arch: \"StyleTTS2 + Latent Diff\", sample: \"—\", rtf: \"0.05 / 0.05\", license: \"Apache 2.0\", strength: \"Sub-100ms on CPU, runs in browser\", highlighted: true },\n34: ];\n35: \n36: const pricingTiers = [\n37:   { name: \"Standard\", price: \"$4.20\", audience: \"Individual Educator\", features: [\"Local WebGPU ASR\", \"Kokoro-82M CPU Director\", \"Remotion Player\", \"Local WebM Export\"] },\n38:   { name: \"Plus\", price: \"$9.60\", audience: \"Active Course Creator\", features: [\"F5-TTS Vocal Mirror\", \"Oracle 23ai sync\", \"20 GB Object Storage\", \"Multi-scene timeline\"] },\n39:   { name: \"Pro\", price: \"$15.60\", audience: \"Production House\", features: [\"OCI Headless Render Farm\", \"Gemma-4 Multimodal\", \"Gemma-4 Script Refiner\", \"Priority weights\"], highlighted: true },\n40:   { name: \"Select\", price: \"$21.00\", audience: \"Enterprise Academy\", features: [\"Multi-seat repositories\", \"Git-for-Video merges\", \"Custom compliance\", \"SSO + Team Auth\"] },\n41: ];\n42: \n43: function Index() {\n44:   return (\n45:     <div className=\"min-h-screen bg-background text-foreground selection:bg-primary/30\">\n46:       <SiteNav />\n47: \n48:       {/* Hero */}\n49:       <header className=\"pt-24 pb-16 px-6 overflow-hidden\">\n50:         <div className=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\">\n51:           <div className=\"animate-fade-up\">\n52:             <div className=\"inline-flex items-center gap-2 px-2 py-1 rounded border border-primary/20 bg-primary/5 mb-6\">\n53:               <span className=\"size-1.5 rounded-full bg-primary animate-pulse\" />\n54:               <span className=\"text-[10px] font-mono uppercase tracking-tighter text-primary\">\n55:                 v2.0.0-GOLD · Enterprise Stable\n56:               </span>\n57:             </div>\n58:             <h1 className=\"text-5xl md:text-7xl font-display font-bold tracking-tight leading-[0.9] mb-6 text-balance\">\n59:               THE LOCAL-FIRST <br />\n60:               <span className=\"text-muted-foreground\">PRO WORKSTATION.</span>\n61:             </h1>\n62:             <p className=\"text-lg text-muted-foreground max-w-[45ch] mb-10 text-pretty\">\n63:               Instrument-grade video production for educators. No latency, no cloud dependencies,\n64:               pure performance architecture.\n65:             </p>\n66:             <div className=\"flex flex-wrap gap-4\">\n67:               <Link\n68:                 to=\"/teleprompter\"\n69:                 className=\"bg-primary text-primary-foreground px-8 py-4 text-sm font-bold uppercase tracking-widest rounded-sm hover:brightness-110 transition-all\"\n70:               >\n71:                 Try Teleprompter →\n72:               </Link>\n73:               <Link\n74:                 to=\"/studio\"\n75:                 className=\"border border-border px-8 py-4 text-sm font-bold uppercase tracking-widest rounded-sm hover:bg-foreground/5 transition-all\"\n76:               >\n77:                 Open Studio\n78:               </Link>\n79:             </div>\n80:           </div>\n81: \n82:           {/* Teleprompter mockup */}\n83:           <div className=\"relative animate-fade-up [animation-delay:200ms]\">\n84:             <div className=\"aspect-video bg-card border border-border rounded-lg overflow-hidden relative shadow-2xl ring-1 ring-foreground/10\">\n85:               <div className=\"absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-card z-10 pointer-events-none\" />\n86:               <div className=\"p-12 font-display text-3xl md:text-4xl font-bold tracking-tight leading-relaxed animate-scroll text-muted-foreground\">\n87:                 Welcome to ProLector. This is the SyllabusMirror engine operating at sub-10ms\n88:                 latency. Your training modules deserve broadcast-grade clarity. Position your eyes\n89:                 on the lens marker for perfect engagement. Welcome to ProLector. This is the\n90:                 SyllabusMirror engine operating at sub-10ms latency. Your training modules deserve\n91:                 broadcast-grade clarity.\n92:               </div>\n93:               <div className=\"absolute top-1/2 left-0 right-0 h-24 -translate-y-1/2 border-y border-primary/30 bg-primary/5 pointer-events-none z-20\" />\n94:               <div className=\"absolute top-4 left-4 flex items-center gap-2 z-30\">\n95:                 <div className=\"size-3 rounded-full bg-destructive/40 border border-destructive animate-pulse\" />\n96:                 <div className=\"text-[10px] font-mono text-destructive uppercase tracking-widest\">\n97:                   REC 00:04:21:09\n98:                 </div>\n99:               </div>\n100:             </div>\n101:           </div>\n102:         </div>\n103:       </header>\n104: \n105:       {/* TTS comparison */}\n106:       <section className=\"py-24 border-y border-border bg-foreground/[0.02]\">\n107:         <div className=\"max-w-7xl mx-auto px-6\">\n108:           <div className=\"flex flex-wrap items-end justify-between gap-4 mb-12\">\n109:             <h2 className=\"text-xs font-mono uppercase tracking-[0.3em] text-primary\">\n110:               SyllabusMirror · Voice-Clone Engine Catalogue\n111:             </h2>\n112:             <span className=\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground\">\n113:               RTF = Real-Time Factor (GPU / CPU)\n114:             </span>\n115:           </div>\n116:           <div className=\"overflow-x-auto\">\n117:             <table className=\"w-full text-left border-collapse\">\n118:               <thead>\n119:                 <tr className=\"border-b border-border\">\n120:                   <th className=\"py-4 pr-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">Model</th>\n121:                   <th className=\"py-4 pr-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">Architecture</th>\n122:                   <th className=\"py-4 pr-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">Sample</th>\n123:                   <th className=\"py-4 pr-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">RTF</th>\n124:                   <th className=\"py-4 pr-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">License</th>\n125:                   <th className=\"py-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">Core Strength</th>\n126:                 </tr>\n127:               </thead>\n128:               <tbody className=\"font-mono text-sm\">\n129:                 {ttsModels.map((m) => (\n130:                   <tr key={m.name} className=\"border-b border-border/50 hover:bg-foreground/5 transition-colors\">\n131:                     <td className={`py-5 pr-4 font-semibold ${m.highlighted ? \"text-primary\" : \"\"}`}>\n132:                       {m.name}\n133:                       {m.highlighted ? <span className=\"ml-2 text-[9px] uppercase tracking-widest\">Live in /teleprompter</span> : null}\n134:                     </td>\n135:                     <td className=\"py-5 pr-4 text-muted-foreground\">{m.arch}</td>\n136:                     <td className=\"py-5 pr-4 text-muted-foreground\">{m.sample}</td>\n137:                     <td className=\"py-5 pr-4\">{m.rtf}</td>\n138:                     <td className=\"py-5 pr-4 text-muted-foreground\">{m.license}</td>\n139:                     <td className=\"py-5 text-sm font-sans text-foreground/80\">{m.strength}</td>\n140:                   </tr>\n141:                 ))}\n142:               </tbody>\n143:             </table>\n144:           </div>\n145:         </div>\n146:       </section>\n147: \n148:       {/* Remotion EDL */}\n149:       <section className=\"py-32 px-6\">\n150:         <div className=\"max-w-7xl mx-auto\">\n151:           <div className=\"grid lg:grid-cols-12 gap-12 items-center\">\n152:             <div className=\"lg:col-span-5\">\n153:               <span className=\"text-xs font-mono uppercase tracking-[0.3em] text-primary mb-4 block\">\n154:                 ADR-001 · Remotion Kernel\n155:               </span>\n156:               <h3 className=\"text-3xl md:text-4xl font-display font-bold mb-6 tracking-tight\">\n157:                 Non-destructive editing as 2 KB JSON.\n158:               </h3>\n159:               <p className=\"text-muted-foreground mb-8 leading-relaxed\">\n160:                 ProLector represents every cut, split, and overlay as an Edit Decision List stored\n161:                 in Oracle 23ai. The browser queries a 2 KB JSON document — not a 500 MB MP4 —\n162:                 rendering the timeline frame-accurately with{\" \"}\n163:                 <code className=\"font-mono text-foreground\">@remotion/player</code>.\n164:               </p>\n165:               <div className=\"space-y-4 mb-8\">\n166:                 {[\n167:                   \"Offline-First PWA Storage (OPFS)\",\n168:                   \"Zero-Latency UI Thread\",\n169:                   \"Re-mux on export, never re-encode\",\n170:                   \"Frame-locked deterministic preview\",\n171:                 ].map((f, i) => (\n172:                   <div key={f} className=\"flex items-center gap-4\">\n173:                     <div className=\"size-8 rounded border border-border grid place-items-center text-xs font-mono text-muted-foreground\">\n174:                       {String(i + 1).padStart(2, \"0\")}\n175:                     </div>\n176:                     <span className=\"text-sm uppercase tracking-widest\">{f}</span>\n177:                   </div>\n178:                 ))}\n179:               </div>\n180:               <Link\n181:                 to=\"/studio\"\n182:                 className=\"inline-block border border-primary text-primary px-6 py-3 text-xs font-bold uppercase tracking-widest hover:bg-primary hover:text-primary-foreground transition-all\"\n183:               >\n184:                 Open Live Studio Demo →\n185:               </Link>\n186:             </div>\n187:             <div className=\"lg:col-span-7\">\n188:               <div className=\"aspect-[16/10] bg-card border border-border rounded-md shadow-inner p-6 font-mono text-xs leading-relaxed overflow-hidden\">\n189:                 <div className=\"text-muted-foreground mb-3\">// edl.json — 1,847 bytes</div>\n190:                 <pre className=\"text-foreground/90 whitespace-pre-wrap\">{`{\n191:   \"video_id\": \"chapter_01_video_01\",\n192:   \"video_source\": \"oci://raw_take_01.mp4\",\n193:   \"active_audio_timeline\": [\n194:     {\n195:       \"segment\": 1,\n196:       \"source_audio\": \"cloned_vocal_mirror.wav\",\n197:       \"start_ms\": 0,\n198:       \"end_ms\": 12400\n199:     },\n200:     {\n201:       \"segment\": 2,\n202:       \"source_audio\": \"cloned_vocal_mirror.wav\",\n203:       \"start_ms\": 15100,\n204:       \"end_ms\": 45000\n205:     }\n206:   ]\n207: }`}</pre>\n208:               </div>\n209:             </div>\n210:           </div>\n211:         </div>\n212:       </section>\n213: \n214:       {/* PWA capabilities */}\n215:       <section className=\"py-24 px-6 border-y border-border bg-foreground/[0.02]\">\n216:         <div className=\"max-w-7xl mx-auto\">\n217:           <div className=\"grid md:grid-cols-3 gap-6\">\n218:             {[\n219:               { tag: \"ADR-009\", title: \"Service Worker Offline Routing\", body: \"Intercepts /v1/chat and routes transparently to localhost:8888 Unsloth when offline.\" },\n220:               { tag: \"ADR-010\", title: \"Origin Private File System\", body: \"Raw VideoFrame chunks stream to OPFS via FileSystemWritableFileStream — RAM stays under 64 MB.\" },\n221:               { tag: \"ADR-008\", title: \"PWA over Electron\", body: \"Zero install, zero commission. macOS, Windows, Linux, ChromeOS — installed from a URL.\" },\n222:             ].map((c) => (\n223:               <div key={c.tag} className=\"border border-border p-8 rounded-sm bg-background\">\n224:                 <span className=\"text-[10px] font-mono uppercase tracking-widest text-primary\">{c.tag}</span>\n225:                 <h4 className=\"font-display font-bold text-xl mt-3 mb-3\">{c.title}</h4>\n226:                 <p className=\"text-sm text-muted-foreground leading-relaxed\">{c.body}</p>\n227:               </div>\n228:             ))}\n229:           </div>\n230:         </div>\n231:       </section>\n232: \n233:       {/* Pricing */}\n234:       <section className=\"py-32 px-6\">\n235:         <div className=\"max-w-7xl mx-auto\">\n236:           <div className=\"mb-16 text-center\">\n237:             <span className=\"text-xs font-mono uppercase tracking-[0.3em] text-primary\">SaaS Tiering</span>\n238:             <h2 className=\"text-4xl md:text-5xl font-display font-bold mt-4 mb-4 tracking-tighter\">LICENSING</h2>\n239:             <p className=\"text-muted-foreground font-mono text-xs uppercase tracking-widest\">\n240:               Monthly operating commitment · Local-first hosting structures\n241:             </p>\n242:           </div>\n243:           <div className=\"grid sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n244:             {pricingTiers.map((t) => (\n245:               <div\n246:                 key={t.name}\n247:                 className={`border p-8 rounded-sm relative transition-colors ${\n248:                   t.highlighted\n249:                     ? \"border-2 border-primary bg-primary/5\"\n250:                     : \"border-border hover:border-muted-foreground\"\n251:                 }`}\n252:               >\n253:                 {t.highlighted ? (\n254:                   <div className=\"absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-primary-foreground text-[10px] font-bold px-3 py-1 uppercase tracking-widest\">\n255:                     Recommended\n256:                   </div>\n257:                 ) : null}\n258:                 <h4\n259:                   className={`text-xs font-mono uppercase tracking-widest mb-1 ${\n260:                     t.highlighted ? \"text-primary\" : \"text-muted-foreground\"\n261:                   }`}\n262:                 >\n263:                   {t.name}\n264:                 </h4>\n265:                 <p className=\"text-[10px] font-mono uppercase text-muted-foreground/70 tracking-wider mb-6\">\n266:                   {t.audience}\n267:                 </p>\n268:                 <div className=\"text-4xl font-display font-bold mb-8\">\n269:                   {t.price}\n270:                   <span className=\"text-sm font-mono text-muted-foreground\">/mo</span>\n271:                 </div>\n272:                 <ul className=\"space-y-3 text-xs font-medium text-muted-foreground mb-12\">\n273:                   {t.features.map((f) => (\n274:                     <li key={f} className=\"flex gap-2\">\n275:                       <span className=\"text-primary\">→</span>\n276:                       <span>{f}</span>\n277:                     </li>\n278:                   ))}\n279:                 </ul>\n280:                 <button\n281:                   className={`w-full py-3 text-[10px] font-bold uppercase tracking-widest transition-all ${\n282:                     t.highlighted\n283:                       ? \"bg-primary text-primary-foreground hover:brightness-110\"\n284:                       : \"border border-border hover:bg-foreground/5\"\n285:                   }`}\n286:                 >\n287:                   Select\n288:                 </button>\n289:               </div>\n290:             ))}\n291:           </div>\n292:         </div>\n293:       </section>\n294: \n295:       <SiteFooter />\n296:     </div>\n297:   );\n298: }\n\n(End of file - total 298 lines)\n</content>",
