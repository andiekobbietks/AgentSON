      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\routes\\\\index.tsx\", \"newString\": \"      {/* Hero */}\\n      <header className=\\\"pt-24 pb-16 px-6 overflow-hidden\\\">\\n        <div className=\\\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\\\">\\n          <div className=\\\"animate-fade-up\\\">\\n            <div className=\\\"inline-flex items-center gap-2 px-2 py-1 rounded border border-primary/20 bg-primary/5 mb-6\\\">\\n              <span className=\\\"size-1.5 rounded-full bg-primary animate-pulse\\\" />\\n              <span className=\\\"text-[10px] font-mono uppercase tracking-tighter text-primary\\\">\\n                v2.0.0-GOLD \\u00b7 Enterprise Stable\\n              </span>\\n            </div>\\n            <h1 className=\\\"text-5xl md:text-7xl font-display font-bold tracking-tight leading-[0.9] mb-6 text-balance\\\">\\n              THE LOCAL-FIRST <br />\\n              <span className=\\\"text-muted-foreground\\\">PRO WORKSTATION.</span>\\n            </h1>\\n            <p className=\\\"text-lg text-muted-foreground max-w-[45ch] mb-10 text-pretty\\\">\\n              Train your voice. Polish your delivery. Ship broadcast-grade\\n              content \\u2014 all from your browser, nothing leaving your machine.\\n            </p>\", \"oldString\": \"      {/* Hero */}\\n      <header className=\\\"pt-24 pb-16 px-6 overflow-hidden\\\">\\n        <div className=\\\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\\\">\\n          <div className=\\\"animate-fade-up\\\">\\n            <div className=\\\"inline-flex items-center gap-2 px-2 py-1 rounded border border-primary/20 bg-primary/5 mb-6\\\">\\n              <span className=\\\"size-1.5 rounded-full bg-primary animate-pulse\\\" />\\n              <span className=\\\"text-[10px] font-mono uppercase tracking-tighter text-primary\\\">\\n                v2.0.0-GOLD \\u00b7 Enterprise Stable\\n              </span>\\n            </div>\\n            <h1 className=\\\"text-5xl md:text-7xl font-display font-bold tracking-tight leading-[0.9] mb-6 text-balance\\\">\\n              THE LOCAL-FIRST <br />\\n              <span className=\\\"text-muted-foreground\\\">PRO WORKSTATION.</span>\\n            </h1>\\n            <p className=\\\"text-lg text-muted-foreground max-w-[45ch] mb-10 text-pretty\\\">\\n              Instrument-grade video production for educators. No latency, no cloud dependencies,\\n              pure performance architecture.\\n            </p>\"}",
