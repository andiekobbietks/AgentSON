      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\lib\\teleprompter\\tokens.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * Shared token model used by the transcript editor, the teleprompter stage,\n3:  * and the SyllabusMirror orchestrator. A Token is a single word (with its\n4:  * trailing punctuation) or a paragraph break (\"\\n\\n\"). Timestamps start as\n5:  * WPM-derived estimates and may be refined later by the TTS engine.\n6:  */\n7: export type TokenStatus = \"pending\" | \"scheduled\" | \"synthesized\" | \"spoken\";\n8: \n9: export type Token = {\n10:   id: string;\n11:   text: string;\n12:   isBreak: boolean;\n13:   startMs: number;\n14:   endMs: number;\n15:   sentenceId: string;\n16:   status: TokenStatus;\n17: };\n18: \n19: export type Sentence = {\n20:   id: string;\n21:   tokenIds: string[];\n22:   text: string;\n23:   startMs: number;\n24:   endMs: number;\n25: };\n26: \n27: function makeId(seed: number) {\n28:   return `t${seed.toString(36)}`;\n29: }\n30: \n31: /** Tokenise a raw script into Tokens with WPM-derived timestamps. */\n32: export function tokenize(script: string, wpm: number): Token[] {\n33:   const msPerWord = (60_000 / Math.max(40, wpm));\n34:   const tokens: Token[] = [];\n35:   let cursor = 0;\n36:   let sentenceIdx = 0;\n37:   let sentenceId = `s${sentenceIdx}`;\n38:   let i = 0;\n39: \n40:   // Split into paragraphs first so \"\\n\\n\" becomes a hard break.\n41:   const paragraphs = script.split(/\\n{2,}/);\n42:   paragraphs.forEach((para, pIdx) => {\n43:     // Within paragraph: split sentences on .?! followed by whitespace.\n44:     const parts = para.split(/(?<=[.?!])\\s+/);\n45:     parts.forEach((sentenceText) => {\n46:       const trimmed = sentenceText.trim();\n47:       if (!trimmed) return;\n48:       sentenceId = `s${sentenceIdx++}`;\n49:       const words = trimmed.split(/\\s+/);\n50:       words.forEach((w) => {\n51:         const start = cursor;\n52:         const end = cursor + msPerWord;\n53:         tokens.push({\n54:           id: makeId(i++),\n55:           text: w,\n56:           isBreak: false,\n57:           startMs: start,\n58:           endMs: end,\n59:           sentenceId,\n60:           status: \"pending\",\n61:         });\n62:         cursor = end;\n63:       });\n64:     });\n65:     if (pIdx < paragraphs.length - 1) {\n66:       tokens.push({\n67:         id: makeId(i++),\n68:         text: \"\\n\\n\",\n69:         isBreak: true,\n70:         startMs: cursor,\n71:         endMs: cursor + msPerWord * 0.5,\n72:         sentenceId: `break-${pIdx}`,\n73:         status: \"pending\",\n74:       });\n75:       cursor += msPerWord * 0.5;\n76:     }\n77:   });\n78: \n79:   return tokens;\n80: }\n81: \n82: /** Re-estimate timestamps from a new WPM, preserving non-pending refinements. */\n83: export function retime(tokens: Token[], wpm: number): Token[] {\n84:   const msPerWord = 60_000 / Math.max(40, wpm);\n85:   let cursor = 0;\n86:   return tokens.map((t) => {\n87:     if (t.status === \"synthesized\" || t.status === \"spoken\") {\n88:       // Keep refined timing but rebase relative to cursor.\n89:       const dur = t.endMs - t.startMs;\n90:       const out = { ...t, startMs: cursor, endMs: cursor + dur };\n91:       cursor += dur;\n92:       return out;\n93:     }\n94:     const dur = t.isBreak ? msPerWord * 0.5 : msPerWord;\n95:     const out = { ...t, startMs: cursor, endMs: cursor + dur };\n96:     cursor += dur;\n97:     return out;\n98:   });\n99: }\n100: \n101: /** Binary search the token containing the given currentMs. */\n102: export function findTokenAtMs(tokens: Token[], ms: number): Token | null {\n103:   if (!tokens.length) return null;\n104:   let lo = 0;\n105:   let hi = tokens.length - 1;\n106:   while (lo <= hi) {\n107:     const mid = (lo + hi) >> 1;\n108:     const t = tokens[mid];\n109:     if (ms < t.startMs) hi = mid - 1;\n110:     else if (ms >= t.endMs) lo = mid + 1;\n111:     else return t;\n112:   }\n113:   return tokens[Math.min(lo, tokens.length - 1)];\n114: }\n115: \n116: /** Group tokens into Sentences (drops breaks). */\n117: export function sentencesOf(tokens: Token[]): Sentence[] {\n118:   const map = new Map<string, Sentence>();\n119:   for (const t of tokens) {\n120:     if (t.isBreak) continue;\n121:     let s = map.get(t.sentenceId);\n122:     if (!s) {\n123:       s = {\n124:         id: t.sentenceId,\n125:         tokenIds: [],\n126:         text: \"\",\n127:         startMs: t.startMs,\n128:         endMs: t.endMs,\n129:       };\n130:       map.set(t.sentenceId, s);\n131:     }\n132:     s.tokenIds.push(t.id);\n133:     s.text = s.text ? `${s.text} ${t.text}` : t.text;\n134:     s.endMs = t.endMs;\n135:   }\n136:   return Array.from(map.values());\n137: }\n138: \n139: export function totalDurationMs(tokens: Token[]): number {\n140:   return tokens.length ? tokens[tokens.length - 1].endMs : 0;\n141: }\n142: \n143: /** Flip every token in a sentence to `scheduled` (unless further along). */\n144: export function markScheduled(tokens: Token[], sentenceId: string): Token[] {\n145:   let changed = false;\n146:   const next = tokens.map((t) => {\n147:     if (t.sentenceId !== sentenceId) return t;\n148:     if (t.status === \"pending\") {\n149:       changed = true;\n150:       return { ...t, status: \"scheduled\" as TokenStatus };\n151:     }\n152:     return t;\n153:   });\n154:   return changed ? next : tokens;\n155: }\n156: \n157: /** Mark every token whose end is before `throughMs` as spoken. */\n158: export function markSpoken(tokens: Token[], throughMs: number): Token[] {\n159:   let changed = false;\n160:   const next = tokens.map((t) => {\n161:     if (t.isBreak) return t;\n162:     if (t.endMs <= throughMs && t.status !== \"spoken\") {\n163:       changed = true;\n164:       return { ...t, status: \"spoken\" as TokenStatus };\n165:     }\n166:     return t;\n167:   });\n168:   return changed ? next : tokens;\n169: }\n170: \n171: /**\n172:  * Diff-aware re-tokenise: greedy word match against existing tokens so that\n173:  * stable ids (and refined timings) survive small edits. New words get fresh\n174:  * pending tokens; deleted ones are dropped.\n175:  */\n176: export function mergeEdit(prev: Token[], script: string, wpm: number): Token[] {\n177:   const fresh = tokenize(script, wpm);\n178:   const used = new Set<number>();\n179:   const out: Token[] = [];\n180:   let searchFrom = 0;\n181:   for (const f of fresh) {\n182:     if (f.isBreak) {\n183:       out.push(f);\n184:       continue;\n185:     }\n186:     let matchIdx = -1;\n187:     for (let i = searchFrom; i < prev.length; i++) {\n188:       if (used.has(i)) continue;\n189:       const p = prev[i];\n190:       if (!p.isBreak && p.text === f.text) {\n191:         matchIdx = i;\n192:         break;\n193:       }\n194:     }\n195:     if (matchIdx >= 0) {\n196:       used.add(matchIdx);\n197:       searchFrom = matchIdx + 1;\n198:       const p = prev[matchIdx];\n199:       out.push({\n200:         ...f,\n201:         id: p.id,\n202:         status: p.status,\n203:         // Keep refined duration if it was measured.\n204:         ...(p.status === \"synthesized\" || p.status === \"spoken\"\n205:           ? { endMs: f.startMs + (p.endMs - p.startMs) }\n206:           : {}),\n207:       });\n208:     } else {\n209:       out.push(f);\n210:     }\n211:   }\n212:   // Re-flow timestamps sequentially so durations chain correctly.\n213:   let cursor = 0;\n214:   return out.map((t) => {\n215:     const dur = t.endMs - t.startMs;\n216:     const r = { ...t, startMs: cursor, endMs: cursor + dur };\n217:     cursor += dur;\n218:     return r;\n219:   });\n220: }\n221: \n222: /** Apply Kokoro-measured audio duration to all tokens in a sentence,\n223:  *  proportionally to their word lengths, and ripple subsequent tokens. */\n224: export function applySentenceDuration(\n225:   tokens: Token[],\n226:   sentenceId: string,\n227:   measuredMs: number,\n228:   status: TokenStatus = \"synthesized\",\n229: ): Token[] {\n230:   const sentenceTokens = tokens.filter((t) => t.sentenceId === sentenceId && !t.isBreak);\n231:   if (!sentenceTokens.length) return tokens;\n232:   const totalChars = sentenceTokens.reduce((n, t) => n + Math.max(1, t.text.length), 0);\n233:   const firstStart = sentenceTokens[0].startMs;\n234:   const newEnd = firstStart + measuredMs;\n235:   const oldEnd = sentenceTokens[sentenceTokens.length - 1].endMs;\n236:   const delta = newEnd - oldEnd;\n237: \n238:   let cursor = firstStart;\n239:   const newDurations = new Map<string, { s: number; e: number }>();\n240:   for (const t of sentenceTokens) {\n241:     const share = Math.max(1, t.text.length) / totalChars;\n242:     const dur = measuredMs * share;\n243:     newDurations.set(t.id, { s: cursor, e: cursor + dur });\n244:     cursor += dur;\n245:   }\n246: \n247:   return tokens.map((t) => {\n248:     const nd = newDurations.get(t.id);\n249:     if (nd) return { ...t, startMs: nd.s, endMs: nd.e, status };\n250:     if (t.startMs >= oldEnd) {\n251:       return { ...t, startMs: t.startMs + delta, endMs: t.endMs + delta };\n252:     }\n253:     return t;\n254:   });\n255: }\n\n(End of file - total 255 lines)\n</content>",
