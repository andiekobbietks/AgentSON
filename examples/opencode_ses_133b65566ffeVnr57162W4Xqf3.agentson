      "output": "<path>C:\\Users\\LLM-Test\\Documents\\cognitive-taxonomy-vscode-ext\\package.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"name\": \"cognitive-taxonomy-protocol\",\n3:   \"displayName\": \"Cognitive Taxonomy Protocol\",\n4:   \"description\": \"Five-colour architectural taxonomy with hover tooltips. Shifts code comprehension from System 2 (linear reading) to System 1 (pattern recognition).\",\n5:   \"version\": \"0.0.1\",\n6:   \"engines\": { \"vscode\": \"^1.85.0\" },\n7:   \"categories\": [\"Programming Languages\", \"Visualization\", \"Education\"],\n8:   \"activationEvents\": [\"onLanguage:python\"],\n9:   \"main\": \"./out/extension.js\",\n10:   \"contributes\": {\n11:     \"commands\": [\n12:       {\n13:         \"command\": \"cognitiveTaxonomy.toggle\",\n14:         \"title\": \"Cognitive Taxonomy: Toggle View\"\n15:       },\n16:       {\n17:         \"command\": \"cognitiveTaxonomy.showMetrics\",\n18:         \"title\": \"Cognitive Taxonomy: Show Metrics\"\n19:       },\n20:       {\n21:         \"command\": \"cognitiveTaxonomy.refreshSidebar\",\n22:         \"title\": \"Cognitive Taxonomy: Refresh Sidebar\"\n23:       },\n24:       {\n25:         \"command\": \"cognitiveTaxonomy.toggleDataFlow\",\n26:         \"title\": \"Cognitive Taxonomy: Toggle Data Flow View\"\n27:       }\n28:     ],\n29:     \"keybindings\": [\n30:       {\n31:         \"command\": \"cognitiveTaxonomy.toggle\",\n32:         \"key\": \"ctrl+shift+t\",\n33:         \"mac\": \"cmd+shift+t\"\n34:       },\n35:       {\n36:         \"command\": \"cognitiveTaxonomy.toggleDataFlow\",\n37:         \"key\": \"ctrl+shift+f\",\n38:         \"mac\": \"cmd+shift+f\"\n39:       }\n40:     ],\n41:     \"viewsContainers\": {\n42:       \"activitybar\": [\n43:         {\n44:           \"id\": \"cognitiveTaxonomy\",\n45:           \"title\": \"Cognitive Taxonomy\",\n46:           \"icon\": \"$(graph)\"\n47:         }\n48:       ]\n49:     },\n50:     \"views\": {\n51:       \"cognitiveTaxonomy\": [\n52:         {\n53:           \"type\": \"webview\",\n54:           \"id\": \"cognitiveTaxonomy.sidebar\",\n55:           \"name\": \"Taxonomy Overview\"\n56:         }\n57:       ]\n58:     },\n59:     \"configuration\": {\n60:       \"title\": \"Cognitive Taxonomy Protocol\",\n61:       \"properties\": {\n62:         \"cognitiveTaxonomy.enabled\": {\n63:           \"type\": \"boolean\",\n64:           \"default\": false,\n65:           \"description\": \"Enable taxonomy line colouring and hover tooltips.\"\n66:         },\n67:         \"cognitiveTaxonomy.showTooltips\": {\n68:           \"type\": \"boolean\",\n69:           \"default\": true,\n70:           \"description\": \"Show architectural tooltips on hover.\"\n71:         },\n72:         \"cognitiveTaxonomy.showBadges\": {\n73:           \"type\": \"boolean\",\n74:           \"default\": true,\n75:           \"description\": \"Show inline category badges at end of lines.\"\n76:         }\n77:       }\n78:     },\n79:     \"languages\": [\n80:       {\n81:         \"id\": \"python\",\n82:         \"aliases\": [\"Python\"],\n83:         \"extensions\": [\".py\", \".pyw\"]\n84:       }\n85:     ]\n86:   },\n87:   \"scripts\": {\n88:     \"vscode:prepublish\": \"npm run compile\",\n89:     \"compile\": \"tsc -p ./\",\n90:     \"watch\": \"tsc -watch -p ./\"\n91:   },\n92:   \"devDependencies\": {\n93:     \"@types/vscode\": \"^1.85.0\",\n94:     \"@types/node\": \"^20.0.0\",\n95:     \"typescript\": \"^5.3.0\"\n96:   }\n97: }\n\n(End of file - total 97 lines)\n</content>",
