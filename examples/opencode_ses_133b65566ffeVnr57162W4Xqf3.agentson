      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\components\\teleprompter\\TranscriptStage.tsx</path>\n<type>file</type>\n<content>\n1: import { useEffect, useRef } from \"react\";\n2: import type { Token } from \"@/lib/teleprompter/tokens\";\n3: import type { EngineId } from \"@/lib/teleprompter/syllabus-mirror\";\n4: import {\n5:   ContextMenu,\n6:   ContextMenuContent,\n7:   ContextMenuItem,\n8:   ContextMenuSeparator,\n9:   ContextMenuTrigger,\n10: } from \"@/components/ui/context-menu\";\n11: import { Tooltip, TooltipContent, TooltipTrigger } from \"@/components/ui/tooltip\";\n12: \n13: type Props = {\n14:   tokens: Token[];\n15:   currentTokenId: string | null;\n16:   fontSize: number;\n17:   mirror: boolean;\n18:   activeEngine: EngineId | null;\n19:   loopRange: { startMs: number; endMs: number } | null;\n20:   onTokenClick: (token: Token) => void;\n21:   onTokenShiftClick?: (token: Token) => void;\n22:   onResynth?: (sentenceId: string, engine: EngineId) => void;\n23: };\n24: \n25: /** Full-screen scrolling stage. Renders each token as a span so the playhead\n26:  *  can centre the active token via scrollIntoView. */\n27: export function TranscriptStage({\n28:   tokens,\n29:   currentTokenId,\n30:   fontSize,\n31:   mirror,\n32:   activeEngine,\n33:   loopRange,\n34:   onTokenClick,\n35:   onTokenShiftClick,\n36:   onResynth,\n37: }: Props) {\n38:   const scrollerRef = useRef<HTMLDivElement | null>(null);\n39:   const activeRef = useRef<HTMLSpanElement | null>(null);\n40:   const lastIdRef = useRef<string | null>(null);\n41: \n42:   useEffect(() => {\n43:     if (!currentTokenId || lastIdRef.current === currentTokenId) return;\n44:     lastIdRef.current = currentTokenId;\n45:     const el = activeRef.current;\n46:     if (el) el.scrollIntoView({ block: \"center\", behavior: \"smooth\" });\n47:   }, [currentTokenId]);\n48: \n49:   const lensColor =\n50:     activeEngine === \"kokoro-q8\"\n51:       ? \"border-primary\"\n52:       : activeEngine === \"kokoro-q4\"\n53:         ? \"border-primary/60\"\n54:         : activeEngine === \"web-speech\"\n55:           ? \"border-muted-foreground\"\n56:           : activeEngine === \"f5-tts\" || activeEngine === \"chatterbox\"\n57:             ? \"border-yellow-500\"\n58:             : \"border-primary/30\";\n59: \n60:   // Group tokens by sentence so we can wrap each sentence in a context menu.\n61:   const sentenceGroups: { id: string; tokens: Token[] }[] = [];\n62:   let cur: { id: string; tokens: Token[] } | null = null;\n63:   for (const t of tokens) {\n64:     if (t.isBreak) {\n65:       if (cur) sentenceGroups.push(cur);\n66:       cur = null;\n67:       sentenceGroups.push({ id: t.id, tokens: [t] });\n68:       continue;\n69:     }\n70:     if (!cur || cur.id !== t.sentenceId) {\n71:       if (cur) sentenceGroups.push(cur);\n72:       cur = { id: t.sentenceId, tokens: [] };\n73:     }\n74:     cur.tokens.push(t);\n75:   }\n76:   if (cur) sentenceGroups.push(cur);\n77: \n78:   const renderToken = (t: Token) => {\n79:     if (t.isBreak)\n80:       return (\n81:         <span key={t.id} style={{ display: \"block\", height: \"1.2em\" }} />\n82:       );\n83:     const active = t.id === currentTokenId;\n84:     const inLoop =\n85:       loopRange && t.startMs >= loopRange.startMs && t.endMs <= loopRange.endMs;\n86:     return (\n87:       <span\n88:         key={t.id}\n89:         ref={active ? activeRef : undefined}\n90:         onClick={(e) => (e.shiftKey ? onTokenShiftClick?.(t) : onTokenClick(t))}\n91:         className={`cursor-pointer rounded-sm transition-colors ${\n92:           active\n93:             ? \"bg-primary/25 text-primary\"\n94:             : t.status === \"spoken\"\n95:               ? \"text-muted-foreground\"\n96:               : \"text-foreground hover:bg-primary/10\"\n97:         } ${inLoop ? \"underline decoration-primary/60 decoration-2 underline-offset-4\" : \"\"}`}\n98:         style={{ padding: \"0 0.05em\" }}\n99:       >\n100:         {t.text}{\" \"}\n101:       </span>\n102:     );\n103:   };\n104: \n105:   return (\n106:     <div className=\"relative bg-card overflow-hidden h-full\">\n107:       <div\n108:         ref={scrollerRef}\n109:         className=\"absolute inset-0 overflow-y-auto scrollbar-none\"\n110:         style={{ scrollbarWidth: \"none\" }}\n111:       >\n112:         <div\n113:           className=\"font-display font-bold tracking-tight text-foreground px-12 md:px-24\"\n114:           style={{\n115:             fontSize,\n116:             lineHeight: 1.5,\n117:             paddingTop: \"50vh\",\n118:             paddingBottom: \"60vh\",\n119:             transform: mirror ? \"scaleX(-1)\" : undefined,\n120:           }}\n121:         >\n122:           {sentenceGroups.map((g) => {\n123:             if (g.tokens.length === 1 && g.tokens[0].isBreak) {\n124:               return renderToken(g.tokens[0]);\n125:             }\n126:             return (\n127:               <ContextMenu key={g.id}>\n128:                 <ContextMenuTrigger asChild>\n129:                   <span>{g.tokens.map(renderToken)}</span>\n130:                 </ContextMenuTrigger>\n131:                 <ContextMenuContent className=\"font-mono text-xs\">\n132:                   <ContextMenuItem onSelect={() => onResynth?.(g.id, \"kokoro-q8\")}>\n133:                     Re-synth · Kokoro q8\n134:                   </ContextMenuItem>\n135:                   <ContextMenuItem onSelect={() => onResynth?.(g.id, \"kokoro-q4\")}>\n136:                     Re-synth · Kokoro q4\n137:                   </ContextMenuItem>\n138:                   <ContextMenuItem onSelect={() => onResynth?.(g.id, \"web-speech\")}>\n139:                     Re-synth · Web Speech\n140:                   </ContextMenuItem>\n141:                   <ContextMenuSeparator />\n142:                   <ContextMenuItem\n143:                     onSelect={() => {\n144:                       const text = g.tokens.map((t) => t.text).join(\" \");\n145:                       navigator.clipboard?.writeText(text).catch(() => undefined);\n146:                     }}\n147:                   >\n148:                     Copy sentence\n149:                   </ContextMenuItem>\n150:                 </ContextMenuContent>\n151:               </ContextMenu>\n152:             );\n153:           })}\n154:         </div>\n155:       </div>\n156: \n157:       {/* Lens marker — tints by active TTS engine */}\n158:       <div\n159:         className={`absolute top-1/2 left-0 right-0 h-24 -translate-y-1/2 border-y ${lensColor} bg-primary/5 pointer-events-none z-10 transition-colors`}\n160:       />\n161:       <Tooltip>\n162:         <TooltipTrigger asChild>\n163:           <div className=\"absolute top-1/2 left-6 -translate-y-1/2 text-[10px] font-mono uppercase tracking-widest text-primary z-20 cursor-help\">\n164:             Lens · {activeEngine ?? \"idle\"}\n165:           </div>\n166:         </TooltipTrigger>\n167:         <TooltipContent side=\"right\">\n168:           Hold your gaze here. Border colour matches the active TTS engine.\n169:         </TooltipContent>\n170:       </Tooltip>\n171:       <div className=\"absolute top-0 left-0 right-0 h-40 bg-gradient-to-b from-card to-transparent pointer-events-none z-10\" />\n172:       <div className=\"absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-card to-transparent pointer-events-none z-10\" />\n173:     </div>\n174:   );\n175: }\n\n(End of file - total 175 lines)\n</content>",
