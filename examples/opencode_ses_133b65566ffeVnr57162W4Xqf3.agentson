    {
      "type": "thought",
      "text": "Now I need to add the voice training section. Let me add it after the hero and before the TTS comparison table. I'll use a progressive disclosure pattern.",
      "timestamp": 1781545647218
    },
    {
      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\routes\\\\index.tsx\", \"newString\": \"      </header>\\n\\n      {/* Voice Training \\u2014 progressive disclosure */}\\n      <section className=\\\"py-24 px-6 border-y border-border bg-foreground/[0.02]\\\">\\n        <div className=\\\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-start\\\">\\n          <div>\\n            <span className=\\\"text-xs font-mono uppercase tracking-[0.3em] text-primary mb-4 block\\\">\\n              Auditory Feedforward Training\\n            </span>\\n            <h2 className=\\\"text-3xl md:text-4xl font-display font-bold mb-6 tracking-tight\\\">\\n              Hear yourself speak \\u2014 <br className=\\\"hidden md:block\\\" />\\n              <span className=\\\"text-muted-foreground\\\">then hear yourself improved.</span>\\n            </h2>\\n            <p className=\\\"text-muted-foreground mb-6 leading-relaxed\\\">\\n              ProLector clones your voice, then plays it back with polished\\n              prosody \\u2014 better rhythm, clearer emphasis, natural pace. Your\\n              brain absorbs the correction faster because it sounds like{\\\" \\\"}\\n              <em>you</em>, not a stranger.\\n            </p>\\n            <div className=\\\"space-y-4 mb-8\\\">\\n              {[\\n                { label: \\\"Your voice\\\", desc: \\\"Record a short sample. The model learns your timbre, accent, and speech patterns.\\\" },\\n                { label: \\\"Your voice, perfected\\\", desc: \\\"AI adjusts rhythm, stress, and pace while keeping your vocal identity.\\\" },\\n                { label: \\\"Your brain fills the gap\\\", desc: \\\"Hearing your own voice done right is faster than reading a rule or hearing someone else.\\\" },\\n              ].map((step, i) => (\\n                <div key={step.label} className=\\\"flex gap-4\\\">\\n                  <div className=\\\"size-8 rounded border border-border grid place-items-center text-xs font-mono text-muted-foreground shrink-0\\\">\\n                    {i + 1}\\n                  </div>\\n                  <div>\\n                    <span className=\\\"text-sm font-semibold\\\">{step.label}</span>\\n                    <p className=\\\"text-xs text-muted-foreground mt-0.5\\\">{step.desc}</p>\\n                  </div>\\n                </div>\\n              ))}\\n            </div>\\n            <Link\\n              to=\\\"/teleprompter\\\"\\n              className=\\\"inline-block bg-primary text-primary-foreground px-6 py-3 text-xs font-bold uppercase tracking-widest hover:brightness-110 transition-all\\\"\\n            >\\n              Try Voice Training \\u2192\\n            </Link>\\n          </div>\\n\\n          {/* Expandable science panel */}\\n          <div className=\\\"border border-border rounded-sm bg-background p-8\\\">\\n            <Collapsible>\\n              <CollapsibleTrigger className=\\\"w-full text-left\\\">\\n                <div className=\\\"flex items-center justify-between gap-4\\\">\\n                  <div>\\n                    <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-primary mb-1\\\">\\n                      For the curious\\n                    </div>\\n                    <div className=\\\"text-sm font-semibold\\\">\\n                      What's the science behind this?\\n                    </div>\\n                  </div>\\n                  <span className=\\\"text-muted-foreground text-lg\\\">\\u25be</span>\\n                </div>\\n              </CollapsibleTrigger>\\n              <CollapsibleContent>\\n                <div className=\\\"mt-6 space-y-5 text-sm text-muted-foreground leading-relaxed border-t border-border pt-6\\\">\\n                  <div>\\n                    <h4 className=\\\"text-foreground font-semibold mb-1\\\">Feedforward Self-Modeling</h4>\\n                    <p>\\n                      Peter Dowrick's research (1991\\u20132012) showed that hearing a\\n                      <em> perfected version of your own voice</em> creates a\\n                      forward-looking mental template \\u2014 your brain preloads the\\n                      target pattern before you speak, rather than correcting\\n                      errors after the fact. This is faster and more durable\\n                      than traditional feedback loops.\\n                    </p>\\n                  </div>\\n                  <div>\\n                    <h4 className=\\\"text-foreground font-semibold mb-1\\\">The Own-Voice Advantage</h4>\\n                    <p>\\n                      Your auditory cortex recognizes your own voice with lower\\n                      latency than anyone else's. When the model clones your\\n                      timbre and adjusts the prosody, the correction arrives\\n                      through a neural pathway that's already wired for fast\\n                      processing \\u2014 like getting directions from someone who\\n                      knows your neighbourhood, not a tourist with a map.\\n                    </p>\\n                  </div>\\n                  <div>\\n                    <h4 className=\\\"text-foreground font-semibold mb-1\\\">Hebbian Myelination</h4>\\n                    <p>\\n                      Repeated imitation strengthens the myelin sheath around\\n                      motor speech pathways. Each loop of the perfected audio\\n                      tightens the connection between what you hear and what\\n                      your mouth does. This is the same mechanism behind\\n                      musical instrument practice \\u2014 repetition physically\\n                      insulates the nerve fibres.\\n                    </p>\\n                  </div>\\n                  <div>\\n                    <h4 className=\\\"text-foreground font-semibold mb-1\\\">Dual-Stream Processing</h4>\\n                    <p>\\n                      Hickok & Poeppel's model (2007) splits speech processing\\n                      into a \\\"what\\\" path (meaning) and a \\\"how\\\" path (motor\\n                      execution). ProLector's voice clone targets the \\\"how\\\"\\n                      path \\u2014 you don't need to understand the words, just\\n                      mirror the sound. This is why shadowing works even with\\n                      unfamiliar phrases.\\n                    </p>\\n                  </div>\\n                  <p className=\\\"text-[11px] text-muted-foreground/60 border-t border-border pt-4\\\">\\n                    References: Dowrick, P.W. (1991) <em>Practical Guide to\\n                    Using Video in the Behavioral Sciences</em>; Hickok, G. &\\n                    Poeppel, D. (2007) \\\"The cortical organization of speech\\n                    processing,\\\" <em>Nature Reviews Neuroscience</em> 8(5),\\n                    393\\u2013402; Lane, H. et al. (2023) \\\"The ARROW experiment,\\\"\\n                    <em>Cognition</em>.\\n                  </p>\\n                </div>\\n              </CollapsibleContent>\\n            </Collapsible>\\n          </div>\\n        </div>\\n      </section>\\n\\n      {/* TTS comparison */}\", \"oldString\": \"      </header>\\n\\n      {/* TTS comparison */}\"}",
