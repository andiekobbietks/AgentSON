      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\routes\\\\studio.tsx\"}",
      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\routes\\studio.tsx</path>\n<type>file</type>\n<content>\n1: import { createFileRoute } from \"@tanstack/react-router\";\n2: import { useEffect, useMemo, useRef, useState } from \"react\";\n3: import { Player } from \"@remotion/player\";\n4: import { AbsoluteFill, Sequence, useCurrentFrame, interpolate } from \"remotion\";\n5: import { SiteNav } from \"@/components/SiteNav\";\n6: import { Dropzone } from \"@/components/studio/Dropzone\";\n7: import { Filmstrip } from \"@/components/studio/Filmstrip\";\n8: import { ClipEditor } from \"@/components/studio/ClipEditor\";\n9: import { ComputeHud } from \"@/components/studio/ComputeHud\";\n10: import { VideoFrameLayer } from \"@/components/studio/VideoFrameLayer\";\n11: import { EdlArticle } from \"@/components/studio/EdlArticle\";\n12: import { openClip, type DecodedClip } from \"@/lib/studio/demux\";\n13: import { pickBackend, type ComputeReport } from \"@/lib/studio/compute-policy\";\n14: import type { Edl, EdlSegment } from \"@/lib/studio/types\";\n15: \n16: export const Route = createFileRoute(\"/studio\")({\n17:   head: () => ({\n18:     meta: [\n19:       { title: \"Studio · Drop an iPhone clip, edit it as JSON\" },\n20:       {\n21:         name: \"description\",\n22:         content:\n23:           \"Drop an iPhone .mov, decode with WebCodecs, edit non-destructively against a JSON EDL. CPU-first, escalates to WebGPU and WebNN only when it must.\",\n24:       },\n25:       { property: \"og:title\", content: \"ProLector Studio · Drop, edit, export the EDL\" },\n26:       {\n27:         property: \"og:description\",\n28:         content: \"WebCodecs decoder, Remotion player, JSON EDL. No upload. No re-encoding to preview.\",\n29:       },\n30:     ],\n31:   }),\n32:   component: Studio,\n33: });\n34: \n35: type Segment = EdlSegment;\n36: \n37: const FPS = 30;\n38: \n39: const DEFAULT_EDL: Edl = {\n40:   video_id: \"chapter_01_video_01\",\n41:   segments: [\n42:     { id: \"s1\", title: \"Cold Open · Welcome\", start_ms: 0, end_ms: 3000, color: \"#f97316\" },\n43:     { id: \"s2\", title: \"Hook · Local-First Pitch\", start_ms: 3000, end_ms: 8000, color: \"#facc15\" },\n44:     { id: \"s3\", title: \"Demo · Voice Cloning\", start_ms: 8000, end_ms: 14000, color: \"#22d3ee\" },\n45:     { id: \"s4\", title: \"Outro · CTA\", start_ms: 14000, end_ms: 18000, color: \"#a78bfa\" },\n46:   ],\n47: };\n48: \n49: function msToFrames(ms: number) {\n50:   return Math.round((ms / 1000) * FPS);\n51: }\n52: \n53: function SegmentCard({ segment }: { segment: Segment }) {\n54:   const frame = useCurrentFrame();\n55:   const opacity = interpolate(frame, [0, 15], [0, 1], { extrapolateRight: \"clamp\" });\n56:   const y = interpolate(frame, [0, 20], [20, 0], { extrapolateRight: \"clamp\" });\n57:   return (\n58:     <AbsoluteFill\n59:       style={{\n60:         background: `linear-gradient(135deg, ${segment.color}22, #09090b)`,\n61:         color: \"#fafafa\",\n62:         fontFamily: \"Inter Tight, sans-serif\",\n63:         padding: 64,\n64:         opacity,\n65:         transform: `translateY(${y}px)`,\n66:       }}\n67:     >\n68:       <div\n69:         style={{\n70:           fontFamily: \"JetBrains Mono, monospace\",\n71:           fontSize: 12,\n72:           letterSpacing: \"0.3em\",\n73:           textTransform: \"uppercase\",\n74:           color: segment.color,\n75:           marginBottom: 24,\n76:         }}\n77:       >\n78:         {segment.id} · {segment.start_ms}→{segment.end_ms} ms\n79:       </div>\n80:       <div style={{ fontSize: 96, fontWeight: 800, lineHeight: 1, letterSpacing: \"-0.04em\" }}>\n81:         {segment.title}\n82:       </div>\n83:       <div\n84:         style={{\n85:           marginTop: 48,\n86:           height: 4,\n87:           width: 120,\n88:           background: segment.color,\n89:         }}\n90:       />\n91:     </AbsoluteFill>\n92:   );\n93: }\n94: \n95: function Composition({ segments }: { segments: Segment[] }) {\n96:   return (\n97:     <AbsoluteFill style={{ background: \"#09090b\" }}>\n98:       {segments.map((seg) => {\n99:         const from = msToFrames(seg.start_ms);\n100:         const duration = Math.max(1, msToFrames(seg.end_ms - seg.start_ms));\n101:         return (\n102:           <Sequence key={seg.id} from={from} durationInFrames={duration} layout=\"none\">\n103:             <SegmentCard segment={seg} />\n104:           </Sequence>\n105:         );\n106:       })}\n107:     </AbsoluteFill>\n108:   );\n109: }\n110: \n111: function Studio() {\n112:   const [edl, setEdl] = useState(DEFAULT_EDL);\n113:   const [edlText, setEdlText] = useState(() => JSON.stringify(DEFAULT_EDL, null, 2));\n114:   const [edlError, setEdlError] = useState<string | null>(null);\n115: \n116:   // iPhone-clip editor state\n117:   const [clip, setClip] = useState<DecodedClip | null>(null);\n118:   const [clipError, setClipError] = useState<string | null>(null);\n119:   const [loadingClip, setLoadingClip] = useState(false);\n120:   const [thumbs, setThumbs] = useState<Array<{ ptsMs: number; bitmap: ImageBitmap }>>([]);\n121:   const [playheadMs, setPlayheadMs] = useState(0);\n122:   const [compute, setCompute] = useState<ComputeReport>({});\n123:   const [clipEdl, setClipEdl] = useState<Edl | null>(null);\n124:   const clipRef = useRef<DecodedClip | null>(null);\n125: \n126:   // Sync text → state for the synthetic demo\n127:   const totalFrames = useMemo(() => {\n128:     const max = edl.segments.reduce((m, s) => Math.max(m, s.end_ms), 0);\n129:     return Math.max(30, msToFrames(max));\n130:   }, [edl]);\n131: \n132:   const clipTotalFrames = useMemo(() => {\n133:     if (!clipEdl) return 30;\n134:     const max = clipEdl.segments.reduce((m, s) => Math.max(m, s.end_ms), 0);\n135:     return Math.max(30, msToFrames(max));\n136:   }, [clipEdl]);\n137: \n138:   useEffect(() => {\n139:     // Probe compute policy once on mount.\n140:     (async () => {\n141:       const next: ComputeReport = {};\n142:       for (const op of [\"decode\", \"resize\", \"grayscale\", \"lut\", \"denoise\"] as const) {\n143:         next[op] = await pickBackend(op);\n144:       }\n145:       setCompute(next);\n146:     })();\n147:   }, []);\n148: \n149:   async function handleFile(file: File) {\n150:     setLoadingClip(true);\n151:     setClipError(null);\n152:     try {\n153:       clipRef.current?.dispose();\n154:       const c = await openClip(file);\n155:       clipRef.current = c;\n156:       setClip(c);\n157:       const seedEdl: Edl = {\n158:         video_id: file.name,\n159:         segments: [\n160:           {\n161:             id: crypto.randomUUID(),\n162:             title: file.name,\n163:             source: file.name,\n164:             in_ms: 0,\n165:             out_ms: c.meta.durationMs,\n166:             start_ms: 0,\n167:             end_ms: c.meta.durationMs,\n168:             color: \"#f97316\",\n169:             effects: [],\n170:           },\n171:         ],\n172:       };\n173:       setClipEdl(seedEdl);\n174:       const t = await c.thumbnails(24);\n175:       setThumbs(t);\n176:     } catch (e) {\n177:       setClipError(e instanceof Error ? e.message : String(e));\n178:     } finally {\n179:       setLoadingClip(false);\n180:     }\n181:   }\n182: \n183:   function exportClipEdl() {\n184:     if (!clipEdl) return;\n185:     const blob = new Blob([JSON.stringify(clipEdl, null, 2)], { type: \"application/json\" });\n186:     const url = URL.createObjectURL(blob);\n187:     const a = document.createElement(\"a\");\n188:     a.href = url;\n189:     a.download = `${clipEdl.video_id}.edl.json`;\n190:     a.click();\n191:     URL.revokeObjectURL(url);\n192:   }\n193: \n194:   const clipDuration = clipEdl ? clipEdl.segments.reduce((m, s) => Math.max(m, s.end_ms), 0) : 0;\n195: \n196:   const applyEdl = () => {\n197:     try {\n198:       const parsed = JSON.parse(edlText);\n199:       if (!Array.isArray(parsed.segments)) throw new Error(\"Missing segments[] array\");\n200:       setEdl(parsed);\n201:       setEdlError(null);\n202:     } catch (e) {\n203:       setEdlError(e instanceof Error ? e.message : String(e));\n204:     }\n205:   };\n206: \n207:   return (\n208:     <div className=\"min-h-screen bg-background text-foreground\">\n209:       <SiteNav />\n210: \n211:       <main className=\"max-w-7xl mx-auto px-6 py-16\">\n212:         <span id=\"drop\" className=\"text-xs font-mono uppercase tracking-[0.3em] text-primary\">\n213:           ADR-001 · Remotion Kernel Live Demo\n214:         </span>\n215:         <h1 className=\"text-4xl md:text-5xl font-display font-bold tracking-tight mt-4 mb-4\">\n216:           Drop your iPhone clip. Edit the JSON. Watch it rebuild.\n217:         </h1>\n218:         <p className=\"text-muted-foreground max-w-2xl mb-10\">\n219:           Drag any <code>.mov</code> or <code>.mp4</code> below. The clip is demuxed by\n220:           MP4Box and decoded by WebCodecs in your browser. Trim, split, and apply\n221:           effects against a 2 KB JSON EDL — CPU-first, escalating to WebGPU/WebNN\n222:           only when it must.\n223:         </p>\n224: \n225:         {/* ───────── iPhone-clip editor ───────── */}\n226:         <section className=\"grid lg:grid-cols-[1fr_360px] gap-6 mb-16\">\n227:           <div className=\"space-y-4\">\n228:             {!clip ? (\n229:               <Dropzone onFile={handleFile} disabled={loadingClip} />\n230:             ) : (\n231:               <div className=\"border border-border rounded-md overflow-hidden bg-card relative\">\n232:                 <Player\n233:                   component={({ segments }) => (\n234:                     <AbsoluteFill style={{ background: \"#09090b\" }}>\n235:                       {(segments as EdlSegment[]).map((seg) => {\n236:                         const from = msToFrames(seg.start_ms);\n237:                         const dur = Math.max(1, msToFrames(seg.end_ms - seg.start_ms));\n238:                         return (\n239:                           <Sequence key={seg.id} from={from} durationInFrames={dur} layout=\"none\">\n240:                             <VideoFrameLayer clip={clipRef.current} segment={seg} />\n241:                           </Sequence>\n242:                         );\n243:                       })}\n244:                     </AbsoluteFill>\n245:                   )}\n246:                   inputProps={{ segments: clipEdl?.segments ?? [] }}\n247:                   compositionWidth={Math.round(clip.meta.width || 1280)}\n248:                   compositionHeight={Math.round(clip.meta.height || 720)}\n249:                   durationInFrames={clipTotalFrames}\n250:                   fps={FPS}\n251:                   controls\n252:                   style={{ width: \"100%\", aspectRatio: `${clip.meta.width || 16} / ${clip.meta.height || 9}` }}\n253:                 />\n254:                 <div className=\"absolute top-3 right-3 w-[220px]\">\n255:                   <ComputeHud report={compute} />\n256:                 </div>\n257:               </div>\n258:             )}\n259: \n260:             {loadingClip && (\n261:               <div className=\"text-[10px] font-mono uppercase tracking-widest text-primary animate-pulse\">\n262:                 Decoding · WebCodecs\n263:               </div>\n264:             )}\n265:             {clipError && (\n266:               <div className=\"border border-destructive/40 bg-destructive/10 text-destructive text-[11px] font-mono p-3 rounded\">\n267:                 {clipError}\n268:               </div>\n269:             )}\n270: \n271:             {clip && clipEdl && (\n272:               <>\n273:                 <Filmstrip\n274:                   thumbs={thumbs}\n275:                   durationMs={clipDuration}\n276:                   playheadMs={playheadMs}\n277:                   onScrub={setPlayheadMs}\n278:                 />\n279:                 <div className=\"text-[10px] font-mono text-muted-foreground\">\n280:                   {clip.meta.name} · {clip.meta.codec} · {clip.meta.width}×{clip.meta.height} · {(clip.meta.durationMs / 1000).toFixed(2)}s\n281:                 </div>\n282:               </>\n283:             )}\n284:           </div>\n285: \n286:           <aside className=\"border border-border rounded-md bg-card p-4 space-y-4\">\n287:             <div className=\"flex items-center justify-between\">\n288:               <span className=\"text-[10px] font-mono uppercase tracking-widest text-primary\">\n289:                 Clip editor\n290:               </span>\n291:               {clipEdl && (\n292:                 <button\n293:                   onClick={exportClipEdl}\n294:                   className=\"text-[10px] font-mono uppercase tracking-widest bg-primary text-primary-foreground px-3 py-1 hover:brightness-110\"\n295:                 >\n296:                   Export EDL\n297:                 </button>\n298:               )}\n299:             </div>\n300:             {clipEdl ? (\n301:               <ClipEditor\n302:                 edl={clipEdl}\n303:                 durationMs={clipDuration}\n304:                 playheadMs={playheadMs}\n305:                 onChange={setClipEdl}\n306:               />\n307:             ) : (\n308:               <div className=\"text-[11px] text-muted-foreground\">\n309:                 Drop a clip on the left to start editing. The timeline, segments,\n310:                 and effect chips appear here.\n311:               </div>\n312:             )}\n313:             <ComputeHud report={compute} />\n314:           </aside>\n315:         </section>\n316: \n317:         {/* ───────── Synthetic example (kept as reference) ───────── */}\n318:         <div className=\"border-t border-border pt-12 mb-6\">\n319:           <span className=\"text-[10px] font-mono uppercase tracking-[0.3em] text-muted-foreground\">\n320:             Synthetic example · no clip required\n321:           </span>\n322:           <h2 className=\"font-display text-2xl font-bold tracking-tight mt-2\">\n323:             Same EDL kernel, no source file\n324:           </h2>\n325:         </div>\n326: \n327:         <div className=\"grid lg:grid-cols-[1fr_420px] gap-6\">\n328:           <div className=\"space-y-4\">\n329:             <div className=\"border border-border rounded-md overflow-hidden bg-card\">\n330:               <Player\n331:                 component={Composition}\n332:                 inputProps={{ segments: edl.segments }}\n333:                 compositionWidth={1280}\n334:                 compositionHeight={720}\n335:                 durationInFrames={totalFrames}\n336:                 fps={FPS}\n337:                 controls\n338:                 loop\n339:                 style={{ width: \"100%\", aspectRatio: \"16 / 9\" }}\n340:               />\n341:             </div>\n342: \n343:             {/* Timeline strip */}\n344:             <div className=\"border border-border rounded-md p-4 bg-background\">\n345:               <div className=\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground mb-3\">\n346:                 Timeline · {totalFrames} frames @ {FPS} fps\n347:               </div>\n348:               <div className=\"relative h-12 bg-card border border-border rounded overflow-hidden\">\n349:                 {edl.segments.map((s) => {\n350:                   const left = (s.start_ms / (totalFrames * (1000 / FPS))) * 100;\n351:                   const width = ((s.end_ms - s.start_ms) / (totalFrames * (1000 / FPS))) * 100;\n352:                   return (\n353:                     <div\n354:                       key={s.id}\n355:                       className=\"absolute top-0 bottom-0 border-r border-background/50 flex items-center px-2 text-[10px] font-mono font-bold uppercase tracking-wider text-background\"\n356:                       style={{ left: `${left}%`, width: `${width}%`, background: s.color }}\n357:                       title={s.title}\n358:                     >\n359:                       <span className=\"truncate\">{s.title}</span>\n360:                     </div>\n361:                   );\n362:                 })}\n363:               </div>\n364:             </div>\n365:           </div>\n366: \n367:           <aside className=\"border border-border rounded-md bg-card flex flex-col\">\n368:             <div className=\"border-b border-border px-4 py-3 flex items-center justify-between\">\n369:               <span className=\"text-[10px] font-mono uppercase tracking-widest text-primary\">\n370:                 edl.json\n371:               </span>\n372:               <span className=\"text-[10px] font-mono text-muted-foreground\">\n373:                 {edlText.length} bytes\n374:               </span>\n375:             </div>\n376:             <textarea\n377:               value={edlText}\n378:               onChange={(e) => setEdlText(e.target.value)}\n379:               className=\"flex-1 min-h-[420px] bg-background border-0 p-4 font-mono text-xs leading-relaxed resize-none focus:outline-none focus:ring-1 focus:ring-primary\"\n380:               spellCheck={false}\n381:             />\n382:             {edlError ? (\n383:               <div className=\"border-t border-destructive/40 bg-destructive/10 text-destructive text-[10px] font-mono p-3\">\n384:                 {edlError}\n385:               </div>\n386:             ) : null}\n387:             <div className=\"border-t border-border p-3 flex gap-2\">\n388:               <button\n389:                 onClick={applyEdl}\n390:                 className=\"flex-1 bg-primary text-primary-foreground py-2 text-[10px] font-bold uppercase tracking-widest hover:brightness-110 transition-all\"\n391:               >\n392:                 Apply EDL\n393:               </button>\n394:               <button\n395:                 onClick={() => {\n396:                   setEdl(DEFAULT_EDL);\n397:                   setEdlText(JSON.stringify(DEFAULT_EDL, null, 2));\n398:                   setEdlError(null);\n399:                 }}\n400:                 className=\"px-4 border border-border text-[10px] font-bold uppercase tracking-widest hover:bg-foreground/5 transition-all\"\n401:               >\n402:                 Reset\n403:               </button>\n404:             </div>\n405:           </aside>\n406:         </div>\n407: \n408:         <EdlArticle />\n409:       </main>\n410:     </div>\n411:   );\n412: }\n\n(End of file - total 412 lines)\n</content>",
