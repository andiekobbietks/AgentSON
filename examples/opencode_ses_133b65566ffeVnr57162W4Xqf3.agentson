    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"/**\\n * ProsodyExplainer \\u2014 Inline definition + visual examples of prosody.\\n *\\n * Shows on first visit as a dismissible banner, and as a tooltip\\n * whenever the word \\\"prosody\\\" appears in the UI. Designed for both\\n * beginners (plain language) and advanced users (technical detail).\\n */\\nimport { useCallback, useEffect, useState } from \\\"react\\\";\\nimport {\\n  Collapsible,\\n  CollapsibleTrigger,\\n  CollapsibleContent,\\n} from \\\"@/components/ui/collapsible\\\";\\n\\nconst DISMISSED_KEY = \\\"prolector.prosody-explainer.dismissed\\\";\\n\\nexport function ProsodyExplainer() {\\n  const [dismissed, setDismissed] = useState(() => {\\n    if (typeof window === \\\"undefined\\\") return false;\\n    return localStorage.getItem(DISMISSED_KEY) === \\\"true\\\";\\n  });\\n\\n  const dismiss = useCallback(() => {\\n    setDismissed(true);\\n    localStorage.setItem(DISMISSED_KEY, \\\"true\\\");\\n  }, []);\\n\\n  if (dismissed) return null;\\n\\n  return (\\n    <div className=\\\"border-b border-primary/20 bg-primary/5 px-6 py-3\\\">\\n      <div className=\\\"max-w-7xl mx-auto flex items-start gap-4\\\">\\n        <div className=\\\"size-6 rounded-full bg-primary/10 grid place-items-center shrink-0 mt-0.5\\\">\\n          <span className=\\\"text-primary text-xs font-bold\\\">?</span>\\n        </div>\\n        <div className=\\\"flex-1 min-w-0\\\">\\n          <p className=\\\"text-sm text-foreground\\\">\\n            <strong>What is prosody?</strong> It's the rhythm, stress, and\\n            intonation of speech \\u2014 the \\\"music\\\" that makes English sound\\n            natural. Two people can say the same words and sound completely\\n            different because of prosody.\\n          </p>\\n          <Collapsible>\\n            <CollapsibleTrigger className=\\\"text-[11px] font-mono text-primary hover:underline mt-1\\\">\\n              Tell me more \\u25be\\n            </CollapsibleTrigger>\\n            <CollapsibleContent>\\n              <div className=\\\"mt-2 text-xs text-muted-foreground leading-relaxed space-y-2\\\">\\n                <p>\\n                  <strong className=\\\"text-foreground\\\">Stress</strong> \\u2014 which\\n                  syllable in a word gets more energy. Compare{\\\" \\\"}\\n                  <em>RE-cord</em> (noun) vs. <em>re-CORD</em> (verb).\\n                </p>\\n                <p>\\n                  <strong className=\\\"text-foreground\\\">Rhythm</strong> \\u2014 English\\n                  is stress-timed: stressed syllables happen at roughly regular\\n                  intervals, and unstressed syllables get squished in between.\\n                  This is different from Italian or Spanish, where syllables\\n                  have more equal timing.\\n                </p>\\n                <p>\\n                  <strong className=\\\"text-foreground\\\">Intonation</strong> \\u2014 the\\n                  rise and fall of pitch across a sentence. It signals\\n                  questions, emphasis, and emotion. A rising pitch at the end\\n                  of a sentence turns a statement into a question.\\n                </p>\\n                <p>\\n                  ProLector shows you the \\\"score\\\" of your speech \\u2014 pitch,\\n                  stress, timing \\u2014 so you can see what native speakers do\\n                  differently and train your ear and mouth to match.\\n                </p>\\n              </div>\\n            </CollapsibleContent>\\n          </Collapsible>\\n        </div>\\n        <button\\n          onClick={dismiss}\\n          className=\\\"text-[10px] font-mono text-muted-foreground hover:text-foreground shrink-0\\\"\\n        >\\n          Got it \\u00d7\\n        </button>\\n      </div>\\n    </div>\\n  );\\n}\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\components\\\\ProsodyExplainer.tsx\"}",
      "output": "Wrote file successfully.",
      "status": "success",
      "timestamp": 1781550667232
    },
