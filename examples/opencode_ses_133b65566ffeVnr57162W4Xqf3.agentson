    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"import { createFileRoute, Link } from \\\"@tanstack/react-router\\\";\\nimport { useCallback, useEffect, useMemo, useRef, useState } from \\\"react\\\";\\nimport {\\n  type Token,\\n  findTokenAtMs,\\n  retime,\\n  sentencesOf,\\n  tokenize,\\n  totalDurationMs,\\n  mergeEdit,\\n} from \\\"@/lib/teleprompter/tokens\\\";\\nimport {\\n  detectCoarticulation,\\n  estimateStress,\\n  estimateVowelCompression,\\n  isContentWord,\\n  type ProsodyWord,\\n} from \\\"@/lib/teleprompter/prosody\\\";\\nimport { TranscriptStage } from \\\"@/components/teleprompter/TranscriptStage\\\";\\nimport { TranscriptEditor } from \\\"@/components/teleprompter/TranscriptEditor\\\";\\nimport { EngineStatus } from \\\"@/components/teleprompter/EngineStatus\\\";\\nimport { Coachmark } from \\\"@/components/teleprompter/Coachmark\\\";\\nimport { useSyllabusMirror } from \\\"@/lib/teleprompter/use-syllabus-mirror\\\";\\nimport { useTriage } from \\\"@/lib/teleprompter/use-triage\\\";\\nimport { useRecording } from \\\"@/lib/teleprompter/use-recording\\\";\\nimport { StumblePlaylist } from \\\"@/components/teleprompter/StumblePlaylist\\\";\\nimport { ABContrast } from \\\"@/components/teleprompter/ABContrast\\\";\\nimport { PunchInEditor } from \\\"@/components/teleprompter/PunchInEditor\\\";\\nimport {\\n  Tooltip,\\n  TooltipContent,\\n  TooltipTrigger,\\n} from \\\"@/components/ui/tooltip\\\";\\nimport type { EngineId } from \\\"@/lib/teleprompter/syllabus-mirror\\\";\\n\\nexport const Route = createFileRoute(\\\"/teleprompter\\\")({\\n  head: () => ({\\n    meta: [\\n      { title: \\\"Teleprompter \\u00b7 ProLector\\\" },\\n      {\\n        name: \\\"description\\\",\\n        content:\\n          \\\"Word-level scrub editor, WPM-locked pacing, and the SyllabusMirror hybrid TTS pipeline \\u2014 Kokoro-82M routed live by CPU feedback.\\\",\\n      },\\n      { property: \\\"og:title\\\", content: \\\"ProLector Teleprompter\\\" },\\n      {\\n        property: \\\"og:description\\\",\\n        content:\\n          \\\"Click any word to scrub. SyllabusMirror routes sentences across Kokoro q8 / q4 / Web Speech using a sliding-window CPU feedback loop.\\\",\\n      },\\n    ],\\n  }),\\n  component: Teleprompter,\\n});\\n\\nconst DEFAULT_SCRIPT = `Welcome to ProLector. This is the SyllabusMirror engine operating at sub-ten-millisecond latency.\\n\\nYour training modules deserve broadcast-grade clarity, so position your eyes directly on the lens marker for perfect engagement.\\n\\nWe deploy Gemma 4 locally. The model parses your text, injects pacing tags, and forwards every clean sentence to the Remotion frame-sequencer. Nothing leaves your machine.\\n\\nPress space to play or pause. Use the up and down arrows to nudge the pace. Press R to reset.`;\\n\\nconst STORAGE_KEY = \\\"prolector.teleprompter.v2\\\";\\nconst LEGACY_KEY = \\\"prolector.teleprompter.v1\\\";\\n\\ntype Settings = {\\n  script: string;\\n  wpm: number;\\n  fontSize: number;\\n  mirror: boolean;\\n  showProsody: boolean;\\n};\\n\\nconst DEFAULTS: Settings = {\\n  script: DEFAULT_SCRIPT,\\n  wpm: 140,\\n  fontSize: 52,\\n  mirror: false,\\n  showProsody: false,\\n};\\n\\nfunction loadSettings(): Settings {\\n  if (typeof window === \\\"undefined\\\") return DEFAULTS;\\n  try {\\n    const v2 = window.localStorage.getItem(STORAGE_KEY);\\n    if (v2) return { ...DEFAULTS, ...JSON.parse(v2) };\\n    const v1 = window.localStorage.getItem(LEGACY_KEY);\\n    if (v1) {\\n      const migrated = { ...DEFAULTS, script: v1 };\\n      window.localStorage.setItem(STORAGE_KEY, JSON.stringify(migrated));\\n      window.localStorage.removeItem(LEGACY_KEY);\\n      return migrated;\\n    }\\n    return DEFAULTS;\\n  } catch {\\n    return DEFAULTS;\\n  }\\n}\\n\\nfunction formatTimecode(ms: number) {\\n  const totalSec = Math.floor(ms / 1000);\\n  const h = String(Math.floor(totalSec / 3600)).padStart(2, \\\"0\\\");\\n  const m = String(Math.floor((totalSec % 3600) / 60)).padStart(2, \\\"0\\\");\\n  const s = String(totalSec % 60).padStart(2, \\\"0\\\");\\n  const f = String(Math.floor(((ms % 1000) / 1000) * 30)).padStart(2, \\\"0\\\");\\n  return `${h}:${m}:${s}:${f}`;\\n}\\n\\nfunction Teleprompter() {\\n  const [settings, setSettings] = useState<Settings>(DEFAULTS);\\n  const [playing, setPlaying] = useState(false);\\n  const [editorOpen, setEditorOpen] = useState(true);\\n  const [currentMs, setCurrentMs] = useState(0);\\n  const [tokens, setTokens] = useState<Token[]>(() => tokenize(DEFAULTS.script, DEFAULTS.wpm));\\n  const rafRef = useRef<number | null>(null);\\n  const lastTickRef = useRef<number | null>(null);\\n  const [voice, setVoice] = useState(\\\"af_heart\\\");\\n\\n  // Loop selection\\n  const [loopAnchor, setLoopAnchor] = useState<number | null>(null);\\n  const [loopRange, setLoopRange] = useState<{ startMs: number; endMs: number } | null>(null);\\n  const [loopArmed, setLoopArmed] = useState(false);\\n\\n  // hydrate from localStorage\\n  useEffect(() => {\\n    const loaded = loadSettings();\\n    setSettings(loaded);\\n    setTokens(tokenize(loaded.script, loaded.wpm));\\n  }, []);\\n\\n  useEffect(() => {\\n    if (typeof window === \\\"undefined\\\") return;\\n    window.localStorage.setItem(STORAGE_KEY, JSON.stringify(settings));\\n  }, [settings]);\\n\\n  const wordCount = useMemo(\\n    () => settings.script.trim().split(/\\\\s+/).filter(Boolean).length,\\n    [settings.script],\\n  );\\n  const estDurationSec = wordCount > 0 ? Math.round((wordCount / settings.wpm) * 60) : 0;\\n\\n  const sentences = useMemo(() => sentencesOf(tokens), [tokens]);\\n  const totalMs = useMemo(() => totalDurationMs(tokens), [tokens]);\\n  const currentToken = useMemo(() => findTokenAtMs(tokens, currentMs), [tokens, currentMs]);\\n\\n  // \\u2500\\u2500 Prosody computation \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n  const prosodyMap = useMemo(() => {\\n    const map = new Map<string, ProsodyWord>();\\n    for (let i = 0; i < tokens.length; i++) {\\n      const t = tokens[i];\\n      if (t.isBreak) continue;\\n\\n      const isContent = isContentWord(t.text);\\n      const position =\\n        i === 0 || tokens[i - 1]?.isBreak\\n          ? \\\"first\\\"\\n          : i === tokens.length - 1 || tokens[i + 1]?.isBreak\\n            ? \\\"last\\\"\\n            : \\\"middle\\\";\\n\\n      // Find the previous non-break token for coarticulation.\\n      let prevToken: Token | undefined;\\n      for (let j = i - 1; j >= 0; j--) {\\n        if (!tokens[j].isBreak) {\\n          prevToken = tokens[j];\\n          break;\\n        }\\n      }\\n\\n      const stress = estimateStress(t.text, position);\\n      const vowelComp = estimateVowelCompression(t.text, stress, isContent);\\n      const coarticulation = prevToken\\n        ? detectCoarticulation(prevToken.text, t.text)\\n        : undefined;\\n\\n      // Simple F0 estimation based on stress and position.\\n      const baseHz = isContent ? 180 : 140;\\n      const f0 = {\\n        onset: baseHz + (stress === \\\"primary\\\" ? 30 : stress === \\\"secondary\\\" ? 10 : -10),\\n        nucleus: baseHz + (stress === \\\"primary\\\" ? 50 : stress === \\\"secondary\\\" ? 20 : 0),\\n        offset: baseHz + (position === \\\"last\\\" ? -20 : 5),\\n        slope: position === \\\"last\\\" ? -15 : stress === \\\"primary\\\" ? 10 : 0,\\n      };\\n\\n      map.set(t.id, {\\n        tokenIndex: i,\\n        f0,\\n        stress,\\n        vowelCompression: vowelComp,\\n        coarticulation,\\n      });\\n    }\\n    return map;\\n  }, [tokens]);\\n\\n  // \\u2500\\u2500 Triage (stumble flagging) \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n  const { markers, markerCount, addMarker, removeMarker, clearMarkers } = useTriage(\\n    currentMs,\\n    currentToken?.text,\\n  );\\n\\n  // \\u2500\\u2500 Recording \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n  const {\\n    state: recState,\\n    recordings,\\n    arm: armRecording,\\n    startRecording,\\n    stopRecording,\\n    deleteRecording,\\n  } = useRecording(currentMs, playing);\\n\\n  // \\u2500\\u2500 Punch-In \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n  const [punchInActive, setPunchInActive] = useState(false);\\n  const [punchRegion, setPunchRegion] = useState<{ startMs: number; endMs: number } | null>(null);\\n\\n  const handlePunchIn = useCallback((startMs: number, endMs: number) => {\\n    setPunchRegion({ startMs, endMs });\\n    setPunchInActive(true);\\n  }, []);\\n\\n  const handlePunchOut = useCallback(() => {\\n    setPunchInActive(false);\\n  }, []);\\n\\n  // \\u2500\\u2500 Side panel tabs \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n  type SideTab = \\\"voice\\\" | \\\"stumbles\\\" | \\\"compare\\\" | \\\"punch-in\\\";\\n  const [activeTab, setActiveTab] = useState<SideTab>(\\\"voice\\\");\\n\\n  // animation loop \\u2014 advance currentMs in milliseconds\\n  useEffect(() => {\\n    if (!playing) {\\n      if (rafRef.current) cancelAnimationFrame(rafRef.current);\\n      rafRef.current = null;\\n      lastTickRef.current = null;\\n      return;\\n    }\\n    const tick = (now: number) => {\\n      const last = lastTickRef.current ?? now;\\n      const dt = now - last;\\n      lastTickRef.current = now;\\n      setCurrentMs((ms) => {\\n        const next = ms + dt;\\n        if (loopArmed && loopRange && next >= loopRange.endMs) {\\n          return loopRange.startMs;\\n        }\\n        if (totalMs > 0 && next >= totalMs) {\\n          setPlaying(false);\\n          return totalMs;\\n        }\\n        return next;\\n      });\\n      rafRef.current = requestAnimationFrame(tick);\\n    };\\n    rafRef.current = requestAnimationFrame(tick);\\n    return () => {\\n      if (rafRef.current) cancelAnimationFrame(rafRef.current);\\n    };\\n  }, [playing, totalMs, loopArmed, loopRange]);\\n\\n  const reset = useCallback(() => {\\n    setPlaying(false);\\n    setCurrentMs(0);\\n  }, []);\\n\\n  // Re-tokenise on script/WPM changes\\n  useEffect(() => {\\n    setTokens((prev) => {\\n      const prevScript = prev\\n        .map((t) => (t.isBreak ? \\\"\\\\n\\\\n\\\" : t.text))\\n        .join(\\\" \\\")\\n        .replace(/ \\\\n\\\\n /g, \\\"\\\\n\\\\n\\\")\\n        .trim();\\n      if (prevScript !== settings.script.trim()) {\\n        return mergeEdit(prev, settings.script, settings.wpm);\\n      }\\n      return retime(prev, settings.wpm);\\n    });\\n  }, [settings.script, settings.wpm]);\\n\\n  // SyllabusMirror orchestrator\\n  const { orchestrator, snapshot } = useSyllabusMirror(\\n    tokens,\\n    sentences,\\n    currentMs,\\n    playing,\\n    setTokens,\\n  );\\n\\n  useEffect(() => {\\n    orchestrator?.setVoice(voice);\\n  }, [orchestrator, voice]);\\n\\n  // keyboard shortcuts\\n  useEffect(() => {\\n    const onKey = (e: KeyboardEvent) => {\\n      const target = e.target as HTMLElement;\\n      if (target && (target.tagName === \\\"TEXTAREA\\\" || target.tagName === \\\"INPUT\\\")) return;\\n      if (e.code === \\\"Space\\\") {\\n        e.preventDefault();\\n        if (playing) {\\n          // During playback: Space flags a stumble (System 1 reflex).\\n          addMarker();\\n        } else {\\n          setPlaying((p) => !p);\\n        }\\n      } else if (e.key === \\\"r\\\" || e.key === \\\"R\\\") {\\n        reset();\\n      } else if (e.key === \\\"ArrowUp\\\") {\\n        setSettings((s) => ({ ...s, wpm: Math.min(220, s.wpm + 5) }));\\n      } else if (e.key === \\\"ArrowDown\\\") {\\n        setSettings((s) => ({ ...s, wpm: Math.max(80, s.wpm - 5) }));\\n      } else if (e.key === \\\"p\\\" || e.key === \\\"P\\\") {\\n        setSettings((s) => ({ ...s, showProsody: !s.showProsody }));\\n      } else if (e.key === \\\"m\\\" || e.key === \\\"M\\\") {\\n        setSettings((s) => ({ ...s, mirror: !s.mirror }));\\n      }\\n    };\\n    window.addEventListener(\\\"keydown\\\", onKey);\\n    return () => window.removeEventListener(\\\"keydown\\\", onKey);\\n  }, [reset, playing, addMarker]);\\n\\n  // Live voice mirror master toggle\\n  const [voiceMirrorOn, setVoiceMirrorOn] = useState(false);\\n  useEffect(() => {\\n    if (!orchestrator) return;\\n    orchestrator.setActive(voiceMirrorOn);\\n    if (voiceMirrorOn) orchestrator.warmup().catch(() => undefined);\\n  }, [orchestrator, voiceMirrorOn]);\\n\\n  const scrubToToken = useCallback(\\n    (t: Token) => {\\n      setCurrentMs(t.startMs);\\n      orchestrator?.notifyScrub();\\n    },\\n    [orchestrator],\\n  );\\n\\n  const handleScrubMs = useCallback(\\n    (ms: number) => {\\n      setCurrentMs(ms);\\n      orchestrator?.notifyScrub();\\n    },\\n    [orchestrator],\\n  );\\n\\n  const handleShiftClick = useCallback(\\n    (t: Token) => {\\n      if (loopAnchor == null) {\\n        setLoopAnchor(t.startMs);\\n      } else {\\n        const a = loopAnchor;\\n        const b = t.endMs;\\n        const startMs = Math.min(a, b);\\n        const endMs = Math.max(a, b);\\n        setLoopRange({ startMs, endMs });\\n        setLoopAnchor(null);\\n      }\\n    },\\n    [loopAnchor],\\n  );\\n\\n  const clearLoop = useCallback(() => {\\n    setLoopRange(null);\\n    setLoopAnchor(null);\\n    setLoopArmed(false);\\n  }, []);\\n\\n  const handleResynth = useCallback(\\n    (sentenceId: string, engine: EngineId) => {\\n      orchestrator?.resynthesize(sentenceId, engine);\\n    },\\n    [orchestrator],\\n  );\\n\\n  // Stumble playlist actions.\\n  const handleSelectStumbleRange = useCallback(\\n    (startMs: number, endMs: number) => {\\n      setLoopRange({ startMs, endMs });\\n      setLoopArmed(true);\\n    },\\n    [],\\n  );\\n\\n  const handlePlayStumbleRange = useCallback(\\n    (startMs: number, endMs: number) => {\\n      setLoopRange({ startMs, endMs });\\n      setLoopArmed(true);\\n      setCurrentMs(startMs);\\n      setPlaying(true);\\n    },\\n    [],\\n  );\\n\\n  // Find the closest marker to currentMs for the flagged-word highlight.\\n  const closestMarkerMs = useMemo(() => {\\n    if (markers.length === 0) return null;\\n    let closest = markers[0];\\n    let minDist = Math.abs(currentMs - closest.currentMs);\\n    for (const m of markers) {\\n      const dist = Math.abs(currentMs - m.currentMs);\\n      if (dist < minDist) {\\n        closest = m;\\n        minDist = dist;\\n      }\\n    }\\n    return minDist < 500 ? closest.currentMs : null;\\n  }, [markers, currentMs]);\\n\\n  return (\\n    <div className=\\\"min-h-screen bg-background text-foreground flex flex-col\\\">\\n      {/* Top bar */}\\n      <div className=\\\"border-b border-border bg-background/90 backdrop-blur sticky top-0 z-40\\\">\\n        <div className=\\\"max-w-7xl mx-auto px-6 h-14 flex items-center justify-between gap-4\\\">\\n          <div className=\\\"flex items-center gap-6\\\">\\n            <Link\\n              to=\\\"/\\\"\\n              className=\\\"font-display font-bold tracking-tighter text-lg uppercase italic\\\"\\n            >\\n              \\u2190 ProLector\\n            </Link>\\n            <span className=\\\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground hidden md:inline\\\">\\n              Teleprompter \\u00b7 SyllabusMirror v1.4\\n            </span>\\n          </div>\\n          <div className=\\\"flex items-center gap-4\\\">\\n            {markerCount > 0 && (\\n              <span className=\\\"text-[10px] font-mono uppercase tracking-widest text-destructive\\\">\\n                {markerCount} flagged\\n              </span>\\n            )}\\n            <Tooltip>\\n              <TooltipTrigger asChild>\\n                <div className=\\\"flex items-center gap-2 font-mono text-[11px] uppercase tracking-widest cursor-help\\\">\\n                  <span className={`size-2 rounded-full ${playing ? \\\"bg-destructive animate-pulse\\\" : \\\"bg-muted-foreground/40\\\"}`} />\\n                  <span className={playing ? \\\"text-destructive\\\" : \\\"text-muted-foreground\\\"}>\\n                    {playing ? \\\"REC\\\" : \\\"STBY\\\"} {formatTimecode(currentMs)}\\n                  </span>\\n                </div>\\n              </TooltipTrigger>\\n              <TooltipContent side=\\\"bottom\\\">\\n                Recording state \\u00b7 SMPTE timecode of the playhead.\\n              </TooltipContent>\\n            </Tooltip>\\n          </div>\\n        </div>\\n      </div>\\n\\n      {/* Controls */}\\n      <div className=\\\"border-b border-border px-6 py-3\\\">\\n        <div className=\\\"max-w-7xl mx-auto flex flex-wrap items-center gap-4 text-xs font-mono uppercase tracking-widest\\\">\\n          <Tooltip>\\n            <TooltipTrigger asChild>\\n              <button\\n                onClick={() => setPlaying((p) => !p)}\\n                className=\\\"bg-primary text-primary-foreground px-5 py-2 font-bold hover:brightness-110 transition-all\\\"\\n              >\\n                {playing ? \\\"\\u25a0 Pause\\\" : \\\"\\u25b6 Play\\\"}\\n              </button>\\n            </TooltipTrigger>\\n            <TooltipContent>Play or pause \\u00b7 Shortcut: Space</TooltipContent>\\n          </Tooltip>\\n          <Tooltip>\\n            <TooltipTrigger asChild>\\n              <button\\n                onClick={reset}\\n                className=\\\"border border-border px-4 py-2 hover:bg-foreground/5 transition-all\\\"\\n              >\\n                Reset\\n              </button>\\n            </TooltipTrigger>\\n            <TooltipContent>Jump back to 00:00:00:00 \\u00b7 Shortcut: R</TooltipContent>\\n          </Tooltip>\\n\\n          <Tooltip>\\n            <TooltipTrigger asChild>\\n              <div className=\\\"flex items-center gap-2\\\">\\n                <label className=\\\"text-muted-foreground\\\">WPM</label>\\n                <input\\n                  type=\\\"range\\\"\\n                  min={80}\\n                  max={220}\\n                  value={settings.wpm}\\n                  onChange={(e) => setSettings((s) => ({ ...s, wpm: Number(e.target.value) }))}\\n                  className=\\\"accent-primary\\\"\\n                />\\n                <span className=\\\"w-10 text-right text-foreground\\\">{settings.wpm}</span>\\n              </div>\\n            </TooltipTrigger>\\n            <TooltipContent>Words per minute \\u00b7 \\u2191 \\u2193 nudges \\u00b15 \\u00b7 Rubric 120\\u2013160</TooltipContent>\\n          </Tooltip>\\n\\n          <Tooltip>\\n            <TooltipTrigger asChild>\\n              <div className=\\\"flex items-center gap-2\\\">\\n                <label className=\\\"text-muted-foreground\\\">Size</label>\\n                <input\\n                  type=\\\"range\\\"\\n                  min={28}\\n                  max={96}\\n                  value={settings.fontSize}\\n                  onChange={(e) => setSettings((s) => ({ ...s, fontSize: Number(e.target.value) }))}\\n                  className=\\\"accent-primary\\\"\\n                />\\n                <span className=\\\"w-10 text-right text-foreground\\\">{settings.fontSize}px</span>\\n              </div>\\n            </TooltipTrigger>\\n            <TooltipContent>Stage font size in pixels.</TooltipContent>\\n          </Tooltip>\\n\\n          <Tooltip>\\n            <TooltipTrigger asChild>\\n              <label className=\\\"flex items-center gap-2 cursor-pointer select-none\\\">\\n                <input\\n                  type=\\\"checkbox\\\"\\n                  checked={settings.mirror}\\n                  onChange={(e) => setSettings((s) => ({ ...s, mirror: e.target.checked }))}\\n                  className=\\\"accent-primary\\\"\\n                />\\n                <span>Mirror</span>\\n              </label>\\n            </TooltipTrigger>\\n            <TooltipContent>Flip horizontally for confidence-monitor glass \\u00b7 Shortcut: M</TooltipContent>\\n          </Tooltip>\\n\\n          <Tooltip>\\n            <TooltipTrigger asChild>\\n              <label className=\\\"flex items-center gap-2 cursor-pointer select-none\\\">\\n                <input\\n                  type=\\\"checkbox\\\"\\n                  checked={settings.showProsody}\\n                  onChange={(e) => setSettings((s) => ({ ...s, showProsody: e.target.checked }))}\\n                  className=\\\"accent-primary\\\"\\n                />\\n                <span>Prosody</span>\\n              </label>\\n            </TooltipTrigger>\\n            <TooltipContent>Visual pitch, stress, and vowel overlays \\u00b7 Shortcut: P</TooltipContent>\\n          </Tooltip>\\n\\n          <Tooltip>\\n            <TooltipTrigger asChild>\\n              <span\\n                className={`ml-auto px-2 py-1 border cursor-help ${\\n                  settings.wpm >= 120 && settings.wpm <= 160\\n                    ? \\\"border-primary/40 text-primary\\\"\\n                    : \\\"border-border text-muted-foreground\\\"\\n                }`}\\n              >\\n                {settings.wpm >= 120 && settings.wpm <= 160 ? \\\"Compliant\\\" : \\\"Out of rubric\\\"} \\u00b7 120\\u2013160\\n              </span>\\n            </TooltipTrigger>\\n            <TooltipContent>Green when 120 \\u2264 WPM \\u2264 160 (broadcast rubric).</TooltipContent>\\n          </Tooltip>\\n          <span className=\\\"text-muted-foreground\\\">\\n            {wordCount} words \\u00b7 ~{Math.floor(estDurationSec / 60)}:\\n            {String(estDurationSec % 60).padStart(2, \\\"0\\\")}\\n          </span>\\n\\n          <Tooltip>\\n            <TooltipTrigger asChild>\\n              <button\\n                onClick={() => setEditorOpen((o) => !o)}\\n                className=\\\"border border-border px-4 py-2 hover:bg-foreground/5 transition-all\\\"\\n              >\\n                {editorOpen ? \\\"Hide Panel\\\" : \\\"Transcript Panel\\\"}\\n              </button>\\n            </TooltipTrigger>\\n            <TooltipContent>Toggle the right-hand transcript + voice panel.</TooltipContent>\\n          </Tooltip>\\n        </div>\\n      </div>\\n\\n      <div className={`flex-1 grid ${editorOpen ? \\\"lg:grid-cols-[1fr_420px]\\\" : \\\"grid-cols-1\\\"} min-h-0`}>\\n        {/* Stage */}\\n        <div className=\\\"relative\\\">\\n          <TranscriptStage\\n            tokens={tokens}\\n            currentTokenId={currentToken?.id ?? null}\\n            fontSize={settings.fontSize}\\n            mirror={settings.mirror}\\n            activeEngine={snapshot?.activeEngine ?? null}\\n            loopRange={loopRange}\\n            onTokenClick={scrubToToken}\\n            onTokenShiftClick={handleShiftClick}\\n            onResynth={handleResynth}\\n            prosody={settings.showProsody ? prosodyMap : undefined}\\n            showProsody={settings.showProsody}\\n            triageMarkerMs={closestMarkerMs}\\n          />\\n          <Coachmark />\\n        </div>\\n\\n        {/* Side panel */}\\n        {editorOpen ? (\\n          <aside className=\\\"border-l border-border bg-background flex flex-col min-h-0\\\">\\n            {/* Tab bar */}\\n            <div className=\\\"flex border-b border-border\\\">\\n              {([\\n                [\\\"voice\\\", \\\"Voice\\\"],\\n                [\\\"stumbles\\\", `Stumbles${markerCount > 0 ? ` (${markerCount})` : \\\"\\\"}`],\\n                [\\\"compare\\\", \\\"Compare\\\"],\\n                [\\\"punch-in\\\", \\\"Punch-In\\\"],\\n              ] as [SideTab, string][]).map(([tab, label]) => (\\n                <button\\n                  key={tab}\\n                  onClick={() => setActiveTab(tab)}\\n                  className={`flex-1 px-3 py-2.5 text-[10px] font-mono uppercase tracking-widest transition-colors ${\\n                    activeTab === tab\\n                      ? \\\"text-primary border-b-2 border-primary\\\"\\n                      : \\\"text-muted-foreground hover:text-foreground\\\"\\n                  }`}\\n                >\\n                  {label}\\n                </button>\\n              ))}\\n            </div>\\n\\n            <div className=\\\"p-4 flex-1 overflow-y-auto space-y-6\\\">\\n              {/* Voice tab */}\\n              {activeTab === \\\"voice\\\" && (\\n                <>\\n                  <TranscriptEditor\\n                    tokens={tokens}\\n                    currentTokenId={currentToken?.id ?? null}\\n                    totalMs={totalMs}\\n                    currentMs={currentMs}\\n                    loopRange={loopRange}\\n                    loopArmed={loopArmed}\\n                    onScrubToToken={scrubToToken}\\n                    onTokenShiftClick={handleShiftClick}\\n                    onToggleLoop={() => setLoopArmed((v) => !v)}\\n                    onClearLoop={clearLoop}\\n                    onScriptChange={(script) => setSettings((s) => ({ ...s, script }))}\\n                    onScrubMs={handleScrubMs}\\n                    onResynth={handleResynth}\\n                  />\\n\\n                  <section className=\\\"border-t border-border pt-6\\\">\\n                    <div className=\\\"flex items-center justify-between mb-3\\\">\\n                      <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-primary\\\">\\n                        SyllabusMirror \\u00b7 Voice Pipeline\\n                      </div>\\n                      <Tooltip>\\n                        <TooltipTrigger asChild>\\n                          <label className=\\\"flex items-center gap-2 text-[10px] font-mono uppercase tracking-widest cursor-pointer\\\">\\n                            <input\\n                              type=\\\"checkbox\\\"\\n                              checked={voiceMirrorOn}\\n                              onChange={(e) => setVoiceMirrorOn(e.target.checked)}\\n                              className=\\\"accent-primary\\\"\\n                            />\\n                            Live\\n                          </label>\\n                        </TooltipTrigger>\\n                        <TooltipContent side=\\\"left\\\">\\n                          Stream audio while the prompter scrolls. Warms up Kokoro\\n                          on first toggle.\\n                        </TooltipContent>\\n                      </Tooltip>\\n                    </div>\\n                    <p className=\\\"text-xs text-muted-foreground leading-relaxed mb-3\\\">\\n                      Sliding 8-second window. Sentences are routed to Kokoro q8 (long /\\n                      director), Kokoro q4 (short / latency-bound), or browser\\n                      SpeechSynthesis (fallback) based on a live RTF feedback loop.\\n                    </p>\\n\\n                    <label className=\\\"block text-[10px] font-mono uppercase tracking-widest text-muted-foreground mb-2\\\">\\n                      Voice\\n                    </label>\\n                    <Tooltip>\\n                      <TooltipTrigger asChild>\\n                        <select\\n                          value={voice}\\n                          onChange={(e) => setVoice(e.target.value)}\\n                          className=\\\"w-full bg-card border border-border p-2 text-sm mb-3\\\"\\n                        >\\n                      <option value=\\\"af_heart\\\">af_heart (female, warm)</option>\\n                      <option value=\\\"af_bella\\\">af_bella (female, clear)</option>\\n                      <option value=\\\"am_michael\\\">am_michael (male, narrator)</option>\\n                      <option value=\\\"am_adam\\\">am_adam (male, deep)</option>\\n                      <option value=\\\"bf_emma\\\">bf_emma (British female)</option>\\n                      <option value=\\\"bm_george\\\">bm_george (British male)</option>\\n                        </select>\\n                      </TooltipTrigger>\\n                      <TooltipContent side=\\\"left\\\">\\n                        Kokoro voice id used for all sentences. Changing clears cache.\\n                      </TooltipContent>\\n                    </Tooltip>\\n\\n                    <EngineStatus\\n                      snapshot={snapshot}\\n                      onToggle={(id, en) => orchestrator?.setEngineEnabled(id, en)}\\n                    />\\n                  </section>\\n\\n                  <section className=\\\"border-t border-border pt-6\\\">\\n                    <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-primary mb-3\\\">\\n                      Shortcuts\\n                    </div>\\n                    <ul className=\\\"space-y-2 text-xs font-mono text-muted-foreground\\\">\\n                      <li><kbd className=\\\"text-foreground\\\">Space</kbd> \\u00b7 play / pause \\u00b7 flag stumble (during playback)</li>\\n                      <li><kbd className=\\\"text-foreground\\\">R</kbd> \\u00b7 reset</li>\\n                      <li><kbd className=\\\"text-foreground\\\">\\u2191 \\u2193</kbd> \\u00b7 \\u00b1 5 WPM</li>\\n                      <li><kbd className=\\\"text-foreground\\\">P</kbd> \\u00b7 toggle prosody overlays</li>\\n                      <li><kbd className=\\\"text-foreground\\\">M</kbd> \\u00b7 toggle mirror</li>\\n                      <li><kbd className=\\\"text-foreground\\\">click</kbd> \\u00b7 scrub to word</li>\\n                      <li><kbd className=\\\"text-foreground\\\">shift+click</kbd> \\u00b7 set loop range</li>\\n                      <li><kbd className=\\\"text-foreground\\\">right-click</kbd> \\u00b7 re-synth menu</li>\\n                    </ul>\\n                  </section>\\n                </>\\n              )}\\n\\n              {/* Stumbles tab */}\\n              {activeTab === \\\"stumbles\\\" && (\\n                <section>\\n                  <StumblePlaylist\\n                    markers={markers}\\n                    tokens={tokens}\\n                    currentMs={currentMs}\\n                    onSelectRange={handleSelectStumbleRange}\\n                    onPlayRange={handlePlayStumbleRange}\\n                    onRemoveMarker={removeMarker}\\n                    onClearAll={clearMarkers}\\n                  />\\n                </section>\\n              )}\\n\\n              {/* Compare tab */}\\n              {activeTab === \\\"compare\\\" && (\\n                <section>\\n                  <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-primary mb-3\\\">\\n                    A/B Contrast \\u00b7 Your Voice vs. AI\\n                  </div>\\n                  <p className=\\\"text-xs text-muted-foreground leading-relaxed mb-3\\\">\\n                    Toggle between your recording and the AI reference to hear\\n                    prosody differences. Use \\\"Alternating\\\" mode to switch every\\n                    3 seconds.\\n                  </p>\\n                  <ABContrast\\n                    recordings={recordings}\\n                    currentMs={currentMs}\\n                    totalMs={totalMs}\\n                    onScrubMs={handleScrubMs}\\n                  />\\n\\n                  <div className=\\\"border-t border-border mt-4 pt-4\\\">\\n                    <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground mb-2\\\">\\n                      Recording\\n                    </div>\\n                    <div className=\\\"flex items-center gap-2\\\">\\n                      {recState === \\\"idle\\\" && (\\n                        <button\\n                          onClick={async () => {\\n                            await armRecording();\\n                            startRecording();\\n                          }}\\n                          className=\\\"text-[11px] font-mono px-4 py-2 bg-destructive text-destructive-foreground hover:brightness-110 transition-all\\\"\\n                        >\\n                          \\u25cf Record\\n                        </button>\\n                      )}\\n                      {recState === \\\"recording\\\" && (\\n                        <button\\n                          onClick={stopRecording}\\n                          className=\\\"text-[11px] font-mono px-4 py-2 bg-destructive text-destructive-foreground hover:brightness-110 transition-all animate-pulse\\\"\\n                        >\\n                          \\u25a0 Stop\\n                        </button>\\n                      )}\\n                      {recState === \\\"arming\\\" && (\\n                        <span className=\\\"text-[10px] font-mono text-muted-foreground\\\">\\n                          Requesting microphone\\u2026\\n                        </span>\\n                      )}\\n                    </div>\\n                  </div>\\n                </section>\\n              )}\\n\\n              {/* Punch-In tab */}\\n              {activeTab === \\\"punch-in\\\" && (\\n                <section>\\n                  <div className=\\\"text-[10px] font-mono uppercase tracking-widest text-primary mb-3\\\">\\n                    Non-Destructive Punch-In\\n                  </div>\\n                  <p className=\\\"text-xs text-muted-foreground leading-relaxed mb-3\\\">\\n                    Select a region, then re-record just that section. The\\n                    original audio is preserved with cross-fade transitions.\\n                  </p>\\n                  <PunchInEditor\\n                    recording={recordings[0] ?? null}\\n                    currentMs={currentMs}\\n                    totalMs={totalMs}\\n                    onPunchIn={handlePunchIn}\\n                    onPunchOut={handlePunchOut}\\n                    punchInActive={punchInActive}\\n                  />\\n                </section>\\n              )}\\n            </div>\\n          </aside>\\n        ) : null}\\n      </div>\\n    </div>\\n  );\\n}\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\routes\\\\teleprompter.tsx\"}",
      "output": "Wrote file successfully.",
