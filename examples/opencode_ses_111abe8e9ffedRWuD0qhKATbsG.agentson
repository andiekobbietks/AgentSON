    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"\\\"\\\"\\\"Extract text from PDFs and DOCX without attaching them as media.\\\"\\\"\\\"\\nimport sys\\nfrom pathlib import Path\\nimport PyPDF2\\n\\ndef extract_pdf(pdf_path, out_path):\\n    with open(pdf_path, \\\"rb\\\") as f:\\n        reader = PyPDF2.PdfReader(f)\\n        text_parts = []\\n        for i, page in enumerate(reader.pages):\\n            text_parts.append(f\\\"\\\\n--- PAGE {i+1} ---\\\\n\\\")\\n            text_parts.append(page.extract_text() or \\\"\\\")\\n        Path(out_path).write_text(\\\"\\\".join(text_parts), encoding=\\\"utf-8\\\")\\n    print(f\\\"OK PDF: {pdf_path} -> {out_path}\\\")\\n\\ndef extract_docx(docx_path, out_path):\\n    try:\\n        from docx import Document\\n    except ImportError:\\n        # Fallback: use zipfile to read document.xml\\n        import zipfile\\n        import re\\n        import xml.etree.ElementTree as ET\\n        with zipfile.ZipFile(docx_path) as z:\\n            with z.open(\\\"word/document.xml\\\") as f:\\n                tree = ET.parse(f)\\n                ns = {\\\"w\\\": \\\"http://schemas.openxmlformats.org/wordprocessingml/2006/main\\\"}\\n                paragraphs = []\\n                for p in tree.getroot().iter(\\\"{http://schemas.openxmlformats.org/wordprocessingml/2006/main}p\\\"):\\n                    texts = [t.text or \\\"\\\" for t in p.iter(\\\"{http://schemas.openxmlformats.org/wordprocessingml/2006/main}t\\\")]\\n                    paragraphs.append(\\\"\\\".join(texts))\\n        Path(out_path).write_text(\\\"\\\\n\\\\n\\\".join(paragraphs), encoding=\\\"utf-8\\\")\\n        print(f\\\"OK DOCX (zipfile): {docx_path} -> {out_path}\\\")\\n        return\\n    doc = Document(docx_path)\\n    paras = [p.text for p in doc.paragraphs]\\n    Path(out_path).write_text(\\\"\\\\n\\\\n\\\".join(paras), encoding=\\\"utf-8\\\")\\n    print(f\\\"OK DOCX: {docx_path} -> {out_path}\\\")\\n\\ntmp = Path(\\\"C:/Users/LLM-Test/.mavis/sessions/mvs_655002872be440d685f9c58dcb581f2a/workspace/oci_extract\\\")\\ntmp.mkdir(parents=True, exist_ok=True)\\n\\n# Critical OCI files to extract\\nfiles = [\\n    # (src, dst_name)\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Mariana\\\\How to AI\\\\Mistral Evaluation Report for a Welsh OCI-Based Agentic Services Business.pdf\\\", \\\"mistral_oci.pdf.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Mariana\\\\How to AI\\\\Mistral Evaluation Report for a Welsh OCI-Based Agentic Services Business.docx\\\", \\\"mistral_oci.docx.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Opprah's Foundation Essentials\\\\ORACLE-LINUX-LXD-SOLOPRENEUR.md.pdf\\\", \\\"oracle_linux_lxd.pdf.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Sovereign AI Stack on OCI (1).pdf\\\", \\\"sovereign_ai_stack_v2.pdf.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Opprah's Foundation Essentials\\\\ADR-SOVEREIGN-AI-STACK.md.pdf\\\", \\\"adr_sovereign_ai_stack.pdf.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\sovereign_intelligence_business_plan.md.pdf\\\", \\\"sovereign_intel_business.pdf.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Oracle Cloud Free Tier Signup.pdf\\\", \\\"signup_v1.pdf.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Oracle Cloud Free_Tier Signup.pdf\\\", \\\"signup_v2.pdf.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Oracle Cloud Free Tier _ Oracle United Kingdom.pdf\\\", \\\"oracle_uk_free_tier.pdf.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\FAQ on Oracle's Cloud Free Tier _ Oracle United Kingdom.pdf\\\", \\\"oracle_uk_faq.pdf.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Sovereign AI Stack on OCI.pdf\\\", \\\"sovereign_ai_stack_v1.pdf.txt\\\"),\\n    (r\\\"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\Sovereign_Intent_Manifolds.PDF\\\", \\\"sovereign_intent_manifolds.pdf.txt\\\"),\\n]\\n\\nfor src, dst in files:\\n    p = Path(src)\\n    if not p.exists():\\n        print(f\\\"MISSING: {src}\\\")\\n        continue\\n    out = tmp / dst\\n    try:\\n        if p.suffix.lower() == \\\".pdf\\\":\\n            extract_pdf(p, out)\\n        elif p.suffix.lower() == \\\".docx\\\":\\n            extract_docx(p, out)\\n        else:\\n            print(f\\\"SKIP: {src}\\\")\\n    except Exception as e:\\n        print(f\\\"FAIL: {src}: {e}\\\")\\n\\nprint(\\\"\\\\nDONE\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_655002872be440d685f9c58dcb581f2a\\\\workspace\\\\extract_pdfs.py\"}",
