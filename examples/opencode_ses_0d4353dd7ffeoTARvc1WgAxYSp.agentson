    {
      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"$allEvents = Get-WinEvent -LogName System -MaxEvents 2000 2>$null; $allEvents | Where-Object { $_.Id -eq 18 -or $_.Id -eq 47 -or $_.Id -eq 50057 -or ($_.ProviderName -and $_.ProviderName -match 'WHEA') -or ($_.Message -and $_.Message -match 'WHEA|UNCORRECTABLE|Hardware Error|machine check') } | Select-Object TimeCreated, Id, ProviderName, LevelDisplayName, Message | Format-List\", \"description\": \"Deep search WHEA events in system log\"}",
