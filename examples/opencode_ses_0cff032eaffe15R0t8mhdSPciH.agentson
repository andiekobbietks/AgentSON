      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\agentsong\\\\docs\\\\viewer\\\\index.html\"}",
      "output": "<path>C:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\viewer\\index.html</path>\n<type>file</type>\n<content>\n1: <!DOCTYPE html>\n2: <html lang=\"en\">\n3: <head>\n4:     <meta charset=\"UTF-8\">\n5:     <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n6:     <title>AgentSON Viewer</title>\n7:     <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n8:     <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n9:     <link href=\"https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n10:     <style>\n11:         :root {\n12:             --bg: #0a0a08;\n13:             --surface: #141410;\n14:             --border: #2a2a1e;\n15:             --text: #e8e0c8;\n16:             --text-muted: #9a9070;\n17:             --accent: #ffb000;\n18:             --success: #a0d060;\n19:             --warning: #d4a030;\n20:             --error: #e05040;\n21:             --purple: #a070d0;\n22:         }\n23:         * { margin: 0; padding: 0; box-sizing: border-box; }\n24:         body {\n25:             font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n26:             background: var(--bg);\n27:             color: var(--text);\n28:             line-height: 1.6;\n29:         }\n30:         .container { max-width: 1200px; margin: 0 auto; padding: 20px; }\n31: \n32:         header { border-bottom: 1px solid var(--border); padding-bottom: 16px; margin-bottom: 20px; }\n33:         h1 { font-family: 'Space Mono', monospace; font-size: 24px; font-weight: 700; }\n34:         h1 span { color: var(--accent); }\n35: \n36:         .controls { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; align-items: center; }\n37:         .btn {\n38:             padding: 7px 14px; border-radius: 6px; cursor: pointer; font-weight: 600;\n39:             font-family: 'IBM Plex Sans', sans-serif; font-size: 13px;\n40:             border: 1px solid var(--border); transition: all 0.2s;\n41:         }\n42:         .btn-primary { background: var(--accent); color: #0a0a08; border-color: var(--accent); }\n43:         .btn-primary:hover { opacity: 0.85; }\n44:         .btn-danger { background: var(--error); color: #fff; border-color: var(--error); }\n45:         .btn-danger:hover { opacity: 0.85; }\n46:         .btn-secondary { background: var(--surface); color: var(--text); }\n47:         .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }\n48:         .btn[disabled] { display: none; }\n49: \n50:         .search-wrap { width: 100%; margin-top: 10px; display: none; }\n51:         .search-wrap.active { display: block; }\n52:         #searchBar {\n53:             width: 100%; padding: 10px 14px; background: var(--surface); border: 1px solid var(--border);\n54:             color: var(--text); border-radius: 6px; font-family: 'IBM Plex Sans', sans-serif; font-size: 14px;\n55:         }\n56:         #searchBar:focus { outline: none; border-color: var(--accent); }\n57:         #searchBar::placeholder { color: var(--text-muted); }\n58: \n59:         .drop-zone {\n60:             border: 2px dashed var(--border); border-radius: 8px; padding: 40px;\n61:             text-align: center; cursor: pointer; transition: all 0.3s ease;\n62:         }\n63:         .drop-zone:hover { border-color: var(--accent); }\n64:         .drop-zone.dragover { border-color: var(--success); background: rgba(160, 208, 96, 0.05); }\n65:         .drop-zone p { color: var(--text-muted); margin-bottom: 8px; }\n66:         .drop-zone strong { color: var(--accent); }\n67:         #fileInput { display: none; }\n68: \n69:         .json-preview {\n70:             margin-bottom: 20px; border: 1px solid var(--border); border-radius: 8px;\n71:             background: var(--surface);\n72:         }\n73:         .json-preview summary {\n74:             padding: 10px 14px; cursor: pointer; color: var(--text-muted); font-size: 13px;\n75:             user-select: none; font-family: 'Space Mono', monospace;\n76:         }\n77:         .json-preview summary:hover { color: var(--accent); }\n78:         .json-preview pre {\n79:             padding: 14px; margin: 0; overflow-x: auto; font-size: 12px;\n80:             background: rgba(0,0,0,0.3); border-top: 1px solid var(--border);\n81:             color: var(--accent); font-family: 'Space Mono', monospace;\n82:         }\n83: \n84:         .session-info {\n85:             background: var(--surface); border: 1px solid var(--border);\n86:             border-radius: 8px; padding: 16px; margin-bottom: 20px;\n87:         }\n88:         .session-info h2 { font-family: 'Space Mono', monospace; font-size: 16px; margin-bottom: 12px; }\n89:         .meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 10px; }\n90:         .meta-item { font-size: 14px; }\n91:         .meta-item .label { color: var(--text-muted); }\n92: \n93:         .entries { display: flex; flex-direction: column; gap: 12px; }\n94:         .entries.side-by-side {\n95:             display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 16px;\n96:         }\n97:         .entries.side-by-side .entry { margin-bottom: 0; }\n98: \n99:         .entry {\n100:             background: var(--surface); border: 1px solid var(--border);\n101:             border-radius: 8px; padding: 14px; position: relative;\n102:             border-left: 4px solid var(--border); transition: border-color 0.2s;\n103:         }\n104:         .entry-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }\n105:         .entry-type {\n106:             font-size: 11px; padding: 2px 8px; border-radius: 10px;\n107:             font-weight: 600; text-transform: uppercase; font-family: 'Space Mono', monospace;\n108:         }\n109:         .copy-btn {\n110:             margin-left: auto; padding: 3px 8px; font-size: 11px;\n111:             background: var(--bg); color: var(--text-muted); border: 1px solid var(--border);\n112:             border-radius: 4px; cursor: pointer; transition: all 0.2s;\n113:             font-family: 'Space Mono', monospace;\n114:         }\n115:         .copy-btn:hover { background: var(--accent); color: #0a0a08; border-color: var(--accent); }\n116:         .copy-btn.copied { background: var(--success); color: #0a0a08; border-color: var(--success); }\n117: \n118:         .role-user { border-left-color: var(--accent); }\n119:         .role-user .entry-type { background: var(--accent); color: #0a0a08; }\n120:         .role-assistant { border-left-color: var(--success); }\n121:         .role-assistant .entry-type { background: var(--success); color: #0a0a08; }\n122:         .role-system { border-left-color: var(--warning); }\n123:         .role-system .entry-type { background: var(--warning); color: #0a0a08; }\n124:         .role-tool { border-left-color: var(--purple); }\n125:         .role-tool .entry-type { background: var(--purple); color: #fff; }\n126:         .role-error { border-left-color: var(--error); }\n127:         .role-error .entry-type { background: var(--error); color: #fff; }\n128: \n129:         .entry-content { font-size: 14px; white-space: pre-wrap; word-break: break-word; }\n130:         .entry-content code {\n131:             background: var(--bg); padding: 2px 6px; border-radius: 4px;\n132:             font-family: 'Space Mono', monospace; font-size: 12px;\n133:         }\n134:         .entry-content pre {\n135:             background: var(--bg); padding: 12px; border-radius: 4px;\n136:             overflow-x: auto; margin-top: 8px;\n137:         }\n138:         .entry-content pre code { padding: 0; background: none; }\n139: \n140:         .metrics {\n141:             display: flex; gap: 16px; flex-wrap: wrap; margin-top: 14px;\n142:             padding-top: 14px; border-top: 1px solid var(--border);\n143:             font-size: 13px; color: var(--text-muted); font-family: 'Space Mono', monospace;\n144:         }\n145: \n146:         .no-session { text-align: center; padding: 40px; color: var(--text-muted); }\n147:         .error-msg { color: var(--error); font-weight: 600; }\n148:     </style>\n149: </head>\n150: <body>\n151:     <div class=\"container\">\n152:         <header>\n153:             <h1><span>Agent</span>SON Viewer</h1>\n154:             <div class=\"controls\">\n155:                 <button id=\"layoutBtn\" class=\"btn btn-secondary\" disabled onclick=\"toggleLayout()\">Side-by-Side</button>\n156:                 <button id=\"sortBtn\" class=\"btn btn-secondary\" disabled onclick=\"toggleSort()\">Sort: Newest</button>\n157:                 <button id=\"downloadBtn\" class=\"btn btn-primary\" disabled onclick=\"downloadAgentSON()\">Download .AgentSON</button>\n158:                 <button id=\"clearBtn\" class=\"btn btn-danger\" disabled onclick=\"clearSession()\">Clear</button>\n159:             </div>\n160:             <div class=\"search-wrap\" id=\"searchWrap\">\n161:                 <input type=\"text\" id=\"searchBar\" placeholder=\"Filter entries...\" oninput=\"filterEntries()\">\n162:             </div>\n163:         </header>\n164: \n165:         <div class=\"drop-zone\" id=\"dropZone\">\n166:             <p>Drag &amp; drop an <strong>.AgentSON</strong> file here</p>\n167:             <p>or click to select</p>\n168:             <input type=\"file\" id=\"fileInput\" accept=\".AgentSON,.agentson,.json\">\n169:         </div>\n170: \n171:         <div id=\"content\">\n172:             <div class=\"no-session\">No session loaded. Drop a file to begin.</div>\n173:         </div>\n174:     </div>\n175: \n176:     <script>\n177:         let currentFileData = null;\n178:         let sortOrder = 'desc';\n179: \n180:         const dropZone = document.getElementById('dropZone');\n181:         const fileInput = document.getElementById('fileInput');\n182:         const contentEl = document.getElementById('content');\n183: \n184:         dropZone.addEventListener('click', () => fileInput.click());\n185: \n186:         dropZone.addEventListener('dragover', (e) => {\n187:             e.preventDefault();\n188:             dropZone.classList.add('dragover');\n189:         });\n190: \n191:         dropZone.addEventListener('dragleave', () => {\n192:             dropZone.classList.remove('dragover');\n193:         });\n194: \n195:         dropZone.addEventListener('drop', (e) => {\n196:             e.preventDefault();\n197:             dropZone.classList.remove('dragover');\n198:             const file = e.dataTransfer.files[0];\n199:             if (file) readFile(file);\n200:         });\n201: \n202:         fileInput.addEventListener('change', (e) => {\n203:             const file = e.target.files[0];\n204:             if (file) readFile(file);\n205:         });\n206: \n207:         function readFile(file) {\n208:             const name = file.name.toLowerCase();\n209:             const validExt = name.endsWith('.agentson') || name.endsWith('.json');\n210:             if (!validExt) {\n211:                 contentEl.innerHTML = '<div class=\"no-session error-msg\">Invalid file type. Please use an .AgentSON or .json file.</div>';\n212:                 return;\n213:             }\n214:             const reader = new FileReader();\n215:             reader.onload = (e) => {\n216:                 try {\n217:                     const data = JSON.parse(e.target.result);\n218:                     if (!data.entries) {\n219:                         throw new Error('Valid JSON but not AgentSON schema (missing \"entries\").');\n220:                     }\n221:                     currentFileData = data;\n222:                     sortOrder = 'desc';\n223:                     renderSession(data);\n224:                     document.getElementById('downloadBtn').disabled = false;\n225:                     document.getElementById('layoutBtn').disabled = false;\n226:                     document.getElementById('sortBtn').disabled = false;\n227:                     document.getElementById('clearBtn').disabled = false;\n228:                     document.getElementById('searchWrap').classList.add('active');\n229:                     document.getElementById('sortBtn').textContent = 'Sort: Newest';\n230:                 } catch (err) {\n231:                     contentEl.innerHTML = '<div class=\"no-session error-msg\">Error: ' + escapeHtml(err.message) + '</div>';\n232:                 }\n233:             };\n234:             reader.readAsText(file);\n235:         }\n236: \n237:         function renderSession(data) {\n238:             const tool = data.tool || {};\n239:             const agent = data.agent || {};\n240:             const entries = data.entries || [];\n241:             const metrics = data.metrics || {};\n242:             const displayEntries = sortOrder === 'desc' ? [...entries].reverse() : entries;\n243: \n244:             let html = '<details class=\"json-preview\"><summary>View Raw JSON Metadata</summary><pre>' +\n245:                 escapeHtml(JSON.stringify({ id: data.id, tool: tool, agent: agent, metrics: metrics, started_at: data.started_at }, null, 2)) +\n246:                 '</pre></details>';\n247: \n248:             html += '<div class=\"session-info\"><h2>Session: ' + escapeHtml(data.id || 'Unknown') + '</h2><div class=\"meta-grid\">';\n249:             html += '<div class=\"meta-item\"><span class=\"label\">Tool:</span> ' + escapeHtml(tool.name || 'Unknown') + '</div>';\n250:             html += '<div class=\"meta-item\"><span class=\"label\">Agent:</span> ' + escapeHtml(agent.name || 'Unknown') + '</div>';\n251:             html += '<div class=\"meta-item\"><span class=\"label\">Model:</span> ' + escapeHtml(agent.model || 'Unknown') + '</div>';\n252:             html += '<div class=\"meta-item\"><span class=\"label\">Started:</span> ' + escapeHtml(data.started_at || 'Unknown') + '</div>';\n253:             html += '<div class=\"meta-item\"><span class=\"label\">Entries:</span> ' + entries.length + '</div>';\n254:             html += '</div></div>';\n255: \n256:             html += '<div class=\"entries\" id=\"entriesContainer\">';\n257:             for (const entry of displayEntries) {\n258:                 const type = entry.type || entry.role || 'unknown';\n259:                 const typeClass = 'type-' + type.replace(/[^a-z-]/g, '-');\n260:                 let role = type.toLowerCase();\n261:                 if (role.startsWith('user')) role = 'user';\n262:                 else if (role === 'thought' || role === 'answer') role = 'assistant';\n263:                 else if (role === 'action' || role.startsWith('tool')) role = 'tool';\n264:                 else if (role === 'side-effect' || role === 'error') role = 'error';\n265:                 else if (role === 'system' || role === 'context') role = 'system';\n266:                 const roleClass = 'role-' + role;\n267: \n268:                 let body = '';\n269:                 if (entry.text) body += escapeHtml(entry.text);\n270:                 if (entry.code) body += '<pre><code>' + escapeHtml(entry.code) + '</code></pre>';\n271:                 if (entry.output) body += '<div class=\"label\" style=\"color:var(--text-muted);margin-top:4px\">Output:</div><pre><code>' + escapeHtml(entry.output) + '</code></pre>';\n272:                 if (entry.query) body += escapeHtml(entry.query);\n273: \n274:                 html += '<div class=\"entry ' + roleClass + '\">';\n275:                 html += '<div class=\"entry-header\"><span class=\"entry-type ' + typeClass + '\">' + escapeHtml(type) + '</span>';\n276:                 html += '<button class=\"copy-btn\" onclick=\"copyEntry(this)\">Copy</button></div>';\n277:                 html += '<div class=\"entry-content\">' + (body || '<em>No content</em>') + '</div>';\n278:                 html += '</div>';\n279:             }\n280:             html += '</div>';\n281: \n282:             if (metrics.total_tokens || metrics.cost) {\n283:                 html += '<div class=\"metrics\">';\n284:                 if (metrics.total_tokens) html += '<span>Tokens: ' + metrics.total_tokens.toLocaleString() + '</span>';\n285:                 if (metrics.cost) html += '<span>Cost: $' + metrics.cost.toFixed(4) + '</span>';\n286:                 if (metrics.total_turns) html += '<span>Turns: ' + metrics.total_turns + '</span>';\n287:                 if (metrics.total_tool_calls) html += '<span>Tool Calls: ' + metrics.total_tool_calls + '</span>';\n288:                 html += '</div>';\n289:             }\n290: \n291:             contentEl.innerHTML = html;\n292:         }\n293: \n294:         function escapeHtml(text) {\n295:             const div = document.createElement('div');\n296:             div.textContent = text;\n297:             return div.innerHTML;\n298:         }\n299: \n300:         function filterEntries() {\n301:             const query = document.getElementById('searchBar').value.toLowerCase();\n302:             const entries = document.querySelectorAll('.entry');\n303:             entries.forEach(entry => {\n304:                 entry.style.display = entry.innerText.toLowerCase().includes(query) ? '' : 'none';\n305:             });\n306:         }\n307: \n308:         function toggleLayout() {\n309:             const container = document.getElementById('entriesContainer');\n310:             if (!container) return;\n311:             const btn = document.getElementById('layoutBtn');\n312:             if (container.classList.contains('side-by-side')) {\n313:                 container.classList.remove('side-by-side');\n314:                 btn.textContent = 'Side-by-Side';\n315:             } else {\n316:                 container.classList.add('side-by-side');\n317:                 btn.textContent = 'Stacked';\n318:             }\n319:         }\n320: \n321:         function toggleSort() {\n322:             if (!currentFileData) return;\n323:             sortOrder = sortOrder === 'asc' ? 'desc' : 'asc';\n324:             document.getElementById('sortBtn').textContent = sortOrder === 'desc' ? 'Sort: Newest' : 'Sort: Oldest';\n325:             renderSession(currentFileData);\n326:         }\n327: \n328:         function copyEntry(btn) {\n329:             const entryContent = btn.closest('.entry').querySelector('.entry-content').innerText;\n330:             navigator.clipboard.writeText(entryContent).then(() => {\n331:                 btn.textContent = 'Copied!';\n332:                 btn.classList.add('copied');\n333:                 setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);\n334:             });\n335:         }\n336: \n337:         function downloadAgentSON() {\n338:             if (!currentFileData) return;\n339:             const blob = new Blob([JSON.stringify(currentFileData, null, 4)], { type: 'application/json' });\n340:             const url = URL.createObjectURL(blob);\n341:             const a = document.createElement('a');\n342:             a.href = url;\n343:             a.download = (currentFileData.id || 'session') + '.AgentSON';\n344:             document.body.appendChild(a);\n345:             a.click();\n346:             document.body.removeChild(a);\n347:             URL.revokeObjectURL(url);\n348:         }\n349: \n350:         function clearSession() {\n351:             currentFileData = null;\n352:             contentEl.innerHTML = '<div class=\"no-session\">No session loaded. Drop a file to begin.</div>';\n353:             document.getElementById('downloadBtn').disabled = true;\n354:             document.getElementById('layoutBtn').disabled = true;\n355:             document.getElementById('sortBtn').disabled = true;\n356:             document.getElementById('clearBtn').disabled = true;\n357:             document.getElementById('searchWrap').classList.remove('active');\n358:             document.getElementById('searchBar').value = '';\n359:             fileInput.value = '';\n360:         }\n361:     </script>\n362: </body>\n363: </html>\n\n(End of file - total 363 lines)\n</content>",
