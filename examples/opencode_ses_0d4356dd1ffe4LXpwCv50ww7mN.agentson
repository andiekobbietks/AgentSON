    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"#Requires -RunAsAdministrator\\n<#\\n.SYNOPSIS\\n    Quick-fix script for WHEA_UNCORRECTABLE_ERROR on HP OMEN\\n.DESCRIPTION\\n    Addresses the most common cause: Intel XTU undervolt instability\\n    and ensures proper dump file configuration.\\n#>\\n\\nparam(\\n    [switch]$UndoOnly,\\n    [switch]$SkipConfirm\\n)\\n\\n$Host.UI.RawUI.WindowTitle = \\\"WHEA Quick-Fix Tool\\\"\\n\\nfunction Write-Step($num, $title) {\\n    Write-Host \\\"`n[$num] $title\\\" -ForegroundColor Cyan\\n}\\n\\nfunction Write-Ok($msg) {\\n    Write-Host \\\"    [OK] $msg\\\" -ForegroundColor Green\\n}\\n\\nfunction Write-Warn($msg) {\\n    Write-Host \\\"    [!] $msg\\\" -ForegroundColor Yellow\\n}\\n\\nfunction Write-Err($msg) {\\n    Write-Host \\\"    [X] $msg\\\" -ForegroundColor Red\\n}\\n\\nWrite-Host @\\\"\\n\\n==============================================\\n  WHEA_UNCORRECTABLE_ERROR QUICK-FIX TOOL\\n  HP OMEN 15-ce0xx Targeted Repair\\n==============================================\\n\\nThis tool addresses the most likely root cause:\\n  Intel XTU undervolt/overclock instability.\\n\\n\\\"@ -ForegroundColor Yellow\\n\\nif (-not $SkipConfirm) {\\n    $confirm = Read-Host \\\"Proceed? (Y/N)\\\"\\n    if ($confirm -notin @(\\\"Y\\\",\\\"y\\\",\\\"Yes\\\",\\\"yes\\\")) {\\n        Write-Host \\\"Aborted.\\\" -ForegroundColor Red\\n        return\\n    }\\n}\\n\\n# \\u2500\\u2500 Step 1: Uninstall Intel XTU \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Step 1 \\\"UNINSTALL INTEL XTU\\\"\\n\\n$xtu = Get-WmiObject Win32_Product -ErrorAction SilentlyContinue | Where-Object { $_.Name -match \\\"Intel.*Extreme Tuning|XTU\\\" }\\nif ($xtu) {\\n    Write-Warn \\\"Intel XTU found: $($xtu.Name)\\\"\\n    if (-not $UndoOnly) {\\n        $xtu | ForEach-Object {\\n            Write-Host \\\"    Uninstalling: $($_.Name)...\\\" -ForegroundColor White\\n            $_.Uninstall() | Out-Null\\n            Write-Ok \\\"Uninstalled: $($_.Name)\\\"\\n        }\\n    } else {\\n        Write-Warn \\\"Use [Programs and Features] to manually uninstall XTU\\\"\\n    }\\n} else {\\n    Write-Ok \\\"Intel XTU not installed\\\"\\n}\\n\\n# \\u2500\\u2500 Step 2: Stop XTU Service \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Step 2 \\\"STOP & DISABLE XTU SERVICE\\\"\\n\\n$svc = Get-Service -Name \\\"*XTU*\\\" -ErrorAction SilentlyContinue\\nif ($svc) {\\n    Stop-Service -Name $svc.Name -Force -ErrorAction SilentlyContinue\\n    Set-Service -Name $svc.Name -StartupType Disabled -ErrorAction SilentlyContinue\\n    Write-Ok \\\"XTU service stopped and disabled\\\"\\n} else {\\n    Write-Ok \\\"No XTU service running\\\"\\n}\\n\\n# \\u2500\\u2500 Step 3: Reset BIOS to Defaults \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Step 3 \\\"BIOS RESET GUIDANCE\\\"\\n\\nWrite-Host @\\\"\\n    To reset BIOS on HP OMEN:\\n    \\n    1. Restart your laptop\\n    2. Press F10 repeatedly during boot\\n    3. In BIOS Setup, press F9 (Load Setup Defaults)\\n    4. Press F10 (Save and Exit)\\n    5. Confirm with Yes\\n    \\n    This will:\\n    - Reset any overclocking/undervolt settings\\n    - Restore factory XMP/Memory profile\\n    - Reset CPU voltage to stock\\n\\\"@ -ForegroundColor White\\n\\n# \\u2500\\u2500 Step 4: Fix Dump File Configuration \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Step 4 \\\"FIX DUMP FILE CONFIGURATION\\\"\\n\\n$crashCtrl = \\\"HKLM:\\\\SYSTEM\\\\CurrentControlSet\\\\Control\\\\CrashControl\\\"\\n\\n# Ensure minidump is enabled\\nSet-ItemProperty -Path $crashCtrl -Name \\\"CrashDumpEnabled\\\" -Value 1 -Type DWord -Force\\nSet-ItemProperty -Path $crashCtrl -Name \\\"MinidumpDir\\\" -Value \\\"C:\\\\WINDOWS\\\\Minidump\\\" -Type ExpandString -Force\\nSet-ItemProperty -Path $crashCtrl -Name \\\"AutoReboot\\\" -Value 1 -Type DWord -Force\\nSet-ItemProperty -Path $crashCtrl -Name \\\"Overwrite\\\" -Value 1 -Type DWord -Force\\n\\n# Ensure Minidump directory exists\\nif (-not (Test-Path \\\"C:\\\\WINDOWS\\\\Minidump\\\")) {\\n    New-Item -Path \\\"C:\\\\WINDOWS\\\\Minidump\\\" -ItemType Directory -Force | Out-Null\\n}\\n\\nWrite-Ok \\\"Minidump configuration set (small dump enabled)\\\"\\nWrite-Ok \\\"AutoReboot enabled (no more stuck BSOD at 0%)\\\"\\n\\n# \\u2500\\u2500 Step 5: Verify Pagefile \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Step 5 \\\"CHECK PAGEFILE\\\"\\n\\n$pagefile = Get-CimInstance Win32_PageFileUsage -ErrorAction SilentlyContinue\\nif ($pagefile) {\\n    foreach ($pf in $pagefile) {\\n        $size = $pf.AllocatedBaseSize\\n        if ($size -lt 4096) {\\n            Write-Warn \\\"Pagefile is ${size} MB - may be too small for kernel dump\\\"\\n            Write-Host \\\"    Recommended: Set to System Managed or \\u2265 8192 MB\\\" -ForegroundColor White\\n        } else {\\n            Write-Ok \\\"Pagefile: ${size} MB (adequate)\\\"\\n        }\\n    }\\n} else {\\n    Write-Warn \\\"No pagefile detected - this WILL cause dump creation failures\\\"\\n}\\n\\n# \\u2500\\u2500 Step 6: Check for BIOS Updates \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Step 6 \\\"BIOS UPDATE CHECK\\\"\\n\\n$bios = Get-CimInstance Win32_BIOS\\nWrite-Host \\\"    Current BIOS: $($bios.SMBIOSBIOSVersion)\\\" -ForegroundColor White\\nWrite-Host \\\"    HP Support: https://support.hp.com/us-en/drivers\\\" -ForegroundColor White\\nWrite-Host \\\"    Search for your model: OMEN 15-ce0xx\\\" -ForegroundColor White\\n\\n# \\u2500\\u2500 Step 7: Run Memory Test \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Step 7 \\\"MEMORY DIAGNOSTIC\\\"\\n\\nWrite-Host @\\\"\\n    Run Windows Memory Diagnostic:\\n    \\n    1. Press Win+R, type: mdsched.exe\\n    2. Select \\\"Restart now and check for problems\\\"\\n    3. Let the test complete (10-15 minutes)\\n    4. Check results in Event Viewer > System > MemoryDiagnostics-Results\\n    \\n    Or run from PowerShell:\\n    mdsched.exe /f\\n\\\"@ -ForegroundColor White\\n\\n# \\u2500\\u2500 Summary \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Host @\\\"\\n\\n==============================================\\n  SUMMARY\\n==============================================\\n\\nCOMPLETED:\\n  [X] Identified Intel XTU as primary suspect\\n  [X] Fixed dump file configuration\\n  [X] Provided BIOS reset instructions\\n\\nNEXT STEPS:\\n  1. RESTART your PC now\\n  2. Enter BIOS (F10 at boot) and reset to defaults (F9)\\n  3. After Windows loads, uninstall Intel XTU\\n  4. Monitor for 24-48 hours\\n  5. If crashes persist, run Memory Diagnostic\\n\\nIf BSOD recurs after these steps:\\n  - Run: .\\\\WHEA_Diagnostic.ps1 -ExportReport\\n  - The report will help narrow down remaining causes\\n\\n==============================================\\n\\n\\\"@ -ForegroundColor Green\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\WHEA_QuickFix.ps1\"}",
      "output": "Wrote file successfully.",
