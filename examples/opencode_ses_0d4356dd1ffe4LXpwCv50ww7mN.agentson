    {
      "type": "action",
      "tool": "write",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\WHEA_Diagnostic.ps1\", \"content\": \"#Requires -RunAsAdministrator\\n<#\\n.SYNOPSIS\\n    Enterprise-grade WHEA_UNCORRECTABLE_ERROR diagnostic tool for HP OMEN 15-ce0xx\\n.DESCRIPTION\\n    Performs root cause analysis on WHEA BSOD errors including:\\n    - Event log analysis (WHEA-Logger, Kernel-Power, volmgr)\\n    - CPU/thermal state inspection\\n    - Intel XTU configuration check\\n    - Driver and firmware version audit\\n    - Dump file configuration verification\\n    - PCIe device health check\\n.NOTES\\n    Run as Administrator. Compatible with Windows 10/11.\\n#>\\n\\nparam(\\n    [switch]$ExportReport,\\n    [string]$OutputPath = \\\"$env:USERPROFILE\\\\Documents\\\\WHEA_Report_$(Get-Date -Format 'yyyyMMdd_HHmmss').txt\\\"\\n)\\n\\n$Report = @()\\n$Report += \\\"=\\\" * 70\\n$Report += \\\"  WHEA_UNCORRECTABLE_ERROR ENTERPRISE DIAGNOSTIC REPORT\\\"\\n$Report += \\\"  Generated: $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')\\\"\\n$Report += \\\"  Host: $env:COMPUTERNAME\\\"\\n$Report += \\\"=\\\" * 70\\n$Report += \\\"\\\"\\n\\nfunction Write-Section($title) {\\n    $Report += \\\"\\\"\\n    $Report += \\\"-\\\" * 60\\n    $Report += \\\"  $title\\\"\\n    $Report += \\\"-\\\" * 60\\n    Write-Host \\\"`n[*] $title\\\" -ForegroundColor Cyan\\n}\\n\\nfunction Write-Finding($severity, $detail) {\\n    $icon = switch ($severity) {\\n        \\\"CRITICAL\\\" { \\\"[!!]\\\" }\\n        \\\"WARNING\\\"  { \\\"[!] \\\" }\\n        \\\"INFO\\\"     { \\\"[i] \\\" }\\n        \\\"OK\\\"       { \\\"[OK]\\\" }\\n        default    { \\\"    \\\" }\\n    }\\n    $color = switch ($severity) {\\n        \\\"CRITICAL\\\" { \\\"Red\\\" }\\n        \\\"WARNING\\\"  { \\\"Yellow\\\" }\\n        \\\"INFO\\\"     { \\\"White\\\" }\\n        \\\"OK\\\"       { \\\"Green\\\" }\\n        default    { \\\"Gray\\\" }\\n    }\\n    $line = \\\"    $icon $detail\\\"\\n    $Report += $line\\n    Write-Host $line -ForegroundColor $color\\n}\\n\\n# \\u2500\\u2500 Section 1: System Identification \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Section \\\"SYSTEM IDENTIFICATION\\\"\\n\\n$cs = Get-CimInstance Win32_ComputerSystem\\n$mb = Get-CimInstance Win32_BaseBoard\\n$bios = Get-CimInstance Win32_BIOS\\n$cpu = Get-CimInstance Win32_Processor\\n\\nWrite-Finding \\\"INFO\\\" \\\"Manufacturer: $($cs.Manufacturer) $($cs.Model)\\\"\\nWrite-Finding \\\"INFO\\\" \\\"Motherboard: $($mb.Product) (S/N: $($mb.SerialNumber))\\\"\\nWrite-Finding \\\"INFO\\\" \\\"BIOS: $($bios.Manufacturer) $($bios.SMBIOSBIOSVersion) v$($bios.Version)\\\"\\nWrite-Finding \\\"INFO\\\" \\\"CPU: $($cpu.Name)\\\"\\nWrite-Finding \\\"INFO\\\" \\\"Cores/Threads: $($cpu.NumberOfCores)/$($cpu.NumberOfLogicalProcessors)\\\"\\nWrite-Finding \\\"INFO\\\" \\\"Max Clock: $($cpu.MaxClockSpeed) MHz | Current: $($cpu.CurrentClockSpeed) MHz\\\"\\n\\n# \\u2500\\u2500 Section 2: WHEA Event Analysis \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Section \\\"WHEA EVENT LOG ANALYSIS\\\"\\n\\n$wheaEvents = @()\\ntry {\\n    $wheaEvents = Get-WinEvent -LogName System -MaxEvents 2000 -ErrorAction Stop |\\n        Where-Object { $_.ProviderName -match \\\"WHEA|Microsoft-Windows-WHEA-Logger\\\" } |\\n        Select-Object TimeCreated, Id, Message\\n} catch {\\n    Write-Finding \\\"INFO\\\" \\\"No WHEA-Logger events found in System log (may have been cleared)\\\"\\n}\\n\\n$kernelPower41 = @()\\ntry {\\n    $kernelPower41 = Get-WinEvent -LogName System -MaxEvents 2000 -ErrorAction Stop |\\n        Where-Object { $_.Id -eq 41 -and $_.ProviderName -eq \\\"Microsoft-Windows-Kernel-Power\\\" } |\\n        Select-Object TimeCreated, Message\\n} catch {}\\n\\n$volmgr161 = @()\\ntry {\\n    $volmgr161 = Get-WinEvent -LogName System -MaxEvents 2000 -ErrorAction Stop |\\n        Where-Object { $_.Id -eq 161 -and $_.ProviderName -eq \\\"volmgr\\\" } |\\n        Select-Object TimeCreated, Message\\n} catch {}\\n\\n$event6008 = @()\\ntry {\\n    $event6008 = Get-WinEvent -LogName System -MaxEvents 2000 -ErrorAction Stop |\\n        Where-Object { $_.Id -eq 6008 } |\\n        Select-Object TimeCreated, Message\\n} catch {}\\n\\nif ($wheaEvents.Count -gt 0) {\\n    Write-Finding \\\"CRITICAL\\\" \\\"Found $($wheaEvents.Count) WHEA-Logger events\\\"\\n    $wheaEvents | Select-Object -First 10 | ForEach-Object {\\n        Write-Finding \\\"CRITICAL\\\" \\\"  [$($_.TimeCreated)] EventID $($_.Id): $($_.Message.Substring(0, [Math]::Min(120, $_.Message.Length)))\\\"\\n    }\\n} else {\\n    Write-Finding \\\"INFO\\\" \\\"No WHEA-Logger events detected (events may have been cleared or BSOD occurred before logging)\\\"\\n}\\n\\nif ($kernelPower41.Count -gt 0) {\\n    Write-Finding \\\"CRITICAL\\\" \\\"Found $($kernelPower41.Count) Kernel-Power Event 41 (unexpected shutdowns)\\\"\\n    $kernelPower41 | Select-Object -First 5 | ForEach-Object {\\n        Write-Finding \\\"CRITICAL\\\" \\\"  [$($_.TimeCreated)] System crashed without clean shutdown\\\"\\n    }\\n} else {\\n    Write-Finding \\\"OK\\\" \\\"No Kernel-Power Event 41 found\\\"\\n}\\n\\nif ($volmgr161.Count -gt 0) {\\n    Write-Finding \\\"WARNING\\\" \\\"Found $($volmgr161.Count) volmgr Event 161 (dump file creation failures)\\\"\\n    Write-Finding \\\"WARNING\\\" \\\"Dump files are NOT being created - BSOD will appear stuck at 0%\\\"\\n    Write-Finding \\\"INFO\\\" \\\"This explains why the BSOD screen shows '0% complete' and never progresses\\\"\\n} else {\\n    Write-Finding \\\"OK\\\" \\\"No dump creation failures detected\\\"\\n}\\n\\nif ($event6008.Count -gt 0) {\\n    Write-Finding \\\"CRITICAL\\\" \\\"Found $($event6008.Count) unexpected shutdown events\\\"\\n}\\n\\n# \\u2500\\u2500 Section 3: Crash Dump Configuration \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Section \\\"CRASH DUMP CONFIGURATION\\\"\\n\\ntry {\\n    $crashCtrl = Get-ItemProperty \\\"HKLM:\\\\SYSTEM\\\\CurrentControlSet\\\\Control\\\\CrashControl\\\" -ErrorAction Stop\\n    $dumpEnabled = $crashCtrl.CrashDumpEnabled\\n    $dumpType = switch ($dumpEnabled) {\\n        0 { \\\"None (No dump)\\\" }\\n        1 { \\\"Small memory dump (256KB)\\\" }\\n        2 { \\\"Kernel memory dump\\\" }\\n        3 { \\\"Complete memory dump\\\" }\\n        7 { \\\"Automatic\\\" }\\n        default { \\\"Unknown ($dumpEnabled)\\\" }\\n    }\\n    Write-Finding \\\"INFO\\\" \\\"CrashDumpEnabled: $dumpEnabled ($dumpType)\\\"\\n    Write-Finding \\\"INFO\\\" \\\"MiniDump directory: $($crashCtrl.MinidumpDir)\\\"\\n    Write-Finding \\\"INFO\\\" \\\"AutoReboot: $($crashCtrl.AutoReboot)\\\"\\n\\n    if ($dumpEnabled -eq 7) {\\n        Write-Finding \\\"WARNING\\\" \\\"Automatic dump may fail if pagefile is too small or on wrong drive\\\"\\n        Write-Finding \\\"INFO\\\" \\\"Ensure system drive (C:) has \\u2265 1.5x RAM pagefile allocated\\\"\\n    }\\n\\n    $pagefile = Get-CimInstance Win32_PageFileUsage -ErrorAction SilentlyContinue\\n    if ($pagefile) {\\n        $pagefile | ForEach-Object {\\n            Write-Finding \\\"INFO\\\" \\\"Pagefile: $($_.Name) - Allocated: $($_.AllocatedBaseSize) MB, Current: $($_.CurrentUsage) MB\\\"\\n            if ($_.AllocatedBaseSize -lt ($cpu.NumberOfCores * 1024 / 1024)) {\\n                Write-Finding \\\"WARNING\\\" \\\"Pagefile may be undersized for complete dump\\\"\\n            }\\n        }\\n    } else {\\n        Write-Finding \\\"WARNING\\\" \\\"No pagefile detected - dump creation will fail\\\"\\n    }\\n} catch {\\n    Write-Finding \\\"WARNING\\\" \\\"Could not read crash control registry\\\"\\n}\\n\\n# \\u2500\\u2500 Section 4: Intel XTU Analysis \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Section \\\"INTEL XTU / OVERCLOCKING ANALYSIS\\\"\\n\\n$xtuService = Get-Service -Name \\\"*XTU*\\\" -ErrorAction SilentlyContinue\\nif ($xtuService) {\\n    Write-Finding \\\"CRITICAL\\\" \\\"Intel XTU service detected: $($xtuService.Name) (Status: $($xtuService.Status))\\\"\\n    if ($xtuService.Status -eq \\\"Stopped\\\" -or $xtuService.Status -eq \\\"StoppedPending\\\") {\\n        Write-Finding \\\"CRITICAL\\\" \\\"XTU service is STOPPED/FAILED - this is a major red flag\\\"\\n        Write-Finding \\\"CRITICAL\\\" \\\"XTU may have applied unstable undervolt/overclock settings\\\"\\n        Write-Finding \\\"INFO\\\" \\\"Undervolting via XTU is the #1 cause of WHEA_UNCORRECTABLE_ERROR on locked CPUs\\\"\\n    }\\n} else {\\n    Write-Finding \\\"INFO\\\" \\\"Intel XTU not detected\\\"\\n}\\n\\n# Check for other overclocking tools\\n$ocTools = Get-WmiObject Win32_Product -ErrorAction SilentlyContinue |\\n    Where-Object { $_.Name -match \\\"XTU|ThrottleStop|MSI Afterburner|EVGA Precision|AMD Ryzen Master\\\" } |\\n    Select-Object Name, Version\\nif ($ocTools) {\\n    Write-Finding \\\"WARNING\\\" \\\"Overclocking/tuning software detected:\\\"\\n    $ocTools | ForEach-Object { Write-Finding \\\"WARNING\\\" \\\"  $($_.Name) v$($_.Version)\\\" }\\n}\\n\\n# CPU Throttling State\\n$thermal = Get-CimInstance MSAcpi_ThermalZoneTemperature -Namespace \\\"root/wmi\\\" -ErrorAction SilentlyContinue\\nif ($thermal) {\\n    Write-Finding \\\"INFO\\\" \\\"Thermal zones detected: $($thermal.Count)\\\"\\n    $thermal | ForEach-Object {\\n        $tempC = [math]::Round(($_.CurrentTemperature - 2732) / 10, 1)\\n        $status = if ($tempC -gt 90) { \\\"CRITICAL\\\" } elseif ($tempC -gt 75) { \\\"WARNING\\\" } else { \\\"OK\\\" }\\n        Write-Finding $status \\\"$($_.InstanceName): ${tempC}\\u00b0C\\\"\\n    }\\n} else {\\n    Write-Finding \\\"INFO\\\" \\\"WMI thermal zones not available - use HWiNFO64 for accurate temps\\\"\\n}\\n\\n# \\u2500\\u2500 Section 5: PCIe Device Health \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Section \\\"PCIe DEVICE HEALTH\\\"\\n\\n$pcieDevices = Get-CimInstance Win32_PnPEntity | Where-Object { $_.PNPClass -eq \\\"Display\\\" -or $_.PNPClass -eq \\\"SCSIAdapter\\\" -or $_.DeviceID -match \\\"PCI\\\" }\\n$pcieDevices | ForEach-Object {\\n    $status = if ($_.Status -eq \\\"OK\\\") { \\\"OK\\\" } else { \\\"WARNING\\\" }\\n    Write-Finding $status \\\"PCI Device: $($_.Name) [Status: $($_.Status)]\\\"\\n    if ($_.ConfigManagerErrorCode -ne 0) {\\n        Write-Finding \\\"CRITICAL\\\" \\\"  Error Code: $($_.ConfigManagerErrorCode) - $($_.ConfigManagerErrorDesc)\\\"\\n    }\\n}\\n\\n# Check for WHEA PCIe errors in event log\\n$pcieErrors = @()\\ntry {\\n    $pcieErrors = Get-WinEvent -LogName System -MaxEvents 1000 -ErrorAction Stop |\\n        Where-Object { $_.Message -match \\\"PCI Express|PCIe|Advanced Error Reporting\\\" } |\\n        Select-Object -First 5\\n} catch {}\\nif ($pcieErrors.Count -gt 0) {\\n    Write-Finding \\\"CRITICAL\\\" \\\"PCIe errors detected in event log\\\"\\n    $pcieErrors | ForEach-Object {\\n        Write-Finding \\\"CRITICAL\\\" \\\"  [$($_.TimeCreated)] $($_.Message.Substring(0, [Math]::Min(100, $_.Message.Length)))\\\"\\n    }\\n}\\n\\n# \\u2500\\u2500 Section 6: Driver & Firmware Audit \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Section \\\"DRIVER & FIRMWARE AUDIT\\\"\\n\\n$gpu = Get-CimInstance Win32_VideoController\\n$gpu | ForEach-Object {\\n    Write-Finding \\\"INFO\\\" \\\"GPU: $($_.Name) Driver: $($_.DriverVersion)\\\"\\n}\\n\\n$storage = Get-CimInstance Win32_DiskDrive\\n$storage | ForEach-Object {\\n    Write-Finding \\\"INFO\\\" \\\"Storage: $($_.Model) [$($_.InterfaceType)] Status: $($_.Status)\\\"\\n}\\n\\n# \\u2500\\u2500 Section 7: Memory Health \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Section \\\"MEMORY HEALTH\\\"\\n\\n$ram = Get-CimInstance Win32_PhysicalMemory\\n$totalRAM = ($ram | Measure-Object -Property Capacity -Sum).Sum / 1GB\\nWrite-Finding \\\"INFO\\\" \\\"Total RAM: $([math]::Round($totalRAM, 1)) GB\\\"\\nWrite-Finding \\\"INFO\\\" \\\"DIMM slots: $($ram.Count)\\\"\\n$ram | ForEach-Object {\\n    $speed = if ($_.Speed) { \\\"$($_.Speed) MHz\\\" } else { \\\"Unknown\\\" }\\n    Write-Finding \\\"INFO\\\" \\\"  Slot: $($_.BankLabel) - $([math]::Round($_.Capacity/1GB,1)) GB - $speed - Manuf: $($_.Manufacturer)\\\"\\n}\\n\\n# Check for memory errors in event log\\n$memErrors = @()\\ntry {\\n    $memErrors = Get-WinEvent -LogName System -MaxEvents 500 -ErrorAction Stop |\\n        Where-Object { $_.Message -match \\\"memory|RAM|ECC|parity\\\" -and $_.Level -le 3 } |\\n        Select-Object -First 5\\n} catch {}\\nif ($memErrors.Count -gt 0) {\\n    Write-Finding \\\"WARNING\\\" \\\"Memory-related errors found in event log\\\"\\n}\\n\\n# \\u2500\\u2500 Section 8: PSU/Battery Health \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Section \\\"POWER SUPPLY / BATTERY HEALTH\\\"\\n\\n$battery = Get-CimInstance Win32_Battery -ErrorAction SilentlyContinue\\nif ($battery) {\\n    $battery | ForEach-Object {\\n        Write-Finding \\\"INFO\\\" \\\"Battery: $($_.Name)\\\"\\n        Write-Finding \\\"INFO\\\" \\\"  Charge: $($_.EstimatedChargeRemaining)% | Status: $($_.BatteryStatus)\\\"\\n        Write-Finding \\\"INFO\\\" \\\"  Chemistry: $($_.Chemistry) | Design Capacity: $($_.DesignCapacity) mWh\\\"\\n        if ($_.EstimatedChargeRemaining -lt 20) {\\n            Write-Finding \\\"WARNING\\\" \\\"Battery critically low - system may crash under load\\\"\\n        }\\n    }\\n}\\n\\n$powerEvents = @()\\ntry {\\n    $powerEvents = Get-WinEvent -LogName System -MaxEvents 200 -ErrorAction Stop |\\n        Where-Object { $_.ProviderName -eq \\\"Microsoft-Windows-Kernel-Power\\\" -and $_.Id -in @(41, 109, 42, 107) } |\\n        Select-Object -First 5\\n} catch {}\\nif ($powerEvents.Count -gt 0) {\\n    Write-Finding \\\"INFO\\\" \\\"Recent power transitions:\\\"\\n    $powerEvents | ForEach-Object {\\n        Write-Finding \\\"INFO\\\" \\\"  [$($_.TimeCreated)] EventID $($_.Id)\\\"\\n    }\\n}\\n\\n# \\u2500\\u2500 Section 9: Minidump Files \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Section \\\"MINIDUMP FILES\\\"\\n\\n$dumpDir = \\\"C:\\\\WINDOWS\\\\Minidump\\\"\\nif (Test-Path $dumpDir) {\\n    $dumps = Get-ChildItem $dumpDir -Filter \\\"*.dmp\\\" -ErrorAction SilentlyContinue | Sort-Object LastWriteTime -Descending\\n    if ($dumps.Count -gt 0) {\\n        Write-Finding \\\"INFO\\\" \\\"Found $($dumps.Count) minidump file(s):\\\"\\n        $dumps | Select-Object -First 10 | ForEach-Object {\\n            Write-Finding \\\"INFO\\\" \\\"  $($_.Name) - $($_.LastWriteTime) - $([math]::Round($_.Length/1KB)) KB\\\"\\n        }\\n        Write-Finding \\\"INFO\\\" \\\"Analyze dumps with: windbg -z `\\\"$dumpDir\\\\$($dumps[0].Name)`\\\" then run !analyze -v\\\"\\n    } else {\\n        Write-Finding \\\"WARNING\\\" \\\"No minidump files found in $dumpDir\\\"\\n    }\\n} else {\\n    Write-Finding \\\"WARNING\\\" \\\"Minidump directory does not exist\\\"\\n}\\n\\n# \\u2500\\u2500 Section 10: WHEA Error Source Summary \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nWrite-Section \\\"ROOT CAUSE ASSESSMENT\\\"\\n\\n$findings = @()\\n$score = 100  # Start at 100, deduct for issues\\n\\n# XTU Assessment\\nif ($xtuService) {\\n    $findings += \\\"XTU_UNSTABLE\\\"\\n    $score -= 35\\n}\\n\\n# Dump failures\\nif ($volmgr161.Count -gt 0) {\\n    $findings += \\\"DUMP_CREATION_FAILURE\\\"\\n    $score -= 5\\n}\\n\\n# Multiple crashes\\nif ($kernelPower41.Count -ge 2) {\\n    $findings += \\\"REPEATED_CRASHES\\\"\\n    $score -= 20\\n}\\n\\n# PCIe errors\\nif ($pcieErrors.Count -gt 0) {\\n    $findings += \\\"PCIE_ERRORS\\\"\\n    $score -= 15\\n}\\n\\n# Thermal issues\\nif ($thermal) {\\n    $hotZones = $thermal | Where-Object { ([math]::Round(($_.CurrentTemperature - 2732) / 10, 1)) -gt 85 }\\n    if ($hotZones) {\\n        $findings += \\\"THERMAL_THROTTLING\\\"\\n        $score -= 15\\n    }\\n}\\n\\n$report_score = [Math]::Max(0, $score)\\n\\n$Report += \\\"\\\"\\n$Report += \\\"    FIXABILITY SCORE: $report_score / 100\\\"\\n$Report += \\\"\\\"\\n$Report += \\\"    ROOT CAUSE CLASSIFICATION:\\\"\\nswitch -Wildcard ($findings -join \\\"|\\\") {\\n    \\\"*XTU_UNSTABLE*\\\" {\\n        $Report += \\\"      PRIMARY: Intel XTU undervolt/overclock instability\\\"\\n        $Report += \\\"      CONFIDENCE: 90%+ (XTU service failure is definitive)\\\"\\n        $Report += \\\"      SEVERITY: Software-configurable (no hardware damage)\\\"\\n    }\\n    \\\"*PCIE_ERRORS*\\\" {\\n        $Report += \\\"      SECONDARY: PCIe bus instability\\\"\\n        $Report += \\\"      CONFIDENCE: 70-85%\\\"\\n        $Report += \\\"      SEVERITY: May indicate GPU/NVMe slot issue\\\"\\n    }\\n    \\\"*THERMAL_THROTTLING*\\\" {\\n        $Report += \\\"      CONTRIBUTING: Thermal throttling detected\\\"\\n        $Report += \\\"      CONFIDENCE: 60-75%\\\"\\n    }\\n    default {\\n        $Report += \\\"      INCONCLUSIVE - Requires further testing\\\"\\n    }\\n}\\n\\n$Report += \\\"\\\"\\n$Report += \\\"    RECOMMENDED ACTIONS (in priority order):\\\"\\n$Report += \\\"      1. UNINSTALL Intel XTU completely (Control Panel > Programs)\\\"\\n$Report += \\\"      2. Reset BIOS to factory defaults (F10 at boot on HP)\\\"\\n$Report += \\\"      3. Update BIOS from HP support site (F.24 may have fixes)\\\"\\n$Report += \\\"      4. Run Windows Memory Diagnostic (mdsched.exe)\\\"\\n$Report += \\\"      5. Update NVIDIA GPU drivers from nvidia.com\\\"\\n$Report += \\\"      6. Clean laptop fans and reapply thermal paste if > 3 years old\\\"\\n\\n# \\u2500\\u2500 Output \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n$Report += \\\"\\\"\\n$Report += \\\"=\\\" * 70\\n$Report += \\\"  END OF REPORT\\\"\\n$Report += \\\"=\\\" * 70\\n\\n$Report | ForEach-Object { Write-Host $_ }\\n\\nif ($ExportReport) {\\n    $Report | Out-File -FilePath $OutputPath -Encoding UTF8\\n    Write-Host \\\"`n[+] Report exported to: $OutputPath\\\" -ForegroundColor Green\\n}\\n\"}",
      "output": "Wrote file successfully.",
      "status": "success",
      "timestamp": 1783146554222
    },
    {
      "type": "thought",
      "text": "Now let me create a Python temperature monitoring tool.",
      "timestamp": 1783146559304
    },
    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"\\nPC Health Monitor - Lightweight temperature and stability monitor\\nFor HP OMEN 15-ce0xx WHEA_UNCORRECTABLE_ERROR investigation\\n\\nUsage:\\n    python pc_health_monitor.py              # Single reading\\n    python pc_health_monitor.py --watch      # Continuous monitoring (5s interval)\\n    python pc_health_monitor.py --watch 10   # Custom interval (10s)\\n    python pc_health_monitor.py --log        # Log to CSV file\\n\\\"\\\"\\\"\\n\\nimport subprocess\\nimport sys\\nimport time\\nimport csv\\nimport os\\nfrom datetime import datetime\\nfrom pathlib import Path\\n\\nCSV_LOG = Path.home() / \\\"Documents\\\" / \\\"pc_health_log.csv\\\"\\n\\ndef get_temperatures():\\n    \\\"\\\"\\\"Get temperatures via OpenHardwareMonitor WMI or fallback to PowerShell.\\\"\\\"\\\"\\n    temps = {}\\n    \\n    # Method 1: Try OpenHardwareMonitor WMI\\n    try:\\n        import wmi\\n        w = wmi.WMI(namespace=\\\"root\\\\OpenHardwareMonitor\\\")\\n        sensors = w.Sensor()\\n        for sensor in sensors:\\n            if sensor.SensorType == \\\"Temperature\\\":\\n                temps[sensor.Name] = float(sensor.Value)\\n        if temps:\\n            return temps\\n    except Exception:\\n        pass\\n    \\n    # Method 2: Try LibreHardwareMonitorLib\\n    try:\\n        import clr\\n        clr.AddReference(r\\\"LibreHardwareMonitorLib\\\")\\n        from LibreHardwareMonitor.Hardware import Computer, SensorType\\n        \\n        computer = Computer()\\n        computer.IsCpuEnabled = True\\n        computer.IsGpuEnabled = True\\n        computer.IsStorageEnabled = True\\n        computer.Open()\\n        \\n        for hardware in computer.Hardware:\\n            hardware.Update()\\n            for sub in hardware.SubHardware:\\n                sub.Update()\\n            for sensor in hardware.Sensors:\\n                if sensor.SensorType == SensorType.Temperature and sensor.Value is not None:\\n                    temps[f\\\"{hardware.Name}/{sensor.Name}\\\"] = float(sensor.Value)\\n        computer.Close()\\n        if temps:\\n            return temps\\n    except Exception:\\n        pass\\n    \\n    # Method 3: PowerShell WMI fallback\\n    try:\\n        result = subprocess.run(\\n            [\\\"powershell\\\", \\\"-Command\\\",\\n             \\\"Get-CimInstance MSAcpi_ThermalZoneTemperature -Namespace 'root/wmi' -EA SilentlyContinue | \\\"\\n             \\\"Select-Object InstanceName, @{N='TempC';E={[math]::Round(($_.CurrentTemperature-2732)/10,1)}} | ConvertTo-Json\\\"],\\n            capture_output=True, text=True, timeout=10\\n        )\\n        if result.returncode == 0 and result.stdout.strip():\\n            import json\\n            data = json.loads(result.stdout)\\n            if isinstance(data, list):\\n                for item in data:\\n                    name = item.get(\\\"InstanceName\\\", \\\"Unknown\\\")\\n                    temp = item.get(\\\"TempC\\\", 0)\\n                    temps[name] = float(temp)\\n            elif isinstance(data, dict):\\n                temps[data.get(\\\"InstanceName\\\", \\\"Unknown\\\")] = float(data.get(\\\"TempC\\\", 0))\\n    except Exception:\\n        pass\\n    \\n    return temps\\n\\ndef get_cpu_usage():\\n    \\\"\\\"\\\"Get CPU usage percentage.\\\"\\\"\\\"\\n    try:\\n        result = subprocess.run(\\n            [\\\"powershell\\\", \\\"-Command\\\",\\n             \\\"(Get-CimInstance Win32_Processor).LoadPercentage\\\"],\\n            capture_output=True, text=True, timeout=10\\n        )\\n        if result.returncode == 0:\\n            return float(result.stdout.strip())\\n    except Exception:\\n        pass\\n    return None\\n\\ndef get_fan_speeds():\\n    \\\"\\\"\\\"Get fan speeds if available.\\\"\\\"\\\"\\n    try:\\n        result = subprocess.run(\\n            [\\\"powershell\\\", \\\"-Command\\\",\\n             \\\"Get-CimInstance MSAcpi_ThermalZoneTemperature -Namespace 'root/wmi' -EA SilentlyContinue | \\\"\\n             \\\"Select-Object InstanceName | ConvertTo-Json\\\"],\\n            capture_output=True, text=True, timeout=10\\n        )\\n    except Exception:\\n        pass\\n    return {}\\n\\ndef get_disk_health():\\n    \\\"\\\"\\\"Get basic disk health info.\\\"\\\"\\\"\\n    health = {}\\n    try:\\n        result = subprocess.run(\\n            [\\\"powershell\\\", \\\"-Command\\\",\\n             \\\"Get-PhysicalDisk | Select-Object FriendlyName, HealthStatus, Temperature | ConvertTo-Json\\\"],\\n            capture_output=True, text=True, timeout=10\\n        )\\n        if result.returncode == 0 and result.stdout.strip():\\n            import json\\n            data = json.loads(result.stdout)\\n            if isinstance(data, list):\\n                for disk in data:\\n                    health[disk.get(\\\"FriendlyName\\\", \\\"Unknown\\\")] = {\\n                        \\\"health\\\": disk.get(\\\"HealthStatus\\\", \\\"Unknown\\\"),\\n                        \\\"temp\\\": disk.get(\\\"Temperature\\\", \\\"N/A\\\")\\n                    }\\n            elif isinstance(data, dict):\\n                health[data.get(\\\"FriendlyName\\\", \\\"Unknown\\\")] = {\\n                    \\\"health\\\": data.get(\\\"HealthStatus\\\", \\\"Unknown\\\"),\\n                    \\\"temp\\\": data.get(\\\"Temperature\\\", \\\"N/A\\\")\\n                }\\n    except Exception:\\n        pass\\n    return health\\n\\ndef get_gpu_temp():\\n    \\\"\\\"\\\"Get GPU temperature via nvidia-smi if available.\\\"\\\"\\\"\\n    try:\\n        result = subprocess.run(\\n            [\\\"nvidia-smi\\\", \\\"--query-gpu=temperature.gpu,name\\\", \\\"--format=csv,noheader,nounits\\\"],\\n            capture_output=True, text=True, timeout=10\\n        )\\n        if result.returncode == 0:\\n            lines = result.stdout.strip().split(\\\"\\\\n\\\")\\n            for line in lines:\\n                parts = line.split(\\\", \\\")\\n                if len(parts) >= 2:\\n                    return {\\\"name\\\": parts[1], \\\"temp\\\": float(parts[0])}\\n    except Exception:\\n        pass\\n    return None\\n\\ndef get_xtu_status():\\n    \\\"\\\"\\\"Check Intel XTU service status.\\\"\\\"\\\"\\n    try:\\n        result = subprocess.run(\\n            [\\\"powershell\\\", \\\"-Command\\\",\\n             \\\"Get-Service -Name '*XTU*' -EA SilentlyContinue | Select-Object Name, Status, StartType | ConvertTo-Json\\\"],\\n            capture_output=True, text=True, timeout=10\\n        )\\n        if result.returncode == 0 and result.stdout.strip():\\n            import json\\n            data = json.loads(result.stdout)\\n            if isinstance(data, list):\\n                return data\\n            return [data]\\n    except Exception:\\n        pass\\n    return []\\n\\ndef get_recent_events(count=5):\\n    \\\"\\\"\\\"Get recent critical/error events.\\\"\\\"\\\"\\n    try:\\n        result = subprocess.run(\\n            [\\\"powershell\\\", \\\"-Command\\\",\\n             f\\\"Get-WinEvent -LogName System -MaxEvents {count} | \\\"\\n             \\\"Where-Object {{$_.Level -le 2 -or $_.Id -in @(41,161,6008)}} | \\\"\\n             \\\"Select-Object TimeCreated, Id, ProviderName, \\\"\\n             \\\"@{N='Msg';E={$_.Message.Substring(0,[Math]::Min(80,$_.Message.Length))}} | ConvertTo-Json\\\"],\\n            capture_output=True, text=True, timeout=15\\n        )\\n        if result.returncode == 0 and result.stdout.strip():\\n            import json\\n            return json.loads(result.stdout)\\n    except Exception:\\n        pass\\n    return []\\n\\ndef format_temp(temp):\\n    \\\"\\\"\\\"Format temperature with color coding.\\\"\\\"\\\"\\n    if temp is None:\\n        return \\\"N/A\\\"\\n    if temp > 90:\\n        return f\\\"{temp}\\u00b0C [CRITICAL]\\\"\\n    elif temp > 80:\\n        return f\\\"{temp}\\u00b0C [HOT]\\\"\\n    elif temp > 70:\\n        return f\\\"{temp}\\u00b0C [WARM]\\\"\\n    else:\\n        return f\\\"{temp}\\u00b0C [OK]\\\"\\n\\ndef print_dashboard():\\n    \\\"\\\"\\\"Print a single dashboard reading.\\\"\\\"\\\"\\n    now = datetime.now().strftime(\\\"%Y-%m-%d %H:%M:%S\\\")\\n    temps = get_temperatures()\\n    cpu_usage = get_cpu_usage()\\n    gpu = get_gpu_temp()\\n    disks = get_disk_health()\\n    xtu = get_xtu_status()\\n    \\n    print(f\\\"\\\\n{'='*60}\\\")\\n    print(f\\\"  PC HEALTH MONITOR - {now}\\\")\\n    print(f\\\"{'='*60}\\\")\\n    \\n    # Temperatures\\n    print(f\\\"\\\\n  TEMPERATURES:\\\")\\n    if temps:\\n        for name, temp in temps.items():\\n            print(f\\\"    {name}: {format_temp(temp)}\\\")\\n    else:\\n        print(\\\"    No thermal data available\\\")\\n        print(\\\"    (Install LibreHardwareMonitor or run as admin)\\\")\\n    \\n    if gpu:\\n        print(f\\\"    GPU ({gpu['name']}): {format_temp(gpu['temp'])}\\\")\\n    \\n    # CPU Usage\\n    if cpu_usage is not None:\\n        print(f\\\"\\\\n  CPU USAGE: {cpu_usage}%\\\")\\n    \\n    # Disk Health\\n    if disks:\\n        print(f\\\"\\\\n  DISK HEALTH:\\\")\\n        for name, info in disks.items():\\n            print(f\\\"    {name}: {info['health']}\\\")\\n    \\n    # XTU Status\\n    if xtu:\\n        print(f\\\"\\\\n  INTEL XTU STATUS:\\\")\\n        for svc in xtu:\\n            status = svc.get(\\\"Status\\\", \\\"Unknown\\\")\\n            warn = \\\" [UNSTABLE]\\\" if status in (\\\"Stopped\\\", \\\"StoppedPending\\\", \\\"StartPending\\\") else \\\"\\\"\\n            print(f\\\"    {svc.get('Name','?')}: {status}{warn}\\\")\\n    \\n    # Recent Events\\n    events = get_recent_events(3)\\n    if events:\\n        print(f\\\"\\\\n  RECENT CRITICAL EVENTS:\\\")\\n        if isinstance(events, list):\\n            for evt in events:\\n                if isinstance(evt, dict):\\n                    print(f\\\"    [{evt.get('TimeCreated','?')}] {evt.get('ProviderName','?')}\\\")\\n        else:\\n            evt = events\\n            print(f\\\"    [{evt.get('TimeCreated','?')}] {evt.get('ProviderName','?')}\\\")\\n    \\n    print(f\\\"\\\\n{'='*60}\\\")\\n    \\n    return temps\\n\\ndef log_to_csv(temps, cpu_usage, gpu):\\n    \\\"\\\"\\\"Append reading to CSV log.\\\"\\\"\\\"\\n    header_needed = not CSV_LOG.exists()\\n    \\n    with open(CSV_LOG, \\\"a\\\", newline=\\\"\\\") as f:\\n        writer = csv.writer(f)\\n        if header_needed:\\n            headers = [\\\"timestamp\\\"] + list(temps.keys()) + [\\\"cpu_usage\\\", \\\"gpu_temp\\\", \\\"gpu_name\\\"]\\n            writer.writerow(headers)\\n        \\n        row = [datetime.now().isoformat()]\\n        row += [temps.get(k, \\\"\\\") for k in temps.keys()]\\n        row.append(cpu_usage or \\\"\\\")\\n        row.append(gpu[\\\"temp\\\"] if gpu else \\\"\\\")\\n        row.append(gpu[\\\"name\\\"] if gpu else \\\"\\\")\\n        writer.writerow(row)\\n    \\n    print(f\\\"  [Logged to {CSV_LOG}]\\\")\\n\\ndef main():\\n    watch_mode = False\\n    interval = 5\\n    log_mode = False\\n    \\n    args = sys.argv[1:]\\n    i = 0\\n    while i < len(args):\\n        if args[i] == \\\"--watch\\\":\\n            watch_mode = True\\n            if i + 1 < len(args) and args[i + 1].isdigit():\\n                interval = int(args[i + 1])\\n                i += 1\\n        elif args[i] == \\\"--log\\\":\\n            log_mode = True\\n        elif args[i] == \\\"--help\\\":\\n            print(__doc__)\\n            return\\n        i += 1\\n    \\n    if watch_mode:\\n        print(f\\\"Monitoring every {interval}s. Press Ctrl+C to stop.\\\")\\n        try:\\n            while True:\\n                temps = print_dashboard()\\n                cpu = get_cpu_usage()\\n                gpu = get_gpu_temp()\\n                if log_mode:\\n                    log_to_csv(temps, cpu, gpu)\\n                time.sleep(interval)\\n        except KeyboardInterrupt:\\n            print(\\\"\\\\nMonitoring stopped.\\\")\\n    else:\\n        temps = print_dashboard()\\n        cpu = get_cpu_usage()\\n        gpu = get_gpu_temp()\\n        if log_mode:\\n            log_to_csv(temps, cpu, gpu)\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\pc_health_monitor.py\"}",
      "output": "Wrote file successfully.",
