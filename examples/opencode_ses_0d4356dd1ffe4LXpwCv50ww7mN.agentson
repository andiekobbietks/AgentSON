      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\pc_health_monitor.py\"}",
      "output": "<path>C:\\Users\\LLM-Test\\Documents\\pc_health_monitor.py</path>\n<type>file</type>\n<content>\n1: \"\"\"\n2: PC Health Monitor - No Stress Testing\n3: Monitors temperatures, disk health, and system events passively.\n4: Run: python pc_health_monitor.py\n5: \"\"\"\n6: \n7: import psutil\n8: import platform\n9: import subprocess\n10: import time\n11: import json\n12: from datetime import datetime, timedelta\n13: \n14: def get_cpu_temp_via_wmi():\n15:     \"\"\"Try to get CPU temperature via WMI (requires admin).\"\"\"\n16:     try:\n17:         import wmi\n18:         w = wmi.WMI(namespace=\"root\\\\OpenHardwareMonitor\")\n19:         sensors = w.Sensor()\n20:         temps = {}\n21:         for sensor in sensors:\n22:             if sensor.SensorType == \"Temperature\" and \"CPU\" in sensor.Name:\n23:                 temps[sensor.Name] = float(sensor.Value)\n24:         return temps\n25:     except Exception:\n26:         pass\n27:     \n28:     # Try MSAcpi_ThermalZoneTemperature\n29:     try:\n30:         result = subprocess.run(\n31:             ['powershell', '-Command', \n32:              'Get-CimInstance MSAcpi_ThermalZoneTemperature -Namespace \"root/wmi\" | Select-Object CurrentTemperature'],\n33:             capture_output=True, text=True, timeout=10\n34:         )\n35:         if result.returncode == 0 and result.stdout.strip():\n36:             lines = result.stdout.strip().split('\\n')\n37:             temps = {}\n38:             for i, line in enumerate(lines):\n39:                 try:\n40:                     val = int(line.strip().replace('CurrentTemperature : ', ''))\n41:                     temps[f\"ThermalZone_{i}\"] = (val / 10) - 273.15  # Convert from deciKelvin\n42:                 except ValueError:\n43:                     continue\n44:             return temps\n45:     except Exception:\n46:         pass\n47:     \n48:     return None\n49: \n50: def get_system_info():\n51:     \"\"\"Gather basic system information.\"\"\"\n52:     info = {\n53:         \"platform\": platform.platform(),\n54:         \"processor\": platform.processor(),\n55:         \"python\": platform.python_version(),\n56:         \"boot_time\": datetime.fromtimestamp(psutil.boot_time()).strftime(\"%Y-%m-%d %H:%M:%S\"),\n57:     }\n58:     \n59:     # CPU usage (non-stress, just current load)\n60:     cpu_percent = psutil.cpu_percent(interval=1)\n61:     cpu_freq = psutil.cpu_freq()\n62:     info[\"cpu_percent\"] = cpu_percent\n63:     info[\"cpu_freq_current\"] = cpu_freq.current if cpu_freq else \"N/A\"\n64:     info[\"cpu_freq_max\"] = cpu_freq.max if cpu_freq else \"N/A\"\n65:     info[\"cpu_count_physical\"] = psutil.cpu_count(logical=False)\n66:     info[\"cpu_count_logical\"] = psutil.cpu_count(logical=True)\n67:     \n68:     # Memory\n69:     mem = psutil.virtual_memory()\n70:     info[\"ram_total_gb\"] = round(mem.total / (1024**3), 1)\n71:     info[\"ram_used_gb\"] = round(mem.used / (1024**3), 1)\n72:     info[\"ram_percent\"] = mem.percent\n73:     \n74:     return info\n75: \n76: def check_disk_health():\n77:     \"\"\"Check disk health via SMART (non-destructive).\"\"\"\n78:     results = []\n79:     for part in psutil.disk_partitions():\n80:         try:\n81:             usage = psutil.disk_usage(part.mountpoint)\n82:             results.append({\n83:                 \"device\": part.device,\n84:                 \"mountpoint\": part.mountpoint,\n85:                 \"fstype\": part.fstype,\n86:                 \"total_gb\": round(usage.total / (1024**3), 1),\n87:                 \"used_gb\": round(usage.used / (1024**3), 1),\n88:                 \"percent\": usage.percent,\n89:             })\n90:         except PermissionError:\n91:             continue\n92:     return results\n93: \n94: def check_recent_events():\n95:     \"\"\"Check for WHEA and critical system events.\"\"\"\n96:     try:\n97:         result = subprocess.run(\n98:             ['powershell', '-Command', \n99:              'Get-EventLog -LogName System -Newest 500 -EntryType Error 2>$null | '\n100:              'Where-Object { $_.Source -like \"*WHEA*\" -or $_.Source -like \"*Kernel-Power*\" -or '\n101:              '$_.Source -like \"*stornvme*\" } | '\n102:              'Select-Object TimeGenerated, Source, InstanceID | Format-Table -AutoSize'],\n103:             capture_output=True, text=True, timeout=15\n104:         )\n105:         return result.stdout if result.stdout else \"No critical events found.\"\n106:     except Exception as e:\n107:         return f\"Could not query events: {e}\"\n108: \n109: def get_temperature_readings():\n110:     \"\"\"Attempt multiple methods to read temperatures.\"\"\"\n111:     temps = {}\n112:     \n113:     # Method 1: psutil (limited on Windows)\n114:     try:\n115:         temps_psutil = psutil.sensors_temperatures()\n116:         if temps_psutil:\n117:             for name, entries in temps_psutil.items():\n118:                 for entry in entries:\n119:                     temps[f\"{name}_{entry.label or 'default'}\"] = entry.current\n120:     except (AttributeError, Exception):\n121:         pass\n122:     \n123:     # Method 2: WMI thermal zones\n124:     if not temps:\n125:         wmi_temps = get_cpu_temp_via_wmi()\n126:         if wmi_temps:\n127:             temps.update(wmi_temps)\n128:     \n129:     return temps if temps else {\"status\": \"Temperature sensors not accessible without admin privileges or OpenHardwareMonitor/LibreHardwareMonitor\"}\n130: \n131: def assess_health(info, disks, temps):\n132:     \"\"\"Generate health assessment and recommendations.\"\"\"\n133:     issues = []\n134:     recommendations = []\n135:     \n136:     # CPU assessment\n137:     if info[\"cpu_percent\"] > 90:\n138:         issues.append(\"CPU usage is very high at idle - possible background process issue\")\n139:     if info[\"ram_percent\"] > 85:\n140:         issues.append(\"RAM usage is critically high - may cause instability\")\n141:     elif info[\"ram_percent\"] > 70:\n142:         recommendations.append(\"RAM usage is elevated - monitor for memory leaks\")\n143:     \n144:     # Disk assessment\n145:     for disk in disks:\n146:         if disk[\"percent\"] > 90:\n147:             issues.append(f\"Drive {disk['device']} is {disk['percent']}% full - low disk space causes instability\")\n148:         if disk[\"total_gb\"] < 100 and disk[\"fstype\"] == \"NTFS\":\n149:             recommendations.append(f\"Drive {disk['device']} is small ({disk['total_gb']}GB) - consider扩容\")\n150:     \n151:     # Temperature assessment (if available)\n152:     if isinstance(temps, dict) and \"status\" not in temps:\n153:         for sensor, temp in temps.items():\n154:             if temp > 90:\n155:                 issues.append(f\"CRITICAL: {sensor} at {temp}°C - overheating risk!\")\n156:             elif temp > 80:\n157:                 recommendations.append(f\"WARNING: {sensor} at {temp}°C - consider improving cooling\")\n158:             elif temp > 70:\n159:                 recommendations.append(f\"Note: {sensor} at {temp}°C - within normal range under load\")\n160:     \n161:     # WHEA-specific recommendations\n162:     recommendations.append(\"WHEA_UNCORRECTABLE_ERROR is typically caused by:\")\n163:     recommendations.append(\"  1. NVMe SSD issues (check firmware with vendor tool)\")\n164:     recommendations.append(\"  2. Dried thermal paste (repaste CPU if >3 years old)\")\n165:     recommendations.append(\"  3. Mixed RAM kits (use matched pairs)\")\n166:     recommendations.append(\"  4. Outdated BIOS/microcode (update from manufacturer)\")\n167:     recommendations.append(\"  5. Failing VRM/motherboard (professional diagnosis needed)\")\n168:     \n169:     return issues, recommendations\n170: \n171: def main():\n172:     print(\"=\" * 60)\n173:     print(\"PC HEALTH MONITOR - Passive Assessment (No Stress Testing)\")\n174:     print(f\"Timestamp: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n175:     print(\"=\" * 60)\n176:     print()\n177:     \n178:     # System info\n179:     print(\"--- SYSTEM INFORMATION ---\")\n180:     info = get_system_info()\n181:     print(f\"  Platform: {info['platform']}\")\n182:     print(f\"  CPU: {info['processor']}\")\n183:     print(f\"  CPU Cores: {info['cpu_count_physical']} physical / {info['cpu_count_logical']} logical\")\n184:     print(f\"  CPU Usage: {info['cpu_percent']}% (current)\")\n185:     print(f\"  CPU Frequency: {info['cpu_freq_current']} MHz / {info['cpu_freq_max']} MHz\")\n186:     print(f\"  RAM: {info['ram_used_gb']}GB / {info['ram_total_gb']}GB ({info['ram_percent']}%)\")\n187:     print(f\"  Last Boot: {info['boot_time']}\")\n188:     print()\n189:     \n190:     # Disk health\n191:     print(\"--- DISK HEALTH ---\")\n192:     disks = check_disk_health()\n193:     for disk in disks:\n194:         print(f\"  {disk['device']} ({disk['mountpoint']}): {disk['used_gb']}GB / {disk['total_gb']}GB ({disk['percent']}%)\")\n195:     print()\n196:     \n197:     # Temperatures\n198:     print(\"--- TEMPERATURE READINGS ---\")\n199:     temps = get_temperature_readings()\n200:     if isinstance(temps, dict):\n201:         if \"status\" in temps:\n202:             print(f\"  {temps['status']}\")\n203:         else:\n204:             for sensor, temp in temps.items():\n205:                 status = \"OK\" if temp < 70 else (\"WARM\" if temp < 85 else \"HOT\")\n206:                 print(f\"  {sensor}: {temp:.1f}°C [{status}]\")\n207:     print()\n208:     \n209:     # Event check\n210:     print(\"--- CRITICAL SYSTEM EVENTS ---\")\n211:     events = check_recent_events()\n212:     print(events)\n213:     print()\n214:     \n215:     # Health assessment\n216:     print(\"--- HEALTH ASSESSMENT ---\")\n217:     issues, recommendations = assess_health(info, disks, temps)\n218:     \n219:     if issues:\n220:         print(\"  ISSUES FOUND:\")\n221:         for issue in issues:\n222:             print(f\"    [!] {issue}\")\n223:     else:\n224:         print(\"  No immediate issues detected.\")\n225:     print()\n226:     \n227:     print(\"  RECOMMENDATIONS:\")\n228:     for rec in recommendations:\n229:         print(f\"    -> {rec}\")\n230:     print()\n231:     \n232:     # WHEA-specific\n233:     print(\"--- WHEA_UNCORRECTABLE_ERROR ANALYSIS ---\")\n234:     print(\"  This error (Stop Code 0x124) indicates a fatal hardware error.\")\n235:     print(\"  Common causes for your HP OMEN 15-ce0xx:\")\n236:     print(\"    1. ADATA SX6000NP NVMe SSD - budget controller, check firmware\")\n237:     print(\"    2. CPU thermal paste dried out after 8 years\")\n238:     print(\"    3. Mixed RAM (SK Hynix + Samsung) timing conflicts\")\n239:     print(\"    4. BIOS F.24 outdated (2021) - update for Intel microcode patches\")\n240:     print(\"    5. Motherboard VRM degradation (age-related)\")\n241:     print()\n242:     print(\"  NEXT STEPS:\")\n243:     print(\"    1. Run: python -m pip install --upgrade pip\")\n244:     print(\"    2. Install LibreHardwareMonitor for real-time temp monitoring\")\n245:     print(\"    3. Check ADATA SSD firmware via ADATA SSD ToolBox\")\n246:     print(\"    4. Update BIOS from HP support website\")\n247:     print(\"    5. Consider repasting CPU if comfortable doing so\")\n248:     print(\"    6. If crashes continue, test with matched RAM kit\")\n249:     print()\n250:     \n251:     print(\"=\" * 60)\n252:     print(\"Run this script periodically to monitor system health.\")\n253:     print(\"For real-time monitoring, use LibreHardwareMonitor or HWiNFO64.\")\n254:     print(\"=\" * 60)\n255: \n256: if __name__ == \"__main__\":\n257:     main()\n\n(End of file - total 257 lines)\n</content>",
