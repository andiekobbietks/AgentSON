erm\": \"^5.3.0\",\n91:     \"yaml\": \"^2.8.2\",\n92:     \"zod\": \"^3.25.76\",\n93:     \"zod-to-json-schema\": \"^3.25.1\"\n94:   },\n95:   \"devDependencies\": {\n96:     \"@eslint/js\": \"^9.32.0\",\n97:     \"@tailwindcss/typography\": \"^0.5.16\",\n98:     \"@testing-library/jest-dom\": \"^6.6.0\",\n99:     \"@testing-library/react\": \"^16.0.0\",\n100:     \"@types/figlet\": \"^1.7.0\",\n101:     \"@types/node\": \"^22.16.5\",\n102:     \"@types/react\": \"^18.3.23\",\n103:     \"@types/react-dom\": \"^18.3.7\",\n104:     \"@vitejs/plugin-react-swc\": \"^3.11.0\",\n105:     \"autoprefixer\": \"^10.4.21\",\n106:     \"eslint\": \"^9.32.0\",\n107:     \"eslint-plugin-react-hooks\": \"^5.2.0\",\n108:     \"eslint-plugin-react-refresh\": \"^0.4.20\",\n109:     \"globals\": \"^15.15.0\",\n110:     \"jsdom\": \"^25.0.1\",\n111:     \"lovable-tagger\": \"^1.1.13\",\n112:     \"postcss\": \"^8.5.6\",\n113:     \"postcss-import\": \"^16.1.1\",\n114:     \"sharp\": \"^0.34.5\",\n115:     \"tailwindcss\": \"^3.4.17\",\n116:     \"ts-node\": \"^10.9.2\",\n117:     \"typescript\": \"^5.8.3\",\n118:     \"typescript-eslint\": \"^8.38.0\",\n119:     \"vite\": \"^6.1.6\",\n120:     \"vite-plugin-pwa\": \"^0.21.1\",\n121:     \"vitest\": \"^3.2.4\",\n122:     \"workbox-window\": \"^7.4.0\"\n123:   },\n124:   \"overrides\": {\n125:     \"serialize-javascript\": \"^7.0.1\",\n126:     \"minimatch\": \"^9.0.5\"\n127:   }\n128: }\n\n(End of file - total 128 lines)\n</content>",
