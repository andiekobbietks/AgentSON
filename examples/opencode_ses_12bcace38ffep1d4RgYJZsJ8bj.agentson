      "output": "<path>C:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\.forge</path>\n<type>file</type>\n<content>\n1: protocol: forge/1.0\n2: type: curriculum\n3: \n4: metadata:\n5:   id: lampforge-curriculum\n6:   title: \"LAMPForge Learning Platform\"\n7:   description: |\n8:     A comprehensive curriculum for terminal mastery, shell scripting,\n9:     and modern frontend development with atomic CSS.\n10:   version: \"1.0.0\"\n11:   author: \"LAMPForge\"\n12:   license: \"MIT\"\n13: \n14: curriculum:\n15:   modules:\n16:     - id: terminal-foundations\n17:       path: curriculum/01-terminal-foundations\n18:       title: \"Terminal Foundations\"\n19:       description: \"Understanding shells, streams, and the command line\"\n20:       lessons: 4\n21: \n22:     - id: bash-essentials\n23:       path: curriculum/02-bash-essentials\n24:       title: \"Bash Essentials\"\n25:       description: \"Core Bash scripting skills\"\n26:       lessons: 10\n27: \n28:     - id: powershell-essentials\n29:       path: curriculum/03-powershell-essentials\n30:       title: \"PowerShell Essentials\"\n31:       description: \"Object-oriented scripting with PowerShell\"\n32:       lessons: 10\n33: \n34:     - id: real-world-automation\n35:       path: curriculum/04-real-world-automation\n36:       title: \"Real-World Automation\"\n37:       description: \"Practical scripting for DevOps and cloud\"\n38:       lessons: 5\n39: \n40:     - id: lampforge-sdtp\n41:       path: curriculum/05-lampforge-sdtp\n42:       title: \"The .forge Protocol\"\n43:       description: \"Creating curriculum with SDTP\"\n44:       lessons: 8\n45: \n46:     - id: frontend-styling\n47:       path: curriculum/06-frontend-styling\n48:       title: \"Frontend Styling\"\n49:       description: \"Modern atomic CSS with UnoCSS\"\n50:       lessons: 2\n51: \n52: runtime:\n53:   shell: browser\n54:   features:\n55:     - unocss-playground\n56:     - live-preview\n57:     - curriculum-browser\n58:     - evidence-capture\n59: \n60: finops:\n61:   budget:\n62:     max_session_gbp: 0.50\n63:     max_lesson_gbp: 0.02\n64:   inference:\n65:     prefer: local-onnx\n66:     fallback:\n67:       - ollama\n68:       - openrouter\n69:     providers:\n70:       openrouter:\n71:         max_requests: 50\n72:         models:\n73:           - mistralai/mistral-7b-instruct\n74:           - meta-llama/llama-3-8b-instruct\n75:   alerts:\n76:     warn_at_percent: 70\n77:     kill_at_percent: 95\n78: \n79: evidence:\n80:   capture:\n81:     - challenge_solutions\n82:     - quiz_responses\n83:     - reflection_responses\n84:     - time_spent\n85:   export:\n86:     formats:\n87:       - jsonl\n88:       - csv\n89:     destination: local\n\n(End of file - total 89 lines)\n</content>",
