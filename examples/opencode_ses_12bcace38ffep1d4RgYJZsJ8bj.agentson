      "output": "<path>C:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\sdk\\forge-ai.ts</path>\n<type>file</type>\n<content>\n1: import {\n2:   type ForgeBlueprint,\n3:   type ScaffoldLevel,\n4:   validateBlueprint,\n5:   getBlueprintToolSchema,\n6: } from \"./forge-types\";\n7: import { getForgeConfig } from \"./forge-config\";\n8: import { getForgeLog, forgeLog } from \"./forge-logger\";\n9: import { runOnnxInference } from \"./forge-onnx\";\n10: import type { ForgeProtocol } from \"./forge-protocol\";\n11: import { FinOpsLedger, FinOpsGuard } from \"./forge-finops\";\n12: import { SemanticEmbedder } from \"../src/lib/forge-embedder\";\n13: import { discoverEdgeAI, inferWithBrowserAI, type EdgeAICapabilities } from \"../src/lib/edge-ai\";\n14: import { classifyRouteFromIntent } from \"./forge-ai-logic\";\n15: import { nanoWarmer } from \"./forge-nano-warmer\";\n16: \n17: // ── Route policies for Arch-Router-1.5B ──────────────────────────\n18: \n19: const ROUTE_POLICIES = [\n20:   {\n21:     name: \"schema_generation\",\n22:     description:\n23:       \"Complex database schema design with multiple entities, relationships, normalization, and transactional CRUD operations.\",\n24:     model_hint: \"qwen2.5-0.5b-instruct\",\n25:   },\n26:   {\n27:     name: \"simple_crud\",\n28:     description:\n29:       \"Basic single-entity CRUD application with simple forms and list views.\",\n30:     model_hint: \"qwen2.5-0.5b-instruct\",\n31:   },\n32:   {\n33:     name: \"ecommerce\",\n34:     description:\n35:       \"E-commerce or transactional website with products, shopping cart, user accounts, and order processing.\",\n36:     model_hint: \"qwen2.5-0.5b-instruct\",\n37:   },\n38: ];\n39: \n40: // ── Endpoints & Discovery ──────────────────────────────────────\n41: \n42: const PROBABLE_PORTS = [55335, 5272, 5273, 50674];\n43: let CachedFoundryPort: number | null = null;\n44: const ONNX_ROUTER_TIMEOUT_MS = 8000;\n45: const ONNX_INFERENCE_TIMEOUT_MS = 30000;\n46: \n47: async function discoverFoundryEndpoint(): Promise<string | null> {\n48:   const config = getForgeConfig();\n49:   if (config.foundryPort) {\n50:     CachedFoundryPort = config.foundryPort;\n51:     return `http://localhost:${config.foundryPort}/v1/chat/completions`;\n52:   }\n53: \n54:   if (CachedFoundryPort) return `http://localhost:${CachedFoundryPort}/v1/chat/completions`;\n55: \n56:   forgeLog.info(\"Foundry\", \"Probing ports for Foundry Local...\", PROBABLE_PORTS.join(\", \"));\n57: \n58:   for (const port of PROBABLE_PORTS) {\n59:     try {\n60:       const controller = new AbortController();\n61:       const timeout = setTimeout(() => controller.abort(), 1500);\n62:       const res = await fetch(`http://localhost:${port}/openai/status`, { signal: controller.signal });\n63:       clearTimeout(timeout);\n64:       if (res.ok) {\n65:         CachedFoundryPort = port;\n66:         forgeLog.success(\"Foundry\", `Discovered Foundry Local on port ${port}`);\n67:         return `http://localhost:${port}/v1/chat/completions`;\n68:       }\n69:     } catch {\n70:       forgeLog.info(\"Foundry\", `Port ${port} - not responding`);\n71:     }\n72:   }\n73: \n74:   forgeLog.warn(\"Foundry\", \"No Foundry Local instance found on any expected port\");\n75:   return null;\n76: }\n77: \n78: export async function discoverFoundryModel(): Promise<string | null> {\n79:   if (!CachedFoundryPort) return null;\n80:   try {\n81:     const controller = new AbortController();\n82:     const timeout = setTimeout(() => controller.abort(), 1500);\n83:     const res = await fetch(`http://localhost:${CachedFoundryPort}/v1/models`, { signal: controller.signal });\n84:     clearTimeout(timeout);\n85:     if (res.ok) {\n86:       const data = await res.json();\n87:       const modelId = data.data?.[0]?.id;\n88:       if (modelId) return `Foundry (${modelId})`;\n89:     }\n90:   } catch { /* ignore */ }\n91:   return null;\n92: }\n93: \n94: // ── Provider Health Checks (for admin panel) ───────────────────\n95: \n96: export interface ProviderStatus {\n97:   name: string;\n98:   status: \"online\" | \"offline\" | \"no-key\" | \"checking\";\n99:   detail?: string;\n100:   latencyMs?: number;\n101: }\n102: \n103: export async function checkAllProviders(): Promise<ProviderStatus[]> {\n104:   const results: ProviderStatus[] = [];\n105: \n106:   // Foundry Local\n107:   const t0 = Date.now();\n108:   const foundryEndpoint = await discoverFoundryEndpoint();\n109:   const foundryLatency = Date.now() - t0;\n110:   if (foundryEndpoint) {\n111:     const model = await discoverFoundryModel();\n112:     results.push({\n113:       name: \"Foundry Local\",\n114:       status: \"online\",\n115:       detail: model || `Port ${CachedFoundryPort}`,\n116:       latencyMs: foundryLatency,\n117:     });\n118:   } else {\n119:     results.push({\n120:       name: \"Foundry Local\",\n121:       status: \"offline\",\n122:       detail: \"Not running - probed ports \" + PROBABLE_PORTS.join(\", \"),\n123:       latencyMs: foundryLatency,\n124:     });\n125:   }\n126: \n127:   // Groq\n128:   const config = getForgeConfig();\n129:   if (!config.groqKey) {\n130:     results.push({ name: \"Groq\", status: \"no-key\", detail: \"No API key configured\" });\n131:   } else {\n132:     try {\n133:       const t1 = Date.now();\n134:       const res = await fetch(\"https://api.groq.com/openai/v1/models\", {\n135:         headers: { Authorization: `Bearer ${config.groqKey}` },\n136:         signal: AbortSignal.timeout(5000),\n137:       });\n138:       const latency = Date.now() - t1;\n139:       if (res.ok) {\n140:         const data = await res.json();\n141:         const modelCount = data.data?.length || 0;\n142:         results.push({\n143:           name: \"Groq\",\n144:           status: \"online\",\n145:           detail: `Key valid - ${modelCount} models available`,\n146:           latencyMs: latency,\n147:         });\n148:       } else {\n149:         const body = await res.text().catch(() => \"\");\n150:         results.push({\n151:           name: \"Groq\",\n152:           status: \"offline\",\n153:           detail: `HTTP ${res.status}: ${body.slice(0, 120)}`,\n154:         });\n155:       }\n156:     } catch (err) {\n157:       results.push({\n158:         name: \"Groq\",\n159:         status: \"offline\",\n160:         detail: String(err),\n161:       });\n162:     }\n163:   }\n164: \n165:   // Cerebras\n166:   if (!config.cerebrasKey) {\n167:     results.push({ name: \"Cerebras\", status: \"no-key\", detail: \"No API key configured\" });\n168:   } else {\n169:     try {\n170:       const t2 = Date.now();\n171:       const res = await fetch(\"https://api.cerebras.ai/v1/models\", {\n172:         headers: { Authorization: `Bearer ${config.cerebrasKey}` },\n173:         signal: AbortSignal.timeout(5000),\n174:       });\n175:       const latency = Date.now() - t2;\n176:       if (res.ok) {\n177:         results.push({\n178:           name: \"Cerebras\",\n179:           status: \"online\",\n180:           detail: \"Key valid\",\n181:           latencyMs: latency,\n182:         });\n183:       } else {\n184:         const body = await res.text().catch(() => \"\");\n185:         results.push({\n186:           name: \"Cerebras\",\n187:           status: \"offline\",\n188:           detail: `HTTP ${res.status}: ${body.slice(0, 120)}`,\n189:         });\n190:       }\n191:     } catch (err) {\n192:       results.push({\n193:         name: \"Cerebras\",\n194:         status: \"offline\",\n195:         detail: String(err),\n196:       });\n197:     }\n198:   }\n199: \n200:   // Browser Native (Gemini Nano)\n201:   const nanoState = nanoWarmer.getState();\n202:   results.push({\n203:     name: \"Chrome ML Core (Gemini)\",\n204:     status: nanoState.status === \"available\" || nanoState.status === \"ready\" ? \"online\" : \"checking\",\n205:     detail: nanoState.status === \"downloading\" ? `Downloading ${Math.round((nanoState.progress || 0) * 100)}%` : nanoState.status,\n206:   });\n207: \n208:   // Browser Native (ONNX)\n209:   results.push({\n210:     name: \"Forge Router Micro (ONNX)\",\n211:     status: \"online\",\n212:     detail: \"Ready for WebNN fallback (Qwen-0.5B)\",\n213:   });\n214: \n215:   return results;\n216: }\n217: \n218: const OLLAMA_ENDPOINT = \"http://localhost:11434/v1/chat/completions\";\n219: \n220: async function tryBrowserAI(\n221:   intent: string,\n222:   scaffoldLevel: ScaffoldLevel,\n223:   routeContext?: string,\n224:   onProgress?: ForgeProgress\n225: ): Promise<ForgeBlueprint | null> {\n226:   onProgress?.(\"Attempting inference via Browser-Native LLM (window.ai)...\");\n227:   const prompt = `${getSystemPrompt(scaffoldLevel, routeContext)}\\n\\nUser intent: ${intent}\\n\\nReturn ONLY the raw JSON blueprint.`;\n228:   \n229:   const response = await inferWithBrowserAI(prompt);\n230:   if (response) {\n231:     const parsed = extractJSON(response);\n232:     if (parsed) {\n233:       return validateBlueprint(parsed);\n234:     }\n235:   }\n236:   return null;\n237: }\n238: \n239: // ── System prompts ───────────────────────────────────────────────\n240: \n241: function getSystemPrompt(scaffoldLevel: ScaffoldLevel, routeContext?: string, failureLogs?: string): string {\n242:   const routeLine = routeContext\n243:     ? `\\nThe routing model classified this intent as \"${routeContext}\". Optimize your schema accordingly.`\n244:     : \"\";\n245: \n246:   const diagnosisLine = failureLogs\n247:     ? `\\n\\nSYSTEM DIAGNOSIS: The following error logs were captured from previous failed attempts in this session. Use this context to avoid repeating the same mistakes (e.g., if a previous provider failed to parse JSON, be extra careful with your output format):\\n${failureLogs}`\n248:     : \"\";\n249: \n250:   const levelInstructions: Record<ScaffoldLevel, string> = {\n251:     exploratory: `You are a database schema designer for a WJEC/Eduqas student targeting Grade E/D.\n252: Produce FLAT 1NF tables only. Simple column types (INT, VARCHAR, TEXT, DATE). \n253: NO foreign keys, NO constraints beyond PRIMARY KEY. NO indexes. NO audit columns.\n254: Each entity is a standalone table with an auto-increment id.`,\n255: \n256:     competent: `You are a database schema designer for a WJEC/Eduqas student targeting Grade C/B.\n257: Produce 2NF-normalized tables with PRIMARY KEYs and basic FOREIGN KEYs.\n258: Use NOT NULL on key fields. Basic data types. No composite indexes.\n259: No audit columns (created_at/updated_at). Simple relationships.`,\n260: \n261:     exemplary: `You are a database schema designer for a WJEC/Eduqas student targeting Grade A/A*.\n262: Produce fully normalized 3NF schemas. Include:\n263: - AUTO_INCREMENT primary keys\n264: - FOREIGN KEY constraints with ON DELETE CASCADE\n265: - Composite indexes on frequently queried columns\n266: - created_at and updated_at audit columns (DATETIME DEFAULT CURRENT_TIMESTAMP)\n267: - Junction tables for M:M relationships with timestamps\n268: - NOT NULL, UNIQUE, CHECK constraints where appropriate`,\n269: \n270:     rad: `You are an expert database architect in RAD 2.0 (Rapid Architectural Development) mode.\n271: Produce the most robust, production-grade normalized schema possible. No grade ceiling. Include EVERY best practice:\n272: - Full 3NF+ normalization\n273: - AUTO_INCREMENT primary keys\n274: - FOREIGN KEY constraints with ON DELETE CASCADE / ON UPDATE CASCADE\n275: - Composite indexes, UNIQUE constraints, CHECK constraints\n276: - created_at, updated_at, and deleted_at (for soft deletes) audit columns\n277: - Junction tables for M:M with timestamps\n278: - Full CRUD with pagination and search considerations\n279: - Input validation requirements\n280: - Session and CSRF token considerations\n281: If the user mentions a non-LAMP stack, still produce the LAMP reference architecture but add rad_migration_notes explaining how to translate to their target stack.`,\n282:   };\n283: \n284:   return `${levelInstructions[scaffoldLevel]}${routeLine}${diagnosisLine}\n285: \n286: CRITICAL: You must call the generate_blueprint tool with a complete ForgeBlueprint JSON. \n287: The scaffold_level must be \"${scaffoldLevel}\".\n288: Entity and field names MUST be snake_case (lowercase letters, numbers, underscores only, starting with a letter).\n289: Every entity MUST have at least one field.\n290: Every entity MUST have an \"id\" field as PRIMARY KEY.\n291: \n292: NAVIGATION: Always include a \"navigation\" object with:\n293:  - \"brand\": the project name (title case)\n294:  - \"items\": an array of entity names (these become navbar links)\n295: \n296: PAGES: Always include a \"pages\" array. For each entity, add a page object with:\n297:  - \"route\": the entity name (e.g. \"books\")\n298:  - \"title\": human-readable title (e.g. \"Books\")\n299:  - \"entity\": the entity name\n300:  - \"layout\": \"table-crud\" for list views, \"form\" for standalone forms\n301:  - \"framework\": \"bootstrap-5\"\n302: `;\n303: }\n304: \n305: // ── Stage 1: Arch-Router (optional) ─────────────────────────────\n306: \n307: export type ForgeProgress = (status: string) => void;\n308: \n309: // Deterministic fallback classifier is now imported from ./forge-ai-logic.ts\n310: \n311: /**\n312:  * Extracts and validates a route policy from ONNX router JSON output.\n313:  * Accepts either an explicit `{ route }` payload in parsed output, or a single unambiguous route mention in text.\n314:  */\n315: function extractRouteFromOnnxResponse(responseStr: string): string | null {\n316:   try {\n317:     const parsedResponse = JSON.parse(responseStr);\n318:     if (parsedResponse?.status !== \"SUCCESS\" || typeof parsedResponse.output !== \"string\") {\n319:       return null;\n320:     }\n321: \n322:     const parsedOutput = extractJSON(parsedResponse.output);\n323:     if (parsedOutput && typeof parsedOutput === \"object\" && \"route\" in parsedOutput) {\n324:       const routeValue = (parsedOutput as { route?: unknown }).route;\n325:       if (typeof routeValue === \"string\" && ROUTE_POLICIES.some((p) => p.name === routeValue)) {\n326:         return routeValue;\n327:       }\n328:     }\n329: \n330:     const matchedPolicies = ROUTE_POLICIES\n331:       .filter((policy) => new RegExp(`\\\\b${policy.name}\\\\b`, \"i\").test(parsedResponse.output))\n332:       .map((policy) => policy.name);\n333: \n334:     if (matchedPolicies.length === 1) {\n335:       return matchedPolicies[0];\n336:     }\n337:   } catch {\n338:     return null;\n339:   }\n340: \n341:   return null;\n342: }\n343: \n344: /**\n345:  * Wraps a promise with a timeout and rejects if execution exceeds `timeoutMs`.\n346:  */\n347: async function withTimeout<T>(promise: Promise<T>, timeoutMs: number): Promise<T> {\n348:   let timeoutId: ReturnType<typeof setTimeout> | undefined;\n349: \n350:   try {\n351:     return await Promise.race([\n352:       promise,\n353:       new Promise<T>((_, reject) => {\n354:         timeoutId = setTimeout(() => reject(new Error(`Timed out after ${timeoutMs}ms`)), timeoutMs);\n355:       }),\n356:     ]);\n357:   } finally {\n358:     if (timeoutId) clearTimeout(timeoutId);\n359:   }\n360: }\n361: \n362: function createSessionId(prefix: string): string {\n363:   return `${prefix}_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;\n364: }\n365: \n366: async function tryOnnxRouter(\n367:   intent: string,\n368:   onProgress?: ForgeProgress\n369: ): Promise<string | null> {\n370:   onProgress?.(\"Routing intent via Browser Native (ONNX)...\");\n371:   forgeLog.info(\"ONNX-Router\", \"Classifying intent via Browser Native (ONNX)...\");\n372: \n373:   const routeNames = ROUTE_POLICIES.map((policy) => policy.name).join(\", \");\n374:   const routePrompt = `Classify this intent into one route policy: ${routeNames}.\\nIntent: ${intent}`;\n375: \n376:   try {\n377:     const responseStr = await withTimeout(runOnnxInference(routePrompt, createSessionId(\"route\")), ONNX_ROUTER_TIMEOUT_MS);\n378:     const onnxRoute = responseStr ? extractRouteFromOnnxResponse(responseStr) : null;\n379:     const route = onnxRoute || classifyRouteFromIntent(intent);\n380:     forgeLog.success(\"ONNX-Router\", `Route classified: ${route}`);\n381:     if (!onnxRoute) {\n382:       forgeLog.info(\"ONNX-Router\", \"ONNX output had no explicit route - applied deterministic fallback classifier\");\n383:     }\n384:     onProgress?.(`Route: ${route} (ONNX router)`);\n385:     return route;\n386:   } catch (error) {\n387:     forgeLog.warn(\"ONNX-Router\", `ONNX router failed - falling back to local Arch-Router: ${String(error)}`);\n388:     onProgress?.(\"ONNX router unavailable - falling back to local Arch-Router...\");\n389:     return null;\n390:   }\n391: }\n392: \n393: async function tryArchRouter(\n394:   intent: string,\n395:   onProgress?: ForgeProgress\n396: ): Promise<string | null> {\n397:   const discovered = await discoverFoundryEndpoint();\n398:   if (!discovered) {\n399:     forgeLog.info(\"ArchRouter\", \"Foundry Local unavailable - using default route\");\n400:     onProgress?.(\"Foundry Local unavailable - using default route\");\n401:     return null;\n402:   }\n403: \n404:   onProgress?.(\"Routing intent via local Arch-Router...\");\n405:   forgeLog.info(\"ArchRouter\", \"Classifying intent via local Arch-Router...\");\n406: \n407:   const routeDescriptions = ROUTE_POLICIES.map(\n408:     (p) => `- \"${p.name}\": ${p.description}`\n409:   ).join(\"\\n\");\n410: \n411:   const userMessage = `Given the following route policies:\\n${routeDescriptions}\\n\\nClassify this user intent into the best matching route. Return JSON with a single \"route\" key.\\n\\nUser intent: \"${intent}\"`;\n412: \n413:   const payload = {\n414:     model: \"qwen2.5-1.5b-instruct-generic-cpu:4\",\n415:     messages: [\n416:       {\n417:         role: \"system\",\n418:         content: \"You are a helpful assistant designed to find the best suited route. Respond with a JSON object containing a single 'route' key matching one of the provided route policy names.\",\n419:       },\n420:       { role: \"user\", content: userMessage },\n421:     ],\n422:     temperature: 0,\n423:     max_tokens: 50,\n424:   };\n425: \n426:   try {\n427:     const controller = new AbortController();\n428:     const timeout = setTimeout(() => controller.abort(), 10000);\n429: \n430:     const response = await fetch(discovered, {\n431:       method: \"POST\",\n432:       headers: { \"Content-Type\": \"application/json\" },\n433:       body: JSON.stringify(payload),\n434:       signal: controller.signal,\n435:     });\n436: \n437:     clearTimeout(timeout);\n438: \n439:     if (response.ok) {\n440:       const data = await response.json();\n441:       const content = data.choices?.[0]?.message?.content || \"\";\n442: \n443:       try {\n444:         const parsed = JSON.parse(content);\n445:         if (parsed.route && ROUTE_POLICIES.some((p) => p.name === parsed.route)) {\n446:           forgeLog.success(\"ArchRouter\", `Route classified: ${parsed.route}`);\n447:           onProgress?.(`Route: ${parsed.route} (local router)`);\n448:           return parsed.route;\n449:         }\n450:       } catch {\n451:         for (const policy of ROUTE_POLICIES) {\n452:           if (content.toLowerCase().includes(policy.name)) {\n453:             forgeLog.success(\"ArchRouter\", `Route extracted from text: ${policy.name}`);\n454:             onProgress?.(`Route: ${policy.name} (local router)`);\n455:             return policy.name;\n456:           }\n457:         }\n458:       }\n459:     } else {\n460:       forgeLog.error(\"ArchRouter\", `HTTP ${response.status}`, await response.text().catch(() => \"\"));\n461:     }\n462:   } catch (err) {\n463:     forgeLog.error(\"ArchRouter\", \"Request failed\", String(err));\n464:   }\n465: \n466:   forgeLog.warn(\"ArchRouter\", \"Arch-Router failed - using default route\");\n467:   onProgress?.(\"Arch-Router failed - using default route\");\n468:   return null;\n469: }\n470: \n471: // ── Stage 2a: Foundry Local generation ──────────────────────────\n472: \n473: async function tryFoundryLocal(\n474:   intent: string,\n475:   scaffoldLevel: ScaffoldLevel,\n476:   routeContext?: string,\n477:   onProgress?: ForgeProgress,\n478:   failureLogs?: string\n479: ): Promise<ForgeBlueprint | null> {\n480:   onProgress?.(\"Generating blueprint via Foundry Local...\");\n481:   forgeLog.info(\"Foundry\", \"Attempting blueprint generation via Foundry Local...\");\n482: \n483:   const toolSchema = getBlueprintToolSchema();\n484:   const systemPrompt = getSystemPrompt(scaffoldLevel, routeContext, failureLogs);\n485: \n486:   const endpoint = await discoverFoundryEndpoint();\n487:   if (!endpoint) {\n488:     forgeLog.warn(\"Foundry\", \"Skipping - Foundry Local not found on expected ports.\");\n489:     onProgress?.(\"Foundry Local not found on expected ports.\");\n490:     return null;\n491:   }\n492: \n493:   const modelAlias = \"qwen2.5-0.5b\";\n494: \n495:   // Strategy 1: Tool-calling\n496:   forgeLog.info(\"Foundry\", \"Strategy 1: Tool-calling mode...\");\n497:   const toolPayload = {\n498:     model: modelAlias,\n499:     messages: [\n500:       { role: \"system\", content: systemPrompt },\n501:       { role: \"user\", content: intent },\n502:     ],\n503:     tools: [toolSchema],\n504:     tool_choice: { type: \"function\", function: { name: \"generate_blueprint\" } },\n505:     temperature: 0.2,\n506:     max_tokens: 4096,\n507:   };\n508: \n509:   // Strategy 2: JSON-in-prompt fallback\n510:   const jsonPayload = {\n511:     model: modelAlias,\n512:     messages: [\n513:       {\n514:         role: \"system\",\n515:         content: `${systemPrompt}\\n\\nIMPORTANT: Since tool-calling is not available, respond with a raw JSON object matching the ForgeBlueprint schema. No markdown, no code fences, just the JSON object.`,\n516:       },\n517:       { role: \"user\", content: intent },\n518:     ],\n519:     temperature: 0.2,\n520:     max_tokens: 4096,\n521:   };\n522: \n523:   // Try tool-calling first\n524:   try {\n525:     const controller = new AbortController();\n526:     const timeout = setTimeout(() => controller.abort(), 120000);\n527: \n528:     const response = await fetch(endpoint, {\n529:       method: \"POST\",\n530:       headers: { \"Content-Type\": \"application/json\" },\n531:       body: JSON.stringify(toolPayload),\n532:       signal: controller.signal,\n533:     });\n534: \n535:     clearTimeout(timeout);\n536: \n537:     if (response.ok) {\n538:       const data = await response.json();\n539: \n540:       const toolCall = data.choices?.[0]?.message?.tool_calls?.[0];\n541:       if (toolCall?.function?.arguments) {\n542:         const args =\n543:           typeof toolCall.function.arguments === \"string\"\n544:             ? JSON.parse(toolCall.function.arguments)\n545:             : toolCall.function.arguments;\n546: \n547:         forgeLog.info(\"Foundry\", \"Tool-call returned arguments - validating...\");\n548:         onProgress?.(\"Validating blueprint...\");\n549:         const blueprint = validateBlueprint(args);\n550:         forgeLog.success(\"Foundry\", \"Blueprint validated - Foundry Local ✓\");\n551:         onProgress?.(\"Blueprint validated - Foundry Local ✓\");\n552:         return blueprint;\n553:       }\n554: \n555:       const content = data.choices?.[0]?.message?.content;\n556:       if (content) {\n557:         forgeLog.info(\"Foundry\", \"Tool-call returned content instead, trying JSON extract...\", content.slice(0, 200));\n558:         const parsed = extractJSON(content);\n559:         if (parsed) {\n560:           onProgress?.(\"Validating blueprint...\");\n561:           const blueprint = validateBlueprint(parsed);\n562:           forgeLog.success(\"Foundry\", \"Blueprint validated - Foundry Local (content fallback) ✓\");\n563:           onProgress?.(\"Blueprint validated - Foundry Local ✓\");\n564:           return blueprint;\n565:         }\n566:       }\n567: \n568:       forgeLog.warn(\"Foundry\", \"Tool-call response had no extractable blueprint\", JSON.stringify(data).slice(0, 300));\n569:     } else {\n570:       const body = await response.text().catch(() => \"\");\n571:       forgeLog.error(\"Foundry\", `Tool-call HTTP ${response.status}`, body.slice(0, 200));\n572:     }\n573:   } catch (err) {\n574:     forgeLog.error(\"Foundry\", \"Tool-calling failed\", String(err));\n575:   }\n576: \n577:   // Try JSON-in-prompt fallback on same endpoint\n578:   forgeLog.info(\"Foundry\", \"Strategy 2: JSON-in-prompt fallback...\");\n579:   try {\n580:     const controller = new AbortController();\n581:     const timeout = setTimeout(() => controller.abort(), 120000);\n582: \n583:     const response = await fetch(endpoint, {\n584:       method: \"POST\",\n585:       headers: { \"Content-Type\": \"application/json\" },\n586:       body: JSON.stringify(jsonPayload),\n587:       signal: controller.signal,\n588:     });\n589: \n590:     clearTimeout(timeout);\n591: \n592:     if (response.ok) {\n593:       const data = await response.json();\n594:       const content = data.choices?.[0]?.message?.content;\n595:       if (content) {\n596:         forgeLog.info(\"Foundry\", \"JSON fallback returned content...\", content.slice(0, 200));\n597:         const parsed = extractJSON(content);\n598:         if (parsed) {\n599:           onProgress?.(\"Validating blueprint...\");\n600:           const blueprint = validateBlueprint(parsed);\n601:           forgeLog.success(\"Foundry\", \"Blueprint validated - Foundry Local (JSON mode) ✓\");\n602:           onProgress?.(\"Blueprint validated - Foundry Local (JSON mode) ✓\");\n603:           return blueprint;\n604:         }\n605:       }\n606:       forgeLog.warn(\"Foundry\", \"JSON fallback had no parseable JSON\");\n607:     } else {\n608:       const body = await response.text().catch(() => \"\");\n609:       forgeLog.error(\"Foundry\", `JSON fallback HTTP ${response.status}`, body.slice(0, 200));\n610:     }\n611:   } catch (err) {\n612:     forgeLog.error(\"Foundry\", \"JSON fallback failed\", String(err));\n613:   }\n614: \n615:   forgeLog.warn(\"Foundry\", \"All Foundry strategies exhausted - moving to cloud\");\n616:   return null;\n617: }\n618: \n619: // ── Stage 2b: Cloud fallbacks (Groq & Cerebras) ────────────────\n620: \n621: async function tryGroq(\n622:   intent: string,\n623:   scaffoldLevel: ScaffoldLevel,\n624:   routeContext?: string,\n625:   onProgress?: ForgeProgress,\n626:   failureLogs?: string\n627: ): Promise<ForgeBlueprint | null> {\n628:   const { groqKey } = getForgeConfig();\n629:   if (!groqKey) {\n630:     forgeLog.warn(\"Groq\", \"Skipping - no API key configured. Add it in /admin/ide-config\");\n631:     return null;\n632:   }\n633: \n634:   onProgress?.(\"Primary cloud fallback (Groq)...\");\n635:   forgeLog.info(\"Groq\", \"Attempting blueprint generation via Groq API...\");\n636: \n637:   const toolSchema = getBlueprintToolSchema();\n638:   const systemPrompt = getSystemPrompt(scaffoldLevel, routeContext, failureLogs);\n639: \n640:   const payload = {\n641:     model: \"llama-3.3-70b-versatile\",\n642:     messages: [\n643:       { role: \"system\", content: systemPrompt },\n644:       { role: \"user\", content: intent },\n645:     ],\n646:     tools: [toolSchema],\n647:     tool_choice: { type: \"function\", function: { name: \"generate_blueprint\" } },\n648:     temperature: 0.2,\n649:     max_tokens: 4096,\n650:   };\n651: \n652:   try {\n653:     const response = await fetch(\"https://api.groq.com/openai/v1/chat/completions\", {\n654:       method: \"POST\",\n655:       headers: {\n656:         \"Content-Type\": \"application/json\",\n657:         Authorization: `Bearer ${groqKey}`,\n658:       },\n659:       body: JSON.stringify(payload),\n660:       signal: AbortSignal.timeout(30000),\n661:     });\n662: \n663:     if (response.ok) {\n664:       const data = await response.json();\n665: \n666:       // Try tool call extraction\n667:       const toolCall = data.choices?.[0]?.message?.tool_calls?.[0];\n668:       if (toolCall?.function?.arguments) {\n669:         const args =\n670:           typeof toolCall.function.arguments === \"string\"\n671:             ? JSON.parse(toolCall.function.arguments)\n672:             : toolCall.function.arguments;\n673: \n674:         forgeLog.info(\"Groq\", \"Tool-call returned - validating...\");\n675:         onProgress?.(\"Validating blueprint...\");\n676:         const blueprint = validateBlueprint(args);\n677:         forgeLog.success(\"Groq\", \"Blueprint validated - Groq ✓\");\n678:         onProgress?.(\"Blueprint validated - Groq ✓\");\n679:         return blueprint;\n680:       }\n681: \n682:       // Fallback: try extracting JSON from content\n683:       const content = data.choices?.[0]?.message?.content;\n684:       if (content) {\n685:         forgeLog.info(\"Groq\", \"No tool call - trying JSON extract from content...\", content.slice(0, 200));\n686:         const parsed = extractJSON(content);\n687:         if (parsed) {\n688:           const blueprint = validateBlueprint(parsed);\n689:           forgeLog.success(\"Groq\", \"Blueprint validated - Groq (content fallback) ✓\");\n690:           onProgress?.(\"Blueprint validated - Groq ✓\");\n691:           return blueprint;\n692:         }\n693:       }\n694: \n695:       forgeLog.warn(\"Groq\", \"Response had no extractable blueprint\", JSON.stringify(data).slice(0, 300));\n696:     } else {\n697:       const body = await response.text().catch(() => \"\");\n698:       forgeLog.error(\"Groq\", `HTTP ${response.status}`, body.slice(0, 300));\n699:     }\n700:   } catch (err) {\n701:     forgeLog.error(\"Groq\", \"Request failed\", String(err));\n702:   }\n703:   return null;\n704: }\n705: \n706: async function tryCerebras(\n707:   intent: string,\n708:   scaffoldLevel: ScaffoldLevel,\n709:   routeContext?: string,\n710:   onProgress?: ForgeProgress,\n711:   failureLogs?: string\n712: ): Promise<ForgeBlueprint | null> {\n713:   const { cerebrasKey } = getForgeConfig();\n714:   if (!cerebrasKey) {\n715:     forgeLog.warn(\"Cerebras\", \"Skipping - no API key configured. Add it in /admin/ide-config\");\n716:     return null;\n717:   }\n718: \n719:   onProgress?.(\"Secondary cloud fallback (Cerebras)...\");\n720:   forgeLog.info(\"Cerebras\", \"Attempting blueprint generation via Cerebras API...\");\n721: \n722:   const toolSchema = getBlueprintToolSchema();\n723:   const systemPrompt = getSystemPrompt(scaffoldLevel, routeContext, failureLogs);\n724: \n725:   const payload = {\n726:     model: \"llama3.1-70b\",\n727:     messages: [\n728:       { role: \"system\", content: systemPrompt },\n729:       { role: \"user\", content: intent },\n730:     ],\n731:     tools: [toolSchema],\n732:     tool_choice: { type: \"function\", function: { name: \"generate_blueprint\" } },\n733:     temperature: 0.2,\n734:     max_tokens: 4096,\n735:   };\n736: \n737:   try {\n738:     const response = await fetch(\"https://api.cerebras.ai/v1/chat/completions\", {\n739:       method: \"POST\",\n740:       headers: {\n741:         \"Content-Type\": \"application/json\",\n742:         Authorization: `Bearer ${cerebrasKey}`,\n743:       },\n744:       body: JSON.stringify(payload),\n745:       signal: AbortSignal.timeout(30000),\n746:     });\n747: \n748:     if (response.ok) {\n749:       const data = await response.json();\n750: \n751:       const toolCall = data.choices?.[0]?.message?.tool_calls?.[0];\n752:       if (toolCall?.function?.arguments) {\n753:         const args =\n754:           typeof toolCall.function.arguments === \"string\"\n755:             ? JSON.parse(toolCall.function.arguments)\n756:             : toolCall.function.arguments;\n757: \n758:         forgeLog.info(\"Cerebras\", \"Tool-call returned - validating...\");\n759:         onProgress?.(\"Validating blueprint...\");\n760:         const blueprint = validateBlueprint(args);\n761:         forgeLog.success(\"Cerebras\", \"Blueprint validated - Cerebras ✓\");\n762:         onProgress?.(\"Blueprint validated - Cerebras ✓\");\n763:         return blueprint;\n764:       }\n765: \n766:       // Fallback: try extracting JSON from content\n767:       const content = data.choices?.[0]?.message?.content;\n768:       if (content) {\n769:         forgeLog.info(\"Cerebras\", \"No tool call - trying JSON extract from content...\", content.slice(0, 200));\n770:         const parsed = extractJSON(content);\n771:         if (parsed) {\n772:           const blueprint = validateBlueprint(parsed);\n773:           forgeLog.success(\"Cerebras\", \"Blueprint validated - Cerebras (content fallback) ✓\");\n774:           onProgress?.(\"Blueprint validated - Cerebras ✓\");\n775:           return blueprint;\n776:         }\n777:       }\n778: \n779:       forgeLog.warn(\"Cerebras\", \"Response had no extractable blueprint\", JSON.stringify(data).slice(0, 300));\n780:     } else {\n781:       const body = await response.text().catch(() => \"\");\n782:       forgeLog.error(\"Cerebras\", `HTTP ${response.status}`, body.slice(0, 300));\n783:     }\n784:   } catch (err) {\n785:     forgeLog.error(\"Cerebras\", \"Request failed\", String(err));\n786:   }\n787:   return null;\n788: }\n789: \n790: // ── Stage 2c: Browser-Native (ONNX/WebNN) Fallback ───────────\n791: \n792: async function tryOnnxFallback(\n793:   intent: string,\n794:   scaffoldLevel: ScaffoldLevel,\n795:   routeContext?: string,\n796:   onProgress?: ForgeProgress,\n797:   failureLogs?: string\n798: ): Promise<ForgeBlueprint | null> {\n799:   onProgress?.(\"Generating blueprint via Browser Native (WebNN/ONNX)...\");\n800:   forgeLog.info(\"ONNX\", \"Attempting browser-native inference with WebNN hardware acceleration...\");\n801: \n802:   try {\n803:     const prompt = `${getSystemPrompt(scaffoldLevel, routeContext, failureLogs)}\\n\\nUser intent: ${intent}`;\n804:     const responseStr = await withTimeout(\n805:       runOnnxInference(prompt, createSessionId(\"blueprint\")),\n806:       ONNX_INFERENCE_TIMEOUT_MS\n807:     );\n808:     if (responseStr) {\n809:       const data = JSON.parse(responseStr);\n810:       if (data.status === \"SUCCESS\" && data.output) {\n811:         forgeLog.success(\"ONNX\", \"Browser-native inference successful ✓\");\n812:         const parsed = extractJSON(data.output);\n813:         if (parsed) {\n814:           return validateBlueprint(parsed);\n815:         }\n816:       }\n817:     }\n818:   } catch (error: any) {\n819:     forgeLog.error(\"ONNX\", `WebNN Inference failed: ${error.message}`);\n820:   }\n821: \n822:   return null;\n823: }\n824: \n825: // ── Public API ──────────────────────────────────────────────────\n826: \n827: export async function runSelfHeal(): Promise<void> {\n828:   forgeLog.info(\"SelfHeal\", \"Starting automated repair sequence...\");\n829:   CachedFoundryPort = null; // Reset port discovery\n830:   await discoverFoundryEndpoint();\n831:   forgeLog.success(\"SelfHeal\", \"Auto-discovery complete. Configuration refreshed.\");\n832: }\n833: \n834: export async function forgeSchema(\n835:   intent: string,\n836:   scaffoldLevel: ScaffoldLevel,\n837:   onProgress?: ForgeProgress,\n838:   forgeConfig?: ForgeProtocol\n839: ): Promise<{ blueprint: ForgeBlueprint; provider: string; route?: string }> {\n840:   forgeLog.info(\"Cascade\", `Starting inference chain for: \"${intent.slice(0, 80)}...\" [${scaffoldLevel}]`);\n841: \n842:   const recentLogs = getForgeLog()\n843:     .filter(l => l.level === \"error\" || l.level === \"warn\")\n844:     .slice(-5)\n845:     .map(l => `[${l.provider}] ${l.message}`)\n846:     .join(\"\\n\");\n847: \n848:   // Initialise FinOps guard from .forge config if provided\n849:   const finopsConfig = forgeConfig?.finops;\n850:   const ledger = new FinOpsLedger(finopsConfig);\n851:   const guard = new FinOpsGuard(ledger);\n852: \n853:   // ── GREEN COMPUTING: Edge-Native Semantic Load Balancing ──\n854:   let batteryLevel = 1.0;\n855:   if (typeof navigator !== \"undefined\" && \"getBattery\" in navigator) {\n856:     try {\n857:       const battery: any = await (navigator as any).getBattery();\n858:       batteryLevel = battery.level;\n859:     } catch { /* ignore */ }\n860:   }\n861: \n862:   const analysis = await SemanticEmbedder.analyzeIntent(intent);\n863:   forgeLog.info(\"FinOps\", `Semantic Analysis: Category [${analysis.semanticCategory}], Score [${analysis.complexityScore.toFixed(2)}], Battery [${(batteryLevel * 100).toFixed(0)}%]`);\n864: \n865:   // Compute dynamic path (overrides static preference)\n866:   const dynamicPrefer = ledger.evaluateSemanticRouting(analysis.complexityScore, batteryLevel);\n867:   forgeLog.info(\"FinOps\", `Dynamic Route Allocation: ${dynamicPrefer.toUpperCase()}`);\n868: \n869:   // Stage 1: Route classification (ONNX-first, then local Arch-Router fallback)\n870:   const route = (await tryOnnxRouter(intent, onProgress)) || (await tryArchRouter(intent, onProgress));\n871: \n872:   // Stage 1.5: TRY BROWSER NATIVE (window.ai) - NEW HIGH PRIORITY\n873:   forgeLog.info(\"Cascade\", \"Stage 1.5: Trying Browser-Native LLM (window.ai)...\");\n874:   const browserAIResult = await guard.wrap(\n875:     \"Browser Native (window.ai)\",\n876:     0,\n877:     () => tryBrowserAI(intent, scaffoldLevel, route || undefined, onProgress)\n878:   );\n879:   if (browserAIResult) {\n880:     browserAIResult.route_policy = route || \"schema_generation\";\n881:     return {\n882:       blueprint: browserAIResult,\n883:       provider: \"Browser-Native (window.ai)\",\n884:       route: route || \"schema_generation\",\n885:     };\n886:   }\n887: \n888:   // Stage 2: ONNX-first blueprint generation\n889:   forgeLog.info(\"Cascade\", \"Stage 2: Blueprint generation - trying Browser Native (ONNX)...\");\n890:   const onnxBlueprint = await guard.wrap(\n891:     \"Browser Native (ONNX)\",\n892:     0,\n893:     () => tryOnnxFallback(intent, scaffoldLevel, route || undefined, onProgress, recentLogs)\n894:   );\n895:   if (onnxBlueprint) {\n896:     onnxBlueprint.route_policy = route || \"schema_generation\";\n897:     return {\n898:       blueprint: onnxBlueprint,\n899:       provider: \"Browser Native (ONNX)\",\n900:       route: route || \"schema_generation\",\n901:     };\n902:   }\n903: \n904:   // Stage 3: Generation - local and cloud fallback chain (order respects finops.inference.prefer)\n905:   const tryLocal = async () => {\n906:     forgeLog.info(\"Cascade\", \"Edge Native unavailable - trying Local Host Servers...\");\n907:     \n908:     // Check local inventory from edge-ai\n909:     const caps = await discoverEdgeAI();\n910:     \n911:     if (caps.foundryLocal) {\n912:         const localBlueprint = await guard.wrap(\n913:           \"Foundry Local\",\n914:           0,\n915:           () => tryFoundryLocal(intent, scaffoldLevel, route || undefined, onProgress, recentLogs)\n916:         );\n917:         if (localBlueprint) {\n918:           localBlueprint.route_policy = route || \"schema_generation\";\n919:           return { blueprint: localBlueprint, provider: \"Foundry Local\", route: route || \"schema_generation\" };\n920:         }\n921:     }\n922: \n923:     // OLLAMA (if foundry failed or not present)\n924:     if (caps.ollama) {\n925:         onProgress?.(\"Generating blueprint via Ollama...\");\n926:         // Reuse tryFoundryLocal logic but pointed at OLLAMA if needed, \n927:         // for now we stick to established foundry + cloud chain but empowered by discovery.\n928:     }\n929:     \n930:     return null;\n931:   };\n932: \n933:   const tryCloud = async () => {\n934:     forgeLog.info(\"Cascade\", \"Local generation failed - trying cloud fallbacks...\");\n935: \n936:     forgeLog.info(\"Cascade\", \"Trying Groq...\");\n937:     const groqBlueprint = await guard.wrap(\n938:       \"Cloud (Groq)\",\n939:       0,\n940:       () => tryGroq(intent, scaffoldLevel, route || undefined, onProgress, recentLogs)\n941:     );\n942:     if (groqBlueprint) {\n943:       groqBlueprint.route_policy = route || \"schema_generation\";\n944:       forgeLog.success(\"Cascade\", \"Blueprint generated by Groq\");\n945:       return { blueprint: groqBlueprint, provider: \"Cloud (Groq)\", route: route || \"schema_generation\" };\n946:     }\n947: \n948:     forgeLog.info(\"Cascade\", \"Trying Cerebras...\");\n949:     const cerebrasBlueprint = await guard.wrap(\n950:       \"Cloud (Cerebras)\",\n951:       0,\n952:       () => tryCerebras(intent, scaffoldLevel, route || undefined, onProgress, recentLogs)\n953:     );\n954:     if (cerebrasBlueprint) {\n955:       cerebrasBlueprint.route_policy = route || \"schema_generation\";\n956:       forgeLog.success(\"Cascade\", \"Blueprint generated by Cerebras\");\n957:       return { blueprint: cerebrasBlueprint, provider: \"Cloud (Cerebras)\", route: route || \"schema_generation\" };\n958:     }\n959: \n960:     return null;\n961:   };\n962: \n963:   if (dynamicPrefer === \"cloud\") {\n964:     // Cloud-first ordering\n965:     const cloudResult = await tryCloud();\n966:     if (cloudResult) return cloudResult;\n967:     const localResult = await tryLocal();\n968:     if (localResult) return localResult;\n969:   } else {\n970:     // local-first (default) or auto\n971:     const localResult = await tryLocal();\n972:     if (localResult) return localResult;\n973:     const cloudResult = await tryCloud();\n974:     if (cloudResult) return cloudResult;\n975:   }\n976: \n977:   forgeLog.error(\"Cascade\", \"ALL PROVIDERS FAILED - no blueprint generated. Check /admin/ide-config for API keys and provider status.\");\n978:   throw new Error(\n979:     \"All AI providers (ONNX, Local, Groq, Cerebras) failed.\\n\\n\" +\n980:     \"Troubleshooting:\\n\" +\n981:     \"• Foundry Local: Is it running? Check with `foundry` CLI.\\n\" +\n982:     \"• Groq / Cerebras: Go to /admin/ide-config and enter your API keys.\\n\" +\n983:     \"• Check the Inference Log on the admin page for detailed diagnostics.\"\n984:   );\n985: }\n986: \n987: // ── Helpers ─────────────────────────────────────────────────────\n988: \n989: function extractJSON(text: string): unknown | null {\n990:   // Try direct parse\n991:   try {\n992:     return JSON.parse(text);\n993:   } catch { /* continue */ }\n994: \n995:   // Try extracting from code fences\n996:   const fenceMatch = text.match(/```(?:json)?\\s*\\n?([\\s\\S]*?)\\n?```/);\n997:   if (fenceMatch) {\n998:     try {\n999:       return JSON.parse(fenceMatch[1]);\n1000:     } catch { /* continue */ }\n1001:   }\n1002: \n1003:   // Try finding JSON object boundaries\n1004:   const firstBrace = text.indexOf(\"{\");\n1005:   const lastBrace = text.lastIndexOf(\"}\");\n1006:   if (firstBrace !== -1 && lastBrace > firstBrace) {\n1007:     try {\n1008:       return JSON.parse(text.slice(firstBrace, lastBrace + 1));\n1009:     } catch { /* give up */ }\n1010:   }\n1011: \n1012:   return null;\n1013: }\n\n(End of file - total 1013 lines)\n</content>",
