      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\LAMPForge_SDTP\\\\forge-flow-learn-0d5b3821\\\\sdk\\\\forge-config.ts\"}",
      "output": "<path>C:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\sdk\\forge-config.ts</path>\n<type>file</type>\n<content>\n1: import type { BrowserCapabilities } from \"../src/lib/browser-flags\";\n2: \n3: export interface ForgeAIConfig {\n4:     groqKey: string;\n5:     cerebrasKey: string;\n6:     foundryPort: number | null;\n7:     ollamaEndpoint: string;\n8:     enableLogging: boolean;\n9:     preferEdgeAI: boolean;\n10:     autoDeepProbe: boolean;\n11:     cachedCapabilities?: BrowserCapabilities;\n12:     lastCapabilityCheck?: string;\n13: }\n14: \n15: const STORAGE_KEY = \"forge-ai-config\";\n16: \n17: const DEFAULTS: ForgeAIConfig = {\n18:     groqKey: \"\",\n19:     cerebrasKey: \"\",\n20:     foundryPort: null,\n21:     ollamaEndpoint: \"http://localhost:11434/v1/chat/completions\",\n22:     enableLogging: true,\n23:     preferEdgeAI: true,\n24:     autoDeepProbe: true,\n25: };\n26: \n27: export function getForgeConfig(): ForgeAIConfig {\n28:     const stored = localStorage.getItem(STORAGE_KEY);\n29:     if (stored) {\n30:         try {\n31:             return { ...DEFAULTS, ...JSON.parse(stored) };\n32:         } catch {\n33:             // Ignore corrupt data\n34:         }\n35:     }\n36:     return { ...DEFAULTS };\n37: }\n38: \n39: export function saveForgeConfig(config: Partial<ForgeAIConfig>) {\n40:     const current = getForgeConfig();\n41:     const next = { ...current, ...config };\n42:     localStorage.setItem(STORAGE_KEY, JSON.stringify(next));\n43: }\n\n(End of file - total 43 lines)\n</content>",
