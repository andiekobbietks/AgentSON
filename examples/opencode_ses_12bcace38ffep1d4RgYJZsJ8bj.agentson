      "output": "<path>C:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\src\\lib\\model-registry.ts</path>\n<type>file</type>\n<content>\n1: export interface SovereignModelCard {\n2:   id: string;\n3:   name: string;\n4:   family: string;\n5:   parameters: string; // e.g. \"0.5B\", \"3.8B\"\n6:   format: \"ONNX (int4)\" | \"WebNN\" | \"GGUF\" | \"Browser Native\" | \"Cloud Pipeline\";\n7:   providerType: \"window-ai\" | \"onnx-web\" | \"foundry-local\" | \"cloud-api\";\n8:   capabilities: string[];\n9:   description: string;\n10:   sdtpRole: string; // Specific role in SDTP/PDE\n11:   status: \"available-now\" | \"coming-soon\" | \"experimental\";\n12:   downloadSize?: string;\n13:   accuracyRef?: string;\n14: }\n15: \n16: export const SOVEREIGN_CATALOGUE: SovereignModelCard[] = [\n17:   {\n18:     id: \"forge-router-sm\",\n19:     name: \"Forge Router Micro\",\n20:     family: \"Qwen2.5\",\n21:     parameters: \"0.5B\",\n22:     format: \"ONNX (int4)\",\n23:     providerType: \"onnx-web\",\n24:     capabilities: [\"json-routing\", \"fast-inference\", \"classification\"],\n25:     description: \"Ultra-fast routing model for zero-latency prompt classification. Runs entirely in browser memory to direct traffic across the multi-tier hierarchy.\",\n26:     sdtpRole: \"PDE Frontend Traffic Director\",\n27:     status: \"available-now\",\n28:     downloadSize: \"350MB\",\n29:     accuracyRef: \"94% routing accuracy on enterprise prompts\"\n30:   },\n31:   {\n32:     id: \"edge-phi-native\",\n33:     name: \"Edge Copilot Native\",\n34:     family: \"Phi-4-mini\",\n35:     parameters: \"3.8B\",\n36:     format: \"Browser Native\",\n37:     providerType: \"window-ai\",\n38:     capabilities: [\"code-gen\", \"reasoning\", \"summarization\", \"tool-calling\"],\n39:     description: \"Microsoft's built-in SLM, unleashed via dynamic flag injection. Executes securely via Windows ML without downloading a separate model blob.\",\n40:     sdtpRole: \"Primary Offline Coder for PDE\",\n41:     status: \"available-now\",\n42:     downloadSize: \"N/A (Built-in)\",\n43:     accuracyRef: \"Comparable to Mixtral 8x7B for basic coding\"\n44:   },\n45:   {\n46:     id: \"chrome-nano-native\",\n47:     name: \"Chrome ML Core\",\n48:     family: \"Gemini Nano\",\n49:     parameters: \"3.2B\",\n50:     format: \"Browser Native\",\n51:     providerType: \"window-ai\",\n52:     capabilities: [\"text-generation\", \"summarization\", \"rewriting\"],\n53:     description: \"Google's on-device model, accessed via the experimental Prompt API. Fully private execution.\",\n54:     sdtpRole: \"Secondary Offline Assistant\",\n55:     status: \"available-now\",\n56:     downloadSize: \"N/A (Built-in)\",\n57:   },\n58:   {\n59:     id: \"forge-architect\",\n60:     name: \"Forge Architect Pro\",\n61:     family: \"Llama 3\",\n62:     parameters: \"8B\",\n63:     format: \"GGUF\",\n64:     providerType: \"foundry-local\",\n65:     capabilities: [\"complex-reasoning\", \"multi-file-editing\", \"architecture\"],\n66:     description: \"Heavy-duty local model requiring the Foundry node. Best for whole-file rewrites and large context windows.\",\n67:     sdtpRole: \"Deep Tech Code Generation\",\n68:     status: \"available-now\",\n69:     downloadSize: \"4.7GB\",\n70:     accuracyRef: \"Llama 3 base accuracy\"\n71:   },\n72:   {\n73:     id: \"forge-vision-net\",\n74:     name: \"Forge Vision Observer\",\n75:     family: \"MoE Vision\",\n76:     parameters: \"1.2B\",\n77:     format: \"WebNN\",\n78:     providerType: \"onnx-web\",\n79:     capabilities: [\"image-analysis\", \"ui-to-code\", \"dom-parsing\"],\n80:     description: \"Experimental vision model mapped to NPU acceleration for parsing UI elements into React components.\",\n81:     sdtpRole: \"Visual PDE Asset Generator\",\n82:     status: \"experimental\",\n83:     downloadSize: \"800MB\",\n84:   },\n85:   {\n86:     id: \"sovereign-cloud-omega\",\n87:     name: \"LAMPForge Omega\",\n88:     family: \"Groq / Cerebras\",\n89:     parameters: \"70B+\",\n90:     format: \"Cloud Pipeline\",\n91:     providerType: \"cloud-api\",\n92:     capabilities: [\"everything\"],\n93:     description: \"Fallback cloud inference when structural complexity exceeds the local node's capabilities.\",\n94:     sdtpRole: \"Ultimate Fallback Oracle\",\n95:     status: \"available-now\",\n96:   }\n97: ];\n\n(End of file - total 97 lines)\n</content>",
