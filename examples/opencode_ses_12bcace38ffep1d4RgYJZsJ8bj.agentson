      "output": "<path>C:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\src\\lib\\edge-ai.ts</path>\n<type>file</type>\n<content>\n1: import { detectCapabilities } from \"./browser-flags\";\n2: \n3: export interface EdgeModelInfo {\n4:   id: string;\n5:   name: string;\n6:   provider: \"window-ai\" | \"webnn\" | \"ollama\" | \"foundry-local\" | \"onnx-web\";\n7:   capabilities: string[];\n8: }\n9: \n10: export interface EdgeAICapabilities {\n11:   webnn: boolean;\n12:   webgpu: boolean;\n13:   windowAI: boolean;\n14:   promptAPI: boolean;\n15:   onnxAvailable: boolean;\n16:   ollama: boolean;\n17:   foundryLocal: boolean;\n18:   tier: \"browser-native\" | \"ollama\" | \"foundry-local\" | \"onnx-webgpu\" | \"cloud\";\n19:   models: EdgeModelInfo[];\n20: }\n21: \n22: // ── Feature Detection ───────────────────────────────────────────\n23: \n24: export function detectWebNN(): boolean {\n25:   return !!(navigator as any).ml;\n26: }\n27: \n28: export function detectWindowAI(): boolean {\n29:   return !!(window as any).ai;\n30: }\n31: \n32: export function detectPromptAPI(): boolean {\n33:   return !!(window as any).ai?.languageModel;\n34: }\n35: \n36: export async function detectONNXRuntime(): Promise<boolean> {\n37:   try {\n38:     const ort = await import(\"onnxruntime-web\");\n39:     return !!ort.InferenceSession;\n40:   } catch {\n41:     return false;\n42:   }\n43: }\n44: \n45: // ── Model Management ────────────────────────────────────────────\n46: \n47: export async function triggerModelDownload(onProgress?: (loaded: number, total: number) => void): Promise<boolean> {\n48:     const caps = await detectCapabilities();\n49:     if (!caps.model.canTriggerDownload) return false;\n50:     \n51:     try {\n52:         const ai = (window as any).ai;\n53:         if (!ai || !ai.languageModel) return false;\n54:         \n55:         await ai.languageModel.create({\n56:             monitor(m: any) {\n57:                 m.addEventListener('downloadprogress', (e: any) => {\n58:                     if (onProgress) onProgress(e.loaded, e.total);\n59:                 });\n60:             }\n61:         });\n62:         return true;\n63:     } catch (e) {\n64:         console.error(\"Failed to trigger model download\", e);\n65:         return false;\n66:     }\n67: }\n68: \n69: export async function getPreferredOnnxBackend(): Promise<'webnn' | 'webgpu' | 'wasm'> {\n70:     const caps = await detectCapabilities();\n71:     return caps.acceleration.preferred;\n72: }\n73: \n74: // ── Local Server Probing ────────────────────────────────────────\n75: \n76: async function probeOllamaModels(): Promise<EdgeModelInfo[]> {\n77:   try {\n78:     const controller = new AbortController();\n79:     const timeout = setTimeout(() => controller.abort(), 3000);\n80:     const res = await fetch(\"http://localhost:11434/api/tags\", {\n81:       signal: controller.signal,\n82:     });\n83:     clearTimeout(timeout);\n84: \n85:     if (!res.ok) return [];\n86:     const data = await res.json();\n87:     return (data.models || []).map((m: any) => ({\n88:       id: m.name,\n89:       name: m.name,\n90:       provider: \"ollama\" as const,\n91:       capabilities: [\"text-generation\", \"tool-calling\"],\n92:     }));\n93:   } catch {\n94:     return [];\n95:   }\n96: }\n97: \n98: async function probeFoundryModels(): Promise<EdgeModelInfo[]> {\n99:   const models: EdgeModelInfo[] = [];\n100:   for (const port of [5273, 5272]) {\n101:     try {\n102:       const controller = new AbortController();\n103:       const timeout = setTimeout(() => controller.abort(), 3000);\n104:       const res = await fetch(`http://localhost:${port}/v1/models`, {\n105:         signal: controller.signal,\n106:       });\n107:       clearTimeout(timeout);\n108: \n109:       if (res.ok) {\n110:         const data = await res.json();\n111:         const list = data.data || data.models || [];\n112:         for (const m of list) {\n113:           models.push({\n114:             id: m.id || m.name,\n115:             name: m.id || m.name,\n116:             provider: \"foundry-local\",\n117:             capabilities: [\"text-generation\", \"onnx\"],\n118:           });\n119:         }\n120:       }\n121:     } catch {\n122:       continue;\n123:     }\n124:   }\n125:   return models;\n126: }\n127: \n128: // ── Main Discovery Function ─────────────────────────────────────\n129: \n130: export async function discoverEdgeAI(): Promise<EdgeAICapabilities> {\n131:   // Use the new rich detection engine\n132:   const caps = await detectCapabilities();\n133:   \n134:   const [onnxAvailable, ollamaModels, foundryModels] = await Promise.all([\n135:       detectONNXRuntime(),\n136:       probeOllamaModels(),\n137:       probeFoundryModels(),\n138:   ]);\n139: \n140:   const models: EdgeModelInfo[] = [];\n141: \n142:   // Browser-native models\n143:   if (caps.apis.windowAI) {\n144:     const availableAPIs = [];\n145:     if (caps.apis.promptAPI.available) availableAPIs.push(\"text-generation\");\n146:     if (caps.apis.summarizer.available) availableAPIs.push(\"summarization\");\n147:     if (caps.apis.writer.available) availableAPIs.push(\"writing\");\n148:     if (caps.apis.rewriter.available) availableAPIs.push(\"rewriting\");\n149: \n150:     models.push({\n151:       id: \"browser-ai\",\n152:       name: `Browser AI (${caps.model.name})`,\n153:       provider: \"window-ai\",\n154:       capabilities: availableAPIs,\n155:     });\n156:   }\n157: \n158:   if (caps.apis.webnn) {\n159:     models.push({\n160:       id: \"webnn-runtime\",\n161:       name: \"WebNN Hardware Accelerated\",\n162:       provider: \"webnn\",\n163:       capabilities: [\"inference\", \"hardware-acceleration\"],\n164:     });\n165:   }\n166: \n167:   if (caps.apis.webgpu && !caps.apis.webnn) {\n168:      models.push({\n169:       id: \"webgpu-runtime\",\n170:       name: \"WebGPU Hardware Accelerated\",\n171:       provider: \"webnn\", // keep API contract\n172:       capabilities: [\"inference\", \"hardware-acceleration\"],\n173:     });\n174:   }\n175: \n176:   // Local server models\n177:   models.push(...ollamaModels);\n178:   models.push(...foundryModels);\n179: \n180:   // ONNX web runtime\n181:   if (onnxAvailable) {\n182:     models.push({\n183:       id: \"onnx-web\",\n184:       name: `ONNX Runtime Web (${caps.acceleration.preferred})`,\n185:       provider: \"onnx-web\",\n186:       capabilities: [\"inference\", \"quantized-models\"],\n187:     });\n188:   }\n189: \n190:   // Determine tier\n191:   let tier: EdgeAICapabilities[\"tier\"] = \"cloud\";\n192:   if (caps.apis.windowAI || caps.apis.webnn) tier = \"browser-native\";\n193:   else if (caps.apis.webgpu) tier = \"onnx-webgpu\";\n194:   else if (ollamaModels.length > 0) tier = \"ollama\";\n195:   else if (foundryModels.length > 0) tier = \"foundry-local\";\n196: \n197:   return {\n198:     webnn: caps.apis.webnn,\n199:     webgpu: caps.apis.webgpu,\n200:     windowAI: caps.apis.windowAI,\n201:     promptAPI: caps.apis.promptAPI.available,\n202:     onnxAvailable,\n203:     ollama: ollamaModels.length > 0,\n204:     foundryLocal: foundryModels.length > 0,\n205:     tier,\n206:     models,\n207:   };\n208: }\n209: \n210: // ── Browser-Native AI Inference ─────────────────────────────────\n211: \n212: export async function inferWithBrowserAI(prompt: string): Promise<string | null> {\n213:   const caps = await detectCapabilities();\n214:   if (caps.apis.promptAPI.status !== 'readily') return null;\n215:   \n216:   try {\n217:     const ai = (window as any).ai;\n218:     const session = await ai.languageModel.create({\n219:       systemPrompt: \"You are a helpful expert.\",\n220:     });\n221:     const response = await session.prompt(prompt);\n222:     session.destroy();\n223:     return response;\n224:   } catch (err) {\n225:     console.warn(\"window.ai inference failed:\", err);\n226:     return null;\n227:   }\n228: }\n229: \n230: export async function inferWithAllAPIs(prompt: string, taskType: 'general' | 'summarize' | 'write' | 'rewrite' = 'general'): Promise<string | null> {\n231:   const caps = await detectCapabilities();\n232:   const ai = (window as any).ai;\n233:   if (!ai) return null;\n234: \n235:   try {\n236:      if (taskType === 'summarize' && caps.apis.summarizer.available) {\n237:         const summarizer = await ai.summarizer.create();\n238:         const res = await summarizer.summarize(prompt);\n239:         summarizer.destroy();\n240:         return res;\n241:      }\n242:      if (taskType === 'write' && caps.apis.writer.available) {\n243:         const writer = await ai.writer.create();\n244:         const res = await writer.write(prompt);\n245:         writer.destroy();\n246:         return res;\n247:      }\n248:      if (taskType === 'rewrite' && caps.apis.rewriter.available) {\n249:         const rewriter = await ai.rewriter.create();\n250:         const res = await rewriter.rewrite(prompt);\n251:         rewriter.destroy();\n252:         return res;\n253:      }\n254: \n255:      // Fallback to promptAPI\n256:      if (caps.apis.promptAPI.available) {\n257:         return await inferWithBrowserAI(prompt);\n258:      }\n259:   } catch (e) {\n260:       console.warn(`inferWithAllAPIs(${taskType}) failed: `, e);\n261:   }\n262:   return null;\n263: }\n264: \n265: // ── CO₂ Estimation ──────────────────────────────────────────────\n266: \n267: export function estimateCO2(tier: EdgeAICapabilities[\"tier\"]): {\n268:   grams: number;\n269:   label: string;\n270:   savings: string;\n271: } {\n272:   switch (tier) {\n273:     case \"browser-native\":\n274:       return { grams: 0, label: \"0g CO₂\", savings: \"~100% reduction vs cloud\" };\n275:     case \"onnx-webgpu\":\n276:       return { grams: 0.05, label: \"~0.05g CO₂\", savings: \"~99% reduction vs cloud (WebGPU hardware acceleration)\" };\n277:     case \"ollama\":\n278:       return { grams: 0.2, label: \"~0.2g CO₂\", savings: \"~98% reduction vs cloud\" };\n279:     case \"foundry-local\":\n280:       return { grams: 0.1, label: \"~0.1g CO₂\", savings: \"~99% reduction vs cloud\" };\n281:     case \"cloud\":\n282:       return { grams: 4.5, label: \"~4.5g CO₂\", savings: \"Cloud inference baseline\" };\n283:   }\n284: }\n\n(End of file - total 284 lines)\n</content>",
