      "output": "<path>C:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\lampforge-benchmark.html</path>\n<type>file</type>\n<content>\n1023:     async function probeFoundryLocal() {\n1024:       const ports = [5272, 55335, 62583];\n1025:       const result = { available: false, port: null, models: [], details: '' };\n1026:       for (const port of ports) {\n1027:         try {\n1028:           const controller = new AbortController();\n1029:           const timeout = setTimeout(() => controller.abort(), 1500);\n1030:           const res = await fetch(`http://localhost:${port}/v1/models`, {\n1031:             signal: controller.signal\n1032:           });\n1033:           clearTimeout(timeout);\n1034:           if (res.ok) {\n1035:             const data = await res.json();\n1036:             result.available = true;\n1037:             result.port = port;\n1038:             result.models = (data.data || []).map(m => m.id);\n1039:             result.details = `Found on port ${port} with ${result.models.length} model(s)`;\n1040:             break;\n1041:           }\n1042:         } catch (e) { /* port not available */ }\n1043:       }\n1044:       if (!result.available) result.details = 'No Foundry Local service detected';\n1045:       return result;\n1046:     }\n1047: \n1048:     // ---- Synthetic Compute Benchmark ----\n1049:     function runComputeBenchmark() {\n1050:       const N = 128;\n1051:       const A = new Float32Array(N * N);\n1052:       const B = new Float32Array(N * N);\n1053:       const C = new Float32Array(N * N);\n1054:       for (let i = 0; i < N * N; i++) { A[i] = Math.random(); B[i] = Math.random(); }\n1055: \n1056:       const iterations = 5;\n1057:       const times = [];\n1058: \n1059:       for (let iter = 0; iter < iterations; iter++) {\n1060:         const start = performance.now();\n1061:         for (let i = 0; i < N; i++) {\n1062:           for (let j = 0; j < N; j++) {\n1063:             let sum = 0;\n1064:             for (let k = 0; k < N; k++) { sum += A[i * N + k] * B[k * N + j]; }\n1065:             C[i * N + j] = sum;\n1066:           }\n1067:         }\n1068:         times.push(performance.now() - start);\n1069:       }\n1070: \n1071:       times.sort((a, b) => a - b);\n1072:       const medianMs = times[Math.floor(times.length / 2)];\n\n(Showing lines 1023-1072 of 1623. Use offset=1073 to continue.)\n</content>",
