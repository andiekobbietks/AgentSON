    {
      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"$os = Get-CimInstance Win32_OperatingSystem; $cpu = Get-CimInstance Win32_Processor; $ram = Get-CimInstance Win32_PhysicalMemory; $gpu = Get-CimInstance Win32_VideoController; $bios = Get-CimInstance Win32_BIOS; Write-Host \\\"=== SYSTEM INFO ===\\\"; Write-Host \\\"CPU: $($cpu.Name)\\\"; Write-Host \\\"Cores: $($cpu.NumberOfCores) / Threads: $($cpu.NumberOfLogicalProcessors)\\\"; Write-Host \\\"Max Clock: $($cpu.MaxClockSpeed) MHz\\\"; Write-Host \\\"Voltage: $($cpu.CurrentVoltage)V\\\"; Write-Host \\\"Status: $($cpu.CpuStatus)\\\"; Write-Host \\\"\\\"; Write-Host \\\"=== RAM ===\\\"; foreach ($r in $ram) { Write-Host \\\"Slot: $($r.DeviceLocator) - $($r.Capacity/1GB)GB - Speed: $($r.Speed)MHz - Mfg: $($r.Manufacturer)\\\" }; Write-Host \\\"\\\"; Write-Host \\\"=== GPU ===\\\"; foreach ($g in $gpu) { Write-Host \\\"$($g.Name) - Driver: $($g.DriverVersion) - Status: $($g.Status)\\\" }; Write-Host \\\"\\\"; Write-Host \\\"=== BIOS ===\\\"; Write-Host \\\"Vendor: $($bios.Manufacturer) - Version: $($bios.SMBIOSBIOSVersion) - Date: $($bios.ReleaseDate)\\\"\", \"description\": \"Get detailed hardware info\"}",
