      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\temperature_monitor.py\", \"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"\\nTemperature monitor for HP Omen 15-ce0xx.\\nUses WMI to read thermal zones and fans.\\nRequires: pip install wmi pywin32\\n\\\"\\\"\\\"\\nimport wmi\\nimport time\\nimport csv\\nfrom datetime import datetime\\n\\ndef get_temperatures():\\n    \\\"\\\"\\\"Read thermal zone temperatures.\\\"\\\"\\\"\\n    c = wmi.WMI(namespace=\\\"root\\\\\\\\OpenHardwareMonitor\\\")\\n    try:\\n        sensors = c.Sensor()\\n        temps = {}\\n        for sensor in sensors:\\n            if sensor.SensorType == 'Temperature':\\n                temps[sensor.Name] = sensor.Value\\n        return temps\\n    except Exception as e:\\n        # Fallback to MSAcpi_ThermalZoneTemperature (requires admin)\\n        c = wmi.WMI(namespace=\\\"root\\\\\\\\WMI\\\")\\n        zones = c.MSAcpi_ThermalZoneTemperature()\\n        temps = {}\\n        for zone in zones:\\n            # Temperature is in tenths of Kelvin\\n            temp_c = (zone.CurrentTemperature / 10) - 273.15\\n            temps[f\\\"Zone{len(temps)}\\\"] = temp_c\\n        return temps\\n\\ndef get_fan_speed():\\n    \\\"\\\"\\\"Read fan speeds.\\\"\\\"\\\"\\n    c = wmi.WMI(namespace=\\\"root\\\\\\\\WMI\\\")\\n    try:\\n        fans = c.MSAcpi_ThermalZoneTemperature()  # This is temp, not fan\\n        # Alternative: use OpenHardwareMonitor for fan data\\n        c2 = wmi.WMI(namespace=\\\"root\\\\\\\\OpenHardwareMonitor\\\")\\n        sensors = c2.Sensor()\\n        fan_speeds = {}\\n        for sensor in sensors:\\n            if sensor.SensorType == 'Fan':\\n                fan_speeds[sensor.Name] = sensor.Value\\n        return fan_speeds\\n    except:\\n        return {}\\n\\ndef log_to_csv(temps, fans, filename=\\\"temperature_log.csv\\\"):\\n    \\\"\\\"\\\"Append data to CSV file.\\\"\\\"\\\"\\n    timestamp = datetime.now().isoformat()\\n    row = {\\\"timestamp\\\": timestamp}\\n    row.update(temps)\\n    row.update(fans)\\n    file_exists = False\\n    try:\\n        with open(filename, 'r') as f:\\n            file_exists = True\\n    except FileNotFoundError:\\n        pass\\n    \\n    with open(filename, 'a', newline='') as csvfile:\\n        fieldnames = list(row.keys())\\n        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)\\n        if not file_exists:\\n            writer.writeheader()\\n        writer.writerow(row)\\n\\nif __name__ == \\\"__main__\\\":\\n    print(\\\"Starting temperature monitoring (Ctrl+C to stop)...\\\")\\n    print(\\\"Log file: temperature_log.csv\\\")\\n    try:\\n        while True:\\n            temps = get_temperatures()\\n            fans = get_fan_speed()\\n            print(f\\\"Temperatures: {temps}\\\")\\n            print(f\\\"Fan speeds: {fans}\\\")\\n            log_to_csv(temps, fans)\\n            time.sleep(5)\\n    except KeyboardInterrupt:\\n        print(\\\"Monitoring stopped.\\\")\"}",
