",\"Driver plug-in motore di alimentazione Intel(R)\",\"Kernel \",\"Boot\",\"Running\",\"OK\",\"TRUE\",\"FALSE\",\"32.768\",\"53.248\",\"0\",\"\",\"C:\\WINDOWS\\system32\\drivers\\intelpep.sys\",\"4.096\"\r\n\"intelpmax\",\"Intel(R) Dynamic Device Peak Power Manager Driver\",\"Intel(R) Dynamic Device Peak Power Manager Driver\",\"Kernel \",\"Manual\",\"Stopped\",\"OK\",\"FALSE\",\"FALSE\",\"12.288\",\"12.288\",\"0\",\"\",\"C:\\WINDOWS\\system32\\drivers\\intelpmax.sys\",\"4.096\"\r\n\"intelppm\",\"Driver processore Intel\",\"Driver processore Intel\",\"Kernel \",\"Manual\",\"Running\",\"OK\",\"TRUE\",\"FALSE\",\"110.592\",\"69.632\",\"0\",\"\",\"C:\\WINDOWS\\system32\\drivers\\intelppm.sys\",\"8.192\"\r\n\"MEIx64\",\"Intel(R) Management Engine Interface \",\"Intel(R) Management Engine Interface \",\"Kernel \",\"Manual\",\"Running\",\"OK\",\"TRUE\",\"FALSE\",\"16.384\",\"167.936\",\"0\",\"12/07/2018 08:42:57\",\"C:\\WINDOWS\\system32\\drivers\\TeeDriverW8x64.sys\",\"4.096\"\r\n\"NativeWifiP\",\"Filtro NativeWiFi\",\"Filtro NativeWiFi\",\"Kernel \",\"Manual\",\"Running\",\"OK\",\"TRUE\",\"FALSE\",\"8.192\",\"589.824\",\"0\",\"\",\"C:\\WINDOWS\\system32\\DRIVERS\\nwifi.sys\",\"4.096\"\r\n\"Netwtw04\",\"___ Intel(R) Wireless Adapter Driver for Windows 10 - 64 Bit\",\"___ Intel(R) Wireless Adapter Driver for Windows 10 - 64 Bit\",\"Kernel \",\"Manual\",\"Running\",\"OK\",\"TRUE\",\"FALSE\",\"2.998.272\",\"4.485.120\",\"0\",\"02/06/2020 20:41:59\",\"C:\\WINDOWS\\system32\\drivers\\Netwtw04.sys\",\"8.192\"\r\n\"NVHDA\",\"Service for NVIDIA High Definition Audio Driver\",\"Service for NVIDIA High Definition Audio Driver\",\"Kernel \",\"Manual\",\"Stopped\",\"OK\",\"FALSE\",\"FALSE\",\"45.056\",\"40.960\",\"0\",\"20/01/2023 10:48:10\",\"C:\\WINDOWS\\system32\\drivers\\nvhda64v.sys\",\"4.096\"\r\n\"nvvad_WaveExtensible\",\"NVIDIA Virtual Audio Device (Wave Extensible) (WDM)\",\"NVIDIA Virtual Audio Device (Wave Extensible) (WDM)\",\"Kernel \",\"Manual\",\"Running\",\"OK\",\"T