      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\mock-data\\seed.ts</path>\n<type>file</type>\n<content>\n1: import type {\n2:   GPTeam,\n3:   GPProject,\n4:   GPDiscussion,\n5:   GPComment,\n6:   GPReaction,\n7:   GPUserProfile,\n8:   LMSCourse,\n9:   LMSChapter,\n10:   LMSLesson,\n11:   LMSEnrollment,\n12:   LMSCourseProgress,\n13:   FGEvent,\n14:   FGEventAttendee,\n15:   FGMentorMatch,\n16:   FGAISettings,\n17:   FGUserSettings,\n18:   FGDMThread,\n19:   FGDMMessage,\n20:   FGNotification,\n21:   FGSSOProvider,\n22: } from \"./types\";\n23: \n24: const now = Date.now();\n25: const daysAgo = (d: number) => new Date(now - d * 86400000).toISOString();\n26: const daysAhead = (d: number) => new Date(now + d * 86400000).toISOString();\n27: \n28: export const CURRENT_USER_ID = \"maya@firstgens.test\";\n29: \n30: export const seedUsers: GPUserProfile[] = [\n31:   {\n32:     user: \"maya@firstgens.test\",\n33:     enabled: true,\n34:     full_name: \"Maya Okafor\",\n35:     bio: \"First-year sociology. First in my family to go to uni. Coffee + library = happy.\",\n36:     readme:\n37:       \"Hi! I'm Maya. I grew up in Peckham and I'm the first person in my family to study at university. I'm interested in social policy, housing and community organising. Outside of class you'll find me at the campus radio station or wandering around Borough Market pretending I can afford the cheese.\",\n38:     image: \"\",\n39:     cover_image: \"\",\n40:     image_background_color: \"#ede9fe\",\n41:   },\n42:   {\n43:     user: \"jordan@firstgens.test\",\n44:     enabled: true,\n45:     full_name: \"Jordan Reyes\",\n46:     bio: \"Third-year CS. Peer mentor. Ask me about imposter syndrome.\",\n47:     readme: \"Third-year CS student, peer mentor on the FirstGens programme.\",\n48:     image: \"\",\n49:     cover_image: \"\",\n50:     image_background_color: \"#dbeafe\",\n51:   },\n52:   {\n53:     user: \"sam@firstgens.test\",\n54:     enabled: true,\n55:     full_name: \"Sam Lindqvist\",\n56:     bio: \"Second-year economics. Loves study groups, hates 9am lectures.\",\n57:     readme: \"\",\n58:     image: \"\",\n59:     cover_image: \"\",\n60:     image_background_color: \"#fef3c7\",\n61:   },\n62:   {\n63:     user: \"priya@firstgens.test\",\n64:     enabled: true,\n65:     full_name: \"Priya Natarajan\",\n66:     bio: \"PhD candidate, mentor in the Mentor Lounge. Here to listen.\",\n67:     readme: \"\",\n68:     image: \"\",\n69:     cover_image: \"\",\n70:     image_background_color: \"#dcfce7\",\n71:   },\n72:   {\n73:     user: \"alex@firstgens.test\",\n74:     enabled: true,\n75:     full_name: \"Alex Chen\",\n76:     bio: \"Fourth-year biomedical sciences. Survived first year, you will too.\",\n77:     readme: \"\",\n78:     image: \"\",\n79:     cover_image: \"\",\n80:     image_background_color: \"#fce7f3\",\n81:   },\n82:   {\n83:     user: \"rosa@firstgens.test\",\n84:     enabled: true,\n85:     full_name: \"Dr. Rosa Hassan\",\n86:     bio: \"Programme coordinator. Space admin for First Year Support.\",\n87:     readme: \"\",\n88:     image: \"\",\n89:     cover_image: \"\",\n90:     image_background_color: \"#e0e7ff\",\n91:   },\n92: ];\n93: \n94: export const seedTeams: GPTeam[] = [\n95:   {\n96:     id: \"Community\",\n97:     title: \"Community\",\n98:     icon: \"🫶\",\n99:     is_private: false,\n100:     archived_at: null,\n101:     archived_by: null,\n102:   },\n103:   {\n104:     id: \"Academic Support\",\n105:     title: \"Academic Support\",\n106:     icon: \"🎓\",\n107:     is_private: false,\n108:     archived_at: null,\n109:     archived_by: null,\n110:   },\n111: ];\n112: \n113: export const seedProjects: GPProject[] = [\n114:   {\n115:     id: \"first-year-support\",\n116:     title: \"First Year Support\",\n117:     description:\n118:       \"A soft landing for first-gen students starting university. Questions welcome, no judgement.\",\n119:     status: \"Open\",\n120:     team: \"Community\",\n121:     progress: 0,\n122:     icon: \"🌱\",\n123:     readme: \"\",\n124:     tasks_count: 0,\n125:     discussions_count: 3,\n126:     archived_at: null,\n127:     archived_by: null,\n128:     is_private: false,\n129:   },\n130:   {\n131:     id: \"mentor-lounge\",\n132:     title: \"Mentor Lounge\",\n133:     description: \"Where mentees and mentors hang out, share wins, and ask the awkward questions.\",\n134:     status: \"Open\",\n135:     team: \"Community\",\n136:     progress: 0,\n137:     icon: \"🛋️\",\n138:     readme: \"\",\n139:     tasks_count: 0,\n140:     discussions_count: 2,\n141:     archived_at: null,\n142:     archived_by: null,\n143:     is_private: false,\n144:   },\n145:   {\n146:     id: \"study-skills\",\n147:     title: \"Study Skills\",\n148:     description:\n149:       \"Note-taking, exam prep, and how to actually read an academic paper without crying.\",\n150:     status: \"Open\",\n151:     team: \"Academic Support\",\n152:     progress: 0,\n153:     icon: \"📚\",\n154:     readme: \"\",\n155:     tasks_count: 0,\n156:     discussions_count: 1,\n157:     archived_at: null,\n158:     archived_by: null,\n159:     is_private: false,\n160:   },\n161:   {\n162:     id: \"money-matters\",\n163:     title: \"Money Matters\",\n164:     description: \"Bursaries, budgeting, part-time work. Talking about money is allowed here.\",\n165:     status: \"Open\",\n166:     team: \"Community\",\n167:     progress: 0,\n168:     icon: \"💸\",\n169:     readme: \"\",\n170:     tasks_count: 0,\n171:     discussions_count: 1,\n172:     archived_at: null,\n173:     archived_by: null,\n174:     is_private: false,\n175:   },\n176: ];\n177: \n178: export const seedDiscussions: GPDiscussion[] = [\n179:   {\n180:     id: \"1\",\n181:     project: \"first-year-support\",\n182:     team: \"Community\",\n183:     status: \"\",\n184:     title: \"Does anyone else feel like everyone knows what they're doing except them?\",\n185:     slug: \"does-anyone-else-feel-like-everyone-knows\",\n186:     content:\n187:       \"<p>I'm two weeks in and I swear every other student grew up knowing what a 'seminar' is. I keep nodding along. Is this normal? I feel completely lost and honestly a bit hopeless about whether I belong here at all.</p>\",\n188:     last_post_at: daysAgo(0),\n189:     last_post_by: \"alex@firstgens.test\",\n190:     comments_count: 2,\n191:     participants_count: 3,\n192:     closed_at: null,\n193:     closed_by: null,\n194:     pinned_at: null,\n195:     pinned_by: null,\n196:     author_id: \"maya@firstgens.test\",\n197:     created_at: daysAgo(1),\n198:   },\n199:   {\n200:     id: \"2\",\n201:     project: \"first-year-support\",\n202:     team: \"Community\",\n203:     status: \"\",\n204:     title: \"Free welcome breakfast on Friday — bring a friend\",\n205:     slug: \"free-welcome-breakfast-on-friday\",\n206:     content:\n207:       \"<p>Reminder that the welcome breakfast is this Friday at 9am in the Atrium. Free pastries, free coffee, and a few of us older students will be there to answer anything. No sign-up needed. 💛</p>\",\n208:     last_post_at: daysAgo(1),\n209:     last_post_by: \"sam@firstgens.test\",\n210:     comments_count: 1,\n211:     participants_count: 2,\n212:     closed_at: null,\n213:     closed_by: null,\n214:     pinned_at: daysAgo(2),\n215:     pinned_by: \"rosa@firstgens.test\",\n216:     author_id: \"rosa@firstgens.test\",\n217:     created_at: daysAgo(3),\n218:   },\n219:   {\n220:     id: \"3\",\n221:     project: \"first-year-support\",\n222:     team: \"Community\",\n223:     status: \"\",\n224:     title: \"Tip: office hours are not scary\",\n225:     slug: \"tip-office-hours-are-not-scary\",\n226:     content:\n227:       \"<p>Took me a whole term to figure this out — lecturers actually <em>want</em> you to come to office hours. You don't need a brilliant question. 'I'm a bit lost' is a fine opener.</p>\",\n228:     last_post_at: daysAgo(4),\n229:     last_post_by: \"alex@firstgens.test\",\n230:     comments_count: 0,\n231:     participants_count: 1,\n232:     closed_at: null,\n233:     closed_by: null,\n234:     pinned_at: null,\n235:     pinned_by: null,\n236:     author_id: \"alex@firstgens.test\",\n237:     created_at: daysAgo(4),\n238:   },\n239:   {\n240:     id: \"4\",\n241:     project: \"mentor-lounge\",\n242:     team: \"Community\",\n243:     status: \"\",\n244:     title: \"Mentors: how do you handle a mentee who goes quiet?\",\n245:     slug: \"mentors-mentee-quiet\",\n246:     content:\n247:       \"<p>My mentee hasn't replied in two weeks. I don't want to be pushy but I also don't want them to disappear. How do you all approach this?</p>\",\n248:     last_post_at: daysAgo(0),\n249:     last_post_by: \"priya@firstgens.test\",\n250:     comments_count: 1,\n251:     participants_count: 2,\n252:     closed_at: null,\n253:     closed_by: null,\n254:     pinned_at: null,\n255:     pinned_by: null,\n256:     author_id: \"jordan@firstgens.test\",\n257:     created_at: daysAgo(2),\n258:   },\n259:   {\n260:     id: \"5\",\n261:     project: \"mentor-lounge\",\n262:     team: \"Community\",\n263:     status: \"\",\n264:     title: \"Win of the week 🎉\",\n265:     slug: \"win-of-the-week\",\n266:     content:\n267:       \"<p>My mentee just submitted their first essay and got a 68. Last month they were ready to drop out. So proud.</p>\",\n268:     last_post_at: daysAgo(1),\n269:     last_post_by: \"priya@firstgens.test\",\n270:     comments_count: 0,\n271:     participants_count: 1,\n272:     closed_at: null,\n273:     closed_by: null,\n274:     pinned_at: null,\n275:     pinned_by: null,\n276:     author_id: \"priya@firstgens.test\",\n277:     created_at: daysAgo(1),\n278:   },\n279:   {\n280:     id: \"6\",\n281:     project: \"study-skills\",\n282:     team: \"Academic Support\",\n283:     status: \"\",\n284:     title: \"How do you actually take notes in a lecture?\",\n285:     slug: \"how-do-you-actually-take-notes\",\n286:     content:\n287:       \"<p>Pen and paper? Laptop? A weird Notion setup? I've tried all three and somehow my notes are useless by the time I get home.</p>\",\n288:     last_post_at: daysAgo(3),\n289:     last_post_by: \"sam@firstgens.test\",\n290:     comments_count: 0,\n291:     participants_count: 1,\n292:     closed_at: null,\n293:     closed_by: null,\n294:     pinned_at: null,\n295:     pinned_by: null,\n296:     author_id: \"sam@firstgens.test\",\n297:     created_at: daysAgo(3),\n298:   },\n299:   {\n300:     id: \"7\",\n301:     project: \"money-matters\",\n302:     team: \"Community\",\n303:     status: \"\",\n304:     title: \"Bursary application deadline next Tuesday — don't miss it\",\n305:     slug: \"bursary-application-deadline\",\n306:     content:\n307:       \"<p>The hardship bursary closes next Tuesday at 5pm. If money is tight, please apply — it's not means-tested very strictly and lots of first-gen students get it.</p>\",\n308:     last_post_at: daysAgo(1),\n309:     last_post_by: \"rosa@firstgens.test\",\n310:     comments_count: 0,\n311:     participants_count: 1,\n312:     closed_at: null,\n313:     closed_by: null,\n314:     pinned_at: daysAgo(1),\n315:     pinned_by: \"rosa@firstgens.test\",\n316:     author_id: \"rosa@firstgens.test\",\n317:     created_at: daysAgo(1),\n318:   },\n319: ];\n320: \n321: export const seedComments: GPComment[] = [\n322:   {\n323:     id: \"c_1\",\n324:     content:\n325:       \"<p>You are absolutely not alone. I felt exactly the same in my first term — turns out half my course were quietly panicking too. It does get easier, promise. 💛</p>\",\n326:     reference_doctype: \"GP Discussion\",\n327:     reference_name: \"1\",\n328:     deleted_at: null,\n329:     author_id: \"jordan@firstgens.test\",\n330:     created_at: daysAgo(0),\n331:   },\n332:   {\n333:     id: \"c_2\",\n334:     content:\n335:       \"<p>+1 to Jordan. Also — there's a drop-in chat with Dr. Hassan on Thursday, totally informal, might be worth a look.</p>\",\n336:     reference_doctype: \"GP Discussion\",\n337:     reference_name: \"1\",\n338:     deleted_at: null,\n339:     author_id: \"alex@firstgens.test\",\n340:     created_at: daysAgo(0),\n341:   },\n342:   {\n343:     id: \"c_3\",\n344:     content: \"<p>Will be there!</p>\",\n345:     reference_doctype: \"GP Discussion\",\n346:     reference_name: \"2\",\n347:     deleted_at: null,\n348:     author_id: \"sam@firstgens.test\",\n349:     created_at: daysAgo(1),\n350:   },\n351:   {\n352:     id: \"c_4\",\n353:     content:\n354:       '<p>Usually I send one low-pressure check-in (\"no need to reply, just thinking of you\") and then give it space. Most come back eventually.</p>',\n355:     reference_doctype: \"GP Discussion\",\n356:     reference_name: \"4\",\n357:     deleted_at: null,\n358:     author_id: \"priya@firstgens.test\",\n359:     created_at: daysAgo(0),\n360:   },\n361: ];\n362: \n363: export const seedReactions: GPReaction[] = [\n364:   {\n365:     id: \"r_1\",\n366:     reference_doctype: \"GP Discussion\",\n367:     reference_name: \"1\",\n368:     user: \"jordan@firstgens.test\",\n369:     emoji: \"💛\",\n370:   },\n371:   {\n372:     id: \"r_2\",\n373:     reference_doctype: \"GP Discussion\",\n374:     reference_name: \"1\",\n375:     user: \"alex@firstgens.test\",\n376:     emoji: \"💛\",\n377:   },\n378:   {\n379:     id: \"r_3\",\n380:     reference_doctype: \"GP Discussion\",\n381:     reference_name: \"1\",\n382:     user: \"rosa@firstgens.test\",\n383:     emoji: \"🤗\",\n384:   },\n385:   {\n386:     id: \"r_4\",\n387:     reference_doctype: \"GP Discussion\",\n388:     reference_name: \"2\",\n389:     user: \"maya@firstgens.test\",\n390:     emoji: \"🎉\",\n391:   },\n392:   {\n393:     id: \"r_5\",\n394:     reference_doctype: \"GP Discussion\",\n395:     reference_name: \"5\",\n396:     user: \"jordan@firstgens.test\",\n397:     emoji: \"🎉\",\n398:   },\n399:   {\n400:     id: \"r_6\",\n401:     reference_doctype: \"GP Discussion\",\n402:     reference_name: \"5\",\n403:     user: \"alex@firstgens.test\",\n404:     emoji: \"🎉\",\n405:   },\n406: ];\n407: \n408: // ============================================================\n409: // LMS seed — fully demoable\n410: // ============================================================\n411: \n412: export const seedCourses: LMSCourse[] = [\n413:   {\n414:     id: \"navigating-uni-first-gen\",\n415:     title: \"Navigating University as a First-Gen Student\",\n416:     short_introduction:\n417:       \"The unwritten rules nobody told you about office hours, reading lists, and asking for help.\",\n418:     description:\n419:       \"A friendly orientation for students who are the first in their family to attend university. We cover the hidden curriculum — the things everyone seems to already know but no-one taught you.\",\n420:     image: \"\",\n421:     paid_course: false,\n422:     featured: true,\n423:     published: true,\n424:     enable_certification: true,\n425:     category: \"Student Life\",\n426:     tags: \"first-gen, orientation, study skills\",\n427:     status: \"Approved\",\n428:     author: \"rosa@firstgens.test\",\n429:     enrollments: 318,\n430:     lessons: 3,\n431:     created_at: daysAgo(60),\n432:   },\n433:   {\n434:     id: \"academic-writing-101\",\n435:     title: \"Academic Writing 101\",\n436:     short_introduction:\n437:       \"How to structure an essay, cite sources, and not panic at the word 'argument'.\",\n438:     description:\n439:       \"Eight short lessons taking you from blank page to submitted essay, with worked examples.\",\n440:     image: \"\",\n441:     paid_course: false,\n442:     featured: true,\n443:     published: true,\n444:     enable_certification: false,\n445:     category: \"Writing\",\n446:     tags: \"writing, essays, citation\",\n447:     status: \"Approved\",\n448:     author: \"priya@firstgens.test\",\n449:     enrollments: 142,\n450:     lessons: 2,\n451:     created_at: daysAgo(40),\n452:   },\n453:   {\n454:     id: \"budgeting-student-loan\",\n455:     title: \"Budgeting on a Student Loan\",\n456:     short_introduction: \"Practical money basics. No jargon, no judgement.\",\n457:     description:\n458:       \"Working out what comes in, what goes out, and what to do when the numbers don't add up.\",\n459:     image: \"\",\n460:     paid_course: false,\n461:     featured: false,\n462:     published: true,\n463:     enable_certification: false,\n464:     category: \"Money\",\n465:     tags: \"money, budgeting, loans\",\n466:     status: \"Approved\",\n467:     author: \"rosa@firstgens.test\",\n468:     enrollments: 89,\n469:     lessons: 2,\n470:     created_at: daysAgo(20),\n471:   },\n472: ];\n473: \n474: export const seedChapters: LMSChapter[] = [\n475:   {\n476:     id: \"ch_nav_1\",\n477:     course: \"navigating-uni-first-gen\",\n478:     title: \"Before you arrive\",\n479:     description: \"Mindset, paperwork, packing.\",\n480:     idx: 1,\n481:   },\n482:   {\n483:     id: \"ch_nav_2\",\n484:     course: \"navigating-uni-first-gen\",\n485:     title: \"The hidden curriculum\",\n486:     description: \"Office hours, reading lists, jargon.\",\n487:     idx: 2,\n488:   },\n489:   {\n490:     id: \"ch_aw_1\",\n491:     course: \"academic-writing-101\",\n492:     title: \"Planning an essay\",\n493:     description: \"From question to outline.\",\n494:     idx: 1,\n495:   },\n496:   {\n497:     id: \"ch_bg_1\",\n498:     course: \"budgeting-student-loan\",\n499:     title: \"The basics\",\n500:     description: \"Money in, money out.\",\n501:     idx: 1,\n502:   },\n503: ];\n504: \n505: // Hand-picked, real, embeddable public lectures / Khan-style overviews.\n506: export const seedLessons: LMSLesson[] = [\n507:   {\n508:     id: \"ls_nav_1\",\n509:     chapter: \"ch_nav_1\",\n510:     course: \"navigating-uni-first-gen\",\n511:     title: \"Welcome — what 'first-gen' means here\",\n512:     body: \"<p>Welcome to the course. In this short intro Dr. Hassan explains who the course is for and how to get the most out of it. Watch the video, then jump to the next lesson.</p><p><strong>Reflection:</strong> write one sentence about why you signed up. You don't have to share it.</p>\",\n513:     youtube_video: \"ZXsQAXx_ao0\",\n514:     include_in_preview: true,\n515:     idx: 1,\n516:   },\n517:   {\n518:     id: \"ls_nav_2\",\n519:     chapter: \"ch_nav_2\",\n520:     course: \"navigating-uni-first-gen\",\n521:     title: \"Office hours, demystified\",\n522:     body: \"<p>Office hours are the single most underused resource at university. Here's what they are, how to book one, and what to say when you arrive.</p>\",\n523:     youtube_video: \"1eVMG9LcDxk\",\n524:     include_in_preview: false,\n525:     idx: 1,\n526:   },\n527:   {\n528:     id: \"ls_nav_3\",\n529:     chapter: \"ch_nav_2\",\n530:     course: \"navigating-uni-first-gen\",\n531:     title: \"Reading a reading list without crying\",\n532:     body: \"<p>Not every item on a reading list is meant to be read cover-to-cover. We break down which are core, which are supplementary, and how to skim with purpose.</p>\",\n533:     youtube_video: \"\",\n534:     include_in_preview: false,\n535:     idx: 2,\n536:   },\n537:   {\n538:     id: \"ls_aw_1\",\n539:     chapter: \"ch_aw_1\",\n540:     course: \"academic-writing-101\",\n541:     title: \"From question to outline\",\n542:     body: \"<p>Every good essay starts with breaking down the question. In this lesson we work through a real prompt together.</p>\",\n543:     youtube_video: \"vtIzMaLkCaM\",\n544:     include_in_preview: true,\n545:     idx: 1,\n546:   },\n547:   {\n548:     id: \"ls_aw_2\",\n549:     chapter: \"ch_aw_1\",\n550:     course: \"academic-writing-101\",\n551:     title: \"Building a paragraph that argues\",\n552:     body: \"<p>PEEL, TEAL, whatever you call it — the point is the same: claim, evidence, reasoning. Watch and then try the exercise.</p>\",\n553:     youtube_video: \"\",\n554:     include_in_preview: false,\n555:     idx: 2,\n556:   },\n557:   {\n558:     id: \"ls_bg_1\",\n559:     chapter: \"ch_bg_1\",\n560:     course: \"budgeting-student-loan\",\n561:     title: \"Where your money actually goes\",\n562:     body: \"<p>Track every spend for a week — yes, every coffee. The point isn't guilt, it's data.</p>\",\n563:     youtube_video: \"HQzoZfc3GwQ\",\n564:     include_in_preview: true,\n565:     idx: 1,\n566:   },\n567:   {\n568:     id: \"ls_bg_2\",\n569:     chapter: \"ch_bg_1\",\n570:     course: \"budgeting-student-loan\",\n571:     title: \"Making a 'survival budget'\",\n572:     body: \"<p>The minimum you need to keep the lights on. Anything above that is choice.</p>\",\n573:     youtube_video: \"\",\n574:     include_in_preview: false,\n575:     idx: 2,\n576:   },\n577: ];\n578: \n579: export const seedEnrollments: LMSEnrollment[] = [\n580:   {\n581:     id: \"enr_1\",\n582:     member: \"maya@firstgens.test\",\n583:     course: \"navigating-uni-first-gen\",\n584:     member_type: \"Student\",\n585:     progress: 33,\n586:     enrolled_on: daysAgo(7),\n587:   },\n588: ];\n589: \n590: export const seedProgress: LMSCourseProgress[] = [\n591:   {\n592:     id: \"prg_1\",\n593:     member: \"maya@firstgens.test\",\n594:     course: \"navigating-uni-first-gen\",\n595:     lesson: \"ls_nav_1\",\n596:     status: \"Complete\",\n597:   },\n598: ];\n599: \n600: export const seedEvents: FGEvent[] = [\n601:   {\n602:     id: \"event_1\",\n603:     title: \"Welcome Breakfast for First-Gen Students\",\n604:     description:\n605:       \"Coffee, pastries, and a chance to meet other students and mentors. No agenda, just hellos.\",\n606:     space: \"first-year-support\",\n607:     event_type: \"In-Person Meetup\",\n608:     starts_on: daysAhead(2),\n609:     ends_on: daysAhead(2),\n610:     location_type: \"In Person\",\n611:     bbb_meeting_id: null,\n612:     external_link: null,\n613:     physical_address: \"The Atrium, Student Union Building\",\n614:     rsvp_required: true,\n615:     capacity: 40,\n616:     hosted_by: \"rosa@firstgens.test\",\n617:   },\n618:   {\n619:     id: \"event_2\",\n620:     title: \"Office Hours: 'Help, I don't understand my reading list'\",\n621:     description: \"Drop-in session with Dr. Hassan. Bring a reading list, leave with a plan.\",\n622:     space: \"study-skills\",\n623:     event_type: \"Drop-in Office Hours\",\n624:     starts_on: daysAhead(5),\n625:     ends_on: daysAhead(5),\n626:     location_type: \"Online (BigBlueButton)\",\n627:     bbb_meeting_id: \"bbb-officehrs-2026-06\",\n628:     external_link: null,\n629:     physical_address: null,\n630:     rsvp_required: false,\n631:     capacity: 25,\n632:     hosted_by: \"rosa@firstgens.test\",\n633:   },\n634:   {\n635:     id: \"event_3\",\n636:     title: \"Webinar: Imposter Syndrome & You\",\n637:     description: \"Priya leads a frank conversation about that voice in your head. 45 mins + Q&A.\",\n638:     space: \"mentor-lounge\",\n639:     event_type: \"Webinar\",\n640:     starts_on: daysAhead(9),\n641:     ends_on: daysAhead(9),\n642:     location_type: \"Online (External Link)\",\n643:     bbb_meeting_id: null,\n644:     external_link: \"https://example.org/webinar/imposter\",\n645:     physical_address: null,\n646:     rsvp_required: true,\n647:     capacity: 100,\n648:     hosted_by: \"priya@firstgens.test\",\n649:   },\n650: ];\n651: \n652: export const seedAttendees: FGEventAttendee[] = [\n653:   { id: \"a_1\", event: \"event_1\", user: \"jordan@firstgens.test\", rsvp_status: \"Going\" },\n654:   { id: \"a_2\", event: \"event_1\", user: \"alex@firstgens.test\", rsvp_status: \"Going\" },\n655:   { id: \"a_3\", event: \"event_1\", user: \"sam@firstgens.test\", rsvp_status: \"Maybe\" },\n656:   { id: \"a_4\", event: \"event_3\", user: \"priya@firstgens.test\", rsvp_status: \"Going\" },\n657:   { id: \"a_5\", event: \"event_3\", user: \"jordan@firstgens.test\", rsvp_status: \"Going\" },\n658: ];\n659: \n660: export const seedMatches: FGMentorMatch[] = [\n661:   {\n662:     id: \"match_1\",\n663:     mentee: \"maya@firstgens.test\",\n664:     mentor: \"jordan@firstgens.test\",\n665:     status: \"Active\",\n666:     matched_on: daysAgo(20),\n667:     matched_via: \"Algorithmic Suggestion\",\n668:     match_notes: \"Both first-gen, overlapping interests in social sciences.\",\n669:   },\n670:   {\n671:     id: \"match_2\",\n672:     mentee: \"sam@firstgens.test\",\n673:     mentor: \"priya@firstgens.test\",\n674:     status: \"Requested\",\n675:     matched_on: daysAgo(2),\n676:     matched_via: \"Self-Requested\",\n677:     match_notes: \"Sam asked for a mentor with research experience.\",\n678:   },\n679: ];\n680: \n681: export const seedAISettings: FGAISettings = {\n682:   enable_sentiment: true,\n683:   sentiment_alert_threshold: 0.75,\n684:   enable_vector_search: true,\n685: };\n686: \n687: export const seedUserSettings: FGUserSettings[] = [\n688:   {\n689:     user: \"maya@firstgens.test\",\n690:     email_on_mention: true,\n691:     email_on_reply: true,\n692:     email_weekly_digest: true,\n693:     push_on_dm: true,\n694:     push_on_mention: true,\n695:     show_in_member_directory: true,\n696:     allow_dm_from_anyone: true,\n697:     theme: \"system\",\n698:     language: \"en\",\n699:     timezone: \"Europe/London\",\n700:   },\n701: ];\n702: \n703: // ============================================================\n704: // DMs — seeded conversations\n705: // ============================================================\n706: \n707: export const seedDMThreads: FGDMThread[] = [\n708:   {\n709:     id: \"dm_maya_jordan\",\n710:     member_a: \"maya@firstgens.test\",\n711:     member_b: \"jordan@firstgens.test\",\n712:     last_message_at: daysAgo(0),\n713:     last_message_preview: \"thanks Jordan — that genuinely helps 💛\",\n714:   },\n715:   {\n716:     id: \"dm_maya_priya\",\n717:     member_a: \"maya@firstgens.test\",\n718:     member_b: \"priya@firstgens.test\",\n719:     last_message_at: daysAgo(2),\n720:     last_message_preview: \"Happy to chat about research — Thursday works.\",\n721:   },\n722:   {\n723:     id: \"dm_maya_rosa\",\n724:     member_a: \"maya@firstgens.test\",\n725:     member_b: \"rosa@firstgens.test\",\n726:     last_message_at: daysAgo(6),\n727:     last_message_preview: \"Bursary form attached — let me know if stuck.\",\n728:   },\n729: ];\n730: \n731: export const seedDMMessages: FGDMMessage[] = [\n732:   {\n733:     id: \"m_1\",\n734:     thread: \"dm_maya_jordan\",\n735:     sender: \"maya@firstgens.test\",\n736:     content: \"Hey! Saw you're a peer mentor — can I ask a daft question about seminars?\",\n737:     created_at: daysAgo(1),\n738:     read_by: [\"maya@firstgens.test\", \"jordan@firstgens.test\"],\n739:   },\n740:   {\n741:     id: \"m_2\",\n742:     thread: \"dm_maya_jordan\",\n743:     sender: \"jordan@firstgens.test\",\n744:     content: \"No daft questions here. Fire away.\",\n745:     created_at: daysAgo(1),\n746:     read_by: [\"maya@firstgens.test\", \"jordan@firstgens.test\"],\n747:   },\n748:   {\n749:     id: \"m_3\",\n750:     thread: \"dm_maya_jordan\",\n751:     sender: \"maya@firstgens.test\",\n752:     content: \"Am I supposed to have read all the reading before? Everyone seems to nod knowingly.\",\n753:     created_at: daysAgo(0),\n754:     read_by: [\"maya@firstgens.test\", \"jordan@firstgens.test\"],\n755:   },\n756:   {\n757:     id: \"m_4\",\n758:     thread: \"dm_maya_jordan\",\n759:     sender: \"jordan@firstgens.test\",\n760:     content: \"Skim the abstract + intro + conclusion. Honestly that's what most of us do week 1.\",\n761:     created_at: daysAgo(0),\n762:     read_by: [\"jordan@firstgens.test\"],\n763:   },\n764:   {\n765:     id: \"m_5\",\n766:     thread: \"dm_maya_jordan\",\n767:     sender: \"maya@firstgens.test\",\n768:     content: \"thanks Jordan — that genuinely helps 💛\",\n769:     created_at: daysAgo(0),\n770:     read_by: [\"maya@firstgens.test\"],\n771:   },\n772:   {\n773:     id: \"m_6\",\n774:     thread: \"dm_maya_priya\",\n775:     sender: \"priya@firstgens.test\",\n776:     content: \"Happy to chat about research — Thursday works.\",\n777:     created_at: daysAgo(2),\n778:     read_by: [\"priya@firstgens.test\"],\n779:   },\n780:   {\n781:     id: \"m_7\",\n782:     thread: \"dm_maya_rosa\",\n783:     sender: \"rosa@firstgens.test\",\n784:     content: \"Bursary form attached — let me know if stuck.\",\n785:     created_at: daysAgo(6),\n786:     read_by: [\"maya@firstgens.test\", \"rosa@firstgens.test\"],\n787:   },\n788: ];\n789: \n790: // ============================================================\n791: // Notifications\n792: // ============================================================\n793: \n794: export const seedNotifications: FGNotification[] = [\n795:   {\n796:     id: \"n_1\",\n797:     for_user: \"maya@firstgens.test\",\n798:     subject: \"Jordan replied to your DM\",\n799:     type: \"DM\",\n800:     document_type: \"FG DM Thread\",\n801:     document_name: \"dm_maya_jordan\",\n802:     read: false,\n803:     created_at: daysAgo(0),\n804:   },\n805:   {\n806:     id: \"n_2\",\n807:     for_user: \"maya@firstgens.test\",\n808:     subject: \"Alex commented on your post\",\n809:     type: \"Reply\",\n810:     document_type: \"GP Discussion\",\n811:     document_name: \"1\",\n812:     read: false,\n813:     created_at: daysAgo(0),\n814:   },\n815:   {\n816:     id: \"n_3\",\n817:     for_user: \"maya@firstgens.test\",\n818:     subject: \"Welcome Breakfast is in 2 days\",\n819:     type: \"Event\",\n820:     document_type: \"FG Event\",\n821:     document_name: \"event_1\",\n822:     read: false,\n823:     created_at: daysAgo(0),\n824:   },\n825:   {\n826:     id: \"n_4\",\n827:     for_user: \"maya@firstgens.test\",\n828:     subject: \"Your mentor match with Jordan is active\",\n829:     type: \"Mentor\",\n830:     document_type: \"FG Mentor Match\",\n831:     document_name: \"match_1\",\n832:     read: true,\n833:     created_at: daysAgo(20),\n834:   },\n835: ];\n836: \n837: // ============================================================\n838: // SSO providers (admin-managed)\n839: // ============================================================\n840: \n841: export const seedSSOProviders: FGSSOProvider[] = [\n842:   {\n843:     id: \"email\",\n844:     label: \"Email & password\",\n845:     enabled: true,\n846:     client_id_set: true,\n847:     notes: \"Built-in. Always available.\",\n848:   },\n849:   {\n850:     id: \"google\",\n851:     label: \"Google\",\n852:     enabled: false,\n853:     client_id_set: false,\n854:     notes: \"Workspace + personal Google accounts.\",\n855:   },\n856:   {\n857:     id: \"microsoft\",\n858:     label: \"Microsoft / Teams\",\n859:     enabled: false,\n860:     client_id_set: false,\n861:     notes: \"Azure AD / Entra ID — supports MS Teams SSO.\",\n862:   },\n863:   {\n864:     id: \"github\",\n865:     label: \"GitHub\",\n866:     enabled: false,\n867:     client_id_set: false,\n868:     notes: \"Good for STEM cohorts.\",\n869:   },\n870:   {\n871:     id: \"discord\",\n872:     label: \"Discord\",\n873:     enabled: false,\n874:     client_id_set: false,\n875:     notes: \"Popular with student communities.\",\n876:   },\n877:   {\n878:     id: \"apple\",\n879:     label: \"Apple\",\n880:     enabled: false,\n881:     client_id_set: false,\n882:     notes: \"Required if you ship a native iOS app.\",\n883:   },\n884: ];\n\n(End of file - total 884 lines)\n</content>",
