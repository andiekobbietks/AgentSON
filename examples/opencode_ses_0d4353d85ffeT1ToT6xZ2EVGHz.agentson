      "type": "action",
      "tool": "question",
      "code": "{\"questions\": [{\"question\": \"Do you have any overclocking enabled (CPU RAM GPU)?\", \"header\": \"Overclocking Status\", \"options\": [{\"label\": \"No overclocking\", \"description\": \"Everything stock/default settings\"}, {\"label\": \"Yes, CPU overclock\", \"description\": \"XMP/DOCP or manual CPU OC\"}, {\"label\": \"Yes, GPU overclock\", \"description\": \"Aftermarket GPU with OC\"}, {\"label\": \"Multiple OC\", \"description\": \"CPU + GPU + RAM OC\"}]}, {\"question\": \"What is your PC usage pattern when these crashes happen?\", \"header\": \"Crash Context\", \"options\": [{\"label\": \"During gaming\", \"description\": \"BSOD occurs while playing games\"}, {\"label\": \"During idle/desktop\", \"description\": \"Random crashes doing basic tasks\"}, {\"label\": \"Under heavy load\", \"description\": \"Video editing, rendering, etc.\"}, {\"label\": \"Random/unsure\", \"description\": \"No clear pattern\"}]}, {\"question\": \"Have you noticed any temperature warnings or unusual fan noise before crashes?\", \"header\": \"Temperature Signs\", \"options\": [{\"label\": \"Yes, temps seem high\", \"description\": \"Fans running loud, feels hot\"}, {\"label\": \"No, seems normal\", \"description\": \"Temps appear normal\"}, {\"label\": \"Not sure\", \"description\": \"Haven't monitored temps\"}]}]}",
