      "output": "<path>C:\\Users\\LLM-Test\\Documents\\agentsong\\importers\\chatgpt.py</path>\n<type>file</type>\n<content>\n1: \"\"\"\n2: ChatGPT Importer for AgentSON.\n3: \n4: Converts ChatGPT conversation exports (conversations.json) into AgentSON format.\n5: ChatGPT exports use a tree structure with mapping nodes.\n6: \"\"\"\n7: \n8: import json\n9: from datetime import datetime\n10: from typing import Dict, List, Optional\n11: import uuid\n12: \n13: \n14: def import_chatgpt(\n15:     export_path: str,\n16:     output_path: Optional[str] = None,\n17:     session_id: Optional[str] = None,\n18:     all_branches: bool = False\n19: ) -> dict:\n20:     \"\"\"\n21:     Import a ChatGPT conversation export into AgentSON format.\n22:     \n23:     Args:\n24:         export_path: Path to conversations.json from ChatGPT export\n25:         output_path: Optional path to write .AgentSON file\n26:         session_id: Optional custom session ID\n27:         all_branches: If True, include all branches; if False, follow main path\n28:     \n29:     Returns:\n30:         AgentSON session dict\n31:     \"\"\"\n32:     with open(export_path, \"r\", encoding=\"utf-8\") as f:\n33:         data = json.load(f)\n34:     \n35:     # Handle both single conversation and array of conversations\n36:     if isinstance(data, list):\n37:         conversations = data\n38:     elif isinstance(data, dict) and \"conversations\" in data:\n39:         conversations = data[\"conversations\"]\n40:     else:\n41:         conversations = [data]\n42:     \n43:     # Import first conversation (or could iterate)\n44:     if not conversations:\n45:         raise ValueError(\"No conversations found in export\")\n46:     \n47:     conv = conversations[0]\n48:     return _convert_conversation(\n49:         conv, output_path, session_id, all_branches\n50:     )\n51: \n52: \n53: def _convert_conversation(\n54:     conv: dict,\n55:     output_path: Optional[str] = None,\n56:     session_id: Optional[str] = None,\n57:     all_branches: bool = False\n58: ) -> dict:\n59:     \"\"\"Convert a single ChatGPT conversation to AgentSON format.\"\"\"\n60:     \n61:     title = conv.get(\"title\", \"Untitled Conversation\")\n62:     conv_id = conv.get(\"id\", str(uuid.uuid4()))\n63:     \n64:     # Use provided session ID or generate from ChatGPT ID\n65:     if session_id is None:\n66:         session_id = f\"chatgpt-{conv_id}\"\n67:     \n68:     # Parse timestamps\n69:     create_time = conv.get(\"create_time\")\n70:     update_time = conv.get(\"update_time\")\n71:     \n72:     started_at = _timestamp_to_iso(create_time) if create_time else None\n73:     ended_at = _timestamp_to_iso(update_time) if update_time else None\n74:     \n75:     # Extract entries from mapping\n76:     mapping = conv.get(\"mapping\", {})\n77:     entries = _extract_entries(mapping, all_branches)\n78:     \n79:     # Determine model from messages\n80:     model = _detect_model(mapping)\n81:     \n82:     # Build AgentSON document\n83:     agentsong = {\n84:         \"$schema\": \"https://agentsong.dev/schema/v1.json\",\n85:         \"id\": session_id,\n86:         \"tool\": {\n87:             \"name\": \"chatgpt\",\n88:             \"version\": \"export\",\n89:             \"session_id\": conv_id\n90:         },\n91:         \"agent\": {\n92:             \"name\": model,\n93:             \"provider\": \"openai\",\n94:             \"variant\": \"default\"\n95:         },\n96:         \"started_at\": started_at,\n97:         \"ended_at\": ended_at,\n98:         \"context\": {\n99:             \"working_directory\": \"\",\n100:             \"platform\": \"web\",\n101:             \"shell\": \"browser\"\n102:         },\n103:         \"title\": title,\n104:         \"entries\": entries,\n105:         \"metadata\": {\n106:             \"total_tokens\": 0,\n107:             \"cost\": 0.0,\n108:             \"messages\": len([e for e in entries if e[\"type\"] in (\"user-query\", \"answer\")]),\n109:             \"parts\": len(entries),\n110:             \"exported_at\": datetime.utcnow().isoformat() + \"Z\",\n111:             \"source_format\": \"chatgpt-export\"\n112:         }\n113:     }\n114:     \n115:     if output_path:\n116:         with open(output_path, \"w\", encoding=\"utf-8\") as f:\n117:             json.dump(agentsong, f, indent=2, ensure_ascii=False, default=str)\n118:     \n119:     return agentsong\n120: \n121: \n122: def _extract_entries(mapping: dict, all_branches: bool = False) -> List[dict]:\n123:     \"\"\"Extract entries from ChatGPT mapping tree.\"\"\"\n124:     entries = []\n125:     \n126:     if not mapping:\n127:         return entries\n128:     \n129:     # Find root node\n130:     root_id = None\n131:     for node_id, node in mapping.items():\n132:         if node.get(\"parent\") is None:\n133:             root_id = node_id\n134:             break\n135:     \n136:     if root_id is None:\n137:         # Try to find any node without parent\n138:         for node_id, node in mapping.items():\n139:             if node.get(\"parent\") not in mapping:\n140:                 root_id = node_id\n141:                 break\n142:     \n143:     if root_id is None:\n144:         return entries\n145:     \n146:     # Walk the tree\n147:     visited = set()\n148:     _walk_tree(mapping, root_id, entries, visited, all_branches)\n149:     \n150:     return entries\n151: \n152: \n153: def _walk_tree(\n154:     mapping: dict,\n155:     node_id: str,\n156:     entries: List[dict],\n157:     visited: set,\n158:     all_branches: bool\n159: ):\n160:     \"\"\"Recursively walk the ChatGPT mapping tree.\"\"\"\n161:     if node_id in visited:\n162:         return\n163:     \n164:     visited.add(node_id)\n165:     node = mapping.get(node_id, {})\n166:     message = node.get(\"message\")\n167:     \n168:     if message:\n169:         entry = _message_to_entry(message)\n170:         if entry:\n171:             entries.append(entry)\n172:     \n173:     # Process children\n174:     children = node.get(\"children\", [])\n175:     if all_branches:\n176:         for child_id in children:\n177:             _walk_tree(mapping, child_id, entries, visited, all_branches)\n178:     elif children:\n179:         # Follow first child (main path)\n180:         _walk_tree(mapping, children[0], entries, visited, all_branches)\n181: \n182: \n183: def _message_to_entry(message: dict) -> Optional[dict]:\n184:     \"\"\"Convert a ChatGPT message to an AgentSON entry.\"\"\"\n185:     role = message.get(\"author\", {}).get(\"role\", \"unknown\")\n186:     content = message.get(\"content\", {})\n187:     \n188:     # Skip system messages\n189:     if role == \"system\":\n190:         return None\n191:     \n192:     # Extract text content\n193:     parts = content.get(\"parts\", [])\n194:     text_parts = []\n195:     for part in parts:\n196:         if isinstance(part, str):\n197:             text_parts.append(part)\n198:         elif isinstance(part, dict) and \"text\" in part:\n199:             text_parts.append(part[\"text\"])\n200:     \n201:     text = \"\\n\".join(text_parts).strip()\n202:     if not text:\n203:         return None\n204:     \n205:     # Detect model from metadata\n206:     metadata = message.get(\"metadata\", {})\n207:     model_slug = metadata.get(\"model_slug\", \"\")\n208:     \n209:     timestamp = message.get(\"create_time\")\n210:     \n211:     if role == \"user\":\n212:         return {\n213:             \"type\": \"user-query\",\n214:             \"text\": text,\n215:             \"timestamp\": int(timestamp * 1000) if timestamp else None\n216:         }\n217:     elif role == \"assistant\":\n218:         entry = {\n219:             \"type\": \"answer\",\n220:             \"text\": text,\n221:             \"timestamp\": int(timestamp * 1000) if timestamp else None\n222:         }\n223:         if model_slug:\n224:             entry[\"model\"] = model_slug\n225:         return entry\n226:     \n227:     return None\n228: \n229: \n230: def _detect_model(mapping: dict) -> str:\n231:     \"\"\"Detect the model used from ChatGPT messages.\"\"\"\n232:     for node_id, node in mapping.items():\n233:         message = node.get(\"message\", {})\n234:         metadata = message.get(\"metadata\", {})\n235:         model_slug = metadata.get(\"model_slug\", \"\")\n236:         if model_slug:\n237:             return model_slug\n238:     return \"gpt-4\"\n239: \n240: \n241: def _timestamp_to_iso(timestamp: Optional[float]) -> Optional[str]:\n242:     \"\"\"Convert Unix timestamp to ISO 8601 string.\"\"\"\n243:     if timestamp is None:\n244:         return None\n245:     try:\n246:         dt = datetime.utcfromtimestamp(timestamp)\n247:         return dt.isoformat() + \"Z\"\n248:     except:\n249:         return None\n\n(End of file - total 249 lines)\n</content>",
      "status": "success",
      "timestamp": 1783213302287
    },
