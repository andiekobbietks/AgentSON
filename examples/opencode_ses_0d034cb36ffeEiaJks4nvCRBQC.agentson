    {
      "type": "action",
      "tool": "read",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\agentsong\\\\supabase\\\\schema.sql\"}",
      "output": "<path>C:\\Users\\LLM-Test\\Documents\\agentsong\\supabase\\schema.sql</path>\n<type>file</type>\n<content>\n1: -- AgentSON Supabase Schema\n2: -- Version: 1.0.0\n3: -- Date: 2026-07-04\n4: \n5: -- Enable UUID extension\n6: CREATE EXTENSION IF NOT EXISTS \"uuid-ossp\";\n7: \n8: -- Sessions table\n9: CREATE TABLE sessions (\n10:   id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n11:   \n12:   -- Core fields\n13:   tool TEXT NOT NULL,\n14:   agent TEXT,\n15:   model TEXT,\n16:   variant TEXT,\n17:   \n18:   -- Timestamps\n19:   started_at TIMESTAMPTZ,\n20:   ended_at TIMESTAMPTZ,\n21:   created_at TIMESTAMPTZ DEFAULT now(),\n22:   updated_at TIMESTAMPTZ DEFAULT now(),\n23:   \n24:   -- Session data (the full .agentsong JSON)\n25:   data JSONB NOT NULL,\n26:   \n27:   -- Full-text search vector (auto-generated)\n28:   search_vector TSVECTOR GENERATED ALWAYS AS (\n29:     to_tsvector('english', \n30:       COALESCE(data->>'id', '') || ' ' ||\n31:       COALESCE(data->'tool'->>'name', '') || ' ' ||\n32:       COALESCE(data->'agent'->>'name', '') || ' ' ||\n33:       COALESCE(\n34:         (SELECT string_agg(\n35:           COALESCE(entry->>'text', '') || ' ' ||\n36:           COALESCE(entry->>'code', '') || ' ' ||\n37:           COALESCE(entry->>'output', ''),\n38:           ' '\n39:         )\n40:         FROM jsonb_array_elements(data->'entries') AS entry),\n41:         ''\n42:       )\n43:     )\n44:   ) STORED,\n45:   \n46:   -- User association\n47:   user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,\n48:   \n49:   -- Metadata\n50:   total_tokens INTEGER,\n51:   cost DECIMAL(10, 6),\n52:   message_count INTEGER,\n53:   \n54:   -- Constraints\n55:   CONSTRAINT valid_tool CHECK (tool IN (\n56:     'opencode', 'minimax', 'antigravity', 'chrome-devtools',\n57:     'cursor', 'claude-code', 'copilot', 'other'\n58:   ))\n59: );\n60: \n61: -- Indexes\n62: CREATE INDEX idx_sessions_user_id ON sessions(user_id);\n63: CREATE INDEX idx_sessions_tool ON sessions(tool);\n64: CREATE INDEX idx_sessions_created_at ON sessions(created_at DESC);\n65: CREATE INDEX idx_sessions_search ON sessions USING GIN(search_vector);\n66: CREATE INDEX idx_sessions_data ON sessions USING GIN(data);\n67: \n68: -- Updated at trigger\n69: CREATE OR REPLACE FUNCTION update_updated_at()\n70: RETURNS TRIGGER AS $$\n71: BEGIN\n72:   NEW.updated_at = now();\n73:   RETURN NEW;\n74: END;\n75: $$ LANGUAGE plpgsql;\n76: \n77: CREATE TRIGGER sessions_updated_at\n78:   BEFORE UPDATE ON sessions\n79:   FOR EACH ROW\n80:   EXECUTE FUNCTION update_updated_at();\n81: \n82: -- Row Level Security\n83: ALTER TABLE sessions ENABLE ROW LEVEL SECURITY;\n84: \n85: -- Policies\n86: CREATE POLICY \"Users can view own sessions\"\n87:   ON sessions FOR SELECT\n88:   USING (auth.uid() = user_id);\n89: \n90: CREATE POLICY \"Users can insert own sessions\"\n91:   ON sessions FOR INSERT\n92:   WITH CHECK (auth.uid() = user_id);\n93: \n94: CREATE POLICY \"Users can update own sessions\"\n95:   ON sessions FOR UPDATE\n96:   USING (auth.uid() = user_id);\n97: \n98: CREATE POLICY \"Users can delete own sessions\"\n99:   ON sessions FOR DELETE\n100:   USING (auth.uid() = user_id);\n101: \n102: -- Function for full-text search\n103: CREATE OR REPLACE FUNCTION search_sessions(\n104:   search_term TEXT,\n105:   user_uuid UUID DEFAULT NULL,\n106:   tool_filter TEXT DEFAULT NULL,\n107:   limit_count INTEGER DEFAULT 50\n108: )\n109: RETURNS TABLE (\n110:   id UUID,\n111:   tool TEXT,\n112:   agent TEXT,\n113:   title TEXT,\n114:   started_at TIMESTAMPTZ,\n115:   created_at TIMESTAMPTZ,\n116:   relevance REAL\n117: ) AS $$\n118: BEGIN\n119:   RETURN QUERY\n120:   SELECT \n121:     s.id,\n122:     s.tool,\n123:     s.agent,\n124:     s.data->>'id' AS title,\n125:     s.started_at,\n126:     s.created_at,\n127:     ts_rank(s.search_vector, plainto_tsquery('english', search_term)) AS relevance\n128:   FROM sessions s\n129:   WHERE \n130:     (user_uuid IS NULL OR s.user_id = user_uuid)\n131:     AND (tool_filter IS NULL OR s.tool = tool_filter)\n132:     AND s.search_vector @@ plainto_tsquery('english', search_term)\n133:   ORDER BY relevance DESC\n134:   LIMIT limit_count;\n135: END;\n136: $$ LANGUAGE plpgsql;\n137: \n138: -- Function to get session stats\n139: CREATE OR REPLACE FUNCTION get_session_stats(user_uuid UUID)\n140: RETURNS TABLE (\n141:   total_sessions BIGINT,\n142:   total_tokens BIGINT,\n143:   total_cost DECIMAL(10, 6),\n144:   tools_used TEXT[],\n145:   date_range TSTZRANGE\n146: ) AS $$\n147: BEGIN\n148:   RETURN QUERY\n149:   SELECT \n150:     COUNT(*)::BIGINT AS total_sessions,\n151:     COALESCE(SUM(s.total_tokens), 0)::BIGINT AS total_tokens,\n152:     COALESCE(SUM(s.cost), 0)::DECIMAL(10, 6) AS total_cost,\n153:     ARRAY_AGG(DISTINCT s.tool) AS tools_used,\n154:     tstzrange(MIN(s.started_at), MAX(s.ended_at)) AS date_range\n155:   FROM sessions s\n156:   WHERE s.user_id = user_uuid;\n157: END;\n158: $$ LANGUAGE plpgsql;\n\n(End of file - total 158 lines)\n</content>",
