= ParagraphStyle('Body', parent=styles['Normal'], fontSize=9, leading=12, spaceAfter=4)\n41:     code_style = ParagraphStyle('Code', parent=styles['Code'], fontSize=8, backColor=LIGHT_GRAY, borderWidth=0.5, borderColor=HexColor(\"#cccccc\"), borderPadding=6, spaceAfter=4, leading=10, fontName='Courier')\n42:     success_style = ParagraphStyle('Success', parent=body_style, textColor=GREEN, fontSize=9)\n43:     fail_style = ParagraphStyle('Fail', parent=body_style, textColor=RED, fontSize=9)\n44:     warn_style = ParagraphStyle('Warn', parent=body_style, textColor=YELLOW, fontSize=9)\n45:     small_style = ParagraphStyle('Small', parent=body_style, fontSize=8, textColor=GRAY)\n46:     bold_style = ParagraphStyle('Bold', parent=body_style, fontSize=9, fontName='Helvetica-Bold')\n47: \n48:     story = []\n49: \n50:     # Title\n\n(Showing lines 1-50 of 359. Use offset=51 to continue.)\n</content>",
