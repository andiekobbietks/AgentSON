      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\agentsong\\\\wiki_cheatsheet.py\", \"content\": \"\\\"\\\"\\\"\\nAgentSON Wiki Deployment Cheat Sheet v2\\nFull reproducibility, CLI versions, bugs, lessons learned\\nGenerated from real deployment session \\u2014 2026-07-05\\n\\\"\\\"\\\"\\n\\nfrom reportlab.lib.pagesizes import A4\\nfrom reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle\\nfrom reportlab.lib.colors import HexColor\\nfrom reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle, HRFlowable, PageBreak\\nfrom reportlab.lib.units import inch\\n\\nAMBER = HexColor(\\\"#FFB000\\\")\\nDARK_BG = HexColor(\\\"#1a1a2e\\\")\\nWHITE = HexColor(\\\"#FFFFFF\\\")\\nGRAY = HexColor(\\\"#888888\\\")\\nGREEN = HexColor(\\\"#00CC66\\\")\\nRED = HexColor(\\\"#FF4444\\\")\\nBLUE = HexColor(\\\"#58a6ff\\\")\\nYELLOW = HexColor(\\\"#FFCC00\\\")\\nLIGHT_GRAY = HexColor(\\\"#f5f5f5\\\")\\n\\ndef build_cheatsheet():\\n    doc = SimpleDocTemplate(\\n        \\\"C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\Documents\\\\\\\\agentsong\\\\\\\\wiki\\\\\\\\AgentSON_Wiki_Cheatsheet.pdf\\\",\\n        pagesize=A4,\\n        rightMargin=40,\\n        leftMargin=40,\\n        topMargin=40,\\n        bottomMargin=40\\n    )\\n\\n    styles = getSampleStyleSheet()\\n    \\n    title_style = ParagraphStyle('CustomTitle', parent=styles['Title'], fontSize=22, textColor=AMBER, spaceAfter=10)\\n    subtitle_style = ParagraphStyle('Subtitle', parent=styles['Normal'], fontSize=10, textColor=GRAY, spaceAfter=20)\\n    h1_style = ParagraphStyle('H1', parent=styles['Heading1'], fontSize=14, textColor=AMBER, spaceBefore=15, spaceAfter=8)\\n    h2_style = ParagraphStyle('H2', parent=styles['Heading2'], fontSize=11, textColor=BLUE, spaceBefore=10, spaceAfter=5)\\n    h3_style = ParagraphStyle('H3', parent=styles['Heading3'], fontSize=10, textColor=HexColor(\\\"#cc9900\\\"), spaceBefore=8, spaceAfter=4)\\n    body_style = ParagraphStyle('Body', parent=styles['Normal'], fontSize=9, leading=12, spaceAfter=4)\\n    code_style = ParagraphStyle('Code', parent=styles['Code'], fontSize=8, backColor=LIGHT_GRAY, borderWidth=0.5, borderColor=HexColor(\\\"#cccccc\\\"), borderPadding=6, spaceAfter=4, leading=10, fontName='Courier')\\n    success_style = ParagraphStyle('Success', parent=body_style, textColor=GREEN, fontSize=9)\\n    fail_style = ParagraphStyle('Fail', parent=body_style, textColor=RED, fontSize=9)\\n    warn_style = ParagraphStyle('Warn', parent=body_style, textColor=YELLOW, fontSize=9)\\n    small_style = ParagraphStyle('Small', parent=body_style, fontSize=8, textColor=GRAY)\\n    bold_style = ParagraphStyle('Bold', parent=body_style, fontSize=9, fontName='Helvetica-Bold')\\n\\n    story = []\\n\\n    # Title\\n    story.append(Paragraph(\\\"AgentSON Wiki Deployment Cheat Sheet\\\", title_style))\\n    story.append(Paragraph(\\\"Full reproducibility record \\u2014 bugs, CLI versions, exact outputs \\u2014 2026-07-05\\\", subtitle_style))\\n    story.append(HRFlowable(width=\\\"100%\\\", thickness=2, color=AMBER))\\n    story.append(Spacer(1, 10))\\n\\n    # Environment\\n    story.append(Paragraph(\\\"0. Environment (Reproducibility Context)\\\", h1_style))\\n    env_data = [\\n        [\\\"Component\\\", \\\"Version / Value\\\", \\\"Notes\\\"],\\n        [\\\"OS\\\", \\\"Windows 10 (Build 19045.6456)\\\", \\\"Italian locale (it-IT)\\\"],\\n        [\\\"Shell\\\", \\\"PowerShell 5.1\\\", \\\"Not PowerShell 7 (pwsh)\\\"],\\n        [\\\"Python\\\", \\\"3.12\\\", \\\"py launcher available\\\"],\\n        [\\\"Git\\\", \\\"Latest (2026)\\\", \\\"Credential manager active\\\"],\\n        [\\\"GitHub Account\\\", \\\"andiekobbietks\\\", \\\"andiekobbietks@outlook.com\\\"],\\n        [\\\"Repo\\\", \\\"andiekobbietks/AgentSON\\\", \\\"Public, master branch\\\"],\\n        [\\\"Wiki Repo\\\", \\\"andiekobbietks/AgentSON.wiki.git\\\", \\\"Separate git endpoint\\\"],\\n        [\\\"OpenCode\\\", \\\"MiMo V2.5 Free\\\", \\\"Model used in this session\\\"],\\n        [\\\"OpenCode DB\\\", \\\"C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\.local\\\\\\\\share\\\\\\\\opencode\\\\\\\\opencode.db\\\", \\\"1.7GB SQLite\\\"],\\n        [\\\"Session ID\\\", \\\"ses_0cbd91919ffeyYUXTVAIBZXQu7\\\", \\\"Slug: jolly-cabin\\\"],\\n    ]\\n    t = Table(env_data, colWidths=[100, 180, 170])\\n    t.setStyle(TableStyle([\\n        ('BACKGROUND', (0, 0), (-1, 0), AMBER),\\n        ('TEXTCOLOR', (0, 0), (-1, 0), WHITE),\\n        ('FONTSIZE', (0, 0), (-1, -1), 8),\\n        ('GRID', (0, 0), (-1, -1), 0.5, GRAY),\\n        ('ROWBACKGROUNDS', (0, 1), (-1, -1), [WHITE, LIGHT_GRAY]),\\n    ]))\\n    story.append(t)\\n    story.append(Spacer(1, 10))\\n\\n    # What We Built\\n    story.append(Paragraph(\\\"1. What We Built\\\", h1_style))\\n    story.append(Paragraph(\\\"9 wiki pages for github.com/andiekobbietks/AgentSON/wiki:\\\", body_style))\\n    pages_data = [\\n        [\\\"Page\\\", \\\"Content\\\", \\\"File Size\\\"],\\n        [\\\"Home\\\", \\\"Landing page with 'Why This Exists' health data story\\\", \\\"~3KB\\\"],\\n        [\\\"Getting-Started\\\", \\\"Install, export, search, fine-tune, view\\\", \\\"~4KB\\\"],\\n        [\\\"Schema\\\", \\\"JSON Schema v1.1 reference \\u2014 entry types, correlation IDs\\\", \\\"~5KB\\\"],\\n        [\\\"Readers\\\", \\\"6 working + 27 planned tool readers\\\", \\\"~4KB\\\"],\\n        [\\\"ADRs\\\", \\\"11 Architecture Decision Records\\\", \\\"~5KB\\\"],\\n        [\\\"SOPs\\\", \\\"14 Standard Operating Procedures\\\", \\\"~4KB\\\"],\\n        [\\\"Coding-Standards\\\", \\\"Non-negotiable code rules\\\", \\\"~3KB\\\"],\\n        [\\\"Mental-Models\\\", \\\"How we think about problems\\\", \\\"~3KB\\\"],\\n        [\\\"Contributing\\\", \\\"How to add readers, write tests, submit PRs\\\", \\\"~3KB\\\"],\\n    ]\\n    t = Table(pages_data, colWidths=[90, 280, 60])\\n    t.setStyle(TableStyle([\\n        ('BACKGROUND', (0, 0), (-1, 0), AMBER),\\n        ('TEXTCOLOR', (0, 0), (-1, 0), WHITE),\\n        ('FONTSIZE', (0, 0), (-1, -1), 8),\\n        ('GRID', (0, 0), (-1, -1), 0.5, GRAY),\\n        ('ROWBACKGROUNDS', (0, 1), (-1, -1), [WHITE, LIGHT_GRAY]),\\n    ]))\\n    story.append(t)\\n    story.append(Spacer(1, 10))\\n\\n    # Step-by-step with exact commands and outputs\\n    story.append(Paragraph(\\\"2. Step-by-Step with Exact Commands and Outputs\\\", h1_style))\\n    \\n    story.append(Paragraph(\\\"Step 1: Create Wiki Content Locally\\\", h2_style))\\n    story.append(Paragraph(\\\"Command:\\\", bold_style))\\n    story.append(Paragraph(\\\"New-Item -ItemType Directory -Path 'C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\Documents\\\\\\\\agentsong\\\\\\\\wiki' -Force\\\", code_style))\\n    story.append(Paragraph(\\\"Expected Output:\\\", bold_style))\\n    story.append(Paragraph(\\\"Directory: C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\Documents\\\\\\\\agentsong\\\", code_style))\\n    story.append(Paragraph(\\\"Mode LastWriteTime Length Name\\\", code_style))\\n    story.append(Paragraph(\\\"d----- 05/07/2026 22:45 wiki\\\", code_style))\\n    story.append(Paragraph(\\\"Then created 9 markdown files using Python write() tool.\\\", body_style))\\n    story.append(Spacer(1, 5))\\n\\n    story.append(Paragraph(\\\"Step 2: Create Wiki on GitHub (Manual)\\\", h2_style))\\n    story.append(Paragraph(\\\"Action:\\\", bold_style))\\n    story.append(Paragraph(\\\"1. Open browser: github.com/andiekobbietks/AgentSON/wiki\\\", body_style))\\n    story.append(Paragraph(\\\"2. Click 'Create the first page'\\\", body_style))\\n    story.append(Paragraph(\\\"3. Edit the default Home page content\\\", body_style))\\n    story.append(Paragraph(\\\"4. Click 'Save Page'\\\", body_style))\\n    story.append(Paragraph(\\\"Expected Result:\\\", bold_style))\\n    story.append(Paragraph(\\\"Banner: 'Your Wiki was created.' \\u2014 Home page shows with 1 revision\\\", success_style))\\n    story.append(Spacer(1, 5))\\n\\n    story.append(Paragraph(\\\"Step 3: Clone Wiki Repo\\\", h2_style))\\n    story.append(Paragraph(\\\"Command:\\\", bold_style))\\n    story.append(Paragraph(\\\"git clone https://github.com/andiekobbietks/AgentSON.wiki.git\\\", code_style))\\n    story.append(Paragraph(\\\"Expected Output:\\\", bold_style))\\n    story.append(Paragraph(\\\"Cloning into 'AgentSON.wiki'...\\\", code_style))\\n    story.append(Paragraph(\\\"remote: Enumerating objects: 3, done.\\\", code_style))\\n    story.append(Paragraph(\\\"remote: Counting objects: 100% (3/3), done.\\\", code_style))\\n    story.append(Paragraph(\\\"remote: Total 3 (delta 0), reused 0 (delta 0), pack-reused 0 (from 0)\\\", code_style))\\n    story.append(Paragraph(\\\"Receiving objects: 100% (3/3), done.\\\", code_style))\\n    story.append(Spacer(1, 5))\\n\\n    story.append(Paragraph(\\\"Step 4: Copy Files\\\", h2_style))\\n    story.append(Paragraph(\\\"Command:\\\", bold_style))\\n    story.append(Paragraph(\\\"copy agentsong\\\\\\\\wiki\\\\\\\\*.* AgentSON.wiki\\\\\\\\\\\", code_style))\\n    story.append(Paragraph(\\\"Expected Output:\\\", bold_style))\\n    story.append(Paragraph(\\\"agentsong\\\\\\\\wiki\\\\\\\\Home.md -> AgentSON.wiki\\\\\\\\Home.md\\\", code_style))\\n    story.append(Paragraph(\\\"(9 files copied \\u2014 Home.md, Getting-Started.md, Schema.md, Readers.md, ADRs.md, SOPs.md, Coding-Standards.md, Mental-Models.md, Contributing.md)\\\", code_style))\\n    story.append(Spacer(1, 5))\\n\\n    story.append(Paragraph(\\\"Step 5: Commit\\\", h2_style))\\n    story.append(Paragraph(\\\"Commands:\\\", bold_style))\\n    story.append(Paragraph(\\\"cd AgentSON.wiki\\\", code_style))\\n    story.append(Paragraph(\\\"git add .\\\", code_style))\\n    story.append(Paragraph(\\\"git commit -m 'Add wiki pages'\\\", code_style))\\n    story.append(Paragraph(\\\"Expected Output:\\\", bold_style))\\n    story.append(Paragraph(\\\"[master 95badf9] Add wiki pages\\\", code_style))\\n    story.append(Paragraph(\\\"9 files changed, 996 insertions(+), 1 deletion(-)\\\", code_style))\\n    story.append(Paragraph(\\\"create mode 100644 ADRs.md\\\", code_style))\\n    story.append(Paragraph(\\\"create mode 100644 Coding-Standards.md\\\", code_style))\\n    story.append(Paragraph(\\\"(etc. for all 9 files)\\\", code_style))\\n    story.append(Spacer(1, 5))\\n\\n    story.append(Paragraph(\\\"Step 6: Push with Token in URL (WORKING METHOD)\\\", h2_style))\\n    story.append(Paragraph(\\\"Prerequisites:\\\", bold_style))\\n    story.append(Paragraph(\\\"- Classic PAT with 'repo' scope generated at github.com/settings/tokens\\\", body_style))\\n    story.append(Paragraph(\\\"- Token format: ghp_REDACTED_SECRET_\\\", body_style))\\n    story.append(Paragraph(\\\"Commands:\\\", bold_style))\\n    story.append(Paragraph(\\\"$token = Read-Host -Prompt 'Paste your new PAT' -AsSecureString\\\", code_style))\\n    story.append(Paragraph(\\\"$tokenPlain = [Runtime.InteropServices.Marshal]::PtrToStringAuto([Runtime.InteropServices.Marshal]::SecureStringToBSTR($token))\\\", code_style))\\n    story.append(Paragraph(\\\"git remote set-url origin \\\\\\\"https://andiekobbietks:${tokenPlain}@github.com/andiekobbietks/AgentSON.wiki.git\\\\\\\"\\\", code_style))\\n    story.append(Paragraph(\\\"git push\\\", code_style))\\n    story.append(Paragraph(\\\"Expected Output:\\\", bold_style))\\n    story.append(Paragraph(\\\"Paste your new PAT: ****************************************\\\", code_style))\\n    story.append(Paragraph(\\\"Enumerating objects: 13, done.\\\", code_style))\\n    story.append(Paragraph(\\\"Counting objects: 100% (13/13), done.\\\", code_style))\\n    story.append(Paragraph(\\\"Delta compression using up to 4 threads\\\", code_style))\\n    story.append(Paragraph(\\\"Compressing objects: 100% (11/11), done.\\\", code_style))\\n    story.append(Paragraph(\\\"Writing objects: 100% (11/11), 12.92 KiB | 2.58 MiB/s, done.\\\", code_style))\\n    story.append(Paragraph(\\\"Total 11 (delta 0), reused 0 (delta 0), pack-reused 0 (from 0)\\\", code_style))\\n    story.append(Paragraph(\\\"To https://github.com/andiekobbietks/AgentSON.wiki.git\\\", code_style))\\n    story.append(Paragraph(\\\"e21356a..95badf9  master -> master\\\", code_style))\\n\\n    # Bugs encountered\\n    story.append(PageBreak())\\n    story.append(Paragraph(\\\"3. Bugs Encountered (Full Reproduction)\\\", h1_style))\\n    \\n    story.append(Paragraph(\\\"Bug 1: Fine-Grained Token Cannot Push to Wiki\\\", h2_style))\\n    story.append(Paragraph(\\\"Command that failed:\\\", bold_style))\\n    story.append(Paragraph(\\\"git push\\\", code_style))\\n    story.append(Paragraph(\\\"Error message:\\\", bold_style))\\n    story.append(Paragraph(\\\"remote: Invalid username or token. Password authentication is not supported for Git operations.\\\", fail_style))\\n    story.append(Paragraph(\\\"fatal: Authentication failed for 'https://github.com/andiekobbietks/AgentSON.wiki.git/'\\\", fail_style))\\n    story.append(Paragraph(\\\"Reproduction steps:\\\", bold_style))\\n    story.append(Paragraph(\\\"1. Generate fine-grained PAT at github.com/settings/tokens?type=beta\\\", body_style))\\n    story.append(Paragraph(\\\"2. Set scope to only AgentSON repo (not wiki)\\\", body_style))\\n    story.append(Paragraph(\\\"3. git push to wiki endpoint\\\", body_style))\\n    story.append(Paragraph(\\\"Root cause:\\\", bold_style))\\n    story.append(Paragraph(\\\"GitHub fine-grained tokens have separate wiki permission \\u2014 must be explicitly granted. Default is deny.\\\", body_style))\\n    story.append(Paragraph(\\\"Fix:\\\", bold_style))\\n    story.append(Paragraph(\\\"Use classic PAT with 'repo' scope (includes wiki). Or grant wiki access in fine-grained token settings.\\\", body_style))\\n    story.append(Spacer(1, 5))\\n\\n    story.append(Paragraph(\\\"Bug 2: Password Authentication Deprecated\\\", h2_style))\\n    story.append(Paragraph(\\\"Command that failed:\\\", bold_style))\\n    story.append(Paragraph(\\\"git push (when prompted for password, entered PAT as password)\\\", code_style))\\n    story.append(Paragraph(\\\"Error message:\\\", bold_style))\\n    story.append(Paragraph(\\\"remote: Invalid username or token. Password authentication is not supported for Git operations.\\\", fail_style))\\n    story.append(Paragraph(\\\"fatal: Authentication failed for 'https://github.com/andiekobbietks/AgentSON.wiki.git/'\\\", fail_style))\\n    story.append(Paragraph(\\\"Root cause:\\\", bold_style))\\n    story.append(Paragraph(\\\"GitHub removed password auth for Git operations in 2021. PATs must be embedded in URL or used via credential helper.\\\", body_style))\\n    story.append(Paragraph(\\\"Fix:\\\", bold_style))\\n    story.append(Paragraph(\\\"Embed token in URL: https://USER:TOKEN@github.com/USER/REPO.git\\\", body_style))\\n    story.append(Spacer(1, 5))\\n\\n    story.append(Paragraph(\\\"Bug 3: Cached Bad Credentials\\\", h2_style))\\n    story.append(Paragraph(\\\"Command that failed:\\\", bold_style))\\n    story.append(Paragraph(\\\"git push (after failed attempt, even with correct token)\\\", code_style))\\n    story.append(Paragraph(\\\"Error message:\\\", bold_style))\\n    story.append(Paragraph(\\\"remote: Invalid username or token. Password authentication is not supported for Git operations.\\\", fail_style))\\n    story.append(Paragraph(\\\"Root cause:\\\", bold_style))\\n    story.append(Paragraph(\\\"Windows Credential Manager cached the failed attempt. Git uses cached creds automatically.\\\", body_style))\\n    story.append(Paragraph(\\\"Fix:\\\", bold_style))\\n    story.append(Paragraph(\\\"git config --global --unset credential.helper\\\", code_style))\\n    story.append(Paragraph(\\\"git config --global credential.helper store\\\", code_style))\\n    story.append(Paragraph(\\\"Then set remote URL with embedded token.\\\", body_style))\\n    story.append(Spacer(1, 5))\\n\\n    story.append(Paragraph(\\\"Bug 4: Token Compromised by Sharing in Chat\\\", h2_style))\\n    story.append(Paragraph(\\\"What happened:\\\", bold_style))\\n    story.append(Paragraph(\\\"User pasted PAT into chat. Token visible to AI and potentially logged.\\\", fail_style))\\n    story.append(Paragraph(\\\"Impact:\\\", bold_style))\\n    story.append(Paragraph(\\\"Any entity with the token can push to all repos with 'repo' scope.\\\", body_style))\\n    story.append(Paragraph(\\\"Fix:\\\", bold_style))\\n    story.append(Paragraph(\\\"1. Immediately delete compromised token at github.com/settings/tokens\\\", body_style))\\n    story.append(Paragraph(\\\"2. Generate new token\\\", body_style))\\n    story.append(Paragraph(\\\"3. Never paste tokens in chat again\\\", body_style))\\n    story.append(Paragraph(\\\"Prevention:\\\", bold_style))\\n    story.append(Paragraph(\\\"Use $token = Read-Host -Prompt 'PAT' -AsSecureString (masked input)\\\", code_style))\\n\\n    # Lessons learned\\n    story.append(Paragraph(\\\"4. Lessons Learned\\\", h1_style))\\n    lessons = [\\n        [\\\"#\\\", \\\"Lesson\\\", \\\"Why It Matters\\\"],\\n        [\\\"1\\\", \\\"Fine-grained tokens need explicit wiki scope\\\", \\\"Default is deny \\u2014 must grant in token settings\\\"],\\n        [\\\"2\\\", \\\"GitHub password auth is gone since 2021\\\", \\\"PAT must be in URL or credential helper\\\"],\\n        [\\\"3\\\", \\\"Cached creds persist across attempts\\\", \\\"Must clear credential helper after failures\\\"],\\n        [\\\"4\\\", \\\"Never share tokens in chat\\\", \\\"Compromised immediately \\u2014 delete and regenerate\\\"],\\n        [\\\"5\\\", \\\"Wiki is a separate git repo\\\", \\\"Different endpoint than main repo (.wiki.git suffix)\\\"],\\n        [\\\"6\\\", \\\"Classic PAT with repo scope covers wiki\\\", \\\"Fine-grained requires extra wiki permission\\\"],\\n        [\\\"7\\\", \\\"Read-Host -AsSecureString masks input\\\", \\\"Prevents shoulder surfing and logging\\\"],\\n        [\\\"8\\\", \\\"Token in URL format: https://USER:TOKEN@github.com/...\\\", \\\"Only reliable auth method for git push\\\"],\\n        [\\\"9\\\", \\\"ReportLab needs pip install first\\\", \\\"Not in default Python install\\\"],\\n        [\\\"10\\\", \\\"Windows copy command uses backslashes\\\", \\\"Not forward slashes like Linux/Mac\\\"],\\n    ]\\n    t = Table(lessons, colWidths=[20, 200, 230])\\n    t.setStyle(TableStyle([\\n        ('BACKGROUND', (0, 0), (-1, 0), AMBER),\\n        ('TEXTCOLOR', (0, 0), (-1, 0), WHITE),\\n        ('FONTSIZE', (0, 0), (-1, -1), 8),\\n        ('GRID', (0, 0), (-1, -1), 0.5, GRAY),\\n        ('ROWBACKGROUNDS', (0, 1), (-1, -1), [WHITE, LIGHT_GRAY]),\\n    ]))\\n    story.append(t)\\n\\n    # Obsolete commands\\n    story.append(Paragraph(\\\"5. Obsolete / Deprecated Commands (Do NOT Use)\\\", h1_style))\\n    obsolete = [\\n        [\\\"Command\\\", \\\"Status\\\", \\\"Replacement\\\"],\\n        [\\\"git push (with password prompt)\\\", \\\"DEPRECATED 2021\\\", \\\"Embed PAT in URL\\\"],\\n        [\\\"git config credential.helper store\\\", \\\"WORKS BUT INSECURE\\\", \\\"Use Read-Host -AsSecureString\\\"],\\n        [\\\"Fine-grained token for wiki\\\", \\\"INSUFFICIENT PERMISSIONS\\\", \\\"Classic PAT or grant wiki scope\\\"],\\n        [\\\"copy (Linux syntax: cp)\\\", \\\"WINDOWS ONLY\\\", \\\"Use copy with backslashes\\\"],\\n        [\\\"python -m pip install reportlab\\\", \\\"WORKS\\\", \\\"pip install reportlab (same result)\\\"],\\n    ]\\n    t = Table(obsolete, colWidths=[180, 120, 150])\\n    t.setStyle(TableStyle([\\n        ('BACKGROUND', (0, 0), (-1, 0), RED),\\n        ('TEXTCOLOR', (0, 0), (-1, 0), WHITE),\\n        ('FONTSIZE', (0, 0), (-1, -1), 8),\\n        ('GRID', (0, 0), (-1, -1), 0.5, GRAY),\\n        ('ROWBACKGROUNDS', (0, 1), (-1, -1), [WHITE, HexColor(\\\"#fff0f0\\\")]),\\n    ]))\\n    story.append(t)\\n\\n    # The working method\\n    story.append(Paragraph(\\\"6. The Working Method (Copy-Paste Ready)\\\", h1_style))\\n    story.append(Paragraph(\\\"# 1. Generate classic PAT with repo scope at github.com/settings/tokens\\\", body_style))\\n    story.append(Paragraph(\\\"# 2. Run these commands in PowerShell:\\\", body_style))\\n    story.append(Paragraph(\\\"cd C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\Documents\\\", code_style))\\n    story.append(Paragraph(\\\"git clone https://github.com/andiekobbietks/AgentSON.wiki.git\\\", code_style))\\n    story.append(Paragraph(\\\"copy agentsong\\\\\\\\wiki\\\\\\\\*.* AgentSON.wiki\\\\\\\\\\\", code_style))\\n    story.append(Paragraph(\\\"cd AgentSON.wiki\\\", code_style))\\n    story.append(Paragraph(\\\"git add .\\\", code_style))\\n    story.append(Paragraph(\\\"git commit -m 'Add wiki pages'\\\", code_style))\\n    story.append(Paragraph(\\\"$token = Read-Host -Prompt 'Paste PAT' -AsSecureString\\\", code_style))\\n    story.append(Paragraph(\\\"$tokenPlain = [Runtime.InteropServices.Marshal]::PtrToStringAuto([Runtime.InteropServices.Marshal]::SecureStringToBSTR($token))\\\", code_style))\\n    story.append(Paragraph(\\\"git remote set-url origin \\\\\\\"https://andiekobbietks:${tokenPlain}@github.com/andiekobbietks/AgentSON.wiki.git\\\\\\\"\\\", code_style))\\n    story.append(Paragraph(\\\"git push\\\", code_style))\\n\\n    # File locations\\n    story.append(Paragraph(\\\"7. File Locations\\\", h1_style))\\n    locations = [\\n        [\\\"What\\\", \\\"Path\\\"],\\n        [\\\"Wiki source files\\\", \\\"C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\Documents\\\\\\\\agentsong\\\\\\\\wiki\\\\\\\\\\\"],\\n        [\\\"Cloned wiki repo\\\", \\\"C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\Documents\\\\\\\\AgentSON.wiki\\\\\\\\\\\"],\\n        [\\\"Main repo\\\", \\\"C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\Documents\\\\\\\\agentsong\\\\\\\\\\\"],\\n        [\\\"OpenCode DB\\\", \\\"C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\.local\\\\\\\\share\\\\\\\\opencode\\\\\\\\opencode.db\\\"],\\n        [\\\"Cheatsheet PDF\\\", \\\"C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\Documents\\\\\\\\agentsong\\\\\\\\wiki\\\\\\\\AgentSON_Wiki_Cheatsheet.pdf\\\"],\\n        [\\\"Session: FreeStyle Libre\\\", \\\"ses_1069f6208ffeXozEyNyMW6RXOO (slug: gentle-engine)\\\"],\\n        [\\\"Session: Current (License)\\\", \\\"ses_0cbd91919ffeyYUXTVAIBZXQu7 (slug: jolly-cabin)\\\"],\\n        [\\\"GitHub Repo\\\", \\\"https://github.com/andiekobbietks/AgentSON\\\"],\\n        [\\\"GitHub Wiki\\\", \\\"https://github.com/andiekobbietks/AgentSON/wiki\\\"],\\n    ]\\n    t = Table(locations, colWidths=[120, 330])\\n    t.setStyle(TableStyle([\\n        ('BACKGROUND', (0, 0), (-1, 0), AMBER),\\n        ('TEXTCOLOR', (0, 0), (-1, 0), WHITE),\\n        ('FONTSIZE', (0, 0), (-1, -1), 8),\\n        ('GRID', (0, 0), (-1, -1), 0.5, GRAY),\\n        ('ROWBACKGROUNDS', (0, 1), (-1, -1), [WHITE, LIGHT_GRAY]),\\n    ]))\\n    story.append(t)\\n\\n    # Remaining tasks\\n    story.append(Paragraph(\\\"8. Remaining Tasks\\\", h1_style))\\n    tasks = [\\n        [\\\"Task\\\", \\\"Status\\\", \\\"Blocker\\\"],\\n        [\\\"Wiki deployment\\\", \\\"DONE\\\", \\\"None\\\"],\\n        [\\\"README 'Why This Exists' section\\\", \\\"DONE\\\", \\\"Committed locally\\\"],\\n        [\\\"Push README to remote\\\", \\\"TODO\\\", \\\"Needs PAT push\\\"],\\n        [\\\"Push ADR-011 + modified files\\\", \\\"TODO\\\", \\\"Needs PAT push\\\"],\\n        [\\\"Fix reader count (6 vs 7)\\\", \\\"DONE\\\", \\\"Fixed in README\\\"],\\n    ]\\n    t = Table(tasks, colWidths=[200, 80, 170])\\n    t.setStyle(TableStyle([\\n        ('BACKGROUND', (0, 0), (-1, 0), AMBER),\\n        ('TEXTCOLOR', (0, 0), (-1, 0), WHITE),\\n        ('FONTSIZE', (0, 0), (-1, -1), 8),\\n        ('GRID', (0, 0), (-1, -1), 0.5, GRAY),\\n        ('ROWBACKGROUNDS', (0, 1), (-1, -1), [WHITE, LIGHT_GRAY]),\\n    ]))\\n    story.append(t)\\n\\n    # Footer\\n    story.append(Spacer(1, 20))\\n    story.append(HRFlowable(width=\\\"100%\\\", thickness=2, color=AMBER))\\n    story.append(Spacer(1, 5))\\n    story.append(Paragraph(\\\"Generated by AgentSON deployment session \\u2014 2026-07-05 22:59 UTC+1\\\", small_style))\\n    story.append(Paragraph(\\\"Author: Andrea Enning (AndieKobbieTech) \\u2014 andiekobbietks@outlook.com\\\", small_style))\\n    story.append(Paragraph(\\\"Model: MiMo V2.5 Free via OpenCode\\\", small_style))\\n    story.append(Paragraph(\\\"License: Apache 2.0 \\u2014 this document is part of the AgentSON project\\\", small_style))\\n\\n    doc.build(story)\\n    print(\\\"PDF generated: agentsong/wiki/AgentSON_Wiki_Cheatsheet.pdf\\\")\\n    print(\\\"Pages: ~6\\\")\\n    print(\\\"Size: ~15KB\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    build_cheatsheet()\\n\"}",
