      "tool": "bash",
      "code": "{\"command\": \"wsl -d Ubuntu -- bash -c \\\"cat /home/andiekobbie/my-bench/apps/fg_companion/frontend/src/data/api.ts\\\"\", \"description\": \"Read api.ts\"}",
      "output": "const BASE = typeof window !== \"undefined\" ? window.location.origin : \"\";\n\nfunction csrfToken(): string {\n  if (typeof document === \"undefined\") return \"\";\n  return (document.cookie.match(/csrftoken=([^;]+)/) ?? [])[1] ?? \"\";\n}\n\nasync function request<T>(\n  method: string,\n  path: string,\n  body?: unknown,\n  params?: Record<string, string>,\n): Promise<T> {\n  let url = `${BASE}/api${path}`;\n  if (params) {\n    const qs = new URLSearchParams(params).toString();\n    if (qs) url += `?${qs}`;\n  }\n  const headers: Record<string, string> = { \"Content-Type\": \"application/json\" };\n  const token = csrfToken();\n  if (token) headers[\"X-Frappe-CSRF-Token\"] = token;\n  const res = await fetch(url, {\n    method,\n    headers,\n    credentials: \"include\",\n    body: body ? JSON.stringify(body) : undefined,\n  });\n  if (!res.ok) {\n    const text = await res.text().catch(() => res.statusText);\n    throw new Error(`Frappe API ${res.status}: ${text.slice(0, 200)}`);\n  }\n  const json = await res.json();\n  return (json.message ?? json.data) as T;\n}\n\nconst resource = {\n  get: <T>(doctype: string, name?: string, params?: Record<string, string>) =>\n    request<T>(\"GET\", `/resource/${doctype}${name ? `/${name}` : \"\"}`, undefined, params),\n  insert: <T>(doctype: string, data: Record<string, unknown>) =>\n    request<T>(\"POST\", \"/method/frappe.client.insert\", { doc: { doctype, ...data } }),\n  update: <T>(doctype: string, name: string, data: Record<string, unknown>) =>\n    request<T>(\"PUT\", `/resource/${doctype}/${name}`, data),\n  delete: (doctype: string, name: string) =>\n    request<void>(\"DELETE\", `/resource/${doctype}/${name}`),\n  call: <T>(method: string, args: Record<string, unknown>) =>\n    request<T>(\"POST\", `/method/${method}`, args),\n};\n\nconst CACHE_TTL = 30_000;\nconst cache = new Map<string, { data: unknown; ts: number }>();\n\nfunction cached<T>(key: string, fn: () => Promise<T>): Promise<T> {\n  const hit = cache.get(key);\n  if (hit && Date.now() - hit.ts < CACHE_TTL) return Promise.resolve(hit.data as T);\n  return fn().then((data) => {\n    cache.set(key, { data, ts: Date.now() });\n    return data;\n  });\n}\n\nfunction invalidate(key?: string) {\n  if (key) {\n    cache.delete(key);\n    return;\n  }\n  cache.clear();\n}\n\nfunction listKey(\n  doctype: string,\n  filters?: Record<string, unknown>,\n  limit?: number,\n  offset?: number,\n) {\n  return `${doctype}:${JSON.stringify(filters)}:${limit ?? 20}:${offset ?? 0}`;\n}\n\nfunction withPagination(limit = 20, offset = 0): Record<string, string> {\n  return { limit_start: String(offset), limit_page_length: String(limit) };\n}\n\nexport const api = {\n  resource,\n  cached,\n  invalidate,\n  csrfToken,\n  listKey,\n  withPagination,\n};\n",
      "status": "success",
