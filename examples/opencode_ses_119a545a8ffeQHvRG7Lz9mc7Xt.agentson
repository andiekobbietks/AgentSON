      "code": "{\"content\": \"import frappe\\nfrappe.init(site=\\\"mysite.localhost\\\", sites_path=\\\"/home/andiekobbie/my-bench/sites\\\")\\nfrappe.connect()\\n# Check GP Project fields\\ndoc = frappe.get_meta(\\\"GP Project\\\")\\nprint(\\\"GP Project fields:\\\")\\nfor f in doc.fields:\\n    if f.fieldname in (\\\"team\\\",\\\"status\\\",\\\"name\\\",\\\"title\\\",\\\"icon\\\",\\\"description\\\"):\\n        print(f\\\"  {f.fieldname}: {f.fieldtype} | options: {f.options}\\\")\\n# Check existing GP Teams\\nteams = frappe.db.sql(\\\"SELECT name, title FROM `tabGP Team`\\\")\\nprint(\\\"GP Teams:\\\", teams)\\n# Check FG Event fields\\ndoc2 = frappe.get_meta(\\\"FG Event\\\")\\nprint(\\\"\\\\nFG Event fields:\\\")\\nfor f in doc2.fields:\\n    if f.fieldname in (\\\"event_type\\\",\\\"location_type\\\"):\\n        print(f\\\"  {f.fieldname}: {f.fieldtype} | options: {f.options}\\\")\\nfrappe.db.commit()\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\check_project_fields.py\"}",
