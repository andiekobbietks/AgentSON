      "code": "{\"command\": \"wsl -d Ubuntu -- bash -c \\\"cat /home/andiekobbie/my-bench/apps/fg_companion/frontend/src/views/PostDetailView.vue\\\"\", \"description\": \"Read PostDetailView\"}",
      "output": "<template>\n  <AppLayout :space-context-id=\"post?.project\">\n    <div class=\"max-w-[720px] mx-auto px-4 md:px-8 py-6\">\n      <div v-if=\"!post\" class=\"p-12 text-center\">\n        <h2 class=\"text-[18px] font-semibold mb-2\">Post not found</h2>\n        <RouterLink to=\"/\" class=\"text-primary underline\">Back home</RouterLink>\n      </div>\n      <template v-else>\n        <RouterLink\n          v-if=\"project\"\n          :to=\"`/spaces/${project.id}`\"\n          class=\"inline-flex items-center gap-1 text-[12px] text-muted-foreground hover:text-foreground mb-4\"\n        >\n          ← {{ project.icon }} {{ project.title }}\n        </RouterLink>\n\n        <article class=\"rounded-xl bg-card border border-border p-6\">\n          <div class=\"flex items-center gap-3 mb-4\">\n            <AppAvatar :user-id=\"post.author_id\" :size=\"40\" />\n            <div>\n              <RouterLink\n                :to=\"`/members/${post.author_id}`\"\n                class=\"block text-[14px] font-semibold leading-tight hover:text-primary\"\n              >\n                {{ getUser(post.author_id)?.full_name }}\n              </RouterLink>\n              <div class=\"text-[12px] text-muted-foreground\">{{ formatDate(post.created_at) }}</div>\n            </div>\n            <div v-if=\"sent\" class=\"ml-auto\">\n              <SentimentBadge :sentiment=\"sent\" />\n            </div>\n          </div>\n\n          <h1 class=\"text-[24px] font-bold leading-tight mb-3\">{{ post.title }}</h1>\n          <div\n            class=\"text-[15px] leading-relaxed text-secondary-foreground [&_p]:mb-3 [&_em]:italic\"\n            v-html=\"post.content\"\n          />\n\n          <!-- Reactions -->\n          <div class=\"mt-5 flex flex-wrap items-center gap-1.5\">\n            <button\n              v-for=\"emoji in QUICK_EMOJIS\"\n              :key=\"emoji\"\n              class=\"h-7 px-2.5 rounded-full border text-[13px] inline-flex items-center gap-1 transition-colors\"\n              :class=\"\n                myReactions.has(emoji)\n                  ? 'bg-primary-soft border-primary/40 text-primary-soft-foreground'\n                  : 'bg-card border-border hover:bg-secondary'\n              \"\n              @click=\"toggleReaction('GP Discussion', postId, emoji)\"\n            >\n              <span>{{ emoji }}</span>\n              <span v-if=\"(reactionCounts[emoji] ?? 0) > 0\" class=\"text-[12px] font-semibold\">{{\n                reactionCounts[emoji]\n              }}</span>\n            </button>\n          </div>\n        </article>\n\n        <!-- Comments -->\n        <section class=\"mt-6\">\n          <h2 class=\"text-[16px] font-semibold mb-3\">\n            {{ comments.length }} {{ comments.length === 1 ? \"comment\" : \"comments\" }}\n          </h2>\n\n          <!-- Reply composer -->\n          <form\n            class=\"rounded-xl bg-card border border-border p-3 mb-4 focus-within:border-border-strong\"\n            @submit.prevent=\"submitReply\"\n          >\n            <div class=\"flex gap-3\">\n              <AppAvatar :user-id=\"currentUserId\" :size=\"32\" />\n              <div class=\"flex-1\">\n                <textarea\n                  v-model=\"reply\"\n                  placeholder=\"Add a comment…\"\n                  rows=\"2\"\n                  class=\"w-full bg-transparent text-[14px] outline-none resize-none placeholder:text-muted-foreground\"\n                />\n                <div class=\"flex justify-end\">\n                  <button\n                    type=\"submit\"\n                    :disabled=\"!reply.trim()\"\n                    class=\"h-8 px-4 rounded-full bg-primary text-primary-foreground text-[13px] font-semibold disabled:opacity-40\"\n                  >\n                    Post\n                  </button>\n                </div>\n              </div>\n            </div>\n          </form>\n\n          <div class=\"flex flex-col gap-3\">\n            <div\n              v-for=\"c in comments\"\n              :key=\"c.id\"\n              class=\"rounded-xl bg-card border border-border p-4\"\n            >\n              <div class=\"flex items-center gap-2.5 mb-2\">\n                <AppAvatar :user-id=\"c.author_id\" :size=\"28\" />\n                <div class=\"text-[13px] font-semibold\">{{ getUser(c.author_id)?.full_name }}</div>\n                <span class=\"text-[11px] text-muted-foreground\">{{\n                  formatDateTime(c.created_at)\n                }}</span>\n              </div>\n              <div\n                class=\"text-[14px] leading-relaxed text-secondary-foreground [&_p]:mb-2\"\n                v-html=\"c.content\"\n              />\n            </div>\n          </div>\n        </section>\n\n        <!-- Similar posts -->\n        <aside v-if=\"similar.length\" class=\"mt-8 rounded-xl bg-card border border-border p-5\">\n          <div class=\"flex items-center gap-2 mb-3\">\n            <span class=\"text-primary\">✨</span>\n            <h3 class=\"text-[14px] font-semibold\">Similar conversations</h3>\n            <span\n              class=\"ml-auto text-[11px] text-muted-foreground\"\n              title=\"Mocked — production uses EmbeddingGemma + vector search.\"\n              >mocked</span\n            >\n          </div>\n          <ul class=\"flex flex-col gap-2\">\n            <li v-for=\"s in similar\" :key=\"s.id\">\n              <RouterLink\n                :to=\"`/posts/${s.id}`\"\n                class=\"text-[13px] text-secondary-foreground hover:text-primary\"\n                >→ {{ s.title }}</RouterLink\n              >\n            </li>\n          </ul>\n        </aside>\n      </template>\n    </div>\n  </AppLayout>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed, onMounted } from \"vue\";\nimport { RouterLink, useRoute } from \"vue-router\";\nimport AppLayout from \"@/components/AppLayout.vue\";\nimport AppAvatar from \"@/components/AppAvatar.vue\";\nimport SentimentBadge from \"@/components/SentimentBadge.vue\";\nimport type { GPDiscussion } from \"@/mock-data/types\";\nimport {\n  createComment,\n  currentUserId,\n  findSimilarPostsAsync,\n  getAISettings,\n  getCommentsFor,\n  getDiscussion,\n  getProject,\n  getReactionsFor,\n  getUser,\n  mockSentiment,\n  toggleReaction,\n} from \"@/data/store\";\n\nconst QUICK_EMOJIS = [\"💛\", \"🎉\", \"🤗\", \"👏\", \"💪\"];\n\nconst route = useRoute();\nconst postId = computed(() => route.params.postId as string);\nconst post = computed(() => getDiscussion(postId.value));\nconst project = computed(() => (post.value ? getProject(post.value.project) : null));\nconst comments = computed(() => getCommentsFor(postId.value));\nconst ai = getAISettings();\nconst sent = computed(() =>\n  post.value && ai.enable_sentiment ? mockSentiment(post.value.content) : null,\n);\nconst similar = ref<GPDiscussion[]>([]);\nonMounted(async () => {\n  if (ai.enable_vector_search && postId.value) {\n    similar.value = await findSimilarPostsAsync(postId.value);\n  }\n});\nconst reactions = computed(() => getReactionsFor(\"GP Discussion\", postId.value));\nconst myReactions = computed(\n  () => new Set(reactions.value.filter((r) => r.user === currentUserId).map((r) => r.emoji)),\n);\nconst reactionCounts = computed(() =>\n  reactions.value.reduce<Record<string, number>>((m, r) => {\n    m[r.emoji] = (m[r.emoji] ?? 0) + 1;\n    return m;\n  }, {}),\n);\n\nconst reply = ref(\"\");\n\nfunction submitReply() {\n  if (!reply.value.trim()) return;\n  createComment({\n    discussion_id: postId.value,\n    content: `<p>${reply.value.replace(/\\n/g, \"</p><p>\")}</p>`,\n  });\n  reply.value = \"\";\n}\n\nfunction formatDate(iso: string) {\n  return new Date(iso).toLocaleDateString(undefined, {\n    month: \"short\",\n    day: \"numeric\",\n    year: \"numeric\",\n  });\n}\nfunction formatDateTime(iso: string) {\n  return new Date(iso).toLocaleString(undefined, {\n    month: \"short\",\n    day: \"numeric\",\n    hour: \"numeric\",\n    minute: \"2-digit\",\n  });\n}\n</script>\n",
