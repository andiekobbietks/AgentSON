':'hosted_by','fieldtype':'Link','label':'Hosted By','options':'User'},\\n        {'fieldname':'attendees','fieldtype':'Table','label':'Attendees','options':'FG Event Attendee'},\\n    ],\\n    'permissions': [\\n        {'role':'System Manager','read':1,'write':1,'create':1,'delete':1},\\n        {'role':'Website User','read':1,'create':1,'write':1},\\n    ],\\n    'sort_field':'starts_on','sort_order':'ASC',\\n})\\n\\nwrite('fg_event_attendee', {\\n    'doctype':'DocType','name':'FG Event Attendee','module':'FG Companion',\\n    'istable':1,'editable_grid':1,\\n    'fields': [\\n        {'fieldname':'user','fieldtype':'Link','label':'User','options':'User','reqd':1},\\n        {'fieldname':'rsvp_status','fieldtype':'Select','label':'RSVP Status',\\n         'options':'Going\\\\nMaybe\\\\nNot Going\\\\nAttended\\\\nNo Show'},\\n    ],\\n    'permissions': [],\\n})\\n\\nwrite('fg_mentor_match', {\\n    'doctype':'DocType','name':'FG Mentor Match','module':'FG Companion',\\n    'autoname':'autoincrement','editable_grid':1,'track_changes':1,\\n    'fields': [\\n        {'fieldname':'mentee','fieldtype':'Link','label':'Mentee','options':'User','reqd':1,'in_list_view':1},\\n        {'fieldname':'mentor','fieldtype':'Link','label':'Mentor','options':'User','reqd':1},\\n        {'fieldname':'status','fieldtype':'Select','label':'Status',\\n         'options':'Requested\\\\nActive\\\\nCompleted\\\\nEnded Early','in_list_view':1,'default':'Requested'},\\n        {'fieldname':'matched_via','fieldtype':'Select','label':'Matched Via',\\n         'options':'Manual\\\\nSelf-Requested\\\\nAlgorithmic Suggestion','default':'Manual'},\\n        {'fieldname':'match_notes','fieldtype':'Small Text','label':'Notes'},\\n    ],\\n    'permissions': [\\n        {'role':'System Manager','read':1,'write':1,'create':1,'delete':1},\\n        {'role':'Website User','read':1,'create':1,'write':1},\\n    ],\\n    'sort_field':'modified','sort_order':'DESC',\\n})\\n\\nwrite('fg_ai_settings', {\\n    'doctype':'DocType','name':'FG AI Settings','module':'FG Companion',\\n    'fields': [\\n        {'fieldname':'enable_sentiment','fieldtype':'Check','label':'Enable Sentiment Analysis','default':'1'},\\n        {'fieldname':'sentiment_alert_threshold','fieldtype':'Float','label':'Sentiment Alert Threshold','default':'0.3'},\\n        {'fieldname':'enable_vector_search','fieldtype':'Check','label':'Enable Vector Search','default':'1'},\\n    ],\\n    'permissions': [{'role':'System Manager','read':1,'write':1,'create':1,'delete':1}],\\n})\\n\\nwrite('fg_user_settings', {\\n    'doctype':'DocType','name':'FG User Settings','module':'FG Companion',\\n    'autoname':'field:user','editable_grid':1,\\n    'fields': [\\n        {'fieldname':'user','fieldtype':'Link','label':'User','options':'User','reqd':1,'unique':1},\\n        {'fieldname':'email_on_mention','fieldtype':'Check','label':'Email on mention','default':'1'},\\n        {'fieldname':'email_on_reply','fieldtype':'Check','label':'Email on reply','default':'1'},\\n        {'fieldname':'email_weekly_digest','fieldtype':'Check','label':'Weekly digest email','default':'0'},\\n        {'fieldname':'push_on_dm','fieldtype':'Check','label':'Push on DM','default':'1'},\\n        {'fieldname':'push_on_mention','fieldtype':'Check','label':'Push on mention','default':'1'},\\n        {'fieldname':'show_in_member_directory','fieldtype':'Check','label':'Show in member directory','default':'1'},\\n        {'fieldname':'allow_dm_from_anyone','fieldtype':'Check','label':'Allow DMs from any member','default':'1'},\\n        {'fieldname':'theme','fieldtype':'Select','label':'Theme',\\n         'options':'system\\\\nlight\\\\ndark','default':'system'},\\n        {'fieldname':'language','fieldtype':'Select','label':'Language',\\n         'options':'en\\\\nes\\\\nfr','default':'en'},\\n        {'fieldname':'timezone','fieldtype':'Data','label':'Timezone','default':'Europe/London'},\\n    ],\\n    'permissions': [\\n        {'role'