      "code": "{\"command\": \"wsl -d Ubuntu -- bash -c \\\"cat /home/andiekobbie/my-bench/apps/fg_companion/frontend/src/components/AppLayout.vue\\\"\", \"description\": \"Read AppLayout component\"}",
      "output": "<template>\n  <div class=\"min-h-screen flex flex-col bg-background\">\n    <!-- Top nav -->\n    <header\n      data-tour=\"topnav\"\n      class=\"sticky top-0 z-40 h-14 bg-surface border-b border-border flex items-center px-4 md:px-6\"\n    >\n      <RouterLink to=\"/\" class=\"flex items-center gap-2 mr-6\">\n        <div\n          class=\"size-7 rounded-md bg-primary text-primary-foreground flex items-center justify-center text-[13px] font-bold\"\n        >\n          Fg\n        </div>\n        <span class=\"font-semibold text-[14px] hidden sm:inline\">FirstGens Community</span>\n      </RouterLink>\n\n      <nav class=\"hidden md:flex items-center gap-1 h-full\">\n        <RouterLink\n          v-for=\"tab in TOP_TABS\"\n          :key=\"tab.to\"\n          :to=\"tab.to\"\n          class=\"relative h-full px-3 inline-flex items-center text-[13px] transition-colors\"\n          :class=\"\n            isActive(tab.to)\n              ? 'text-foreground font-semibold'\n              : 'text-muted-foreground hover:text-foreground'\n          \"\n        >\n          {{ tab.label }}\n          <span\n            v-if=\"isActive(tab.to)\"\n            class=\"absolute bottom-0 left-3 right-3 h-[2px] bg-primary rounded-full\"\n          />\n        </RouterLink>\n      </nav>\n\n      <div class=\"ml-auto flex items-center gap-1\">\n        <button\n          type=\"button\"\n          class=\"size-8 rounded-md flex items-center justify-center text-muted-foreground hover:bg-secondary\"\n          aria-label=\"Search\"\n        >\n          <svg class=\"size-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <circle cx=\"11\" cy=\"11\" r=\"8\" />\n            <path d=\"m21 21-4.3-4.3\" />\n          </svg>\n        </button>\n\n        <button\n          type=\"button\"\n          data-tour=\"newpost\"\n          class=\"h-8 px-3 ml-1 rounded-full bg-primary text-primary-foreground text-[13px] font-semibold inline-flex items-center gap-1 hover:opacity-90\"\n          @click=\"showModal = true\"\n        >\n          <svg class=\"size-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path d=\"M5 12h14M12 5l7 7-7 7\" />\n          </svg>\n          <span class=\"hidden sm:inline\">New post</span>\n        </button>\n\n        <RouterLink\n          to=\"/messages\"\n          class=\"relative size-8 rounded-md flex items-center justify-center text-muted-foreground hover:bg-secondary\"\n          aria-label=\"Messages\"\n        >\n          <svg class=\"size-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\" />\n          </svg>\n          <span\n            v-if=\"unreadDMs > 0\"\n            class=\"absolute -top-0.5 -right-0.5 min-w-4 h-4 px-1 rounded-full bg-destructive text-[10px] font-bold text-destructive-foreground flex items-center justify-center\"\n          >\n            {{ unreadDMs }}\n          </span>\n        </RouterLink>\n\n        <RouterLink\n          to=\"/notifications\"\n          class=\"relative size-8 rounded-md flex items-center justify-center text-muted-foreground hover:bg-secondary\"\n          aria-label=\"Notifications\"\n        >\n          <svg class=\"size-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path d=\"M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0\" />\n          </svg>\n          <span\n            v-if=\"unreadNotifs > 0\"\n            class=\"absolute -top-0.5 -right-0.5 min-w-4 h-4 px-1 rounded-full bg-destructive text-[10px] font-bold text-destructive-foreground flex items-center justify-center\"\n          >\n            {{ unreadNotifs }}\n          </span>\n        </RouterLink>\n\n        <div class=\"relative\" data-tour=\"profile\">\n          <button\n            type=\"button\"\n            class=\"ml-1 inline-flex items-center\"\n            aria-label=\"Your account\"\n            @click=\"profileMenu = !profileMenu\"\n            @blur=\"scheduleClose\"\n          >\n            <AppAvatar :user-id=\"currentUserId\" :size=\"32\" />\n          </button>\n          <div\n            v-if=\"profileMenu\"\n            class=\"absolute right-0 top-10 w-56 bg-popover border border-border rounded-xl shadow-lg py-1.5 z-50\"\n          >\n            <div class=\"px-3 py-2 border-b border-border\">\n              <div class=\"text-[13px] font-semibold\">{{ me?.full_name }}</div>\n              <div class=\"text-[11px] text-muted-foreground truncate\">{{ currentUserId }}</div>\n              <div class=\"text-[10px] text-primary mt-0.5\">Demo account</div>\n            </div>\n            <RouterLink\n              :to=\"`/members/${currentUserId}`\"\n              class=\"flex items-center gap-2 px-3 py-2 text-[13px] hover:bg-secondary\"\n              @click=\"profileMenu = false\"\n              >View profile</RouterLink\n            >\n            <RouterLink\n              to=\"/settings\"\n              class=\"flex items-center gap-2 px-3 py-2 text-[13px] hover:bg-secondary\"\n              @click=\"profileMenu = false\"\n              >⚙️ Settings</RouterLink\n            >\n            <RouterLink\n              to=\"/docs\"\n              class=\"flex items-center gap-2 px-3 py-2 text-[13px] hover:bg-secondary\"\n              @click=\"profileMenu = false\"\n              >Docs &amp; ADR</RouterLink\n            >\n          </div>\n        </div>\n      </div>\n    </header>\n\n    <!-- Body -->\n    <div class=\"flex flex-1 min-h-0\">\n      <!-- Sidebar -->\n      <aside\n        data-tour=\"sidebar\"\n        class=\"hidden md:flex w-60 shrink-0 flex-col border-r border-border bg-sidebar px-3 py-4 gap-1 overflow-y-auto\"\n      >\n        <div class=\"relative mb-3\">\n          <svg\n            class=\"size-3.5 absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground\"\n            fill=\"none\"\n            stroke=\"currentColor\"\n            viewBox=\"0 0 24 24\"\n          >\n            <circle cx=\"11\" cy=\"11\" r=\"8\" />\n            <path d=\"m21 21-4.3-4.3\" />\n          </svg>\n          <input\n            placeholder=\"Search…\"\n            class=\"w-full h-8 pl-8 pr-3 rounded-full bg-secondary text-[13px] outline-none focus:ring-2 focus:ring-primary/30 placeholder:text-muted-foreground\"\n          />\n        </div>\n\n        <SidebarItem to=\"/\" label=\"Home Feed\" :active=\"route.path === '/'\" icon=\"🏠\" />\n\n        <template v-for=\"team in teams\" :key=\"team.id\">\n          <div v-if=\"getProjectsByTeam(team.id).length\" class=\"mt-4\">\n            <div\n              class=\"px-2 mb-1 text-[11px] uppercase tracking-wider font-semibold text-muted-foreground/80\"\n            >\n              {{ team.icon }} {{ team.title }}\n            </div>\n            <div class=\"flex flex-col gap-0.5\">\n              <RouterLink\n                v-for=\"p in getProjectsByTeam(team.id)\"\n                :key=\"p.id\"\n                :to=\"`/spaces/${p.id}`\"\n                class=\"h-8 px-2 rounded-md flex items-center gap-2 text-[13px] transition-colors\"\n                :class=\"\n                  isSpaceActive(p.id)\n                    ? 'bg-primary-soft text-primary-soft-foreground font-semibold'\n                    : 'text-secondary-foreground hover:bg-secondary'\n                \"\n              >\n                <span class=\"text-base leading-none\">{{ p.icon }}</span>\n                <span class=\"truncate\">{{ p.title }}</span>\n              </RouterLink>\n            </div>\n          </div>\n        </template>\n\n        <div\n          class=\"mt-6 px-2 text-[11px] uppercase tracking-wider font-semibold text-muted-foreground/80\"\n        >\n          Docs\n        </div>\n        <SidebarItem to=\"/docs\" label=\"Prototype docs\" :active=\"route.path === '/docs'\" icon=\"📄\" />\n        <SidebarItem\n          to=\"/settings\"\n          label=\"Settings\"\n          :active=\"route.path === '/settings'\"\n          icon=\"⚙️\"\n        />\n\n        <div class=\"mt-auto pt-4\">\n          <RouterLink\n            :to=\"`/members/${currentUserId}`\"\n            class=\"flex items-center gap-2 p-2 rounded-md hover:bg-secondary\"\n          >\n            <AppAvatar :user-id=\"currentUserId\" :size=\"32\" />\n            <div class=\"min-w-0\">\n              <div class=\"text-[13px] font-semibold truncate\">{{ me?.full_name }}</div>\n              <div class=\"text-[11px] text-muted-foreground truncate\">View profile</div>\n            </div>\n          </RouterLink>\n        </div>\n      </aside>\n\n      <!-- Main content -->\n      <main class=\"flex-1 min-w-0 bg-background\">\n        <slot />\n      </main>\n    </div>\n\n    <!-- New Post Modal -->\n    <NewPostModal :open=\"showModal\" :default-space-id=\"spaceContextId\" @close=\"showModal = false\" />\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed } from \"vue\";\nimport { RouterLink, useRoute } from \"vue-router\";\nimport {\n  getTeams,\n  getProjectsByTeam,\n  getUser,\n  currentUserId,\n  getUnreadDMCount,\n  getUnreadNotificationCount,\n} from \"@/data/store\";\nimport AppAvatar from \"./AppAvatar.vue\";\nimport NewPostModal from \"./NewPostModal.vue\";\nimport SidebarItem from \"./SidebarItem.vue\";\n\nconst props = defineProps<{ spaceContextId?: string }>();\n\nconst route = useRoute();\nconst showModal = ref(false);\nconst profileMenu = ref(false);\n\nconst teams = getTeams();\nconst me = computed(() => getUser(currentUserId));\nconst unreadDMs = computed(() => getUnreadDMCount());\nconst unreadNotifs = computed(() => getUnreadNotificationCount());\n\nconst TOP_TABS = [\n  { to: \"/\", label: \"Home\" },\n  { to: \"/events\", label: \"Events\" },\n  { to: \"/members\", label: \"Members\" },\n  { to: \"/courses\", label: \"Courses\" },\n  { to: \"/mentors\", label: \"Mentors\" },\n];\n\nfunction isActive(path: string) {\n  return path === \"/\" ? route.path === \"/\" : route.path.startsWith(path);\n}\n\nfunction isSpaceActive(id: string) {\n  return route.path === `/spaces/${id}` || props.spaceContextId === id;\n}\n\nfunction scheduleClose() {\n  setTimeout(() => (profileMenu.value = false), 150);\n}\n</script>\n",
