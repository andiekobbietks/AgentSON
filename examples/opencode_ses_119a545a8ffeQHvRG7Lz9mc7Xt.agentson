      "output": "<template>\n  <AppLayout>\n    <div class=\"max-w-[1040px] mx-auto px-4 md:px-8 py-6\">\n      <div class=\"flex items-start justify-between mb-5 gap-4 flex-wrap\">\n        <div>\n          <h1 class=\"text-[24px] font-bold leading-tight\">Courses</h1>\n          <p class=\"text-[14px] text-muted-foreground mt-0.5\">\n            Bite-sized, self-paced. Take what's useful, skip what isn't.\n          </p>\n        </div>\n        <RouterLink\n          to=\"/courses/new\"\n          class=\"h-9 px-4 rounded-full bg-primary text-primary-foreground text-[13px] font-semibold inline-flex items-center gap-1.5 hover:opacity-90\"\n        >\n          + Create course\n        </RouterLink>\n      </div>\n\n      <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3\">\n        <RouterLink\n          v-for=\"c in courses\"\n          :key=\"c.id\"\n          :to=\"`/courses/${c.id}`\"\n          class=\"group rounded-xl bg-card border border-border p-5 flex flex-col hover:border-border-strong transition-colors\"\n        >\n          <div\n            class=\"aspect-video rounded-lg bg-gradient-to-br from-primary-soft to-secondary mb-4 flex items-center justify-center text-4xl\"\n          >\n            📘\n          </div>\n          <div class=\"flex items-center gap-2 text-[11px] text-muted-foreground mb-1\">\n            <span class=\"font-semibold uppercase tracking-wider\">{{ c.category }}</span>\n            <span v-if=\"c.featured\" class=\"inline-flex items-center gap-0.5 text-flag-foreground\"\n              >⭐ Featured</span\n            >\n            <span\n              v-if=\"getEnrollment(c.id)\"\n              class=\"inline-flex items-center gap-0.5 text-primary-soft-foreground\"\n              >✓ Enrolled</span\n            >\n          </div>\n          <h2 class=\"text-[15px] font-semibold leading-snug group-hover:text-primary\">\n            {{ c.title }}\n          </h2>\n          <p class=\"text-[13px] text-muted-foreground mt-1 flex-1\">{{ c.short_introduction }}</p>\n          <div class=\"flex items-center gap-3 mt-3 text-[12px] text-muted-foreground\">\n            <span>📖 {{ c.lessons }} lessons</span>\n            <span>👤 {{ c.enrollments }}</span>\n          </div>\n          <div v-if=\"getEnrollment(c.id)\" class=\"mt-3\">\n            <div class=\"h-1.5 rounded-full bg-secondary overflow-hidden\">\n              <div\n                class=\"h-full bg-primary transition-all\"\n                :style=\"{ width: `${courseProgressPercent(c.id)}%` }\"\n              />\n            </div>\n            <div class=\"text-[11px] text-muted-foreground mt-1\">\n              {{ courseProgressPercent(c.id) }}% complete\n            </div>\n          </div>\n        </RouterLink>\n      </div>\n    </div>\n  </AppLayout>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from \"vue\";\nimport { RouterLink } from \"vue-router\";\nimport AppLayout from \"@/components/AppLayout.vue\";\nimport { getCourses, getEnrollment, courseProgressPercent } from \"@/data/store\";\n\nconst courses = computed(() => getCourses());\n</script>\n",
