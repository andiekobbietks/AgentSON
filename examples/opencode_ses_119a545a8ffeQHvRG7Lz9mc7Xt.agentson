      "code": "{\"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"Fix FG DocType module paths in tabDocType.\\\"\\\"\\\"\\nimport frappe\\nfrappe.init(site=\\\"mysite.localhost\\\")\\nfrappe.connect()\\n\\n# Update module field for all FG DocTypes to point to fg_companion.fg_companion\\nfg_doctypes = ['FG Event', 'FG Event Attendee', 'FG Mentor Match',\\n               'FG AI Settings', 'FG User Settings']\\nfor dt in fg_doctypes:\\n    frappe.db.set_value('DocType', dt, 'module', 'FG Companion', update_modified=False)\\n    print(f'Updated {dt} module -> FG Companion')\\n\\nfrappe.db.commit()\\nprint('Done.')\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\fix_fg_modules.py\"}",
