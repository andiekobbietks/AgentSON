      "code": "{\"command\": \"wsl -d Ubuntu -- bash -c \\\"cat /home/andiekobbie/my-bench/apps/fg_companion/frontend/src/views/CourseDetailView.vue\\\"\", \"description\": \"Read CourseDetailView\"}",
      "output": "<template>\n  <AppLayout>\n    <div class=\"max-w-[900px] mx-auto px-4 md:px-8 py-6\">\n      <div v-if=\"!course\" class=\"p-12 text-center\">\n        <h2 class=\"text-[18px] font-semibold mb-2\">Course not found</h2>\n        <RouterLink to=\"/courses\" class=\"text-primary underline\">Back to courses</RouterLink>\n      </div>\n      <template v-else>\n        <!-- Hero -->\n        <div class=\"rounded-xl overflow-hidden border border-border bg-card mb-5\">\n          <div\n            class=\"aspect-[4/1] bg-gradient-to-br from-primary-soft via-secondary to-primary-soft flex items-center justify-center text-6xl\"\n          >\n            📘\n          </div>\n          <div class=\"p-6\">\n            <div class=\"text-[11px] uppercase tracking-wider font-semibold text-muted-foreground\">\n              {{ course.category }}\n            </div>\n            <h1 class=\"text-[26px] font-bold leading-tight mt-1\">{{ course.title }}</h1>\n            <p class=\"text-[15px] text-secondary-foreground mt-2\">{{ course.description }}</p>\n            <div class=\"flex items-center gap-4 mt-4 text-[13px] text-muted-foreground flex-wrap\">\n              <span\n                >By\n                <RouterLink\n                  :to=\"`/members/${course.author}`\"\n                  class=\"text-foreground font-semibold hover:underline\"\n                  >{{ getUser(course.author)?.full_name }}</RouterLink\n                ></span\n              >\n              <span>📖 {{ course.lessons }} lessons</span>\n              <span>👤 {{ course.enrollments }} enrolled</span>\n              <span v-if=\"course.enable_certification\" class=\"text-primary-soft-foreground\"\n                >🏆 Certificate on completion</span\n              >\n            </div>\n\n            <div class=\"mt-5 flex items-center gap-3 flex-wrap\">\n              <template v-if=\"enr\">\n                <div class=\"flex-1 min-w-[180px]\">\n                  <div class=\"h-2 rounded-full bg-secondary overflow-hidden\">\n                    <div class=\"h-full bg-primary transition-all\" :style=\"{ width: `${pct}%` }\" />\n                  </div>\n                  <div class=\"text-[12px] text-muted-foreground mt-1\">{{ pct }}% complete</div>\n                </div>\n                <button\n                  type=\"button\"\n                  class=\"h-10 px-5 rounded-full bg-primary text-primary-foreground text-[14px] font-semibold inline-flex items-center gap-2 hover:opacity-90\"\n                  @click=\"goToFirst\"\n                >\n                  ▶ Continue\n                </button>\n              </template>\n              <button\n                v-else\n                type=\"button\"\n                class=\"h-10 px-5 rounded-full bg-primary text-primary-foreground text-[14px] font-semibold hover:opacity-90\"\n                @click=\"enrollInCourse(courseId)\"\n              >\n                Enroll for free\n              </button>\n            </div>\n          </div>\n        </div>\n\n        <!-- Chapters -->\n        <section>\n          <div class=\"flex items-center justify-between mb-3\">\n            <h2 class=\"text-[16px] font-semibold\">Course content</h2>\n            <button\n              v-if=\"isAuthor\"\n              type=\"button\"\n              class=\"h-8 px-3 rounded-full border border-border text-[12px] font-semibold inline-flex items-center gap-1 hover:bg-secondary\"\n              @click=\"addChapterPrompt\"\n            >\n              + Add chapter\n            </button>\n          </div>\n          <div class=\"flex flex-col gap-2\">\n            <div\n              v-for=\"ch in chapters\"\n              :key=\"ch.id\"\n              class=\"rounded-xl border border-border bg-card overflow-hidden\"\n            >\n              <div class=\"px-4 py-3 border-b border-border bg-secondary/40\">\n                <div class=\"text-[14px] font-semibold\">{{ ch.idx }}. {{ ch.title }}</div>\n                <div v-if=\"ch.description\" class=\"text-[12px] text-muted-foreground\">\n                  {{ ch.description }}\n                </div>\n              </div>\n              <ul>\n                <li\n                  v-for=\"l in getLessonsForChapter(ch.id)\"\n                  :key=\"l.id\"\n                  class=\"border-b border-border last:border-0\"\n                >\n                  <RouterLink\n                    :to=\"`/courses/${courseId}/lessons/${l.id}`\"\n                    class=\"flex items-center gap-3 px-4 py-2.5 hover:bg-secondary/40\"\n                  >\n                    <span>{{ isLessonComplete(l.id) ? \"✅\" : \"⭕\" }}</span>\n                    <span class=\"text-[13px] flex-1\">{{ l.title }}</span>\n                    <span v-if=\"l.youtube_video\" class=\"text-[11px] text-muted-foreground\"\n                      >▶ video</span\n                    >\n                  </RouterLink>\n                </li>\n                <li\n                  v-if=\"!getLessonsForChapter(ch.id).length\"\n                  class=\"px-4 py-3 text-[12px] text-muted-foreground\"\n                >\n                  No lessons yet.\n                </li>\n              </ul>\n              <div v-if=\"isAuthor\" class=\"px-4 py-2 border-t border-border bg-background\">\n                <div v-if=\"addLessonForChapter === ch.id\">\n                  <div class=\"flex flex-col gap-2 py-1\">\n                    <input\n                      v-model=\"lessonTitle\"\n                      placeholder=\"Lesson title\"\n                      autofocus\n                      class=\"h-9 px-3 rounded-md border border-border bg-background text-[13px] outline-none focus:ring-2 focus:ring-primary/30\"\n                    />\n                    <input\n                      v-model=\"lessonYt\"\n                      placeholder=\"YouTube URL (optional)\"\n                      class=\"h-9 px-3 rounded-md border border-border bg-background text-[13px] outline-none focus:ring-2 focus:ring-primary/30\"\n                    />\n                    <textarea\n                      v-model=\"lessonBody\"\n                      placeholder=\"Short description (optional)\"\n                      rows=\"2\"\n                      class=\"px-3 py-2 rounded-md border border-border bg-background text-[13px] outline-none focus:ring-2 focus:ring-primary/30 resize-none\"\n                    />\n                    <div class=\"flex gap-2\">\n                      <button\n                        type=\"button\"\n                        class=\"h-8 px-3 rounded-full bg-primary text-primary-foreground text-[12px] font-semibold\"\n                        @click=\"submitLesson(ch.id)\"\n                      >\n                        Add lesson\n                      </button>\n                      <button\n                        type=\"button\"\n                        class=\"h-8 px-3 rounded-full text-[12px] text-muted-foreground hover:bg-secondary\"\n                        @click=\"addLessonForChapter = null\"\n                      >\n                        Cancel\n                      </button>\n                    </div>\n                  </div>\n                </div>\n                <button\n                  v-else\n                  type=\"button\"\n                  class=\"text-[12px] text-primary font-semibold inline-flex items-center gap-1\"\n                  @click=\"addLessonForChapter = ch.id\"\n                >\n                  + Add lesson\n                </button>\n              </div>\n            </div>\n          </div>\n        </section>\n      </template>\n    </div>\n  </AppLayout>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed } from \"vue\";\nimport { RouterLink, useRoute, useRouter } from \"vue-router\";\nimport AppLayout from \"@/components/AppLayout.vue\";\nimport {\n  getCourse,\n  getChaptersForCourse,\n  getLessonsForChapter,\n  getEnrollment,\n  enrollInCourse,\n  courseProgressPercent,\n  isLessonComplete,\n  addChapter,\n  addLesson,\n  getUser,\n  currentUserId,\n} from \"@/data/store\";\n\nconst route = useRoute();\nconst router = useRouter();\nconst courseId = computed(() => route.params.courseId as string);\nconst course = computed(() => getCourse(courseId.value));\nconst chapters = computed(() => getChaptersForCourse(courseId.value));\nconst enr = computed(() => getEnrollment(courseId.value));\nconst pct = computed(() => courseProgressPercent(courseId.value));\nconst isAuthor = computed(() => course.value?.author === currentUserId);\n\nconst addLessonForChapter = ref<string | null>(null);\nconst lessonTitle = ref(\"\");\nconst lessonYt = ref(\"\");\nconst lessonBody = ref(\"\");\n\nfunction addChapterPrompt() {\n  const title = prompt(\"Chapter title?\");\n  if (title) addChapter(courseId.value, title);\n}\n\nfunction submitLesson(chapterId: string) {\n  if (!lessonTitle.value.trim()) return;\n  addLesson({\n    course: courseId.value,\n    chapter: chapterId,\n    title: lessonTitle.value,\n    body: lessonBody.value ? `<p>${lessonBody.value}</p>` : \"\",\n    youtube_video: lessonYt.value,\n  });\n  lessonTitle.value = \"\";\n  lessonYt.value = \"\";\n  lessonBody.value = \"\";\n  addLessonForChapter.value = null;\n}\n\nfunction goToFirst() {\n  const first = chapters.value.flatMap((ch) => getLessonsForChapter(ch.id))[0];\n  if (first) router.push(`/courses/${courseId.value}/lessons/${first.id}`);\n}\n</script>\n",
