    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"Generate fg_companion DocType JSON and Python files.\\\"\\\"\\\"\\n\\nimport os, json\\n\\nBASE = \\\"/home/andiekobbie/my-bench/apps/fg_companion/fg_companion/doctype\\\"\\n\\ndef write(name, data):\\n    path = os.path.join(BASE, name, name + \\\".json\\\")\\n    with open(path, \\\"w\\\") as f:\\n        json.dump(data, f, indent=2)\\n    print(f\\\"Written: {path}\\\")\\n\\n# \\u2500\\u2500 FG Event \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nwrite(\\\"fg_event\\\", {\\n    \\\"doctype\\\": \\\"DocType\\\",\\n    \\\"name\\\": \\\"FG Event\\\",\\n    \\\"module\\\": \\\"FG Companion\\\",\\n    \\\"autoname\\\": \\\"field:title\\\",\\n    \\\"editable_grid\\\": 1,\\n    \\\"track_changes\\\": 1,\\n    \\\"fields\\\": [\\n        {\\\"fieldname\\\": \\\"title\\\",        \\\"fieldtype\\\": \\\"Data\\\",        \\\"label\\\": \\\"Title\\\",           \\\"reqd\\\": 1,       \\\"in_list_view\\\": 1},\\n        {\\\"fieldname\\\": \\\"description\\\",  \\\"fieldtype\\\": \\\"Text Editor\\\",  \\\"label\\\": \\\"Description\\\"},\\n        {\\\"fieldname\\\": \\\"space\\\",        \\\"fieldtype\\\": \\\"Link\\\",         \\\"label\\\": \\\"Space\\\",           \\\"options\\\": \\\"GP Project\\\"},\\n        {\\\"fieldname\\\": \\\"event_type\\\",   \\\"fieldtype\\\": \\\"Select\\\",       \\\"label\\\": \\\"Event Type\\\",\\n         \\\"options\\\": \\\"Webinar\\\\nIn-Person Meetup\\\\nWorkshop\\\\nDrop-in Office Hours\\\\nNetworking\\\", \\\"in_list_view\\\": 1},\\n        {\\\"fieldname