\"fieldtype\\\": \\\"Check\\\", \\\"label\\\": \\\"RSVP Required\\\", \\\"default\\\": \\\"0\\\"},\\n  {\\\"fieldname\\\": \\\"capacity\\\", \\\"fieldtype\\\": \\\"Int\\\", \\\"label\\\": \\\"Capacity\\\"},\\n  {\\\"fieldname\\\": \\\"hosted_by\\\", \\\"fieldtype\\\": \\\"Link\\\", \\\"label\\\": \\\"Hosted By\\\", \\\"options\\\": \\\"User\\\"},\\n  {\\\"fieldname\\\": \\\"attendees\\\", \\\"fieldtype\\\": \\\"Table\\\", \\\"label\\\": \\\"Attendees\\\", \\\"options\\\": \\\"FG Event Attendee\\\"}\\n ],\\n \\\"permissions\\\": [\\n  {\\\"role\\\": \\\"System Manager\\\", \\\"read\\\": 1, \\\"write\\\": 1, \\\"create\\\": 1, \\\"delete\\\": 1},\\n  {\\\"role\\\": \\\"Website User\\\", \\\"read\\\": 1, \\\"create\\\": 1, \\\"write\\\": 1}\\n ],\\n \\\"sort_field\\\": \\\"starts_on\\\",\\n \\\"sort_order\\\": \\\"ASC\\\"\\n}\\nJSONEOF\\necho fg_event.json done\\\"\", \"description\": \"Write FG Event DocType JSON\"}",
