      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\store_wired.ts\", \"oldString\": \"interface RavenChannel {\\n  name: string;\\n  channel_name: string;\\n  type: string;\\n  channel_description?: string;\\n  is_direct_message: boolean;\\n  is_self_message: boolean;\\n  is_archived: boolean;\\n  peer_user_id?: string;\\n  last_message?: string;\\n  last_message_timestamp?: string;\\n  unread_count?: number;\\n}\\n\\ninterface RavenMessage {\\n  name: string;\\n  channel_id: string;\\n  text: string;\\n  message_type: string;\\n  owner: string;\\n  creation: string;\\n  text_format?: string;\\n  json_content?: string;\\n  linked_message?: string;\\n  is_reply?: boolean;\\n  reactions?: Record<string, string[]>;\\n}\\n\\n// Map Raven channel \\u2192 FGDMThread\\nfunction ravenChannelToThread(ch: RavenChannel, userId: string): FGDMThread {\\n  return {\\n    id: ch.name,\\n    channel_name: ch.channel_name,\\n    dm_user_1: userId,\\n    dm_user_2: ch.peer_user_id ?? \\\"\\\",\\n    last_message: ch.last_message ?? \\\"\\\",\\n    last_message_timestamp: ch.last_message_timestamp ?? \\\"\\\",\\n    unread_count: ch.unread_count ?? 0,\\n  };\\n}\\n\\n// Map Raven message \\u2192 FGDMMessage\\nfunction ravenMessageToDM(msg: RavenMessage): FGDMMessage {\\n  return {\\n    id: msg.name,\\n    channel: msg.channel_id,\\n    sender: msg.owner,\\n    content: msg.text,\\n    timestamp: msg.creation,\\n    read_by: [],\\n    reactions: msg.reactions ?? {},\\n  };\\n}\", \"newString\": \"interface RavenChannel {\\n  name: string;\\n  channel_name: string;\\n  type: string;\\n  channel_description?: string;\\n  is_direct_message: boolean;\\n  is_self_message: boolean;\\n  is_archived: boolean;\\n  creation?: string;\\n  owner?: string;\\n  last_message_timestamp?: string;\\n  last_message_details?: string; // \\\"text _ timestamp\\\" format\\n  peer_user_id?: string;\\n  workspace?: string;\\n}\\n\\ninterface RavenMessage {\\n  name: string;\\n  channel_id: string;\\n  text: string;\\n  message_type: string;\\n  owner: string;\\n  creation: string;\\n  text_format?: string;\\n  linked_message?: string;\\n  is_reply?: boolean;\\n}\\n\\n// Extract peer user id from channel name (format: \\\"user1 _ user2\\\")\\nfunction extractPeerUserId(channelName: string, currentUser: string): string {\\n  const parts = channelName.split(\\\" _ \\\");\\n  return parts.find((p) => p !== currentUser) ?? \\\"\\\";\\n}\\n\\n// Map Raven channel \\u2192 FGDMThread\\nfunction ravenChannelToThread(ch: RavenChannel, userId: string): FGDMThread {\\n  // Parse last_message_details: \\\"text _ ISO_timestamp\\\" or just text\\n  let lastPreview = \\\"\\\";\\n  let lastTs = \\\"\\\";\\n  if (ch.last_message_details) {\\n    const parts = ch.last_message_details.split(\\\" _ \\\");\\n    lastPreview = parts[0] ?? \\\"\\\";\\n    lastTs = parts.length > 1 ? parts.slice(1).join(\\\" _ \\\") : \\\"\\\";\\n  }\\n  return {\\n    id: ch.name,\\n    channel_type: ch.is_direct_message ? \\\"DM\\\" : \\\"Group\\\",\\n    is_direct_message: ch.is_direct_message,\\n    is_thread: false,\\n    is_self_message: ch.is_self_message,\\n    dm_user_1: ch.name.split(\\\" _ \\\")[0],\\n    dm_user_2: ch.name.split(\\\" _ \\\")[1] ?? \\\"\\\",\\n    workspace: ch.workspace ?? \\\"\\\",\\n    last_message_at: lastTs || ch.last_message_timestamp ?? ch.creation ?? \\\"\\\",\\n    last_message_preview: lastPreview,\\n  };\\n}\\n\\n// Map Raven message \\u2192 FGDMMessage\\nfunction ravenMessageToDM(msg: RavenMessage): FGDMMessage {\\n  return {\\n    id: msg.name,\\n    channel: msg.channel_id,\\n    sender: msg.owner,\\n    text: msg.text,\\n    message_type: \\\"Text\\\",\\n    file: \\\"\\\",\\n    image_width: 0,\\n    image_height: 0,\\n    content: msg.text,\\n    created_at: msg.creation,\\n    read_by: [],\\n  };\\n}\"}",
