      "output": "@import \"tailwindcss\";\n@import \"tw-animate-css\";\n\n@custom-variant dark (&:is(.dark *));\n\n/*\n * Design system — FirstGens brand: forest green primary, warm cream surfaces,\n * Anton display / Archivo body, border-only cards (no shadow at rest).\n */\n\n@theme inline {\n  --font-sans: \"Archivo\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n  --font-display: \"Anton\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n\n  --radius: 0.75rem;\n  --radius-sm: 0.375rem;\n  --radius-md: 0.5rem;\n  --radius-lg: 0.75rem;\n  --radius-xl: 1rem;\n  --radius-2xl: 1.25rem;\n\n  --color-background: var(--background);\n  --color-foreground: var(--foreground);\n  --color-surface: var(--surface);\n  --color-card: var(--card);\n  --color-card-foreground: var(--card-foreground);\n  --color-popover: var(--popover);\n  --color-popover-foreground: var(--popover-foreground);\n  --color-primary: var(--primary);\n  --color-primary-foreground: var(--primary-foreground);\n  --color-primary-soft: var(--primary-soft);\n  --color-primary-soft-foreground: var(--primary-soft-foreground);\n  --color-secondary: var(--secondary);\n  --color-secondary-foreground: var(--secondary-foreground);\n  --color-muted: var(--muted);\n  --color-muted-foreground: var(--muted-foreground);\n  --color-subtle: var(--subtle);\n  --color-accent: var(--accent);\n  --color-accent-foreground: var(--accent-foreground);\n  --color-destructive: var(--destructive);\n  --color-destructive-foreground: var(--destructive-foreground);\n  --color-border: var(--border);\n  --color-border-strong: var(--border-strong);\n  --color-input: var(--input);\n  --color-ring: var(--ring);\n  --color-flag: var(--flag);\n  --color-flag-foreground: var(--flag-foreground);\n  --color-success: var(--success);\n  --color-brand-terracotta: var(--brand-terracotta);\n  --color-brand-terracotta-foreground: var(--brand-terracotta-foreground);\n  --color-sidebar: var(--sidebar);\n  --color-sidebar-foreground: var(--sidebar-foreground);\n  --color-sidebar-border: var(--sidebar-border);\n  --color-sidebar-accent: var(--sidebar-accent);\n  --color-surface-gray-2: var(--surface-gray-2);\n  --color-ink-gray-5: var(--ink-gray-5);\n  --color-surface-white: var(--surface-white);\n\n  --shadow-card: 0 1px 3px rgba(15, 23, 42, 0.06), 0 1px 2px rgba(15, 23, 42, 0.04);\n  --shadow-modal: 0 20px 60px rgba(15, 23, 42, 0.12);\n  --shadow-dropdown: 0 4px 16px rgba(15, 23, 42, 0.08);\n}\n\n:root {\n  /* frappe-ui base tokens (Light Mode) — FirstGens warm cream surfaces */\n  --surface-base: oklch(0.97 0.015 80);\n  --surface-card: oklch(0.995 0.005 80);\n  --surface-sidebar: oklch(0.995 0.005 80);\n  --ink-base: oklch(0.18 0.02 30);\n  --surface-white: oklch(1 0 0);\n\n  --surface-gray-2: oklch(0.95 0.01 80);\n  --surface-gray-3: oklch(0.90 0.012 80);\n  --surface-gray-9: oklch(0.27 0.02 30);\n  --surface-gray-10: oklch(0.18 0.02 30);\n\n  --ink-gray-4: oklch(0.7 0.015 60);\n  --ink-gray-5: oklch(0.5 0.015 60);\n  --ink-gray-8: oklch(0.27 0.02 30);\n  --ink-gray-9: oklch(0.18 0.02 30);\n\n  --outline-gray-1: oklch(0.95 0.01 80);\n  --outline-gray-2: oklch(0.90 0.012 80);\n  --outline-gray-4: oklch(0.82 0.015 80);\n\n  --surface-red-2: oklch(0.95 0.02 25);\n  --surface-red-3: oklch(0.9 0.05 25);\n  --ink-red: oklch(0.6 0.22 25);\n\n  --surface-amber-2: oklch(0.97 0.05 80);\n  --ink-amber: oklch(0.55 0.13 70);\n\n  /* FirstGens forest green — primary accent */\n  --primary: oklch(0.45 0.10 152);\n  --primary-foreground: oklch(0.99 0.01 80);\n  --primary-soft: oklch(0.93 0.035 152);\n  --primary-soft-foreground: oklch(0.32 0.08 152);\n  --ring: oklch(0.45 0.10 152);\n  --success: oklch(0.7 0.17 145);\n\n  /* FirstGens terracotta — secondary accent, available for badges/CTAs */\n  --brand-terracotta: oklch(0.62 0.13 45);\n  --brand-terracotta-foreground: oklch(0.99 0.01 80);\n\n  --background: var(--surface-base);\n  --surface: var(--surface-card);\n  --foreground: var(--ink-base);\n  --card: var(--surface-card);\n  --card-foreground: var(--ink-base);\n  --popover: var(--surface-card);\n  --popover-foreground: var(--ink-base);\n  --secondary: var(--surface-gray-2);\n  --secondary-foreground: var(--ink-gray-8);\n  --muted: var(--surface-gray-2);\n  --muted-foreground: var(--ink-gray-5);\n  --subtle: var(--surface-gray-3);\n  --accent: var(--primary-soft);\n  --accent-foreground: var(--primary-soft-foreground);\n  --destructive: var(--surface-red-2);\n  --destructive-foreground: var(--ink-red);\n  --border: var(--outline-gray-2);\n  --border-strong: var(--outline-gray-4);\n  --input: var(--surface-gray-2);\n  --flag: var(--surface-amber-2);\n  --flag-foreground: var(--ink-amber);\n\n  --sidebar: var(--surface-sidebar);\n  --sidebar-foreground: var(--ink-gray-8);\n  --sidebar-border: var(--outline-gray-2);\n  --sidebar-accent: var(--surface-gray-2);\n}\n\n.dark {\n  /* frappe-ui base tokens (Dark Mode) — FirstGens aubergine surfaces */\n  --surface-base: oklch(0.18 0.02 350);\n  --surface-card: oklch(0.22 0.02 350);\n  --surface-sidebar: oklch(0.22 0.02 350);\n  --ink-base: oklch(0.97 0.015 80);\n  --surface-white: oklch(1 0 0);\n\n  --surface-gray-2: oklch(0.28 0.02 350);\n  --surface-gray-3: oklch(0.32 0.02 350);\n  --surface-gray-9: oklch(0.85 0.02 80);\n  --surface-gray-10: oklch(0.97 0.015 80);\n\n  --ink-gray-4: oklch(0.55 0.015 80);\n  --ink-gray-5: oklch(0.7 0.015 80);\n  --ink-gray-8: oklch(0.9 0.015 80);\n  --ink-gray-9: oklch(0.97 0.015 80);\n\n  --outline-gray-1: oklch(1 0 0 / 8%);\n  --outline-gray-2: oklch(1 0 0 / 12%);\n  --outline-gray-4: oklch(1 0 0 / 20%);\n\n  --surface-red-2: oklch(0.3 0.1 25);\n  --surface-red-3: oklch(0.35 0.12 25);\n  --ink-red: oklch(0.65 0.2 25);\n\n  --surface-amber-2: oklch(0.3 0.08 70);\n  --ink-amber: oklch(0.85 0.12 80);\n\n  --primary: oklch(0.6 0.12 152);\n  --primary-foreground: oklch(0.99 0.01 80);\n  --primary-soft: oklch(0.3 0.06 152);\n  --primary-soft-foreground: oklch(0.85 0.06 152);\n  --ring: oklch(0.6 0.12 152);\n  --success: oklch(0.7 0.17 145);\n\n  --brand-terracotta: oklch(0.68 0.13 45);\n  --brand-terracotta-foreground: oklch(0.99 0.01 80);\n}\n\n@layer base {\n  * {\n    border-color: var(--color-border);\n  }\n  html, body {\n    background-color: var(--color-background);\n    color: var(--color-foreground);\n    font-family: var(--font-sans);\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n  h1, h2, h3, h4 {\n    font-family: var(--font-display);\n    letter-spacing: -0.01em;\n    font-weight: 700;\n  }\n  ::-webkit-scrollbar { width: 10px; height: 10px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb {\n    background: var(--color-border);\n    border-radius: 9999px;\n    border: 2px solid var(--color-background);\n  }\n  ::-webkit-scrollbar-thumb:hover { background: var(--color-border-strong); }\n}\n",
