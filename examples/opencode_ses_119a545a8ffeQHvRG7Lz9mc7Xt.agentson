      "code": "{\"command\": \"wsl -d Ubuntu -- bash -c \\\"cat /home/andiekobbie/my-bench/apps/fg_companion/fg_companion/api.py\\\"\", \"description\": \"Read fg_companion API endpoints\"}",
      "output": "import frappe\n\n@frappe.whitelist()\ndef get_events(space=None):\n    filters = {}\n    if space:\n        filters['space'] = space\n    return frappe.get_list('FG Event', filters=filters, order_by='starts_on asc')\n\n@frappe.whitelist()\ndef get_event(name):\n    return frappe.get_doc('FG Event', name)\n\n@frappe.whitelist()\ndef rsvp(event, rsvp_status):\n    user = frappe.session.user\n    doc = frappe.get_doc('FG Event', event)\n    # Remove existing attendee row for this user\n    doc.set('attendees', [a for a in doc.attendees if a.user != user])\n    doc.append('attendees', {'user': user, 'rsvp_status': rsvp_status})\n    doc.save(ignore_permissions=True)\n    return doc\n\n@frappe.whitelist()\ndef get_mentor_matches(user=None):\n    user = user or frappe.session.user\n    return frappe.get_list('FG Mentor Match',\n        filters={'mentee': user},\n        order_by='modified desc')\n\n@frappe.whitelist()\ndef request_mentor(mentor, notes=''):\n    return frappe.get_doc({\n        'doctype': 'FG Mentor Match',\n        'mentee': frappe.session.user,\n        'mentor': mentor,\n        'status': 'Requested',\n        'match_notes': notes,\n    }).insert(ignore_permissions=True)\n\n@frappe.whitelist()\ndef get_ai_settings():\n    from fg_companion.fg_companion.doctype.fg_ai_settings.fg_ai_settings import FGAISettings\n    return FGAISettings.get_singleton().as_dict()\n\n@frappe.whitelist()\ndef get_user_settings(user=None):\n    from fg_companion.fg_companion.doctype.fg_user_settings.fg_user_settings import FGUserSettings\n    settings = FGUserSettings.get_for_user(user)\n    return settings.as_dict() if settings else None\n\n@frappe.whitelist()\ndef update_user_settings(patch):\n    from fg_companion.fg_companion.doctype.fg_user_settings.fg_user_settings import FGUserSettings\n    settings = FGUserSettings.get_for_user()\n    settings.update(patch)\n    settings.save(ignore_permissions=True)\n    return settings.as_dict()\n\n@frappe.whitelist()\ndef toggle_reaction(reference_doctype, reference_name, emoji):\n    Reaction = frappe.qb.DocType('GP Reaction')\n    existing = frappe.db.exists('GP Reaction', {\n        'reference_doctype': reference_doctype,\n        'reference_name': reference_name,\n        'user': frappe.session.user,\n        'emoji': emoji,\n    })\n    if existing:\n        frappe.delete_doc('GP Reaction', existing, ignore_permissions=True)\n    else:\n        frappe.get_doc({\n            'doctype': 'GP Reaction',\n            'reference_doctype': reference_doctype,\n            'reference_name': reference_name,\n            'user': frappe.session.user,\n            'emoji': emoji,\n        }).insert(ignore_permissions=True)\n    return True\n",
