      "code": "{\"command\": \"wsl -d Ubuntu -- bash -c \\\"cat > /home/andiekobbie/my-bench/apps/fg_companion/seed_fg_companion.py << 'PYEOF'\\n#!/usr/bin/env python3\\n\\\"\\\"\\\"Seed fg_companion + gameplan + lms from prototype mock data into the real DB.\\\"\\\"\\\"\\nimport frappe, getpass, sys\\n\\nfrappe.init(site='mysite.localhost')\\nfrappe.connect()\\n\\nCREATED_BY = frappe.session.user if frappe.session.user != 'Guest' else 'Administrator'\\nNOW = frappe.utils.now()\\n\\ndef seed_or_get(doctype, filters, defaults):\\n    \\\"\\\"\\\"Return existing record or create a new one.\\\"\\\"\\\"\\n    existing = frappe.db.exists(doctype, filters)\\n    if existing:\\n        return frappe.get_doc(doctype, existing)\\n    doc = frappe.get_doc({'doctype': doctype, **defaults})\\n    doc.insert(ignore_permissions=True)\\n    return doc\\n\\n# \\u2500\\u2500 Users / GP User Profiles \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nusers = [\\n    ('Sienna-Rae Martinez', 'sienna@example.com', '#ede9fe'),\\n    ('Priya Nair',           'priya@example.com',  '#dcfce7'),\\n    ('Kwame Mensah',         'kwame@example.com',  '#fef3c7'),\\n    ('Leila Ahmadi',         'leila@example.com',  '#fce7f3'),\\n    ('Marcus Webb',          'marcus@example.com', '#e0f2fe'),\\n    ('Zara Thompson',        'zara@example.com',  '#f3e8ff'),\\n]\\n\\nfor full_name, email, color in users:\\n    username = email.split('@')[0]\\n    if not frappe.db.exists('User', email):\\n        frappe.get_doc({\\n            'doctype': 'User',\\n            'email': email,\\n            'first_name': full_name.split()[0],\\n            'last_name': ' '.join(full_name.split()[1:]),\\n            'send_welcome_email': 0,\\n            'user_type': 'Website User',\\n        }).insert(ignore_permissions=True)\\n    seed_or_get('GP User Profile', {'user': email},\\n        {'user': email, 'full_name': full_name,\\n         'image_background_color': color, 'bio': f'{full_name} is a member of FirstGens.'})\\n\\n# \\u2500\\u2500 Teams \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nteams_data = [\\n    ('general',   'General',    ''),\\n    ('academic',  'Academic',   ''),\\n    ('wellbeing', 'Wellbeing',  ''),\\n]\\nteams = {}\\nfor tid, title, icon in teams_data:\\n    teams[tid] = seed_or_get('GP Team', {'name': tid},\\n        {'name': tid, 'title': title, 'icon': icon or '\\ud83d\\udcac', 'is_private': False})\\n\\n# \\u2500\\u2500 Projects (Spaces) \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nprojects_data = [\\n    ('welan',   'Welsh Language',    'Space for sharing in Welsh and supporting each other.',           '\\ud83c\\uddee\\ud83c\\uddf1', 'general'),\\n    ('csx',     'Computer Science',  'CS exam prep, uni questions, career advice \\u2014 all welcome.',      '\\ud83d\\udcbb',  'academic'),\\n    ('mental-health', 'Mental Health','A safe, supportive space to talk about wellbeing.',             '\\ud83c\\udf3f',  'wellbeing'),\\n    ('finances','Student Finances',  'Managing money as a student \\u2014 bursaries, jobs, budgeting.',     '\\ud83d\\udcb7',  'wellbeing'),\\n]\\nprojects = {}\\nfor pid, title, desc, icon, team in projects_data:\\n    projects[pid] = seed_or_get('GP Project', {'name': pid}, {\\n        'name': pid, 'title': title, 'description': desc, 'icon': icon,\\n        'team': teams[team].name, 'status': 'Open', 'is_private': False})\\n\\n# \\u2500\\u2500 Discussions \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\ndiscussions_data = [\\n    ('csx-1',  'csx',     'Sienna-Rae Martinez',  'A-level CS coursework help needed',\\n     'I am really struggling with the recursion part of my NEA...'),\\n    ('csx-2',  'csx',     'Kwame Mensah',         'How are people revising for CS exams?',\\n     'With only 6 weeks to go I am not sure where to start.'),\\n    ('welan-1','welan',   'Priya Nair',            'Cymraeg Gweithio group \\u2014 anyone interested?',\\n     'Setting up a weekly chat in Welsh to practise together.'),\\n    ('mh-1',   'mental-health', 'Leila Ahmadi',     'First week at university \\u2014 feeling a bit lost',\\n     'I arrived last week and honestly everything feels a bit overwhelming...'),\\n    ('fin-1',  'finances', 'Marcus Webb',           'Bursary applications \\u2014 when do they open?',\\n     'I have been looking everywhere but cannot find the dates for next year.'),\\n]\\ndiscussions = {}\\nfor did, project, author, title, content in discussions_data:\\n    discussions[did] = seed_or_get('GP Discussion', {'name': did}, {\\n        'name': did, 'project': projects[project].name, 'title': title,\\n        'content': f'<p>{content}</p>', 'status': 'Open',\\n        'author_id': next(e for n,e,_ in users if n == author)})\\n\\n# \\u2500\\u2500 FG Events \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nevents_data = [\\n    ('Welcome Week Mixer', 'Informal meetup for first-years. Come say hi!',\\n     'In-Person Meetup', '2026-09-25 18:00:00', 'Online (External Link)', '', 'https://meet.example.com/welcome'),\\n    ('Computer Science Drop-in', 'Weekly revision help with CS mentors.',\\n     'Drop-in Office Hours', '2026-09-30 16:00:00', 'Online (BigBlueButton)', 'fg-cs-dropin', ''),\\n]\\nfor i, (title, desc, etype, starts, ltype, bbb, ext) in enumerate(events_data):\\n    ename = f'Event-{i+1}'\\n    if not frappe.db.exists('FG Event', ename):\\n        doc = frappe.get_doc({'doctype': 'FG Event', 'title': title})\\n        doc.description = desc\\n        doc.event_type = etype\\n        doc.starts_on = starts\\n        doc.location_type = ltype\\n        if bbb: doc.bbb_meeting_id = bbb\\n        if ext: doc.external_link = ext\\n        doc.capacity = 30\\n        doc.insert(ignore_permissions=True)\\n\\n# \\u2500\\u2500 FG AI Settings \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2