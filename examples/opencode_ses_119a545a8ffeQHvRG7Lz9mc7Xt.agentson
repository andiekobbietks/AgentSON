    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"Seed fg_companion + gameplan from prototype mock data.\\\"\\\"\\\"\\nimport frappe\\nfrappe.init(site=\\\"mysite.localhost\\\")\\nfrappe.connect()\\n\\ndef s(doctype, name, defaults):\\n    if frappe.db.exists(doctype, name):\\n        return frappe.get_doc(doctype, name)\\n    try:\\n        d = frappe.get_doc({\\\"doctype\\\": doctype, \\\"name\\\": name, **defaults})\\n        d.insert(ignore_permissions=True, ignore_if_duplicate=True)\\n        return d\\n    except Exception as e:\\n        print(f\\\"SKIP {doctype}/{name}: {e}\\\")\\n        return frappe.get_doc(doctype, name)\\n\\nusers = [\\n    (\\\"sienna@example.com\\\", \\\"Sienna-Rae Martinez\\\", \\\"#ede9fe\\\"),\\n    (\\\"priya@example.com\\\",  \\\"Priya Nair\\\",           \\\"#dcfce7\\\"),\\n    (\\\"kwame@example.com\\\",   \\\"Kwame Mensah\\\",         \\\"#fef3c7\\\"),\\n    (\\\"leila@example.com\\\",   \\\"Leila Ahmadi\\\",        \\\"#fce7f3\\\"),\\n    (\\\"marcus@example.com\\\",  \\\"Marcus Webb\\\",         \\\"#e0f2fe\\\"),\\n    (\\\"zara@example.com\\\",    \\\"Zara Thompson\\\",       \\\"#f3e8ff\\\"),\\n]\\nfor email, full_name, color in users:\\n    if not frappe.db.exists(\\\"User\\\", email):\\n        try:\\n            frappe.get_doc({\\n                \\\"doctype\\\": \\\"User\\\", \\\"email\\\": email,\\n                \\\"first_name\\\": full_name.split()[0],\\n                \\\"last_name\\\": \\\" \\\".join(full_name.split()[1:]),\\n                \\\"send_welcome_email\\\": 0, \\\"user_type\\\": \\\"Website User\\\"\\n            }).insert(ignore_permissions=True)\\n        except Exception as e:\\n            print(f\\\"SKIP User {email}: {e}\\\")\\n    try:\\n        s(\\\"GP User Profile\\\", email, {\\n            \\\"user\\\": email, \\\"full_name\\\": full_name, \\\"image_background_color\\\": color})\\n    except Exception as e:\\n        print(f\\\"SKIP GPUserProfile {email}: {e}\\\")\\n\\nteams = {\\n    \\\"general\\\":  s(\\\"GP Team\\\", \\\"general\\\",  {\\\"title\\\": \\\"General\\\",  \\\"is_private\\\": False}),\\n    \\\"academic\\\": s(\\\"GP Team\\\", \\\"academic\\\", {\\\"title\\\": \\\"Academic\\\", \\\"is_private\\\": False}),\\n}\\nprojects = {\\n    \\\"csx\\\":  s(\\\"GP Project\\\", \\\"csx\\\",            {\\\"title\\\": \\\"Computer Science\\\", \\\"description\\\": \\\"CS exam prep, uni questions, career advice.\\\", \\\"icon\\\": \\\"\\ud83d\\udcbb\\\", \\\"team\\\": teams[\\\"academic\\\"].name, \\\"status\\\": \\\"Open\\\"}),\\n    \\\"welan\\\": s(\\\"GP Project\\\", \\\"welan\\\",          {\\\"title\\\": \\\"Welsh Language\\\",   \\\"description\\\": \\\"Space for sharing in Welsh.\\\",              \\\"icon\\\": \\\"\\ud83c\\udff4\\\",  \\\"team\\\": teams[\\\"general\\\"].name,  \\\"status\\\": \\\"Open\\\"}),\\n    \\\"mh\\\":   s(\\\"GP Project\\\", \\\"mental-health\\\",  {\\\"title\\\": \\\"Mental Health\\\",     \\\"description\\\": \\\"A safe supportive space.\\\",                \\\"icon\\\": \\\"\\ud83c\\udf3f\\\",  \\\"team\\\": \\\"general\\\",               \\\"status\\\": \\\"Open\\\"}),\\n    \\\"fin\\\":  s(\\\"GP Project\\\", \\\"finances\\\",       {\\\"title\\\": \\\"Student Finances\\\",  \\\"description\\\": \\\"Managing money as a student.\\\",           \\\"icon\\\": \\\"\\ud83d\\udcb7\\\",  \\\"team\\\": \\\"general\\\",               \\\"status\\\": \\\"Open\\\"}),\\n}\\ndiscs = [\\n    (\\\"csx-1\\\",  \\\"csx\\\",  \\\"sienna@example.com\\\", \\\"A-level CS coursework help\\\",  \\\"Recursion in my NEA is really tricky.\\\"),\\n    (\\\"csx-2\\\",  \\\"csx\\\",  \\\"kwame@example.com\\\",  \\\"CS exam revision tips?\\\",       \\\"6 weeks left, not sure where to start.\\\"),\\n    (\\\"welan-1\\\",\\\"welan\\\",\\\"priya@example.com\\\",  \\\"Cymraeg Gweithio group\\\",       \\\"Weekly Welsh chat, all levels welcome.\\\"),\\n    (\\\"mh-1\\\",   \\\"mh\\\",   \\\"leila@example.com\\\",  \\\"First week at university\\\",     \\\"Everything feels a bit overwhelming.\\\"),\\n    (\\\"fin-1\\\",  \\\"fin\\\",  \\\"marcus@example.com\\\", \\\"Bursary application dates?\\\",   \\\"Cannot find when they open.\\\"),\\n]\\nfor did, pid, author, title, content in discs:\\n    s(\\\"GP Discussion\\\", did, {\\n        \\\"project\\\": projects[pid].name, \\\"title\\\": title,\\n        \\\"content\\\": f\\\"<p>{content}</p>\\\", \\\"status\\\": \\\"Open\\\", \\\"author_id\\\": author})\\n\\nevents = [\\n    (\\\"Welcome Week Mixer\\\", \\\"Informal meetup for first-years.\\\", \\\"In-Personal Meetup\\\",    \\\"2026-09-25 18:00:00\\\", \\\"ext\\\",  \\\"https://meet.example.com\\\",  30),\\n    (\\\"CS Drop-in\\\",         \\\"Weekly CS revision help.\\\",          \\\"Drop-in Office Hours\\\",  \\\"2026-09-30 16:00:00\\\", \\\"bbb\\\",  \\\"fg-cs-dropin\\\",               20),\\n]\\nfor i, (title, desc, etype, starts, ltype, link, cap) in enumerate(events):\\n    ename = f\\\"Event-{i+1}\\\"\\n    if not frappe.db.exists(\\\"FG Event\\\", ename):\\n        try:\\n            doc = frappe.get_doc({\\\"doctype\\\": \\\"FG Event\\\", \\\"title\\\": title})\\n            doc.description = desc\\n            doc.event_type = etype\\n            doc.starts_on = starts\\n            doc.location_type = ltype\\n            doc.capacity = cap\\n            if ltype == \\\"ext\\\":\\n                doc.external_link = link\\n            else:\\n                doc.bbb_meeting_id = link\\n            doc.insert(ignore_permissions=True)\\n        except Exception as e:\\n            print(f\\\"EVENT ERROR {ename}: {e}\\\")\\n\\nif not frappe.db.exists(\\\"FG AI Settings\\\", \\\"FG AI Settings\\\"):\\n    try:\\n        frappe.get_doc({\\n            \\\"doctype\\\": \\\"FG AI Settings\\\", \\\"name\\\": \\\"FG AI Settings\\\",\\n            \\\"enable_sentiment\\\": 1, \\\"sentiment_alert_threshold\\\": 0.3,\\n            \\\"enable_vector_search\\\": 1\\n        }).insert(ignore_permissions=True)\\n    except Exception as e:\\n        print(f\\\"AI SETTINGS ERROR: {e}\\\")\\n\\nfrappe.db.commit()\\nprint(\\\"Seed complete!\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\seed_fg_companion.py\"}",
      "output": "Wrote file successfully.\n\n<system-reminder>\nYou just created or modified a file. If this file IS the deliverable the user asked for (document, report, image, spreadsheet, archive, audio, video, code artifact, etc.), you MUST include it in your response with `<media src=\"/absolute/path\" />`; do not only print the path. If it is only an intermediate/source edit, no media tag is needed.\n</system-reminder>",
