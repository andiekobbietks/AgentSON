    {
      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"wsl -d Ubuntu -- bash -c \\\"cat > /home/andiekobbie/my-bench/apps/fg_companion/fg_companion/doctype/fg_event/fg_event.py << 'PYEOF'\\nimport frappe\\nfrom frappe.model.document import Document\\n\\nclass FGEvent(Document):\\n    def before_save(self):\\n        if self.starts_on and not self.ends_on:\\n            # Default ends_on to 1 hour after starts_on\\n            from frappe.utils import add_to_date\\n            self.ends_on = add_to_date(self.starts_on, hours=1)\\n\\n    def after_insert(self):\\n        # Create a notification log when a new event is created\\n        if self.hosted_by:\\n            frappe.publish_realtime(\\n                event='fg_event_created',\\n                message={'event': self.name, 'title': self.title},\\n                after_commit=True,\\n            )\\nPYEOF\\n\\ncat > /home/andiekobbie/my-bench/apps/fg_companion/fg_companion/doctype/fg_event_attendee/fg_event_attendee.py << 'PYEOF'\\nimport frappe\\nfrom frappe.model.document import Document\\n\\nclass FGEventAttendee(Document):\\n    pass\\nPYEOF\\n\\ncat > /home/andiekobbie/my-bench/apps/fg_companion/fg_companion/doctype/fg_mentor_match/fg_mentor_match.py << 'PYEOF'\\nimport frappe\\nfrom frappe.model.document import Document\\n\\nclass FGMentorMatch(Document):\\n    def validate(self):\\n        if self.mentee == self.mentor:\\n            frappe.throw('Mentee and mentor cannot be the same user.')\\n        # Check for existing active match\\n        existing = frappe.db.exists('FG Mentor Match', {\\n            'mentee': self.mentee,\\n            'mentor': self.mentor,\\n            'status': ['in', ['Requested', 'Active']],\\n        })\\n        if existing and existing != self.name:\\n            frappe.throw(f'An active or pending match already exists ({existing}).')\\nPYEOF\\n\\ncat > /home/andiekobbie/my-bench/apps/fg_companion/fg_companion/doctype/fg_ai_settings/fg_ai_settings.py << 'PYEOF'\\nimport frappe\\nfrom frappe.model.document import Document\\n\\nclass FGAISettings(Document):\\n    @staticmethod\\n    def get_singleton():\\n        if not frappe.db.exists('FG AI Settings', 'FG AI Settings'):\\n            doc = frappe.get_doc({'doctype': 'FG AI Settings', 'name': 'FG AI Settings'})\\n            doc.insert(ignore_permissions=True)\\n        return frappe.get_doc('FG AI Settings', 'FG AI Settings')\\nPYEOF\\n\\ncat > /home/andiekobbie/my-bench/apps/fg_companion/fg_companion/doctype/fg_user_settings/fg_user_settings.py << 'PYEOF'\\nimport frappe\\nfrom frappe.model.document import Document\\n\\nclass FGUserSettings(Document):\\n    @staticmethod\\n    def get_for_user(user=None):\\n        user = user or frappe.session.user\\n        if user == 'Guest':\\n            return None\\n        if not frappe.db.exists('FG User Settings', user):\\n            doc = frappe.get_doc({'doctype': 'FG User Settings', 'user': user})\\n            doc.insert(ignore_permissions=True)\\n        return frappe.get_doc('FG User Settings', user)\\nPYEOF\\necho done\\\"\", \"description\": \"Write all DocType Python controllers\"}",
      "output": "done\n",
      "status": "success",
      "timestamp": 1781983972232
