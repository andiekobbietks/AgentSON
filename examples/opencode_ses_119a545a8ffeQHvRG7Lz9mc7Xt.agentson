    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"import { ref, onMounted, onUnmounted } from \\\"vue\\\";\\nimport * as mockStore from \\\"@/mock-data/store\\\";\\nimport { api } from \\\"./api\\\";\\nimport type {\\n  GPDiscussion,\\n  GPComment,\\n  GPUserProfile,\\n  FGMentorMatch,\\n  FGUserSettings,\\n  LMSCourse,\\n  LMSChapter,\\n  LMSLesson,\\n  RSVPStatus,\\n  SentimentLabel,\\n  FGDMThread,\\n  FGDMMessage,\\n  FGNotification,\\n  FGSSOProvider,\\n  SSOProviderId,\\n  FGPoll,\\n  FGPollVote,\\n  FGBadge,\\n  FGBadgeAward,\\n  HDTicket,\\n  HDTicketType,\\n  HDPriority,\\n  HDTicketStatus,\\n  FGSubscriptionPlan,\\n  FGPaymentPlan,\\n  FGEvent,\\n  FGEventAttendee,\\n  FGAISettings,\\n} from \\\"@/mock-data/types\\\";\\n\\n// Use real API when we have a CSRF token (authenticated session).\\n// Both /portal/* and /app/* have CSRF cookies when logged in.\\nconst IS_AUTHENTICATED = typeof window !== \\\"undefined\\\" && !!api.csrfToken();\\n\\nfunction useRealApi(): boolean {\\n  return IS_AUTHENTICATED;\\n}\\n\\nlet currentUser = mockStore.currentUserId;\\nif (IS_AUTHENTICATED && typeof document !== \\\"undefined\\\") {\\n  const el = document.querySelector('meta[name=\\\"frappe-user\\\"]');\\n  if (el) currentUser = el.getAttribute(\\\"content\\\") ?? currentUser;\\n}\\n\\nexport const useStoreVersion = mockStore.useStoreVersion;\\nexport const currentUserId = currentUser;\\n\\n// --- In-memory fallback state (seeded from mock) ---\\ninterface CacheEntry<T> {\\n  data: T;\\n  ts: number;\\n}\\nconst ttl = 30_000;\\nconst queryCache = new Map<string, CacheEntry<unknown>>();\\nfunction cacheGet<T>(key: string): T | undefined {\\n  const e = queryCache.get(key);\\n  if (e && Date.now() - e.ts < ttl) return e.data as T;\\n  return undefined;\\n}\\nfunction cacheSet(key: string, data: unknown) {\\n  queryCache.set(key, { data, ts: Date.now() });\\n}\\n\\nexport function invalidateCache(key?: string) {\\n  api.invalidate(key);\\n  queryCache.clear();\\n}\\n\\n// ===================== Raven DM types (mirrors Raven API) =====================\\ninterface RavenChannel {\\n  name: string;\\n  channel_name: string;\\n  type: string;\\n  channel_description?: string;\\n  is_direct_message: boolean;\\n  is_self_message: boolean;\\n  is_archived: boolean;\\n  peer_user_id?: string;\\n  last_message?: string;\\n  last_message_timestamp?: string;\\n  unread_count?: number;\\n}\\n\\ninterface RavenMessage {\\n  name: string;\\n  channel_id: string;\\n  text: string;\\n  message_type: string;\\n  owner: string;\\n  creation: string;\\n  text_format?: string;\\n  json_content?: string;\\n  linked_message?: string;\\n  is_reply?: boolean;\\n  reactions?: Record<string, string[]>;\\n}\\n\\n// Map Raven channel \\u2192 FGDMThread\\nfunction ravenChannelToThread(ch: RavenChannel, userId: string): FGDMThread {\\n  return {\\n    id: ch.name,\\n    channel_name: ch.channel_name,\\n    dm_user_1: userId,\\n    dm_user_2: ch.peer_user_id ?? \\\"\\\",\\n    last_message: ch.last_message ?? \\\"\\\",\\n    last_message_timestamp: ch.last_message_timestamp ?? \\\"\\\",\\n    unread_count: ch.unread_count ?? 0,\\n  };\\n}\\n\\n// Map Raven message \\u2192 FGDMMessage\\nfunction ravenMessageToDM(msg: RavenMessage): FGDMMessage {\\n  return {\\n    id: msg.name,\\n    channel: msg.channel_id,\\n    sender: msg.owner,\\n    content: msg.text,\\n    timestamp: msg.creation,\\n    read_by: [],\\n    reactions: msg.reactions ?? {},\\n  };\\n}\\n\\n// ===================== Selectors =====================\\n\\nexport const getUsers = () =>\\n  useRealApi()\\n    ? (cacheGet<GPUserProfile[]>(\\\"users\\\") ??\\n       (async () => {\\n         const users = await api.resource.get<GPUserProfile[]>(\\\"GP User Profile\\\");\\n         cacheSet(\\\"users\\\", users);\\n         return users;\\n       })())\\n    : mockStore.getUsers();\\n\\nexport const getUser = (id: string) =>\\n  useRealApi() ? mockStore.getUser(id) : mockStore.getUser(id);\\nexport const getProjects = () => mockStore.getProjects();\\nexport const getProject = (id: string) => mockStore.getProject(id);\\nexport const getTeams = () => mockStore.getTeams();\\nexport const getProjectsByTeam = (teamId: string) => mockStore.getProjectsByTeam(teamId);\\n\\nexport async function getDiscussionsAsync(\\n  projectId?: string,\\n  limit = 20,\\n  offset = 0,\\n): Promise<{\\n  posts: GPDiscussion[];\\n  total: number;\\n}> {\\n  if (!useRealApi()) {\\n    const all = mockStore.getDiscussions(projectId);\\n    return { posts: all.slice(offset, offset + limit), total: all.length };\\n  }\\n  const filters: Record<string, string> = {};\\n  if (projectId) filters[\\\"project\\\"] = projectId;\\n  const params: Record<string, string> = {\\n    ...api.withPagination(limit, offset),\\n    ...(Object.keys(filters).length ? { filters: JSON.stringify([[\\\"project\\\", \\\"=\\\", projectId]]) } : {}),\\n    order_by: \\\"pinned_at desc, last_post_at desc\\\",\\n  };\\n  const result = await api.resource.get<GPDiscussion[]>(\\\"GP Discussion\\\", undefined, params);\\n  return { posts: result, total: -1 };\\n}\\n\\nexport function getDiscussions(projectId?: string): GPDiscussion[] {\\n  return mockStore.getDiscussions(projectId);\\n}\\n\\nexport const getDiscussion = (id: string) => mockStore.getDiscussion(id);\\n\\nexport function getCommentsFor(discussionId: string): GPComment[] {\\n  return mockStore.getCommentsFor(discussionId);\\n}\\n\\nexport const getReactionsFor = (ref: \\\"GP Discussion\\\" | \\\"GP Comment\\\", id: string) =>\\n  mockStore.getReactionsFor(ref, id);\\n\\n// \\u2500\\u2500\\u2500 Events (real API) \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n\\nexport function getEvents(): FGEvent[] {\\n  if (!useRealApi()) return mockStore.getEvents();\\n  const cached = cacheGet<FGEvent[]>(\\\"fg_events\\\");\\n  if (cached) return cached;\\n  // fg_companion.api returns a list \\u2014 fetch via RPC\\n  api.resource\\n    .call<FGEvent[]>(\\\"fg_companion.api.get_events\\\")\\n    .then((events) => cacheSet(\\\"fg_events\\\", events))\\n    .catch(() => {});\\n  return cached ?? mockStore.getEvents();\\n}\\n\\nexport async function getEventsAsync(): Promise<FGEvent[]> {\\n  if (!useRealApi()) return mockStore.getEvents();\\n  const cached = cacheGet<FGEvent[]>(\\\"fg_events\\\");\\n  if (cached) return cached;\\n  try {\\n    const events = await api.resource.call<FGEvent[]>(\\\"fg_companion.api.get_events\\\");\\n    cacheSet(\\\"fg_events\\\", events);\\n    return events;\\n  } catch {\\n    return mockStore.getEvents();\\n  }\\n}\\n\\nexport async function getEvent(id: string): Promise<FGEvent | null> {\\n  if (!useRealApi()) return mockStore.getEvent(id);\\n  try {\\n    return await api.resource.call<FGEvent>(\\\"fg_companion.api.get_event\\\", { name: id });\\n  } catch {\\n    return mockStore.getEvent(id);\\n  }\\n}\\n\\nexport async function getAttendees(eventId: string): Promise<FGEventAttendee[]> {\\n  if (!useRealApi()) return mockStore.getAttendees(eventId);\\n  try {\\n    const event = await api.resource.call<FGEvent>(\\\"fg_companion.api.get_event\\\", { name: eventId });\\n    return (event as any)?.attendees ?? [];\\n  } catch {\\n    return mockStore.getAttendees(eventId);\\n  }\\n}\\n\\n// \\u2500\\u2500\\u2500 Mentor Matches \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n\\nexport const getMatchesForUser = (userId: string) => mockStore.getMatchesForUser(userId);\\nexport const getRecentPostsByUser = (userId: string) => mockStore.getRecentPostsByUser(userId);\\nexport const getAISettings = (): FGAISettings => mockStore.getAISettings();\\n\\n// \\u2500\\u2500\\u2500 LMS Courses (real API via Frappe resource) \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n\\nexport async function getCoursesAsync(): Promise<LMSCourse[]> {\\n  if (!useRealApi()) return mockStore.getCourses();\\n  const key = \\\"lms_courses\\\";\\n  const cached = cacheGet<LMSCourse[]>(key);\\n  if (cached) return cached;\\n  try {\\n    const courses = await api.resource.get<LMSCourse[]>(\\\"LMS Course\\\", undefined, {\\n      fields: JSON.stringify([\\\"name\\\", \\\"title\\\", \\\"short_introduction\\\", \\\"description\\\", \\\"image\\\", \\\"paid_course\\\", \\\"published\\\", \\\"upcoming\\\"]),\\n      order_by: \\\"modified desc\\\",\\n    });\\n    cacheSet(key, courses);\\n    return courses;\\n  } catch {\\n    return mockStore.getCourses();\\n  }\\n}\\n\\nexport const getCourses = () =>\\n  useRealApi()\\n    ? (cacheGet<LMSCourse[]>(\\\"lms_courses\\\") ?? mockStore.getCourses())\\n    : mockStore.getCourses();\\n\\nexport const getAllCoursesIncludingDrafts = () => mockStore.getAllCoursesIncludingDrafts();\\nexport const getCourse = (id: string) => mockStore.getCourse(id);\\nexport const getChaptersForCourse = (courseId: string) => mockStore.getChaptersForCourse(courseId);\\nexport const getLessonsForChapter = (chapterId: string) =>\\n  mockStore.getLessonsForChapter(chapterId);\\nexport const getLessonsForCourse = (courseId: string) => mockStore.getLessonsForCourse(courseId);\\nexport const getLesson = (id: string) => mockStore.getLesson(id);\\nexport const getEnrollment = (courseId: string, userId = currentUserId) =>\\n  mockStore.getEnrollment(courseId, userId);\\nexport const getMyEnrollments = (userId = currentUserId) => mockStore.getMyEnrollments(userId);\\nexport const isLessonComplete = (lessonId: string, userId = currentUserId) =>\\n  mockStore.isLessonComplete(lessonId, userId);\\nexport function courseProgressPercent(courseId: string, userId = currentUserId) {\\n  return mockStore.courseProgressPercent(courseId, userId);\\n}\\n\\n// \\u2500\\u2500\\u2500 User settings \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n\\nexport const getUserSettings = (userId = currentUserId): FGUserSettings =>\\n  mockStore.getUserSettings(userId);\\n\\n// \\u2500\\u2500\\u2500 DMs \\u2014 Raven (real API) \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n\\nconst dmThreadSet = ref(new Set<string>());\\nfunction rebuildThreadIndex(threads: FGDMThread[]) {\\n  dmThreadSet.value = new Set(threads.map((t) => t.id));\\n}\\n\\nexport async function getDMThreadsForUserAsync(userId = currentUserId): Promise<FGDMThread[]> {\\n  if (!useRealApi()) {\\n    const threads = mockStore.getDMThreadsForUser(userId);\\n    rebuildThreadIndex(threads);\\n    return threads;\\n  }\\n  try {\\n    const result = await api.resource.call<{ channels: RavenChannel[]; dm_channels: RavenChannel[] }>(\\n      \\\"raven_channel.get_all_channels\\\",\\n      { hide_archived: true }\\n    );\\n    const threads: FGDMThread[] = (result.dm_channels ?? []).map((ch) =>\\n      ravenChannelToThread(ch, userId)\\n    );\\n    rebuildThreadIndex(threads);\\n    return threads;\\n  } catch {\\n    return mockStore.getDMThreadsForUser(userId);\\n  }\\n}\\n\\nexport const getDMThreadsForUser = (userId = currentUserId): FGDMThread[] =>\\n  mockStore.getDMThreadsForUser(userId);\\n\\nexport async function getDMThreadAsync(id: string): Promise<FGDMThread | null> {\\n  if (!useRealApi()) return mockStore.getDMThread(id);\\n  try {\\n    const result = await api.resource.call<RavenChannel[]>(\\\"raven_channel.get_all_channels\\\", {\\n      hide_archived: true,\\n    });\\n    const ch = [...(result.channels ?? []), ...(result.dm_channels ?? [])].find((c) => c.name === id);\\n    return ch ? ravenChannelToThread(ch, currentUserId) : null;\\n  } catch {\\n    return mockStore.getDMThread(id);\\n  }\\n}\\n\\nexport const getDMThread = (id: string) => mockStore.getDMThread(id);\\n\\nexport async function getDMMessagesAsync(threadId: string): Promise<FGDMMessage[]> {\\n  if (!useRealApi()) return mockStore.getDMMessages(threadId);\\n  try {\\n    const msgs = await api.resource.get<RavenMessage[]>(\\\"Raven Message\\\", undefined, {\\n      filters: JSON.stringify([[\\\"channel_id\\\", \\\"=\\\", threadId]]),\\n      order_by: \\\"creation asc\\\",\\n    });\\n    return msgs.map(ravenMessageToDM);\\n  } catch {\\n    return mockStore.getDMMessages(threadId);\\n  }\\n}\\n\\nexport const getDMMessages = (threadId: string): FGDMMessage[] =>\\n  mockStore.getDMMessages(threadId);\\n\\nexport const getOtherMember = (thread: FGDMThread, userId = currentUserId) =>\\n  thread.dm_user_1 === userId ? thread.dm_user_2 : thread.dm_user_1;\\n\\nexport async function openOrCreateDMWithAsync(otherUserId: string): Promise<FGDMThread> {\\n  if (!useRealApi()) {\\n    const r = mockStore.openOrCreateDMWith(otherUserId);\\n    rebuildThreadIndex(mockStore.getDMThreadsForUser());\\n    return r;\\n  }\\n  try {\\n    const ch = await api.resource.call<RavenChannel>(\\\"raven_channel.create_direct_message_channel\\\", {\\n      user_id: otherUserId,\\n    });\\n    return ravenChannelToThread(ch, currentUserId);\\n  } catch {\\n    return mockStore.openOrCreateDMWith(otherUserId);\\n  }\\n}\\n\\nexport function openOrCreateDMWith(otherUserId: string): FGDMThread {\\n  return mockStore.openOrCreateDMWith(otherUserId);\\n}\\n\\nexport async function sendDMAsync(threadId: string, content: string): Promise<FGDMMessage | null> {\\n  if (!useRealApi()) return mockStore.sendDM(threadId, content);\\n  try {\\n    const msg = await api.resource.call<RavenMessage>(\\\"raven_message.send_message\\\", {\\n      channel_id: threadId,\\n      text: content,\\n    });\\n    return ravenMessageToDM(msg);\\n  } catch {\\n    return mockStore.sendDM(threadId, content);\\n  }\\n}\\n\\nexport function sendDM(threadId: string, content: string): FGDMMessage | null {\\n  return mockStore.sendDM(threadId, content);\\n}\\n\\nexport function markThreadRead(threadId: string) {\\n  mockStore.markThreadRead(threadId);\\n}\\n\\nconst allThreadIds = ref(new Set<string>());\\n\\nexport function getUnreadDMCount(userId = currentUserId): number {\\n  const tids = new Set(mockStore.getDMThreadsForUser(userId).map((t) => t.id));\\n  if (tids.size === 0) return 0;\\n  allThreadIds.value = tids;\\n  let count = 0;\\n  for (const m of allDmMessages()) {\\n    if (m.sender !== userId && !m.read_by.includes(userId) && tids.has(m.channel)) {\\n      count++;\\n    }\\n  }\\n  return count;\\n}\\n\\nfunction allDmMessages(): FGDMMessage[] {\\n  const seen = new Set<string>();\\n  const all: FGDMMessage[] = [];\\n  for (const t of mockStore.getDMThreadsForUser()) {\\n    for (const m of mockStore.getDMMessages(t.id)) {\\n      if (!seen.has(m.id)) {\\n        seen.add(m.id);\\n        all.push(m);\\n      }\\n    }\\n  }\\n  return all;\\n}\\n\\n// \\u2500\\u2500\\u2500 Notifications \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n\\nexport const getNotifications = (userId = currentUserId): FGNotification[] =>\\n  mockStore.getNotifications(userId);\\nexport const getUnreadNotificationCount = (userId = currentUserId) =>\\n  mockStore.getUnreadNotificationCount(userId);\\n\\n// ===================== Mutators (with real API calls) =====================\\n\\nexport async function createDiscussion(input: {\\n  project: string;\\n  title: string;\\n  content: string;\\n}): Promise<GPDiscussion> {\\n  if (useRealApi()) {\\n    const result = await api.resource.insert<{ name: string }>(\\\"GP Discussion\\\", {\\n      project: input.project,\\n      title: input.title,\\n      content: input.content,\\n    });\\n    invalidateCache();\\n    return mockStore.getDiscussion(result.name) ?? mockStore.createDiscussion(input);\\n  }\\n  return mockStore.createDiscussion(input);\\n}\\n\\nexport async function createComment(input: {\\n  discussion_id: string;\\n  content: string;\\n}): Promise<GPComment> {\\n  if (useRealApi()) {\\n    await api.resource.insert(\\\"GP Comment\\\", {\\n      reference_doctype: \\\"GP Discussion\\\",\\n      reference_name: input.discussion_id,\\n      content: input.content,\\n    });\\n    invalidateCache();\\n  }\\n  return mockStore.createComment(input);\\n}\\n\\nexport function toggleReaction(ref: \\\"GP Discussion\\\" | \\\"GP Comment\\\", id: string, emoji: string) {\\n  if (useRealApi()) {\\n    api.resource\\n      .call(\\\"fg_companion.api.toggle_reaction\\\", {\\n        reference_doctype: ref,\\n        reference_name: id,\\n        emoji,\\n      })\\n      .catch(() => {});\\n  }\\n  mockStore.toggleReaction(ref, id, emoji);\\n}\\n\\nexport async function setRSVP(eventId: string, status: RSVPStatus) {\\n  if (useRealApi()) {\\n    await api.resource.call(\\\"fg_companion.api.rsvp\\\", { event: eventId, rsvp_status: status });\\n    invalidateCache(\\\"fg_events\\\");\\n  }\\n  mockStore.setRSVP(eventId, status);\\n}\\n\\nexport function createEvent(input: {\\n  title: string;\\n  description: string;\\n  starts_on: string;\\n  event_type: string;\\n}) {\\n  return mockStore.createEvent(input);\\n}\\nexport const getMyRSVP = (eventId: string): RSVPStatus | null => mockStore.getMyRSVP(eventId);\\n\\nexport async function requestMentor(mentorId: string, notes: string): Promise<FGMentorMatch> {\\n  if (useRealApi()) {\\n    await api.resource.insert(\\\"FG Mentor Match\\\", {\\n      mentee: currentUserId,\\n      mentor: mentorId,\\n      status: \\\"Requested\\\",\\n      match_notes: notes,\\n    });\\n    invalidateCache();\\n  }\\n  return mockStore.requestMentor(mentorId, notes);\\n}\\n\\n// \\u2500\\u2500\\u2500 LMS mutators \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n\\nexport function createCourse(input: {\\n  title: string;\\n  short_introduction: string;\\n  description: string;\\n  category: string;\\n  tags: string;\\n}): LMSCourse {\\n  return mockStore.createCourse(input);\\n}\\nexport function addChapter(courseId: string, title: string): LMSChapter {\\n  return mockStore.addChapter(courseId, title);\\n}\\nexport function addLesson(input: {\\n  course: string;\\n  chapter: string;\\n  title: string;\\n  body: string;\\n  youtube_video: string;\\n}): LMSLesson {\\n  return mockStore.addLesson(input);\\n}\\nexport function enrollInCourse(courseId: string) {\\n  mockStore.enrollInCourse(courseId);\\n}\\nexport function markLessonComplete(lessonId: string, complete: boolean) {\\n  mockStore.markLessonComplete(lessonId, complete);\\n}\\nexport function extractYouTubeId(input: string): string {\\n  return mockStore.extractYouTubeId(input);\\n}\\n\\n// \\u2500\\u2500\\u2500 User settings mutators \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n\\nexport function updateUserSettings(patch: Partial<FGUserSettings>) {\\n  mockStore.updateUserSettings(patch);\\n}\\nexport function updateProfile(patch: Partial<GPUserProfile>) {\\n  mockStore.updateProfile(patch);\\n}\\n\\n// \\u2500\\u2500\\u2500 SSO \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n\\nexport const getSSOProviders = (): FGSSOProvider[] => mockStore.getSSOProviders();\\nexport function updateSSOProvider(id: SSOProviderId, patch: Partial<FGSSOProvider>) {\\n  mockStore.updateSSOProvider(id, patch);\\n}\\n\\n// \\u2500\\u2500\\u2500 Polls \\u2500\\u2500\\u250