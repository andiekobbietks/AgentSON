      "output": "import { createApp } from \"vue\";\nimport { createRouter, createWebHistory } from \"vue-router\";\nimport App from \"./App.vue\";\nimport \"./styles.css\";\n\n// Route components (lazy-loaded for production performance)\nconst HomeView = () => import(\"./views/HomeView.vue\");\nconst EventsView = () => import(\"./views/EventsView.vue\");\nconst MembersView = () => import(\"./views/MembersView.vue\");\nconst MemberDetailView = () => import(\"./views/MemberDetailView.vue\");\nconst CoursesView = () => import(\"./views/CoursesView.vue\");\nconst CourseDetailView = () => import(\"./views/CourseDetailView.vue\");\nconst CourseNewView = () => import(\"./views/CourseNewView.vue\");\nconst LessonView = () => import(\"./views/LessonView.vue\");\nconst MentorsView = () => import(\"./views/MentorsView.vue\");\nconst MessagesView = () => import(\"./views/MessagesView.vue\");\nconst ThreadView = () => import(\"./views/ThreadView.vue\");\nconst NotificationsView = () => import(\"./views/NotificationsView.vue\");\nconst PostDetailView = () => import(\"./views/PostDetailView.vue\");\nconst SpaceView = () => import(\"./views/SpaceView.vue\");\nconst SettingsView = () => import(\"./views/SettingsView.vue\");\nconst DocsView = () => import(\"./views/DocsView.vue\");\n\nconst router = createRouter({\n  history: createWebHistory(\"/portal/\"),\n  routes: [\n    { path: \"/\", component: HomeView },\n    { path: \"/events\", component: EventsView },\n    { path: \"/members\", component: MembersView },\n    { path: \"/members/:userId\", component: MemberDetailView },\n    { path: \"/courses\", component: CoursesView },\n    { path: \"/courses/new\", component: CourseNewView },\n    { path: \"/courses/:courseId\", component: CourseDetailView },\n    { path: \"/courses/:courseId/lessons/:lessonId\", component: LessonView },\n    { path: \"/mentors\", component: MentorsView },\n    {\n      path: \"/messages\",\n      component: MessagesView,\n      children: [{ path: \":threadId\", component: ThreadView }],\n    },\n    { path: \"/notifications\", component: NotificationsView },\n    { path: \"/posts/:postId\", component: PostDetailView },\n    { path: \"/spaces/:spaceId\", component: SpaceView },\n    { path: \"/settings\", component: SettingsView },\n    { path: \"/docs\", component: DocsView },\n  ],\n});\n\nconst app = createApp(App);\napp.use(router);\napp.mount(\"#app\");\n",
