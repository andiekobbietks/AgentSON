    {
      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"wsl -d Ubuntu -- bash -c \\\"cat /home/andiekobbie/my-bench/apps/fg_companion/frontend/src/components/PostCard.vue /home/andiekobbie/my-bench/apps/fg_companion/frontend/src/components/NewPostModal.vue /home/andiekobbie/my-bench/apps/fg_companion/frontend/src/components/AppAvatar.vue\\\"\", \"description\": \"Read PostCard NewPostModal AppAvatar\"}",
      "output": "<template>\n  <RouterLink\n    :to=\"`/posts/${post.id}`\"\n    class=\"group block rounded-xl bg-card border border-border p-5 transition-all hover:border-border-strong hover:shadow-md\"\n  >\n    <div class=\"flex items-start gap-3\">\n      <AppAvatar :user-id=\"post.author_id\" :size=\"36\" />\n      <div class=\"flex-1 min-w-0\">\n        <div\n          class=\"flex items-center gap-1.5 flex-wrap text-[12px] text-muted-foreground leading-tight\"\n        >\n          <span class=\"font-semibold text-foreground text-[13px]\">{{ author?.full_name }}</span>\n          <template v-if=\"showSpace && project\">\n            <span aria-hidden>·</span>\n            <span\n              >in\n              <span class=\"text-foreground/80\">{{ project.icon }} {{ project.title }}</span></span\n            >\n          </template>\n          <span aria-hidden>·</span>\n          <span>{{ timeAgo(post.created_at) }}</span>\n          <span\n            v-if=\"post.pinned_at\"\n            class=\"inline-flex items-center gap-1 text-primary-soft-foreground ml-1\"\n            >📌 Pinned</span\n          >\n          <SentimentBadge v-if=\"sent\" :sentiment=\"sent\" />\n        </div>\n\n        <h3 class=\"mt-1.5 text-[16px] font-semibold leading-snug text-foreground\">\n          {{ post.title }}\n        </h3>\n        <div\n          class=\"mt-1 text-[14px] leading-relaxed text-secondary-foreground line-clamp-2\"\n          v-html=\"post.content\"\n        />\n\n        <div\n          class=\"mt-3 pt-3 border-t border-border/70 flex items-center gap-5 text-[12px] text-muted-foreground\"\n        >\n          <span class=\"inline-flex items-center gap-1.5\">❤ {{ reactionCount }}</span>\n          <span class=\"inline-flex items-center gap-1.5\"\n            >💬 {{ post.comments_count }}\n            {{ post.comments_count === 1 ? \"comment\" : \"comments\" }}</span\n          >\n          <span v-if=\"poll\" class=\"inline-flex items-center gap-1.5\">📊 Poll</span>\n          <span v-if=\"reactionCount > 0\" class=\"text-[14px] leading-none\">{{ topEmojis }}</span>\n        </div>\n        <PollCard v-if=\"poll\" :poll=\"poll\" />\n      </div>\n    </div>\n  </RouterLink>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from \"vue\";\nimport { RouterLink } from \"vue-router\";\nimport type { GPDiscussion } from \"@/mock-data/types\";\nimport {\n  getProject,\n  getUser,\n  mockSentiment,\n  getAISettings,\n  getReactionsFor,\n  getPollForDiscussion,\n} from \"@/data/store\";\nimport AppAvatar from \"./AppAvatar.vue\";\nimport SentimentBadge from \"./SentimentBadge.vue\";\nimport PollCard from \"./PollCard.vue\";\n\nconst props = defineProps<{\n  post: GPDiscussion;\n  showSpace?: boolean;\n}>();\n\nconst project = computed(() => getProject(props.post.project));\nconst author = computed(() => getUser(props.post.author_id));\nconst ai = getAISettings();\nconst sent = computed(() => (ai.enable_sentiment ? mockSentiment(props.post.content) : null));\nconst poll = computed(() => getPollForDiscussion(props.post.id));\nconst reactions = computed(() => getReactionsFor(\"GP Discussion\", props.post.id));\nconst reactionCount = computed(() => reactions.value.length);\nconst topEmojis = computed(() =>\n  [...new Set(reactions.value.map((r) => r.emoji))].slice(0, 3).join(\" \"),\n);\n\nfunction timeAgo(iso: string) {\n  const diff = Date.now() - new Date(iso).getTime();\n  const mins = Math.floor(diff / 60000);\n  if (mins < 1) return \"just now\";\n  if (mins < 60) return `${mins}m`;\n  const hrs = Math.floor(mins / 60);\n  if (hrs < 24) return `${hrs}h`;\n  return `${Math.floor(hrs / 24)}d`;\n}\n</script>\n<template>\n  <Teleport to=\"body\">\n    <div\n      v-if=\"open\"\n      class=\"fixed inset-0 z-50 bg-foreground/30 flex items-start justify-center pt-[10vh] px-4\"\n      @click=\"emit('close')\"\n    >\n      <div\n        class=\"w-full max-w-[680px] bg-card rounded-2xl shadow-2xl overflow-hidden flex flex-col\"\n        @click.stop\n      >\n        <header class=\"flex items-center justify-between px-6 py-4 border-b border-border\">\n          <h2 class=\"text-[16px] font-semibold\">New post</h2>\n          <button\n            class=\"size-8 rounded-md flex items-center justify-center text-muted-foreground hover:bg-secondary\"\n            aria-label=\"Close\"\n            @click=\"emit('close')\"\n          >\n            ✕\n          </button>\n        </header>\n\n        <div class=\"px-6 pt-5\">\n          <input\n            v-model=\"title\"\n            placeholder=\"Post title\"\n            autofocus\n            class=\"w-full bg-transparent text-[20px] font-semibold outline-none placeholder:text-muted-foreground/60\"\n          />\n        </div>\n\n        <textarea\n          v-model=\"body\"\n          placeholder=\"Share something kind. Ask a question. It's safe here.\"\n          :rows=\"8\"\n          class=\"px-6 pt-3 pb-4 w-full bg-transparent text-[15px] leading-relaxed outline-none resize-none placeholder:text-muted-foreground/60\"\n        />\n\n        <div\n          class=\"px-3 h-9 border-t border-border bg-background flex items-center gap-0.5 text-muted-foreground\"\n        >\n          <button\n            v-for=\"sym in ['B', 'I', '🔗', '🖼']\"\n            :key=\"sym\"\n            type=\"button\"\n            class=\"size-7 rounded-md flex items-center justify-center hover:bg-secondary hover:text-foreground text-[11px] font-bold\"\n          >\n            {{ sym }}\n          </button>\n        </div>\n\n        <footer class=\"px-6 py-3 border-t border-border flex items-center gap-3\">\n          <label class=\"text-[12px] text-muted-foreground\">Space</label>\n          <select\n            v-model=\"spaceId\"\n            class=\"h-8 px-2 rounded-md border border-border bg-background text-[13px] outline-none focus:border-primary\"\n          >\n            <option v-for=\"p in projects\" :key=\"p.id\" :value=\"p.id\">\n              {{ p.icon }} {{ p.title }}\n            </option>\n          </select>\n          <div class=\"ml-auto flex items-center gap-2\">\n            <button\n              class=\"h-8 px-3 rounded-full text-[13px] font-semibold text-muted-foreground hover:bg-secondary\"\n              @click=\"emit('close')\"\n            >\n              Cancel\n            </button>\n            <button\n              :disabled=\"!title.trim() || !body.trim()\"\n              class=\"h-8 px-5 rounded-full text-[13px] font-semibold bg-primary text-primary-foreground hover:opacity-90 disabled:opacity-40\"\n              @click=\"submit\"\n            >\n              Publish\n            </button>\n          </div>\n        </footer>\n      </div>\n    </div>\n  </Teleport>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, watch } from \"vue\";\nimport { useRouter } from \"vue-router\";\nimport { createDiscussion, getProjects } from \"@/data/store\";\n\nconst props = defineProps<{\n  open: boolean;\n  defaultSpaceId?: string;\n}>();\nconst emit = defineEmits<{ close: [] }>();\n\nconst router = useRouter();\nconst projects = getProjects();\nconst title = ref(\"\");\nconst body = ref(\"\");\nconst spaceId = ref(props.defaultSpaceId ?? projects[0]?.id);\n\nwatch(\n  () => props.open,\n  (v) => {\n    if (v) {\n      title.value = \"\";\n      body.value = \"\";\n      spaceId.value = props.defaultSpaceId ?? projects[0]?.id;\n    }\n  },\n);\n\nfunction onKey(e: KeyboardEvent) {\n  if (e.key === \"Escape\") emit(\"close\");\n}\n\nwatch(\n  () => props.open,\n  (v) => {\n    if (v) document.addEventListener(\"keydown\", onKey);\n    else document.removeEventListener(\"keydown\", onKey);\n  },\n);\n\nfunction submit() {\n  if (!title.value.trim() || !body.value.trim() || !spaceId.value) return;\n  const d = createDiscussion({\n    project: spaceId.value,\n    title: title.value,\n    content: `<p>${body.value.replace(/\\n\\n+/g, \"</p><p>\").replace(/\\n/g, \"<br/>\")}</p>`,\n  });\n  emit(\"close\");\n  router.push(`/posts/${d.id}`);\n}\n</script>\n<template>\n  <span\n    class=\"inline-flex items-center justify-center rounded-full font-semibold text-foreground shrink-0\"\n    :class=\"className\"\n    :style=\"{\n      width: `${size}px`,\n      height: `${size}px`,\n      background: bg,\n      fontSize: `${Math.round(size * 0.42)}px`,\n    }\"\n    :aria-label=\"u?.full_name\"\n  >\n    {{ initial }}\n  </span>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed } from \"vue\";\nimport { getUser } from \"@/data/store\";\n\nconst props = defineProps<{\n  userId: string;\n  size?: number;\n  class?: string;\n}>();\n\nconst size = computed(() => props.size ?? 36);\nconst className = computed(() => props.class ?? \"\");\nconst u = computed(() => getUser(props.userId));\nconst bg = computed(() => u.value?.image_background_color || \"#ede9fe\");\nconst initial = computed(() => (u.value?.full_name || \"?\").charAt(0).toUpperCase());\n</script>\n",
      "status": "success",
      "timestamp": 1781981735093
    },
    {
      "type": "thought",
      "text": "Now let me also check the mock data store and types to understand the full picture of what's mocked vs real.",
      "timestamp": 1781981738847
    },
    {
      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"wsl -d Ubuntu -- bash -c \\\"cat /home/andiekobbie/my-bench/apps/fg_companion/frontend/src/mock-data/types.ts\\\"\", \"description\": \"Read mock data types\"}",
      "output": "// Types intentionally mirror real Frappe DocTypes from frappe/gameplan and\n// frappe/lms. Researched against the live `main` branch .json files — see\n// /docs/01_SCHEMA_MAPPING_TO_FRAPPE.md and /docs/04_FRAPPE_TRANSLATION.md.\n//\n// IMPORTANT NAMING NOTES:\n// - Field names below are snake_case to mirror Frappe exactly.\n// - Where Frappe stores a value via standard meta fields (`name`, `owner`,\n//   `creation`, `modified`), we keep convenience aliases here (`id`,\n//   `author_id`, `created_at`) and document the mapping. This is the ONLY\n//   place those aliases exist — every component reads through them.\n// - Child-table rows in Frappe also carry implicit `parent`, `parenttype`,\n//   `parentfield`, `idx`. We don't model those for the prototype.\n\n// ============================================================\n// frappe/gameplan\n// ============================================================\n\n/** DocType: `GP Team` */\nexport interface GPTeam {\n  id: string;\n  title: string;\n  icon: string;\n  is_private: boolean;\n  archived_at: string | null;\n  archived_by: string | null;\n}\n\n/** DocType: `GP Project` (UI label: \"Space\") */\nexport interface GPProject {\n  id: string;\n  title: string;\n  description: string;\n  status: \"Open\" | \"Completed\";\n  team: string;\n  progress: number;\n  icon: string;\n  readme: string;\n  tasks_count: number;\n  discussions_count: number;\n  archived_at: string | null;\n  archived_by: string | null;\n  is_private: boolean;\n}\n\n/** DocType: `GP Discussion` (UI label: \"Post\") */\nexport interface GPDiscussion {\n  id: string;\n  project: string;\n  team: string;\n  status: string;\n  title: string;\n  slug: string;\n  content: string;\n  last_post_at: string;\n  last_post_type: \"GP Comment\" | \"GP Poll\";\n  last_post: string;\n  last_post_by: string | null;\n  comments_count: number;\n  participants_count: number;\n  closed_at: string | null;\n  closed_by: string | null;\n  pinned_at: string | null;\n  pin_scope: \"Global\" | \"Space\";\n  pinned_by: string | null;\n  author_id: string;\n  created_at: string;\n}\n\n/** DocType: `GP Comment` */\nexport interface GPComment {\n  id: string;\n  content: string;\n  reference_doctype: \"GP Discussion\";\n  reference_name: string;\n  edited_at: string | null;\n  deleted_at: string | null;\n  author_id: string;\n  created_at: string;\n}\n\n/** DocType: `GP Reaction` (istable=1). */\nexport interface GPReaction {\n  id: string;\n  reference_doctype: \"GP Discussion\" | \"GP Comment\";\n  reference_name: string;\n  user: string;\n  emoji: string;\n}\n\n/** DocType: `GP User Profile` */\nexport interface GPUserProfile {\n  user: string;\n  enabled: boolean;\n  full_name: string;\n  bio: string;\n  readme: string;\n  image: string;\n  cover_image: string;\n  image_background_color: string;\n}\n\n// ============================================================\n// frappe/lms — full prototype (mirrors real DocType field names)\n// ============================================================\n\n/** DocType: `LMS Course` */\nexport interface LMSCourse {\n  id: string; // → `name`\n  title: string;\n  short_introduction: string;\n  description: string; // Text Editor — long form\n  image: string;\n  card_gradient:\n    | \"Red\"\n    | \"Blue\"\n    | \"Green\"\n    | \"Amber\"\n    | \"Cyan\"\n    | \"Orange\"\n    | \"Pink\"\n    | \"Purple\"\n    | \"Teal\"\n    | \"Violet\"\n    | \"Yellow\"\n    | \"Gray\";\n  paid_course: boolean;\n  paid_certificate: boolean;\n  featured: boolean;\n  published: boolean;\n  published_on: string;\n  upcoming: boolean;\n  disable_self_learning: boolean;\n  enable_certification: boolean;\n  course_price: number;\n  currency: string;\n  amount_usd: number;\n  category: string;\n  tags: string; // comma separated, matches LMS\n  status: \"In Progress\" | \"Under Review\" | \"Approved\";\n  author: string; // → Link `User` (instructor)\n  instructors: string[]; // Table MultiSelect → Course Instructor\n  enrollments: number; // denormalised for cards\n  lessons: number; // denormalised\n  rating: string;\n  created_at: string;\n}\n\n/** DocType: `LMS Chapter` (parent: LMS Course) */\nexport interface LMSChapter {\n  id: string; // → `name`\n  course: string; // → Link `LMS Course`\n  title: string;\n  description: string;\n  idx: number; // order\n}\n\n/**\n * DocType: `LMS Lesson` (parent: LMS Chapter)\n *\n * In real LMS the body is a Markdown/HTML field with embedded shortcodes\n * like `{{ YouTubeVideo(\"VIDEO_ID\") }}`. For the prototype we surface\n * `youtube_video` as a first-class field — porting is a search/replace\n * to the shortcode form. See /docs/04_FRAPPE_TRANSLATION.md.\n */\nexport interface LMSLesson {\n  id: string; // → `name`\n  chapter: string; // → Link `LMS Chapter`\n  course: string; // → Link `LMS Course` (denormalised)\n  title: string;\n  body: string; // Markdown/HTML\n  youtube_video: string; // 11-char YouTube ID (or \"\")\n  include_in_preview: boolean;\n  idx: number;\n}\n\n/** DocType: `LMS Enrollment` */\nexport interface LMSEnrollment {\n  id: string;\n  member: string; // → Link `User`\n  course: string; // → Link `LMS Course`\n  member_name: string;\n  member_username: string;\n  member_type: \"Student\" | \"Mentor\" | \"Staff\";\n  role: \"Member\" | \"Admin\";\n  progress: number; // 0..100\n  current_lesson: string;\n  enrolled_on: string;\n  payment: string;\n  certificate: string;\n  purchased_certificate: boolean;\n}\n\n/** DocType: `LMS Course Progress` (per-lesson completion) */\nexport interface LMSCourseProgress {\n  id: string;\n  member: string;\n  member_name: string;\n  course: string;\n  chapter: string;\n  lesson: string;\n  status: \"Complete\" | \"Partially Complete\" | \"Incomplete\";\n  is_scorm_chapter: boolean;\n}\n\n/** DocType: `LMS Certificate` */\nexport interface LMSCertificate {\n  id: string;\n  member: string;\n  member_name: string;\n  course: string;\n  course_title: string;\n  issue_date: string;\n  expiry_date: string | null;\n  published: boolean;\n}\n\n// ============================================================\n// fg_companion — NEW custom Frappe app (to be created)\n// ============================================================\n\nexport type EventType =\n  | \"Webinar\"\n  | \"In-Person Meetup\"\n  | \"Workshop\"\n  | \"Drop-in Office Hours\"\n  | \"Networking\";\n\nexport type LocationType = \"Online (BigBlueButton)\" | \"Online (External Link)\" | \"In Person\";\n\n/** DocType (new): `FG Event` */\nexport interface FGEvent {\n  id: string;\n  title: string;\n  description: string;\n  space: string | null;\n  event_type: EventType;\n  starts_on: string;\n  ends_on: string;\n  location_type: LocationType;\n  bbb_meeting_id: string | null;\n  external_link: string | null;\n  physical_address: string | null;\n  rsvp_required: boolean;\n  capacity: number;\n  hosted_by: string;\n}\n\nexport type RSVPStatus = \"Going\" | \"Maybe\" | \"Not Going\" | \"Attended\" | \"No Show\";\n\n/** DocType (new): `FG Event Attendee` */\nexport interface FGEventAttendee {\n  id: string;\n  event: string;\n  user: string;\n  rsvp_status: RSVPStatus;\n}\n\nexport type MentorMatchStatus = \"Requested\" | \"Active\" | \"Completed\" | \"Ended Early\";\n\nexport type MatchedVia = \"Manual\" | \"Self-Requested\" | \"Algorithmic Suggestion\";\n\n/** DocType (new): `FG Mentor Match` */\nexport interface FGMentorMatch {\n  id: string;\n  mentee: string;\n  mentor: string;\n  status: MentorMatchStatus;\n  matched_on: string;\n  matched_via: MatchedVia;\n  match_notes: string;\n}\n\n/** Single DocType (new): `FG AI Settings` */\nexport interface FGAISettings {\n  enable_sentiment: boolean;\n  sentiment_alert_threshold: number;\n  enable_vector_search: boolean;\n}\n\n// ============================================================\n// fg_companion — Polls (mirrors custom fg_poll + fg_poll_vote)\n// ============================================================\n\nexport type PollOption = {\n  text: string;\n  votes: number;\n};\n\nexport interface FGPoll {\n  id: string;\n  discussion: string;\n  question: string;\n  options: PollOption[];\n  created_by: string;\n  created_at: string;\n  is_anonymous: boolean;\n  is_closed: boolean;\n}\n\nexport interface FGPollVote {\n  id: string;\n  poll: string;\n  user: string;\n  option_index: number;\n  created_at: string;\n}\n\n// ============================================================\n// fg_companion — Gamification (EPS + badges)\n// ============================================================\n\nexport interface FGBadge {\n  id: string;\n  name: string;\n  description: string;\n  icon: string;\n  threshold: number;\n}\n\nexport interface FGBadgeAward {\n  id: string;\n  badge: string;\n  user: string;\n  awarded_at: string;\n}\n\nexport interface FGEnergyPoints {\n  user: string;\n  points: number;\n}\n\n/**\n * DocType (new): `FG User Settings`\n *\n * Mirrors the per-user Notification + Privacy panels in Circle.\n * In Frappe these would be a mix of Notification Settings (core) and a\n * small custom DocType for community-specific toggles.\n */\nexport interface FGUserSettings {\n  user: string;\n  email_on_mention: boolean;\n  email_on_reply: boolean;\n  email_weekly_digest: boolean;\n  push_on_dm: boolean;\n  push_on_mention: boolean;\n  show_in_member_directory: boolean;\n  allow_dm_from_anyone: boolean;\n  theme: \"system\" | \"light\" | \"dark\";\n  language: \"en\" | \"es\" | \"fr\";\n  timezone: string;\n}\n\n// — mocked AI output (computed, not stored) —\nexport type SentimentLabel = \"Positive\" | \"Neutral\" | \"Negative\" | \"Needs Attention\";\n\n// ============================================================\n// Raven (frappe/raven)\n// ============================================================\n\n/** DocType (Raven): `Raven Channel` (1:1 DM variant) */\nexport interface FGDMThread {\n  id: string;\n  channel_type: \"DM\" | \"Group\";\n  is_direct_message: boolean;\n  is_thread: boolean;\n  is_self_message: boolean;\n  dm_user_1: string; // → Link `User`\n  dm_user_2: string; // → Link `User`\n  workspace: string;\n  last_message_at: string;\n  last_message_preview: string;\n}\n\n/** DocType (Raven): `Raven Message` */\nexport interface FGDMMessage {\n  id: string;\n  channel: string; // → Link `Raven Channel`\n  sender: string; // → Link `User`\n  text: string; // Long Text (not `content`)\n  message_type: \"Text\" | \"JSON\" | \"HTML\" | \"Markdown\";\n  file: string;\n  image_width: number;\n  image_height: number;\n  content: string; // alias for text in prototype\n  created_at: string;\n  read_by: string[];\n}\n\n/** DocType (Raven): `Raven Channel Member` */\nexport interface FGDMChannelMember {\n  id: string;\n  channel: string; // → Link `Raven Channel`\n  user: string; // → Link `User`\n  last_read_message: string;\n}\n\n// ============================================================\n// frappe/helpdesk — Support / safeguarding\n// ============================================================\n\nexport type HDTicketType = \"Bug\" | \"Feature\" | \"Service\" | \"Incident\";\nexport type HDPriority = \"Low\" | \"Medium\" | \"High\" | \"Urgent\";\nexport type HDTicketStatus = \"Open\" | \"Replied\" | \"Resolved\" | \"Closed\";\n\n/** DocType: `HD Ticket` */\nexport interface HDTicket {\n  id: string;\n  name: string;\n  subject: string;\n  description: string; // Text Editor\n  ticket_type: HDTicketType;\n  priority: HDPriority;\n  status: HDTicketStatus;\n  raised_by: string; // → Link `User`\n  assigned_to: string; // → Link `User` (agent)\n  team: string; // → Link `HD Team`\n  project: string;\n  contact: string;\n  email: string;\n  phone: string;\n  via_customer_portal: boolean;\n  first_responded_on: string | null;\n  resolution_date: string | null;\n  creation: string;\n  modified: string;\n}\n\n/** DocType: `HD Agent` */\nexport interface HDAgent {\n  id: string;\n  user: string; // → Link `User`\n  group: string; // → Link `HD Agent Group`\n  is_current_user: boolean;\n  enabled: boolean;\n}\n\n/** DocType: `HD Team` */\nexport interface HDTeam {\n  id: string;\n  name: string;\n  response_time: number; // in hours\n  incoming_email_account: string;\n}\n\n/** DocType (Frappe core): `Notification Log` */\nexport interface FGNotification {\n  id: string;\n  for_user: string;\n  subject: string;\n  type: \"Mention\" | \"Reply\" | \"DM\" | \"Event\" | \"System\" | \"Mentor\";\n  document_type:\n    | \"GP Discussion\"\n    | \"FG DM Thread\"\n    | \"FG Event\"\n    | \"FG Mentor Match\"\n    | \"HD Ticket\"\n    | \"\";\n  document_name: string;\n  read: boolean;\n  created_at: string;\n}\n\n// — mocked AI output (computed, not stored) —\nexport type SentimentLabel = \"Positive\" | \"Neutral\" | \"Negative\" | \"Needs Attention\";\n\n// ============================================================\n// frappe/erpnext — Energy Points (gamification)\n// ============================================================\n\n/** DocType: `Energy Point Rule` */\nexport interface FGEnergyPointRule {\n  id: string;\n  name: string;\n  reference_doctype: string;\n  fieldname: string;\n  points: number;\n  rule: \"Every Time\" | \"Auto\";\n  apply_once: boolean;\n  disabled: boolean;\n}\n\n/** DocType: `Energy Point Log` */\nexport interface FGEnergyPointLog {\n  id: string;\n  user: string; // → Link `User`\n  type: \"Auto\" | \"Manual\" | \"Revert\";\n  rule: string; // → Link `Energy Point Rule`\n  points: number;\n  reason: string;\n  reference_doctype: string;\n  reference_name: string;\n  created: string;\n}\n\n/** DocType: `Energy Point Request` */\nexport interface FGEnergyPointRequest {\n  id: string;\n  user: string;\n  type: \"Review\" | \"Assign\";\n  points: number;\n  reason: string;\n  status: \"Approved\" | \"Rejected\" | \"Pending\";\n  requested_by: string;\n  reference_doctype: string;\n  reference_name: string;\n}\n\n// ============================================================\n// frappe/payments — Billing / Subscription (Gherkin scenario 5)\n// ============================================================\n\n/** DocType: `Subscription Plan` */\nexport interface FGSubscriptionPlan {\n  id: string;\n  name: string;\n  plan_name: string;\n  price: number;\n  currency: string;\n  billing_interval: \"Daily\" | \"Weekly\" | \"Monthly\" | \"Yearly\";\n  billing_interval_count: number;\n  description: string;\n}\n\n/** DocType: `Subscription Plan Detail` (child of Subscription) */\nexport interface FGSubscriptionPlanDetail {\n  plan: string; // → Link `Subscription Plan`\n  qty: number;\n}\n\n/** DocType: `Subscription` (frappe/payments) */\nexport interface FGSubscription {\n  id: string;\n  name: string;\n  party_type: \"Customer\";\n  party: string; // → Link `Customer`\n  party_name: string;\n  status:\n    | \"Active\"\n    | \"Cancelled\"\n    | \"Past Due Date\"\n    | \"Cancelled\"\n    | \"Unpaid\"\n    | \"Expired\"\n    | \"Trial\"\n    | \"New\"\n    | \"Membership Hold\";\n  start_date: string;\n  end_date: string | null;\n  trial_period_start: string | null;\n  trial_period_end: string | null;\n  current_invoice_start: string;\n  current_invoice_end: string;\n  days_until_due: number;\n  generate_invoice_at:\n    | \"Beginning of the current billing period\"\n    | \"End of the current billing period\"\n    | \"After the current billing period ends\";\n  plans: FGSubscriptionPlanDetail[];\n  sales_invoice: string | null;\n  cost_center: string;\n  company: string;\n}\n\n/** DocType: `Payment Plan` (simplified for prototype) */\nexport interface FGPaymentPlan {\n  id: string;\n  plan_name: string;\n  price: number;\n  currency: string;\n  billing_period: string;\n  description: string;\n  features: string[];\n}\n\n// ============================================================\n// fg_companion — SSO providers (per-workspace)\n// ============================================================\n\nexport type SSOProviderId = \"email\" | \"google\" | \"microsoft\" | \"github\" | \"discord\" | \"apple\";\n\n/**\n * DocType (new): `FG SSO Provider`\n *\n * Port targets:\n *  - Supabase: enable provider in Auth → Providers, then\n *    supabase.auth.signInWithOAuth({ provider: <id> })\n *  - Frappe: `Social Login Key` DocType (one row per provider) plus\n *    the OAuth flow in `frappe.integrations.oauth2`.\n */\nexport interface FGSSOProvider {\n  id: SSOProviderId;\n  label: string;\n  enabled: boolean;\n  client_id_set: boolean;\n  notes: string;\n}\n",
