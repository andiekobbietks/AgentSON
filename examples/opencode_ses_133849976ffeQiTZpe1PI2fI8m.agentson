      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\components\\\\teleprompter\\\\ProsodyVisualizer.tsx\"}",
      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\components\\teleprompter\\ProsodyVisualizer.tsx</path>\n<type>file</type>\n<content>\n1: /**\n2:  * ProsodyVisualizer — Renders Visual Prosody overlays for a token span.\n3:  *\n4:  * Shows pitch contour sparkline, stress badge, vowel compression ratio,\n5:  * and coarticulation bridge arrows between adjacent words. Each tooltip\n6:  * explains the linguistic rule driving the visual.\n7:  */\n8: import type { ProsodyWord } from \"@/lib/teleprompter/prosody\";\n9: \n10: type Props = {\n11:   prosody: ProsodyWord;\n12:   /** Whether this token is the active playhead token. */\n13:   active?: boolean;\n14:   /** Font size for scaling visuals. */\n15:   fontSize?: number;\n16: };\n17: \n18: export function ProsodyVisualizer({ prosody, active = false, fontSize = 52 }: Props) {\n19:   const scale = Math.max(0.4, Math.min(1, fontSize / 52));\n20:   const showDetail = active || scale > 0.7;\n21: \n22:   return (\n23:     <span className=\"relative inline-block\">\n24:       {/* Stress indicator */}\n25:       {prosody.stress && (\n26:         <span\n27:           className={`absolute -top-3 left-1/2 -translate-x-1/2 text-[8px] font-mono font-bold leading-none ${\n28:             prosody.stress === \"primary\"\n29:               ? \"text-primary\"\n30:               : prosody.stress === \"secondary\"\n31:                 ? \"text-primary/50\"\n32:                 : \"text-muted-foreground/30\"\n33:           }`}\n34:           style={{ fontSize: `${8 * scale}px` }}\n35:         >\n36:           {prosody.stress === \"primary\" ? \"●\" : prosody.stress === \"secondary\" ? \"○\" : \"·\"}\n37:         </span>\n38:       )}\n39: \n40:       {/* Pitch contour sparkline (mini SVG) */}\n41:       {prosody.f0 && prosody.f0.onset != null && prosody.f0.offset != null && (\n42:         <span\n43:           className=\"absolute -bottom-2 left-0 right-0 flex justify-center pointer-events-none\"\n44:           style={{ height: `${10 * scale}px` }}\n45:         >\n46:           <PitchSparkline\n47:             onset={prosody.f0.onset}\n48:             nucleus={prosody.f0.nucleus ?? prosody.f0.onset}\n49:             offset={prosody.f0.offset}\n50:             slope={prosody.f0.slope}\n51:             width={40 * scale}\n52:             height={8 * scale}\n53:             active={active}\n54:           />\n55:         </span>\n56:       )}\n57: \n58:       {/* Vowel compression badge */}\n59:       {showDetail && prosody.vowelCompression && (\n60:         <span\n61:           className=\"absolute -bottom-4 left-1/2 -translate-x-1/2 text-[6px] font-mono leading-none whitespace-nowrap\"\n62:           style={{ fontSize: `${6 * scale}px` }}\n63:         >\n64:           <span\n65:             className={`inline-block px-0.5 rounded ${\n66:               prosody.vowelCompression.label === \"full\"\n67:                 ? \"text-green-500\"\n68:                 : prosody.vowelCompression.label === \"compressed\"\n69:                   ? \"text-yellow-500\"\n70:                   : prosody.vowelCompression.label === \"reduced\"\n71:                     ? \"text-orange-500\"\n72:                     : \"text-red-400\"\n73:             }`}\n74:           >\n75:             {prosody.vowelCompression.label === \"schwa\"\n76:               ? \"ə\"\n77:               : `${Math.round(prosody.vowelCompression.ratio * 100)}%`}\n78:           </span>\n79:         </span>\n80:       )}\n81: \n82:       {/* Coarticulation bridge indicator */}\n83:       {showDetail && prosody.coarticulation && (\n84:         <CoarticulationBadge type={prosody.coarticulation.bridgeType} scale={scale} />\n85:       )}\n86:     </span>\n87:   );\n88: }\n89: \n90: function PitchSparkline({\n91:   onset,\n92:   nucleus,\n93:   offset,\n94:   slope,\n95:   width,\n96:   height,\n97:   active,\n98: }: {\n99:   onset: number;\n100:   nucleus: number;\n101:   offset: number;\n102:   slope?: number;\n103:   width: number;\n104:   height: number;\n105:   active?: boolean;\n106: }) {\n107:   // Normalize Hz to 0..1 range (typical English range: 80-300 Hz)\n108:   const minHz = 80;\n109:   const maxHz = 300;\n110:   const norm = (hz: number) =>\n111:     Math.max(0, Math.min(1, (hz - minHz) / (maxHz - minHz)));\n112: \n113:   const y1 = height - norm(onset) * height;\n114:   const y2 = height - norm(nucleus) * height;\n115:   const y3 = height - norm(offset) * height;\n116: \n117:   const mid = width / 2;\n118:   const ctrl1 = width * 0.25;\n119:   const ctrl2 = width * 0.75;\n120: \n121:   const d = `M 0 ${y1} C ${ctrl1} ${y1} ${ctrl1} ${y2} ${mid} ${y2} S ${ctrl2} ${y3} ${width} ${y3}`;\n122: \n123:   const rising = slope != null ? slope > 0 : offset > onset;\n124: \n125:   return (\n126:     <svg width={width} height={height} viewBox={`0 0 ${width} ${height}`}>\n127:       <path\n128:         d={d}\n129:         fill=\"none\"\n130:         stroke={rising ? \"hsl(var(--primary))\" : \"hsl(var(--muted-foreground))\"}\n131:         strokeWidth={1.5}\n132:         opacity={active ? 1 : 0.6}\n133:       />\n134:     </svg>\n135:   );\n136: }\n137: \n138: function CoarticulationBadge({ type, scale }: { type: string; scale: number }) {\n139:   const labels: Record<string, { icon: string; tooltip: string }> = {\n140:     \"linking-r\": { icon: \"→r\", tooltip: \"Linking R: consonant + vowel bridge\" },\n141:     intrusion: { icon: \"↻\", tooltip: \"Intrusion: epenthetic /r/, /j/, or /w/\" },\n142:     elision: { icon: \"⊘\", tooltip: \"Elision: /t/ or /d/ dropped before consonant\" },\n143:     assimilation: { icon: \"≈\", tooltip: \"Assimilation: /n/ → /m/ before bilabial\" },\n144:     \"glottal-stop\": { icon: \"ʔ\", tooltip: \"Glottal stop: /t/ replaced by glottal\" },\n145:     \"flap-t\": { icon: \"ɾ\", tooltip: \"Flap T: /t/ → /ɾ/ between vowels (American)\" },\n146:   };\n147: \n148:   const info = labels[type];\n149:   if (!info) return null;\n150: \n151:   return (\n152:     <span\n153:       className=\"absolute -top-1 -right-1 text-[7px] font-mono text-muted-foreground/60\"\n154:       title={info.tooltip}\n155:       style={{ fontSize: `${7 * scale}px` }}\n156:     >\n157:       {info.icon}\n158:     </span>\n159:   );\n160: }\n\n(End of file - total 160 lines)\n</content>",
