      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\components\\teleprompter\\Coachmark.tsx</path>\n<type>file</type>\n<content>\n1: import { useEffect, useState } from \"react\";\n2: \n3: const KEY = \"prolector.teleprompter.coach.v1\";\n4: \n5: export function Coachmark() {\n6:   const [open, setOpen] = useState(false);\n7:   useEffect(() => {\n8:     try {\n9:       if (!localStorage.getItem(KEY)) setOpen(true);\n10:     } catch {\n11:       /* ignore */\n12:     }\n13:   }, []);\n14:   if (!open) return null;\n15:   const dismiss = () => {\n16:     try {\n17:       localStorage.setItem(KEY, \"1\");\n18:     } catch {\n19:       /* ignore */\n20:     }\n21:     setOpen(false);\n22:   };\n23:   return (\n24:     <div className=\"absolute top-4 right-4 z-30 w-[280px] border border-primary/40 bg-background/95 backdrop-blur p-4 shadow-xl\">\n25:       <div className=\"text-[10px] font-mono uppercase tracking-widest text-primary mb-2\">\n26:         First visit · shortcuts\n27:       </div>\n28:       <ul className=\"space-y-1.5 text-xs font-mono text-foreground\">\n29:         <li><kbd className=\"text-primary\">Space</kbd> · play / pause</li>\n30:         <li><kbd className=\"text-primary\">R</kbd> · reset playhead</li>\n31:         <li><kbd className=\"text-primary\">↑ ↓</kbd> · nudge WPM ±5</li>\n32:         <li><kbd className=\"text-primary\">click</kbd> · scrub to any word</li>\n33:         <li><kbd className=\"text-primary\">shift+click</kbd> · set loop range</li>\n34:         <li><kbd className=\"text-primary\">right-click</kbd> · re-synthesise menu</li>\n35:       </ul>\n36:       <p className=\"text-[11px] text-muted-foreground mt-3 leading-relaxed\">\n37:         Hover any control for an inline tooltip. Toggle <span className=\"text-foreground\">Live</span>{\" \"}\n38:         in the side panel to stream voice.\n39:       </p>\n40:       <button\n41:         onClick={dismiss}\n42:         className=\"mt-3 w-full bg-primary text-primary-foreground py-1.5 text-[11px] font-mono uppercase tracking-widest hover:brightness-110\"\n43:       >\n44:         Got it\n45:       </button>\n46:     </div>\n47:   );\n48: }\n\n(End of file - total 48 lines)\n</content>",
