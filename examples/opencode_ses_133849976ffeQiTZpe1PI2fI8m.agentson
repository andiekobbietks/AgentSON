      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\routeTree.gen.ts</path>\n<type>file</type>\n<content>\n1: /* eslint-disable */\n2: \n3: // @ts-nocheck\n4: \n5: // noinspection JSUnusedGlobalSymbols\n6: \n7: // This file was automatically generated by TanStack Router.\n8: // You should NOT make any changes in this file as it will be overwritten.\n9: // Additionally, you should also exclude this file from your linter and/or formatter to prevent it from being checked or modified.\n10: \n11: import { Route as rootRouteImport } from './routes/__root'\n12: import { Route as TeleprompterRouteImport } from './routes/teleprompter'\n13: import { Route as StudioRouteImport } from './routes/studio'\n14: import { Route as ScoreRouteImport } from './routes/score'\n15: import { Route as GitRouteImport } from './routes/git'\n16: import { Route as AboutRouteImport } from './routes/about'\n17: import { Route as IndexRouteImport } from './routes/index'\n18: \n19: const TeleprompterRoute = TeleprompterRouteImport.update({\n20:   id: '/teleprompter',\n21:   path: '/teleprompter',\n22:   getParentRoute: () => rootRouteImport,\n23: } as any)\n24: const StudioRoute = StudioRouteImport.update({\n25:   id: '/studio',\n26:   path: '/studio',\n27:   getParentRoute: () => rootRouteImport,\n28: } as any)\n29: const ScoreRoute = ScoreRouteImport.update({\n30:   id: '/score',\n31:   path: '/score',\n32:   getParentRoute: () => rootRouteImport,\n33: } as any)\n34: const GitRoute = GitRouteImport.update({\n35:   id: '/git',\n36:   path: '/git',\n37:   getParentRoute: () => rootRouteImport,\n38: } as any)\n39: const AboutRoute = AboutRouteImport.update({\n40:   id: '/about',\n41:   path: '/about',\n42:   getParentRoute: () => rootRouteImport,\n43: } as any)\n44: const IndexRoute = IndexRouteImport.update({\n45:   id: '/',\n46:   path: '/',\n47:   getParentRoute: () => rootRouteImport,\n48: } as any)\n49: \n50: export interface FileRoutesByFullPath {\n51:   '/': typeof IndexRoute\n52:   '/about': typeof AboutRoute\n53:   '/git': typeof GitRoute\n54:   '/score': typeof ScoreRoute\n55:   '/studio': typeof StudioRoute\n56:   '/teleprompter': typeof TeleprompterRoute\n57: }\n58: export interface FileRoutesByTo {\n59:   '/': typeof IndexRoute\n60:   '/about': typeof AboutRoute\n61:   '/git': typeof GitRoute\n62:   '/score': typeof ScoreRoute\n63:   '/studio': typeof StudioRoute\n64:   '/teleprompter': typeof TeleprompterRoute\n65: }\n66: export interface FileRoutesById {\n67:   __root__: typeof rootRouteImport\n68:   '/': typeof IndexRoute\n69:   '/about': typeof AboutRoute\n70:   '/git': typeof GitRoute\n71:   '/score': typeof ScoreRoute\n72:   '/studio': typeof StudioRoute\n73:   '/teleprompter': typeof TeleprompterRoute\n74: }\n75: export interface FileRouteTypes {\n76:   fileRoutesByFullPath: FileRoutesByFullPath\n77:   fullPaths: '/' | '/about' | '/git' | '/score' | '/studio' | '/teleprompter'\n78:   fileRoutesByTo: FileRoutesByTo\n79:   to: '/' | '/about' | '/git' | '/score' | '/studio' | '/teleprompter'\n80:   id:\n81:     | '__root__'\n82:     | '/'\n83:     | '/about'\n84:     | '/git'\n85:     | '/score'\n86:     | '/studio'\n87:     | '/teleprompter'\n88:   fileRoutesById: FileRoutesById\n89: }\n90: export interface RootRouteChildren {\n91:   IndexRoute: typeof IndexRoute\n92:   AboutRoute: typeof AboutRoute\n93:   GitRoute: typeof GitRoute\n94:   ScoreRoute: typeof ScoreRoute\n95:   StudioRoute: typeof StudioRoute\n96:   TeleprompterRoute: typeof TeleprompterRoute\n97: }\n98: \n99: declare module '@tanstack/react-router' {\n100:   interface FileRoutesByPath {\n101:     '/teleprompter': {\n102:       id: '/teleprompter'\n103:       path: '/teleprompter'\n104:       fullPath: '/teleprompter'\n105:       preLoaderRoute: typeof TeleprompterRouteImport\n106:       parentRoute: typeof rootRouteImport\n107:     }\n108:     '/studio': {\n109:       id: '/studio'\n110:       path: '/studio'\n111:       fullPath: '/studio'\n112:       preLoaderRoute: typeof StudioRouteImport\n113:       parentRoute: typeof rootRouteImport\n114:     }\n115:     '/score': {\n116:       id: '/score'\n117:       path: '/score'\n118:       fullPath: '/score'\n119:       preLoaderRoute: typeof ScoreRouteImport\n120:       parentRoute: typeof rootRouteImport\n121:     }\n122:     '/git': {\n123:       id: '/git'\n124:       path: '/git'\n125:       fullPath: '/git'\n126:       preLoaderRoute: typeof GitRouteImport\n127:       parentRoute: typeof rootRouteImport\n128:     }\n129:     '/about': {\n130:       id: '/about'\n131:       path: '/about'\n132:       fullPath: '/about'\n133:       preLoaderRoute: typeof AboutRouteImport\n134:       parentRoute: typeof rootRouteImport\n135:     }\n136:     '/': {\n137:       id: '/'\n138:       path: '/'\n139:       fullPath: '/'\n140:       preLoaderRoute: typeof IndexRouteImport\n141:       parentRoute: typeof rootRouteImport\n142:     }\n143:   }\n144: }\n145: \n146: const rootRouteChildren: RootRouteChildren = {\n147:   IndexRoute: IndexRoute,\n148:   AboutRoute: AboutRoute,\n149:   GitRoute: GitRoute,\n150:   ScoreRoute: ScoreRoute,\n151:   StudioRoute: StudioRoute,\n152:   TeleprompterRoute: TeleprompterRoute,\n153: }\n154: export const routeTree = rootRouteImport\n155:   ._addFileChildren(rootRouteChildren)\n156:   ._addFileTypes<FileRouteTypes>()\n157: \n158: import type { getRouter } from './router.tsx'\n159: import type { startInstance } from './start.ts'\n160: declare module '@tanstack/react-start' {\n161:   interface Register {\n162:     ssr: true\n163:     router: Awaited<ReturnType<typeof getRouter>>\n164:     config: Awaited<ReturnType<typeof startInstance.getOptions>>\n165:   }\n166: }\n\n(End of file - total 166 lines)\n</content>",
