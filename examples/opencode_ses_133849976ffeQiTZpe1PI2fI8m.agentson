      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\styles.css</path>\n<type>file</type>\n<content>\n1: @import \"tailwindcss\" source(none);\n2: @source \"../src\";\n3: @import \"tw-animate-css\";\n4: \n5: @custom-variant dark (&:is(.dark *));\n6: \n7: /*\n8:  * ProLector — Instrument Grade Dark\n9:  * Tokens ported verbatim from the approved design direction:\n10:  *   bg #09090b · fg #fafafa · muted #71717a · primary #f97316 · border #27272a\n11:  */\n12: \n13: @theme inline {\n14:   --radius-sm: calc(var(--radius) - 4px);\n15:   --radius-md: calc(var(--radius) - 2px);\n16:   --radius-lg: var(--radius);\n17:   --radius-xl: calc(var(--radius) + 4px);\n18:   --radius-2xl: calc(var(--radius) + 8px);\n19:   --radius-3xl: calc(var(--radius) + 12px);\n20:   --radius-4xl: calc(var(--radius) + 16px);\n21:   --color-background: var(--background);\n22:   --color-foreground: var(--foreground);\n23:   --color-card: var(--card);\n24:   --color-card-foreground: var(--card-foreground);\n25:   --color-popover: var(--popover);\n26:   --color-popover-foreground: var(--popover-foreground);\n27:   --color-primary: var(--primary);\n28:   --color-primary-foreground: var(--primary-foreground);\n29:   --color-secondary: var(--secondary);\n30:   --color-secondary-foreground: var(--secondary-foreground);\n31:   --color-muted: var(--muted);\n32:   --color-muted-foreground: var(--muted-foreground);\n33:   --color-accent: var(--accent);\n34:   --color-accent-foreground: var(--accent-foreground);\n35:   --color-destructive: var(--destructive);\n36:   --color-destructive-foreground: var(--destructive-foreground);\n37:   --color-border: var(--border);\n38:   --color-input: var(--input);\n39:   --color-ring: var(--ring);\n40:   --color-ring-offset-background: var(--background);\n41:   --color-chart-1: var(--chart-1);\n42:   --color-chart-2: var(--chart-2);\n43:   --color-chart-3: var(--chart-3);\n44:   --color-chart-4: var(--chart-4);\n45:   --color-chart-5: var(--chart-5);\n46:   --color-sidebar: var(--sidebar);\n47:   --color-sidebar-foreground: var(--sidebar-foreground);\n48:   --color-sidebar-primary: var(--sidebar-primary);\n49:   --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);\n50:   --color-sidebar-accent: var(--sidebar-accent);\n51:   --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);\n52:   --color-sidebar-border: var(--sidebar-border);\n53:   --color-sidebar-ring: var(--sidebar-ring);\n54:   --font-sans: 'Inter', ui-sans-serif, system-ui, sans-serif;\n55:   --font-display: 'Inter Tight', 'Inter', sans-serif;\n56:   --font-mono: 'JetBrains Mono', ui-monospace, monospace;\n57: }\n58: \n59: :root {\n60:   --radius: 0.375rem;\n61:   /* #09090b */\n62:   --background: oklch(0.145 0 0);\n63:   /* #fafafa */\n64:   --foreground: oklch(0.985 0 0);\n65:   /* zinc-900 surface for cards */\n66:   --card: oklch(0.205 0 0);\n67:   --card-foreground: oklch(0.985 0 0);\n68:   --popover: oklch(0.205 0 0);\n69:   --popover-foreground: oklch(0.985 0 0);\n70:   /* primary = #f97316 orange */\n71:   --primary: oklch(0.705 0.213 47.604);\n72:   --primary-foreground: oklch(0.985 0 0);\n73:   --secondary: oklch(0.269 0 0);\n74:   --secondary-foreground: oklch(0.985 0 0);\n75:   /* #71717a */\n76:   --muted: oklch(0.269 0 0);\n77:   --muted-foreground: oklch(0.708 0 0);\n78:   --accent: oklch(0.269 0 0);\n79:   --accent-foreground: oklch(0.985 0 0);\n80:   --destructive: oklch(0.637 0.237 25.331);\n81:   --destructive-foreground: oklch(0.985 0 0);\n82:   /* #27272a */\n83:   --border: oklch(0.269 0 0);\n84:   --input: oklch(0.269 0 0);\n85:   --ring: oklch(0.705 0.213 47.604);\n86:   --chart-1: oklch(0.705 0.213 47.604);\n87:   --chart-2: oklch(0.696 0.17 162.48);\n88:   --chart-3: oklch(0.769 0.188 70.08);\n89:   --chart-4: oklch(0.627 0.265 303.9);\n90:   --chart-5: oklch(0.645 0.246 16.439);\n91:   --sidebar: oklch(0.205 0 0);\n92:   --sidebar-foreground: oklch(0.985 0 0);\n93:   --sidebar-primary: oklch(0.705 0.213 47.604);\n94:   --sidebar-primary-foreground: oklch(0.985 0 0);\n95:   --sidebar-accent: oklch(0.269 0 0);\n96:   --sidebar-accent-foreground: oklch(0.985 0 0);\n97:   --sidebar-border: oklch(0.269 0 0);\n98:   --sidebar-ring: oklch(0.705 0.213 47.604);\n99: }\n100: \n101: /* Dark mirrors root — the app is dark-only. */\n102: .dark { color-scheme: dark; }\n103: \n104: @keyframes fade-up {\n105:   from { opacity: 0; transform: translateY(10px); }\n106:   to { opacity: 1; transform: translateY(0); }\n107: }\n108: @keyframes prompt-scroll {\n109:   0% { transform: translateY(0); }\n110:   100% { transform: translateY(-50%); }\n111: }\n112: .animate-fade-up { animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }\n113: .animate-scroll { animation: prompt-scroll 20s linear infinite; }\n114: \n115: @layer base {\n116:   * {\n117:     border-color: var(--color-border);\n118:   }\n119: \n120:   body {\n121:     background-color: var(--color-background);\n122:     color: var(--color-foreground);\n123:     font-family: var(--font-sans);\n124:     font-feature-settings: \"ss01\", \"cv11\";\n125:   }\n126:   html { color-scheme: dark; }\n127: }\n\n(End of file - total 127 lines)\n</content>",
