      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\components\\SiteFooter.tsx</path>\n<type>file</type>\n<content>\n1: import { Link } from \"@tanstack/react-router\";\n2: \n3: export function SiteFooter() {\n4:   return (\n5:     <footer className=\"border-t border-border pt-16 pb-8 px-6\">\n6:       <div className=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between gap-12\">\n7:         <div className=\"max-w-md\">\n8:           <span className=\"font-display font-bold tracking-tighter text-xl uppercase italic mb-6 block text-foreground\">\n9:             ProLector\n10:           </span>\n11:           <p className=\"text-sm text-muted-foreground leading-relaxed mb-6\">\n12:             Derived from the Latin <em className=\"text-foreground not-italic font-medium\">lector</em>{\" \"}\n13:             (one who reads), ProLector was forged in the demanding ADR environments of corporate\n14:             training. Our journey from a simple mirror script to a full non-destructive workstation\n15:             is driven by local-first engineering principles.\n16:           </p>\n17:           <Link\n18:             to=\"/about\"\n19:             className=\"text-xs font-bold uppercase tracking-widest text-primary hover:underline underline-offset-4\"\n20:           >\n21:             Our ADR Journey →\n22:           </Link>\n23:         </div>\n24:         <div className=\"grid grid-cols-2 gap-12 text-xs font-mono uppercase tracking-widest\">\n25:           <div className=\"flex flex-col gap-4\">\n26:             <span className=\"text-muted-foreground\">System</span>\n27:             <Link to=\"/teleprompter\" className=\"hover:text-primary transition-colors\">\n28:               Teleprompter\n29:             </Link>\n30:             <Link to=\"/studio\" className=\"hover:text-primary transition-colors\">\n31:               Studio\n32:             </Link>\n33:             <Link to=\"/git\" className=\"hover:text-primary transition-colors\">\n34:               Git-for-Video\n35:             </Link>\n36:           </div>\n37:           <div className=\"flex flex-col gap-4\">\n38:             <span className=\"text-muted-foreground\">Architect</span>\n39:             <Link to=\"/about\" className=\"hover:text-primary transition-colors\">\n40:               Genesis\n41:             </Link>\n42:             <a href=\"#\" className=\"hover:text-primary transition-colors\">\n43:               License\n44:             </a>\n45:             <a href=\"#\" className=\"hover:text-primary transition-colors\">\n46:               Security\n47:             </a>\n48:           </div>\n49:         </div>\n50:       </div>\n51:       <div className=\"max-w-7xl mx-auto border-t border-border/50 mt-16 pt-8 text-center text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">\n52:         © 2026 ProLector Logic. Precision Built. No Cloud Required.\n53:       </div>\n54:     </footer>\n55:   );\n56: }\n\n(End of file - total 56 lines)\n</content>",
