      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\lib\\teleprompter\\prosody.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * Prosody data model for Visual Prosody overlays.\n3:  *\n4:  * Coarticulation bridges, pitch contours, and vowel compression markers\n5:  * are computed from TTS engine internals (ChatTTS break tokens, F5-TTS\n6:  * alignment data) or estimated heuristically from word properties.\n7:  */\n8: \n9: export type CoarticulationType =\n10:   | \"linking-r\"      // \"far_away\" → \"far_raid\"\n11:   | \"intrusion\"      // \"law_oder\" → \"law_dorder\"\n12:   | \"elision\"        // \"next_day\" → \"nex_day\"\n13:   | \"assimilation\"   // \"ten_bikes\" → \"tem_bikes\"\n14:   | \"glottal-stop\"   // \"uh_oh\"\n15:   | \"flap-t\";        // \"water\" → \"wader\" (American)\n16: \n17: export type StressLevel = \"unstressed\" | \"secondary\" | \"primary\";\n18: \n19: export type ProsodyWord = {\n20:   tokenIndex: number;\n21:   f0?: {                    // Pitch contour (fundamental frequency)\n22:     onset?: number;         // Hz at word start\n23:     nucleus?: number;       // Hz at stressed syllable\n24:     offset?: number;        // Hz at word end\n25:     slope?: number;         // Direction: positive = rising, negative = falling\n26:   };\n27:   stress?: StressLevel;\n28:   vowelCompression?: {      // How compressed the vowel is\n29:     ratio: number;          // 0.0 = fully reduced (schwa), 1.0 = full vowel\n30:     label: string;          // \"full\" | \"compressed\" | \"reduced\" | \"schwa\"\n31:   };\n32:   duration?: {\n33:     targetMs: number;\n34:     actualMs?: number;      // From TTS alignment\n35:     compression: number;    // 1.0 = normal, <1.0 = compressed\n36:   };\n37:   coarticulation?: {\n38:     bridgeType: CoarticulationType;\n39:     direction: \"right\" | \"bidirectional\";\n40:     strength: number;       // 0.0 = weak, 1.0 = strong\n41:   };\n42: };\n43: \n44: export type ProsodySentence = {\n45:   sentenceId: string;\n46:   words: ProsodyWord[];\n47:   globalPitchRange?: { min: number; max: number };\n48:   rhythm?: {\n49:     regularity: number;     // 0.0 = arrhythmic, 1.0 = perfectly regular\n50:     beatStrength: number;   // Perceived pulse clarity\n51:   };\n52: };\n53: \n54: /**\n55:  * English coarticulation detection rules.\n56:  * Returns the most likely bridge type between two adjacent words.\n57:  */\n58: export function detectCoarticulation(\n59:   wordA: string,\n60:   wordB: string,\n61: ): ProsodyWord[\"coarticulation\"] {\n62:   const a = wordA.toLowerCase().replace(/[^a-z']$/, \"\");\n63:   const b = wordB.toLowerCase().replace(/[^a-z']$/, \"\");\n64:   if (!a || !b) return undefined;\n65: \n66:   // Linking R: word ends in 'r' or 're', next starts with vowel\n67:   if (/(?:^|[^aeiou])r?e?d?$/.test(a) && /^[aeiou]/.test(b)) {\n68:     return { bridgeType: \"linking-r\", direction: \"right\", strength: 0.8 };\n69:   }\n70: \n71:   // Intrusion: both words end/start with vowels (epenthetic /r/ or /j/ or /w/)\n72:   if (/[aeiou]$/.test(a) && /^[aeiou]/.test(b)) {\n73:     const lastChar = a[a.length - 1];\n74:     const firstChar = b[0];\n75:     if (\"ao\".includes(lastChar) && firstChar === \"a\") {\n76:       return { bridgeType: \"intrusion\", direction: \"bidirectional\", strength: 0.6 };\n77:     }\n78:     return { bridgeType: \"intrusion\", direction: \"bidirectional\", strength: 0.4 };\n79:   }\n80: \n81:   // Elision: /t/ or /d/ at end, consonant at start\n82:   if (/[td]$/.test(a) && /^[bdfghjklmnpqrstvwxyz]/.test(b)) {\n83:     return { bridgeType: \"elision\", direction: \"right\", strength: 0.5 };\n84:   }\n85: \n86:   // Assimilation: /n/ before bilabials → /m/\n87:   if (/n$/.test(a) && /^[bmp]/.test(b)) {\n88:     return { bridgeType: \"assimilation\", direction: \"right\", strength: 0.7 };\n89:   }\n90: \n91:   // Flap T: /t/ between vowels (American English)\n92:   if (/[^aeiou]t[aeiou]$/.test(a) && /^[aeiou]/.test(b)) {\n93:     return { bridgeType: \"flap-t\", direction: \"right\", strength: 0.9 };\n94:   }\n95: \n96:   return undefined;\n97: }\n98: \n99: /**\n100:  * Estimate word stress from syllable count and position.\n101:  * Heuristic: monosyllables are primary, first syllable is primary,\n102:  * last syllable is often secondary.\n103:  */\n104: export function estimateStress(\n105:   word: string,\n106:   position: \"first\" | \"middle\" | \"last\" | \"mono\",\n107: ): StressLevel {\n108:   const syllableCount = estimateSyllableCount(word);\n109:   if (syllableCount === 1) return \"primary\";\n110:   if (position === \"first\") return \"primary\";\n111:   if (position === \"last\") return \"secondary\";\n112:   return \"unstressed\";\n113: }\n114: \n115: /**\n116:  * Rough syllable count from vowel clusters.\n117:  */\n118: export function estimateSyllableCount(word: string): number {\n119:   const w = word.toLowerCase().replace(/[^a-z]/g, \"\");\n120:   if (!w) return 1;\n121:   const vowels = w.match(/[aeiouy]+/g);\n122:   if (!vowels) return 1;\n123:   let count = vowels.length;\n124:   // Silent e: \"make\" → 1 syllable, not 2\n125:   if (w.endsWith(\"e\") && count > 1) count--;\n126:   // \"le\" ending: \"table\" → 2 syllables\n127:   if (w.endsWith(\"le\") && !/[aeiou]le$/.test(w)) count++;\n128:   return Math.max(1, count);\n129: }\n130: \n131: /**\n132:  * Estimate vowel compression ratio based on word properties.\n133:  *\n134:  * Content words (nouns, verbs, adjectives) keep full vowels.\n135:  * Function words (the, a, of, and) get reduced.\n136:  * Stressed syllables stay full; unstressed compress.\n137:  */\n138: export function estimateVowelCompression(\n139:   word: string,\n140:   stressLevel: StressLevel,\n141:   isContentWord: boolean,\n142: ): ProsodyWord[\"vowelCompression\"] {\n143:   let ratio: number;\n144:   if (stressLevel === \"primary\" && isContentWord) {\n145:     ratio = 1.0;\n146:   } else if (stressLevel === \"primary\") {\n147:     ratio = 0.85;\n148:   } else if (stressLevel === \"secondary\") {\n149:     ratio = 0.7;\n150:   } else if (isContentWord) {\n151:     ratio = 0.55;\n152:   } else {\n153:     // Function words collapse to schwa\n154:     ratio = 0.3;\n155:   }\n156: \n157:   const label =\n158:     ratio > 0.85 ? \"full\" :\n159:     ratio > 0.6 ? \"compressed\" :\n160:     ratio > 0.4 ? \"reduced\" :\n161:     \"schwa\";\n162: \n163:   return { ratio, label };\n164: }\n165: \n166: /**\n167:  * Content word detector (simplified POS heuristic).\n168:  */\n169: export function isContentWord(word: string): boolean {\n170:   const funcWords = new Set([\n171:     \"the\", \"a\", \"an\", \"is\", \"are\", \"was\", \"were\", \"be\", \"been\", \"being\",\n172:     \"have\", \"has\", \"had\", \"do\", \"does\", \"did\", \"will\", \"would\", \"shall\",\n173:     \"should\", \"may\", \"might\", \"must\", \"can\", \"could\", \"to\", \"of\", \"in\",\n174:     \"for\", \"on\", \"with\", \"at\", \"by\", \"from\", \"as\", \"into\", \"through\",\n175:     \"during\", \"before\", \"after\", \"above\", \"below\", \"between\", \"out\",\n176:     \"off\", \"over\", \"under\", \"again\", \"further\", \"then\", \"once\", \"and\",\n177:     \"but\", \"or\", \"nor\", \"not\", \"so\", \"yet\", \"both\", \"either\", \"neither\",\n178:     \"each\", \"every\", \"all\", \"any\", \"few\", \"more\", \"most\", \"other\",\n179:     \"some\", \"such\", \"no\", \"only\", \"own\", \"same\", \"than\", \"too\", \"very\",\n180:     \"just\", \"because\", \"if\", \"when\", \"where\", \"how\", \"what\", \"which\",\n181:     \"who\", \"whom\", \"this\", \"that\", \"these\", \"those\", \"it\", \"its\",\n182:     \"he\", \"him\", \"his\", \"she\", \"her\", \"they\", \"them\", \"their\", \"we\",\n183:     \"us\", \"our\", \"you\", \"your\", \"my\", \"me\", \"i\",\n184:   ]);\n185:   return !funcWords.has(word.toLowerCase().replace(/[^a-z']/g, \"\"));\n186: }\n\n(End of file - total 186 lines)\n</content>",
