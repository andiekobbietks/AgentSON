      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\components\\ui\\badge.tsx</path>\n<type>file</type>\n<content>\n1: import * as React from \"react\";\n2: import { cva, type VariantProps } from \"class-variance-authority\";\n3: \n4: import { cn } from \"@/lib/utils\";\n5: \n6: const badgeVariants = cva(\n7:   \"inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2\",\n8:   {\n9:     variants: {\n10:       variant: {\n11:         default: \"border-transparent bg-primary text-primary-foreground shadow hover:bg-primary/80\",\n12:         secondary:\n13:           \"border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80\",\n14:         destructive:\n15:           \"border-transparent bg-destructive text-destructive-foreground shadow hover:bg-destructive/80\",\n16:         outline: \"text-foreground\",\n17:       },\n18:     },\n19:     defaultVariants: {\n20:       variant: \"default\",\n21:     },\n22:   },\n23: );\n24: \n25: export interface BadgeProps\n26:   extends React.HTMLAttributes<HTMLDivElement>, VariantProps<typeof badgeVariants> {}\n27: \n28: function Badge({ className, variant, ...props }: BadgeProps) {\n29:   return <div className={cn(badgeVariants({ variant }), className)} {...props} />;\n30: }\n31: \n32: export { Badge, badgeVariants };\n\n(End of file - total 32 lines)\n</content>",
