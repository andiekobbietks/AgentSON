      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\routes\\index.tsx</path>\n<type>file</type>\n<content>\n1: import { createFileRoute } from \"@tanstack/react-router\";\n2: import { Link } from \"@tanstack/react-router\";\n3: import { SiteNav } from \"@/components/SiteNav\";\n4: import { SiteFooter } from \"@/components/SiteFooter\";\n5: import {\n6:   Collapsible,\n7:   CollapsibleTrigger,\n8:   CollapsibleContent,\n9: } from \"@/components/ui/collapsible\";\n10: \n11: export const Route = createFileRoute(\"/\")({\n12:   head: () => ({\n13:     meta: [\n14:       { title: \"ProLector — The Local-First Pro Workstation\" },\n15:       {\n16:         name: \"description\",\n17:         content:\n18:           \"Instrument-grade teleprompter & non-destructive video editing for professional educators. Local-first, offline-capable, zero-latency.\",\n19:       },\n20:       { property: \"og:title\", content: \"ProLector — Local-First Workstation for Educators\" },\n21:       {\n22:         property: \"og:description\",\n23:         content:\n24:           \"Auditory feedforward training with voice cloning (F5-TTS & Kokoro-82M), non-destructive editing, and broadcast teleprompter. Runs in your browser.\",\n25:       },\n26:     ],\n27:   }),\n28:   component: Index,\n29: });\n30: \n31: const ttsModels = [\n32:   { name: \"F5-TTS\", arch: \"Flow Matching + DiT\", sample: \"3–10 s\", rtf: \"0.15 / 1.20\", license: \"Permissive\", strength: \"Zero pronunciation drift, breath sim\" },\n33:   { name: \"Chatterbox-Turbo\", arch: \"Acoustic Transf. + CFG\", sample: \"5 s\", rtf: \"0.10 / 0.90\", license: \"MIT\", strength: \"Inline paralinguistic tags\" },\n34:   { name: \"Pocket TTS\", arch: \"Quantized Codec\", sample: \"5 s\", rtf: \"0.10 / 0.40\", license: \"Open Source\", strength: \"Mobile + desktop CPU\" },\n35:   { name: \"Fish Speech 1.5\", arch: \"Dual Autoregressive\", sample: \"10–20 s\", rtf: \"0.30 / 2.50\", license: \"AGPL / Comm\", strength: \"Free-form emotion prompting\" },\n36:   { name: \"ChatTTS\", arch: \"Conversational Transf.\", sample: \"—\", rtf: \"0.20 / 1.10\", license: \"Open Source\", strength: \"Conversational ticks, laughter\" },\n37:   { name: \"XTTS v2\", arch: \"GPT-AR + VITS\", sample: \"6 s\", rtf: \"0.50 / 3.20\", license: \"CPML (Non-Comm)\", strength: \"17+ languages\" },\n38:   { name: \"Kokoro-82M\", arch: \"StyleTTS2 + Latent Diff\", sample: \"—\", rtf: \"0.05 / 0.05\", license: \"Apache 2.0\", strength: \"Sub-100ms on CPU, runs in browser\", highlighted: true },\n39: ];\n40: \n41: const pricingTiers = [\n42:   { name: \"Standard\", price: \"$4.20\", audience: \"Individual Educator\", features: [\"Local WebGPU ASR\", \"Kokoro-82M CPU Director\", \"Remotion Player\", \"Local WebM Export\"] },\n43:   { name: \"Plus\", price: \"$9.60\", audience: \"Active Course Creator\", features: [\"Voice Clone Training (F5-TTS)\", \"Oracle 23ai sync\", \"20 GB Object Storage\", \"Multi-scene timeline\"] },\n44:   { name: \"Pro\", price: \"$15.60\", audience: \"Production House\", features: [\"OCI Headless Render Farm\", \"Gemma-4 Multimodal\", \"Gemma-4 Script Refiner\", \"Priority weights\"], highlighted: true },\n45:   { name: \"Select\", price: \"$21.00\", audience: \"Enterprise Academy\", features: [\"Multi-seat repositories\", \"Git-for-Video merges\", \"Custom compliance\", \"SSO + Team Auth\"] },\n46: ];\n47: \n48: function Index() {\n49:   return (\n50:     <div className=\"min-h-screen bg-background text-foreground selection:bg-primary/30\">\n51:       <SiteNav />\n52: \n53:       {/* Hero */}\n54:       <header className=\"pt-24 pb-16 px-6 overflow-hidden\">\n55:         <div className=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\">\n56:           <div className=\"animate-fade-up\">\n57:             <div className=\"inline-flex items-center gap-2 px-2 py-1 rounded border border-primary/20 bg-primary/5 mb-6\">\n58:               <span className=\"size-1.5 rounded-full bg-primary animate-pulse\" />\n59:               <span className=\"text-[10px] font-mono uppercase tracking-tighter text-primary\">\n60:                 v2.0.0-GOLD · Enterprise Stable\n61:               </span>\n62:             </div>\n63:             <h1 className=\"text-5xl md:text-7xl font-display font-bold tracking-tight leading-[0.9] mb-6 text-balance\">\n64:               THE LOCAL-FIRST <br />\n65:               <span className=\"text-muted-foreground\">PRO WORKSTATION.</span>\n66:             </h1>\n67:             <p className=\"text-lg text-muted-foreground max-w-[45ch] mb-10 text-pretty\">\n68:               Train your voice. Polish your delivery. Ship broadcast-grade\n69:               content — all from your browser, nothing leaving your machine.\n70:             </p>\n71:             <div className=\"flex flex-wrap gap-4\">\n72:               <Link\n73:                 to=\"/teleprompter\"\n74:                 className=\"bg-primary text-primary-foreground px-8 py-4 text-sm font-bold uppercase tracking-widest rounded-sm hover:brightness-110 transition-all\"\n75:               >\n76:                 Try Teleprompter →\n77:               </Link>\n78:               <Link\n79:                 to=\"/studio\"\n80:                 className=\"border border-border px-8 py-4 text-sm font-bold uppercase tracking-widest rounded-sm hover:bg-foreground/5 transition-all\"\n81:               >\n82:                 Open Studio\n83:               </Link>\n84:             </div>\n85:           </div>\n86: \n87:           {/* Teleprompter mockup */}\n88:           <div className=\"relative animate-fade-up [animation-delay:200ms]\">\n89:             <div className=\"aspect-video bg-card border border-border rounded-lg overflow-hidden relative shadow-2xl ring-1 ring-foreground/10\">\n90:               <div className=\"absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-card z-10 pointer-events-none\" />\n91:               <div className=\"p-12 font-display text-3xl md:text-4xl font-bold tracking-tight leading-relaxed animate-scroll text-muted-foreground\">\n92:                 Welcome to ProLector. This is the SyllabusMirror engine operating at sub-10ms\n93:                 latency. Your training modules deserve broadcast-grade clarity. Position your eyes\n94:                 on the lens marker for perfect engagement. Welcome to ProLector. This is the\n95:                 SyllabusMirror engine operating at sub-10ms latency. Your training modules deserve\n96:                 broadcast-grade clarity.\n97:               </div>\n98:               <div className=\"absolute top-1/2 left-0 right-0 h-24 -translate-y-1/2 border-y border-primary/30 bg-primary/5 pointer-events-none z-20\" />\n99:               <div className=\"absolute top-4 left-4 flex items-center gap-2 z-30\">\n100:                 <div className=\"size-3 rounded-full bg-destructive/40 border border-destructive animate-pulse\" />\n101:                 <div className=\"text-[10px] font-mono text-destructive uppercase tracking-widest\">\n102:                   REC 00:04:21:09\n103:                 </div>\n104:               </div>\n105:             </div>\n106:           </div>\n107:         </div>\n108:       </header>\n109: \n110:       {/* Voice Training — progressive disclosure */}\n111:       <section className=\"py-24 px-6 border-y border-border bg-foreground/[0.02]\">\n112:         <div className=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-start\">\n113:           <div>\n114:             <span className=\"text-xs font-mono uppercase tracking-[0.3em] text-primary mb-4 block\">\n115:               Auditory Feedforward Training\n116:             </span>\n117:             <h2 className=\"text-3xl md:text-4xl font-display font-bold mb-6 tracking-tight\">\n118:               Hear yourself speak — <br className=\"hidden md:block\" />\n119:               <span className=\"text-muted-foreground\">then hear yourself improved.</span>\n120:             </h2>\n121:             <p className=\"text-muted-foreground mb-6 leading-relaxed\">\n122:               ProLector clones your voice, then plays it back with polished\n123:               prosody — better rhythm, clearer emphasis, natural pace. Your\n124:               brain absorbs the correction faster because it sounds like{\" \"}\n125:               <em>you</em>, not a stranger.\n126:             </p>\n127:             <div className=\"space-y-4 mb-8\">\n128:               {[\n129:                 { label: \"Your voice\", desc: \"Record a short sample. The model learns your timbre, accent, and speech patterns.\" },\n130:                 { label: \"Your voice, perfected\", desc: \"AI adjusts rhythm, stress, and pace while keeping your vocal identity.\" },\n131:                 { label: \"Your brain fills the gap\", desc: \"Hearing your own voice done right is faster than reading a rule or hearing someone else.\" },\n132:               ].map((step, i) => (\n133:                 <div key={step.label} className=\"flex gap-4\">\n134:                   <div className=\"size-8 rounded border border-border grid place-items-center text-xs font-mono text-muted-foreground shrink-0\">\n135:                     {i + 1}\n136:                   </div>\n137:                   <div>\n138:                     <span className=\"text-sm font-semibold\">{step.label}</span>\n139:                     <p className=\"text-xs text-muted-foreground mt-0.5\">{step.desc}</p>\n140:                   </div>\n141:                 </div>\n142:               ))}\n143:             </div>\n144:             <Link\n145:               to=\"/teleprompter\"\n146:               className=\"inline-block bg-primary text-primary-foreground px-6 py-3 text-xs font-bold uppercase tracking-widest hover:brightness-110 transition-all\"\n147:             >\n148:               Try Voice Training →\n149:             </Link>\n150:           </div>\n151: \n152:           {/* Expandable science panel */}\n153:           <div className=\"border border-border rounded-sm bg-background p-8\">\n154:             <Collapsible>\n155:               <CollapsibleTrigger className=\"w-full text-left\">\n156:                 <div className=\"flex items-center justify-between gap-4\">\n157:                   <div>\n158:                     <div className=\"text-[10px] font-mono uppercase tracking-widest text-primary mb-1\">\n159:                       For the curious\n160:                     </div>\n161:                     <div className=\"text-sm font-semibold\">\n162:                       What's the science behind this?\n163:                     </div>\n164:                   </div>\n165:                   <span className=\"text-muted-foreground text-lg\">▾</span>\n166:                 </div>\n167:               </CollapsibleTrigger>\n168:               <CollapsibleContent>\n169:                 <div className=\"mt-6 space-y-5 text-sm text-muted-foreground leading-relaxed border-t border-border pt-6\">\n170:                   <div>\n171:                     <h4 className=\"text-foreground font-semibold mb-1\">Feedforward Self-Modeling</h4>\n172:                     <p>\n173:                       Peter Dowrick's research (1991–2012) showed that hearing a\n174:                       <em> perfected version of your own voice</em> creates a\n175:                       forward-looking mental template — your brain preloads the\n176:                       target pattern before you speak, rather than correcting\n177:                       errors after the fact. This is faster and more durable\n178:                       than traditional feedback loops.\n179:                     </p>\n180:                   </div>\n181:                   <div>\n182:                     <h4 className=\"text-foreground font-semibold mb-1\">The Own-Voice Advantage</h4>\n183:                     <p>\n184:                       Your auditory cortex recognizes your own voice with lower\n185:                       latency than anyone else's. When the model clones your\n186:                       timbre and adjusts the prosody, the correction arrives\n187:                       through a neural pathway that's already wired for fast\n188:                       processing — like getting directions from someone who\n189:                       knows your neighbourhood, not a tourist with a map.\n190:                     </p>\n191:                   </div>\n192:                   <div>\n193:                     <h4 className=\"text-foreground font-semibold mb-1\">Hebbian Myelination</h4>\n194:                     <p>\n195:                       Repeated imitation strengthens the myelin sheath around\n196:                       motor speech pathways. Each loop of the perfected audio\n197:                       tightens the connection between what you hear and what\n198:                       your mouth does. This is the same mechanism behind\n199:                       musical instrument practice — repetition physically\n200:                       insulates the nerve fibres.\n201:                     </p>\n202:                   </div>\n203:                   <div>\n204:                     <h4 className=\"text-foreground font-semibold mb-1\">Dual-Stream Processing</h4>\n205:                     <p>\n206:                       Hickok & Poeppel's model (2007) splits speech processing\n207:                       into a \"what\" path (meaning) and a \"how\" path (motor\n208:                       execution). ProLector's voice clone targets the \"how\"\n209:                       path — you don't need to understand the words, just\n210:                       mirror the sound. This is why shadowing works even with\n211:                       unfamiliar phrases.\n212:                     </p>\n213:                   </div>\n214:                   <p className=\"text-[11px] text-muted-foreground/60 border-t border-border pt-4\">\n215:                     References: Dowrick, P.W. (1991) <em>Practical Guide to\n216:                     Using Video in the Behavioral Sciences</em>; Hickok, G. &\n217:                     Poeppel, D. (2007) \"The cortical organization of speech\n218:                     processing,\" <em>Nature Reviews Neuroscience</em> 8(5),\n219:                     393–402; Lane, H. et al. (2023) \"The ARROW experiment,\"\n220:                     <em>Cognition</em>.\n221:                   </p>\n222:                 </div>\n223:               </CollapsibleContent>\n224:             </Collapsible>\n225:           </div>\n226:         </div>\n227:       </section>\n228: \n229:       {/* TTS comparison */}\n230:       <section className=\"py-24 border-y border-border bg-foreground/[0.02]\">\n231:         <div className=\"max-w-7xl mx-auto px-6\">\n232:           <div className=\"flex flex-wrap items-end justify-between gap-4 mb-12\">\n233:             <h2 className=\"text-xs font-mono uppercase tracking-[0.3em] text-primary\">\n234:               SyllabusMirror · Voice-Clone Engine Catalogue\n235:             </h2>\n236:             <span className=\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground\">\n237:               RTF = Real-Time Factor (GPU / CPU)\n238:             </span>\n239:           </div>\n240:           <div className=\"overflow-x-auto\">\n241:             <table className=\"w-full text-left border-collapse\">\n242:               <thead>\n243:                 <tr className=\"border-b border-border\">\n244:                   <th className=\"py-4 pr-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">Model</th>\n245:                   <th className=\"py-4 pr-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">Architecture</th>\n246:                   <th className=\"py-4 pr-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">Sample</th>\n247:                   <th className=\"py-4 pr-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">RTF</th>\n248:                   <th className=\"py-4 pr-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">License</th>\n249:                   <th className=\"py-4 text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">Core Strength</th>\n250:                 </tr>\n251:               </thead>\n252:               <tbody className=\"font-mono text-sm\">\n253:                 {ttsModels.map((m) => (\n254:                   <tr key={m.name} className=\"border-b border-border/50 hover:bg-foreground/5 transition-colors\">\n255:                     <td className={`py-5 pr-4 font-semibold ${m.highlighted ? \"text-primary\" : \"\"}`}>\n256:                       {m.name}\n257:                       {m.highlighted ? <span className=\"ml-2 text-[9px] uppercase tracking-widest\">Live in /teleprompter</span> : null}\n258:                     </td>\n259:                     <td className=\"py-5 pr-4 text-muted-foreground\">{m.arch}</td>\n260:                     <td className=\"py-5 pr-4 text-muted-foreground\">{m.sample}</td>\n261:                     <td className=\"py-5 pr-4\">{m.rtf}</td>\n262:                     <td className=\"py-5 pr-4 text-muted-foreground\">{m.license}</td>\n263:                     <td className=\"py-5 text-sm font-sans text-foreground/80\">{m.strength}</td>\n264:                   </tr>\n265:                 ))}\n266:               </tbody>\n267:             </table>\n268:           </div>\n269:         </div>\n270:       </section>\n271: \n272:       {/* Remotion EDL */}\n273:       <section className=\"py-32 px-6\">\n274:         <div className=\"max-w-7xl mx-auto\">\n275:           <div className=\"grid lg:grid-cols-12 gap-12 items-center\">\n276:             <div className=\"lg:col-span-5\">\n277:               <span className=\"text-xs font-mono uppercase tracking-[0.3em] text-primary mb-4 block\">\n278:                 ADR-001 · Remotion Kernel\n279:               </span>\n280:               <h3 className=\"text-3xl md:text-4xl font-display font-bold mb-6 tracking-tight\">\n281:                 Non-destructive editing as 2 KB JSON.\n282:               </h3>\n283:               <p className=\"text-muted-foreground mb-8 leading-relaxed\">\n284:                 ProLector represents every cut, split, and overlay as an Edit Decision List stored\n285:                 in Oracle 23ai. The browser queries a 2 KB JSON document — not a 500 MB MP4 —\n286:                 rendering the timeline frame-accurately with{\" \"}\n287:                 <code className=\"font-mono text-foreground\">@remotion/player</code>.\n288:               </p>\n289:               <div className=\"space-y-4 mb-8\">\n290:                 {[\n291:                   \"Offline-First PWA Storage (OPFS)\",\n292:                   \"Zero-Latency UI Thread\",\n293:                   \"Re-mux on export, never re-encode\",\n294:                   \"Frame-locked deterministic preview\",\n295:                 ].map((f, i) => (\n296:                   <div key={f} className=\"flex items-center gap-4\">\n297:                     <div className=\"size-8 rounded border border-border grid place-items-center text-xs font-mono text-muted-foreground\">\n298:                       {String(i + 1).padStart(2, \"0\")}\n299:                     </div>\n300:                     <span className=\"text-sm uppercase tracking-widest\">{f}</span>\n301:                   </div>\n302:                 ))}\n303:               </div>\n304:               <Link\n305:                 to=\"/studio\"\n306:                 className=\"inline-block border border-primary text-primary px-6 py-3 text-xs font-bold uppercase tracking-widest hover:bg-primary hover:text-primary-foreground transition-all\"\n307:               >\n308:                 Open Live Studio Demo →\n309:               </Link>\n310:             </div>\n311:             <div className=\"lg:col-span-7\">\n312:               <div className=\"aspect-[16/10] bg-card border border-border rounded-md shadow-inner p-6 font-mono text-xs leading-relaxed overflow-hidden\">\n313:                 <div className=\"text-muted-foreground mb-3\">// edl.json — 1,847 bytes</div>\n314:                 <pre className=\"text-foreground/90 whitespace-pre-wrap\">{`{\n315:   \"video_id\": \"chapter_01_video_01\",\n316:   \"video_source\": \"oci://raw_take_01.mp4\",\n317:   \"active_audio_timeline\": [\n318:     {\n319:       \"segment\": 1,\n320:       \"source_audio\": \"feedforward_voice_clone.wav\",\n321:       \"start_ms\": 0,\n322:       \"end_ms\": 12400\n323:     },\n324:     {\n325:       \"segment\": 2,\n326:       \"source_audio\": \"feedforward_voice_clone.wav\",\n327:       \"start_ms\": 15100,\n328:       \"end_ms\": 45000\n329:     }\n330:   ]\n331: }`}</pre>\n332:               </div>\n333:             </div>\n334:           </div>\n335:         </div>\n336:       </section>\n337: \n338:       {/* PWA capabilities */}\n339:       <section className=\"py-24 px-6 border-y border-border bg-foreground/[0.02]\">\n340:         <div className=\"max-w-7xl mx-auto\">\n341:           <div className=\"grid md:grid-cols-3 gap-6\">\n342:             {[\n343:               { tag: \"ADR-009\", title: \"Service Worker Offline Routing\", body: \"Intercepts /v1/chat and routes transparently to localhost:8888 Unsloth when offline.\" },\n344:               { tag: \"ADR-010\", title: \"Origin Private File System\", body: \"Raw VideoFrame chunks stream to OPFS via FileSystemWritableFileStream — RAM stays under 64 MB.\" },\n345:               { tag: \"ADR-008\", title: \"PWA over Electron\", body: \"Zero install, zero commission. macOS, Windows, Linux, ChromeOS — installed from a URL.\" },\n346:             ].map((c) => (\n347:               <div key={c.tag} className=\"border border-border p-8 rounded-sm bg-background\">\n348:                 <span className=\"text-[10px] font-mono uppercase tracking-widest text-primary\">{c.tag}</span>\n349:                 <h4 className=\"font-display font-bold text-xl mt-3 mb-3\">{c.title}</h4>\n350:                 <p className=\"text-sm text-muted-foreground leading-relaxed\">{c.body}</p>\n351:               </div>\n352:             ))}\n353:           </div>\n354:         </div>\n355:       </section>\n356: \n357:       {/* Pricing */}\n358:       <section className=\"py-32 px-6\">\n359:         <div className=\"max-w-7xl mx-auto\">\n360:           <div className=\"mb-16 text-center\">\n361:             <span className=\"text-xs font-mono uppercase tracking-[0.3em] text-primary\">SaaS Tiering</span>\n362:             <h2 className=\"text-4xl md:text-5xl font-display font-bold mt-4 mb-4 tracking-tighter\">LICENSING</h2>\n363:             <p className=\"text-muted-foreground font-mono text-xs uppercase tracking-widest\">\n364:               Monthly operating commitment · Local-first hosting structures\n365:             </p>\n366:           </div>\n367:           <div className=\"grid sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n368:             {pricingTiers.map((t) => (\n369:               <div\n370:                 key={t.name}\n371:                 className={`border p-8 rounded-sm relative transition-colors ${\n372:                   t.highlighted\n373:                     ? \"border-2 border-primary bg-primary/5\"\n374:                     : \"border-border hover:border-muted-foreground\"\n375:                 }`}\n376:               >\n377:                 {t.highlighted ? (\n378:                   <div className=\"absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-primary-foreground text-[10px] font-bold px-3 py-1 uppercase tracking-widest\">\n379:                     Recommended\n380:                   </div>\n381:                 ) : null}\n382:                 <h4\n383:                   className={`text-xs font-mono uppercase tracking-widest mb-1 ${\n384:                     t.highlighted ? \"text-primary\" : \"text-muted-foreground\"\n385:                   }`}\n386:                 >\n387:                   {t.name}\n388:                 </h4>\n389:                 <p className=\"text-[10px] font-mono uppercase text-muted-foreground/70 tracking-wider mb-6\">\n390:                   {t.audience}\n391:                 </p>\n392:                 <div className=\"text-4xl font-display font-bold mb-8\">\n393:                   {t.price}\n394:                   <span className=\"text-sm font-mono text-muted-foreground\">/mo</span>\n395:                 </div>\n396:                 <ul className=\"space-y-3 text-xs font-medium text-muted-foreground mb-12\">\n397:                   {t.features.map((f) => (\n398:                     <li key={f} className=\"flex gap-2\">\n399:                       <span className=\"text-primary\">→</span>\n400:                       <span>{f}</span>\n401:                     </li>\n402:                   ))}\n403:                 </ul>\n404:                 <button\n405:                   className={`w-full py-3 text-[10px] font-bold uppercase tracking-widest transition-all ${\n406:                     t.highlighted\n407:                       ? \"bg-primary text-primary-foreground hover:brightness-110\"\n408:                       : \"border border-border hover:bg-foreground/5\"\n409:                   }`}\n410:                 >\n411:                   Select\n412:                 </button>\n413:               </div>\n414:             ))}\n415:           </div>\n416:         </div>\n417:       </section>\n418: \n419:       <SiteFooter />\n420:     </div>\n421:   );\n422: }\n\n(End of file - total 422 lines)\n</content>",
