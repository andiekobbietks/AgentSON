      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\routes\\score.tsx</path>\n<type>file</type>\n<content>\n1: import { createFileRoute, Link } from \"@tanstack/react-router\";\n2: import { useCallback, useEffect, useMemo, useState } from \"react\";\n3: import {\n4:   type Token,\n5:   findTokenAtMs,\n6:   sentencesOf,\n7:   tokenize,\n8:   totalDurationMs,\n9: } from \"@/lib/teleprompter/tokens\";\n10: import {\n11:   detectCoarticulation,\n12:   estimateStress,\n13:   estimateVowelCompression,\n14:   isContentWord,\n15:   type ProsodyWord,\n16: } from \"@/lib/teleprompter/prosody\";\n17: import { PitchContour } from \"@/components/teleprompter/PitchContour\";\n18: import { Tooltip, TooltipContent, TooltipTrigger } from \"@/components/ui/tooltip\";\n19: \n20: export const Route = createFileRoute(\"/score\")({\n21:   head: () => ({\n22:     meta: [\n23:       { title: \"Score View · ProLector\" },\n24:       {\n25:         name: \"description\",\n26:         content:\n27:           \"Pronunciation workbook: continuous pitch contour, stress badges, vowel compression, and coarticulation bridges rendered above your script.\",\n28:       },\n29:     ],\n30:   }),\n31:   component: ScoreView,\n32: });\n33: \n34: const DEFAULT_SCRIPT = `Welcome to ProLector. This is the Score View engine operating at sub-ten-millisecond latency.\n35: \n36: Your training modules deserve broadcast-grade clarity, so position your eyes directly on the lens marker for perfect engagement.\n37: \n38: We deploy Gemma 4 locally. The model parses your text, injects pacing tags, and forwards every clean sentence to the Remotion frame-sequencer. Nothing leaves your machine.\n39: \n40: Press space to play or pause. Use the up and down arrows to nudge the pace. Press R to reset.`;\n41: \n42: const WPM_PRESETS = [\n43:   { label: \"TED Talk\", wpm: 120 },\n44:   { label: \"Tutorial\", wpm: 135 },\n45:   { label: \"BBC News\", wpm: 155 },\n46:   { label: \"Audiobook\", wpm: 150 },\n47:   { label: \"Conversational\", wpm: 145 },\n48: ];\n49: \n50: function ScoreView() {\n51:   const [script, setScript] = useState(DEFAULT_SCRIPT);\n52:   const [wpm, setWpm] = useState(140);\n53:   const [currentMs, setCurrentMs] = useState(0);\n54:   const [playing, setPlaying] = useState(false);\n55:   const [charWidth, setCharWidth] = useState(9);\n56:   const [showAnnotations, setShowAnnotations] = useState(true);\n57: \n58:   const tokens = useMemo(() => tokenize(script, wpm), [script, wpm]);\n59:   const sentences = useMemo(() => sentencesOf(tokens), [tokens]);\n60:   const totalMs = useMemo(() => totalDurationMs(tokens), [tokens]);\n61:   const currentToken = useMemo(() => findTokenAtMs(tokens, currentMs), [tokens, currentMs]);\n62: \n63:   // Prosody computation.\n64:   const prosodyMap = useMemo(() => {\n65:     const map = new Map<string, ProsodyWord>();\n66:     for (let i = 0; i < tokens.length; i++) {\n67:       const t = tokens[i];\n68:       if (t.isBreak) continue;\n69:       const isContent = isContentWord(t.text);\n70:       const position =\n71:         i === 0 || tokens[i - 1]?.isBreak\n72:           ? \"first\"\n73:           : i === tokens.length - 1 || tokens[i + 1]?.isBreak\n74:             ? \"last\"\n75:             : \"middle\";\n76:       let prevToken: Token | undefined;\n77:       for (let j = i - 1; j >= 0; j--) {\n78:         if (!tokens[j].isBreak) {\n79:           prevToken = tokens[j];\n80:           break;\n81:         }\n82:       }\n83:       const stress = estimateStress(t.text, position);\n84:       const vowelComp = estimateVowelCompression(t.text, stress, isContent);\n85:       const coarticulation = prevToken\n86:         ? detectCoarticulation(prevToken.text, t.text)\n87:         : undefined;\n88:       const baseHz = isContent ? 180 : 140;\n89:       const f0 = {\n90:         onset: baseHz + (stress === \"primary\" ? 30 : stress === \"secondary\" ? 10 : -10),\n91:         nucleus: baseHz + (stress === \"primary\" ? 50 : stress === \"secondary\" ? 20 : 0),\n92:         offset: baseHz + (position === \"last\" ? -20 : 5),\n93:         slope: position === \"last\" ? -15 : stress === \"primary\" ? 10 : 0,\n94:       };\n95:       map.set(t.id, { tokenIndex: i, f0, stress, vowelCompression: vowelComp, coarticulation });\n96:     }\n97:     return map;\n98:   }, [tokens]);\n99: \n100:   // Group tokens by sentence.\n101:   const sentenceGroups = useMemo(() => {\n102:     const groups: { id: string; tokens: Token[] }[] = [];\n103:     let cur: { id: string; tokens: Token[] } | null = null;\n104:     for (const t of tokens) {\n105:       if (t.isBreak) {\n106:         if (cur) groups.push(cur);\n107:         cur = null;\n108:         groups.push({ id: t.id, tokens: [t] });\n109:         continue;\n110:       }\n111:       if (!cur || cur.id !== t.sentenceId) {\n112:         if (cur) groups.push(cur);\n113:         cur = { id: t.sentenceId, tokens: [] };\n114:       }\n115:       cur.tokens.push(t);\n116:     }\n117:     if (cur) groups.push(cur);\n118:     return groups;\n119:   }, [tokens]);\n120: \n121:   // Animation loop.\n122:   useEffect(() => {\n123:     if (!playing) return;\n124:     let raf: number;\n125:     let last: number | null = null;\n126:     const tick = (now: number) => {\n127:       const dt = last != null ? now - last : 0;\n128:       last = now;\n129:       setCurrentMs((ms) => {\n130:         const next = ms + dt;\n131:         if (totalMs > 0 && next >= totalMs) {\n132:           setPlaying(false);\n133:           return totalMs;\n134:         }\n135:         return next;\n136:       });\n137:       raf = requestAnimationFrame(tick);\n138:     };\n139:     raf = requestAnimationFrame(tick);\n140:     return () => cancelAnimationFrame(raf);\n141:   }, [playing, totalMs]);\n142: \n143:   // Keyboard shortcuts.\n144:   useEffect(() => {\n145:     const onKey = (e: KeyboardEvent) => {\n146:       const target = e.target as HTMLElement;\n147:       if (target && (target.tagName === \"TEXTAREA\" || target.tagName === \"INPUT\")) return;\n148:       if (e.code === \"Space\") {\n149:         e.preventDefault();\n150:         setPlaying((p) => !p);\n151:       } else if (e.key === \"r\" || e.key === \"R\") {\n152:         setPlaying(false);\n153:         setCurrentMs(0);\n154:       } else if (e.key === \"ArrowUp\") {\n155:         setWpm((w) => Math.min(220, w + 5));\n156:       } else if (e.key === \"ArrowDown\") {\n157:         setWpm((w) => Math.max(80, w - 5));\n158:       }\n159:     };\n160:     window.addEventListener(\"keydown\", onKey);\n161:     return () => window.removeEventListener(\"keydown\", onKey);\n162:   }, []);\n163: \n164:   const wordCount = script.trim().split(/\\s+/).filter(Boolean).length;\n165:   const estDurationSec = wordCount > 0 ? Math.round((wordCount / wpm) * 60) : 0;\n166: \n167:   return (\n168:     <div className=\"min-h-screen bg-background text-foreground flex flex-col\">\n169:       {/* Top bar */}\n170:       <div className=\"border-b border-border bg-background/90 backdrop-blur sticky top-0 z-40\">\n171:         <div className=\"max-w-7xl mx-auto px-6 h-14 flex items-center justify-between gap-4\">\n172:           <div className=\"flex items-center gap-6\">\n173:             <Link\n174:               to=\"/\"\n175:               className=\"font-display font-bold tracking-tighter text-lg uppercase italic\"\n176:             >\n177:               ← ProLector\n178:             </Link>\n179:             <span className=\"text-[10px] font-mono uppercase tracking-widest text-muted-foreground hidden md:inline\">\n180:               Score View · Pronunciation Workbook\n181:             </span>\n182:           </div>\n183:           <div className=\"flex items-center gap-4\">\n184:             <Tooltip>\n185:               <TooltipTrigger asChild>\n186:                 <div className=\"flex items-center gap-2 font-mono text-[11px] uppercase tracking-widest cursor-help\">\n187:                   <span className={`size-2 rounded-full ${playing ? \"bg-destructive animate-pulse\" : \"bg-muted-foreground/40\"}`} />\n188:                   <span className={playing ? \"text-destructive\" : \"text-muted-foreground\"}>\n189:                     {playing ? \"PLAY\" : \"STOP\"}\n190:                   </span>\n191:                 </div>\n192:               </TooltipTrigger>\n193:               <TooltipContent>Playback state</TooltipContent>\n194:             </Tooltip>\n195:           </div>\n196:         </div>\n197:       </div>\n198: \n199:       {/* Controls */}\n200:       <div className=\"border-b border-border px-6 py-3\">\n201:         <div className=\"max-w-7xl mx-auto flex flex-wrap items-center gap-4 text-xs font-mono uppercase tracking-widest\">\n202:           <button\n203:             onClick={() => setPlaying((p) => !p)}\n204:             className=\"bg-primary text-primary-foreground px-5 py-2 font-bold hover:brightness-110 transition-all\"\n205:           >\n206:             {playing ? \"■ Pause\" : \"▶ Play\"}\n207:           </button>\n208:           <button\n209:             onClick={() => { setPlaying(false); setCurrentMs(0); }}\n210:             className=\"border border-border px-4 py-2 hover:bg-foreground/5 transition-all\"\n211:           >\n212:             Reset\n213:           </button>\n214: \n215:           <div className=\"flex items-center gap-2\">\n216:             <label className=\"text-muted-foreground\">WPM</label>\n217:             <input\n218:               type=\"range\"\n219:               min={80}\n220:               max={220}\n221:               value={wpm}\n222:               onChange={(e) => setWpm(Number(e.target.value))}\n223:               className=\"accent-primary\"\n224:             />\n225:             <span className=\"w-10 text-right text-foreground\">{wpm}</span>\n226:           </div>\n227: \n228:           {/* WPM presets */}\n229:           <div className=\"flex items-center gap-1\">\n230:             {WPM_PRESETS.map((p) => (\n231:               <button\n232:                 key={p.label}\n233:                 onClick={() => setWpm(p.wpm)}\n234:                 className={`px-2 py-1 text-[9px] font-mono border transition-colors ${\n235:                   wpm === p.wpm\n236:                     ? \"border-primary text-primary bg-primary/5\"\n237:                     : \"border-border text-muted-foreground hover:border-primary/30\"\n238:                 }`}\n239:               >\n240:                 {p.label}\n241:               </button>\n242:             ))}\n243:           </div>\n244: \n245:           <div className=\"flex items-center gap-2\">\n246:             <label className=\"text-muted-foreground\">Zoom</label>\n247:             <input\n248:               type=\"range\"\n249:               min={6}\n250:               max={14}\n251:               value={charWidth}\n252:               onChange={(e) => setCharWidth(Number(e.target.value))}\n253:               className=\"accent-primary\"\n254:             />\n255:           </div>\n256: \n257:           <label className=\"flex items-center gap-2 cursor-pointer select-none\">\n258:             <input\n259:               type=\"checkbox\"\n260:               checked={showAnnotations}\n261:               onChange={(e) => setShowAnnotations(e.target.checked)}\n262:               className=\"accent-primary\"\n263:             />\n264:             <span>Annotations</span>\n265:           </label>\n266: \n267:           <span className=\"text-muted-foreground\">\n268:             {wordCount} words · ~{Math.floor(estDurationSec / 60)}:\n269:             {String(estDurationSec % 60).padStart(2, \"0\")}\n270:           </span>\n271:         </div>\n272:       </div>\n273: \n274:       {/* Score area */}\n275:       <div className=\"flex-1 overflow-y-auto p-6 md:p-12\">\n276:         <div className=\"max-w-7xl mx-auto space-y-12\">\n277:           {/* Legend */}\n278:           <div className=\"flex flex-wrap items-center gap-6 text-[10px] font-mono text-muted-foreground\">\n279:             <span className=\"flex items-center gap-1.5\">\n280:               <span className=\"text-primary font-bold\">●</span> Primary stress\n281:             </span>\n282:             <span className=\"flex items-center gap-1.5\">\n283:               <span className=\"text-primary/50\">○</span> Secondary stress\n284:             </span>\n285:             <span className=\"flex items-center gap-1.5\">\n286:               <span className=\"text-muted-foreground/30\">·</span> Unstressed\n287:             </span>\n288:             <span className=\"flex items-center gap-1.5\">\n289:               <span className=\"inline-block w-3 h-0.5 bg-green-500 rounded\" /> Full vowel\n290:             </span>\n291:             <span className=\"flex items-center gap-1.5\">\n292:               <span className=\"inline-block w-3 h-0.5 bg-yellow-500 rounded\" /> Compressed\n293:             </span>\n294:             <span className=\"flex items-center gap-1.5\">\n295:               <span className=\"inline-block w-3 h-0.5 bg-orange-500 rounded\" /> Reduced\n296:             </span>\n297:             <span className=\"flex items-center gap-1.5\">\n298:               <span className=\"inline-block w-3 h-0.5 bg-red-500 rounded\" /> Schwa\n299:             </span>\n300:             <span className=\"flex items-center gap-1.5\">\n301:               <span className=\"text-muted-foreground/50\">→r</span> Linking R\n302:             </span>\n303:             <span className=\"flex items-center gap-1.5\">\n304:               <span className=\"text-muted-foreground/50\">↻</span> Intrusion\n305:             </span>\n306:             <span className=\"flex items-center gap-1.5\">\n307:               <span className=\"text-muted-foreground/50\">ɾ</span> Flap T\n308:             </span>\n309:           </div>\n310: \n311:           {/* Sentences */}\n312:           {sentenceGroups.map((group) => {\n313:             if (group.tokens.length === 1 && group.tokens[0].isBreak) {\n314:               return <div key={group.id} className=\"h-8\" />;\n315:             }\n316:             const words = group.tokens.map((t) => ({\n317:               text: t.text,\n318:               id: t.id,\n319:               startMs: t.startMs,\n320:               endMs: t.endMs,\n321:             }));\n322:             return (\n323:               <div key={group.id} className=\"border border-border rounded-sm bg-card p-6\">\n324:                 <PitchContour\n325:                   words={words}\n326:                   prosodyMap={prosodyMap}\n327:                   charWidth={charWidth}\n328:                   showAnnotations={showAnnotations}\n329:                   currentMs={currentMs}\n330:                   onWordClick={(ms) => {\n331:                     setCurrentMs(ms);\n332:                   }}\n333:                 />\n334:               </div>\n335:             );\n336:           })}\n337: \n338:           {/* Footer info */}\n339:           <div className=\"text-center text-[10px] font-mono text-muted-foreground/40 py-8 border-t border-border\">\n340:             Score View · Pitch contour is estimated from word stress and position.\n341:             For production use, extract F0 from TTS engine internals (ChatTTS break tokens, F5-TTS alignment).\n342:           </div>\n343:         </div>\n344:       </div>\n345:     </div>\n346:   );\n347: }\n\n(End of file - total 347 lines)\n</content>",
