      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\components\\teleprompter\\TranscriptEditor.tsx</path>\n<type>file</type>\n<content>\n1: import { useEffect, useMemo, useRef, useState } from \"react\";\n2: import type { Token } from \"@/lib/teleprompter/tokens\";\n3: import type { EngineId } from \"@/lib/teleprompter/syllabus-mirror\";\n4: import {\n5:   ContextMenu,\n6:   ContextMenuContent,\n7:   ContextMenuItem,\n8:   ContextMenuSeparator,\n9:   ContextMenuTrigger,\n10: } from \"@/components/ui/context-menu\";\n11: import { Tooltip, TooltipContent, TooltipTrigger } from \"@/components/ui/tooltip\";\n12: \n13: type Props = {\n14:   tokens: Token[];\n15:   currentTokenId: string | null;\n16:   totalMs: number;\n17:   currentMs: number;\n18:   loopRange: { startMs: number; endMs: number } | null;\n19:   loopArmed: boolean;\n20:   onScrubToToken: (token: Token) => void;\n21:   onTokenShiftClick: (token: Token) => void;\n22:   onToggleLoop: () => void;\n23:   onClearLoop: () => void;\n24:   onScriptChange: (script: string) => void;\n25:   onScrubMs: (ms: number) => void;\n26:   onResynth: (sentenceId: string, engine: EngineId) => void;\n27: };\n28: \n29: /** Right-side transcript editor: edit mode (raw textarea) + scrub mode\n30:  *  (clickable word tokens) + a thin SVG scrubber strip. */\n31: export function TranscriptEditor({\n32:   tokens,\n33:   currentTokenId,\n34:   totalMs,\n35:   currentMs,\n36:   loopRange,\n37:   loopArmed,\n38:   onScrubToToken,\n39:   onTokenShiftClick,\n40:   onToggleLoop,\n41:   onClearLoop,\n42:   onScriptChange,\n43:   onScrubMs,\n44:   onResynth,\n45: }: Props) {\n46:   const [mode, setMode] = useState<\"scrub\" | \"edit\">(\"scrub\");\n47: \n48:   const script = useMemo(\n49:     () =>\n50:       tokens\n51:         .map((t) => (t.isBreak ? \"\\n\\n\" : t.text))\n52:         .join(\" \")\n53:         .replace(/ \\n\\n /g, \"\\n\\n\"),\n54:     [tokens],\n55:   );\n56: \n57:   // contentEditable ref + commit-on-blur\n58:   const editRef = useRef<HTMLDivElement | null>(null);\n59:   useEffect(() => {\n60:     if (mode === \"edit\" && editRef.current) {\n61:       editRef.current.innerText = script;\n62:     }\n63:     // eslint-disable-next-line react-hooks/exhaustive-deps\n64:   }, [mode]);\n65: \n66:   // Group tokens into sentences for context-menu wrapping in Scrub mode.\n67:   const sentenceGroups: { id: string; tokens: Token[] }[] = useMemo(() => {\n68:     const groups: { id: string; tokens: Token[] }[] = [];\n69:     let cur: { id: string; tokens: Token[] } | null = null;\n70:     for (const t of tokens) {\n71:       if (t.isBreak) {\n72:         if (cur) groups.push(cur);\n73:         cur = null;\n74:         groups.push({ id: t.id, tokens: [t] });\n75:         continue;\n76:       }\n77:       if (!cur || cur.id !== t.sentenceId) {\n78:         if (cur) groups.push(cur);\n79:         cur = { id: t.sentenceId, tokens: [] };\n80:       }\n81:       cur.tokens.push(t);\n82:     }\n83:     if (cur) groups.push(cur);\n84:     return groups;\n85:   }, [tokens]);\n86: \n87:   return (\n88:     <section>\n89:       <div className=\"flex items-center justify-between mb-3\">\n90:         <div className=\"text-[10px] font-mono uppercase tracking-widest text-primary\">\n91:           Transcript\n92:         </div>\n93:         <div className=\"flex items-center gap-2\">\n94:           <Tooltip>\n95:             <TooltipTrigger asChild>\n96:               <button\n97:                 onClick={onToggleLoop}\n98:                 className={`px-2 py-1 border text-[10px] font-mono uppercase tracking-widest ${\n99:                   loopArmed\n100:                     ? \"bg-primary text-primary-foreground border-primary\"\n101:                     : \"border-border text-muted-foreground hover:text-foreground\"\n102:                 }`}\n103:               >\n104:                 Loop {loopRange ? \"●\" : \"○\"}\n105:               </button>\n106:             </TooltipTrigger>\n107:             <TooltipContent side=\"bottom\" className=\"max-w-xs\">\n108:               Shift+click two words to set a range, then arm Loop to repeat.\n109:             </TooltipContent>\n110:           </Tooltip>\n111:           {loopRange ? (\n112:             <button\n113:               onClick={onClearLoop}\n114:               className=\"px-2 py-1 border border-border text-[10px] font-mono uppercase tracking-widest text-muted-foreground hover:text-destructive\"\n115:               title=\"Clear loop\"\n116:             >\n117:               ×\n118:             </button>\n119:           ) : null}\n120:           <div className=\"flex border border-border text-[10px] font-mono uppercase\">\n121:             <Tooltip>\n122:               <TooltipTrigger asChild>\n123:                 <button\n124:                   onClick={() => setMode(\"scrub\")}\n125:                   className={`px-2 py-1 ${mode === \"scrub\" ? \"bg-primary text-primary-foreground\" : \"text-muted-foreground\"}`}\n126:                 >\n127:                   Scrub\n128:                 </button>\n129:               </TooltipTrigger>\n130:               <TooltipContent side=\"bottom\">\n131:                 Click any word to jump the playhead.\n132:               </TooltipContent>\n133:             </Tooltip>\n134:             <Tooltip>\n135:               <TooltipTrigger asChild>\n136:                 <button\n137:                   onClick={() => setMode(\"edit\")}\n138:                   className={`px-2 py-1 ${mode === \"edit\" ? \"bg-primary text-primary-foreground\" : \"text-muted-foreground\"}`}\n139:                 >\n140:                   Edit\n141:                 </button>\n142:               </TooltipTrigger>\n143:               <TooltipContent side=\"bottom\">\n144:                 Edit script in place. Stable token ids survive small edits.\n145:               </TooltipContent>\n146:             </Tooltip>\n147:           </div>\n148:         </div>\n149:       </div>\n150: \n151:       {/* Scrubber strip */}\n152:       <Tooltip>\n153:         <TooltipTrigger asChild>\n154:           <div>\n155:             <Scrubber\n156:               tokens={tokens}\n157:               totalMs={totalMs}\n158:               currentMs={currentMs}\n159:               loopRange={loopRange}\n160:               onScrubMs={onScrubMs}\n161:             />\n162:           </div>\n163:         </TooltipTrigger>\n164:         <TooltipContent side=\"bottom\" className=\"max-w-xs\">\n165:           Click anywhere to scrub. Bars colour by synthesis status; primary tint\n166:           = audio ready.\n167:         </TooltipContent>\n168:       </Tooltip>\n169: \n170:       {mode === \"edit\" ? (\n171:         <div\n172:           ref={editRef}\n173:           contentEditable\n174:           suppressContentEditableWarning\n175:           onBlur={(e) => {\n176:             const text = (e.currentTarget as HTMLDivElement).innerText;\n177:             onScriptChange(text);\n178:           }}\n179:           className=\"w-full h-64 mt-3 bg-card border border-border p-3 font-mono text-xs leading-relaxed overflow-y-auto whitespace-pre-wrap focus:outline-none focus:ring-1 focus:ring-primary\"\n180:         />\n181:       ) : (\n182:         <div className=\"mt-3 max-h-64 overflow-y-auto bg-card border border-border p-3 text-sm leading-relaxed\">\n183:           {sentenceGroups.map((g) => {\n184:             if (g.tokens.length === 1 && g.tokens[0].isBreak)\n185:               return <span key={g.id} className=\"block h-3\" />;\n186:             return (\n187:               <ContextMenu key={g.id}>\n188:                 <ContextMenuTrigger asChild>\n189:                   <span>\n190:                     {g.tokens.map((t) => {\n191:                       const active = t.id === currentTokenId;\n192:                       const inLoop =\n193:                         loopRange &&\n194:                         t.startMs >= loopRange.startMs &&\n195:                         t.endMs <= loopRange.endMs;\n196:                       return (\n197:                         <span\n198:                           key={t.id}\n199:                           onClick={(e) =>\n200:                             e.shiftKey\n201:                               ? onTokenShiftClick(t)\n202:                               : onScrubToToken(t)\n203:                           }\n204:                           className={`cursor-pointer rounded-sm px-0.5 transition-colors ${\n205:                             active\n206:                               ? \"bg-primary text-primary-foreground\"\n207:                               : t.status === \"spoken\"\n208:                                 ? \"text-muted-foreground\"\n209:                                 : t.status === \"synthesized\"\n210:                                   ? \"text-primary/80 hover:bg-primary/10\"\n211:                                   : t.status === \"scheduled\"\n212:                                     ? \"text-primary/50 hover:bg-primary/10\"\n213:                                     : \"text-foreground hover:bg-primary/10\"\n214:                           } ${inLoop ? \"underline decoration-primary/60 underline-offset-2\" : \"\"}`}\n215:                         >\n216:                           {t.text}{\" \"}\n217:                         </span>\n218:                       );\n219:                     })}\n220:                   </span>\n221:                 </ContextMenuTrigger>\n222:                 <ContextMenuContent className=\"font-mono text-xs\">\n223:                   <ContextMenuItem onSelect={() => onResynth(g.id, \"kokoro-q8\")}>\n224:                     Re-synth · Kokoro q8\n225:                   </ContextMenuItem>\n226:                   <ContextMenuItem onSelect={() => onResynth(g.id, \"kokoro-q4\")}>\n227:                     Re-synth · Kokoro q4\n228:                   </ContextMenuItem>\n229:                   <ContextMenuItem onSelect={() => onResynth(g.id, \"web-speech\")}>\n230:                     Re-synth · Web Speech\n231:                   </ContextMenuItem>\n232:                   <ContextMenuSeparator />\n233:                   <ContextMenuItem\n234:                     onSelect={() => {\n235:                       const text = g.tokens.map((t) => t.text).join(\" \");\n236:                       navigator.clipboard?.writeText(text).catch(() => undefined);\n237:                     }}\n238:                   >\n239:                     Copy sentence\n240:                   </ContextMenuItem>\n241:                 </ContextMenuContent>\n242:               </ContextMenu>\n243:             );\n244:           })}\n245:         </div>\n246:       )}\n247:     </section>\n248:   );\n249: }\n250: \n251: function Scrubber({\n252:   tokens,\n253:   totalMs,\n254:   currentMs,\n255:   loopRange,\n256:   onScrubMs,\n257: }: {\n258:   tokens: Token[];\n259:   totalMs: number;\n260:   currentMs: number;\n261:   loopRange: { startMs: number; endMs: number } | null;\n262:   onScrubMs: (ms: number) => void;\n263: }) {\n264:   const width = 320;\n265:   const height = 22;\n266:   const ratio = totalMs > 0 ? currentMs / totalMs : 0;\n267: \n268:   const handle = (e: React.MouseEvent<SVGSVGElement>) => {\n269:     const rect = (e.currentTarget as SVGSVGElement).getBoundingClientRect();\n270:     const x = e.clientX - rect.left;\n271:     const r = Math.min(1, Math.max(0, x / rect.width));\n272:     onScrubMs(r * totalMs);\n273:   };\n274: \n275:   return (\n276:     <svg\n277:       viewBox={`0 0 ${width} ${height}`}\n278:       preserveAspectRatio=\"none\"\n279:       className=\"w-full h-5 cursor-pointer border border-border bg-card\"\n280:       onClick={handle}\n281:     >\n282:       {loopRange && totalMs > 0 ? (\n283:         <rect\n284:           x={(loopRange.startMs / totalMs) * width}\n285:           y={0}\n286:           width={Math.max(\n287:             1,\n288:             ((loopRange.endMs - loopRange.startMs) / totalMs) * width,\n289:           )}\n290:           height={height}\n291:           fill=\"color-mix(in oklab, var(--primary) 18%, transparent)\"\n292:         />\n293:       ) : null}\n294:       {tokens.map((t) => {\n295:         if (t.isBreak || totalMs === 0) return null;\n296:         const x = (t.startMs / totalMs) * width;\n297:         const w = Math.max(0.5, ((t.endMs - t.startMs) / totalMs) * width);\n298:         const color =\n299:           t.status === \"synthesized\" || t.status === \"spoken\"\n300:             ? \"var(--primary)\"\n301:             : t.status === \"scheduled\"\n302:               ? \"color-mix(in oklab, var(--primary) 40%, transparent)\"\n303:               : \"var(--border)\";\n304:         return (\n305:           <rect\n306:             key={t.id}\n307:             x={x}\n308:             y={6}\n309:             width={w}\n310:             height={10}\n311:             fill={color}\n312:             opacity={0.85}\n313:           />\n314:         );\n315:       })}\n316:       <line\n317:         x1={ratio * width}\n318:         x2={ratio * width}\n319:         y1={0}\n320:         y2={height}\n321:         stroke=\"var(--primary)\"\n322:         strokeWidth={1.5}\n323:       />\n324:     </svg>\n325:   );\n326: }\n\n(End of file - total 326 lines)\n</content>",
