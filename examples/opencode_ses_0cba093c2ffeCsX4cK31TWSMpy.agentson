    {
      "type": "user-query",
      "text": "Search the web for evidence about healthcare data interoperability problems, specifically:\n\n1. FDA or EU MDR requirements for medical device data export\n2. Any cases where lack of API access to health data was challenged\n3. The concept of \"clinical decision latency\" from lack of data interoperability\n4. Any NHS or EU healthcare interoperability regulations (like FHIR requirements)\n\nReturn exact quotes and URLs from authoritative sources.",
      "timestamp": 1783290096708
    },
