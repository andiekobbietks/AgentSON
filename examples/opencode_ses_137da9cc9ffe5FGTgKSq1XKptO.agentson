n  Line 147: # PEDAGOGY: A \"resource\" block creates something in AWS.\r\n\n  Line 148: # This one creates a Virtual Private Cloud (VPC) - your own\r\n\n  Line 149: # private network in the cloud. Think of it like setting up\r\n\n  Line 150: # your own private office building where you control who\r\n\n  Line 151: # can enter and what rooms exist.\r\n\n  Line 153: # AWS re/Start Module 3.2: VPC Fundamentals\r\n\n  Line 154: # Estimated monthly cost: $0.00 (VPCs are free, resources inside cost money)\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\RandD\\strategic_finops_vision.md:\n  Line 1: # Strategic FinOps Vision: Implementation Architecture & Sources\r\n\n  Line 77: # .forge file specifies optional policy reference\r\n\n  Line 113: # sdk/pricing-constants.yaml\r\n\n  Line 114: # Last updated: 2026-01-15\r\n\n  Line 115: # Next review: 2027-01-15\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\RandD\\localstack_aws_restart_integration.md:\n  Line 1: # LocalStack Integration for AWS re/Start Track\r\n\n  Line 151: # .devcontainer/docker-compose.yml\r\n\n  Line 190: # default.forge\r\n\n  Line 257: # PEDAGOGY: Creating an S3 Bucket\r\n\n  Line 258: # ═══════════════════════════════════════════════════════════════\r\n\n  Line 260: # What just happened:\r\n\n  Line 261: #   You created an S3 bucket named \"my-first-bucket\"\r\n\n  Line 262: #   S3 = Simple Storage Service (object storage)\r\n\n  Line 264: # Real AWS cost: ~$0.023 per GB/month (but FREE in LocalStack!)\r\n\n  Line 266: # AWS re/Start Module 3.2: S3 is one of the \"Core Services\"\r\n\n  Line 268: # Try next:\r\n\n  Line 269: #   awslocal s3 cp myfile.txt s3://my-first-bucket/\r\n\n  Line 270: #   awslocal s3 ls s3://my-first-bucket/\r\n\n  Line 271: # ═══════════════════════════════════════════════════════════════\r\n\n  Line 338: # .forge can specify VS Code extensions\r\n\n  Line 437: # Step 1: Create a bucket\r\n\n  Line 440: # PEDAGOGY: You just created an S3 bucket!\r\n\n  Line 441: # S3 buckets are like folders in the cloud that can hold unlimited files.\r\n\n  Line 442: # Names must be globally unique (in real AWS) and lowercase.\r\n\n  Line 443: # AWS re/Start 3.2.1: Object Storage Concepts\r\n\n  Line 445: # Step 2: Upload a file\r\n\n  Line 448: # PEDAGOGY: You uploaded index.html to your bucket.\r\n\n  Line 449: # In real AWS, this would cost ~$0.005 per 1000 PUT requests.\r\n\n  Line 450: # LocalStack: FREE and instant!\r\n\n  Line 452: # Step 3: Enable static website hosting\r\n\n  Line 455: # PEDAGOGY: Your bucket is now a static website!\r\n\n  Line 456: # Access it at: http://student-portfolio.s3.localhost.localstack.cloud:4566\r\n\n  Line 457: # AWS re/Start 3.2.3: S3 Static Website Hosting\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\RandD\\finops_explainer_and_rationale.md:\n  Line 1: # FinOps in SDTP: Origins, Rationale, and Strategic Saliency\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\RandD\\copyright_clean_room_explainer.md:\n  Line 1: # Copyright Law & Clean Room Implementations: Why .forge Is Legally Sound\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\docs\\DESIGN-TOKEN-AUDIT.md:\n  Line 1: # LAMPForge Design Token Consistency Audit\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\docs\\COGNITIVE_TAXONOMY_PROTOCOL.md:\n  Line 1: # The Cognitive Taxonomy Protocol: The Visual Grammar of Code\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\spec\\SPECIFICATION.md:\n  Line 1: # SDTP `.forge` Protocol Specification\r\n\n  Line 99: # Minimal valid .forge file\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\spec\\SECURITY.md:\n  Line 1: # SDTP `.forge` Protocol - Security Model Specification\r\n\n  Line 419: # .git/hooks/pre-commit\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\spec\\LIFECYCLE.md:\n  Line 1: # SDTP `.forge` Protocol - Lifecycle Specification\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\spec\\GRAMMAR.md:\n  Line 1: # SDTP `.forge` Protocol - Formal Grammar\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\spec\\FINOPS.md:\n  Line 1: # SDTP `.forge` Protocol - FinOps Governance Specification\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\runtime\\README.md:\n  Line 1: # LAMPForge Runtime Bundle\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\README.md:\n  Line 480: # Clone the repository\r\n\n  Line 484: # Install dependencies\r\n\n  Line 487: # Start the development server\r\n\n  Line 506: # Foundry Local\r\n\n  Line 509: # Or Ollama\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\RandD\\tutorial_integration.md:\n  Line 1: # Tutorial System Integration Architecture\r\n\n  Line 113: # .forge file structure\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\RandD\\python_oci_backend_architecture.md:\n  Line 1: # Python Backend Architecture for Oracle OCI Always Free\r\n\n  Line 200: # Middleware\r\n\n  Line 211: # Routes\r\n\n  Line 466: # Install ARM-optimised dependencies\r\n\n  Line 473: # Install Python dependencies\r\n\n  Line 477: # Copy application\r\n\n  Line 480: # Copy models (or mount as volume)\r\n\n  Line 483: # Run with uvicorn\r\n\n  Line 491: # deploy-oci.sh\r\n\n  Line 493: # Variables\r\n\n  Line 500: # Create instance\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\RandD\\curriculum_architecture.md:\n  Line 1: # SDTP Curriculum Architecture: .forge Lesson Files\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\RandD\\cli_origin_story.md:\n  Line 1: # The Making of forge-cli: A Design Chronicle\r\n\n  Line 546: # Create a new .forge file\r\n\n  Line 550: # Validate against schema\r\n\n  Line 554: # Preview generated code\r\n\n  Line 558: # Work with examples\r\n\n  Line 562: # Manage curriculum\r\n\n  Line 566: # Skip banner\r\n\n\nC:\\Users\\LLM-Test\\LAMPForge_SDTP\\forge-flow-learn-0d5b3821\\RandD\\cli_development.md:\n  Line 1: # CLI Development Guide\r\n\n  Line 64: # Beginner: guided wizard\r\n\n  Line 67: # Power user: template + output\r\n\n  Line 98: # Generate starter code from .forge\r\n\n  Line 101: # Output structure:\r\n\n  Line 102: # ./src/\r\n\n  Line 103: # ├── sql/\r\n\n  Line 104: # │   └── schema.sql\r\n\n  Line 105: # ├── php/\r\n\n\n(Results truncated: showing 100 of 229 matches (129 hidden). Consider using a more specific path or pattern.)",
