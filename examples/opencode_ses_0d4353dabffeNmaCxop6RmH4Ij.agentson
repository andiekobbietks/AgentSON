    {
      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"\\\"\\\"\\\"\\nPC Health Monitor - No Stress Testing\\nMonitors temperatures, disk health, and system events passively.\\nRun: python pc_health_monitor.py\\n\\\"\\\"\\\"\\n\\nimport psutil\\nimport platform\\nimport subprocess\\nimport time\\nimport json\\nfrom datetime import datetime, timedelta\\n\\ndef get_cpu_temp_via_wmi():\\n    \\\"\\\"\\\"Try to get CPU temperature via WMI (requires admin).\\\"\\\"\\\"\\n    try:\\n        import wmi\\n        w = wmi.WMI(namespace=\\\"root\\\\\\\\OpenHardwareMonitor\\\")\\n        sensors = w.Sensor()\\n        temps = {}\\n        for sensor in sensors:\\n            if sensor.SensorType == \\\"Temperature\\\" and \\\"CPU\\\" in sensor.Name:\\n                temps[sensor.Name] = float(sensor.Value)\\n        return temps\\n    except Exception:\\n        pass\\n    \\n    # Try MSAcpi_ThermalZoneTemperature\\n    try:\\n        result = subprocess.run(\\n            ['powershell', '-Command', \\n             'Get-CimInstance MSAcpi_ThermalZoneTemperature -Namespace \\\"root/wmi\\\" | Select-Object CurrentTemperature'],\\n            capture_output=True, text=True, timeout=10\\n        )\\n        if result.returncode == 0 and result.stdout.strip():\\n            lines = result.stdout.strip().split('\\\\n')\\n            temps = {}\\n            for i, line in enumerate(lines):\\n                try:\\n                    val = int(line.strip().replace('CurrentTemperature : ', ''))\\n                    temps[f\\\"ThermalZone_{i}\\\"] = (val / 10) - 273.15  # Convert from deciKelvin\\n                except ValueError:\\n                    continue\\n            return temps\\n    except Exception:\\n        pass\\n    \\n    return None\\n\\ndef get_system_info():\\n    \\\"\\\"\\\"Gather basic system information.\\\"\\\"\\\"\\n    info = {\\n        \\\"platform\\\": platform.platform(),\\n        \\\"processor\\\": platform.processor(),\\n        \\\"python\\\": platform.python_version(),\\n        \\\"boot_time\\\": datetime.fromtimestamp(psutil.boot_time()).strftime(\\\"%Y-%m-%d %H:%M:%S\\\"),\\n    }\\n    \\n    # CPU usage (non-stress, just current load)\\n    cpu_percent = psutil.cpu_percent(interval=1)\\n    cpu_freq = psutil.cpu_freq()\\n    info[\\\"cpu_percent\\\"] = cpu_percent\\n    info[\\\"cpu_freq_current\\\"] = cpu_freq.current if cpu_freq else \\\"N/A\\\"\\n    info[\\\"cpu_freq_max\\\"] = cpu_freq.max if cpu_freq else \\\"N/A\\\"\\n    info[\\\"cpu_count_physical\\\"] = psutil.cpu_count(logical=False)\\n    info[\\\"cpu_count_logical\\\"] = psutil.cpu_count(logical=True)\\n    \\n    # Memory\\n    mem = psutil.virtual_memory()\\n    info[\\\"ram_total_gb\\\"] = round(mem.total / (1024**3), 1)\\n    info[\\\"ram_used_gb\\\"] = round(mem.used / (1024**3), 1)\\n    info[\\\"ram_percent\\\"] = mem.percent\\n    \\n    return info\\n\\ndef check_disk_health():\\n    \\\"\\\"\\\"Check disk health via SMART (non-destructive).\\\"\\\"\\\"\\n    results = []\\n    for part in psutil.disk_partitions():\\n        try:\\n            usage = psutil.disk_usage(part.mountpoint)\\n            results.append({\\n                \\\"device\\\": part.device,\\n                \\\"mountpoint\\\": part.mountpoint,\\n                \\\"fstype\\\": part.fstype,\\n                \\\"total_gb\\\": round(usage.total / (1024**3), 1),\\n                \\\"used_gb\\\": round(usage.used / (1024**3), 1),\\n                \\\"percent\\\": usage.percent,\\n            })\\n        except PermissionError:\\n            continue\\n    return results\\n\\ndef check_recent_events():\\n    \\\"\\\"\\\"Check for WHEA and critical system events.\\\"\\\"\\\"\\n    try:\\n        result = subprocess.run(\\n            ['powershell', '-Command', \\n             'Get-EventLog -LogName System -Newest 500 -EntryType Error 2>$null | '\\n             'Where-Object { $_.Source -like \\\"*WHEA*\\\" -or $_.Source -like \\\"*Kernel-Power*\\\" -or '\\n             '$_.Source -like \\\"*stornvme*\\\" } | '\\n             'Select-Object TimeGenerated, Source, InstanceID | Format-Table -AutoSize'],\\n            capture_output=True, text=True, timeout=15\\n        )\\n        return result.stdout if result.stdout else \\\"No critical events found.\\\"\\n    except Exception as e:\\n        return f\\\"Could not query events: {e}\\\"\\n\\ndef get_temperature_readings():\\n    \\\"\\\"\\\"Attempt multiple methods to read temperatures.\\\"\\\"\\\"\\n    temps = {}\\n    \\n    # Method 1: psutil (limited on Windows)\\n    try:\\n        temps_psutil = psutil.sensors_temperatures()\\n        if temps_psutil:\\n            for name, entries in temps_psutil.items():\\n                for entry in entries:\\n                    temps[f\\\"{name}_{entry.label or 'default'}\\\"] = entry.current\\n    except (AttributeError, Exception):\\n        pass\\n    \\n    # Method 2: WMI thermal zones\\n    if not temps:\\n        wmi_temps = get_cpu_temp_via_wmi()\\n        if wmi_temps:\\n            temps.update(wmi_temps)\\n    \\n    return temps if temps else {\\\"status\\\": \\\"Temperature sensors not accessible without admin privileges or OpenHardwareMonitor/LibreHardwareMonitor\\\"}\\n\\ndef assess_health(info, disks, temps):\\n    \\\"\\\"\\\"Generate health assessment and recommendations.\\\"\\\"\\\"\\n    issues = []\\n    recommendations = []\\n    \\n    # CPU assessment\\n    if info[\\\"cpu_percent\\\"] > 90:\\n        issues.append(\\\"CPU usage is very high at idle - possible background process issue\\\")\\n    if info[\\\"ram_percent\\\"] > 85:\\n        issues.append(\\\"RAM usage is critically high - may cause instability\\\")\\n    elif info[\\\"ram_percent\\\"] > 70:\\n        recommendations.append(\\\"RAM usage is elevated - monitor for memory leaks\\\")\\n    \\n    # Disk assessment\\n    for disk in disks:\\n        if disk[\\\"percent\\\"] > 90:\\n            issues.append(f\\\"Drive {disk['device']} is {disk['percent']}% full - low disk space causes instability\\\")\\n        if disk[\\\"total_gb\\\"] < 100 and disk[\\\"fstype\\\"] == \\\"NTFS\\\":\\n            recommendations.append(f\\\"Drive {disk['device']} is small ({disk['total_gb']}GB) - consider\\u6269\\u5bb9\\\")\\n    \\n    # Temperature assessment (if available)\\n    if isinstance(temps, dict) and \\\"status\\\" not in temps:\\n        for sensor, temp in temps.items():\\n            if temp > 90:\\n                issues.append(f\\\"CRITICAL: {sensor} at {temp}\\u00b0C - overheating risk!\\\")\\n            elif temp > 80:\\n                recommendations.append(f\\\"WARNING: {sensor} at {temp}\\u00b0C - consider improving cooling\\\")\\n            elif temp > 70:\\n                recommendations.append(f\\\"Note: {sensor} at {temp}\\u00b0C - within normal range under load\\\")\\n    \\n    # WHEA-specific recommendations\\n    recommendations.append(\\\"WHEA_UNCORRECTABLE_ERROR is typically caused by:\\\")\\n    recommendations.append(\\\"  1. NVMe SSD issues (check firmware with vendor tool)\\\")\\n    recommendations.append(\\\"  2. Dried thermal paste (repaste CPU if >3 years old)\\\")\\n    recommendations.append(\\\"  3. Mixed RAM kits (use matched pairs)\\\")\\n    recommendations.append(\\\"  4. Outdated BIOS/microcode (update from manufacturer)\\\")\\n    recommendations.append(\\\"  5. Failing VRM/motherboard (professional diagnosis needed)\\\")\\n    \\n    return issues, recommendations\\n\\ndef main():\\n    print(\\\"=\\\" * 60)\\n    print(\\\"PC HEALTH MONITOR - Passive Assessment (No Stress Testing)\\\")\\n    print(f\\\"Timestamp: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\\")\\n    print(\\\"=\\\" * 60)\\n    print()\\n    \\n    # System info\\n    print(\\\"--- SYSTEM INFORMATION ---\\\")\\n    info = get_system_info()\\n    print(f\\\"  Platform: {info['platform']}\\\")\\n    print(f\\\"  CPU: {info['processor']}\\\")\\n    print(f\\\"  CPU Cores: {info['cpu_count_physical']} physical / {info['cpu_count_logical']} logical\\\")\\n    print(f\\\"  CPU Usage: {info['cpu_percent']}% (current)\\\")\\n    print(f\\\"  CPU Frequency: {info['cpu_freq_current']} MHz / {info['cpu_freq_max']} MHz\\\")\\n    print(f\\\"  RAM: {info['ram_used_gb']}GB / {info['ram_total_gb']}GB ({info['ram_percent']}%)\\\")\\n    print(f\\\"  Last Boot: {info['boot_time']}\\\")\\n    print()\\n    \\n    # Disk health\\n    print(\\\"--- DISK HEALTH ---\\\")\\n    disks = check_disk_health()\\n    for disk in disks:\\n        print(f\\\"  {disk['device']} ({disk['mountpoint']}): {disk['used_gb']}GB / {disk['total_gb']}GB ({disk['percent']}%)\\\")\\n    print()\\n    \\n    # Temperatures\\n    print(\\\"--- TEMPERATURE READINGS ---\\\")\\n    temps = get_temperature_readings()\\n    if isinstance(temps, dict):\\n        if \\\"status\\\" in temps:\\n            print(f\\\"  {temps['status']}\\\")\\n        else:\\n            for sensor, temp in temps.items():\\n                status = \\\"OK\\\" if temp < 70 else (\\\"WARM\\\" if temp < 85 else \\\"HOT\\\")\\n                print(f\\\"  {sensor}: {temp:.1f}\\u00b0C [{status}]\\\")\\n    print()\\n    \\n    # Event check\\n    print(\\\"--- CRITICAL SYSTEM EVENTS ---\\\")\\n    events = check_recent_events()\\n    print(events)\\n    print()\\n    \\n    # Health assessment\\n    print(\\\"--- HEALTH ASSESSMENT ---\\\")\\n    issues, recommendations = assess_health(info, disks, temps)\\n    \\n    if issues:\\n        print(\\\"  ISSUES FOUND:\\\")\\n        for issue in issues:\\n            print(f\\\"    [!] {issue}\\\")\\n    else:\\n        print(\\\"  No immediate issues detected.\\\")\\n    print()\\n    \\n    print(\\\"  RECOMMENDATIONS:\\\")\\n    for rec in recommendations:\\n        print(f\\\"    -> {rec}\\\")\\n    print()\\n    \\n    # WHEA-specific\\n    print(\\\"--- WHEA_UNCORRECTABLE_ERROR ANALYSIS ---\\\")\\n    print(\\\"  This error (Stop Code 0x124) indicates a fatal hardware error.\\\")\\n    print(\\\"  Common causes for your HP OMEN 15-ce0xx:\\\")\\n    print(\\\"    1. ADATA SX6000NP NVMe SSD - budget controller, check firmware\\\")\\n    print(\\\"    2. CPU thermal paste dried out after 8 years\\\")\\n    print(\\\"    3. Mixed RAM (SK Hynix + Samsung) timing conflicts\\\")\\n    print(\\\"    4. BIOS F.24 outdated (2021) - update for Intel microcode patches\\\")\\n    print(\\\"    5. Motherboard VRM degradation (age-related)\\\")\\n    print()\\n    print(\\\"  NEXT STEPS:\\\")\\n    print(\\\"    1. Run: python -m pip install --upgrade pip\\\")\\n    print(\\\"    2. Install LibreHardwareMonitor for real-time temp monitoring\\\")\\n    print(\\\"    3. Check ADATA SSD firmware via ADATA SSD ToolBox\\\")\\n    print(\\\"    4. Update BIOS from HP support website\\\")\\n    print(\\\"    5. Consider repasting CPU if comfortable doing so\\\")\\n    print(\\\"    6. If crashes continue, test with matched RAM kit\\\")\\n    print()\\n    \\n    print(\\\"=\\\" * 60)\\n    print(\\\"Run this script periodically to monitor system health.\\\")\\n    print(\\\"For real-time monitoring, use LibreHardwareMonitor or HWiNFO64.\\\")\\n    print(\\\"=\\\" * 60)\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\pc_health_monitor.py\"}",
