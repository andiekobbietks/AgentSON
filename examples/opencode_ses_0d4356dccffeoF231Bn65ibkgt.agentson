      "text": "Good, psutil and pywin32 are installed. Now let me write a comprehensive Python diagnostic script.",
      "timestamp": 1783146434942
    },
    {
      "type": "action",
      "tool": "write",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\hw_diag.py\", \"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"Enterprise Hardware Diagnostics - WHEA_UNCORRECTABLE_ERROR Root Cause Analysis\\\"\\\"\\\"\\nimport psutil\\nimport os\\nimport json\\nimport datetime\\nimport ctypes\\nimport sys\\n\\nreport = {}\\n\\n# ============================================================\\n# 1. CPU Information\\n# ============================================================\\ncpu_freq = psutil.cpu_freq()\\ncpu_times = psutil.cpu_times_percent(interval=2)\\ncpu_stats = psutil.cpu_stats()\\n\\nreport[\\\"cpu\\\"] = {\\n    \\\"physical_cores\\\": psutil.cpu_count(logical=False),\\n    \\\"logical_cores\\\": psutil.cpu_count(logical=True),\\n    \\\"frequency_current_mhz\\\": cpu_freq.current if cpu_freq else None,\\n    \\\"frequency_max_mhz\\\": cpu_freq.max if cpu_freq else None,\\n    \\\"cpu_percent\\\": psutil.cpu_percent(interval=1),\\n    \\\"user_percent\\\": cpu_times.user,\\n    \\\"system_percent\\\": cpu_times.system,\\n    \\\"idle_percent\\\": cpu_times.idle,\\n    \\\"ctx_switches\\\": cpu_stats.ctx_switches,\\n    \\\"interrupts\\\": cpu_stats.interrupts,\\n}\\n\\n# ============================================================\\n# 2. Memory Analysis\\n# ============================================================\\nvm = psutil.virtual_memory()\\nsw = psutil.swap_memory()\\n\\nreport[\\\"memory\\\"] = {\\n    \\\"total_gb\\\": round(vm.total / (1024**3), 2),\\n    \\\"available_gb\\\": round(vm.available / (1024**3), 2),\\n    \\\"used_gb\\\": round(vm.used / (1024**3), 2),\\n    \\\"percent_used\\\": vm.percent,\\n    \\\"swap_total_gb\\\": round(sw.total / (1024**3), 2),\\n    \\\"swap_used_gb\\\": round(sw.used / (1024**3), 2),\\n    \\\"swap_percent\\\": sw.percent,\\n}\\n\\n# ============================================================\\n# 3. Disk Health\\n# ============================================================\\ndisk_info = []\\nfor part in psutil.disk_partitions():\\n    try:\\n        usage = psutil.disk_usage(part.mountpoint)\\n        disk_info.append({\\n            \\\"device\\\": part.device,\\n            \\\"mountpoint\\\": part.mountpoint,\\n            \\\"fstype\\\": part.fstype,\\n            \\\"total_gb\\\": round(usage.total / (1024**3), 2),\\n            \\\"used_gb\\\": round(usage.used / (1024**3), 2),\\n            \\\"percent_used\\\": usage.percent,\\n        })\\n    except PermissionError:\\n        pass\\n\\nreport[\\\"disks\\\"] = disk_info\\n\\n# ============================================================\\n# 4. Temperature Sensors (if available)\\n# ============================================================\\ntry:\\n    temps = psutil.sensors_temperatures()\\n    if temps:\\n        temp_data = {}\\n        for name, entries in temps.items():\\n            temp_data[name] = [\\n                {\\\"label\\\": e.label or name, \\\"current\\\": e.current, \\\"high\\\": e.high, \\\"critical\\\": e.critical}\\n                for e in entries\\n            ]\\n        report[\\\"temperatures\\\"] = temp_data\\n    else:\\n        report[\\\"temperatures\\\"] = \\\"No temperature sensors available via psutil\\\"\\nexcept Exception as e:\\n    report[\\\"temperatures\\\"] = f\\\"Error reading temps: {str(e)}\\\"\\n\\n# ============================================================\\n# 5. Battery (laptop check)\\n# ============================================================\\ntry:\\n    bat = psutil.sensors_battery()\\n    if bat:\\n        report[\\\"battery\\\"] = {\\n            \\\"percent\\\": bat.percent,\\n            \\\"plugged\\\": bat.power_plugged,\\n            \\\"secs_left\\\": bat.secsleft,\\n        }\\n    else:\\n        report[\\\"battery\\\"] = \\\"No battery detected\\\"\\nexcept:\\n    report[\\\"battery\\\"] = \\\"Unable to read battery\\\"\\n\\n# ============================================================\\n# 6. Top Memory Consumers\\n# ============================================================\\nprocs = []\\nfor p in psutil.process_iter(['pid', 'name', 'memory_percent', 'memory_info']):\\n    try:\\n        info = p.info\\n        procs.append({\\n            \\\"pid\\\": info['pid'],\\n            \\\"name\\\": info['name'],\\n            \\\"mem_percent\\\": round(info['memory_percent'], 2),\\n            \\\"mem_rss_mb\\\": round(info['memory_info'].rss / (1024**2), 1) if info['memory_info'] else 0,\\n        })\\n    except (psutil.NoSuchProcess, psutil.AccessDenied):\\n        pass\\n\\nprocs.sort(key=lambda x: x['mem_percent'], reverse=True)\\nreport[\\\"top_processes\\\"] = procs[:15]\\n\\n# ============================================================\\n# 7. WHEA Error History from Event Log\\n# ============================================================\\ntry:\\n    import win32evtlog\\n    import win32evtlogutil\\n\\n    whea_events = []\\n    hand = win32evtlog.OpenEventLog(None, \\\"System\\\")\\n    flags = win32evtlog.EVENTLOG_BACKWARDS_READ | win32evtlog.EVENTLOG_SEQUENTIAL_READ\\n    total = 0\\n\\n    while total < 2000:\\n        events = win32evtlog.ReadEventLog(hand, flags, 0)\\n        if not events:\\n            break\\n        for event in events:\\n            total += 1\\n            # WHEA errors: EventID 41 (Kernel-Power critical), EventID 18 (WHEA), Source containing WHEA\\n            if event.EventID in (41, 18) or \\\"WHEA\\\" in (event.SourceName or \\\"\\\"):\\n                whea_events.append({\\n                    \\\"time\\\": str(event.TimeGenerated),\\n                    \\\"event_id\\\": event.EventID,\\n                    \\\"source\\\": event.SourceName,\\n                    \\\"level\\\": event.EventType,\\n                })\\n    win32evtlog.CloseEventLog(hand)\\n    report[\\\"whea_events\\\"] = whea_events[:30]\\nexcept Exception as e:\\n    report[\\\"whea_events\\\"] = f\\\"Error reading event log: {str(e)}\\\"\\n\\n# ============================================================\\n# 8. System Uptime\\n# ============================================================\\nboot_time = datetime.datetime.fromtimestamp(psutil.boot_time())\\nuptime = datetime.datetime.now() - boot_time\\nreport[\\\"system\\\"] = {\\n    \\\"boot_time\\\": str(boot_time),\\n    \\\"uptime_hours\\\": round(uptime.total_seconds() / 3600, 2),\\n    \\\"os\\\": os.name,\\n}\\n\\n# ============================================================\\n# Output\\n# ============================================================\\nprint(json.dumps(report, indent=2, default=str))\\n\"}",
      "output": "Wrote file successfully.",
