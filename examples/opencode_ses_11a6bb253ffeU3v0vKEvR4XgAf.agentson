      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\package.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"name\": \"community-launchpad-proto\",\n3:   \"private\": true,\n4:   \"sideEffects\": false,\n5:   \"type\": \"module\",\n6:   \"scripts\": {\n7:     \"dev\": \"vite dev\",\n8:     \"build\": \"vite build\",\n9:     \"build:dev\": \"vite build --mode development\",\n10:     \"preview\": \"vite preview\",\n11:     \"lint\": \"eslint .\",\n12:     \"format\": \"prettier --write .\"\n13:   },\n14:   \"dependencies\": {\n15:     \"@tailwindcss/vite\": \"^4.3.1\",\n16:     \"@vueuse/core\": \"^10.9.0\",\n17:     \"class-variance-authority\": \"^0.7.1\",\n18:     \"clsx\": \"^2.1.1\",\n19:     \"date-fns\": \"^4.1.0\",\n20:     \"frappe-ui\": \"latest\",\n21:     \"tailwind-merge\": \"^3.5.0\",\n22:     \"tailwindcss\": \"^4.2.1\",\n23:     \"tw-animate-css\": \"^1.3.4\",\n24:     \"vue\": \"^3.4.21\",\n25:     \"vue-router\": \"^4.3.0\",\n26:     \"zod\": \"^3.24.2\"\n27:   },\n28:   \"devDependencies\": {\n29:     \"@eslint/js\": \"^9.32.0\",\n30:     \"@types/node\": \"^22.16.5\",\n31:     \"@typescript-eslint/eslint-plugin\": \"^8.61.1\",\n32:     \"@typescript-eslint/parser\": \"^8.61.1\",\n33:     \"@vitejs/plugin-vue\": \"^5.0.4\",\n34:     \"@vue/compiler-sfc\": \"^3.4.21\",\n35:     \"eslint\": \"^9.32.0\",\n36:     \"eslint-config-prettier\": \"^10.1.1\",\n37:     \"eslint-plugin-prettier\": \"^5.2.6\",\n38:     \"eslint-plugin-vue\": \"^10.9.2\",\n39:     \"globals\": \"^15.15.0\",\n40:     \"prettier\": \"^3.7.3\",\n41:     \"typescript\": \"^6.0.3\",\n42:     \"vite\": \"^8.0.16\",\n43:     \"vue-eslint-parser\": \"^10.4.1\"\n44:   }\n45: }\n\n(End of file - total 45 lines)\n</content>",
