      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\ThreadView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <div class=\"flex flex-col h-full\">\n3:     <div v-if=\"!thread\" class=\"p-6 text-[14px]\">\n4:       Thread not found.\n5:       <RouterLink to=\"/messages\" class=\"text-primary underline\">Back to messages</RouterLink>\n6:     </div>\n7:     <template v-else>\n8:       <header class=\"h-14 px-4 border-b border-border flex items-center gap-3 bg-surface\">\n9:         <AppAvatar :user-id=\"other.user\" :size=\"32\" />\n10:         <div class=\"min-w-0\">\n11:           <div class=\"text-[14px] font-semibold truncate\">{{ other.full_name }}</div>\n12:           <div class=\"text-[11px] text-muted-foreground truncate\">{{ other.bio }}</div>\n13:         </div>\n14:       </header>\n15: \n16:       <div\n17:         ref=\"scrollRef\"\n18:         class=\"flex-1 overflow-y-auto px-4 py-5 flex flex-col gap-3 bg-background\"\n19:       >\n20:         <div\n21:           v-for=\"m in messages\"\n22:           :key=\"m.id\"\n23:           class=\"flex gap-2\"\n24:           :class=\"m.sender === currentUserId ? 'justify-end' : 'justify-start'\"\n25:         >\n26:           <AppAvatar v-if=\"m.sender !== currentUserId\" :user-id=\"m.sender\" :size=\"28\" />\n27:           <div\n28:             class=\"max-w-[70%] rounded-2xl px-3.5 py-2 text-[14px] leading-snug whitespace-pre-wrap break-words\"\n29:             :class=\"\n30:               m.sender === currentUserId\n31:                 ? 'bg-primary text-primary-foreground rounded-br-sm'\n32:                 : 'bg-secondary text-secondary-foreground rounded-bl-sm'\n33:             \"\n34:           >\n35:             {{ m.content }}\n36:           </div>\n37:         </div>\n38:         <div\n39:           v-if=\"messages.length === 0\"\n40:           class=\"text-center text-[13px] text-muted-foreground py-10\"\n41:         >\n42:           Say hi 👋\n43:         </div>\n44:       </div>\n45: \n46:       <form\n47:         class=\"border-t border-border bg-surface p-3 flex items-end gap-2\"\n48:         @submit.prevent=\"send\"\n49:       >\n50:         <textarea\n51:           v-model=\"draft\"\n52:           :placeholder=\"`Message ${other.full_name}`\"\n53:           rows=\"1\"\n54:           class=\"flex-1 resize-none rounded-xl border border-border bg-background px-3 py-2 text-[14px] outline-none focus:ring-2 focus:ring-primary/30 max-h-32\"\n55:           @keydown.enter.exact.prevent=\"send\"\n56:         />\n57:         <button\n58:           type=\"submit\"\n59:           :disabled=\"!draft.trim()\"\n60:           class=\"h-9 px-4 rounded-full bg-primary text-primary-foreground text-[13px] font-semibold disabled:opacity-40\"\n61:         >\n62:           Send\n63:         </button>\n64:       </form>\n65:     </template>\n66:   </div>\n67: </template>\n68: \n69: <script setup lang=\"ts\">\n70: import { ref, computed, watch, nextTick, onMounted } from \"vue\";\n71: import { RouterLink, useRoute } from \"vue-router\";\n72: import AppAvatar from \"@/components/AppAvatar.vue\";\n73: import {\n74:   currentUserId,\n75:   getDMMessages,\n76:   getDMThread,\n77:   getOtherMember,\n78:   getUser,\n79:   markThreadRead,\n80:   sendDM,\n81: } from \"@/data/store\";\n82: \n83: const route = useRoute();\n84: const threadId = computed(() => route.params.threadId as string);\n85: const thread = computed(() => getDMThread(threadId.value));\n86: const other = computed(() => {\n87:   const t = thread.value;\n88:   if (!t) return null;\n89:   return getUser(getOtherMember(t))!;\n90: });\n91: const messages = computed(() => getDMMessages(threadId.value));\n92: const draft = ref(\"\");\n93: const scrollRef = ref<HTMLDivElement | null>(null);\n94: \n95: onMounted(() => markThreadRead(threadId.value));\n96: watch(threadId, () => markThreadRead(threadId.value));\n97: \n98: watch(\n99:   () => messages.value.length,\n100:   () => nextTick(() => scrollRef.value?.scrollTo({ top: scrollRef.value.scrollHeight })),\n101: );\n102: \n103: function send() {\n104:   if (!draft.value.trim()) return;\n105:   sendDM(threadId.value, draft.value);\n106:   draft.value = \"\";\n107: }\n108: </script>\n\n(End of file - total 108 lines)\n</content>",
