      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\NotificationsView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout>\n3:     <div class=\"max-w-[720px] mx-auto px-4 md:px-8 py-6\">\n4:       <header class=\"mb-5 flex items-center justify-between\">\n5:         <div>\n6:           <h1 class=\"text-[24px] font-bold leading-tight\">Notifications</h1>\n7:           <p class=\"text-[13px] text-muted-foreground mt-0.5\">\n8:             Maps 1:1 to Frappe <code class=\"font-mono\">Notification Log</code>.\n9:           </p>\n10:         </div>\n11:         <button\n12:           type=\"button\"\n13:           class=\"h-8 px-3 rounded-full bg-secondary text-[12px] font-semibold hover:bg-secondary/70\"\n14:           @click=\"markAllNotificationsRead()\"\n15:         >\n16:           Mark all read\n17:         </button>\n18:       </header>\n19: \n20:       <ul class=\"flex flex-col gap-2\">\n21:         <li v-for=\"n in items\" :key=\"n.id\">\n22:           <component\n23:             :is=\"linkFor(n) ? RouterLink : 'div'\"\n24:             :to=\"linkFor(n) || undefined\"\n25:             @click=\"linkFor(n) && markNotificationRead(n.id)\"\n26:           >\n27:             <div\n28:               class=\"flex items-start gap-3 rounded-xl border p-4 transition-colors\"\n29:               :class=\"n.read ? 'border-border bg-card' : 'border-primary/30 bg-primary-soft/50'\"\n30:             >\n31:               <div class=\"text-xl\">{{ iconFor(n.type) }}</div>\n32:               <div class=\"flex-1 min-w-0\">\n33:                 <div class=\"text-[14px] font-semibold\">{{ n.subject }}</div>\n34:                 <div class=\"text-[12px] text-muted-foreground mt-0.5\">\n35:                   {{ n.type }} · {{ new Date(n.created_at).toLocaleString() }}\n36:                 </div>\n37:               </div>\n38:               <span v-if=\"!n.read\" class=\"size-2 rounded-full bg-primary mt-1.5\" />\n39:             </div>\n40:           </component>\n41:         </li>\n42:         <li v-if=\"items.length === 0\" class=\"text-center text-[13px] text-muted-foreground py-10\">\n43:           You're all caught up.\n44:         </li>\n45:       </ul>\n46:     </div>\n47:   </AppLayout>\n48: </template>\n49: \n50: <script setup lang=\"ts\">\n51: import { onMounted, computed } from \"vue\";\n52: import { RouterLink } from \"vue-router\";\n53: import AppLayout from \"@/components/AppLayout.vue\";\n54: import { getNotifications, markAllNotificationsRead, markNotificationRead } from \"@/data/store\";\n55: import type { FGNotification } from \"@/mock-data/types\";\n56: \n57: const items = computed(() => getNotifications());\n58: \n59: onMounted(() => setTimeout(() => markAllNotificationsRead(), 800));\n60: \n61: function iconFor(t: FGNotification[\"type\"]) {\n62:   return { DM: \"💬\", Reply: \"↩️\", Mention: \"@\", Event: \"📅\", Mentor: \"🤝\" }[t] ?? \"🔔\";\n63: }\n64: \n65: function linkFor(n: FGNotification): string | null {\n66:   switch (n.document_type) {\n67:     case \"GP Discussion\":\n68:       return `/posts/${n.document_name}`;\n69:     case \"FG DM Thread\":\n70:       return `/messages/${n.document_name}`;\n71:     case \"FG Event\":\n72:       return \"/events\";\n73:     case \"FG Mentor Match\":\n74:       return \"/mentors\";\n75:     default:\n76:       return null;\n77:   }\n78: }\n79: </script>\n\n(End of file - total 79 lines)\n</content>",
