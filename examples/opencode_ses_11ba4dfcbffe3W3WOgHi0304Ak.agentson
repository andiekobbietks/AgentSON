      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\PostDetailView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout :space-context-id=\"post?.project\">\n3:     <div class=\"max-w-[720px] mx-auto px-4 md:px-8 py-6\">\n4:       <div v-if=\"!post\" class=\"p-12 text-center\">\n5:         <h2 class=\"text-[18px] font-semibold mb-2\">Post not found</h2>\n6:         <RouterLink to=\"/\" class=\"text-primary underline\">Back home</RouterLink>\n7:       </div>\n8:       <template v-else>\n9:         <RouterLink\n10:           v-if=\"project\"\n11:           :to=\"`/spaces/${project.id}`\"\n12:           class=\"inline-flex items-center gap-1 text-[12px] text-muted-foreground hover:text-foreground mb-4\"\n13:         >\n14:           ← {{ project.icon }} {{ project.title }}\n15:         </RouterLink>\n16: \n17:         <article class=\"rounded-xl bg-card border border-border p-6\">\n18:           <div class=\"flex items-center gap-3 mb-4\">\n19:             <AppAvatar :user-id=\"post.author_id\" :size=\"40\" />\n20:             <div>\n21:               <RouterLink\n22:                 :to=\"`/members/${post.author_id}`\"\n23:                 class=\"block text-[14px] font-semibold leading-tight hover:text-primary\"\n24:               >\n25:                 {{ getUser(post.author_id)?.full_name }}\n26:               </RouterLink>\n27:               <div class=\"text-[12px] text-muted-foreground\">{{ formatDate(post.created_at) }}</div>\n28:             </div>\n29:             <div v-if=\"sent\" class=\"ml-auto\">\n30:               <SentimentBadge :sentiment=\"sent\" />\n31:             </div>\n32:           </div>\n33: \n34:           <h1 class=\"text-[24px] font-bold leading-tight mb-3\">{{ post.title }}</h1>\n35:           <div\n36:             class=\"text-[15px] leading-relaxed text-secondary-foreground [&_p]:mb-3 [&_em]:italic\"\n37:             v-html=\"post.content\"\n38:           />\n39: \n40:           <!-- Reactions -->\n41:           <div class=\"mt-5 flex flex-wrap items-center gap-1.5\">\n42:             <button\n43:               v-for=\"emoji in QUICK_EMOJIS\"\n44:               :key=\"emoji\"\n45:               class=\"h-7 px-2.5 rounded-full border text-[13px] inline-flex items-center gap-1 transition-colors\"\n46:               :class=\"\n47:                 myReactions.has(emoji)\n48:                   ? 'bg-primary-soft border-primary/40 text-primary-soft-foreground'\n49:                   : 'bg-card border-border hover:bg-secondary'\n50:               \"\n51:               @click=\"toggleReaction('GP Discussion', postId, emoji)\"\n52:             >\n53:               <span>{{ emoji }}</span>\n54:               <span v-if=\"(reactionCounts[emoji] ?? 0) > 0\" class=\"text-[12px] font-semibold\">{{\n55:                 reactionCounts[emoji]\n56:               }}</span>\n57:             </button>\n58:           </div>\n59:         </article>\n60: \n61:         <!-- Comments -->\n62:         <section class=\"mt-6\">\n63:           <h2 class=\"text-[16px] font-semibold mb-3\">\n64:             {{ comments.length }} {{ comments.length === 1 ? \"comment\" : \"comments\" }}\n65:           </h2>\n66: \n67:           <!-- Reply composer -->\n68:           <form\n69:             class=\"rounded-xl bg-card border border-border p-3 mb-4 focus-within:border-border-strong\"\n70:             @submit.prevent=\"submitReply\"\n71:           >\n72:             <div class=\"flex gap-3\">\n73:               <AppAvatar :user-id=\"currentUserId\" :size=\"32\" />\n74:               <div class=\"flex-1\">\n75:                 <textarea\n76:                   v-model=\"reply\"\n77:                   placeholder=\"Add a comment…\"\n78:                   rows=\"2\"\n79:                   class=\"w-full bg-transparent text-[14px] outline-none resize-none placeholder:text-muted-foreground\"\n80:                 />\n81:                 <div class=\"flex justify-end\">\n82:                   <button\n83:                     type=\"submit\"\n84:                     :disabled=\"!reply.trim()\"\n85:                     class=\"h-8 px-4 rounded-full bg-primary text-primary-foreground text-[13px] font-semibold disabled:opacity-40\"\n86:                   >\n87:                     Post\n88:                   </button>\n89:                 </div>\n90:               </div>\n91:             </div>\n92:           </form>\n93: \n94:           <div class=\"flex flex-col gap-3\">\n95:             <div\n96:               v-for=\"c in comments\"\n97:               :key=\"c.id\"\n98:               class=\"rounded-xl bg-card border border-border p-4\"\n99:             >\n100:               <div class=\"flex items-center gap-2.5 mb-2\">\n101:                 <AppAvatar :user-id=\"c.author_id\" :size=\"28\" />\n102:                 <div class=\"text-[13px] font-semibold\">{{ getUser(c.author_id)?.full_name }}</div>\n103:                 <span class=\"text-[11px] text-muted-foreground\">{{\n104:                   formatDateTime(c.created_at)\n105:                 }}</span>\n106:               </div>\n107:               <div\n108:                 class=\"text-[14px] leading-relaxed text-secondary-foreground [&_p]:mb-2\"\n109:                 v-html=\"c.content\"\n110:               />\n111:             </div>\n112:           </div>\n113:         </section>\n114: \n115:         <!-- Similar posts -->\n116:         <aside v-if=\"similar.length\" class=\"mt-8 rounded-xl bg-card border border-border p-5\">\n117:           <div class=\"flex items-center gap-2 mb-3\">\n118:             <span class=\"text-primary\">✨</span>\n119:             <h3 class=\"text-[14px] font-semibold\">Similar conversations</h3>\n120:             <span\n121:               class=\"ml-auto text-[11px] text-muted-foreground\"\n122:               title=\"Mocked — production uses EmbeddingGemma + vector search.\"\n123:               >mocked</span\n124:             >\n125:           </div>\n126:           <ul class=\"flex flex-col gap-2\">\n127:             <li v-for=\"s in similar\" :key=\"s.id\">\n128:               <RouterLink\n129:                 :to=\"`/posts/${s.id}`\"\n130:                 class=\"text-[13px] text-secondary-foreground hover:text-primary\"\n131:                 >→ {{ s.title }}</RouterLink\n132:               >\n133:             </li>\n134:           </ul>\n135:         </aside>\n136:       </template>\n137:     </div>\n138:   </AppLayout>\n139: </template>\n140: \n141: <script setup lang=\"ts\">\n142: import { ref, computed } from \"vue\";\n143: import { RouterLink, useRoute } from \"vue-router\";\n144: import AppLayout from \"@/components/AppLayout.vue\";\n145: import AppAvatar from \"@/components/AppAvatar.vue\";\n146: import SentimentBadge from \"@/components/SentimentBadge.vue\";\n147: import {\n148:   createComment,\n149:   currentUserId,\n150:   findSimilarPosts,\n151:   getAISettings,\n152:   getCommentsFor,\n153:   getDiscussion,\n154:   getProject,\n155:   getReactionsFor,\n156:   getUser,\n157:   mockSentiment,\n158:   toggleReaction,\n159: } from \"@/data/store\";\n160: \n161: const QUICK_EMOJIS = [\"💛\", \"🎉\", \"🤗\", \"👏\", \"💪\"];\n162: \n163: const route = useRoute();\n164: const postId = computed(() => route.params.postId as string);\n165: const post = computed(() => getDiscussion(postId.value));\n166: const project = computed(() => (post.value ? getProject(post.value.project) : null));\n167: const comments = computed(() => getCommentsFor(postId.value));\n168: const ai = getAISettings();\n169: const sent = computed(() =>\n170:   post.value && ai.enable_sentiment ? mockSentiment(post.value.content) : null,\n171: );\n172: const similar = computed(() => (ai.enable_vector_search ? findSimilarPosts(postId.value) : []));\n173: const reactions = computed(() => getReactionsFor(\"GP Discussion\", postId.value));\n174: const myReactions = computed(\n175:   () => new Set(reactions.value.filter((r) => r.user === currentUserId).map((r) => r.emoji)),\n176: );\n177: const reactionCounts = computed(() =>\n178:   reactions.value.reduce<Record<string, number>>((m, r) => {\n179:     m[r.emoji] = (m[r.emoji] ?? 0) + 1;\n180:     return m;\n181:   }, {}),\n182: );\n183: \n184: const reply = ref(\"\");\n185: \n186: function submitReply() {\n187:   if (!reply.value.trim()) return;\n188:   createComment({\n189:     discussion_id: postId.value,\n190:     content: `<p>${reply.value.replace(/\\n/g, \"</p><p>\")}</p>`,\n191:   });\n192:   reply.value = \"\";\n193: }\n194: \n195: function formatDate(iso: string) {\n196:   return new Date(iso).toLocaleDateString(undefined, {\n197:     month: \"short\",\n198:     day: \"numeric\",\n199:     year: \"numeric\",\n200:   });\n201: }\n202: function formatDateTime(iso: string) {\n203:   return new Date(iso).toLocaleString(undefined, {\n204:     month: \"short\",\n205:     day: \"numeric\",\n206:     hour: \"numeric\",\n207:     minute: \"2-digit\",\n208:   });\n209: }\n210: </script>\n\n(End of file - total 210 lines)\n</content>",
      "status": "success",
      "timestamp": 1781947643707
    },
