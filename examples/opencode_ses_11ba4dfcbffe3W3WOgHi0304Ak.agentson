      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\EventsView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout>\n3:     <div class=\"max-w-[720px] mx-auto px-4 md:px-8 py-6\">\n4:       <header class=\"mb-5\">\n5:         <h1 class=\"text-[24px] font-bold leading-tight\">Events</h1>\n6:         <p class=\"text-[14px] text-muted-foreground mt-0.5\">\n7:           Show up, meet people, ask questions. RSVPs are casual.\n8:         </p>\n9:       </header>\n10: \n11:       <div class=\"flex flex-col gap-2\">\n12:         <article\n13:           v-for=\"e in events\"\n14:           :key=\"e.id\"\n15:           class=\"rounded-xl bg-card border border-border p-5 flex gap-4 hover:border-border-strong transition-colors\"\n16:         >\n17:           <div\n18:             class=\"size-14 rounded-lg bg-secondary flex flex-col items-center justify-center shrink-0\"\n19:           >\n20:             <div class=\"text-[10px] font-bold tracking-wider text-muted-foreground\">\n21:               {{ getMonth(e.starts_on) }}\n22:             </div>\n23:             <div class=\"text-[20px] font-bold leading-none\">{{ getDay(e.starts_on) }}</div>\n24:           </div>\n25: \n26:           <div class=\"flex-1 min-w-0\">\n27:             <div class=\"flex items-center gap-1.5 text-[12px] text-muted-foreground mb-1\">\n28:               <span\n29:                 class=\"px-2 py-0.5 rounded-full bg-secondary text-secondary-foreground font-medium\"\n30:                 >{{ e.event_type }}</span\n31:               >\n32:               <template v-if=\"getProject(e.space)\">\n33:                 <span>·</span>\n34:                 <span>{{ getProject(e.space)?.icon }} {{ getProject(e.space)?.title }}</span>\n35:               </template>\n36:             </div>\n37:             <h2 class=\"text-[16px] font-semibold leading-snug\">{{ e.title }}</h2>\n38:             <p class=\"text-[13px] text-muted-foreground mt-1 line-clamp-2\">{{ e.description }}</p>\n39: \n40:             <div class=\"mt-2 flex flex-col gap-1 text-[12px] text-muted-foreground\">\n41:               <div class=\"inline-flex items-center gap-1.5\">🕐 {{ formatDate(e.starts_on) }}</div>\n42:               <div class=\"inline-flex items-center gap-1.5\">\n43:                 <template v-if=\"e.location_type === 'In Person'\"\n44:                   >📍 {{ e.physical_address }}</template\n45:                 >\n46:                 <template v-else-if=\"e.location_type === 'Online (BigBlueButton)'\"\n47:                   >📹 BigBlueButton · {{ e.bbb_meeting_id }}</template\n48:                 >\n49:                 <template v-else>🔗 {{ e.external_link }}</template>\n50:               </div>\n51:               <div v-if=\"getUser(e.hosted_by)\" class=\"text-muted-foreground\">\n52:                 Hosted by {{ getUser(e.hosted_by)?.full_name }}\n53:               </div>\n54:             </div>\n55: \n56:             <div class=\"mt-3 flex items-center justify-between gap-2\">\n57:               <span class=\"text-[12px] text-muted-foreground\"\n58:                 >{{ goingCount(e.id) }}/{{ e.capacity }} going</span\n59:               >\n60:               <div class=\"flex gap-1\">\n61:                 <button\n62:                   v-for=\"s in ['Going', 'Maybe', 'Not Going'] as const\"\n63:                   :key=\"s\"\n64:                   class=\"text-[12px] h-7 px-3 rounded-full border transition-colors\"\n65:                   :class=\"\n66:                     getMyRSVP(e.id) === s\n67:                       ? 'bg-primary text-primary-foreground border-primary'\n68:                       : 'border-border text-secondary-foreground hover:bg-secondary'\n69:                   \"\n70:                   @click=\"setRSVP(e.id, s)\"\n71:                 >\n72:                   {{ s }}\n73:                 </button>\n74:               </div>\n75:             </div>\n76:           </div>\n77:         </article>\n78:       </div>\n79:     </div>\n80:   </AppLayout>\n81: </template>\n82: \n83: <script setup lang=\"ts\">\n84: import { computed } from \"vue\";\n85: import AppLayout from \"@/components/AppLayout.vue\";\n86: import { getEvents, getAttendees, getMyRSVP, getProject, getUser, setRSVP } from \"@/data/store\";\n87: import type { RSVPStatus } from \"@/mock-data/types\";\n88: \n89: const events = computed(() => getEvents());\n90: \n91: function getMonth(iso: string) {\n92:   return new Date(iso).toLocaleString(undefined, { month: \"short\" }).toUpperCase();\n93: }\n94: function getDay(iso: string) {\n95:   return new Date(iso).getDate();\n96: }\n97: function formatDate(iso: string) {\n98:   return new Date(iso).toLocaleString(undefined, {\n99:     weekday: \"short\",\n100:     hour: \"numeric\",\n101:     minute: \"2-digit\",\n102:   });\n103: }\n104: function goingCount(eventId: string) {\n105:   return getAttendees(eventId).filter((a) => a.rsvp_status === \"Going\").length;\n106: }\n107: </script>\n\n(End of file - total 107 lines)\n</content>",
