      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\DocsView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout>\n3:     <div class=\"max-w-[720px] mx-auto px-4 md:px-8 py-6\">\n4:       <h1 class=\"text-[24px] font-bold leading-tight\">Docs</h1>\n5:       <p class=\"text-[14px] text-muted-foreground mt-1 mb-6\">\n6:         These docs live as real markdown files at\n7:         <code class=\"font-mono text-[12px] bg-secondary px-1.5 py-0.5 rounded\">/docs</code> in the\n8:         repo.\n9:       </p>\n10:       <ul class=\"flex flex-col gap-2\">\n11:         <li\n12:           v-for=\"d in docs\"\n13:           :key=\"d.file\"\n14:           class=\"flex items-start gap-3 rounded-xl bg-card border border-border p-4 hover:border-border-strong transition-colors\"\n15:         >\n16:           <span class=\"text-muted-foreground mt-0.5 shrink-0\">📄</span>\n17:           <div>\n18:             <div class=\"text-[14px] font-semibold\">{{ d.title }}</div>\n19:             <div class=\"text-[12px] text-muted-foreground mt-0.5\">\n20:               /docs/{{ d.file }} — {{ d.desc }}\n21:             </div>\n22:           </div>\n23:         </li>\n24:       </ul>\n25:     </div>\n26:   </AppLayout>\n27: </template>\n28: \n29: <script setup lang=\"ts\">\n30: import AppLayout from \"@/components/AppLayout.vue\";\n31: \n32: const docs = [\n33:   { file: \"00_OVERVIEW.md\", title: \"Overview\", desc: \"What this prototype is and isn't.\" },\n34:   {\n35:     file: \"01_SCHEMA_MAPPING_TO_FRAPPE.md\",\n36:     title: \"Schema mapping to Frappe\",\n37:     desc: \"Every TypeScript type ↔ real Frappe DocType, field-for-field.\",\n38:   },\n39:   {\n40:     file: \"02_WHATS_MOCKED_VS_REAL.md\",\n41:     title: \"What's mocked vs real\",\n42:     desc: \"Sentiment classifier and vector search are keyword stubs.\",\n43:   },\n44:   {\n45:     file: \"03_PORTING_GUIDE.md\",\n46:     title: \"Porting guide (high-level)\",\n47:     desc: \"Steps to move to Frappe + custom fg_companion app.\",\n48:   },\n49:   {\n50:     file: \"04_FRAPPE_TRANSLATION.md\",\n51:     title: \"Frappe translation (deep dive)\",\n52:     desc: \"Concrete Python: DocType JSON, hooks.py, Custom Fields, doc_events, REST/RPC swap.\",\n53:   },\n54:   {\n55:     file: \"05_CIRCLE_TO_FRAPPE_MAPPING.md\",\n56:     title: \"Circle.so → Frappe feature map\",\n57:     desc: \"Every Circle.so surface and its exact Frappe equivalent.\",\n58:   },\n59:   {\n60:     file: \"06_FRAPPE_ECOSYSTEM_TWIN.md\",\n61:     title: \"Frappe ecosystem as a Circle.so twin\",\n62:     desc: \"Raven, Helpdesk, Wiki, Insights, Builder — which app covers which Circle feature.\",\n63:   },\n64:   {\n65:     file: \"07_ADR_001_FRAPPE_PLATFORM.md\",\n66:     title: \"ADR-0001 — Platform decision\",\n67:     desc: \"Architecture Decision Record (UK GDS format) adopting Frappe + Gameplan + LMS.\",\n68:   },\n69: ];\n70: </script>\n\n(End of file - total 70 lines)\n</content>",
