      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\SpaceView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout :space-context-id=\"spaceId\">\n3:     <div class=\"max-w-[720px] mx-auto px-4 md:px-8 py-6\">\n4:       <div v-if=\"!project\" class=\"p-12 text-center\">\n5:         <h2 class=\"text-[18px] font-semibold mb-2\">Space not found</h2>\n6:         <RouterLink to=\"/\" class=\"text-primary underline\">Back home</RouterLink>\n7:       </div>\n8:       <template v-else>\n9:         <header class=\"mb-5\">\n10:           <div class=\"flex items-start justify-between gap-3\">\n11:             <div>\n12:               <div class=\"text-[32px] leading-none mb-1\">{{ project.icon }}</div>\n13:               <h1 class=\"text-[20px] font-bold leading-tight\">{{ project.title }}</h1>\n14:               <p class=\"text-[13px] text-muted-foreground mt-1\">{{ project.description }}</p>\n15:               <div class=\"text-[12px] text-muted-foreground mt-2\">\n16:                 {{ project.discussions_count }} discussions ·\n17:                 {{ project.is_private ? \"Private\" : \"Public\" }}\n18:               </div>\n19:             </div>\n20:             <button\n21:               class=\"h-8 px-3 rounded-full bg-primary text-primary-foreground text-[13px] font-semibold inline-flex items-center gap-1 hover:opacity-90 shrink-0\"\n22:               @click=\"showModal = true\"\n23:             >\n24:               + Post\n25:             </button>\n26:           </div>\n27:         </header>\n28: \n29:         <div class=\"flex flex-col gap-2\">\n30:           <div v-if=\"posts.length === 0\" class=\"py-20 text-center\">\n31:             <div class=\"text-[64px] leading-none mb-3\">{{ project.icon }}</div>\n32:             <div class=\"text-[16px] font-semibold mb-1\">Nothing here yet</div>\n33:             <div class=\"text-[14px] text-muted-foreground max-w-[280px] mx-auto mb-4\">\n34:               Be the first to share something with the group 👋\n35:             </div>\n36:             <button\n37:               class=\"h-9 px-4 rounded-full bg-primary text-primary-foreground text-[13px] font-semibold\"\n38:               @click=\"showModal = true\"\n39:             >\n40:               Start a discussion\n41:             </button>\n42:           </div>\n43:           <PostCard v-for=\"p in posts\" :key=\"p.id\" :post=\"p\" :show-space=\"false\" />\n44:         </div>\n45:       </template>\n46:     </div>\n47: \n48:     <NewPostModal :open=\"showModal\" :default-space-id=\"spaceId\" @close=\"showModal = false\" />\n49:   </AppLayout>\n50: </template>\n51: \n52: <script setup lang=\"ts\">\n53: import { ref, computed } from \"vue\";\n54: import { RouterLink, useRoute } from \"vue-router\";\n55: import AppLayout from \"@/components/AppLayout.vue\";\n56: import PostCard from \"@/components/PostCard.vue\";\n57: import NewPostModal from \"@/components/NewPostModal.vue\";\n58: import { getDiscussions, getProject } from \"@/data/store\";\n59: \n60: const route = useRoute();\n61: const spaceId = computed(() => route.params.spaceId as string);\n62: const project = computed(() => getProject(spaceId.value));\n63: const posts = computed(() => getDiscussions(spaceId.value));\n64: const showModal = ref(false);\n65: </script>\n\n(End of file - total 65 lines)\n</content>",
