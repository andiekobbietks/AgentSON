div>\n43:           <div v-else class=\"flex flex-col gap-2\">\n44:             <PostCard v-for=\"p in posts\" :key=\"p.id\" :post=\"p\" />\n45:           </div>\n46:         </section>\n47:       </template>\n48:     </div>\n49:   </AppLayout>\n50: </template>\n51: \n52: <script setup lang=\"ts\">\n53: import { computed } from \"vue\";\n54: import { RouterLink, useRoute, useRouter } from \"vue-router\";\n55: import AppLayout from \"@/components/AppLayout.vue\";\n56: import AppAvatar from \"@/components/AppAvatar.vue\";\n57: import PostCard from \"@/components/PostCard.vue\";\n58: import { getUser, getRecentPostsByUser, openOrCreateDMWith, currentUserId } from \"@/data/store\";\n59: \n60: const route = useRoute();\n61: const router = useRouter();\n62: const userId = computed(() => route.params.userId as string);\n63: const u = computed(() => getUser(userId.value));\n64: const posts = computed(() => getRecentPostsByUser(userId.value));\n65: const isMe = computed(() => userId.value === currentUserId);\n66: \n67: function messageMember() {\n68:   const t = openOrCreateDMWith(userId.value);\n69:   router.push(`/messages/${t.id}`);\n70: }\n71: </script>\n\n(End of file - total 71 lines)\n</content>",
