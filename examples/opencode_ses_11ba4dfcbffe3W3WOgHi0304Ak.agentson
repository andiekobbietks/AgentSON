      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\SettingsView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout>\n3:     <div class=\"max-w-[860px] mx-auto px-4 md:px-8 py-6\">\n4:       <h1 class=\"text-[24px] font-bold leading-tight mb-1\">Settings</h1>\n5:       <p class=\"text-[13px] text-muted-foreground mb-5\">\n6:         Signed in as <strong>{{ me.full_name }}</strong> ({{ currentUserId }}) — demo account.\n7:         <RouterLink :to=\"`/members/${currentUserId}`\" class=\"underline\"\n8:           >View public profile →</RouterLink\n9:         >\n10:       </p>\n11: \n12:       <div class=\"grid grid-cols-1 md:grid-cols-[200px_1fr] gap-5\">\n13:         <!-- Tab nav -->\n14:         <nav class=\"flex md:flex-col gap-1 text-[13px]\">\n15:           <button\n16:             v-for=\"t in TABS\"\n17:             :key=\"t.id\"\n18:             type=\"button\"\n19:             class=\"h-9 px-3 rounded-md inline-flex items-center gap-2 text-left transition-colors\"\n20:             :class=\"\n21:               tab === t.id\n22:                 ? 'bg-primary-soft text-primary-soft-foreground font-semibold'\n23:                 : 'text-secondary-foreground hover:bg-secondary'\n24:             \"\n25:             @click=\"tab = t.id\"\n26:           >\n27:             {{ t.icon }} {{ t.label }}\n28:           </button>\n29:         </nav>\n30: \n31:         <!-- Tab content -->\n32:         <section class=\"rounded-xl bg-card border border-border p-5 relative\">\n33:           <div\n34:             v-if=\"saved\"\n35:             class=\"absolute top-3 right-3 text-[11px] bg-success/15 text-success px-2 py-0.5 rounded-full\"\n36:           >\n37:             Saved\n38:           </div>\n39: \n40:           <!-- Profile -->\n41:           <div v-if=\"tab === 'profile'\" class=\"flex flex-col gap-4\">\n42:             <h2 class=\"text-[16px] font-semibold\">Public profile</h2>\n43:             <label class=\"flex flex-col gap-1.5\">\n44:               <span class=\"text-[12px] font-semibold text-secondary-foreground\">Full name</span>\n45:               <input\n46:                 :defaultValue=\"me.full_name\"\n47:                 class=\"h-10 px-3 rounded-md border border-border bg-background text-[14px]\"\n48:                 @blur=\"\n49:                   (e) => {\n50:                     updateProfile({ full_name: (e.target as HTMLInputElement).value });\n51:                     flash();\n52:                   }\n53:                 \"\n54:               />\n55:             </label>\n56:             <label class=\"flex flex-col gap-1.5\">\n57:               <span class=\"text-[12px] font-semibold text-secondary-foreground\"\n58:                 >Headline / bio (1 line)</span\n59:               >\n60:               <input\n61:                 :defaultValue=\"me.bio\"\n62:                 class=\"h-10 px-3 rounded-md border border-border bg-background text-[14px]\"\n63:                 @blur=\"\n64:                   (e) => {\n65:                     updateProfile({ bio: (e.target as HTMLInputElement).value });\n66:                     flash();\n67:                   }\n68:                 \"\n69:               />\n70:             </label>\n71:             <label class=\"flex flex-col gap-1.5\">\n72:               <span class=\"text-[12px] font-semibold text-secondary-foreground\"\n73:                 >About (longer)</span\n74:               >\n75:               <textarea\n76:                 :defaultValue=\"me.readme\"\n77:                 rows=\"5\"\n78:                 class=\"px-3 py-2 rounded-md border border-border bg-background text-[14px] resize-none\"\n79:                 @blur=\"\n80:                   (e) => {\n81:                     updateProfile({ readme: (e.target as HTMLTextAreaElement).value });\n82:                     flash();\n83:                   }\n84:                 \"\n85:               />\n86:             </label>\n87:             <label class=\"flex flex-col gap-1.5\">\n88:               <span class=\"text-[12px] font-semibold text-secondary-foreground\"\n89:                 >Avatar background colour</span\n90:               >\n91:               <input\n92:                 type=\"color\"\n93:                 :defaultValue=\"me.image_background_color\"\n94:                 class=\"h-10 w-20 rounded-md border border-border bg-background\"\n95:                 @change=\"\n96:                   (e) => {\n97:                     updateProfile({ image_background_color: (e.target as HTMLInputElement).value });\n98:                     flash();\n99:                   }\n100:                 \"\n101:               />\n102:             </label>\n103:           </div>\n104: \n105:           <!-- Notifications -->\n106:           <div v-if=\"tab === 'notifications'\" class=\"flex flex-col gap-1\">\n107:             <h2 class=\"text-[16px] font-semibold mb-3\">Notifications</h2>\n108:             <div\n109:               class=\"text-[11px] uppercase tracking-wider font-semibold text-muted-foreground mt-3 mb-1\"\n110:             >\n111:               Email\n112:             </div>\n113:             <Toggle\n114:               label=\"When someone @mentions me\"\n115:               :value=\"settings.email_on_mention\"\n116:               @change=\"\n117:                 (v) => {\n118:                   updateUserSettings({ email_on_mention: v });\n119:                   flash();\n120:                 }\n121:               \"\n122:             />\n123:             <Toggle\n124:               label=\"When someone replies to my post\"\n125:               :value=\"settings.email_on_reply\"\n126:               @change=\"\n127:                 (v) => {\n128:                   updateUserSettings({ email_on_reply: v });\n129:                   flash();\n130:                 }\n131:               \"\n132:             />\n133:             <Toggle\n134:               label=\"Weekly community digest\"\n135:               :value=\"settings.email_weekly_digest\"\n136:               @change=\"\n137:                 (v) => {\n138:                   updateUserSettings({ email_weekly_digest: v });\n139:                   flash();\n140:                 }\n141:               \"\n142:             />\n143:             <div\n144:               class=\"text-[11px] uppercase tracking-wider font-semibold text-muted-foreground mt-3 mb-1\"\n145:             >\n146:               Push\n147:             </div>\n148:             <Toggle\n149:               label=\"Direct messages\"\n150:               :value=\"settings.push_on_dm\"\n151:               @change=\"\n152:                 (v) => {\n153:                   updateUserSettings({ push_on_dm: v });\n154:                   flash();\n155:                 }\n156:               \"\n157:             />\n158:             <Toggle\n159:               label=\"@mentions\"\n160:               :value=\"settings.push_on_mention\"\n161:               @change=\"\n162:                 (v) => {\n163:                   updateUserSettings({ push_on_mention: v });\n164:                   flash();\n165:                 }\n166:               \"\n167:             />\n168:           </div>\n169: \n170:           <!-- Privacy -->\n171:           <div v-if=\"tab === 'privacy'\" class=\"flex flex-col gap-1\">\n172:             <h2 class=\"text-[16px] font-semibold mb-3\">Privacy</h2>\n173:             <Toggle\n174:               label=\"Show me in the member directory\"\n175:               :value=\"settings.show_in_member_directory\"\n176:               @change=\"\n177:                 (v) => {\n178:                   updateUserSettings({ show_in_member_directory: v });\n179:                   flash();\n180:                 }\n181:               \"\n182:             />\n183:             <Toggle\n184:               label=\"Allow direct messages from any member\"\n185:               :value=\"settings.allow_dm_from_anyone\"\n186:               @change=\"\n187:                 (v) => {\n188:                   updateUserSettings({ allow_dm_from_anyone: v });\n189:                   flash();\n190:                 }\n191:               \"\n192:             />\n193:           </div>\n194: \n195:           <!-- Appearance -->\n196:           <div v-if=\"tab === 'appearance'\" class=\"flex flex-col gap-4\">\n197:             <h2 class=\"text-[16px] font-semibold\">Appearance &amp; language</h2>\n198:             <label class=\"flex flex-col gap-1.5\">\n199:               <span class=\"text-[12px] font-semibold text-secondary-foreground\">Theme</span>\n200:               <select\n201:                 :value=\"settings.theme\"\n202:                 class=\"h-10 px-2 rounded-md border border-border bg-background text-[14px]\"\n203:                 @change=\"\n204:                   (e) => {\n205:                     updateUserSettings({\n206:                       theme: (e.target as HTMLSelectElement).value as 'system' | 'light' | 'dark',\n207:                     });\n208:                     flash();\n209:                   }\n210:                 \"\n211:               >\n212:                 <option value=\"system\">System</option>\n213:                 <option value=\"light\">Light</option>\n214:                 <option value=\"dark\">Dark</option>\n215:               </select>\n216:             </label>\n217:             <label class=\"flex flex-col gap-1.5\">\n218:               <span class=\"text-[12px] font-semibold text-secondary-foreground\">Language</span>\n219:               <select\n220:                 :value=\"settings.language\"\n221:                 class=\"h-10 px-2 rounded-md border border-border bg-background text-[14px]\"\n222:                 @change=\"\n223:                   (e) => {\n224:                     updateUserSettings({\n225:                       language: (e.target as HTMLSelectElement).value as 'en' | 'es' | 'fr',\n226:                     });\n227:                     flash();\n228:                   }\n229:                 \"\n230:               >\n231:                 <option value=\"en\">English</option>\n232:                 <option value=\"es\">Español</option>\n233:                 <option value=\"fr\">Français</option>\n234:               </select>\n235:             </label>\n236:             <div class=\"flex flex-col gap-1.5\">\n237:               <span class=\"text-[12px] font-semibold text-secondary-foreground\">Timezone</span>\n238:               <div\n239:                 class=\"h-10 px-3 rounded-md border border-border bg-background flex items-center gap-2 text-[13px] text-muted-foreground\"\n240:               >\n241:                 🌐 {{ settings.timezone }}\n242:               </div>\n243:             </div>\n244:           </div>\n245: \n246:           <!-- Sign-in & SSO -->\n247:           <div v-if=\"tab === 'signin'\" class=\"flex flex-col gap-4\">\n248:             <div>\n249:               <h2 class=\"text-[16px] font-semibold\">Sign-in methods</h2>\n250:               <p class=\"text-[12px] text-muted-foreground mt-1\">\n251:                 Choose how members sign in. Each provider maps to a Frappe\n252:                 <code class=\"font-mono\">Social Login Key</code> row.\n253:               </p>\n254:             </div>\n255:             <div class=\"rounded-xl border border-border bg-card divide-y divide-border\">\n256:               <div v-for=\"p in ssoProviders\" :key=\"p.id\" class=\"flex items-start gap-3 p-3.5\">\n257:                 <div\n258:                   class=\"size-9 rounded-lg bg-secondary flex items-center justify-center text-[15px]\"\n259:                 >\n260:                   {{ providerIcon(p.id) }}\n261:                 </div>\n262:                 <div class=\"flex-1 min-w-0\">\n263:                   <div class=\"flex items-center gap-2\">\n264:                     <div class=\"text-[14px] font-semibold\">{{ p.label }}</div>\n265:                     <span\n266:                       v-if=\"p.enabled\"\n267:                       class=\"text-[10px] uppercase tracking-wider font-bold text-success\"\n268:                       >Enabled</span\n269:                     >\n270:                   </div>\n271:                   <div class=\"text-[12px] text-muted-foreground mt-0.5\">{{ p.notes }}</div>\n272:                   <button\n273:                     v-if=\"p.enabled && p.id !== 'email'\"\n274:                     type=\"button\"\n275:                     class=\"mt-2 inline-flex h-7 px-3 rounded-md border border-border text-[12px] font-semibold hover:bg-secondary\"\n276:                     @click=\"alert(`In production this would launch the ${p.label} OAuth flow.`)\"\n277:                   >\n278:                     Test sign-in\n279:                   </button>\n280:                 </div>\n281:                 <button\n282:                   type=\"button\"\n283:                   role=\"switch\"\n284:                   :aria-checked=\"p.enabled\"\n285:                   :disabled=\"p.id === 'email'\"\n286:                   class=\"relative h-5 w-9 rounded-full transition-colors mt-1 disabled:opacity-50 disabled:cursor-not-allowed\"\n287:                   :class=\"p.enabled ? 'bg-primary' : 'bg-secondary'\"\n288:                   @click=\"\n289:                     () => {\n290:                       updateSSOProvider(p.id, { enabled: !p.enabled });\n291:                       flash();\n292:                     }\n293:                   \"\n294:                 >\n295:                   <span\n296:                     class=\"absolute top-0.5 size-4 rounded-full bg-card shadow transition-transform\"\n297:                     :class=\"p.enabled ? 'translate-x-[18px]' : 'translate-x-0.5'\"\n298:                   />\n299:                 </button>\n300:               </div>\n301:             </div>\n302:           </div>\n303:         </section>\n304:       </div>\n305:     </div>\n306:   </AppLayout>\n307: </template>\n308: \n309: <script setup lang=\"ts\">\n310: import { ref } from \"vue\";\n311: import { RouterLink } from \"vue-router\";\n312: import AppLayout from \"@/components/AppLayout.vue\";\n313: import Toggle from \"@/components/Toggle.vue\";\n314: import {\n315:   getSSOProviders,\n316:   getUser,\n317:   getUserSettings,\n318:   updateProfile,\n319:   updateSSOProvider,\n320:   updateUserSettings,\n321:   currentUserId,\n322: } from \"@/data/store\";\n323: import type { SSOProviderId } from \"@/mock-data/types\";\n324: \n325: const me = getUser(currentUserId)!;\n326: const settings = getUserSettings();\n327: const ssoProviders = getSSOProviders();\n328: const tab = ref<\"profile\" | \"notifications\" | \"privacy\" | \"appearance\" | \"signin\">(\"profile\");\n329: const saved = ref(false);\n330: \n331: const TABS = [\n332:   { id: \"profile\", label: \"Profile\", icon: \"👤\" },\n333:   { id: \"notifications\", label: \"Notifications\", icon: \"🔔\" },\n334:   { id: \"privacy\", label: \"Privacy\", icon: \"🔒\" },\n335:   { id: \"appearance\", label: \"Appearance\", icon: \"🎨\" },\n336:   { id: \"signin\", label: \"Sign-in & SSO\", icon: \"🔑\" },\n337: ] as const;\n338: \n339: function flash() {\n340:   saved.value = true;\n341:   setTimeout(() => (saved.value = false), 1500);\n342: }\n343: \n344: function providerIcon(id: string) {\n345:   return (\n346:     { google: \"🟦\", microsoft: \"🟪\", github: \"🐙\", discord: \"💜\", apple: \"\", email: \"✉️\" }[id] ??\n347:     \"🔑\"\n348:   );\n349: }\n350: </script>\n\n(End of file - total 350 lines)\n</content>",
