      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\CourseNewView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout>\n3:     <div class=\"max-w-[640px] mx-auto px-4 md:px-8 py-6\">\n4:       <RouterLink\n5:         to=\"/courses\"\n6:         class=\"inline-flex items-center gap-1 text-[12px] text-muted-foreground hover:text-foreground mb-3\"\n7:       >\n8:         ← All courses\n9:       </RouterLink>\n10:       <h1 class=\"text-[24px] font-bold leading-tight\">Create a course</h1>\n11:       <p class=\"text-[13px] text-muted-foreground mt-1 mb-5\">\n12:         Mirrors the <code class=\"font-mono\">LMS Course</code> DocType in frappe/lms. After creating\n13:         you'll be dropped onto the course page where you can add chapters and YouTube-video lessons.\n14:       </p>\n15: \n16:       <form\n17:         class=\"flex flex-col gap-4 bg-card border border-border rounded-xl p-5\"\n18:         @submit.prevent=\"submit\"\n19:       >\n20:         <label class=\"flex flex-col gap-1.5\">\n21:           <span class=\"text-[12px] font-semibold text-secondary-foreground\"\n22:             >Title <span class=\"text-destructive\">*</span></span\n23:           >\n24:           <input\n25:             v-model=\"title\"\n26:             required\n27:             placeholder=\"e.g. Surviving Freshers' Week\"\n28:             class=\"h-10 px-3 rounded-md border border-border bg-background text-[14px] outline-none focus:ring-2 focus:ring-primary/30\"\n29:           />\n30:         </label>\n31:         <label class=\"flex flex-col gap-1.5\">\n32:           <span class=\"text-[12px] font-semibold text-secondary-foreground\"\n33:             >Short introduction</span\n34:           >\n35:           <input\n36:             v-model=\"intro\"\n37:             placeholder=\"One sentence that appears on the card\"\n38:             class=\"h-10 px-3 rounded-md border border-border bg-background text-[14px] outline-none focus:ring-2 focus:ring-primary/30\"\n39:           />\n40:         </label>\n41:         <label class=\"flex flex-col gap-1.5\">\n42:           <span class=\"text-[12px] font-semibold text-secondary-foreground\">Description</span>\n43:           <textarea\n44:             v-model=\"desc\"\n45:             rows=\"4\"\n46:             placeholder=\"What learners will get out of this course\"\n47:             class=\"px-3 py-2 rounded-md border border-border bg-background text-[14px] outline-none focus:ring-2 focus:ring-primary/30 resize-none\"\n48:           />\n49:         </label>\n50:         <div class=\"grid grid-cols-2 gap-3\">\n51:           <label class=\"flex flex-col gap-1.5\">\n52:             <span class=\"text-[12px] font-semibold text-secondary-foreground\">Category</span>\n53:             <select\n54:               v-model=\"category\"\n55:               class=\"h-10 px-2 rounded-md border border-border bg-background text-[14px]\"\n56:             >\n57:               <option>Student Life</option>\n58:               <option>Writing</option>\n59:               <option>Money</option>\n60:               <option>Wellbeing</option>\n61:               <option>Career</option>\n62:             </select>\n63:           </label>\n64:           <label class=\"flex flex-col gap-1.5\">\n65:             <span class=\"text-[12px] font-semibold text-secondary-foreground\">Tags</span>\n66:             <input\n67:               v-model=\"tags\"\n68:               placeholder=\"comma, separated\"\n69:               class=\"h-10 px-3 rounded-md border border-border bg-background text-[14px]\"\n70:             />\n71:           </label>\n72:         </div>\n73:         <div class=\"flex items-center gap-2 pt-2\">\n74:           <button\n75:             type=\"submit\"\n76:             class=\"h-10 px-5 rounded-full bg-primary text-primary-foreground text-[14px] font-semibold\"\n77:           >\n78:             Create course\n79:           </button>\n80:           <RouterLink\n81:             to=\"/courses\"\n82:             class=\"h-10 px-4 rounded-full text-[14px] text-muted-foreground hover:bg-secondary inline-flex items-center\"\n83:             >Cancel</RouterLink\n84:           >\n85:         </div>\n86:       </form>\n87:     </div>\n88:   </AppLayout>\n89: </template>\n90: \n91: <script setup lang=\"ts\">\n92: import { ref } from \"vue\";\n93: import { RouterLink, useRouter } from \"vue-router\";\n94: import AppLayout from \"@/components/AppLayout.vue\";\n95: import { createCourse } from \"@/data/store\";\n96: \n97: const router = useRouter();\n98: const title = ref(\"\");\n99: const intro = ref(\"\");\n100: const desc = ref(\"\");\n101: const category = ref(\"Student Life\");\n102: const tags = ref(\"\");\n103: \n104: function submit() {\n105:   if (!title.value.trim()) return;\n106:   const c = createCourse({\n107:     title: title.value,\n108:     short_introduction: intro.value,\n109:     description: desc.value,\n110:     category: category.value,\n111:     tags: tags.value,\n112:   });\n113:   router.push(`/courses/${c.id}`);\n114: }\n115: </script>\n\n(End of file - total 115 lines)\n</content>",
