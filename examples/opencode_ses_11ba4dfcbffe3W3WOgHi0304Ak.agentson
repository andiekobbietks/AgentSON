      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\MentorsView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout>\n3:     <div class=\"max-w-[920px] mx-auto px-4 md:px-8 py-6\">\n4:       <header class=\"mb-5\">\n5:         <h1 class=\"text-[24px] font-bold leading-tight\">Mentor Match</h1>\n6:         <p class=\"text-[14px] text-muted-foreground mt-0.5\">\n7:           Mentors here are other students and staff who've been where you are.\n8:         </p>\n9:       </header>\n10: \n11:       <!-- My matches -->\n12:       <section class=\"mb-8\">\n13:         <h2 class=\"text-[14px] font-semibold text-muted-foreground uppercase tracking-wider mb-3\">\n14:           My matches\n15:         </h2>\n16:         <div class=\"flex flex-col gap-2\">\n17:           <div v-if=\"matches.length === 0\" class=\"text-[13px] text-muted-foreground\">\n18:             No matches yet — request one below.\n19:           </div>\n20:           <div\n21:             v-for=\"m in matches\"\n22:             :key=\"m.id\"\n23:             class=\"rounded-xl bg-card border border-border p-4 flex items-center gap-3\"\n24:           >\n25:             <AppAvatar :user-id=\"getOtherUserId(m)\" :size=\"40\" />\n26:             <div class=\"flex-1 min-w-0\">\n27:               <div class=\"text-[14px] font-semibold truncate\">\n28:                 {{ getUser(getOtherUserId(m))?.full_name }}\n29:                 <span class=\"text-muted-foreground font-normal ml-1\"\n30:                   >({{ m.mentee === currentUserId ? \"your mentor\" : \"your mentee\" }})</span\n31:                 >\n32:               </div>\n33:               <div class=\"text-[12px] text-muted-foreground truncate\">{{ m.match_notes }}</div>\n34:             </div>\n35:             <span\n36:               class=\"text-[11px] font-semibold px-2.5 py-0.5 rounded-full\"\n37:               :class=\"statusStyles[m.status]\"\n38:               >{{ m.status }}</span\n39:             >\n40:           </div>\n41:         </div>\n42:       </section>\n43: \n44:       <!-- Find a mentor -->\n45:       <section>\n46:         <h2 class=\"text-[14px] font-semibold text-muted-foreground uppercase tracking-wider mb-3\">\n47:           Find a mentor\n48:         </h2>\n49:         <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3\">\n50:           <div\n51:             v-for=\"u in candidates\"\n52:             :key=\"u.user\"\n53:             class=\"rounded-xl bg-card border border-border p-5 flex flex-col items-center text-center\"\n54:           >\n55:             <AppAvatar :user-id=\"u.user\" :size=\"56\" />\n56:             <RouterLink\n57:               :to=\"`/members/${u.user}`\"\n58:               class=\"mt-3 text-[14px] font-semibold hover:text-primary\"\n59:               >{{ u.full_name }}</RouterLink\n60:             >\n61:             <p class=\"mt-1 text-[12px] text-muted-foreground line-clamp-3 mb-3\">{{ u.bio }}</p>\n62:             <button\n63:               type=\"button\"\n64:               class=\"mt-auto h-8 px-4 rounded-full bg-primary text-primary-foreground text-[12px] font-semibold\"\n65:               @click=\"selected = u.user\"\n66:             >\n67:               Request match\n68:             </button>\n69:           </div>\n70:         </div>\n71:       </section>\n72: \n73:       <!-- Request modal -->\n74:       <div\n75:         v-if=\"selected\"\n76:         class=\"fixed inset-0 bg-foreground/30 flex items-center justify-center p-4 z-50\"\n77:         @click=\"selected = null\"\n78:       >\n79:         <div class=\"bg-card rounded-2xl p-6 max-w-md w-full shadow-2xl\" @click.stop>\n80:           <h3 class=\"text-[16px] font-semibold mb-1\">\n81:             Request {{ getUser(selected)?.full_name }} as a mentor\n82:           </h3>\n83:           <p class=\"text-[12px] text-muted-foreground mb-3\">\n84:             A short note about what you're hoping for helps a lot.\n85:           </p>\n86:           <textarea\n87:             v-model=\"notes\"\n88:             rows=\"4\"\n89:             placeholder=\"e.g. I'd love help navigating my first essays and getting comfortable with office hours.\"\n90:             class=\"w-full bg-secondary/60 rounded-lg p-3 text-[14px] outline-none resize-none focus:ring-2 focus:ring-primary/30\"\n91:           />\n92:           <div class=\"flex justify-end gap-2 mt-3\">\n93:             <button\n94:               type=\"button\"\n95:               class=\"text-[13px] font-semibold h-8 px-3 rounded-full hover:bg-secondary\"\n96:               @click=\"selected = null\"\n97:             >\n98:               Cancel\n99:             </button>\n100:             <button\n101:               type=\"button\"\n102:               class=\"text-[13px] font-semibold h-8 px-4 rounded-full bg-primary text-primary-foreground\"\n103:               @click=\"sendRequest\"\n104:             >\n105:               Send request\n106:             </button>\n107:           </div>\n108:         </div>\n109:       </div>\n110:     </div>\n111:   </AppLayout>\n112: </template>\n113: \n114: <script setup lang=\"ts\">\n115: import { ref, computed } from \"vue\";\n116: import { RouterLink } from \"vue-router\";\n117: import AppLayout from \"@/components/AppLayout.vue\";\n118: import AppAvatar from \"@/components/AppAvatar.vue\";\n119: import { currentUserId, getMatchesForUser, getUser, getUsers, requestMentor } from \"@/data/store\";\n120: import type { FGMentorMatch } from \"@/mock-data/types\";\n121: \n122: const matches = computed(() => getMatchesForUser(currentUserId));\n123: const myMentorIds = computed(\n124:   () => new Set(matches.value.filter((m) => m.mentee === currentUserId).map((m) => m.mentor)),\n125: );\n126: const candidates = computed(() =>\n127:   getUsers().filter((u) => u.user !== currentUserId && !myMentorIds.value.has(u.user)),\n128: );\n129: \n130: const selected = ref<string | null>(null);\n131: const notes = ref(\"\");\n132: \n133: const statusStyles: Record<string, string> = {\n134:   Requested: \"bg-flag/30 text-flag-foreground\",\n135:   Active: \"bg-primary-soft text-primary-soft-foreground\",\n136:   Completed: \"bg-secondary text-secondary-foreground\",\n137:   \"Ended Early\": \"bg-secondary text-secondary-foreground\",\n138: };\n139: \n140: function getOtherUserId(m: FGMentorMatch) {\n141:   return m.mentee === currentUserId ? m.mentor : m.mentee;\n142: }\n143: \n144: function sendRequest() {\n145:   if (!selected.value) return;\n146:   requestMentor(selected.value, notes.value || \"—\");\n147:   selected.value = null;\n148:   notes.value = \"\";\n149: }\n150: </script>\n\n(End of file - total 150 lines)\n</content>",
