      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\LessonView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout>\n3:     <div class=\"max-w-[820px] mx-auto px-4 md:px-8 py-6\">\n4:       <RouterLink\n5:         :to=\"`/courses/${courseId}`\"\n6:         class=\"inline-flex items-center gap-1 text-[12px] text-muted-foreground hover:text-foreground mb-4\"\n7:       >\n8:         ← {{ course?.title }}\n9:       </RouterLink>\n10: \n11:       <div v-if=\"!lesson\" class=\"p-12 text-center\">\n12:         <h2 class=\"text-[18px] font-semibold mb-2\">Lesson not found</h2>\n13:         <RouterLink to=\"/courses\" class=\"text-primary underline\">Back to courses</RouterLink>\n14:       </div>\n15:       <template v-else>\n16:         <h1 class=\"text-[24px] font-bold leading-tight mb-4\">{{ lesson.title }}</h1>\n17: \n18:         <div\n19:           v-if=\"lesson.youtube_video\"\n20:           class=\"aspect-video rounded-xl overflow-hidden border border-border bg-black mb-4\"\n21:         >\n22:           <iframe\n23:             :title=\"lesson.title\"\n24:             :src=\"`https://www.youtube-nocookie.com/embed/${lesson.youtube_video}?rel=0`\"\n25:             allow=\"\n26:               accelerometer;\n27:               autoplay;\n28:               clipboard-write;\n29:               encrypted-media;\n30:               gyroscope;\n31:               picture-in-picture;\n32:             \"\n33:             allowfullscreen\n34:             class=\"w-full h-full\"\n35:           />\n36:         </div>\n37:         <div\n38:           v-else\n39:           class=\"aspect-video rounded-xl border border-dashed border-border bg-secondary/40 mb-4 flex items-center justify-center text-[13px] text-muted-foreground\"\n40:         >\n41:           (No video for this lesson — text only)\n42:         </div>\n43: \n44:         <article\n45:           class=\"text-[14px] leading-relaxed text-secondary-foreground\"\n46:           v-html=\"lesson.body || '<p></p>'\"\n47:         />\n48: \n49:         <div class=\"mt-6 flex items-center gap-3 flex-wrap\">\n50:           <button\n51:             v-if=\"!enrolled\"\n52:             type=\"button\"\n53:             class=\"h-9 px-4 rounded-full bg-primary text-primary-foreground text-[13px] font-semibold\"\n54:             @click=\"enrollInCourse(courseId)\"\n55:           >\n56:             Enroll to track progress\n57:           </button>\n58:           <button\n59:             v-if=\"enrolled\"\n60:             type=\"button\"\n61:             class=\"h-9 px-4 rounded-full text-[13px] font-semibold inline-flex items-center gap-1.5 border\"\n62:             :class=\"\n63:               done\n64:                 ? 'bg-success/10 border-success/30 text-success'\n65:                 : 'bg-primary text-primary-foreground border-primary'\n66:             \"\n67:             @click=\"markLessonComplete(lessonId, !done)\"\n68:           >\n69:             {{ done ? \"✅ Completed\" : \"⭕ Mark complete\" }}\n70:           </button>\n71:         </div>\n72: \n73:         <nav class=\"mt-8 pt-4 border-t border-border flex items-center justify-between gap-3\">\n74:           <button\n75:             type=\"button\"\n76:             :disabled=\"!prev\"\n77:             class=\"h-9 px-3 rounded-full border border-border text-[13px] inline-flex items-center gap-1 disabled:opacity-40\"\n78:             @click=\"prev && router.push(`/courses/${courseId}/lessons/${prev.id}`)\"\n79:           >\n80:             ← {{ prev?.title ?? \"Previous\" }}\n81:           </button>\n82:           <button\n83:             type=\"button\"\n84:             :disabled=\"!next\"\n85:             class=\"h-9 px-3 rounded-full border border-border text-[13px] inline-flex items-center gap-1 disabled:opacity-40\"\n86:             @click=\"next && router.push(`/courses/${courseId}/lessons/${next.id}`)\"\n87:           >\n88:             {{ next?.title ?? \"Next\" }} →\n89:           </button>\n90:         </nav>\n91:       </template>\n92:     </div>\n93:   </AppLayout>\n94: </template>\n95: \n96: <script setup lang=\"ts\">\n97: import { computed } from \"vue\";\n98: import { RouterLink, useRoute, useRouter } from \"vue-router\";\n99: import AppLayout from \"@/components/AppLayout.vue\";\n100: import {\n101:   getCourse,\n102:   getLesson,\n103:   getChaptersForCourse,\n104:   getLessonsForChapter,\n105:   isLessonComplete,\n106:   markLessonComplete,\n107:   getEnrollment,\n108:   enrollInCourse,\n109: } from \"@/data/store\";\n110: \n111: const route = useRoute();\n112: const router = useRouter();\n113: const courseId = computed(() => route.params.courseId as string);\n114: const lessonId = computed(() => route.params.lessonId as string);\n115: const course = computed(() => getCourse(courseId.value));\n116: const lesson = computed(() => getLesson(lessonId.value));\n117: const done = computed(() => isLessonComplete(lessonId.value));\n118: const enrolled = computed(() => !!getEnrollment(courseId.value));\n119: \n120: const flat = computed(() =>\n121:   getChaptersForCourse(courseId.value).flatMap((ch) => getLessonsForChapter(ch.id)),\n122: );\n123: const idx = computed(() => flat.value.findIndex((l) => l.id === lessonId.value));\n124: const prev = computed(() => (idx.value > 0 ? flat.value[idx.value - 1] : null));\n125: const next = computed(() => (idx.value < flat.value.length - 1 ? flat.value[idx.value + 1] : null));\n126: </script>\n\n(End of file - total 126 lines)\n</content>",
