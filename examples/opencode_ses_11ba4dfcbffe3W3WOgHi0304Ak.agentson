      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\CourseDetailView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout>\n3:     <div class=\"max-w-[900px] mx-auto px-4 md:px-8 py-6\">\n4:       <div v-if=\"!course\" class=\"p-12 text-center\">\n5:         <h2 class=\"text-[18px] font-semibold mb-2\">Course not found</h2>\n6:         <RouterLink to=\"/courses\" class=\"text-primary underline\">Back to courses</RouterLink>\n7:       </div>\n8:       <template v-else>\n9:         <!-- Hero -->\n10:         <div class=\"rounded-xl overflow-hidden border border-border bg-card mb-5\">\n11:           <div\n12:             class=\"aspect-[4/1] bg-gradient-to-br from-primary-soft via-secondary to-primary-soft flex items-center justify-center text-6xl\"\n13:           >\n14:             📘\n15:           </div>\n16:           <div class=\"p-6\">\n17:             <div class=\"text-[11px] uppercase tracking-wider font-semibold text-muted-foreground\">\n18:               {{ course.category }}\n19:             </div>\n20:             <h1 class=\"text-[26px] font-bold leading-tight mt-1\">{{ course.title }}</h1>\n21:             <p class=\"text-[15px] text-secondary-foreground mt-2\">{{ course.description }}</p>\n22:             <div class=\"flex items-center gap-4 mt-4 text-[13px] text-muted-foreground flex-wrap\">\n23:               <span\n24:                 >By\n25:                 <RouterLink\n26:                   :to=\"`/members/${course.author}`\"\n27:                   class=\"text-foreground font-semibold hover:underline\"\n28:                   >{{ getUser(course.author)?.full_name }}</RouterLink\n29:                 ></span\n30:               >\n31:               <span>📖 {{ course.lessons }} lessons</span>\n32:               <span>👤 {{ course.enrollments }} enrolled</span>\n33:               <span v-if=\"course.enable_certification\" class=\"text-primary-soft-foreground\"\n34:                 >🏆 Certificate on completion</span\n35:               >\n36:             </div>\n37: \n38:             <div class=\"mt-5 flex items-center gap-3 flex-wrap\">\n39:               <template v-if=\"enr\">\n40:                 <div class=\"flex-1 min-w-[180px]\">\n41:                   <div class=\"h-2 rounded-full bg-secondary overflow-hidden\">\n42:                     <div class=\"h-full bg-primary transition-all\" :style=\"{ width: `${pct}%` }\" />\n43:                   </div>\n44:                   <div class=\"text-[12px] text-muted-foreground mt-1\">{{ pct }}% complete</div>\n45:                 </div>\n46:                 <button\n47:                   type=\"button\"\n48:                   class=\"h-10 px-5 rounded-full bg-primary text-primary-foreground text-[14px] font-semibold inline-flex items-center gap-2 hover:opacity-90\"\n49:                   @click=\"goToFirst\"\n50:                 >\n51:                   ▶ Continue\n52:                 </button>\n53:               </template>\n54:               <button\n55:                 v-else\n56:                 type=\"button\"\n57:                 class=\"h-10 px-5 rounded-full bg-primary text-primary-foreground text-[14px] font-semibold hover:opacity-90\"\n58:                 @click=\"enrollInCourse(courseId)\"\n59:               >\n60:                 Enroll for free\n61:               </button>\n62:             </div>\n63:           </div>\n64:         </div>\n65: \n66:         <!-- Chapters -->\n67:         <section>\n68:           <div class=\"flex items-center justify-between mb-3\">\n69:             <h2 class=\"text-[16px] font-semibold\">Course content</h2>\n70:             <button\n71:               v-if=\"isAuthor\"\n72:               type=\"button\"\n73:               class=\"h-8 px-3 rounded-full border border-border text-[12px] font-semibold inline-flex items-center gap-1 hover:bg-secondary\"\n74:               @click=\"addChapterPrompt\"\n75:             >\n76:               + Add chapter\n77:             </button>\n78:           </div>\n79:           <div class=\"flex flex-col gap-2\">\n80:             <div\n81:               v-for=\"ch in chapters\"\n82:               :key=\"ch.id\"\n83:               class=\"rounded-xl border border-border bg-card overflow-hidden\"\n84:             >\n85:               <div class=\"px-4 py-3 border-b border-border bg-secondary/40\">\n86:                 <div class=\"text-[14px] font-semibold\">{{ ch.idx }}. {{ ch.title }}</div>\n87:                 <div v-if=\"ch.description\" class=\"text-[12px] text-muted-foreground\">\n88:                   {{ ch.description }}\n89:                 </div>\n90:               </div>\n91:               <ul>\n92:                 <li\n93:                   v-for=\"l in getLessonsForChapter(ch.id)\"\n94:                   :key=\"l.id\"\n95:                   class=\"border-b border-border last:border-0\"\n96:                 >\n97:                   <RouterLink\n98:                     :to=\"`/courses/${courseId}/lessons/${l.id}`\"\n99:                     class=\"flex items-center gap-3 px-4 py-2.5 hover:bg-secondary/40\"\n100:                   >\n101:                     <span>{{ isLessonComplete(l.id) ? \"✅\" : \"⭕\" }}</span>\n102:                     <span class=\"text-[13px] flex-1\">{{ l.title }}</span>\n103:                     <span v-if=\"l.youtube_video\" class=\"text-[11px] text-muted-foreground\"\n104:                       >▶ video</span\n105:                     >\n106:                   </RouterLink>\n107:                 </li>\n108:                 <li\n109:                   v-if=\"!getLessonsForChapter(ch.id).length\"\n110:                   class=\"px-4 py-3 text-[12px] text-muted-foreground\"\n111:                 >\n112:                   No lessons yet.\n113:                 </li>\n114:               </ul>\n115:               <div v-if=\"isAuthor\" class=\"px-4 py-2 border-t border-border bg-background\">\n116:                 <div v-if=\"addLessonForChapter === ch.id\">\n117:                   <div class=\"flex flex-col gap-2 py-1\">\n118:                     <input\n119:                       v-model=\"lessonTitle\"\n120:                       placeholder=\"Lesson title\"\n121:                       autofocus\n122:                       class=\"h-9 px-3 rounded-md border border-border bg-background text-[13px] outline-none focus:ring-2 focus:ring-primary/30\"\n123:                     />\n124:                     <input\n125:                       v-model=\"lessonYt\"\n126:                       placeholder=\"YouTube URL (optional)\"\n127:                       class=\"h-9 px-3 rounded-md border border-border bg-background text-[13px] outline-none focus:ring-2 focus:ring-primary/30\"\n128:                     />\n129:                     <textarea\n130:                       v-model=\"lessonBody\"\n131:                       placeholder=\"Short description (optional)\"\n132:                       rows=\"2\"\n133:                       class=\"px-3 py-2 rounded-md border border-border bg-background text-[13px] outline-none focus:ring-2 focus:ring-primary/30 resize-none\"\n134:                     />\n135:                     <div class=\"flex gap-2\">\n136:                       <button\n137:                         type=\"button\"\n138:                         class=\"h-8 px-3 rounded-full bg-primary text-primary-foreground text-[12px] font-semibold\"\n139:                         @click=\"submitLesson(ch.id)\"\n140:                       >\n141:                         Add lesson\n142:                       </button>\n143:                       <button\n144:                         type=\"button\"\n145:                         class=\"h-8 px-3 rounded-full text-[12px] text-muted-foreground hover:bg-secondary\"\n146:                         @click=\"addLessonForChapter = null\"\n147:                       >\n148:                         Cancel\n149:                       </button>\n150:                     </div>\n151:                   </div>\n152:                 </div>\n153:                 <button\n154:                   v-else\n155:                   type=\"button\"\n156:                   class=\"text-[12px] text-primary font-semibold inline-flex items-center gap-1\"\n157:                   @click=\"addLessonForChapter = ch.id\"\n158:                 >\n159:                   + Add lesson\n160:                 </button>\n161:               </div>\n162:             </div>\n163:           </div>\n164:         </section>\n165:       </template>\n166:     </div>\n167:   </AppLayout>\n168: </template>\n169: \n170: <script setup lang=\"ts\">\n171: import { ref, computed } from \"vue\";\n172: import { RouterLink, useRoute, useRouter } from \"vue-router\";\n173: import AppLayout from \"@/components/AppLayout.vue\";\n174: import {\n175:   getCourse,\n176:   getChaptersForCourse,\n177:   getLessonsForChapter,\n178:   getEnrollment,\n179:   enrollInCourse,\n180:   courseProgressPercent,\n181:   isLessonComplete,\n182:   addChapter,\n183:   addLesson,\n184:   getUser,\n185:   currentUserId,\n186: } from \"@/data/store\";\n187: \n188: const route = useRoute();\n189: const router = useRouter();\n190: const courseId = computed(() => route.params.courseId as string);\n191: const course = computed(() => getCourse(courseId.value));\n192: const chapters = computed(() => getChaptersForCourse(courseId.value));\n193: const enr = computed(() => getEnrollment(courseId.value));\n194: const pct = computed(() => courseProgressPercent(courseId.value));\n195: const isAuthor = computed(() => course.value?.author === currentUserId);\n196: \n197: const addLessonForChapter = ref<string | null>(null);\n198: const lessonTitle = ref(\"\");\n199: const lessonYt = ref(\"\");\n200: const lessonBody = ref(\"\");\n201: \n202: function addChapterPrompt() {\n203:   const title = prompt(\"Chapter title?\");\n204:   if (title) addChapter(courseId.value, title);\n205: }\n206: \n207: function submitLesson(chapterId: string) {\n208:   if (!lessonTitle.value.trim()) return;\n209:   addLesson({\n210:     course: courseId.value,\n211:     chapter: chapterId,\n212:     title: lessonTitle.value,\n213:     body: lessonBody.value ? `<p>${lessonBody.value}</p>` : \"\",\n214:     youtube_video: lessonYt.value,\n215:   });\n216:   lessonTitle.value = \"\";\n217:   lessonYt.value = \"\";\n218:   lessonBody.value = \"\";\n219:   addLessonForChapter.value = null;\n220: }\n221: \n222: function goToFirst() {\n223:   const first = chapters.value.flatMap((ch) => getLessonsForChapter(ch.id))[0];\n224:   if (first) router.push(`/courses/${courseId.value}/lessons/${first.id}`);\n225: }\n226: </script>\n\n(End of file - total 226 lines)\n</content>",
