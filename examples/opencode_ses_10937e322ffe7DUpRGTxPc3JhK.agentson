      "tool": "write",
      "code": "{\"content\": \"\\\"\\\"\\\"Diagnose: find the share-token appointment + check for stale web tours.\\n\\nCONTAINS LIVE ODOO API KEY. Delete after use.\\n\\\"\\\"\\\"\\nimport xmlrpc.client\\nimport sys\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"  # noqa: S105\\n\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\")\\nuid = common.authenticate(DB, USERNAME, API_KEY, {})\\nif not uid:\\n    print(\\\"ERR: auth failed\\\", file=sys.stderr); sys.exit(1)\\nprint(f\\\"OK: uid={uid}\\\")\\n\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\")\\n\\n# \\u2500\\u2500 1. Find appointment type that owns the /book/27e80afd share token \\u2500\\u2500\\u2500\\u2500\\u2500\\nprint(\\\"\\\\n[1] Search for appointment.type with share_token=27e80afd\\\")\\ntry:\\n    fields = models.execute_kw(DB, uid, API_KEY, \\\"appointment.type\\\", \\\"fields_get\\\", [], {\\\"attributes\\\": [\\\"type\\\", \\\"help\\\"]})\\nexcept Exception as e:\\n    print(f\\\"  ERR fields_get: {e}\\\"); sys.exit(1)\\n\\ntoken_fields = [f for f in fields if any(k in f.lower() for k in [\\\"token\\\", \\\"share\\\", \\\"url\\\", \\\"slug\\\", \\\"access\\\", \\\"book\\\"])]\\nprint(f\\\"  Candidate token fields: {token_fields}\\\")\\n\\n# Try each token field\\nfound_type = None\\nfor tf in token_fields:\\n    try:\\n        recs = models.execute_kw(\\n            DB, uid, API_KEY, \\\"appointment.type\\\", \\\"search_read\\\",\\n            [[[tf, \\\"=\\\", \\\"27e80afd\\\"]]],\\n            {\\\"fields\\\": [\\\"id\\\", \\\"name\\\", tf, \\\"is_published\\\", \\\"website_published\\\"]},\\n        )\\n        if recs:\\n            found_type = (tf, recs[0])\\n            print(f\\\"  FOUND via field '{tf}': {recs[0]}\\\")\\n            break\\n    except Exception as e:\\n        pass\\n\\n# Fallback: list all appointment types\\nif not found_type:\\n    print(\\\"  \\u2192 no appointment.type with token 27e80afd; listing all\\\")\\n    all_types = models.execute_kw(\\n        DB, uid, API_KEY, \\\"appointment.type\\\", \\\"search_read\\\",\\n        [[]], {\\\"fields\\\": [\\\"id\\\", \\\"name\\\", \\\"is_published\\\", \\\"website_published\\\", \\\"website_url\\\"]},\\n    )\\n    for t in all_types:\\n        print(f\\\"    [{t['id']}] {t['name']:<40} pub={t.get('is_published')}  url={t.get('website_url')}\\\")\\n\\n# \\u2500\\u2500 2. If we found it, dump the full record \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nif found_type:\\n    tf, _ = found_type\\n    print(f\\\"\\\\n[2] Full dump of appointment.type where {tf}='27e80afd'\\\")\\n    full = models.execute_kw(\\n        DB, uid, API_KEY, \\\"appointment.type\\\", \\\"read\\\",\\n        [[found_type[1][\\\"id\\\"]]], {\\\"fields\\\": list(fields.keys())},\\n    )[0]\\n    for k, v in sorted(full.items()):\\n        v_str = repr(v)\\n        if len(v_str) > 120: v_str = v_str[:117] + \\\"...\\\"\\n        print(f\\\"  {k:<28} = {v_str}\\\")\\n\\n# \\u2500\\u2500 3. Check web_tour.tour for stale entries \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nprint(\\\"\\\\n[3] web_tour.tour state\\\")\\ntry:\\n    if models.execute_kw(DB, uid, API_KEY, \\\"ir.model\\\", \\\"search\\\",\\n        [[[\\\"model\\\", \\\"=\\\", \\\"web_tour.tour\\\"]]]) == []:\\n        # Newer Odoo uses different model\\n        tour_models = models.execute_kw(DB, uid, API_KEY, \\\"ir.model\\\", \\\"search_read\\\",\\n            [[[\\\"model\\\", \\\"like\\\", \\\"tour\\\"]]], {\\\"fields\\\": [\\\"model\\\", \\\"name\\\"]})\\n        print(f\\\"  Tour models available: {[m['model'] for m in tour_models]}\\\")\\n        for tm in tour_models:\\n            tname = tm[\\\"model\\\"]\\n            print(f\\\"  -- model {tname} --\\\")\\n            try:\\n                tfields = models.execute_kw(DB, uid, API_KEY, tname, \\\"fields_get\\\", [], {\\\"attributes\\\": [\\\"type\\\"]})\\n                interesting = [f for f in tfields if any(k in f.lower() for k in [\\\"name\\\", \\\"url\\\", \\\"model\\\", \\\"state\\\", \\\"active\\\", \\\"sequence\\\"])]\\n                tours = models.execute_kw(DB, uid, API_KEY, tname, \\\"search_read\\\",\\n                    [[]], {\\\"fields\\\": interesting})\\n                for t in tours[:30]:\\n                    print(f\\\"    {t}\\\")\\n                if len(tours) > 30: print(f\\\"    ... {len(tours)-30} more\\\")\\n            except Exception as e:\\n                print(f\\\"    ERR reading {tname}: {e}\\\")\\n    else:\\n        tours = models.execute_kw(DB, uid, API_KEY, \\\"web_tour.tour\\\", \\\"search_read\\\", [[]], {\\\"fields\\\": [\\\"name\\\", \\\"url\\\", \\\"model\\\"]})\\n        for t in tours: print(f\\\"    {t}\\\")\\nexcept Exception as e:\\n    print(f\\\"  ERR: {e}\\\")\\n\\n# \\u2500\\u2500 4. Check for stale ir.model.data referencing uninstalled modules \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nprint(\\\"\\\\n[4] Stale ir.model.data from the 9 uninstalled modules\\\")\\nuninstalled = [\\\"project\\\", \\\"account\\\", \\\"hr\\\", \\\"sign\\\", \\\"purchase\\\", \\\"helpdesk\\\", \\\"planning\\\", \\\"survey\\\", \\\"knowledge\\\"]\\ntry:\\n    stale = models.execute_kw(\\n        DB, uid, API_KEY, \\\"ir.model.data\\\", \\\"search_read\\\",\\n        [[[\\\"module\\\", \\\"in\\\", uninstalled]]], {\\\"fields\\\": [\\\"module\\\", \\\"name\\\", \\\"model\\\", \\\"res_id\\\"], \\\"limit\\\": 50},\\n    )\\n    print(f\\\"  {len(stale)} ir.model.data records still reference the uninstalled modules\\\")\\n    for s in stale[:20]:\\n        print(f\\\"    {s['module']:<12} {s['name']:<45} -> {s['model']}#{s['res_id']}\\\")\\nexcept Exception as e:\\n    print(f\\\"  ERR: {e}\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\odoo_diagnose.py\"}",
