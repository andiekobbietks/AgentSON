      "code": "{\"content\": \"\\\"\\\"\\\"Set a sensible home action for the user + verify the appointment page.\\n\\nCONTAINS LIVE ODOO API KEY.\\n\\\"\\\"\\\"\\nimport xmlrpc.client\\nimport urllib.request\\nimport re\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"  # noqa: S105\\n\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\")\\nuid = common.authenticate(DB, USERNAME, API_KEY, {})\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\")\\nprint(f\\\"OK: uid={uid}\\\")\\n\\n\\n# \\u2500\\u2500 1. Find good home-action candidates \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nprint(\\\"\\\\n[1] Find a good home action to set on the user\\\")\\n# Look for the Odoo canonical \\\"main\\\" / \\\"home\\\" / \\\"apps\\\" actions\\nfor term in [\\\"action_open_main\\\", \\\"action_open_apps\\\", \\\"action_open_home\\\", \\\"open_apps\\\", \\\"open_menu\\\", \\\"action_main_menu\\\"]:\\n    r = models.execute_kw(DB, uid, API_KEY, \\\"ir.model.data\\\", \\\"search_read\\\",\\n        [[[\\\"name\\\", \\\"=\\\", term]]], {\\\"fields\\\": [\\\"module\\\", \\\"name\\\", \\\"res_id\\\"]})\\n    for hit in r:\\n        print(f\\\"  {hit['module']}.{hit['name']} -> #{hit['res_id']}\\\")\\n\\n# Also look up the \\\"Settings\\\" action \\u2014 a safe landing target\\nprint(\\\"\\\\n  Settings action:\\\")\\nfor term in [\\\"action_menu_admin\\\", \\\"action_open_settings\\\", \\\"open_settings\\\", \\\"base_setup.action_menu_admin\\\"]:\\n    r = models.execute_kw(DB, uid, API_KEY, \\\"ir.model.data\\\", \\\"search_read\\\",\\n        [[[\\\"name\\\", \\\"=\\\", term.split('.')[-1]], [\\\"model\\\", \\\"=\\\", \\\"ir.actions.act_window\\\"]]],\\n        {\\\"fields\\\": [\\\"module\\\", \\\"name\\\", \\\"res_id\\\"]})\\n    for hit in r:\\n        print(f\\\"    {hit['module']}.{hit['name']} -> act_window#{hit['res_id']}\\\")\\n\\n\\n# \\u2500\\u2500 2. Set home_action_id to the apps menu action \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n# The Odoo default is to show the apps menu when home_action_id is False.\\n# But if that's somehow broken, we can set a specific one.\\n# A safe pick: the Discuss action (it's always installed and works as a landing).\\nprint(\\\"\\\\n[2] Look up a known-good action to use as a landing target\\\")\\n# Try discuss (mail) since it's a core module\\ndiscuss = models.execute_kw(DB, uid, API_KEY, \\\"ir.model.data\\\", \\\"search_read\\\",\\n    [[[\\\"name\\\", \\\"=\\\", \\\"action_discuss\\\"], [\\\"model\\\", \\\"=\\\", \\\"ir.actions.act_window\\\"]]],\\n    {\\\"fields\\\": [\\\"module\\\", \\\"name\\\", \\\"res_id\\\"]})\\nfor d in discuss:\\n    print(f\\\"  {d['module']}.{d['name']} -> act_window#{d['res_id']}\\\")\\n\\n# If we found the discuss action, set it as home\\nhome_action_id = discuss[0][\\\"res_id\\\"] if discuss else False\\nprint(f\\\"  using home_action_id = {home_action_id}\\\")\\n\\nif home_action_id:\\n    ok = models.execute_kw(DB, uid, API_KEY, \\\"res.users\\\", \\\"write\\\",\\n        [[uid], {\\\"home_action_id\\\": home_action_id}])\\n    print(f\\\"  set home_action_id on user OK={ok}\\\")\\n    me = models.execute_kw(DB, uid, API_KEY, \\\"res.users\\\", \\\"read\\\", [[uid]],\\n        {\\\"fields\\\": [\\\"id\\\", \\\"name\\\", \\\"home_action_id\\\"]})[0]\\n    print(f\\\"  verified: {me}\\\")\\n\\n\\n# \\u2500\\u2500 3. Verify appointment page (case-insensitive intro check) \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nprint(\\\"\\\\n[3] Verify public appointment page (case-insensitive markers)\\\")\\ntry:\\n    req = urllib.request.Request(f\\\"{URL}/book/27e80afd\\\",\\n        headers={\\\"User-Agent\\\": \\\"Mozilla/5.0\\\"})\\n    with urllib.request.urlopen(req, timeout=20) as r:\\n        html = r.read().decode(\\\"utf-8\\\", errors=\\\"replace\\\")\\n        # case-insensitive search\\n        hl = html.lower()\\n        markers = {\\n            \\\"title 'Discovery Consultation & More'\\\": \\\"discovery consultation &amp; more\\\" in hl,\\n            \\\"h1 'Discovery Consultation & More'\\\":   \\\"<h1\\\" in hl and \\\"discovery consultation &amp; more\\\" in hl,\\n            \\\"title 'Discovery Consultation' (new)\\\":  \\\"discovery consultation | andiekobbie\\\" in hl or \\\"<title>discovery consultation</title>\\\" in hl,\\n            \\\"h2 'Discovery Consultation' (new)\\\":     \\\"<h2\\\" in hl and \\\"discovery consultation\\\" in hl,\\n            \\\"intro: 'sovereign cloud journey'\\\":      \\\"sovereign cloud journey\\\" in hl,\\n            \\\"pill: 'video call'\\\":                    \\\"video call\\\" in hl,\\n            \\\"pill: '30 minutes'\\\":                    \\\"30 minutes\\\" in hl,\\n            \\\"pill: 'europe/london'\\\":                 \\\"europe/london\\\" in hl,\\n            \\\"pill: 'free'\\\":                          \\\"<span\\\" in hl and \\\">free<\\\" in hl,\\n            \\\"host: 'andrea'\\\":                        \\\"andrea\\\" in hl,\\n        }\\n        print(f\\\"  /book/27e80afd  status={r.status}  bytes={len(html)}\\\")\\n        for k, v in markers.items():\\n            print(f\\\"     {'OK ' if v else '-- '}  {k}\\\")\\n        # Count tour markers (should be 0)\\n        tour_hits = re.findall(r\\\"tour_enabled|current_tour|web_studio_new_app_tour\\\", html)\\n        print(f\\\"  tour markers in HTML: {len(tour_hits)} (should be 0)\\\")\\nexcept Exception as e:\\n    print(f\\\"  ERR: {e}\\\")\\n\\n\\n# \\u2500\\u2500 4. Verify canonical URL too \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nprint(\\\"\\\\n[4] Verify canonical /appointment/<slug> URL\\\")\\ntry:\\n    req = urllib.request.Request(f\\\"{URL}/appointment/discovery-consultation-1\\\",\\n        headers={\\\"User-Agent\\\": \\\"Mozilla/5.0\\\"})\\n    with urllib.request.urlopen(req, timeout=20) as r:\\n        html = r.read().decode(\\\"utf-8\\\", errors=\\\"replace\\\")\\n        hl = html.lower()\\n        print(f\\\"  /appointment/discovery-consultation-1  status={r.status}  bytes={len(html)}\\\")\\n        print(f\\\"     title matches 'Discovery Consultation' (new): {'<title>discovery consultation</title>' in hl or 'discovery consultation | andiekobbie' in hl}\\\")\\n        print(f\\\"     title matches 'Discovery Consultation & More' (old): {'discovery consultation &amp; more' in hl}\\\")\\n        print(f\\\"     has 'sovereign cloud journey' intro: {'sovereign cloud journey' in hl}\\\")\\nexcept Exception as e:\\n    print(f\\\"  ERR: {e}\\\")\\n\\n\\n# \\u2500\\u2500 5. Final note on backend \\u2014 assets will recompile on next user request \\u2500\\u2500\\nprint(\\\"\\\\n[5] Backend status\\\")\\ntry:\\n    r = urllib.request.Request(f\\\"{URL}/odoo\\\", headers={\\\"User-Agent\\\": \\\"Mozilla/5.0\\\"})\\n    with urllib.request.urlopen(r, timeout=20) as resp:\\n        html = resp.read().decode(\\\"utf-8\\\", errors=\\\"replace\\\")\\n        is_login = \\\"name=\\\\\\\"login\\\\\\\"\\\" in html or \\\"web.login\\\" in html or \\\"/web/login\\\" in html\\n        is_app = \\\"o_web_client\\\" in html\\n        print(f\\\"  /odoo (unauth) status={resp.status} bytes={len(html)}  is_login={is_login}  is_spa_shell={is_app}\\\")\\n        # The SPA shell loads a 7.4MB JS bundle. The actual SPA must be visited\\n        # while LOGGED IN to trigger the recompile + render the menu.\\n        print(f\\\"  \\u2192 when the user refreshes /odoo in their browser, Odoo will recompile\\\")\\n        print(f\\\"     the deleted backend assets and serve fresh JS+CSS.\\\")\\nexcept Exception as e:\\n    print(f\\\"  ERR: {e}\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\odoo_set_home.py\"}",
