      "output": "<path>C:\\Users\\LLM-Test\\.minimax\\sessions\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\workspace\\akcloud-site\\netlify.toml</path>\n<type>file</type>\n<content>\n1: # ─── Build & deploy ───────────────────────────────────────────\n2: # AKcloud is a pure static site — no build step required.\n3: # Netlify will serve the repo root as-is.\n4: \n5: [build]\n6:   publish = \".\"\n7:   # No build command needed. Uncomment when you add a static site generator:\n8:   # command = \"npm run build\"\n9: \n10: # ─── Redirects ─────────────────────────────────────────────────\n11: # Pretty URLs and the admin route.\n12: \n13: [[redirects]]\n14:   from = \"/admin\"\n15:   to   = \"/admin.html\"\n16:   status = 200\n17: \n18: # Force HTTPS (Netlify does this by default; this is belt-and-braces)\n19: [[redirects]]\n20:   from = \"http://akcloud.netlify.app/*\"\n21:   to   = \"https://akcloud.netlify.app/:splat\"\n22:   status = 301\n23:   force = false\n24: \n25: # API → Functions\n26: [[redirects]]\n27:   from = \"/api/*\"\n28:   to   = \"/.netlify/functions/:splat\"\n29:   status = 200\n30: \n31: # ─── Headers (security + caching) ──────────────────────────────\n32: [[headers]]\n33:   for = \"/*\"\n34:   [headers.values]\n35:     X-Frame-Options           = \"DENY\"\n36:     X-Content-Type-Options    = \"nosniff\"\n37:     Referrer-Policy           = \"strict-origin-when-cross-origin\"\n38:     Permissions-Policy        = \"camera=(), microphone=(), geolocation=()\"\n39:     Strict-Transport-Security = \"max-age=63072000; includeSubDomains; preload\"\n40: \n41: [[headers]]\n42:   for = \"/assets/*\"\n43:   [headers.values]\n44:     Cache-Control = \"public, max-age=31536000, immutable\"\n45: \n46: [[headers]]\n47:   for = \"/*.html\"\n48:   [headers.values]\n49:     Cache-Control = \"public, max-age=0, must-revalidate\"\n50: \n51: [[headers]]\n52:   for = \"/admin.html\"\n53:   [headers.values]\n54:     X-Robots-Tag = \"noindex, nofollow\"\n55:     # When you turn on Visitor Access in the Netlify dashboard, this header\n56:     # tells search engines to skip the page entirely.\n57: \n58: # ─── Environment (set these in Netlify UI for prod) ────────────\n59: # [context.production.environment]\n60: #   RESEND_API_KEY = \"re_xxx\"\n61: #   ODOO_URL       = \"https://your-sovereign-odoo.example.com\"\n62: #   ODOO_DB        = \"akcloud\"\n63: #   ODOO_USER      = \"api@akcloud.example.com\"\n64: #   ODOO_API_KEY   = \"xxx\"\n65: #   NOTIFY_EMAIL   = \"you@akcloud.example.com\"\n66: \n67: # ─── Functions ─────────────────────────────────────────────────\n68: [functions]\n69:   directory = \"netlify/functions\"\n70:   node_bundler = \"esbuild\"\n\n(End of file - total 70 lines)\n</content>",
