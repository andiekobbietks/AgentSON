      "code": "{\"content\": \"\\\"\\\"\\\"Final: read parent view, publish canonical URL, bust cache, re-verify.\\n\\nCONTAINS LIVE ODOO API KEY.\\n\\\"\\\"\\\"\\nimport xmlrpc.client\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"  # noqa: S105\\n\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\")\\nuid = common.authenticate(DB, USERNAME, API_KEY, {})\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\")\\n\\n# 1. Find the parent appointment_info view (the one that actually has the H1)\\nprint(\\\"[1] Hunt the H1 source in parent view 1117 + inherited views\\\")\\nfor vid in [1117, 3328, 3330]:\\n    v = models.execute_kw(DB, uid, API_KEY, \\\"ir.ui.view\\\", \\\"read\\\", [[vid]],\\n        {\\\"fields\\\": [\\\"id\\\", \\\"key\\\", \\\"name\\\", \\\"arch\\\", \\\"inherit_id\\\", \\\"mode\\\", \\\"active\\\"]})[0]\\n    print(f\\\"  -- {v['key']} (id {vid}) inherit={v.get('inherit_id')} mode={v.get('mode')} active={v.get('active')} --\\\")\\n    arch = v.get(\\\"arch\\\") or \\\"\\\"\\n    for ln in arch.splitlines():\\n        if \\\"<h1\\\" in ln or \\\"<h2\\\" in ln or \\\"appointment_type.name\\\" in ln or \\\"appointment_type.display_name\\\" in ln or \\\"o_appointment_type_name\\\" in ln or \\\"mb-4 h4\\\" in ln:\\n            print(f\\\"      {ln.strip()[:240]}\\\")\\n    print()\\n\\n# 2. Publish the canonical URL too + bump the type so the cache invalidates\\nprint(\\\"[2] Publish appointment.type #1 so /appointment/<slug> also works\\\")\\nok = models.execute_kw(DB, uid, API_KEY, \\\"appointment.type\\\", \\\"write\\\",\\n    [[1], {\\n        \\\"is_published\\\": True,\\n        \\\"website_published\\\": True,\\n        \\\"appointment_duration\\\": 0.5,    # 30 mins \\u2014 bump write_date\\n        \\\"name\\\": \\\"Discovery Consultation\\\", # ensure name + write_date\\n    }])\\nprint(f\\\"  write OK={ok}\\\")\\n\\n# 3. Also fix the share invite #2: it has staff_user_ids=[] which prevents the host filter\\nprint(\\\"\\\\n[3] Fix share invite #2 \\u2014 set staff_user_ids=[2] (Andrea) so the host filter applies\\\")\\nok = models.execute_kw(DB, uid, API_KEY, \\\"appointment.invite\\\", \\\"write\\\",\\n    [[2], {\\\"staff_user_ids\\\": [(6, 0, [uid])]}])\\nprint(f\\\"  invite write OK={ok}\\\")\\n\\n# 4. Try to clear ir.ui.view cache\\nprint(\\\"\\\\n[4] Clear ir.ui.view caches\\\")\\nfor method in [\\\"clear_caches\\\"]:\\n    try:\\n        ret = models.execute_kw(DB, uid, API_KEY, \\\"ir.ui.view\\\", method, [])\\n        print(f\\\"  {method}: {ret}\\\")\\n    except Exception as e:\\n        print(f\\\"  {method}: ERR {type(e).__name__}\\\")\\n\\n# 5. Bust the website cache via the website model\\nprint(\\\"\\\\n[5] Bust website cache\\\")\\ntry:\\n    website_ids = models.execute_kw(DB, uid, API_KEY, \\\"website\\\", \\\"search\\\", [[]])\\n    for wid in website_ids:\\n        try:\\n            r = models.execute_kw(DB, uid, API_KEY, \\\"website\\\", \\\"reset_template_cache\\\", [[wid]])\\n            print(f\\\"  website {wid} reset_template_cache: {r}\\\")\\n        except Exception as e:\\n            print(f\\\"  website {wid} ERR: {e}\\\")\\nexcept Exception as e:\\n    print(f\\\"  ERR: {e}\\\")\\n\\n# 6. Verify\\nprint(\\\"\\\\n[6] Final verification \\u2014 fetch both URLs with cache-buster\\\")\\nimport urllib.request\\nfor path in [\\\"/book/27e80afd\\\", \\\"/appointment/discovery-consultation-1\\\"]:\\n    url = f\\\"{URL}{path}?cb=import-time\\\"\\n    try:\\n        req = urllib.request.Request(url, headers={\\\"User-Agent\\\": \\\"Mozilla/5.0\\\", \\\"Cache-Control\\\":\\\"no-cache\\\",\\\"Pragma\\\":\\\"no-cache\\\"})\\n        with urllib.request.urlopen(req, timeout=20) as resp:\\n            html = resp.read().decode(\\\"utf-8\\\", errors=\\\"replace\\\")\\n            import re\\n            m = re.search(r\\\"<title>([^<]+)</title>\\\", html)\\n            t = m.group(1) if m else \\\"(no title)\\\"\\n            h1 = re.findall(r\\\"<h1[^>]*>([^<]+)</h1>\\\", html)\\n            print(f\\\"  {path}\\\")\\n            print(f\\\"     title: {t}\\\")\\n            print(f\\\"     h1:    {h1}\\\")\\n            print(f\\\"     bytes: {len(html)}  status: {resp.status}\\\")\\n    except Exception as e:\\n        print(f\\\"  {path} ERR: {e}\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\odoo_finish.py\"}",
