      "code": "{\"content\": \"\\\"\\\"\\\"Find the QWeb view that renders the type-page H1.\\n\\nCONTAINS LIVE ODOO API KEY.\\n\\\"\\\"\\\"\\nimport xmlrpc.client\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"  # noqa: S105\\n\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\")\\nuid = common.authenticate(DB, USERNAME, API_KEY, {})\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\")\\n\\n# Search ALL views for the literal 'mb-4 h4' class which appears in the H1\\nprint(\\\"[1] Find view with H1 'mb-4 h4' (matches the rendered H1)\\\")\\nviews = models.execute_kw(DB, uid, API_KEY, \\\"ir.ui.view\\\", \\\"search_read\\\",\\n    [[[\\\"arch\\\", \\\"ilike\\\", \\\"mb-4 h4\\\"]]],\\n    {\\\"fields\\\": [\\\"id\\\", \\\"key\\\", \\\"name\\\", \\\"arch\\\", \\\"inherit_id\\\", \\\"mode\\\"]})\\nprint(f\\\"  found {len(views)} views\\\")\\nfor v_ in views:\\n    arch = v_.get(\\\"arch\\\") or \\\"\\\"\\n    print(f\\\"  -- id={v_['id']} key={v_['key']} inherit={v_.get('inherit_id')} --\\\")\\n    # show the H1 line and a bit of context\\n    for ln in arch.splitlines():\\n        if \\\"<h1\\\" in ln or \\\"appointment_type\\\" in ln or \\\"mb-4 h4\\\" in ln:\\n            print(f\\\"    {ln.strip()[:200]}\\\")\\n\\n# Also search for \\\"<h1 t-field\\\" or \\\"t-out\\\" patterns referencing appointment_type\\nprint(\\\"\\\\n[2] Views where appointment_type.name is rendered as H1\\\")\\nviews2 = models.execute_kw(DB, uid, API_KEY, \\\"ir.ui.view\\\", \\\"search_read\\\",\\n    [[[\\\"arch\\\", \\\"ilike\\\", \\\"appointment_type\\\"]]],\\n    {\\\"fields\\\": [\\\"id\\\", \\\"key\\\", \\\"name\\\", \\\"arch\\\", \\\"inherit_id\\\", \\\"mode\\\"]})\\nprint(f\\\"  found {len(views2)} views\\\")\\nfor v_ in views2:\\n    arch = v_.get(\\\"arch\\\") or \\\"\\\"\\n    if \\\"appointment_type.name\\\" in arch or \\\"appointment_type.display_name\\\" in arch:\\n        print(f\\\"  -- id={v_['id']} key={v_['key']} --\\\")\\n        for ln in arch.splitlines():\\n            if \\\"appointment_type.name\\\" in ln or \\\"appointment_type.display_name\\\" in ln or \\\"<h1\\\" in ln or \\\"<h2\\\" in ln:\\n                print(f\\\"    {ln.strip()[:240]}\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\odoo_find_h1_view.py\"}",
