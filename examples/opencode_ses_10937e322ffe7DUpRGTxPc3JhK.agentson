;\\n  border-top-left-radius: 8px;\\n  box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55);\\n  pointer-events: none; z-index: 1;\\n  transition:\\n    width     0.55s cubic-bezier(0.22, 1, 0.36, 1),\\n    height    0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.06s,\\n    border-color 0.4s ease 0.24s,\\n    box-shadow 0.45s ease 0.12s,\\n    border-radius 0.45s ease 0.18s;\\n}\\n.login-modal:hover::before {\\n  width:  calc(100% + 2px);\\n  height: calc(100% + 2px);\\n  border-color: #39FF14;\\n  border-radius: 8px;\\n  box-shadow:\\n    0 0 10px #39FF14,\\n    0 0 28px rgba(57,255,20,0.50),\\n    0 0 56px rgba(57,255,20,0.25);\\n}\\\"\\\"\\\"\\n\\ncontent = replace_once(content, old, new, \\\".login-modal hover sweep\\\")\\n\\n\\n# \\u2500\\u2500 5. Admin modal CORNER (inline in JS) \\u2014 tag the div so CSS can style it \\u2500\\u2500\\nold = \\\"var CORNER='position:absolute;top:-1px;left:-1px;width:44px;height:44px;border-top:2px solid #39FF14;border-left:2px solid #39FF14;border-top-left-radius:8px;box-shadow:0 0 6px #39FF14,0 0 14px rgba(57,255,20,0.55);pointer-events:none;';\\\"\\nnew = \\\"var CORNER='position:absolute;top:-1px;left:-1px;width:44px;height:44px;border:2px solid transparent;border-top-color:#39FF14;border-left-color:#39FF14;border-top-left-radius:8px;box-shadow:0 0 6px #39FF14,0 0 14px rgba(57,255,20,0.55);pointer-events:none;z-index:1;transition:width 0.55s cubic-bezier(0.22,1,0.36,1),height 0.55s cubic-bezier(0.22,1,0.36,1) 0.06s,border-color 0.4s ease 0.24s,box-shadow 0.45s ease 0.12s,border-radius 0.45s ease 0.18s;';\\\"\\ncontent = replace_once(content, old, new, \\\"admin CORNER base style\\\")\\n\\n# Tag the two CORNER div instances with a class so CSS can target hover state.\\n# Pattern: '<div style=\\\"'+CORNER+'\\\"></div>' \\u2014 wrap with class\\nold = \\\"'<div style=\\\\\\\\'\\\"+CORNER+\\\"\\\\\\\\'></div>'\\\"\\n# But there are two CORNER divs; we want to add a class.  Easiest: append class to innerHTML.\\n# The literal pattern that appears twice is:\\n#   '<div style=\\\"'+CORNER+'\\\"></div>'+\\nold_a = \\\"'<div style=\\\\\\\\'\\\\\\\"+CORNER+\\\\\\\"\\\\\\\\'></div>'+'\\\"\\nnew_a = \\\"'<div class=\\\\\\\"ak-corner\\\\\\\" style=\\\\\\\\'\\\\\\\"+CORNER+\\\\\\\"\\\\\\\\'></div>'+'\\\"\\nif old_a in content:\\n    # Replace first instance only\\n    content = content.replace(old_a, new_a, 1)\\n    print(\\\"OK:   admin CORNER div 1 tagged\\\")\\n    content = content.replace(old_a, new_a, 1)\\n    print(\\\"OK:   admin CORNER div 2 tagged\\\")\\nelse:\\n    # Try a different escaping \\u2014 the source uses single-quoted JS string\\n    old_b = \\\"'<div style=\\\\\\\"'+CORNER+'\\\\\\\"></div>'+\\\"\\n    new_b = \\\"'<div class=\\\\\\\"ak-corner\\\\\\\" style=\\\\\\\"'+CORNER+'\\\\\\\"></div>'+\\\"\\n    if old_b in content:\\n        content = content.replace(old_b, new_b)\\n        cnt = content.count(new_b)\\n        print(f\\\"OK:   admin CORNER divs tagged (count={cnt})\\\")\\n    else:\\n        # Inspect actual line and report\\n        print(\\\"WARN: admin CORNER tagging pattern not found \\u2014 trying regex on the file\\\")\\n        import re\\n        # Find all '<div style=\\\"'+CORNER+'\\\"></div>' occurrences\\n        pat = re.compile(r\\\"'<div style=\\\\\\\"'\\\\+CORNER\\\\+'\\\\\\\"[^>]*></div>'\\\")\\n        hits = pat.findall(content)\\n        print(f\\\"   regex hits: {len(hits)}\\\")\\n        for h in hits[:3]:\\n            print(f\\\"   {h!r}\\\")\\n\\n\\n# \\u2500\\u2500 6. Add a CSS rule for the admin .ak-corner hover (using parent #_d1/#_d2) \\u2500\\n# Inject before the closing </style>\\nak_corner_css = \\\"\\\"\\\"\\n/* Admin modal corner marker hover \\u2014 sweeps to full border like .card */\\n#_d1:hover .ak-corner,\\n#_d2:hover .ak-corner,\\n#_d3:hover .ak-corner {\\n  width:  calc(100% + 2px);\\n  height: calc(100% + 2px);\\n  border-color: #39FF14;\\n  border-radius: 8px;\\n  box-shadow:\\n    0 0 10px #39FF14,\\n    0 0 28px rgba(57,255,20,0.50),\\n    0 0 56px rgba(57,255,20,0.25);\\n}\\n\\\"\\\"\\\"\\nold = \\\"</style>\\\"\\nif content.count(old) != 1:\\n    print(f\\\"WARN: </style> matched {content.count(old)} times \\u2014 expected 1\\\")\\ncontent = content.replace(old, ak_corner_css + old, 1)\\nprint(\\\"OK:   admin .ak-corner hover CSS injected\\\")\\n\\n\\n# \\u2500\\u2500 7. Add a small extra touch: perk-dot expands a touch on hover too \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\n# (the user said 'for each' \\u2014 the perk-dot is the other accent on cards)\\nperk_extra = \\\"\\\"\\\"\\n/* Perk card dot \\u2014 pulses bigger on hover for consistency */\\n.perk-card { transition: background 0.3s ease, transform 0.4s cubic-bezier(0.22,1,0.36,1); }\\n.perk-card:hover { transform: translateX(3px); }\\n.perk-card:hover .perk-dot { transform: scale(1.4); box-shadow: 0 0 10px #39FF14, 0 0 22px rgba(57,255,20,0.55); }\\n.perk-dot { transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), box-shadow 0.4s ease; }\\n\\\"\\\"\\\"\\nold = \\\"</style>\\\"\\nif content.count(old) != 1:\\n    print(f\\\"WARN: </style> matched {content.count(old)} times \\u2014 re-checking\\\")\\ncontent = content.replace(old, perk_extra + old, 1)\\nprint(\\\"OK:   perk-card hover polish injected\\\")\\n\\n\\nwith open(target, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n    f.write(content)\\n\\nprint(\\\"\\\\nFinal marker rules in file:\\\")\\nfor line in content.split(\\\"\\\\n\\\"):\\n    s = line.strip()\\n    if any(x in s for x in [\\\"::before\\\", \\\"hover::before\\\", \\\"ak-corner\\\", \\\"perk-dot\\\"]):\\n        if \\\"/*\\\" not in s[:5]:\\n            print(\\\"  \\\" + s)\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\fix_marker_hover.py\"}",
