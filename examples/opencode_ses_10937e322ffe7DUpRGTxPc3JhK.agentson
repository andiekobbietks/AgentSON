n                                <p class=\"m-0\">Use the top button '<b>+ New</b>' to create an appointment type.</p>\r\n                            </div>\r\n                            <div class=\"o_appointment_svg mx-auto text-center py-3 w-75\">\r\n                                <i class=\"mx-auto h3 fa fa-circle-o-notch fa-spin\"/>\r\n                            </div>\r\n                            <div class=\"mt-4 text-center d-none\">\r\n                                <t t-if=\"current_search\">\r\n                                    <h4>No result for \"<t t-out=\"current_search\"/>\"</h4>\r\n                                    <a href=\"/appointment\">See all appointments <i class=\"fa fa-long-arrow-right\"/></a>\r\n                                </t>\r\n                                <h4 t-else=\"\">There is currently no appointment available</h4>\r\n                            </div>\r\n                        </div>\r\n                        <div t-elif=\"mode_cards\" class=\"col-md px-0\">\r\n                            <div class=\"row row-gap-3\">\r\n                                <t t-call=\"website_appointment.appointments_cards\"/>\r\n                            </div>\r\n                        </div>\r\n                        <div t-elif=\"mode_pictures\" class=\"row g-3\">\r\n                            <t t-call=\"website_appointment.appointments_pictures\"/>\r\n                        </div>\r\n                        <div t-else=\"\" class=\"row g-2\">\r\n                            <t t-call=\"website_appointment.appointments_list\"/>\r\n                        </div>\r\n                        <div class=\"d-flex justify-content-center my-3\">\r\n                            <t t-call=\"website.pager\"/>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"oe_structure oe_empty\"/>\r\n                </div>\r\n            </div>\r\n        </t>\r\n    </t>\r\n\r\n\r\n",
