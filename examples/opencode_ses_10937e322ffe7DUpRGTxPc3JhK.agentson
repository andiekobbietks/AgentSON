      "code": "{\"content\": \"\\\"\\\"\\\"Find the actual /book/<token> page template + the invite/booking record.\\n\\nCONTAINS LIVE ODOO API KEY.\\n\\\"\\\"\\\"\\nimport xmlrpc.client\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"  # noqa: S105\\n\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\")\\nuid = common.authenticate(DB, USERNAME, API_KEY, {})\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\")\\n\\n# 1. Inspect appointment.invite \\u2014 this likely holds the share token\\nprint(\\\"[1] appointment.invite \\u2014 schema + records\\\")\\ntry:\\n    f = models.execute_kw(DB, uid, API_KEY, \\\"appointment.invite\\\", \\\"fields_get\\\", [], {\\\"attributes\\\": [\\\"type\\\", \\\"help\\\"]})\\n    print(\\\"  fields:\\\")\\n    for name, meta in sorted(f.items()):\\n        print(f\\\"    {name:<28} {meta.get('type','?'):<10} {meta.get('help','')[:70]}\\\")\\n    recs = models.execute_kw(DB, uid, API_KEY, \\\"appointment.invite\\\", \\\"read\\\", [[1, 2]])\\n    for r in recs:\\n        print(f\\\"  record {r.get('id')}:\\\")\\n        for k, v in r.items():\\n            sv = repr(v)\\n            if len(sv) > 140: sv = sv[:137] + \\\"...\\\"\\n            print(f\\\"    {k:<28} = {sv}\\\")\\nexcept Exception as e:\\n    print(f\\\"  ERR: {e}\\\")\\n\\n# 2. Inspect calendar.event \\u2014 might be the appointment event\\nprint(\\\"\\\\n[2] calendar.event \\u2014 schema + records\\\")\\ntry:\\n    f = models.execute_kw(DB, uid, API_KEY, \\\"calendar.event\\\", \\\"fields_get\\\", [], {\\\"attributes\\\": [\\\"type\\\"]})\\n    recs = models.execute_kw(DB, uid, API_KEY, \\\"calendar.event\\\", \\\"read\\\", [[1, 2]])\\n    for r in recs:\\n        print(f\\\"  record {r.get('id')}:\\\")\\n        for k, v in r.items():\\n            if k in (\\\"description\\\", \\\"location\\\", \\\"name\\\", \\\"access_token\\\", \\\"appointment_type_id\\\", \\\"state\\\", \\\"active\\\"):\\n                print(f\\\"    {k:<28} = {v!r}\\\")\\nexcept Exception as e:\\n    print(f\\\"  ERR: {e}\\\")\\n\\n# 3. Find the QWeb view that actually renders the appointment PAGE (not the button)\\nprint(\\\"\\\\n[3] Views that render the appointment TYPE page (search for 'appointment_info' / 'h1' usage)\\\")\\ntry:\\n    # Get all qweb views mentioning appointment\\n    candidates = models.execute_kw(DB, uid, API_KEY, \\\"ir.ui.view\\\", \\\"search_read\\\",\\n        [[[\\\"key\\\", \\\"ilike\\\", \\\"website_appointment\\\"]]],\\n        {\\\"fields\\\": [\\\"id\\\", \\\"key\\\", \\\"name\\\", \\\"arch\\\", \\\"inherit_id\\\"]})\\n    for v_ in candidates:\\n        if v_.get(\\\"arch\\\") and (\\\"appointment_type\\\" in v_[\\\"arch\\\"] or \\\"h1\\\" in v_[\\\"arch\\\"] or \\\"<h1\\\" in v_[\\\"arch\\\"]):\\n            print(f\\\"  -- {v_['key']} (id {v_['id']}) --\\\")\\n            # look for h1\\n            arch = v_[\\\"arch\\\"]\\n            for snippet_marker in [\\\"<h1\\\", \\\"appointment_type.name\\\", \\\"appointment_type.display_name\\\"]:\\n                idx = arch.find(snippet_marker)\\n                if idx >= 0:\\n                    print(f\\\"    '{snippet_marker}' at {idx}: ...{arch[max(0,idx-40):idx+120].replace(chr(10),' | ')}...\\\")\\n            # also search for \\\"& More\\\" or the old name\\n            for tok in [\\\"& More\\\", \\\"Discovery Consultation\\\", \\\"appointment_type.name\\\"]:\\n                idx = arch.find(tok)\\n                if idx >= 0:\\n                    print(f\\\"    '{tok}' at {idx}: ...{arch[max(0,idx-40):idx+120].replace(chr(10),' | ')}...\\\")\\nexcept Exception as e:\\n    print(f\\\"  ERR: {e}\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\odoo_invite_inspect.py\"}",
