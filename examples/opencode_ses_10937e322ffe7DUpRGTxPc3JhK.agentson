e 52, in retrying\\n    result = func()\\n             ^^^^^^\\n  File \"/home/odoo/src/odoo/saas-19.3/odoo/service/model.py\", line 55, in call_kw\\n    result = method(recs, *args, **kwargs)\\n             ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\\n  File \"/home/odoo/src/odoo/saas-19.3/odoo/orm/models.py\", line 5182, in search_read\\n    records = self.search_fetch(domain or [], fields, offset=offset, limit=limit, order=order)\\n              ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\\n  File \"/home/odoo/src/odoo/saas-19.3/odoo/orm/models.py\", line 1456, in search_fetch\\n    fields_to_fetch = self._determine_fields_to_fetch(field_names)\\n                      ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\\n  File \"/home/odoo/src/odoo/saas-19.3/odoo/orm/models.py\", line 3141, in _determine_fields_to_fetch\\n    raise ValueError(f\"Invalid field {field_name!r} on {self._name!r}\") from e\\nValueError: Invalid field \\'model\\' on \\'web_tour.tour\\'\\n'>\r\n\r\n[4] Stale ir.model.data from the 9 uninstalled modules\r\n  7 ir.model.data records still reference the uninstalled modules\r\n    account      group_account_basic                           -> res.groups#33\r\n    account      group_cash_rounding                           -> res.groups#37\r\n    account      group_delivery_invoice_address                -> res.groups#30\r\n    project      group_project_stages                          -> res.groups#53\r\n    purchase     group_send_reminder                           -> res.groups#86\r\n    purchase     group_warning_purchase                        -> res.groups#85\r\n    sign         manage_template_access                        -> res.groups#27\r\n\r\n",
