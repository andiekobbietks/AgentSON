      "code": "{\"content\": \"\\\"\\\"\\\"Check the Odoo Appointment module + booking link status.\\n\\nAlso contains the live Odoo API key. Delete after use.\\n\\\"\\\"\\\"\\nimport xmlrpc.client\\nimport sys\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"  # noqa: S105\\n\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\")\\ntry:\\n    uid = common.authenticate(DB, USERNAME, API_KEY, {})\\nexcept Exception as e:\\n    print(f\\\"ERR: cannot reach Odoo: {e}\\\", file=sys.stderr)\\n    sys.exit(1)\\nif not uid:\\n    print(\\\"ERR: authentication failed\\\", file=sys.stderr)\\n    sys.exit(1)\\nprint(f\\\"OK: authenticated as uid={uid}\\\")\\n\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\")\\n\\n# \\u2500\\u2500 1. Is the Appointment app installed at all? \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nprint(\\\"\\\\n[1] Appointment module state\\\")\\nappt_mod = models.execute_kw(\\n    DB, uid, API_KEY,\\n    \\\"ir.module.module\\\", \\\"search_read\\\",\\n    [[[\\\"name\\\", \\\"in\\\", [\\\"appointment\\\", \\\"website_appointment\\\"]]]],\\n    {\\\"fields\\\": [\\\"name\\\", \\\"shortdesc\\\", \\\"state\\\"]},\\n)\\nfor m in appt_mod:\\n    print(f\\\"  - {m['shortdesc']:<20} ({m['name']})  state={m['state']}\\\")\\nif not appt_mod or all(m[\\\"state\\\"] != \\\"installed\\\" for m in appt_mod):\\n    print(\\\"  \\u2192 Appointment module is NOT installed. The booking link is NOT ready.\\\")\\n    print(\\\"    Install it via Apps menu (search 'Appointments') and publish a type.\\\")\\n    sys.exit(0)\\n\\n# \\u2500\\u2500 2. What appointment types exist? \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nprint(\\\"\\\\n[2] Appointment types\\\")\\ntry:\\n    types = models.execute_kw(\\n        DB, uid, API_KEY,\\n        \\\"appointment.type\\\", \\\"search_read\\\",\\n        [[]],\\n        {\\\"fields\\\": [\\n            \\\"id\\\", \\\"name\\\", \\\"is_published\\\", \\\"website_id\\\",\\n            \\\"appointment_tz\\\", \\\"min_schedule_hours\\\", \\\"max_schedule_days\\\",\\n            \\\"message_confirmation\\\",\\n        ]},\\n    )\\nexcept Exception as e:\\n    print(f\\\"  ERR: cannot query appointment.type: {e}\\\", file=sys.stderr)\\n    sys.exit(1)\\n\\nif not types:\\n    print(\\\"  \\u2192 No appointment types defined yet.\\\")\\n    print(\\\"    Go to Appointments \\u2192 Configuration \\u2192 Appointment Types \\u2192 New.\\\")\\n    sys.exit(0)\\n\\nprint(f\\\"  Found {len(types)} appointment type(s):\\\")\\nfor t in types:\\n    pub = \\\"PUBLISHED\\\" if t.get(\\\"is_published\\\") else \\\"DRAFT\\\"\\n    print(f\\\"  - [{t['id']}] {t['name']}  ({pub})  tz={t.get('appointment_tz','-')}\\\")\\n    print(f\\\"      lead-time: {t.get('min_schedule_hours','?')}h min, {t.get('max_schedule_days','?')}d max\\\")\\n\\n# \\u2500\\u2500 3. Public booking URLs \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nprint(\\\"\\\\n[3] Public booking URLs\\\")\\nready = False\\nfor t in types:\\n    if t.get(\\\"is_published\\\"):\\n        slug = t[\\\"name\\\"].lower().replace(\\\" \\\", \\\"-\\\")\\n        # Odoo's URL pattern \\u2014 verify by HEAD request\\n        candidates = [\\n            f\\\"{URL}/appointment/{t['id']}\\\",\\n            f\\\"{URL}/book-appointment/{t['id']}\\\",\\n        ]\\n        print(f\\\"  - {t['name']}  \\u2192\\\")\\n        for url in candidates:\\n            print(f\\\"      {url}\\\")\\n        ready = True\\n\\nif not ready:\\n    print(\\\"  \\u2192 No appointment type is published. Toggle 'Published' to make the link live.\\\")\\nprint(f\\\"\\\\nResult: {'APPOINTMENT LINK IS READY' if ready else 'NOT READY YET \\u2014 see above'}\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\odoo_appointment_check.py\"}",
