      "code": "{\"command\": \"$urls = @(\\n  \\\"https://andiekobbie.odoo.com/book/27e80afd\\\",\\n  \\\"https://andiekobbie.odoo.com/appointment/discovery-consultation-1\\\",\\n  \\\"https://andiekobbie.odoo.com/odoo\\\"\\n)\\nforeach ($u in $urls) {\\n  try {\\n    $r = Invoke-WebRequest -Uri $u -UseBasicParsing -TimeoutSec 20 -MaximumRedirection 5\\n    $title = (Select-String -InputObject $r.Content -Pattern \\\"<title>[^<]*</title>\\\" -AllMatches).Matches[0].Value -replace \\\"<title>|</title>\\\",\\\"\\\"\\n    Write-Host \\\"  $u\\\"\\n    Write-Host \\\"      status=$($r.StatusCode)  title=$title  bytes=$($r.Content.Length)\\\"\\n    $hasAppt = $r.Content -match \\\"appointment_intro|Discovery Consultation|Andrea|appointment_tz|booking_intro|message_intro\\\"\\n    $hasTour = $r.Content -match \\\"TourService|getTour|tour_enabled|web_studio_new_app_tour\\\"\\n    Write-Host \\\"      has_appt_marker=$hasAppt  has_tour_marker=$hasTour\\\"\\n  } catch {\\n    $code = $null\\n    if ($_.Exception.Response) { $code = $_.Exception.Response.StatusCode.value__ }\\n    Write-Host \\\"  $u  -> $code  $($_.Exception.Message)\\\"\\n  }\\n}\", \"timeout\": 90000, \"description\": \"Verify share link + canonical URL + backend\"}",
