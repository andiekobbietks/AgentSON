      "code": "{\"content\": \"import sys\\n\\ntarget = r\\\"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\akcloud-site\\\\index.html\\\"\\n\\nwith open(target, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n    content = f.read()\\n\\n\\ndef replace_once(haystack, old, new, label):\\n    if old not in haystack:\\n        print(f\\\"FAIL: {label}\\\")\\n        return haystack\\n    if haystack.count(old) > 1:\\n        print(f\\\"FAIL: {label} (matched {haystack.count(old)} times \\u2014 expected 1)\\\")\\n        return haystack\\n    print(f\\\"OK:   {label}\\\")\\n    return haystack.replace(old, new)\\n\\n\\n# \\u2500\\u2500 1. .card \\u2192 trace from corner to full border, overshoot, magnifier glow \\u2500\\u2500\\nold = \\\"\\\"\\\"  .card { position: relative; background: #111; border: 1px solid #242424; border-radius: 8px; padding: 30px; transition: border-color 0.2s, box-shadow 0.2s; }\\n  .card::before { content: ''; position: absolute; top: -1px; left: -1px; width: 38px; height: 38px; border-top: 2px solid #39FF14; border-left: 2px solid #39FF14; border-top-left-radius: 8px; box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); transition: width 0.2s, height 0.2s, box-shadow 0.2s; }\\n  .card:hover { border-color: rgba(57,255,20,0.30); box-shadow: 0 0 0 1px rgba(57,255,20,0.15), 0 8px 32px rgba(0,0,0,0.40); }\\n  .card:hover::before { width: 80px; height: 80px; box-shadow: 0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.50), 0 0 48px rgba(57,255,20,0.25); }\\\"\\\"\\\"\\n\\nnew = \\\"\\\"\\\"  .card {\\n    position: relative; background: #111; border: 1px solid #242424; border-radius: 8px; padding: 30px;\\n    transition: border-color 0.3s ease, box-shadow 0.4s ease, transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);\\n  }\\n  .card::before {\\n    content: ''; position: absolute; top: -1px; left: -1px;\\n    width: 38px; height: 38px;\\n    border: 2px solid transparent;\\n    border-top-color: #39FF14; border-left-color: #39FF14;\\n    border-top-left-radius: 8px;\\n    box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55);\\n    pointer-events: none; z-index: 1;\\n    transition:\\n      width        0.55s cubic-bezier(0.22, 1, 0.36, 1),\\n      height       0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.06s,\\n      border-color 0.4s  ease 0.24s,\\n      box-shadow   0.45s ease 0.12s,\\n      border-radius 0.45s ease 0.18s;\\n  }\\n  .card:hover {\\n    border-color: rgba(57,255,20,0.30);\\n    box-shadow: 0 0 0 1px rgba(57,255,20,0.15), 0 8px 32px rgba(0,0,0,0.40);\\n    transform: translateY(-2px);\\n  }\\n  .card:hover::before {\\n    /* sweep from the 38px corner to cover the whole card, with a small overshoot\\n       for the magnifier feel \\u2014 extends ~1px past each edge. */\\n    width:  calc(100% + 2px);\\n    height: calc(100% + 2px);\\n    border-color: #39FF14;\\n    border-radius: 8px;\\n    box-shadow:\\n      0 0 10px #39FF14,\\n      0 0 28px rgba(57,255,20,0.50),\\n      0 0 56px rgba(57,255,20,0.25);\\n  }\\\"\\\"\\\"\\n\\ncontent = replace_once(content, old, new, \\\".card hover sweep\\\")\\n\\n\\n# \\u2500\\u2500 2. .card-outcome \\u2014 same treatment \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nold = \\\"\\\"\\\"  .card-outcome { position: relative; background: #111; border: 1px solid #242424; border-radius: 8px; padding: 32px; transition: border-color 0.2s, box-shadow 0.2s; }\\n  .card-outcome::before { content: ''; position: absolute; top: -1px; left: -1px; width: 38px; height: 38px; border-top: 2px solid #39FF14; border-left: 2px solid #39FF14; border-top-left-radius: 8px; box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); transition: width 0.2s, height 0.2s, box-shadow 0.2s; }\\n  .card-outcome:hover { border-color: rgba(57,255,20,0.30); box-shadow: 0 0 0 1px rgba(57,255,20,0.15), 0 8px 32px rgba(0,0,0,0.40); }\\n  .card-outcome:hover::before { width: 80px; height: 80px; box-shadow: 0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.50), 0 0 48px rgba(57,255,20,0.25); }\\\"\\\"\\\"\\n\\nnew = \\\"\\\"\\\"  .card-outcome {\\n    position: relative; background: #111; border: 1px solid #242424; border-radius: 8px; padding: 32px;\\n    transition: border-color 0.3s ease, box-shadow 0.4s ease, transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);\\n  }\\n  .card-outcome::before {\\n    content: ''; position: absolute; top: -1px; left: -1px;\\n    width: 38px; height: 38px;\\n    border: 2px solid transparent;\\n    border-top-color: #39FF14; border-left-color: #39FF14;\\n    border-top-left-radius: 8px;\\n    box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55);\\n    pointer-events: none; z-index: 1;\\n    transition:\\n      width        0.55s cubic-bezier(0.22, 1, 0.36, 1),\\n      height       0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.06s,\\n      border-color 0.4s  ease 0.24s,\\n      box-shadow   0.45s ease 0.12s,\\n      border-radius 0.45s ease 0.18s;\\n  }\\n  .card-outcome:hover {\\n    border-color: rgba(57,255,20,0.30);\\n    box-shadow: 0 0 0 1px rgba(57,255,20,0.15), 0 8px 32px rgba(0,0,0,0.40);\\n    transform: translateY(-2px);\\n  }\\n  .card-outcome:hover::before {\\n    width:  calc(100% + 2px);\\n    height: calc(100% + 2px);\\n    border-color: #39FF14;\\n    border-radius: 8px;\\n    box-shadow:\\n      0 0 10px #39FF14,\\n      0 0 28px rgba(57,255,20,0.50),\\n      0 0 56px rgba(57,255,20,0.25);\\n  }\\\"\\\"\\\"\\n\\ncontent = replace_once(content, old, new, \\\".card-outcome hover sweep\\\")\\n\\n\\n# \\u2500\\u2500 3. Admin modal CORNER base style \\u2014 already done by previous run, skip if so\\nold = \\\"var CORNER='position:absolute;top:-1px;left:-1px;width:44px;height:44px;border-top:2px solid #39FF14;border-left:2px solid #39FF14;border-top-left-radius:8px;box-shadow:0 0 6px #39FF14,0 0 14px rgba(57,255,20,0.55);pointer-events:none;';\\\"\\nnew = \\\"var CORNER='position:absolute;top:-1px;left:-1px;width:44px;height:44px;border:2px solid transparent;border-top-color:#39FF14;border-left-color:#39FF14;border-top-left-radius:8px;box-shadow:0 0 6px #39FF14,0 0 14px rgba(57,255,20,0.55);pointer-events:none;z-index:1;transition:width 0.55s cubic-bezier(0.22,1,0.36,1),height 0.55s cubic-bezier(0.22,1,0.36,1) 0.06s,border-color 0.4s ease 0.24s,box-shadow 0.45s ease 0.12s,border-radius 0.45s ease 0.18s;';\\\"\\ncontent = replace_once(content, old, new, \\\"admin CORNER base style\\\")\\n\\n\\n# \\u2500\\u2500 4. Tag the two CORNER divs with class=\\\"ak-corner\\\" (literal string match) \\u2500\\nold = \\\"'<div style=\\\\\\\"'+CORNER+'\\\\\\\"></div>'+\\\"\\nnew = \\\"'<div class=\\\\\\\"ak-corner\\\\\\\" style=\\\\\\\"'+CORNER+'\\\\\\\"></div>'+\\\"\\nif old in content:\\n    cnt = content.count(old)\\n    content = content.replace(old, new)\\n    print(f\\\"OK:   tagged {cnt} admin CORNER div(s) with class\\\")\\nelse:\\n    print(\\\"FAIL: CORNER div literal not found\\\")\\n\\n\\n# \\u2500\\u2500 5. Inject CSS for the admin .ak-corner hover + perk-card polish \\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\nextra_css = \\\"\\\"\\\"\\n  /* \\u2500\\u2500 Admin modal corner marker hover \\u2014 matches the card sweep \\u2500\\u2500 */\\n  #_d1:hover .ak-corner,\\n  #_d2:hover .ak-corner,\\n  #_d3:hover .ak-corner {\\n    width:  calc(100% + 2px);\\n    height: calc(100% + 2px);\\n    border-color: #39FF14;\\n    border-radius: 8px;\\n    box-shadow:\\n      0 0 10px #39FF14,\\n      0 0 28px rgba(57,255,20,0.50),\\n      0 0 56px rgba(57,255,20,0.25);\\n  }\\n  /* \\u2500\\u2500 Perk card dot \\u2014 pulse + nudge on hover, for visual consistency \\u2500\\u2500 */\\n  .perk-card { transition: background 0.3s ease, transform 0.4s cubic-bezier(0.22,1,0.36,1); }\\n  .perk-card:hover { transform: translateX(3px); }\\n  .perk-dot { transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), box-shadow 0.4s ease; }\\n  .perk-card:hover .perk-dot { transform: scale(1.45); box-shadow: 0 0 10px #39FF14, 0 0 22px rgba(57,255,20,0.55); }\\n\\\"\\\"\\\"\\n\\nold = \\\"</style>\\\"\\nif content.count(old) != 1:\\n    print(f\\\"FAIL: </style> matched {content.count(old)} times\\\")\\n    sys.exit(1)\\ncontent = content.replace(old, extra_css + old, 1)\\nprint(\\\"OK:   admin hover CSS + perk polish injected before </style>\\\")\\n\\n\\nwith open(target, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n    f.write(content)\\n\\n# Quick verification\\nprint(\\\"\\\\n--- verification ---\\\")\\nmarkers = [\\n    \\\"ak-corner\\\",\\n    \\\".card:hover::before\\\",\\n    \\\"calc(100% + 2px)\\\",\\n    \\\"perk-card:hover .perk-dot\\\",\\n    \\\"border-top-color: #39FF14; border-left-color: #39FF14;\\\",\\n]\\nfor m in markers:\\n    n = content.count(m)\\n    print(f\\\"  '{m}'  \\u2192  {n} occurrence(s)\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\fix_marker_hover.py\"}",
