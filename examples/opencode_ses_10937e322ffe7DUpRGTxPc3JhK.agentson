2.7s both;\\n  }\\n  @keyframes spxPresFade {\\n    0%    { opacity: 0; }\\n    12%   { opacity: 1; }\\n    68%   { opacity: 1; }\\n    100%  { opacity: 0; }\\n  }\\n  @keyframes spxPreLine {\\n    from { width: 0; opacity: 0; }\\n    to   { width: min(340px, 70vw); opacity: 1; }\\n  }\\n  @keyframes spxPreAK {\\n    from { opacity: 0; letter-spacing: 0.1em; transform: translateY(6px); }\\n    to   { opacity: 1; letter-spacing: 0.55em; transform: translateY(0); }\\n  }\\n  @keyframes spxType {\\n    from { width: 0; }\\n    to   { width: 9.4em; }\\n  }\\n  @keyframes spxCursor {\\n    0%, 100% { border-color: #39FF14; }\\n    50%       { border-color: transparent; }\\n  }\\n  @keyframes spxCursorOff {\\n    to { border-color: transparent; }\\n  }\\\"\\\"\\\"\\n\\nif old_presents_css in content:\\n    content = content.replace(old_presents_css, new_presents_css)\\n    print(\\\"OK: presents CSS updated\\\")\\nelse:\\n    print(\\\"FAIL: presents CSS not found - check whitespace/diff\\\")\\n    sys.exit(1)\\n\\n# \\u2500\\u2500 SHIFT BIG AK from 1.4s -> 3.0s\\nold1 = \\\"animation: spxAK 3.1s cubic-bezier(0.4, 0, 0.2, 1) 1.4s forwards;\\\"\\nnew1 = \\\"animation: spxAK 3.1s cubic-bezier(0.4, 0, 0.2, 1) 3.0s forwards;\\\"\\nif old1 in content:\\n    content = content.replace(old1, new1)\\n    print(\\\"OK: spxAK delay -> 3.0s\\\")\\nelse:\\n    print(\\\"FAIL: spxAK delay not found\\\")\\n\\n# \\u2500\\u2500 SHIFT radial: 1.92s -> 3.5s\\nold2 = \\\"animation: spxRadialPulse 2.4s ease-in-out 1.92s 2 alternate;\\\"\\nnew2 = \\\"animation: spxRadialPulse 2.4s ease-in-out 3.5s 2 alternate;\\\"\\nif old2 in content:\\n    content = content.replace(old2, new2)\\n    print(\\\"OK: spxRadialPulse delay -> 3.5s\\\")\\nelse:\\n    print(\\\"FAIL: spxRadialPulse delay not found\\\")\\n\\n# \\u2500\\u2500 SHIFT logo: 4.0s -> 5.6s\\nold3 = \\\"animation: spxLogo 2.4s cubic-bezier(0.4, 0, 0.2, 1) 4.0s forwards;\\\"\\nnew3 = \\\"animation: spxLogo 2.4s cubic-bezier(0.4, 0, 0.2, 1) 5.