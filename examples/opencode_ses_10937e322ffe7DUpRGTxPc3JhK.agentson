      "code": "{\"content\": \"\\\"\\\"\\\"Find the correct host field on appointment.type.\\n\\nCONTAINS LIVE ODOO API KEY.\\n\\\"\\\"\\\"\\nimport xmlrpc.client\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"  # noqa: S105\\n\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\")\\nuid = common.authenticate(DB, USERNAME, API_KEY, {})\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\")\\n\\n# Dump full schema of appointment.type\\nf = models.execute_kw(DB, uid, API_KEY, \\\"appointment.type\\\", \\\"fields_get\\\", [], {\\\"attributes\\\": [\\\"type\\\", \\\"help\\\"]})\\nprint(\\\"appointment.type fields (looking for host/staff/assignee/responsible):\\\")\\nfor name, meta in sorted(f.items()):\\n    if any(kw in name.lower() for kw in [\\\"host\\\", \\\"staff\\\", \\\"user\\\", \\\"assignee\\\", \\\"responsible\\\", \\\"employee\\\", \\\"seller\\\", \\\"owner\\\"]):\\n        print(f\\\"  {name:<32} {meta.get('type','?'):<12} {meta.get('help','')[:90]}\\\")\\n\\n# Also show all many2one / many2many fields for completeness\\nprint(\\\"\\\\nAll many2one / many2many fields:\\\")\\nfor name, meta in sorted(f.items()):\\n    if meta.get(\\\"type\\\") in (\\\"many2one\\\", \\\"many2many\\\"):\\n        print(f\\\"  {name:<32} {meta['type']:<10} {meta.get('relation','')}\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\odoo_host_field.py\"}",
