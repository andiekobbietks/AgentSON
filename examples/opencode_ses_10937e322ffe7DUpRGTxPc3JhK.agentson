      "code": "{\"content\": \"import urllib.request, re, time\\nfor path in [\\\"/book/27e80afd\\\", \\\"/appointment/discovery-consultation-1\\\"]:\\n    url = f\\\"https://andiekobbie.odoo.com{path}?cb={int(time.time()*1000)}\\\"\\n    try:\\n        req = urllib.request.Request(url, headers={\\\"User-Agent\\\":\\\"Mozilla/5.0\\\",\\\"Cache-Control\\\":\\\"no-cache\\\",\\\"Pragma\\\":\\\"no-cache\\\"})\\n        with urllib.request.urlopen(req, timeout=20) as resp:\\n            html = resp.read().decode(\\\"utf-8\\\", errors=\\\"replace\\\")\\n            t = re.search(r\\\"<title>([^<]+)</title>\\\", html)\\n            h1s = re.findall(r\\\"<h1[^>]*>([^<]+)</h1>\\\", html)\\n            print(f\\\"{path}\\\")\\n            print(f\\\"  status={resp.status}  bytes={len(html)}\\\")\\n            print(f\\\"  title: {t.group(1) if t else '-'}\\\")\\n            print(f\\\"  h1:    {h1s}\\\")\\n            # Also check for our intro markers\\n            has_intro = \\\"Sovereign cloud journey\\\" in html or \\\"sovereign cloud journey\\\" in html\\n            has_video = \\\"Video call\\\" in html\\n            has_30 = \\\"30 minutes\\\" in html\\n            print(f\\\"  markers: intro={has_intro}  video_pill={has_video}  30min={has_30}\\\")\\n    except Exception as e:\\n        print(f\\\"{path} ERR: {e}\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\odoo_verify_final.py\"}",
