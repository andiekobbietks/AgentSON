      "output": "<path>C:\\Users\\LLM-Test\\Downloads\\index (2).html</path>\n<type>file</type>\n<content>\n125:   }\n126: \n127:   /* ── SPLASH: AK PRESENTS intro ── */\n128:   #spx-presents {\n129:     position: absolute;\n130:     display: flex;\n131:     flex-direction: column;\n132:     align-items: center;\n133:     gap: 20px;\n134:     opacity: 0;\n135:     animation: spxPresFade 2.8s cubic-bezier(0.4,0,0.2,1) forwards;\n136:   }\n137:   #spx-pre-ak {\n138:     font-family: 'Exo 2', sans-serif; font-weight: 900;\n139:     font-size: clamp(28px, 6vw, 48px);\n140:     letter-spacing: 0.55em; text-transform: uppercase;\n141:     color: #39FF14;\n142:     text-shadow:\n143:       0 0 12px #39FF14,\n144:       0 0 32px rgba(57,255,20,0.65),\n145:       0 0 70px rgba(57,255,20,0.3);\n146:     opacity: 0;\n147:     animation: spxPreAK 0.5s ease 0.35s both;\n148:   }\n149:   #spx-pre-line {\n150:     height: 1px;\n151:     width: 0;\n152:     background: linear-gradient(90deg, transparent, #39FF14, transparent);\n153:     box-shadow: 0 0 10px #39FF14, 0 0 28px rgba(57,255,20,0.5);\n154:     animation: spxPreLine 0.65s ease 0.2s both;\n155:   }\n156:   #spx-pre-word {\n157:     font-family: 'JetBrains Mono', monospace; font-weight: 500;\n158:     font-size: clamp(11px, 2.2vw, 15px);\n159:     letter-spacing: 0.52em; text-transform: uppercase;\n160:     color: #C8C8C8;\n161:     overflow: hidden; white-space: nowrap;\n162:     width: 0;\n163:     border-right: 2px solid #39FF14;\n164:     box-sizing: content-box;\n165:     animation:\n166:       spxType 0.7s steps(8,end) 0.75s both,\n167:       spxCursor 0.6s step-end 0.75s 3,\n168:       spxCursorOff 0s 2.7s both;\n169:   }\n170:   @keyframes spxPresFade {\n171:     0%    { opacity: 0; }\n172:     12%   { opacity: 1; }\n173:     68%   { opacity: 1; }\n174:     100%  { opacity: 0; }\n175:   }\n176:   @keyframes spxPreLine {\n177:     from { width: 0; opacity: 0; }\n178:     to   { width: min(340px, 70vw); opacity: 1; }\n179:   }\n180:   @keyframes spxPreAK {\n181:     from { opacity: 0; letter-spacing: 0.1em; transform: translateY(6px); }\n182:     to   { opacity: 1; letter-spacing: 0.55em; transform: translateY(0); }\n183:   }\n184:   @keyframes spxType {\n185:     from { width: 0; }\n186:     to   { width: 9.4em; }\n187:   }\n188:   @keyframes spxCursor {\n189:     0%, 100% { border-color: #39FF14; }\n190:     50%       { border-color: transparent; }\n191:   }\n192:   @keyframes spxCursorOff {\n193:     to { border-color: transparent; }\n194:   }\n195: \n196:   /* ── SPLASH ── */\n197:   #spx {\n198:     position: fixed; inset: 0; z-index: 9999;\n199:     display: flex; align-items: center; justify-content: center;\n200:     background: #080808; overflow: hidden;\n201:   }\n202:   #spx-grid {\n203:     position: absolute; inset: 0; pointer-events: none;\n204:     background-image: linear-gradient(rgba(57,255,20,0.03) 1px, transparent 1px),\n205:                       linear-gradient(90deg, rgba(57,255,20,0.03) 1px, transparent 1px);\n206:     background-size: 48px 48px;\n207:   }\n208:   #spx-radial {\n209:     position: absolute; inset: 0; pointer-events: none;\n210:     background: radial-gradient(ellipse 65% 60% at 50% 50%,\n211:       rgba(57,255,20,0.11) 0%, rgba(57,255,20,0.04) 45%, transparent 70%);\n212:     animation: spxRadialPulse 2.4s ease-in-out 3.5s 2 alternate;\n213:   }\n214:   #spx-ak {\n215:     position: absolute;\n216:     font-family: 'Exo 2', sans-serif; font-weight: 900;\n217:     font-size: clamp(130px, 35vmin, 340px);\n218:     line-height: 1; letter-spacing: -0.03em; color: #39FF14;\n219:     text-shadow:\n220:       0 0 24px #39FF14,\n221:       0 0 70px rgba(57,255,20,0.65),\n222:       0 0 140px rgba(57,255,20,0.38),\n223:       0 0 260px rgba(57,255,20,0.18);\n224:     animation: spxAK 3.1s cubic-bezier(0.4, 0, 0.2, 1) 3.0s forwards;\n225:   }\n226:   #spx-logo {\n227:     position: absolute;\n228:     display: flex; flex-direction: column; align-items: center;\n229:     opacity: 0;\n230:     animation: spxLogo 2.4s cubic-bezier(0.4, 0, 0.2, 1) 5.6s forwards;\n231:   }\n232:   #spx-logo img {\n233:     width: min(440px, 74vw); height: auto;\n234:     filter:\n235:       drop-shadow(0 0 28px rgba(57,255,20,0.42))\n236:       drop-shadow(0 0 72px rgba(57,255,20,0.18));\n237:     image-rendering: -webkit-optimize-contrast;\n238:   }\n239:   #spx-tagline {\n240:     margin-top: 20px;\n241:     font-family: 'Exo 2', sans-serif; font-weight: 700;\n242:     font-size: clamp(10px, 2vw, 13px); letter-spacing: 0.32em;\n243:     text-transform: uppercase; color: #787878;\n244:     opacity: 0;\n\n(Showing lines 125-244 of 948. Use offset=245 to continue.)\n</content>",
