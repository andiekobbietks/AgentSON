True\r\n  [3328] website_appointment.appointment_info                    active=True\r\n  [3348] website_appointment.s_appointments                      active=True\r\n  [3349] website_appointment.s_appointments_card                 active=True\r\n  [3334] website_appointment.appointments_cards                  active=True\r\n  [1115] appointment.appointments_dropdown                       active=True\r\n  [1116] appointment.appointment_type_select                     active=True\r\n  [3337] website_appointment.appointments_list                   active=True\r\n  [3351] website_appointment.s_appointments_list                 active=True\r\n  [3350] website_appointment.s_appointments_picture              active=True\r\n  [3339] website_appointment.appointments_pictures               active=True\r\n  [3355] website_appointment.s_appointments_preview_data         active=True\r\n  [3356] website_appointment.s_appointments_picture_preview_data active=True\r\n  [3357] website_appointment.s_appointments_list_preview_data    active=True\r\n\r\n",
