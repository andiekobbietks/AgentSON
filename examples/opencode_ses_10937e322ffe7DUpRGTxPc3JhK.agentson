      "code": "{\"content\": \"\\\"\\\"\\\"Read the website_calendar_index view (likely the appointment page template).\\n\\nCONTAINS LIVE ODOO API KEY.\\n\\\"\\\"\\\"\\nimport xmlrpc.client\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"  # noqa: S105\\n\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\")\\nuid = common.authenticate(DB, USERNAME, API_KEY, {})\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\")\\n\\n# Read views that might contain the H1\\nfor vid in [3330, 3329, 3328, 3359, 3348, 3351, 3355, 3356, 3357]:\\n    try:\\n        v = models.execute_kw(DB, uid, API_KEY, \\\"ir.ui.view\\\", \\\"read\\\",\\n            [[vid]], {\\\"fields\\\": [\\\"id\\\", \\\"name\\\", \\\"key\\\", \\\"arch\\\"]})[0]\\n        arch = v.get(\\\"arch\\\") or \\\"\\\"\\n        has_h1 = \\\"<h1\\\" in arch\\n        has_appt = \\\"appointment_type\\\" in arch\\n        marker = \\\"\\\"\\n        if has_h1: marker += \\\" [has h1]\\\"\\n        if has_appt: marker += \\\" [has appointment_type]\\\"\\n        print(f\\\"[{v['id']:>4}] {v['key']:<60}  arch_len={len(arch)}{marker}\\\")\\n        if has_h1 or has_appt:\\n            # show relevant lines\\n            for ln in arch.splitlines():\\n                if \\\"<h1\\\" in ln or \\\"<h2\\\" in ln or \\\"appointment_type.name\\\" in ln or \\\"appointment_type.display_name\\\" in ln:\\n                    print(f\\\"        {ln.strip()[:200]}\\\")\\n    except Exception as e:\\n        print(f\\\"  [{vid}] ERR: {e}\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\odoo_read_calendar_index.py\"}",
