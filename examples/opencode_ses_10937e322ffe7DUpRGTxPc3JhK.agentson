      "code": "{\"content\": \"\\\"\\\"\\\"Odoo cleanup \\u2014 uninstall 9 parent modules to declutter the dashboard.\\n\\nWARNING: This file contains a real Odoo API key. Delete after use.\\n\\\"\\\"\\\"\\nimport xmlrpc.client\\nimport sys\\nimport time\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"  # noqa: S105\\n\\n# 1. Authenticate\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\")\\ntry:\\n    uid = common.authenticate(DB, USERNAME, API_KEY, {})\\nexcept Exception as e:\\n    print(f\\\"ERR: cannot reach auth endpoint: {e}\\\", file=sys.stderr)\\n    sys.exit(1)\\n\\nif not uid:\\n    print(\\\"ERR: authentication failed \\u2014 check API key / email / db name\\\", file=sys.stderr)\\n    sys.exit(1)\\nprint(f\\\"OK: authenticated as uid={uid}\\\")\\n\\n# 2. Object endpoint\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\")\\n\\n# 3. Parent modules to uninstall\\nparent_modules = [\\n    \\\"project\\\", \\\"account\\\", \\\"hr\\\", \\\"sign\\\", \\\"purchase\\\",\\n    \\\"helpdesk\\\", \\\"planning\\\", \\\"survey\\\", \\\"knowledge\\\",\\n]\\n\\n# 4. Find installed\\ntry:\\n    recs = models.execute_kw(\\n        DB, uid, API_KEY,\\n        \\\"ir.module.module\\\", \\\"search_read\\\",\\n        [[[\\\"name\\\", \\\"in\\\", parent_modules], [\\\"state\\\", \\\"=\\\", \\\"installed\\\"]]],\\n        {\\\"fields\\\": [\\\"id\\\", \\\"name\\\", \\\"shortdesc\\\", \\\"state\\\"]},\\n    )\\nexcept Exception as e:\\n    print(f\\\"ERR: search_read failed: {e}\\\", file=sys.stderr)\\n    sys.exit(1)\\n\\nif not recs:\\n    print(\\\"OK: no removable parent modules found \\u2014 DB already clean\\\")\\n    sys.exit(0)\\n\\nprint(f\\\"FOUND: {len(recs)} module(s) installed\\\")\\nfor r in recs:\\n    print(f\\\"  - {r['shortdesc']:<25} ({r['name']})  state={r['state']}\\\")\\n\\nids = [r[\\\"id\\\"] for r in recs]\\nprint(f\\\"\\\\nTRIGGER: uninstalling {len(ids)} module(s)\\u2026\\\")\\ntry:\\n    models.execute_kw(\\n        DB, uid, API_KEY,\\n        \\\"ir.module.module\\\", \\\"button_immediate_uninstall\\\",\\n        [ids],\\n    )\\n    print(\\\"OK: uninstall completed\\\")\\nexcept Exception as e:\\n    # connection drop during registry reload is NORMAL\\n    print(f\\\"NOTE: {type(e).__name__} \\u2014 registry likely reloading. Wait 30-60s and refresh Odoo.\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.mavis\\\\sessions\\\\mvs_8d6cdf45af11451ca152d51c37e4fa64\\\\workspace\\\\odoo_cleanup.py\"}",
