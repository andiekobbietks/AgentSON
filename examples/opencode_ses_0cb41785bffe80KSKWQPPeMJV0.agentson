docs\\404.html\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\dev\\index.html\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\.nojekyll\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-001-Reading-FreeStyle-Libre-2-Sensor.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-005-Searching-AI-Sessions.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-007-Setting-Up-Nightscout-Server.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-008-WhatsApp-Bot-Setup.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-006-Sharing-Data-with-Doctors.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-004-Exporting-AI-Sessions.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-003-Viewing-Glucose-Data-in-Browser.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-002-Converting-Libre-Data-to-AgentSON.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-009-TV-Dashboard-Setup.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\CHROME-DEVTOOLS-AI-MECHANISM.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-014-West-Africa-Voice-Alerts.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-013-NHS-FHIR-Integration.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-012-Setting-Up-Juggluco-on-Mothers-Phone.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-011-Fine-tuning-MedGemma-on-Glucose-Data.md\nC:\\Users\\LLM-Test\\Documents\\agentsong\\docs\\sops\\SOP-010-Setting-Up-MedGemma-HAI-DEF.md",
