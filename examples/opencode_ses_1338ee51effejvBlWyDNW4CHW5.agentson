    {
      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"$content = @'\\nimport { useEffect, useRef, useState } from \\\"react\\\";\\nimport { Play, Pause, RotateCcw, Eye, EyeOff, ChevronUp, ChevronDown } from \\\"lucide-react\\\";\\n\\ntype Props = {\\n  playing: boolean;\\n  onTogglePlay: () => void;\\n  onReset: () => void;\\n  wpm: number;\\n  onWpmChange: (wpm: number) => void;\\n  showAnnotations: boolean;\\n  onToggleAnnotations: () => void;\\n  progress: number;\\n  simpleMode: boolean;\\n};\\n\\nexport function FloatingPlayer({\\n  playing,\\n  onTogglePlay,\\n  onReset,\\n  wpm,\\n  onWpmChange,\\n  showAnnotations,\\n  onToggleAnnotations,\\n  progress,\\n  simpleMode,\\n}: Props) {\\n  const [expanded, setExpanded] = useState(false);\\n  const idleTimer = useRef<ReturnType<typeof setTimeout>>();\\n  const containerRef = useRef<HTMLDivElement>(null);\\n\\n  const resetIdleTimer = () => {\\n    clearTimeout(idleTimer.current);\\n    idleTimer.current = setTimeout(() => setExpanded(false), 3000);\\n  };\\n\\n  const handleMouseEnter = () => {\\n    setExpanded(true);\\n    resetIdleTimer();\\n  };\\n\\n  const handleMouseLeave = () => {\\n    resetIdleTimer();\\n  };\\n\\n  useEffect(() => {\\n    return () => clearTimeout(idleTimer.current);\\n  }, []);\\n\\n  return (\\n    <div\\n      ref={containerRef}\\n      onMouseEnter={handleMouseEnter}\\n      onMouseLeave={handleMouseLeave}\\n      onFocus={() => setExpanded(true)}\\n      className={`fixed bottom-6 right-6 z-50 transition-all duration-300 ease-out ${\\n        expanded ? \\\"w-64\\\" : \\\"w-14\\\"\\n      }`}\\n      role=\\\"region\\\"\\n      aria-label={simpleMode ? \\\"Voice playback controls\\\" : \\\"Floating transport controls\\\"}\\n    >\\n      {/* Progress ring behind the button */}\\n      <div className={`flex items-end gap-3 ${expanded ? \\\"flex-row\\\" : \\\"flex-col items-end\\\"}`}>\\n        {/* Main controls pill */}\\n        <div\\n          className={`flex items-center gap-2 bg-card border border-border rounded-2xl shadow-2xl overflow-hidden transition-all duration-300 ${\\n            expanded ? \\\"px-3 py-2.5\\\" : \\\"px-0 py-0\\\"\\n          }`}\\n        >\\n          {/* Play/Pause button - always visible */}\\n          <button\\n            onClick={onTogglePlay}\\n            className=\\\"relative flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-xl bg-primary text-primary-foreground hover:brightness-110 transition-all\\\"\\n            aria-label={playing ? \\\"Pause playback\\\" : \\\"Start playback\\\"}\\n          >\\n            {/* Progress ring SVG */}\\n            <svg\\n              className=\\\"absolute inset-0 w-full h-full -rotate-90\\\"\\n              viewBox=\\\"0 0 40 40\\\"\\n              aria-hidden=\\\"true\\\"\\n            >\\n              <circle\\n                cx=\\\"20\\\"\\n                cy=\\\"20\\\"\\n                r=\\\"18\\\"\\n                fill=\\\"none\\\"\\n                stroke=\\\"hsl(var(--primary-foreground))\\\"\\n                strokeWidth=\\\"2\\\"\\n                opacity=\\\"0.2\\\"\\n              />\\n              <circle\\n                cx=\\\"20\\\"\\n                cy=\\\"20\\\"\\n                r=\\\"18\\\"\\n                fill=\\\"none\\\"\\n                stroke=\\\"hsl(var(--primary-foreground))\\\"\\n                strokeWidth=\\\"2\\\"\\n                strokeDasharray={`${2 * Math.PI * 18}`}\\n                strokeDashoffset={`${2 * Math.PI * 18 * (1 - progress)}`}\\n                strokeLinecap=\\\"round\\\"\\n              />\\n            </svg>\\n            <span className=\\\"relative z-10\\\">\\n              {playing ? <Pause size={18} /> : <Play size={18} className=\\\"ml-0.5\\\" />}\\n            </span>\\n          </button>\\n\\n          {/* Expanded controls */}\\n          {expanded && (\\n            <>\\n              <div className=\\\"w-px h-6 bg-border\\\" />\\n              <button\\n                onClick={onReset}\\n                className=\\\"flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-lg hover:bg-foreground/10 text-muted-foreground hover:text-foreground transition-colors\\\"\\n                aria-label=\\\"Reset to beginning\\\"\\n              >\\n                <RotateCcw size={15} />\\n              </button>\\n              <button\\n                onClick={onToggleAnnotations}\\n                className=\\\"flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-lg hover:bg-foreground/10 text-muted-foreground hover:text-foreground transition-colors\\\"\\n                aria-label={showAnnotations ? \\\"Hide marks\\\" : \\\"Show marks\\\"}\\n              >\\n                {showAnnotations ? <Eye size={15} /> : <EyeOff size={15} />}\\n              </button>\\n              <div className=\\\"flex items-center gap-1.5\\\">\\n                <input\\n                  type=\\\"range\\\"\\n                  min={80}\\n                  max={220}\\n                  value={wpm}\\n                  onChange={(e) => onWpmChange(Number(e.target.value))}\\n                  className=\\\"accent-primary w-16 h-1\\\"\\n                  aria-label=\\\"Words per minute\\\"\\n                />\\n                <span className=\\\"text-[11px] font-mono text-muted-foreground w-7 text-right\\\">{wpm}</span>\\n              </div>\\n            </>\\n          )}\\n        </div>\\n\\n        {/* Expand/collapse hint */}\\n        {!expanded && (\\n          <button\\n            onClick={() => setExpanded(true)}\\n            className=\\\"w-6 h-6 flex items-center justify-center rounded-full bg-card border border-border text-muted-foreground hover:text-foreground transition-colors shadow-lg\\\"\\n            aria-label=\\\"Show more controls\\\"\\n          >\\n            <ChevronUp size={12} />\\n          </button>\\n        )}\\n      </div>\\n    </div>\\n  );\\n}\\n'@\\nSet-Content -Path \\\"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\components\\\\teleprompter\\\\FloatingPlayer.tsx\\\" -Value $content -Encoding UTF8\", \"description\": \"Write FloatingPlayer component\", \"timeout\": 30000}",
