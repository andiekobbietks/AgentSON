    {
      "type": "action",
      "tool": "read",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\routes\\\\score.tsx\"}",
      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\routes\\score.tsx</path>\n<type>file</type>\n<content>\n1: import { createFileRoute, Link } from \"@tanstack/react-router\";\n2: import { useCallback, useEffect, useMemo, useState } from \"react\";\n3: import {\n4:   type Token,\n5:   findTokenAtMs,\n6:   sentencesOf,\n7:   tokenize,\n8:   totalDurationMs,\n9: } from \"@/lib/teleprompter/tokens\";\n10: import {\n11:   detectCoarticulation,\n12:   estimateStress,\n13:   estimateVowelCompression,\n14:   isContentWord,\n15:   type ProsodyWord,\n16: } from \"@/lib/teleprompter/prosody\";\n17: import { PitchContour } from \"@/components/teleprompter/PitchContour\";\n18: import { WalkthroughOverlay } from \"@/components/teleprompter/WalkthroughOverlay\";\n19: import { Tooltip, TooltipContent, TooltipTrigger } from \"@/components/ui/tooltip\";\n20: import {\n21:   Play,\n22:   Pause,\n23:   RotateCcw,\n24:   Eye,\n25:   EyeOff,\n26:   Info,\n27:   HelpCircle,\n28:   Sparkles,\n29: } from \"lucide-react\";\n30: \n31: export const Route = createFileRoute(\"/score\")({\n32:   head: () => ({\n33:     meta: [\n34:       { title: \"Score View - ProLector\" },\n35:       {\n36:         name: \"description\",\n37:         content:\n38:           \"Pronunciation workbook: continuous pitch contour, stress badges, vowel compression, and coarticulation bridges rendered above your script.\",\n39:       },\n40:     ],\n41:   }),\n42:   component: ScoreView,\n43: });\n44: \n45: const DEFAULT_SCRIPT = `Welcome to ProLector. This is the Score View engine operating at sub-ten-millisecond latency.\n46: \n47: Your training modules deserve broadcast-grade clarity, so position your eyes directly on the lens marker for perfect engagement.\n48: \n49: We deploy Gemma 4 locally. The model parses your text, injects pacing tags, and forwards every clean sentence to the Remotion frame-sequencer. Nothing leaves your machine.\n50: \n51: Press space to play or pause. Use the up and down arrows to nudge the pace. Press R to reset.`;\n52: \n53: const WPM_PRESETS = [\n54:   { label: \"TED Talk\", wpm: 120 },\n55:   { label: \"Tutorial\", wpm: 135 },\n56:   { label: \"BBC News\", wpm: 155 },\n57:   { label: \"Audiobook\", wpm: 150 },\n58:   { label: \"Conversational\", wpm: 145 },\n59: ];\n60: \n61: function ScoreView() {\n62:   const [script, setScript] = useState(DEFAULT_SCRIPT);\n63:   const [wpm, setWpm] = useState(140);\n64:   const [currentMs, setCurrentMs] = useState(0);\n65:   const [playing, setPlaying] = useState(false);\n66:   const [charWidth, setCharWidth] = useState(11);\n67:   const [showAnnotations, setShowAnnotations] = useState(true);\n68:   const [simpleMode, setSimpleMode] = useState(() => {\n69:     return localStorage.getItem(\"prolector-simple-mode\") !== \"false\";\n70:   });\n71:   const [showWalkthrough, setShowWalkthrough] = useState(() => {\n72:     return localStorage.getItem(\"prolector-walkthrough-seen\") !== \"true\";\n73:   });\n74: \n75:   const tokens = useMemo(() => tokenize(script, wpm), [script, wpm]);\n76:   const sentences = useMemo(() => sentencesOf(tokens), [tokens]);\n77:   const totalMs = useMemo(() => totalDurationMs(tokens), [tokens]);\n78:   const currentToken = useMemo(() => findTokenAtMs(tokens, currentMs), [tokens, currentMs]);\n79: \n80:   const prosodyMap = useMemo(() => {\n81:     const map = new Map<string, ProsodyWord>();\n82:     for (let i = 0; i < tokens.length; i++) {\n83:       const t = tokens[i];\n84:       if (t.isBreak) continue;\n85:       const isContent = isContentWord(t.text);\n86:       const position =\n87:         i === 0 || tokens[i - 1]?.isBreak\n88:           ? \"first\"\n89:           : i === tokens.length - 1 || tokens[i + 1]?.isBreak\n90:             ? \"last\"\n91:             : \"middle\";\n92:       let prevToken: Token | undefined;\n93:       for (let j = i - 1; j >= 0; j--) {\n94:         if (!tokens[j].isBreak) {\n95:           prevToken = tokens[j];\n96:           break;\n97:         }\n98:       }\n99:       const stress = estimateStress(t.text, position);\n100:       const vowelComp = estimateVowelCompression(t.text, stress, isContent);\n101:       const coarticulation = prevToken\n102:         ? detectCoarticulation(prevToken.text, t.text)\n103:         : undefined;\n104:       const baseHz = isContent ? 180 : 140;\n105:       const f0 = {\n106:         onset: baseHz + (stress === \"primary\" ? 30 : stress === \"secondary\" ? 10 : -10),\n107:         nucleus: baseHz + (stress === \"primary\" ? 50 : stress === \"secondary\" ? 20 : 0),\n108:         offset: baseHz + (position === \"last\" ? -20 : 5),\n109:         slope: position === \"last\" ? -15 : stress === \"primary\" ? 10 : 0,\n110:       };\n111:       map.set(t.id, { tokenIndex: i, f0, stress, vowelCompression: vowelComp, coarticulation });\n112:     }\n113:     return map;\n114:   }, [tokens]);\n115: \n116:   const sentenceGroups = useMemo(() => {\n117:     const groups: { id: string; tokens: Token[] }[] = [];\n118:     let cur: { id: string; tokens: Token[] } | null = null;\n119:     for (const t of tokens) {\n120:       if (t.isBreak) {\n121:         if (cur) groups.push(cur);\n122:         cur = null;\n123:         groups.push({ id: t.id, tokens: [t] });\n124:         continue;\n125:       }\n126:       if (!cur || cur.id !== t.sentenceId) {\n127:         if (cur) groups.push(cur);\n128:         cur = { id: t.sentenceId, tokens: [] };\n129:       }\n130:       cur.tokens.push(t);\n131:     }\n132:     if (cur) groups.push(cur);\n133:     return groups;\n134:   }, [tokens]);\n135: \n136:   useEffect(() => {\n137:     if (!playing) return;\n138:     let raf: number;\n139:     let last: number | null = null;\n140:     const tick = (now: number) => {\n141:       const dt = last != null ? now - last : 0;\n142:       last = now;\n143:       setCurrentMs((ms) => {\n144:         const next = ms + dt;\n145:         if (totalMs > 0 && next >= totalMs) {\n146:           setPlaying(false);\n147:           return totalMs;\n148:         }\n149:         return next;\n150:       });\n151:       raf = requestAnimationFrame(tick);\n152:     };\n153:     raf = requestAnimationFrame(tick);\n154:     return () => cancelAnimationFrame(raf);\n155:   }, [playing, totalMs]);\n156: \n157:   useEffect(() => {\n158:     const onKey = (e: KeyboardEvent) => {\n159:       const target = e.target as HTMLElement;\n160:       if (target && (target.tagName === \"TEXTAREA\" || target.tagName === \"INPUT\")) return;\n161:       if (e.code === \"Space\") {\n162:         e.preventDefault();\n163:         setPlaying((p) => !p);\n164:       } else if (e.key === \"r\" || e.key === \"R\") {\n165:         setPlaying(false);\n166:         setCurrentMs(0);\n167:       } else if (e.key === \"ArrowUp\") {\n168:         setWpm((w) => Math.min(220, w + 5));\n169:       } else if (e.key === \"ArrowDown\") {\n170:         setWpm((w) => Math.max(80, w - 5));\n171:       }\n172:     };\n173:     window.addEventListener(\"keydown\", onKey);\n174:     return () => window.removeEventListener(\"keydown\", onKey);\n175:   }, []);\n176: \n177:   const wordCount = script.trim().split(/\\s+/).filter(Boolean).length;\n178:   const estDurationSec = wordCount > 0 ? Math.round((wordCount / wpm) * 60) : 0;\n179: \n180:   const toggleSimpleMode = () => {\n181:     const next = !simpleMode;\n182:     setSimpleMode(next);\n183:     localStorage.setItem(\"prolector-simple-mode\", String(next));\n184:   };\n185: \n186:   return (\n187:     <div className=\"min-h-screen bg-background text-foreground flex flex-col\">\n188:       {showWalkthrough && (\n189:         <WalkthroughOverlay\n190:           simpleMode={simpleMode}\n191:           onClose={() => {\n192:             setShowWalkthrough(false);\n193:             localStorage.setItem(\"prolector-walkthrough-seen\", \"true\");\n194:           }}\n195:         />\n196:       )}\n197: \n198:       {/* Top bar */}\n199:       <div className=\"border-b border-border bg-background/90 backdrop-blur sticky top-0 z-40\">\n200:         <div className=\"max-w-7xl mx-auto px-6 h-16 flex items-center justify-between gap-4\">\n201:           <div className=\"flex items-center gap-6\">\n202:             <Link\n203:               to=\"/\"\n204:               className=\"font-display font-bold tracking-tighter text-xl uppercase italic\"\n205:             >\n206:               {\"\\u2190\"} ProLector\n207:             </Link>\n208:             <span className=\"text-sm font-mono uppercase tracking-widest text-muted-foreground hidden md:inline\">\n209:               {simpleMode ? \"Voice Coach\" : \"Score View\"}\n210:             </span>\n211:           </div>\n212:           <div className=\"flex items-center gap-3\">\n213:             <button\n214:               onClick={() => setShowWalkthrough(true)}\n215:               className=\"flex items-center gap-2 px-4 py-2.5 text-sm font-medium rounded-lg border border-border hover:bg-foreground/5 transition-all\"\n216:               aria-label=\"Show walkthrough guide\"\n217:             >\n218:               <HelpCircle size={18} />\n219:               <span className=\"hidden sm:inline\">How to use</span>\n220:             </button>\n221: \n222:             <button\n223:               onClick={toggleSimpleMode}\n224:               className={`flex items-center gap-2 px-4 py-2.5 text-sm font-medium rounded-lg border transition-all ${\n225:                 simpleMode\n226:                   ? \"border-primary bg-primary/10 text-primary\"\n227:                   : \"border-border hover:bg-foreground/5\"\n228:               }`}\n229:               aria-label={simpleMode ? \"Switch to detailed view\" : \"Switch to simple view\"}\n230:             >\n231:               <Sparkles size={18} />\n232:               <span className=\"hidden sm:inline\">{simpleMode ? \"Simple\" : \"Expert\"}</span>\n233:             </button>\n234: \n235:             <Tooltip>\n236:               <TooltipTrigger asChild>\n237:                 <div className=\"flex items-center gap-2.5 font-mono text-sm uppercase tracking-widest cursor-help px-3 py-2 rounded-lg border border-border\">\n238:                   <span className={`size-2.5 rounded-full ${playing ? \"bg-destructive animate-pulse\" : \"bg-muted-foreground/40\"}`} />\n239:                   <span className={playing ? \"text-destructive\" : \"text-muted-foreground\"}>\n240:                     {playing ? \"PLAY\" : \"STOP\"}\n241:                   </span>\n242:                 </div>\n243:               </TooltipTrigger>\n244:               <TooltipContent>Playback state</TooltipContent>\n245:             </Tooltip>\n246:           </div>\n247:         </div>\n248:       </div>\n249: \n250:       {/* Controls */}\n251:       <div className=\"border-b border-border px-6 py-4\">\n252:         <div className=\"max-w-7xl mx-auto flex flex-wrap items-center gap-4\">\n253:           <button\n254:             onClick={() => setPlaying((p) => !p)}\n255:             className=\"flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 text-base font-bold rounded-lg hover:brightness-110 transition-all\"\n256:           >\n257:             {playing ? <Pause size={20} /> : <Play size={20} />}\n258:             {playing ? \"Pause\" : \"Play\"}\n259:           </button>\n260:           <button\n261:             onClick={() => { setPlaying(false); setCurrentMs(0); }}\n262:             className=\"flex items-center gap-2 border border-border px-5 py-3 text-base font-medium rounded-lg hover:bg-foreground/5 transition-all\"\n263:           >\n264:             <RotateCcw size={18} />\n265:             Reset\n266:           </button>\n267: \n268:           <div className=\"flex items-center gap-3 ml-4\">\n269:             <label className=\"text-sm font-mono text-muted-foreground\">WPM</label>\n270:             <input\n271:               type=\"range\"\n272:               min={80}\n273:               max={220}\n274:               value={wpm}\n275:               onChange={(e) => setWpm(Number(e.target.value))}\n276:               className=\"accent-primary w-32\"\n277:               aria-label=\"Words per minute\"\n278:             />\n279:             <span className=\"w-12 text-right text-base font-mono font-bold text-foreground\">{wpm}</span>\n280:           </div>\n281: \n282:           <div className=\"flex items-center gap-2 ml-2\">\n283:             {WPM_PRESETS.map((p) => (\n284:               <button\n285:                 key={p.label}\n286:                 onClick={() => setWpm(p.wpm)}\n287:                 className={`px-3 py-2 text-sm font-medium border rounded-lg transition-colors ${\n288:                   wpm === p.wpm\n289:                     ? \"border-primary text-primary bg-primary/10\"\n290:                     : \"border-border text-muted-foreground hover:border-primary/40 hover:text-foreground\"\n291:                 }`}\n292:               >\n293:                 {p.label}\n294:               </button>\n295:             ))}\n296:           </div>\n297: \n298:           <div className=\"flex items-center gap-3 ml-4\">\n299:             <label className=\"text-sm font-mono text-muted-foreground\">Zoom</label>\n300:             <input\n301:               type=\"range\"\n302:               min={8}\n303:               max={16}\n304:               value={charWidth}\n305:               onChange={(e) => setCharWidth(Number(e.target.value))}\n306:               className=\"accent-primary w-24\"\n307:               aria-label=\"Text zoom level\"\n308:             />\n309:           </div>\n310: \n311:           <button\n312:             onClick={() => setShowAnnotations((v) => !v)}\n313:             className={`flex items-center gap-2 px-4 py-2.5 text-sm font-medium border rounded-lg transition-all ${\n314:               showAnnotations\n315:                 ? \"border-primary text-primary bg-primary/10\"\n316:                 : \"border-border text-muted-foreground hover:bg-foreground/5\"\n317:             }`}\n318:             aria-label={showAnnotations ? \"Hide pronunciation marks\" : \"Show pronunciation marks\"}\n319:           >\n320:             {showAnnotations ? <Eye size={18} /> : <EyeOff size={18} />}\n321:             <span className=\"hidden sm:inline\">{simpleMode ? \"Marks\" : \"Annotations\"}</span>\n322:           </button>\n323: \n324:           <span className=\"text-sm font-mono text-muted-foreground ml-auto\">\n325:             {wordCount} words {\"\\u00B7\"} ~{Math.floor(estDurationSec / 60)}:\n326:             {String(estDurationSec % 60).padStart(2, \"0\")}\n327:           </span>\n328:         </div>\n329:       </div>\n330: \n331:       {/* Score area */}\n332:       <div className=\"flex-1 overflow-y-auto p-6 md:p-12\">\n333:         <div className=\"max-w-7xl mx-auto space-y-12\">\n334:           {/* Legend */}\n335:           <div\n336:             className=\"flex flex-wrap items-center gap-x-8 gap-y-3 text-sm font-mono text-muted-foreground p-4 rounded-lg bg-card border border-border\"\n337:             role=\"region\"\n338:             aria-label={simpleMode ? \"Reading guide for marks above words\" : \"Prosody legend\"}\n339:           >\n340:             <span className=\"flex items-center gap-2\">\n341:               <span className=\"inline-block w-3 h-3 rounded-full bg-primary\" aria-hidden=\"true\" />\n342:               {simpleMode ? \"Loudest word\" : \"Primary stress\"}\n343:             </span>\n344:             <span className=\"flex items-center gap-2\">\n345:               <span className=\"inline-block w-3 h-3 rounded-full border-2 border-primary/50\" aria-hidden=\"true\" />\n346:               {simpleMode ? \"Somewhat loud\" : \"Secondary stress\"}\n347:             </span>\n348:             <span className=\"flex items-center gap-2\">\n349:               <span className=\"inline-block w-2 h-2 rounded-full bg-muted-foreground/30\" aria-hidden=\"true\" />\n350:               {simpleMode ? \"Quick word\" : \"Unstressed\"}\n351:             </span>\n352:             <span className=\"w-px h-4 bg-border\" aria-hidden=\"true\" />\n353:             <span className=\"flex items-center gap-2\">\n354:               <span className=\"inline-block w-4 h-1 bg-green-500 rounded\" aria-hidden=\"true\" />\n355:               {simpleMode ? \"Clear vowel\" : \"Full vowel\"}\n356:             </span>\n357:             <span className=\"flex items-center gap-2\">\n358:               <span className=\"inline-block w-4 h-1 bg-yellow-500 rounded\" aria-hidden=\"true\" />\n359:               {simpleMode ? \"Squished vowel\" : \"Compressed\"}\n360:             </span>\n361:             <span className=\"flex items-center gap-2\">\n362:               <span className=\"inline-block w-4 h-1 bg-orange-500 rounded\" aria-hidden=\"true\" />\n363:               {simpleMode ? \"Fast vowel\" : \"Reduced\"}\n364:             </span>\n365:             <span className=\"flex items-center gap-2\">\n366:               <span className=\"inline-block w-4 h-1 bg-red-500 rounded\" aria-hidden=\"true\" />\n367:               {simpleMode ? \"Mumbled\" : \"Schwa\"}\n368:             </span>\n369:             <span className=\"w-px h-4 bg-border\" aria-hidden=\"true\" />\n370:             <span className=\"flex items-center gap-2\">\n371:               <span className=\"text-primary font-bold text-base\" aria-hidden=\"true\">{\"\\u2192\"}</span>\n372:               {simpleMode ? \"Words link together\" : \"Linking R\"}\n373:             </span>\n374:             <span className=\"flex items-center gap-2\">\n375:               <span className=\"text-primary font-bold text-base\" aria-hidden=\"true\">{\"\\u21BB\"}</span>\n376:               {simpleMode ? \"Extra sound inserted\" : \"Intrusion\"}\n377:             </span>\n378:             <span className=\"flex items-center gap-2\">\n379:               <span className=\"text-primary font-bold text-base\" aria-hidden=\"true\">{\"\\u027E\"}</span>\n380:               {simpleMode ? \"T becomes D sound\" : \"Flap T\"}\n381:             </span>\n382:           </div>\n383: \n384:           {/* Sentences */}\n385:           {sentenceGroups.map((group) => {\n386:             if (group.tokens.length === 1 && group.tokens[0].isBreak) {\n387:               return <div key={group.id} className=\"h-10\" />;\n388:             }\n389:             const words = group.tokens.map((t) => ({\n390:               text: t.text,\n391:               id: t.id,\n392:               startMs: t.startMs,\n393:               endMs: t.endMs,\n394:             }));\n395:             return (\n396:               <div\n397:                 key={group.id}\n398:                 className=\"border border-border rounded-xl bg-card p-8\"\n399:                 role=\"article\"\n400:                 aria-label=\"Sentence with pitch analysis\"\n401:               >\n402:                 <PitchContour\n403:                   words={words}\n404:                   prosodyMap={prosodyMap}\n405:                   charWidth={charWidth}\n406:                   showAnnotations={showAnnotations}\n407:                   currentMs={currentMs}\n408:                   simpleMode={simpleMode}\n409:                   onWordClick={(ms) => {\n410:                     setCurrentMs(ms);\n411:                   }}\n412:                 />\n413:               </div>\n414:             );\n415:           })}\n416: \n417:           {/* Footer info */}\n418:           <div className=\"text-center text-sm font-mono text-muted-foreground/40 py-8 border-t border-border\">\n419:             {simpleMode\n420:               ? \"The wavy line shows how your voice pitch goes up and down.\"\n421:               : \"Score View - Pitch contour is estimated from word stress and position.\"}\n422:           </div>\n423:         </div>\n424:       </div>\n425:     </div>\n426:   );\n427: }\n\n(End of file - total 427 lines)\n</content>",
