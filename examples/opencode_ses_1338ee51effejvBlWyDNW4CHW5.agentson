    {
      "type": "action",
      "tool": "read",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\demo_antigravity.py\"}",
      "output": "<path>C:\\Users\\LLM-Test\\Documents\\demo_antigravity.py</path>\n<type>file</type>\n<content>\n1: \"\"\"\n2: Derivatives Pricing Engine — Demo File\n3: \n4: This file demonstrates the Cognitive Taxonomy Protocol.\n5: Open this file in VS Code and press Ctrl+Shift+T to toggle taxonomy view.\n6: \"\"\"\n7: \n8: import numpy as np\n9: from scipy.stats import norm\n10: import datetime\n11: from typing import Dict, List, Optional\n12: from dataclasses import dataclass, field\n13: import logging\n14: \n15: # Setup logging\n16: logging.basicConfig(level=logging.INFO)\n17: logger = logging.getLogger(__name__)\n18: \n19: # ─── BLUE: Data Structures ─────────────────────────────────────────────\n20: \n21: @dataclass\n22: class Option:\n23:     \"\"\"Represents a financial option contract.\"\"\"\n24:     strike: float\n25:     expiry: datetime.date\n26:     option_type: str\n27:     underlying: str\n28:     volatility: float\n29:     risk_free_rate: float\n30:     \n31:     def payoff(self, spot: float) -> float:\n32:         \"\"\"Calculate option payoff at expiry.\"\"\"\n33:         if self.option_type == 'call':\n34:             return max(spot - self.strike, 0.0)\n35:         else:\n36:             return max(self.strike - spot, 0.0)\n37: \n38: @dataclass\n39: class Position:\n40:     \"\"\"Represents a trading position.\"\"\"\n41:     option: Option\n42:     quantity: int\n43:     entry_price: float\n44:     entry_date: datetime.date = field(default_factory=datetime.date.today)\n45: \n46: # Hard constraints\n47: UNDERLYINGS = ['SPX', 'NDX', 'DJX', 'RUT']\n48: MAX_POSITION_SIZE = 1000000\n49: MAX_NOTIONAL = 50000000\n50: MAX_VOLATILITY = 2.0\n51: MIN_VOLATILITY = 0.01\n52: MAX_RISK_FREE_RATE = 0.50\n53: MIN_RISK_FREE_RATE = -0.10\n54: \n55: # ─── GREEN: Infrastructure ─────────────────────────────────────────────\n56: \n57: def get_market_data(underlying: str) -> Dict:\n58:     \"\"\"Fetch real-time market data from Bloomberg.\"\"\"\n59:     # Simulated market data\n60:     return {\n61:         'spot': 4500.0,\n62:         'volatility': 0.20,\n63:         'risk_free_rate': 0.05\n64:     }\n65: \n66: def calculate_greeks(option: Option, spot: float) -> Dict:\n67:     \"\"\"Calculate option Greeks (delta, gamma, theta, vega, rho).\"\"\"\n68:     T = (option.expiry - datetime.date.today()).days / 365.0\n69:     if T <= 0:\n70:         return {'delta': 0, 'gamma': 0, 'theta': 0, 'vega': 0, 'rho': 0}\n71:     \n72:     d1 = (np.log(spot/option.strike) + (option.risk_free_rate + 0.5*option.volatility**2)*T) / (option.volatility*np.sqrt(T))\n73:     d2 = d1 - option.volatility*np.sqrt(T)\n74:     \n75:     if option.option_type == 'call':\n76:         delta = norm.cdf(d1)\n77:     else:\n78:         delta = norm.cdf(d1) - 1\n79:     \n80:     gamma = norm.pdf(d1) / (spot * option.volatility * np.sqrt(T))\n81:     theta = (-(spot * norm.pdf(d1) * option.volatility) / (2 * np.sqrt(T)) - \n82:              option.risk_free_rate * option.strike * np.exp(-option.risk_free_rate * T) * norm.cdf(d2))\n83:     vega = spot * norm.pdf(d1) * np.sqrt(T) / 100\n84:     rho = option.strike * T * np.exp(-option.risk_free_rate * T) * norm.cdf(d2) / 100\n85:     \n86:     return {\n87:         'delta': delta,\n88:         'gamma': gamma,\n89:         'theta': theta,\n90:         'vega': vega,\n91:         'rho': rho\n92:     }\n93: \n94: def log_trade(trade: Dict) -> None:\n95:     \"\"\"Log trade to audit trail for compliance.\"\"\"\n96:     logger.info(f\"TRADE: {trade}\")\n97: \n98: # ─── ORANGE: Transaction Logic ─────────────────────────────────────────\n99: \n100: def black_scholes(spot: float, strike: float, expiry_days: int, \n101:                   vol: float, rate: float, option_type: str) -> float:\n102:     \"\"\"Price option using Black-Scholes model.\"\"\"\n103:     T = expiry_days / 365.0\n104:     if T <= 0:\n105:         return 0.0\n106:     \n107:     d1 = (np.log(spot/strike) + (rate + 0.5*vol**2)*T) / (vol*np.sqrt(T))\n108:     d2 = d1 - vol*np.sqrt(T)\n109:     \n110:     if option_type == 'call':\n111:         return spot*norm.cdf(d1) - strike*np.exp(-rate*T)*norm.cdf(d2)\n112:     else:\n113:         return strike*np.exp(-rate*T)*norm.cdf(-d2) - spot*norm.cdf(-d1)\n114: \n115: def price_option(option: Option, spot: float) -> float:\n116:     \"\"\"Price a single option.\"\"\"\n117:     expiry_days = (option.expiry - datetime.date.today()).days\n118:     return black_scholes(\n119:         spot, option.strike, expiry_days,\n120:         option.volatility, option.risk_free_rate, option.option_type\n121:     )\n122: \n123: def calculate_portfolio_value(positions: List[Position], market_data: Dict) -> float:\n124:     \"\"\"Calculate total portfolio value.\"\"\"\n125:     total = 0.0\n126:     for pos in positions:\n127:         price = price_option(pos.option, market_data['spot'])\n128:         total += price * pos.quantity\n129:     return total\n130: \n131: def calculate_var(positions: List[Position], confidence: float = 0.95) -> float:\n132:     \"\"\"Calculate Value at Risk.\"\"\"\n133:     # Simplified VaR calculation\n134:     returns = []\n135:     for pos in positions:\n136:         # Assume 1-day 95% VaR\n137:         var_per_contract = pos.option.strike * 0.02 * np.sqrt(1/252)\n138:         returns.append(var_per_contract * pos.quantity)\n139:     \n140:     sorted_returns = sorted(returns)\n141:     index = int((1 - confidence) * len(sorted_returns))\n142:     return abs(sorted_returns[index]) if index < len(sorted_returns) else 0\n143: \n144: # ─── RED: Constraints ──────────────────────────────────────────────────\n145: \n146: def validate_option(option: Option) -> bool:\n147:     \"\"\"Validate option parameters against business rules.\"\"\"\n148:     if option.strike <= 0:\n149:         raise ValueError(\"Strike price must be positive\")\n150:     \n151:     if option.expiry <= datetime.date.today():\n152:         raise ValueError(\"Expiry must be in the future\")\n153:     \n154:     if option.option_type not in ['call', 'put']:\n155:         raise ValueError(\"Option type must be 'call' or 'put'\")\n156:     \n157:     if option.underlying not in UNDERLYINGS:\n158:         raise ValueError(f\"Underlying must be one of {UNDERLYINGS}\")\n159:     \n160:     if option.volatility < MIN_VOLATILITY or option.volatility > MAX_VOLATILITY:\n161:         raise ValueError(f\"Volatility must be between {MIN_VOLATILITY} and {MAX_VOLATILITY}\")\n162:     \n163:     if option.risk_free_rate < MIN_RISK_FREE_RATE or option.risk_free_rate > MAX_RISK_FREE_RATE:\n164:         raise ValueError(f\"Risk-free rate must be between {MIN_RISK_FREE_RATE} and {MAX_RISK_FREE_RATE}\")\n165:     \n166:     return True\n167: \n168: def validate_position(position: Position) -> bool:\n169:     \"\"\"Validate position size constraints.\"\"\"\n170:     if abs(position.quantity) > MAX_POSITION_SIZE:\n171:         raise ValueError(f\"Position size cannot exceed {MAX_POSITION_SIZE}\")\n172:     \n173:     notional = abs(position.quantity) * position.option.strike\n174:     if notional > MAX_NOTIONAL:\n175:         raise ValueError(f\"Notional cannot exceed ${MAX_NOTIONAL:,.0f}\")\n176:     \n177:     return True\n178: \n179: def validate_portfolio(positions: List[Position]) -> bool:\n180:     \"\"\"Validate entire portfolio constraints.\"\"\"\n181:     total_notional = sum(abs(p.quantity) * p.option.strike for p in positions)\n182:     \n183:     if total_notional > MAX_NOTIONAL * 10:\n184:         raise ValueError(\"Portfolio notional exceeds limit\")\n185:     \n186:     return True\n187: \n188: # ─── PURPLE: Documentation ─────────────────────────────────────────────\n189: \n190: \"\"\"\n191: # Derivatives Pricing Engine\n192: \n193: ## Architecture\n194: - BLUE: Option, Position data structures, constants\n195: - GREEN: Market data, Greeks, audit logging\n196: - ORANGE: Black-Scholes pricing, portfolio valuation, VaR\n197: - RED: Validation rules for options, positions, portfolio\n198: - PURPLE: This documentation\n199: \n200: ## Business Rules\n201: - Strike price must be positive\n202: - Expiry must be in the future\n203: - Option type must be 'call' or 'put'\n204: - Underlying must be in UNDERLYINGS list\n205: - Volatility must be between 1% and 200%\n206: - Risk-free rate must be between -10% and 50%\n207: - Max position size: 1,000,000\n208: - Max notional: $50,000,000\n209: \n210: ## Risk Controls\n211: - All trades logged to audit trail\n212: - Greeks calculated in real-time\n213: - Position limits enforced\n214: - Notional limits enforced\n215: - VaR calculated daily\n216: \n217: ## Usage Example\n218: ```python\n219: # Create an option\n220: option = Option(\n221:     strike=4500.0,\n222:     expiry=datetime.date(2026, 12, 31),\n223:     option_type='call',\n224:     underlying='SPX',\n225:     volatility=0.20,\n226:     risk_free_rate=0.05\n227: )\n228: \n229: # Validate\n230: validate_option(option)\n231: \n232: # Price\n233: price = price_option(option, spot=4500.0)\n234: ```\n235: \"\"\"\n236: \n237: # ─── Main ──────────────────────────────────────────────────────────────\n238: \n239: if __name__ == \"__main__\":\n240:     # Create a sample option\n241:     option = Option(\n242:         strike=4500.0,\n243:         expiry=datetime.date(2026, 12, 31),\n244:         option_type='call',\n245:         underlying='SPX',\n246:         volatility=0.20,\n247:         risk_free_rate=0.05\n248:     )\n249:     \n250:     # Validate\n251:     validate_option(option)\n252:     \n253:     # Get market data\n254:     market_data = get_market_data('SPX')\n255:     \n256:     # Price the option\n257:     price = price_option(option, market_data['spot'])\n258:     print(f\"Option price: ${price:.2f}\")\n259:     \n260:     # Calculate Greeks\n261:     greeks = calculate_greeks(option, market_data['spot'])\n262:     print(f\"Greeks: {greeks}\")\n263:     \n264:     # Create a position\n265:     position = Position(\n266:         option=option,\n267:         quantity=100,\n268:         entry_price=price\n269:     )\n270:     \n271:     # Validate position\n272:     validate_position(position)\n273:     \n274:     # Log the trade\n275:     log_trade({\n276:         'type': 'NEW',\n277:         'option': option.__dict__,\n278:         'quantity': position.quantity,\n279:         'price': price\n280:     })\n\n(End of file - total 280 lines)\n</content>",
