      "tool": "read",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\.gemini\\\\antigravity\\\\scratch\\\\prolector-yourvoice-perfected\\\\src\\\\components\\\\teleprompter\\\\PitchContour.tsx\"}",
      "output": "<path>C:\\Users\\LLM-Test\\.gemini\\antigravity\\scratch\\prolector-yourvoice-perfected\\src\\components\\teleprompter\\PitchContour.tsx</path>\n<type>file</type>\n<content>\n1: /**\n2:  * PitchContour — Continuous SVG pitch contour rendered above a line of text.\n3:  *\n4:  * Renders a smooth bezier curve representing the F0 (fundamental frequency)\n5:  * across all words in a segment, like a melody line on a lead sheet.\n6:  * Below the curve, stress badges, vowel compression markers, and\n7:  * coarticulation bridges are rendered inline.\n8:  */\n9: import { useMemo } from \"react\";\n10: import type { ProsodyWord } from \"@/lib/teleprompter/prosody\";\n11: \n12: type Props = {\n13:   words: { text: string; id: string; startMs: number; endMs: number }[];\n14:   prosodyMap: Map<string, ProsodyWord>;\n15:   /** Width in pixels per character (for horizontal scaling). */\n16:   charWidth?: number;\n17:   /** Height of the pitch contour area. */\n18:   contourHeight?: number;\n19:   /** Whether to show inline annotations. */\n20:   showAnnotations?: boolean;\n21:   /** Current playback position in ms. */\n22:   currentMs?: number;\n23:   /** Callback when a word is clicked. */\n24:   onWordClick?: (startMs: number) => void;\n25: };\n26: \n27: export function PitchContour({\n28:   words,\n29:   prosodyMap,\n30:   charWidth = 9,\n31:   contourHeight = 80,\n32:   showAnnotations = true,\n33:   currentMs,\n34:   onWordClick,\n35: }: Props) {\n36:   // Compute the pitch points for the SVG path.\n37:   const pitchPoints = useMemo(() => {\n38:     const points: { x: number; y: number; hz: number; wordId: string }[] = [];\n39:     let x = 0;\n40:     const minHz = 80;\n41:     const maxHz = 320;\n42: \n43:     for (const word of words) {\n44:       const prosody = prosodyMap.get(word.id);\n45:       const hz = prosody?.f0?.nucleus ?? 160;\n46:       const charOffset = word.text.length * charWidth * 0.5;\n47:       const px = x + charOffset;\n48:       const normalized = (hz - minHz) / (maxHz - minHz);\n49:       const py = contourHeight - normalized * (contourHeight - 20) - 10;\n50:       points.push({ x: px, y: py, hz, wordId: word.id });\n51:       x += word.text.length * charWidth + charWidth; // word + space\n52:     }\n53:     return points;\n54:   }, [words, prosodyMap, charWidth, contourHeight]);\n55: \n56:   // Build the smooth SVG path.\n57:   const pathD = useMemo(() => {\n58:     if (pitchPoints.length < 2) return \"\";\n59:     const pts = pitchPoints;\n60:     let d = `M ${pts[0].x} ${pts[0].y}`;\n61:     for (let i = 1; i < pts.length; i++) {\n62:       const prev = pts[i - 1];\n63:       const curr = pts[i];\n64:       const cpx1 = prev.x + (curr.x - prev.x) * 0.4;\n65:       const cpx2 = prev.x + (curr.x - prev.x) * 0.6;\n66:       d += ` C ${cpx1} ${prev.y} ${cpx2} ${curr.y} ${curr.x} ${curr.y}`;\n67:     }\n68:     return d;\n69:   }, [pitchPoints]);\n70: \n71:   // Build the filled area path.\n72:   const areaD = useMemo(() => {\n73:     if (!pathD) return \"\";\n74:     const lastPt = pitchPoints[pitchPoints.length - 1];\n75:     const firstPt = pitchPoints[0];\n76:     return `${pathD} L ${lastPt.x} ${contourHeight} L ${firstPt.x} ${contourHeight} Z`;\n77:   }, [pathD, pitchPoints, contourHeight]);\n78: \n79:   // Compute word positions for the text layer.\n80:   const wordPositions = useMemo(() => {\n81:     let x = 0;\n82:     return words.map((w) => {\n83:       const start = x;\n84:       x += w.text.length * charWidth + charWidth;\n85:       return { ...w, x, width: w.text.length * charWidth };\n86:     });\n87:   }, [words, charWidth]);\n88: \n89:   const totalWidth = useMemo(() => {\n90:     if (wordPositions.length === 0) return 0;\n91:     const last = wordPositions[wordPositions.length - 1];\n92:     return last.x + last.width + charWidth * 2;\n93:   }, [wordPositions, charWidth]);\n94: \n95:   // Find the word at currentMs.\n96:   const activeWordId = useMemo(() => {\n97:     if (currentMs == null) return null;\n98:     for (const w of words) {\n99:       if (currentMs >= w.startMs && currentMs <= w.endMs) return w.id;\n100:     }\n101:     return null;\n102:   }, [words, currentMs]);\n103: \n104:   return (\n105:     <div className=\"overflow-x-auto scrollbar-thin\">\n106:       <div className=\"inline-block\" style={{ minWidth: totalWidth }}>\n107:         {/* Pitch contour SVG */}\n108:         <svg\n109:           width={totalWidth}\n110:           height={contourHeight + 4}\n111:           viewBox={`0 0 ${totalWidth} ${contourHeight + 4}`}\n112:           className=\"block\"\n113:         >\n114:           {/* Filled area under curve */}\n115:           <path d={areaD} fill=\"hsl(var(--primary))\" opacity={0.06} />\n116:           {/* Main contour line */}\n117:           <path d={pathD} fill=\"none\" stroke=\"hsl(var(--primary))\" strokeWidth={2} opacity={0.7} />\n118:           {/* Pitch dots */}\n119:           {pitchPoints.map((pt) => (\n120:             <circle\n121:               key={pt.wordId}\n122:               cx={pt.x}\n123:               cy={pt.y}\n124:               r={3}\n125:               fill=\"hsl(var(--primary))\"\n126:               opacity={0.8}\n127:             />\n128:           ))}\n129:           {/* Hz labels on hover */}\n130:           {pitchPoints.map((pt) => (\n131:             <text\n132:               key={`label-${pt.wordId}`}\n133:               x={pt.x}\n134:               y={pt.y - 8}\n135:               textAnchor=\"middle\"\n136:               className=\"fill-muted-foreground\"\n137:               fontSize={9}\n138:               fontFamily=\"var(--font-mono)\"\n139:             >\n140:               {Math.round(pt.hz)}\n141:             </text>\n142:           ))}\n143:         </svg>\n144: \n145:         {/* Text layer with annotations */}\n146:         <div\n147:           className=\"relative font-display font-bold tracking-tight\"\n148:           style={{ fontSize: 28, lineHeight: 1.8, paddingLeft: charWidth }}\n149:         >\n150:           {wordPositions.map((w) => {\n151:             const prosody = prosodyMap.get(w.id);\n152:             const isActive = w.id === activeWordId;\n153:             return (\n154:               <span\n155:                 key={w.id}\n156:                 onClick={() => onWordClick?.(w.startMs)}\n157:                 className={`relative inline-block cursor-pointer transition-colors ${\n158:                   isActive\n159:                     ? \"bg-primary/20 text-primary\"\n160:                     : \"text-foreground hover:bg-primary/10\"\n161:                 }`}\n162:                 style={{ padding: \"0 0.05em\" }}\n163:               >\n164:                 {w.text}\n165:                 {showAnnotations && prosody && (\n166:                   <span className=\"absolute -top-3 left-1/2 -translate-x-1/2 flex flex-col items-center pointer-events-none\">\n167:                     {/* Stress dot */}\n168:                     {prosody.stress && (\n169:                       <span\n170:                         className={`text-[7px] leading-none ${\n171:                           prosody.stress === \"primary\"\n172:                             ? \"text-primary font-bold\"\n173:                             : prosody.stress === \"secondary\"\n174:                               ? \"text-primary/50\"\n175:                               : \"text-muted-foreground/30\"\n176:                         }`}\n177:                       >\n178:                         {prosody.stress === \"primary\" ? \"●\" : prosody.stress === \"secondary\" ? \"○\" : \"·\"}\n179:                       </span>\n180:                     )}\n181:                   </span>\n182:                 )}\n183:                 {showAnnotations && prosody?.coarticulation && (\n184:                   <span\n185:                     className=\"absolute -top-1 -right-1 text-[6px] text-muted-foreground/50 pointer-events-none\"\n186:                     title={prosody.coarticulation.bridgeType}\n187:                   >\n188:                     {prosody.coarticulation.bridgeType === \"linking-r\"\n189:                       ? \"→r\"\n190:                       : prosody.coarticulation.bridgeType === \"flap-t\"\n191:                         ? \"ɾ\"\n192:                         : prosody.coarticulation.bridgeType === \"intrusion\"\n193:                           ? \"↻\"\n194:                           : prosody.coarticulation.bridgeType === \"elision\"\n195:                             ? \"⊘\"\n196:                             : \"≈\"}\n197:                   </span>\n198:                 )}\n199:                 {/* Vowel compression bar */}\n200:                 {showAnnotations && prosody?.vowelCompression && (\n201:                   <span className=\"absolute -bottom-1 left-0 right-0 flex justify-center pointer-events-none\">\n202:                     <span\n203:                       className=\"block h-[2px] rounded-full\"\n204:                       style={{\n205:                         width: `${prosody.vowelCompression.ratio * 100}%`,\n206:                         backgroundColor:\n207:                           prosody.vowelCompression.label === \"full\"\n208:                             ? \"hsl(142, 71%, 45%)\"\n209:                             : prosody.vowelCompression.label === \"compressed\"\n210:                               ? \"hsl(48, 96%, 53%)\"\n211:                               : prosody.vowelCompression.label === \"reduced\"\n212:                                 ? \"hsl(24, 95%, 53%)\"\n213:                                 : \"hsl(0, 84%, 60%)\",\n214:                         opacity: 0.5,\n215:                       }}\n216:                     />\n217:                   </span>\n218:                 )}\n219:                 {\" \"}\n220:               </span>\n221:             );\n222:           })}\n223:         </div>\n224:       </div>\n225:     </div>\n226:   );\n227: }\n\n(End of file - total 227 lines)\n</content>",
