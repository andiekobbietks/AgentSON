      "code": "{\"todos\": [{\"content\": \"Add Simple Mode toggle to score.tsx (jargon \\u2192 plain English labels)\", \"priority\": \"high\", \"status\": \"completed\"}, {\"content\": \"Create WalkthroughOverlay component for first-time users\", \"priority\": \"high\", \"status\": \"completed\"}, {\"content\": \"Fix PitchContour.tsx - increase all font sizes (7px\\u219214px, 6px\\u219212px, 9px\\u219214px), bigger pitch dots, larger coarticulation badges\", \"priority\": \"high\", \"status\": \"completed\"}, {\"content\": \"Fix score.tsx legend - increase from 10px to 14px, larger icons\", \"priority\": \"high\", \"status\": \"completed\"}, {\"content\": \"Fix score.tsx controls - larger buttons, bigger slider labels, increase preset text\", \"priority\": \"high\", \"status\": \"completed\"}, {\"content\": \"Replace Unicode symbols in PitchContour with lucide-react icons (Volume2 for stress, Link for coarticulation, etc.)\", \"priority\": \"medium\", \"status\": \"completed\"}, {\"content\": \"Add aria-labels and roles to PitchContour SVG and interactive elements\", \"priority\": \"medium\", \"status\": \"completed\"}, {\"content\": \"Test dev server still runs after changes\", \"priority\": \"high\", \"status\": \"in_progress\"}]}",
