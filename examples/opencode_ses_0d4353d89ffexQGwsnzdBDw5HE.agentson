      "code": "{\"command\": \"python -c \\\"\\nimport ctypes, ctypes.wintypes\\nimport struct\\n\\n# Check if any overclocking is applied via registry\\nimport winreg\\nkeys_to_check = [\\n    (r'SOFTWARE\\\\Intel\\\\IntelSSA\\\\Power', 'Intel Power'),\\n    (r'SOFTWARE\\\\Intel\\\\DTMTK', 'Intel DTMTK'),\\n    (r'SYSTEM\\\\CurrentControlSet\\\\Services\\\\IntelXTU', 'Intel XTU'),\\n]\\nfor path, name in keys_to_check:\\n    try:\\n        key = winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, path)\\n        print(f'[FOUND] {name} registry entries exist')\\n        i = 0\\n        while True:\\n            try:\\n                val_name, val_data, val_type = winreg.EnumValue(key, i)\\n                if 'voltage' in val_name.lower() or 'multiplier' in val_name.lower() or 'offset' in val_name.lower():\\n                    print(f'  {val_name} = {val_data}')\\n                i += 1\\n            except WindowsError:\\n                break\\n        winreg.CloseKey(key)\\n    except:\\n        pass\\nprint('Registry scan complete')\\n\\\" 2>&1\", \"description\": \"Check for overclocking settings in registry\"}",
