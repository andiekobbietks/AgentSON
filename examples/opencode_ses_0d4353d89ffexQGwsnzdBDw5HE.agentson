      "tool": "bash",
      "code": "{\"command\": \"python -c \\\"\\nimport subprocess, json, sys\\ntry:\\n    import wmi\\n    w = wmi.WMI(namespace='root/OpenHardwareMonitor')\\n    sensors = w.Sensor()\\n    for s in sensors:\\n        if s.SensorType == 'Temperature' and s.Value:\\n            print(f'{s.Parent}: {s.Name} = {s.Value}\\u00b0C')\\nexcept:\\n    print('OpenHardwareMonitor WMI not available')\\n    try:\\n        w = wmi.WMI(namespace='root/wmi')\\n        temps = w.MSAcpi_ThermalZoneTemperature()\\n        for t in temps:\\n            temp_c = (t.CurrentTemperature - 2732) / 10\\n            print(f'Thermal Zone: {temp_c}\\u00b0C')\\n    except Exception as e:\\n        print(f'WMI thermal read failed: {e}')\\n\\\" 2>&1\", \"description\": \"Read temperatures via WMI Python\"}",
