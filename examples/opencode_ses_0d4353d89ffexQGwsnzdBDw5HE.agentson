      "tool": "bash",
      "code": "{\"command\": \"python -c \\\"\\nimport ctypes\\nimport ctypes.wintypes as wt\\n\\n# Simple BIOS/firmware check via WMI\\nimport wmi\\nw = wmi.WMI()\\ncs = w.Win32_ComputerSystemProduct()\\nbios = w.Win32_BIOS()\\nfor b in bios:\\n    print(f'BIOS: {b.Manufacturer} {b.Name} v{b.SMBIOSBIOSVersion} Release: {b.ReleaseDate}')\\nfor c in cs:\\n    print(f'System: {c.Manufacturer} {c.Name} UUID: {c.UUID[:16]}...')\\nprint()\\nproc = w.Win32_Processor()\\nfor p in proc:\\n    print(f'CPU: {p.Name}')\\n    print(f'  Current Voltage: {p.CurrentVoltage}')\\n    print(f'  Ext Clock: {p.ExtClock} MHz')\\n    print(f'  Max Clock: {p.MaxClockSpeed} MHz')\\n    print(f'  Current Clock: {p.CurrentClockSpeed} MHz')\\n    print(f'  Status: {p.Status}')\\n    print(f'  Upgrade Method: {p.UpgradeMethod}')\\n\\\" 2>&1\", \"description\": \"Get BIOS and CPU voltage info\"}",
