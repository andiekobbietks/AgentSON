      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"python -c \\\"\\nimport ctypes\\nimport ctypes.wintypes as wt\\n\\n# Use OpenHardwareMonitor-style approach via ctypes\\n# Check power status and battery health\\nclass SYSTEM_BATTERY_STATE(ctypes.Structure):\\n    _fields_ = [\\n        ('AcOnLine', wt.BOOLEAN),\\n        ('BatteryPresent', wt.BOOLEAN),\\n        ('Charging', wt.BOOLEAN),\\n        ('Discharging', wt.BOOLEAN),\\n        ('Spare1', wt.BYTE * 3),\\n        ('MaxCapacity', wt.DWORD),\\n        ('RemainingCapacity', wt.DWORD),\\n        ('Rate', wt.DWORD),\\n        ('EstimatedTime', wt.DWORD),\\n        ('DefaultAlert1', wt.BYTE),\\n        ('DefaultAlert2', wt.BYTE),\\n    ]\\n\\ntry:\\n    kernel32 = ctypes.windll.kernel32\\n    batt = SYSTEM_BATTERY_STATE()\\n    result = kernel32.CallNtPowerInformation(5, None, 0, ctypes.byref(batt), ctypes.sizeof(batt))\\n    if result == 0:\\n        print(f'AC Power: {bool(batt.AcOnLine)}')\\n        print(f'Battery Present: {bool(batt.BatteryPresent)}')\\n        print(f'Charging: {bool(batt.Charging)}')\\n        print(f'Max Capacity: {batt.MaxCapacity} mWh')\\n        print(f'Remaining: {batt.RemainingCapacity} mWh')\\n        print(f'Charge Rate: {batt.Rate} mW')\\n        pct = (batt.RemainingCapacity / batt.MaxCapacity * 100) if batt.MaxCapacity > 0 else 0\\n        print(f'Battery Health: {pct:.1f}%')\\n    else:\\n        print(f'NtPowerInformation failed: {result}')\\nexcept Exception as e:\\n    print(f'Error: {e}')\\n\\\" 2>&1\", \"description\": \"Check battery health via NT API\"}",
      "output": "Error: function 'CallNtPowerInformation' not found\r\n",
      "status": "success",
