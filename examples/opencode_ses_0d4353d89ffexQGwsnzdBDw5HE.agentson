    {
      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"Get-WinEvent -FilterHashtable @{LogName='System'; Level=1,2; StartTime=(Get-Date).AddDays(-7)} -MaxEvents 50 | Where-Object { $_.Message -match 'WHEA|Hardware|Correctable' } | Select-Object TimeCreated, Id, LevelDisplayName, Message | Format-Table -AutoSize\", \"description\": \"Check WHEA hardware errors in event logs\"}",
