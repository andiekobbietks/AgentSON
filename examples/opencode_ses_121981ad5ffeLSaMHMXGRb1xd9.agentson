XNr_PywWwt9e37hPl3r8dayhiChJPkejNWW3M34%3D\",\n484:           \"footnoteNumber\": 6\n485:         }, {\n486:           \"index\": 1040,\n487:           \"uri\": \"https://www.google.com/url?sa\\u003dE\\u0026q\\u003dhttps%3A%2F%2Fvertexaisearch.cloud.google.com%2Fgrounding-api-redirect%2FAUZIYQHI3Da1Y5nqn15_fi5O67YTGSwPDz3k04tXOvw4AO04OJTdbmSx33DP7LKIw3DAcI7V9oGxe4YlFyDBMYdgYP0AWJ6xgTC3dPMOSlxyoFE0hfsJsQaioqZZlmwWkmU5ijDFAFbw0uTXaBwJjvZDrGQ%3D\",\n488:           \"footnoteNumber\": 7\n489:         }, {\n490:           \"index\": 1187,\n491:           \"uri\": \"https://www.google.com/url?sa\\u003dE\\u0026q\\u003dhttps%3A%2F%2Fvertexaisearch.cloud.google.com%2Fgrounding-api-redirect%2FAUZIYQHosgNCK8sGZmrBepaB45XlgeLxjbfEZZnxCnv1Zrh1X7ItI8UrbcWYn6rZDo4mTUB9fMRVbIYB8kNsbMtPrixcFtSv4eO9Ur1aL4MsPuRxNu2Q11SRD2Qo36SnMAY_YAPVLt8WPrN1Ig8Ou-nRJdAMh3VEGAVL4ws1h8aU0smeNkLJyY4FpelM1rYsKMlZh-_GV0ptywBBh9BTQf6iWqvv5c63A693yTjb\",\n492:           \"footnoteNumber\": 8\n493:         }, {\n494:           \"index\": 1297,\n495:           \"uri\": \"https://www.google.com/url?sa\\u003dE\\u0026q\\u003dhttps%3A%2F%2Fvertexaisearch.cloud.google.com%2Fgrounding-api-redirect%2FAUZIYQEqDgjR3rXMDx0hGu20rTvtRqkADhhH3oVaCW2YuTn35ERNhaHTcCK3Ljymki1xAxj3-iTh8tisgi05LSB85FGg4LVtSIUGfo3YmbWGMYu6p1dlXNr_PywWwt9e37hPl3r8dayhiChJPkejNWW3M34%3D\",\n496:           \"footnoteNumber\": 6\n497:         }, {\n498:           \"index\": 1297,\n499:           \"uri\": \"https://www.google.com/url?sa\\u003dE\\u0026q\\u003dhttps%3A%2F%2Fvertexaisearch.cloud.google.com%2Fgrounding-api-redirect%2FAUZIYQHGPmEZeJN6beOjp3dQedauAwAdTKJ1y1nGSQ0RUtJlfz9RahktyGDyGvXXwsJq9WQ5X8P88oyQMnZ1Qc0lc7avmWNp-K929YIkK_Ln4ZhLXTDdDOecBx_wYVpCp0l1WMkx4SMkM1cAyL1BjLN9NydwUOGmZZz5MAlmEE6H4Eo1f6wqYckqVDsQjxo%3D\",\n500:           \"footnoteNumber\": 9\n501:         }, {\n502:           \"index\": 1348,\n\n(Output capped at 50 KB. Showing lines 1-502. Use offset=503 to continue.)\n</content>",
