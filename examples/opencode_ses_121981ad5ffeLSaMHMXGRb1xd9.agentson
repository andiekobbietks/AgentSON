      "code": "{\"command\": \"node -e \\\"\\nconst fs = require('fs');\\nconst buf = fs.readFileSync('C:/Users/LLM-Test/.mavis/nexus/nexus.db');\\nconst hex = buf.toString('hex').toLowerCase();\\nconst sid = '6d76735f3534623531393338303743343439333038353266363135643962613530616164';\\nlet idx = 0, count = 0;\\nwhile ((idx = hex.indexOf(sid, idx)) !== -1 && count < 3) {\\n  const byteOff = idx / 2;\\n  const ctx = buf.toString('utf8', Math.max(0,byteOff-100), byteOff+300);\\n  console.log('=== nexus.db byte', byteOff, '===');\\n  console.log(ctx);\\n  console.log('---');\\n  idx += 10; count++;\\n}\\nif (count === 0) console.log('Session ID not in nexus.db either');\\nconsole.log('nexus.db size:', buf.length, 'bytes');\\n\\\" 2>&1\", \"description\": \"Search nexus.db for session ID\"}",
