      "code": "{\"command\": \"mavis session messages mvs_54b5193807c44930852f615d9ba50aad --limit 100 2>&1 | node -e \\\"\\nconst chunks = [];\\nprocess.stdin.on('data', c => chunks.push(c));\\nprocess.stdin.on('end', () => {\\n  const raw = JSON.parse(Buffer.concat(chunks).toString());\\n  console.log('Total messages returned:', raw.messages.length);\\n  console.log('First message timestamp:', new Date(raw.messages[0]?.timestamp).toISOString());\\n  console.log('First message role:', raw.messages[0]?.role);\\n  console.log('First message content (first 200):', (raw.messages[0]?.msg_content || raw.messages[0]?.thinking_content || '').substring(0, 200));\\n});\\n\\\" 2>&1\", \"timeout\": 20000, \"description\": \"Get all messages with high limit\"}",
