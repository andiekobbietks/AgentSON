      "output": "<path>C:\\Users\\LLM-Test\\Documents\\FGCompanionStore.ts</path>\n<type>file</type>\n<content>\n1: // FG Companion Store - Frappe UI compliant implementation\n2: \n3: import { \n4:   useCall, \n5:   toast, \n6:   dialog,\n7:   computed\n8: } from 'frappe-ui'\n9: \n10: export const FGCompanionStore = {\n11:   setup() {\n12:     // ===== Frappe UI Data Fetching Pattern =====\n13:     // Use Frappe UI's useCall for data fetching with lazy loading\n14:     // Events store\n15:     const { \n16:       data: events, \n17:       execute: fetchEvents, \n18:       loading: loadingEvents, \n19:       error: eventsError \n20:     } = useCall('fg_companion.api.get_events', {\n21:       lazy: true\n22:     })\n23:     \n24:     // Raven DMs store - combined channels + messages\n25:     const {\n26:       data: ravenDMs,\n27:       execute: fetchRavenDMs,\n28:       loading: loadingRavenDMs,\n29:       error: ravenDMsError\n30:     } = useCall('raven_channel.get_all_channels', {\n31:       lazy: true\n32:     })\n33:     \n34:     // LMS Courses store\n35:     const {\n36:       data: lmsCourses,\n37:       execute: fetchLmsCourses,\n38:       loading: loadingLmsCourses,\n39:       error: lmsCoursesError\n40:     } = useCall('lms.utils.get_courses', {\n41:       lazy: true\n42:     })\n43:     \n44:     // ===== Frappe UI Imperative APIs =====\n45:     // Custom method for creating DMs using Frappe UI's dialog for loading states\n46:     const openOrCreateDMWithUser = async (userId, userName) => {\n47:       try {\n48:         // Use Frappe UI's dialog API for loading state\n49:         return await dialog.loading(\n50:           async () => {\n51:             const { data } = await useCall('raven_channel.create_direct_message_channel', {\n52:               method: 'POST',\n53:               params: {\n54:                 user_id: userId,\n55:                 user_name: userName\n56:               }\n57:             })\n58:             \n59:             // Refresh DMs list using Frappe UI pattern\n60:             await fetchRavenDMs()\n61:             \n62:             return data\n63:           },\n64:           `Creating DM with ${userName}...`\n65:         )\n66:       } catch (error) {\n67:         // Use Frappe UI's toast API for error handling\n68:         toast.error(`Failed to create DM with ${userName}: ${error.message}`)\n69:         throw error\n70:       }\n71:     }\n72:     \n73:     // ===== Frappe UI Public API Pattern =====\n74:     return {\n75:       // State - reactive from Frappe UI useCall composable\n76:       events,\n77:       ravenDMs,\n78:       lmsCourses,\n79:       loadingEvents,\n80:       loadingRavenDMs,\n81:       loadingLmsCourses,\n82:       eventsError,\n83:       ravenDMsError,\n84:       lmsCoursesError,\n85:       \n86:       // Methods - Frappe UI imperative patterns\n87:       loadEvents: async () => {\n88:         try {\n89:           return await fetchEvents()\n90:         } catch (error) {\n91:           toast.error(`Failed to load events: ${error.message}`)\n92:           throw error\n93:         }\n94:       },\n95:       \n96:       loadRavenDMs: async () => {\n97:         try {\n98:           return await fetchRavenDMs()\n99:         } catch (error) {\n100:           toast.error(`Failed to load DMs: ${error.message}`)\n101:           throw error\n102:         }\n103:       },\n104:       \n105:       loadLmsCourses: async () => {\n106:         try {\n107:           return await fetchLmsCourses()\n108:         } catch (error) {\n109:           toast.error(`Failed to load courses: ${error.message}`)\n110:           throw error\n111:         }\n112:       },\n113:       \n114:       createDMWithUser: openOrCreateDMWithUser\n115:     }\n116:   }\n117: }\n\n(End of file - total 117 lines)\n</content>",
