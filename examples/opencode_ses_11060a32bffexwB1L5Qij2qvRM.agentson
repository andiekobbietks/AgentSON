      "output": "<path>C:\\Users\\LLM-Test\\Documents\\FGCompanionStore.ts</path>\n<type>file</type>\n<content>\n1: // FG Companion Store - Frappe UI compliant implementation\n2: \n3: import { \n4:   useCall, \n5:   toast, \n6:   dialog,\n7:   computed\n8: } from 'frappe-ui'\n9: \n10: export const FGCompanionStore = {\n11:   setup() {\n12:     // Use Frappe UI's useCall for data fetching\n13:     // Events store\n14:     const { \n15:       data: events, \n16:       execute: fetchEvents, \n17:       loading: loadingEvents, \n18:       error: eventsError \n19:     } = useCall('fg_companion.api.get_events', {\n20:       lazy: true\n21:     })\n22:     \n23:     // Raven DMs store - combined channels + messages\n24:     const {\n25:       data: ravenDMs,\n26:       execute: fetchRavenDMs,\n27:       loading: loadingRavenDMs,\n28:       error: ravenDMsError\n29:     } = useCall('raven_channel.get_all_channels', {\n30:       lazy: true\n31:     })\n32:     \n33:     // LMS Courses store\n34:     const {\n35:       data: lmsCourses,\n36:       execute: fetchLmsCourses,\n37:       loading: loadingLmsCourses,\n38:       error: lmsCoursesError\n39:     } = useCall('lms.utils.get_courses', {\n40:       lazy: true\n41:     })\n42:     \n43:     // Custom method for creating DMs using Frappe UI's dialog\n44:     const openOrCreateDMWithUser = async (userId, userName) => {\n45:       try {\n46:         // Use Frappe UI's dialog for loading state\n47:         return await dialog.loading(\n48:           async () => {\n49:             const { data } = await useCall('raven_channel.create_direct_message_channel', {\n50:               method: 'POST',\n51:               params: {\n52:                 user_id: userId,\n53:                 user_name: userName\n54:               }\n55:             })\n56:             \n57:             // Refresh DMs list\n58:             await fetchRavenDMs()\n59:             \n60:             return data\n61:           },\n62:           `Creating DM with ${userName}...`\n63:         )\n64:       } catch (error) {\n65:         toast.error(`Failed to create DM with ${userName}: ${error.message}`)\n66:         throw error\n67:       }\n68:     }\n69:     \n70:     // Public API using Frappe UI patterns\n71:     return {\n72:       // State - reactive from Frappe UI useCall\n73:       events,\n74:       ravenDMs,\n75:       lmsCourses,\n76:       loadingEvents,\n77:       loadingRavenDMs,\n78:       loadingLmsCourses,\n79:       eventsError,\n80:       ravenDMsError,\n81:       lmsCoursesError,\n82:       \n83:       // Methods - Frappe UI imperative patterns\n84:       loadEvents: async () => {\n85:         try {\n86:           return await fetchEvents()\n87:         } catch (error) {\n88:           toast.error(`Failed to load events: ${error.message}`)\n89:           throw error\n90:         }\n91:       },\n92:       \n93:       loadRavenDMs: async () => {\n94:         try {\n95:           return await fetchRavenDMs()\n96:         } catch (error) {\n97:           toast.error(`Failed to load DMs: ${error.message}`)\n98:           throw error\n99:         }\n100:       },\n101:       \n102:       loadLmsCourses: async () => {\n103:         try {\n104:           return await fetchLmsCourses()\n105:         } catch (error) {\n106:           toast.error(`Failed to load courses: ${error.message}`)\n107:           throw error\n108:         }\n109:       },\n110:       \n111:       createDMWithUser: openOrCreateDMWithUser\n112:     }\n113:   }\n114: }\n\n(End of file - total 114 lines)\n</content>",
