      "code": "{\"content\": \"//!/usr/bin/env node\\n\\n// Verification script for Frappe UI converted components\\n\\nconst fs = require('fs')\\n\\nfunction checkFrappeUICompliance() {\\n  console.log('\\ud83d\\udd0d Checking Frappe UI compliance...\\\\n')\\n  \\n  const components = [\\n    { name: 'FGCompanionStore.ts', path: 'C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\Documents\\\\\\\\FGCompanionStore.ts' },\\n    { name: 'FGCompanionStoreTest.vue', path: 'C:\\\\\\\\Users\\\\\\\\LLM-Test\\\\\\\\Documents\\\\\\\\FGCompanionStoreTest.vue' }\\n  ]\\n  \\n  let totalScore = 0\\n  \\n  for (const component of components) {\\n    console.log('\\ud83d\\udcc1 Checking ' + component.name + '...\\\\n')\\n    \\n    if (!fs.existsSync(component.path)) {\\n      console.log('  \\u274c ' + component.name + ' not found')\\n      continue\\n    }\\n    \\n    const content = fs.readFileSync(component.path, 'utf8')\\n    \\n    // Frappe UI compliance checks\\n    const checks = [\\n      {\\n        name: 'Uses Frappe UI imports',\\n        test: /from\\\\s+[\\\"']frappe-ui[\\\"']\\\\s+import\\\\s*[{]/g,\\n        weight: 30,\\n        message: '\\u2705 Uses Frappe UI imports'\\n      },\\n      {\\n        name: 'Uses useCall composable',\\n        test: /useCall\\\\s*\\\\(/g,\\n        weight: 25,\\n        message: '\\u2705 Uses useCall composable'\\n      },\\n      {\\n        name: 'Uses Frappe UI components',\\n        test: /Frappe[A-Z][a-zA-Z]*/g,\\n        weight: 20,\\n        message: '\\u2705 Uses Frappe UI components'\\n      },\\n      {\\n        name: 'Uses Frappe UI imperative APIs',\\n        test: /(toast\\\\.|dialog\\\\.|alert\\\\.|loading)/g,\\n        weight: 15,\\n        message: '\\u2705 Uses Frappe UI imperative APIs'\\n      },\\n      {\\n        name: 'Uses data-slot for customization',\\n        test: /data-slot\\\\s*=\\\\s*\\\"/g,\\n        weight: 10,\\n        message: '\\u2705 Uses data-slot for customization'\\n      },\\n      {\\n        name: 'Uses data-variant for styling',\\n        test: /data-variant\\\\s*=\\\\s*\\\"/g,\\n        weight: 10,\\n        message: '\\u2705 Uses data-variant for styling'\\n      },\\n      {\\n        name: 'No custom state management',\\n        test: /(defineModel|reactive|ref\\\\s*=\\\\s*{)/g,\\n        negative: true,\\n        weight: -10,\\n        message: '\\u274c Uses custom state management'\\n      },\\n      {\\n        name: 'No native fetch API',\\n        test: /fetch\\\\s*\\\\(/g,\\n        negative: true,\\n        weight: -15,\\n        message: '\\u274c Uses native fetch API'\\n      },\\n      {\\n        name: 'No custom APIs',\\n        test: /fetchEvents|loadEvents|createDM|loadRavenDMs|loadLmsCourses/g,\\n        negative: true,\\n        weight: -10,\\n        message: '\\u274c Uses custom APIs'\\n      }\\n    ]\\n    \\n    let componentScore = 0\\n    let componentIssues = []\\n    \\n    for (const check of checks) {\\n      let passed = false\\n      \\n      if (check.negative) {\\n        passed = !check.test.test(content)\\n      } else {\\n        passed = check.test.test(content)\\n      }\\n      \\n      if (passed) {\\n        console.log('  ' + check.message)\\n        componentScore += check.weight\\n      } else {\\n        if (check.negative) {\\n          console.log('  ' + check.message)\\n          componentIssues.push(check.name)\\n        } else {\\n          console.log('  ' + check.message)\\n        }\\n      }\\n    }\\n    \\n    const componentPercentage = Math.max(0, componentScore)\\n    console.log('  \\ud83d\\udcca Score: ' + componentPercentage + '%\\\\n')\\n    \\n    if (componentIssues.length > 0) {\\n      console.log('  \\u26a0\\ufe0f  Issues: ' + componentIssues.join(', ') + '\\\\n')\\n    }\\n    \\n    totalScore += componentPercentage\\n  }\\n  \\n  const averageScore = components.length > 0 ? totalScore / components.length : 0\\n  \\n  console.log('\\ud83d\\udcc8 Final Compliance Report:\\\\n')\\n  console.log('\\ud83d\\udcca Average Frappe UI Compliance: ' + averageScore.toFixed(1) + '%\\\\n')\\n  \\n  if (averageScore >= 80) {\\n    console.log('\\u2705 EXCELLENT: Implementation is fully Frappe UI compliant!')\\n  } else if (averageScore >= 60) {\\n    console.log('\\u2705 GOOD: Implementation follows most Frappe UI patterns')\\n  } else if (averageScore >= 40) {\\n    console.log('\\u26a0\\ufe0f FAIR: Implementation has some Frappe UI patterns but needs improvement')\\n  } else {\\n    console.log('\\u274c POOR: Implementation is far from Frappe UI standards')\\n  }\\n  \\n  return averageScore >= 60\\n}\\n\\n// Run the verification\\nif (require.main === module) {\\n  const success = checkFrappeUICompliance()\\n  process.exit(success ? 0 : 1)\\n}\\n\\nmodule.exports = { checkFrappeUICompliance }\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\verify-frappe-ui.js\"}",
