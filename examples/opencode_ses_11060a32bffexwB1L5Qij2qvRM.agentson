n'\n61:     },\n62:     {\n63:       name: 'Has API methods',\n64:       test: /(fetchEvents|fetchRavenDMs|openOrCreateDMWithUser|fetchLmsCourses)/g,\n65:       message: '✅ Has API methods'\n66:     },\n67:     {\n68:       name: 'Uses defineExpose',\n69:       test: /defineExpose/g,\n70:       message: '✅ Uses defineExpose'\n71:     },\n72:     {\n73:       name: 'Exports reactive state',\n74:       test: /(events.value|ravenDMs.value|lmsCourses.value)/g,\n75:       message: '✅ Exports reactive state'\n76:     }\n77:   ]\n78:   \n79:   let allPassed = true\n80:   \n81:   checks.forEach(check => {\n82:     if (check.test.test(content)) {\n83:       console.log(check.message)\n84:     } else {\n85:       console.log(`❌ Missing: ${check.name}`)\n86:       allPassed = false\n87:     }\n88:   })\n89:   \n90:   // Check for design principle violations\n91:   const violations = [\n92:     {\n93:       name: 'No config blob props',\n94:       test: /:options\\s*:/g,\n95:       message: '❌ Found config blob prop (:options)'\n96:     },\n97:     {\n98:       name: 'No generic mode prop',\n99:       test: /:mode\\s*:/g,\n100:       message: '❌ Found generic mode prop (:mode)'\n101:     },\n102:     {\n103:       name: 'Has semantic color axis',\n104:       test: /(intent|severity|appearance|kind|status)/g,\n105:       message: '❌ Found semantic color axis prop'\n106:     },\n107:     {\n108:       name: 'Has class-name injection props',\n109:       test: /(triggerClass|contentClass|itemClass)/g,\n110:       message: '❌ Found class-name injection prop'\n111:     }\n112:   ]\n113:   \n114:   violations.forEach(violation => {\n115:     if (violation.test.test(content)) {\n116:       console.log(violation.message)\n117:       allPassed = false\n118:     }\n119:   })\n120:   \n121:   console.log('\\n📊 Summary:')\n122:   if (allPassed) {\n123:     console.log('✅ All design principles followed correctly!')\n124:   } else {\n125:     console.log('❌ Some design principles violations detected')\n126:   }\n127:   \n128:   return allPassed\n129: }\n130: \n131: // Run the verification\n132: if (require.main === module) {\n133:   const success = checkStoreTS()\n134:   process.exit(success ? 0 : 1)\n135: }\n136: \n137: module.exports = { checkStoreTS }\n\n(End of file - total 137 lines)\n</content>",
