      "output": "<path>C:\\Users\\LLM-Test\\Documents\\FGCompanionStoreTest.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <div class=\"fg-companion-store\">\n3:     <h2>FG Companion Store Test</h2>\n4:     \n5:     <!-- Events Section -->\n6:     <FrappePanel \n7:       title=\"Events Store\" \n8:       variant=\"subtle\"\n9:       theme=\"blue\"\n10:       data-slot=\"section\"\n11:     >\n12:       <template #header>\n13:         <h3>Events Management</h3>\n14:       </template>\n15:       \n16:       <template #default>\n17:         <FrappeButton \n18:           data-slot=\"trigger\"\n19:           data-variant=\"solid\"\n20:           data-theme=\"blue\"\n21:           @click=\"loadEvents\"\n22:           :disabled=\"loadingEvents\"\n23:         >\n24:           {{ loadingEvents ? 'Loading...' : 'Load Events' }}\n25:         </FrappeButton>\n26:         \n27:         <FrappeAlert \n28:           v-if=\"eventsError\"\n29:           data-variant=\"subtle\"\n30:           data-theme=\"red\"\n31:           title=\"Error\"\n32:         >\n33:           {{ eventsError?.message || 'Unknown error' }}\n34:         </FrappeAlert>\n35:         \n36:         <FrappeList \n37:           v-if=\"events && events.length > 0\"\n38:           data-slot=\"item\"\n39:           :data-variant=\"getEventVariant(event.type)\"\n40:         >\n41:           <template #item=\"{ item, index }\">\n42:             <div class=\"event-item\">\n43:               <div class=\"event-title\">{{ item.title }}</div>\n44:               <div class=\"event-description\">{{ item.description }}</div>\n45:               <div class=\"event-timestamp\">{{ formatDate(item.timestamp) }}</div>\n46:             </div>\n47:           </template>\n48:         </FrappeList>\n49:         \n50:         <div v-if=\"!events || events.length === 0\" data-slot=\"empty\">\n51:           No events to display\n52:         </div>\n53:       </template>\n54:     </FrappePanel>\n55:     \n56:     <!-- Raven DMs Section -->\n57:     <FrappePanel \n58:       title=\"Raven DMs Store\" \n59:       variant=\"outline\"\n60:       theme=\"green\"\n61:       data-slot=\"section\"\n62:     >\n63:       <template #header>\n64:         <h3>Raven Direct Messages</h3>\n65:       </template>\n66:       \n67:       <template #default>\n68:         <FrappeButton \n69:           data-slot=\"trigger\"\n70:           data-variant=\"outline\"\n71:           data-theme=\"green\"\n72:           @click=\"loadRavenDMs\"\n73:           :disabled=\"loadingRavenDMs\"\n74:         >\n75:           {{ loadingRavenDMs ? 'Loading...' : 'Load DMs' }}\n76:         </FrappeButton>\n77:         \n78:         <FrappeAlert \n79:           v-if=\"ravenDMsError\"\n80:           data-variant=\"subtle\"\n81:           data-theme=\"red\"\n82:           title=\"Error\"\n83:         >\n84:           {{ ravenDMsError?.message || 'Unknown error' }}\n85:         </FrappeAlert>\n86:         \n87:         <FrappeList \n88:           v-if=\"ravenDMs && ravenDMs.length > 0\"\n89:           data-slot=\"item\"\n90:           :data-variant=\"getDMVariant(dm.lastMessage)\"\n91:         >\n92:           <template #item=\"{ item: dm, index }\">\n93:             <div class=\"dm-item\">\n94:               <div class=\"dm-name\">{{ dm.name }}</div>\n95:               <div class=\"dm-preview\" v-if=\"dm.lastMessage\">\n96:                 <span class=\"dm-sender\">{{ dm.lastMessage.sender }}:</span>\n97:                 <span class=\"dm-content\">{{ dm.lastMessage.content }}</span>\n98:               </div>\n99:               <div class=\"dm-no-messages\" v-else>No messages</div>\n100:               <div class=\"dm-unread-count\" v-if=\"dm.unreadCount > 0\">\n101:                 {{ dm.unreadCount }} unread\n102:               </div>\n103:             </div>\n104:           </template>\n105:         </FrappeList>\n106:         \n107:         <div v-if=\"!ravenDMs || ravenDMs.length === 0\" data-slot=\"empty\">\n108:           No DMs to display\n109:         </div>\n110:       </template>\n111:     </FrappePanel>\n112:     \n113:     <!-- LMS Courses Section -->\n114:     <FrappePanel \n115:       title=\"LMS Courses Store\" \n116:       variant=\"ghost\"\n117:       theme=\"purple\"\n118:       data-slot=\"section\"\n119:     >\n120:       <template #header>\n121:         <h3>Learning Management System</h3>\n122:       </template>\n123:       \n124:       <template #default>\n125:         <FrappeButton \n126:           data-slot=\"trigger\"\n127:           data-variant=\"ghost\"\n128:           data-theme=\"purple\"\n129:           @click=\"loadLmsCourses\"\n130:           :disabled=\"loadingLmsCourses\"\n131:         >\n132:           {{ loadingLmsCourses ? 'Loading...' : 'Load Courses' }}\n133:         </FrappeButton>\n134:         \n135:         <FrappeAlert \n136:           v-if=\"lmsCoursesError\"\n137:           data-variant=\"subtle\"\n138:           data-theme=\"red\"\n139:           title=\"Error\"\n140:         >\n141:           {{ lmsCoursesError?.message || 'Unknown error' }}\n142:         </FrappeAlert>\n143:         \n144:         <FrappeList \n145:           v-if=\"lmsCourses && lmsCourses.length > 0\"\n146:           data-slot=\"item\"\n147:           :data-variant=\"getCourseVariant(course.status)\"\n148:         >\n149:           <template #item=\"{ item: course, index }\">\n150:             <div class=\"course-item\">\n151:               <div class=\"course-name\">{{ course.name }}</div>\n152:               <div class=\"course-description\">{{ course.description }}</div>\n153:               <div class=\"course-instructor\">{{ course.instructor }}</div>\n154:               <FrappeBadge \n155:                 :data-variant=\"getCourseStatusVariant(course.status)\"\n156:                 data-size=\"small\"\n157:               >\n158:                 {{ course.status }}\n159:               </FrappeBadge>\n160:             </div>\n161:           </template>\n162:         </FrappeList>\n163:         \n164:         <div v-if=\"!lmsCourses || lmsCourses.length === 0\" data-slot=\"empty\">\n165:           No courses to display\n166:         </div>\n167:       </template>\n168:     </FrappePanel>\n169:     \n170:     <!-- Create DM Section -->\n171:     <FrappePanel \n172:       title=\"Create Direct Message\" \n173:       variant=\"solid\"\n174:       theme=\"orange\"\n175:       data-slot=\"section\"\n176:     >\n177:       <template #header>\n178:         <h3>Start New Conversation</h3>\n179:       </template>\n180:       \n181:       <template #default>\n182:         <div class=\"dm-form\">\n183:           <FrappeInput\n184:             v-model=\"newUserId\"\n185:             placeholder=\"User ID\"\n186:             data-slot=\"input\"\n187:           />\n188:           <FrappeInput\n189:             v-model=\"newUserName\"\n190:             placeholder=\"User Name\"\n191:             data-slot=\"input\"\n192:           />\n193:           <FrappeButton \n194:             data-slot=\"trigger\"\n195:             data-variant=\"solid\"\n196:             data-theme=\"orange\"\n197:             @click=\"createDMWithUser\"\n198:             :disabled=\"loadingRavenDMs || !newUserId || !newUserName\"\n199:           >\n200:             Create DM\n201:           </FrappeButton>\n202:         </div>\n203:       </template>\n204:     </FrappePanel>\n205:   </div>\n206: </template>\n207: \n208: <script setup>\n209: import { \n210:   FrappeButton, \n211:   FrappePanel, \n212:   FrappeAlert, \n213:   FrappeList, \n214:   FrappeInput,\n215:   FrappeBadge\n216: } from 'frappe-ui'\n217: import { FGCompanionStore } from './FGCompanionStore.ts'\n218: import { ref } from 'vue'\n219: \n220: const {\n221:   events,\n222:   ravenDMs,\n223:   lmsCourses,\n224:   loadingEvents,\n225:   loadingRavenDMs,\n226:   loadingLmsCourses,\n227:   eventsError,\n228:   ravenDMsError,\n229:   lmsCoursesError,\n230:   loadEvents,\n231:   loadRavenDMs,\n232:   loadLmsCourses,\n233:   createDMWithUser\n234: } = FGCompanionStore.setup()\n235: \n236: const newUserId = ref('')\n237: const newUserName = ref('')\n238: \n239: const loadEvents = async () => {\n240:   await loadEvents()\n241: }\n242: \n243: const loadRavenDMs = async () => {\n244:   await loadRavenDMs()\n245: }\n246: \n247: const loadLmsCourses = async () => {\n248:   await loadLmsCourses()\n249: }\n250: \n251: const createDMWithUser = async () => {\n252:   if (!newUserId.value || !newUserName.value) return\n253:   \n254:   await createDMWithUser(newUserId.value, newUserName.value)\n255:   \n256:   // Reset form\n257:   newUserId.value = ''\n258:   newUserName.value = ''\n259: }\n260: \n261: const getEventVariant = (type) => {\n262:   const variants = {\n263:     'system': 'solid',\n264:     'user': 'outline',\n265:     'team': 'subtle',\n266:     'default': 'ghost'\n267:   }\n268:   return variants[type] || variants.default\n269: }\n270: \n271: const getDMVariant = (lastMessage) => {\n272:   return lastMessage ? 'solid' : 'outline'\n273: }\n274: \n275: const getCourseVariant = (status) => {\n276:   const variants = {\n277:     'enrolled': 'solid',\n278:     'completed': 'outline',\n279:     'in_progress': 'subtle',\n280:     'archived': 'ghost'\n281:   }\n282:   return variants[status] || variants.default\n283: }\n284: \n285: const getCourseStatusVariant = (status) => {\n286:   const colors = {\n287:     'enrolled': 'blue',\n288:     'completed': 'green',\n289:     'in_progress': 'yellow',\n290:     'archived': 'gray'\n291:   }\n292:   return colors[status] || colors.default\n293: }\n294: \n295: const formatDate = (timestamp) => {\n296:   return new Date(timestamp).toLocaleDateString()\n297: }\n298: </script>\n299: \n300: <style scoped>\n301: .fg-companion-store {\n302:   padding: 2rem;\n303:   max-width: 1200px;\n304:   margin: 0 auto;\n305:   font-family: system-ui, sans-serif;\n306: }\n307: \n308: .dm-form {\n309:   display: flex;\n310:   gap: 1rem;\n311:   margin: 1rem 0;\n312:   flex-wrap: wrap;\n313: }\n314: \n315: .dm-form .fg-input {\n316:   flex: 1;\n317:   min-width: 200px;\n318: }\n319: \n320: .event-item,\n321: .dm-item,\n322: .course-item {\n323:   padding: 1rem;\n324:   margin: 0.5rem 0;\n325:   border-bottom: 1px solid #eee;\n326: }\n327: \n328: .event-item:last-child,\n329: .dm-item:last-child,\n330: .course-item:last-child {\n331:   border-bottom: none;\n332: }\n333: \n334: .event-title {\n335:   font-weight: bold;\n336:   color: #0066cc;\n337:   margin-bottom: 0.5rem;\n338: }\n339: \n340: .dm-name {\n341:   font-weight: bold;\n342:   color: #0066cc;\n343:   margin-bottom: 0.5rem;\n344: }\n345: \n346: .course-name {\n347:   font-weight: bold;\n348:   color: #0066cc;\n349:   margin-bottom: 0.5rem;\n350: }\n351: \n352: .dm-sender {\n353:   font-weight: bold;\n354:   color: #0066cc;\n355: }\n356: \n357: .dm-preview {\n358:   margin: 0.5rem 0;\n359: }\n360: \n361: .dm-no-messages {\n362:   color: #999;\n363:   font-style: italic;\n364:   margin: 0.5rem 0;\n365: }\n366: \n367: .dm-unread-count {\n368:   color: #dc3545;\n369:   font-weight: bold;\n370:   font-size: 0.9rem;\n371: }\n372: </style>\n\n(End of file - total 372 lines)\n</content>",
