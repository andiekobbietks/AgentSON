      "code": "{\"content\": \"<template>\\n  <div class=\\\"fg-companion-store\\\">\\n    <h2>FG Companion Store Test</h2>\\n    \\n    <!-- Events Section -->\\n    <FrappePanel \\n      title=\\\"Events Store\\\" \\n      variant=\\\"subtle\\\"\\n      theme=\\\"blue\\\"\\n      data-slot=\\\"section\\\"\\n    >\\n      <template #header>\\n        <h3>Events Management</h3>\\n      </template>\\n      \\n      <template #default>\\n        <FrappeButton \\n          data-slot=\\\"trigger\\\"\\n          data-variant=\\\"solid\\\"\\n          data-theme=\\\"blue\\\"\\n          @click=\\\"loadEvents\\\"\\n          :disabled=\\\"loadingEvents\\\"\\n        >\\n          {{ loadingEvents ? 'Loading...' : 'Load Events' }}\\n        </FrappeButton>\\n        \\n        <FrappeAlert \\n          v-if=\\\"eventsError\\\"\\n          data-variant=\\\"subtle\\\"\\n          data-theme=\\\"red\\\"\\n          title=\\\"Error\\\"\\n        >\\n          {{ eventsError?.message || 'Unknown error' }}\\n        </FrappeAlert>\\n        \\n        <FrappeList \\n          v-if=\\\"events && events.length > 0\\\"\\n          data-slot=\\\"item\\\"\\n          :data-variant=\\\"getEventVariant(event.type)\\\"\\n        >\\n          <template #item=\\\"{ item, index }\\\">\\n            <div class=\\\"event-item\\\">\\n              <div class=\\\"event-title\\\">{{ item.title }}</div>\\n              <div class=\\\"event-description\\\">{{ item.description }}</div>\\n              <div class=\\\"event-timestamp\\\">{{ formatDate(item.timestamp) }}</div>\\n            </div>\\n          </template>\\n        </FrappeList>\\n        \\n        <div v-if=\\\"!events || events.length === 0\\\" data-slot=\\\"empty\\\">\\n          No events to display\\n        </div>\\n      </template>\\n    </FrappePanel>\\n    \\n    <!-- Raven DMs Section -->\\n    <FrappePanel \\n      title=\\\"Raven DMs Store\\\" \\n      variant=\\\"outline\\\"\\n      theme=\\\"green\\\"\\n      data-slot=\\\"section\\\"\\n    >\\n      <template #header>\\n        <h3>Raven Direct Messages</h3>\\n      </template>\\n      \\n      <template #default>\\n        <FrappeButton \\n          data-slot=\\\"trigger\\\"\\n          data-variant=\\\"outline\\\"\\n          data-theme=\\\"green\\\"\\n          @click=\\\"loadRavenDMs\\\"\\n          :disabled=\\\"loadingRavenDMs\\\"\\n        >\\n          {{ loadingRavenDMs ? 'Loading...' : 'Load DMs' }}\\n        </FrappeButton>\\n        \\n        <FrappeAlert \\n          v-if=\\\"ravenDMsError\\\"\\n          data-variant=\\\"subtle\\\"\\n          data-theme=\\\"red\\\"\\n          title=\\\"Error\\\"\\n        >\\n          {{ ravenDMsError?.message || 'Unknown error' }}\\n        </FrappeAlert>\\n        \\n        <FrappeList \\n          v-if=\\\"ravenDMs && ravenDMs.length > 0\\\"\\n          data-slot=\\\"item\\\"\\n          :data-variant=\\\"getDMVariant(dm.lastMessage)\\\"\\n        >\\n          <template #item=\\\"{ item: dm, index }\\\">\\n            <div class=\\\"dm-item\\\">\\n              <div class=\\\"dm-name\\\">{{ dm.name }}</div>\\n              <div class=\\\"dm-preview\\\" v-if=\\\"dm.lastMessage\\\">\\n                <span class=\\\"dm-sender\\\">{{ dm.lastMessage.sender }}:</span>\\n                <span class=\\\"dm-content\\\">{{ dm.lastMessage.content }}</span>\\n              </div>\\n              <div class=\\\"dm-no-messages\\\" v-else>No messages</div>\\n              <div class=\\\"dm-unread-count\\\" v-if=\\\"dm.unreadCount > 0\\\">\\n                {{ dm.unreadCount }} unread\\n              </div>\\n            </div>\\n          </template>\\n        </FrappeList>\\n        \\n        <div v-if=\\\"!ravenDMs || ravenDMs.length === 0\\\" data-slot=\\\"empty\\\">\\n          No DMs to display\\n        </div>\\n      </template>\\n    </FrappePanel>\\n    \\n    <!-- LMS Courses Section -->\\n    <FrappePanel \\n      title=\\\"LMS Courses Store\\\" \\n      variant=\\\"ghost\\\"\\n      theme=\\\"purple\\\"\\n      data-slot=\\\"section\\\"\\n    >\\n      <template #header>\\n        <h3>Learning Management System</h3>\\n      </template>\\n      \\n      <template #default>\\n        <FrappeButton \\n          data-slot=\\\"trigger\\\"\\n          data-variant=\\\"ghost\\\"\\n          data-theme=\\\"purple\\\"\\n          @click=\\\"loadLmsCourses\\\"\\n          :disabled=\\\"loadingLmsCourses\\\"\\n        >\\n          {{ loadingLmsCourses ? 'Loading...' : 'Load Courses' }}\\n        </FrappeButton>\\n        \\n        <FrappeAlert \\n          v-if=\\\"lmsCoursesError\\\"\\n          data-variant=\\\"subtle\\\"\\n          data-theme=\\\"red\\\"\\n          title=\\\"Error\\\"\\n        >\\n          {{ lmsCoursesError?.message || 'Unknown error' }}\\n        </FrappeAlert>\\n        \\n        <FrappeList \\n          v-if=\\\"lmsCourses && lmsCourses.length > 0\\\"\\n          data-slot=\\\"item\\\"\\n          :data-variant=\\\"getCourseVariant(course.status)\\\"\\n        >\\n          <template #item=\\\"{ item: course, index }\\\">\\n            <div class=\\\"course-item\\\">\\n              <div class=\\\"course-name\\\">{{ course.name }}</div>\\n              <div class=\\\"course-description\\\">{{ course.description }}</div>\\n              <div class=\\\"course-instructor\\\">{{ course.instructor }}</div>\\n              <FrappeBadge \\n                :data-variant=\\\"getCourseStatusVariant(course.status)\\\"\\n                data-size=\\\"small\\\"\\n              >\\n                {{ course.status }}\\n              </FrappeBadge>\\n            </div>\\n          </template>\\n        </FrappeList>\\n        \\n        <div v-if=\\\"!lmsCourses || lmsCourses.length === 0\\\" data-slot=\\\"empty\\\">\\n          No courses to display\\n        </div>\\n      </template>\\n    </FrappePanel>\\n    \\n    <!-- Create DM Section -->\\n    <FrappePanel \\n      title=\\\"Create Direct Message\\\" \\n      variant=\\\"solid\\\"\\n      theme=\\\"orange\\\"\\n      data-slot=\\\"section\\\"\\n    >\\n      <template #header>\\n        <h3>Start New Conversation</h3>\\n      </template>\\n      \\n      <template #default>\\n        <div class=\\\"dm-form\\\">\\n          <FrappeInput\\n            v-model=\\\"newUserId\\\"\\n            placeholder=\\\"User ID\\\"\\n            data-slot=\\\"input\\\"\\n          />\\n          <FrappeInput\\n            v-model=\\\"newUserName\\\"\\n            placeholder=\\\"User Name\\\"\\n            data-slot=\\\"input\\\"\\n          />\\n          <FrappeButton \\n            data-slot=\\\"trigger\\\"\\n            data-variant=\\\"solid\\\"\\n            data-theme=\\\"orange\\\"\\n            @click=\\\"createDMWithUser\\\"\\n            :disabled=\\\"loadingRavenDMs || !newUserId || !newUserName\\\"\\n          >\\n            Create DM\\n          </FrappeButton>\\n        </div>\\n      </template>\\n    </FrappePanel>\\n  </div>\\n</template>\\n\\n<script setup>\\nimport { \\n  FrappeButton, \\n  FrappePanel, \\n  FrappeAlert, \\n  FrappeList, \\n  FrappeInput,\\n  FrappeBadge\\n} from 'frappe-ui'\\nimport { FGCompanionStore } from './FGCompanionStore.ts'\\nimport { ref } from 'vue'\\n\\nconst {\\n  events,\\n  ravenDMs,\\n  lmsCourses,\\n  loadingEvents,\\n  loadingRavenDMs,\\n  loadingLmsCourses,\\n  eventsError,\\n  ravenDMsError,\\n  lmsCoursesError,\\n  loadEvents,\\n  loadRavenDMs,\\n  loadLmsCourses,\\n  createDMWithUser\\n} = FGCompanionStore.setup()\\n\\nconst newUserId = ref('')\\nconst newUserName = ref('')\\n\\nconst loadEvents = async () => {\\n  await loadEvents()\\n}\\n\\nconst loadRavenDMs = async () => {\\n  await loadRavenDMs()\\n}\\n\\nconst loadLmsCourses = async () => {\\n  await loadLmsCourses()\\n}\\n\\nconst createDMWithUser = async () => {\\n  if (!newUserId.value || !newUserName.value) return\\n  \\n  await createDMWithUser(newUserId.value, newUserName.value)\\n  \\n  // Reset form\\n  newUserId.value = ''\\n  newUserName.value = ''\\n}\\n\\nconst getEventVariant = (type) => {\\n  const variants = {\\n    'system': 'solid',\\n    'user': 'outline',\\n    'team': 'subtle',\\n    'default': 'ghost'\\n  }\\n  return variants[type] || variants.default\\n}\\n\\nconst getDMVariant = (lastMessage) => {\\n  return lastMessage ? 'solid' : 'outline'\\n}\\n\\nconst getCourseVariant = (status) => {\\n  const variants = {\\n    'enrolled': 'solid',\\n    'completed': 'outline',\\n    'in_progress': 'subtle',\\n    'archived': 'ghost'\\n  }\\n  return variants[status] || variants.default\\n}\\n\\nconst getCourseStatusVariant = (status) => {\\n  const colors = {\\n    'enrolled': 'blue',\\n    'completed': 'green',\\n    'in_progress': 'yellow',\\n    'archived': 'gray'\\n  }\\n  return colors[status] || colors.default\\n}\\n\\nconst formatDate = (timestamp) => {\\n  return new Date(timestamp).toLocaleDateString()\\n}\\n</script>\\n\\n<style scoped>\\n.fg-companion-store {\\n  padding: 2rem;\\n  max-width: 1200px;\\n  margin: 0 auto;\\n  font-family: system-ui, sans-serif;\\n}\\n\\ndm-form {\\n  display: flex;\\n  gap: 1rem;\\n  margin: 1rem 0;\\n  flex-wrap: wrap;\\n}\\n\\ndm-form .fg-input {\\n  flex: 1;\\n  min-width: 200px;\\n}\\n\\nevent-item,\\ndm-item,\\ncourse-item {\\n  padding: 1rem;\\n  margin: 0.5rem 0;\\n  border-bottom: 1px solid #eee;\\n}\\n\\nevent-item:last-child,\\ndm-item:last-child,\\ncourse-item:last-child {\\n  border-bottom: none;\\n}\\n\\nevent-title {\\n  font-weight: bold;\\n  color: #0066cc;\\n  margin-bottom: 0.5rem;\\n}\\n\\ndm-name {\\n  font-weight: bold;\\n  color: #0066cc;\\n  margin-bottom: 0.5rem;\\n}\\n\\ncourse-name {\\n  font-weight: bold;\\n  color: #0066cc;\\n  margin-bottom: 0.5rem;\\n}\\n\\ndm-sender {\\n  font-weight: bold;\\n  color: #0066cc;\\n}\\n\\ndm-preview {\\n  margin: 0.5rem 0;\\n}\\n\\ndm-no-messages {\\n  color: #999;\\n  font-style: italic;\\n  margin: 0.5rem 0;\\n}\\n\\ndm-unread-count {\\n  color: #dc3545;\\n  font-weight: bold;\\n  font-size: 0.9rem;\\n}\\n</style>\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\FGCompanionStoreTest.vue\"}",
