,\n56:         weight: 10,\n57:         message: '✅ Uses data-slot for customization'\n58:       },\n59:       {\n60:         name: 'Uses data-variant for styling',\n61:         test: /data-variant\\s*=\\s*\"/g,\n62:         weight: 10,\n63:         message: '✅ Uses data-variant for styling'\n64:       },\n65:       {\n66:         name: 'No custom state management',\n67:         test: /(defineModel|reactive|ref\\s*=\\s*{)/g,\n68:         negative: true,\n69:         weight: -10,\n70:         message: '❌ Uses custom state management'\n71:       },\n72:       {\n73:         name: 'No native fetch API',\n74:         test: /fetch\\s*\\(/g,\n75:         negative: true,\n76:         weight: -15,\n77:         message: '❌ Uses native fetch API'\n78:       },\n79:       {\n80:         name: 'No custom APIs',\n81:         test: /fetchEvents|loadEvents|createDM|loadRavenDMs|loadLmsCourses/g,\n82:         negative: true,\n83:         weight: -10,\n84:         message: '❌ Uses custom APIs'\n85:       }\n86:     ]\n87:     \n88:     let componentScore = 0\n89:     let componentIssues = []\n90:     \n91:     for (const check of checks) {\n92:       let passed = false\n93:       \n94:       if (check.negative) {\n95:         passed = !check.test.test(content)\n96:       } else {\n97:         passed = check.test.test(content)\n98:       }\n99:       \n100:       if (passed) {\n101:         console.log('  ' + check.message)\n102:         componentScore += check.weight\n103:       } else {\n104:         if (check.negative) {\n105:           console.log('  ' + check.message)\n106:           componentIssues.push(check.name)\n107:         } else {\n108:           console.log('  ' + check.message)\n109:         }\n110:       }\n111:     }\n112:     \n113:     const componentPercentage = Math.max(0, componentScore)\n114:     console.log('  📊 Score: ' + componentPercentage + '%\\n')\n115:     \n116:     if (componentIssues.length > 0) {\n117:       console.log('  ⚠️  Issues: ' + componentIssues.join(', ') + '\\n')\n118:     }\n119:     \n120:     totalScore += componentPercentage\n121:   }\n122:   \n123:   const averageScore = components.length > 0 ? totalScore / components.length : 0\n124:   \n125:   console.log('📈 Final Compliance Report:\\n')\n126:   console.log('📊 Average Frappe UI Compliance: ' + averageScore.toFixed(1) + '%\\n')\n127:   \n128:   if (averageScore >= 80) {\n129:     console.log('✅ EXCELLENT: Implementation is fully Frappe UI compliant!')\n130:   } else if (averageScore >= 60) {\n131:     console.log('✅ GOOD: Implementation follows most Frappe UI patterns')\n132:   } else if (averageScore >= 40) {\n133:     console.log('⚠️ FAIR: Implementation has some Frappe UI patterns but needs improvement')\n134:   } else {\n135:     console.log('❌ POOR: Implementation is far from Frappe UI standards')\n136:   }\n137:   \n138:   return averageScore >= 60\n139: }\n140: \n141: // Run the verification\n142: if (require.main === module) {\n143:   const success = checkFrappeUICompliance()\n144:   process.exit(success ? 0 : 1)\n145: }\n146: \n147: module.exports = { checkFrappeUICompliance }\n\n(End of file - total 147 lines)\n</content>",
