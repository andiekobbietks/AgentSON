      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"import xmlrpc.client\\nimport ssl\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\n\\nssl_ctx = ssl.create_default_context()\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\", context=ssl_ctx)\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\", context=ssl_ctx)\\n\\nuid = common.authenticate(DB, USERNAME, API_KEY, {})\\nprint(f\\\"Authenticated: uid={uid}\\\")\\n\\ndef execute(model, method, args=None, kwargs=None):\\n    a = args or []\\n    k = kwargs or {}\\n    return models.execute_kw(DB, uid, API_KEY, model, method, a, k)\\n\\n# 1. Find the Discovery Consultation appointment type\\nprint(\\\"--- Finding appointment type ---\\\")\\napt_ids = execute(\\\"appointment.type\\\", \\\"search\\\", [[[\\\"name\\\", \\\"ilike\\\", \\\"discovery\\\"]]])\\nif not apt_ids:\\n    apt_ids = execute(\\\"appointment.type\\\", \\\"search\\\", [[]])\\n    all_apts = execute(\\\"appointment.type\\\", \\\"read\\\", [apt_ids, [\\\"name\\\"]])\\n    print(\\\"All appointment types:\\\")\\n    for a in all_apts:\\n        print(f\\\"  id={a['id']}: {a['name']}\\\")\\nelse:\\n    apt = execute(\\\"appointment.type\\\", \\\"read\\\", [apt_ids, [\\\"name\\\", \\\"is_published\\\", \\\"website_published\\\", \\\"staff_user_ids\\\"]])\\n    print(f\\\"  id={apt[0]['id']}, name='{apt[0]['name']}', published={apt[0].get('website_published')}, staff={apt[0].get('staff_user_ids')}\\\")\\n\\n    # Force correct name\\n    execute(\\\"appointment.type\\\", \\\"write\\\", [apt_ids, {\\\"name\\\": \\\"Discovery Consultation\\\"}])\\n    print(\\\"  -> Wrote name='Discovery Consultation'\\\")\\n\\n# 2. Clean the view 1117 arch (remove the cache-bust comment)\\nprint(\\\"\\\\n--- Cleaning view 1117 arch ---\\\")\\nview = execute(\\\"ir.ui.view\\\", \\\"read\\\", [[1117], [\\\"arch_db\\\"]])\\narch = view[0][\\\"arch_db\\\"]\\nclean_arch = arch.replace(\\\"<!-- cache-bust -->\\\", \\\"\\\")\\nif clean_arch != arch:\\n    execute(\\\"ir.ui.view\\\", \\\"write\\\", [[1117], {\\\"arch_db\\\": clean_arch}])\\n    print(\\\"  Removed cache-bust comment\\\")\\nelse:\\n    print(\\\"  Arch already clean\\\")\\n\\n# 3. Also find and touch the appointment.info view (parent) to bust\\nprint(\\\"\\\\n--- Checking parent views ---\\\")\\n# Search for the template that renders the H1\\nparent_views = execute(\\\"ir.ui.view\\\", \\\"search\\\", [[[\\\"name\\\", \\\"ilike\\\", \\\"appointment\\\"]]])\\nviews = execute(\\\"ir.ui.view\\\", \\\"read\\\", [parent_views, [\\\"name\\\", \\\"active\\\", \\\"inherit_id\\\"]])\\nfor v in views:\\n    print(f\\\"  id={v['id']}: {v['name']} (active={v['active']})\\\")\\n\\n# 4. Find invite by searching all\\nprint(\\\"\\\\n--- Finding invite ---\\\")\\ninvite_ids = execute(\\\"appointment.invite\\\", \\\"search\\\", [[]])\\nif invite_ids:\\n    invites = execute(\\\"appointment.invite\\\", \\\"read\\\", [invite_ids, [\\\"url_code\\\", \\\"staff_user_ids\\\", \\\"appointment_type_ids\\\"]])\\n    for inv in invites:\\n        code = inv.get(\\\"url_code\\\", \\\"\\\")\\n        print(f\\\"  id={inv['id']}: code={code}, staff={inv.get('staff_user_ids')}, types={inv.get('appointment_type_ids')}\\\")\\n        if \\\"27e80afd\\\" in str(code):\\n            if not inv.get('staff_user_ids'):\\n                execute(\\\"appointment.invite\\\", \\\"write\\\", [[inv['id']], {\\\"staff_user_ids\\\": [[6, 0, [2]]]}])\\n                print(f\\\"    -> Set staff_user_ids=[2] (Andrea)\\\")\\n            else:\\n                print(f\\\"    staff_user_ids already set: {inv['staff_user_ids']}\\\")\\n\\nprint(\\\"\\\\nDone! URLs to check:\\\")\\nprint(\\\"  https://andiekobbie.odoo.com/appointment/discovery-consultation-1\\\")\\nprint(\\\"  https://andiekobbie.odoo.com/book/27e80afd\\\")\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\fix_odoo_cache.py\"}",
