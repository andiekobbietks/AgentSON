ep-end 1.0s 4,\\n      spxCursorOff 0s 2.95s both;\\n  }\\n  @keyframes spxPresFade {\\n    0%    { opacity: 0; }\\n    8%    { opacity: 1; }\\n    78%   { opacity: 1; }\\n    100%  { opacity: 0; }\\n  }\\n  @keyframes spxAKIn {\\n    0%   { opacity: 0; transform: scale(0.7) translateY(20px); }\\n    100% { opacity: 1; transform: scale(1) translateY(0); }\\n  }\\n  @keyframes spxType {\\n    from { width: 0; }\\n    to   { width: 9.4em; }\\n  }\\n  @keyframes spxCursor {\\n    0%, 100% { border-color: #39FF14; }\\n    50%       { border-color: transparent; }\\n  }\\n  @keyframes spxCursorOff {\\n    to { border-color: transparent; }\\n  }\"}",
