      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\fix_odoo_cache.py\", \"content\": \"import xmlrpc.client\\nimport ssl\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nUSERNAME = \\\"admin\\\"  # or your login\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"\\n\\nssl_ctx = ssl.create_default_context()\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\", context=ssl_ctx)\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\", context=ssl_ctx)\\n\\nuid = common.authenticate(DB, USERNAME, API_KEY, {})\\nprint(f\\\"Authenticated: uid={uid}\\\")\\n\\ndef execute(model, method, *args):\\n    return models.execute_kw(DB, uid, API_KEY, model, method, *args)\\n\\n# 1. Read view 1117\\nview = execute(\\\"ir.ui.view\\\", \\\"read\\\", 1117, [\\\"name\\\", \\\"arch_db\\\", \\\"active\\\"])\\nprint(f\\\"View 1117: name={view[0]['name']}, active={view[0]['active']}\\\")\\n\\n# 2. Archive then unarchive to bust QWeb cache\\nexecute(\\\"ir.ui.view\\\", \\\"write\\\", [1117], {\\\"active\\\": False})\\nprint(\\\"Archived view 1117\\\")\\nexecute(\\\"ir.ui.view\\\", \\\"write\\\", [1117], {\\\"active\\\": True})\\nprint(\\\"Unarchived view 1117\\\")\\n\\n# 3. Clear website page cache via ir.config_parameter\\nir_config = execute(\\\"ir.config_parameter\\\", \\\"search\\\", [[\\\"key\\\", \\\"=\\\", \\\"website.cache\\\"]])\\nif ir_config:\\n    execute(\\\"ir.config_parameter\\\", \\\"write\\\", ir_config, {\\\"value\\\": \\\"\\\"})\\n    print(\\\"Cleared website.cache parameter\\\")\\n\\n# 4. Try to clear ir.qweb cache by writing a no-op to force recompile\\n# Find all qweb views referencing appointment\\nqweb_views = execute(\\\"ir.qweb\\\", \\\"search\\\", [[\\\"ir.ui.view\\\", \\\"name\\\", \\\"ilike\\\", \\\"appointment\\\"]])\\nprint(f\\\"Found {len(qweb_views)} qweb views matching 'appointment'\\\")\\n\\nprint(\\\"\\\\nDone! The H1/title should now show 'Discovery Consultation'\\\")\\nprint(\\\"If not, wait ~1h for full cache TTL expiry or clear from Website editor.\\\")\\n\"}",
