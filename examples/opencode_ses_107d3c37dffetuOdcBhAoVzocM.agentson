      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\AKcloud\\\\akcloud-deploy\\\\admin.html\"}",
      "output": "<path>C:\\Users\\LLM-Test\\Documents\\AKcloud\\akcloud-deploy\\admin.html</path>\n<type>file</type>\n<content>\n1: <!DOCTYPE html>\n2: <html lang=\"en\">\n3: <head>\n4: <meta charset=\"utf-8\">\n5: <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n6: <title>Brand Assets — AKCloud Admin</title>\n7: <script>\n8:   // Auth guard — runs before page renders\n9:   (function(){\n10:     const SES = 'ak_ses';\n11:     if (!sessionStorage.getItem(SES)) {\n12:       // No valid session — redirect silently\n13:       document.addEventListener('DOMContentLoaded', function() {\n14:         document.body.style.display = 'none';\n15:       });\n16:       window.location.replace('/');\n17:     }\n18:   })();\n19: </script>\n20: <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n21: <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n22: <link href=\"https://fonts.googleapis.com/css2?family=Exo+2:wght@400;600;700;900&family=DM+Sans:wght@400;500;700&family=JetBrains+Mono:wght@400;500;700&display=swap\" rel=\"stylesheet\">\n23: <style>\n24:   *, *::before, *::after { box-sizing: border-box; }\n25:   html { scroll-behavior: smooth; }\n26:   body { margin: 0; background: #080808; font-family: 'DM Sans', sans-serif; color: #C8C8C8; }\n27:   ::selection { background: rgba(57,255,20,0.25); color: #fff; }\n28: \n29:   @keyframes akTrace { from { transform: translateX(-100%); } to { transform: translateX(600%); } }\n30:   @keyframes akNode { 0%, 100% { opacity: 0.35; transform: scale(0.9); } 50% { opacity: 1; transform: scale(1.15); } }\n31:   @keyframes akFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }\n32:   @media (prefers-reduced-motion: reduce) { * { animation: none !important; transition: none !important; } }\n33: \n34:   nav { position: fixed; top: 0; left: 0; right: 0; height: 64px; z-index: 50; display: flex; align-items: center; justify-content: space-between; padding: 0 40px; background: rgba(8,8,8,0.9); backdrop-filter: blur(12px); border-bottom: 1px solid #242424; }\n35:   .nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }\n36:   .nav-logo img { height: 36px; width: auto; image-rendering: -webkit-optimize-contrast; filter: drop-shadow(0 0 6px rgba(80,200,70,0.35)); }\n37:   .nav-title { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #787878; }\n38:   .nav-back { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #787878; text-decoration: none; transition: color 0.15s; }\n39:   .nav-back:hover { color: #39FF14; }\n40:   .nav-right { display: flex; align-items: center; gap: 20px; }\n41:   .btn-logout { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #787878; background: transparent; border: 1px solid #242424; border-radius: 4px; padding: 7px 14px; cursor: pointer; transition: all 0.15s; }\n42:   .btn-logout:hover { color: #ff5555; border-color: #ff5555; }\n43:   .odoo-status { display: inline-flex; align-items: center; gap: 6px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.06em; }\n44:   .odoo-dot { width: 7px; height: 7px; border-radius: 50%; }\n45:   .odoo-dot.live { background: #39FF14; box-shadow: 0 0 6px #39FF14; }\n46:   .odoo-dot.off { background: #3a3a3a; }\n47: \n48:   .page { max-width: 1180px; margin: 0 auto; padding: 96px 40px 80px; }\n49:   .eyebrow { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: #39FF14; text-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); margin-bottom: 14px; }\n50:   .page-title { margin: 0 0 8px; font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 36px; color: #fff; line-height: 1.1; }\n51:   .page-sub { margin: 0 0 64px; font-family: 'DM Sans', sans-serif; font-size: 16px; line-height: 1.6; color: #787878; max-width: 520px; }\n52: \n53:   .section-head { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #787878; margin: 0 0 20px; padding-bottom: 12px; border-bottom: 1px solid #242424; }\n54: \n55:   .asset-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; margin-bottom: 56px; }\n56: \n57:   .asset-card { position: relative; background: #111; border: 1px solid #242424; border-radius: 8px; overflow: hidden; transition: border-color 0.2s, box-shadow 0.2s; }\n58:   .asset-card::before { content: ''; position: absolute; top: -1px; left: -1px; width: 36px; height: 36px; border-top: 2px solid #39FF14; border-left: 2px solid #39FF14; border-top-left-radius: 8px; box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); transition: width 0.2s, height 0.2s; pointer-events: none; }\n59:   .asset-card:hover { border-color: rgba(57,255,20,0.3); box-shadow: 0 0 0 1px rgba(57,255,20,0.12), 0 8px 32px rgba(0,0,0,0.4); }\n60:   .asset-card:hover::before { width: 72px; height: 72px; }\n61: \n62:   .asset-preview { display: flex; align-items: center; justify-content: center; height: 160px; background: #0d0d0d; border-bottom: 1px solid #242424; padding: 24px; }\n63:   .asset-preview.dark-bg { background: #191919; }\n64:   .asset-preview img { max-width: 100%; max-height: 100%; object-fit: contain; image-rendering: -webkit-optimize-contrast; }\n65: \n66:   .asset-info { padding: 18px 20px; }\n67:   .asset-name { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 14px; color: #fff; margin-bottom: 4px; }\n68:   .asset-meta { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #787878; letter-spacing: 0.04em; margin-bottom: 14px; }\n69: \n70:   .dl-group { display: flex; gap: 8px; flex-wrap: wrap; }\n71:   .dl-btn { display: inline-flex; align-items: center; gap: 6px; font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; background: transparent; border: 1px solid #242424; border-radius: 4px; padding: 7px 12px; cursor: pointer; color: #C8C8C8; transition: all 0.15s; }\n72:   .dl-btn:hover { color: #39FF14; border-color: #39FF14; box-shadow: inset 0 0 0 1px #39FF14, 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.4); }\n73:   .dl-btn.primary { color: #080808; background: #39FF14; border-color: #39FF14; box-shadow: 0 0 8px #39FF14, 0 0 20px rgba(57,255,20,0.4); }\n74:   .dl-btn.primary:hover { box-shadow: 0 0 12px #39FF14, 0 0 32px rgba(57,255,20,0.55); transform: translateY(-1px); }\n75: \n76:   .font-card { background: #111; border: 1px solid #242424; border-radius: 8px; padding: 24px 28px; margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; transition: border-color 0.2s; }\n77:   .font-card:hover { border-color: rgba(57,255,20,0.2); }\n78:   .font-preview-text { font-size: 28px; font-weight: 700; color: #fff; line-height: 1; }\n79:   .font-details { flex: 1; min-width: 200px; }\n80:   .font-name { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 14px; color: #fff; margin-bottom: 2px; }\n81:   .font-role { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #39FF14; text-shadow: 0 0 6px rgba(57,255,20,0.4); letter-spacing: 0.04em; margin-bottom: 6px; }\n82:   .font-weights { font-family: 'DM Sans', sans-serif; font-size: 13px; color: #787878; }\n83: \n84:   .color-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; margin-bottom: 56px; }\n85:   .color-swatch { background: #111; border: 1px solid #242424; border-radius: 8px; overflow: hidden; }\n86:   .swatch-block { height: 56px; }\n87:   .swatch-info { padding: 12px 14px; }\n88:   .swatch-name { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 12px; color: #fff; margin-bottom: 2px; }\n89:   .swatch-hex { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #787878; letter-spacing: 0.05em; }\n90: \n91:   .circuit-rule { max-width: 1180px; margin: 0 auto 56px; padding: 0 40px; }\n92:   .circuit-line { position: relative; height: 1px; width: 100%; background: #242424; overflow: hidden; }\n93:   .circuit-pulse { position: absolute; top: 0; left: 0; height: 100%; width: 14%; background: linear-gradient(90deg, transparent, #39FF14, transparent); box-shadow: 0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.5); animation: akTrace 4s linear infinite; }\n94: \n95:   .toast { position: fixed; bottom: 32px; right: 32px; z-index: 999; background: #191919; border: 1px solid rgba(57,255,20,0.4); border-radius: 6px; padding: 12px 18px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #39FF14; text-shadow: 0 0 6px rgba(57,255,20,0.4); box-shadow: 0 0 0 1px rgba(57,255,20,0.1), 0 8px 24px rgba(0,0,0,0.6); opacity: 0; transform: translateY(8px); transition: all 0.22s ease; pointer-events: none; }\n96:   .toast.show { opacity: 1; transform: translateY(0); }\n97: \n98:   .waitlist-table { width: 100%; border-collapse: collapse; font-family: 'JetBrains Mono', monospace; font-size: 12px; }\n99:   .waitlist-table thead th { padding: 10px 14px; text-align: left; font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #787878; border-bottom: 1px solid #242424; white-space: nowrap; }\n100:   .waitlist-table tbody tr { border-bottom: 1px solid #191919; transition: background 0.12s; }\n101:   .waitlist-table tbody tr:last-child { border-bottom: none; }\n102:   .waitlist-table tbody tr:hover { background: rgba(57,255,20,0.04); }\n103:   .waitlist-table tbody td { padding: 11px 14px; color: #C8C8C8; }\n104:   .waitlist-table tbody td.td-email { color: #fff; }\n105:   .waitlist-table tbody td.td-ts { color: #787878; }\n106:   .waitlist-table tbody td.td-num { color: #3a3a3a; }\n107:   .waitlist-empty { padding: 36px 0; text-align: center; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #3a3a3a; letter-spacing: 0.04em; }\n108:   .waitlist-scroll { max-height: 320px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: #242424 transparent; }\n109:   .waitlist-scroll::-webkit-scrollbar { width: 4px; }\n110:   .waitlist-scroll::-webkit-scrollbar-track { background: transparent; }\n111:   .waitlist-scroll::-webkit-scrollbar-thumb { background: #242424; border-radius: 2px; }\n112: \n113:   @media (max-width: 640px) {\n114:     .page { padding: 88px 20px 60px; }\n115:     nav { padding: 0 20px; }\n116:     .asset-grid { grid-template-columns: 1fr; }\n117:   }\n118: </style>\n119: </head>\n120: <body>\n121: \n122: <div style=\"position:fixed; inset:0; pointer-events:none; background-image:linear-gradient(rgba(57,255,20,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(57,255,20,0.02) 1px, transparent 1px); background-size:48px 48px; z-index:0;\"></div>\n123: \n124: <nav>\n125:   <a href=\"/\" class=\"nav-logo\">\n126:     <img src=\"assets/ak-mark2.png\" srcset=\"assets/ak-mark2@2x.png 2x, assets/ak-mark2@4x.png 4x\" alt=\"AKCloud\" width=\"72\" height=\"36\">\n127:     <span class=\"nav-title\">Admin Panel</span>\n128:   </a>\n129:   <div class=\"nav-right\">\n130:     <div class=\"odoo-status\" id=\"odoo-status-dot\"><span class=\"odoo-dot off\" id=\"odoo-ind\"></span><span id=\"odoo-status-label\" style=\"color:#3a3a3a;\">Odoo · not configured</span></div>\n131:     <a href=\"/\" class=\"nav-back\">← Site</a>\n132:     <button class=\"btn-logout\" onclick=\"adminLogout()\">Sign Out</button>\n133:   </div>\n134: </nav>\n135: \n136: <div class=\"page\" style=\"position:relative; z-index:1; animation: akFade 0.3s ease;\">\n137: \n138:   <div class=\"eyebrow\">Admin Panel</div>\n139:   <h1 class=\"page-title\">Brand Asset Library</h1>\n140:   <p class=\"page-sub\">Download all logos, marks and fonts at the highest available quality. All image assets exported at 4× resolution for retina and print use.</p>\n141: \n142:   <!-- ── LOGOS ── -->\n143:   <div class=\"section-head\">Logos &amp; Marks</div>\n144:   <div class=\"asset-grid\">\n145: \n146:     <div class=\"asset-card\">\n147:       <div class=\"asset-preview\">\n148:         <img src=\"assets/ak-logo.png\" srcset=\"assets/ak-logo@2x.png 2x, assets/ak-logo@4x.png 4x\" alt=\"AKCloud Full Logo\" style=\"max-height:90px; filter:drop-shadow(0 0 12px rgba(80,200,70,0.35));\">\n149:       </div>\n150:       <div class=\"asset-info\">\n151:         <div class=\"asset-name\">AKCloud Full Logo</div>\n152:         <div class=\"asset-meta\">PNG · Transparent BG · 4× export</div>\n153:         <div class=\"dl-group\">\n154:           <a class=\"dl-btn primary\" href=\"assets/ak-logo@4x.png\" download=\"AKCloud-logo-4x.png\">↓ 4× PNG</a>\n155:           <a class=\"dl-btn\" href=\"assets/ak-logo@2x.png\" download=\"AKCloud-logo-2x.png\">2× PNG</a>\n156:           <a class=\"dl-btn\" href=\"assets/ak-logo.png\" download=\"AKCloud-logo.png\">1× PNG</a>\n157:         </div>\n158:       </div>\n159:     </div>\n160: \n161:     <div class=\"asset-card\">\n162:       <div class=\"asset-preview dark-bg\">\n163:         <img src=\"assets/ak-mark2.png\" srcset=\"assets/ak-mark2@2x.png 2x, assets/ak-mark2@4x.png 4x\" alt=\"AK Mark\" style=\"max-height:80px; filter:drop-shadow(0 0 10px rgba(80,200,70,0.4));\">\n164:       </div>\n165:       <div class=\"asset-info\">\n166:         <div class=\"asset-name\">AK Mark (Horizontal)</div>\n167:         <div class=\"asset-meta\">PNG · Transparent BG · 4× export</div>\n168:         <div class=\"dl-group\">\n169:           <a class=\"dl-btn primary\" href=\"assets/ak-mark2@4x.png\" download=\"AKCloud-mark-4x.png\">↓ 4× PNG</a>\n170:           <a class=\"dl-btn\" href=\"assets/ak-mark2@2x.png\" download=\"AKCloud-mark-2x.png\">2× PNG</a>\n171:           <a class=\"dl-btn\" href=\"assets/ak-mark2.png\" download=\"AKCloud-mark.png\">1× PNG</a>\n172:         </div>\n173:       </div>\n174:     </div>\n175: \n176:   </div>\n177: \n178:   <!-- ── COLOUR PALETTE ── -->\n179:   <div class=\"circuit-rule\" style=\"max-width:none; padding:0; margin:0 0 32px;\"><div class=\"circuit-line\"><div class=\"circuit-pulse\"></div></div></div>\n180:   <div class=\"section-head\">Colour Palette</div>\n181:   <div class=\"color-grid\">\n182:     <div class=\"color-swatch\">\n183:       <div class=\"swatch-block\" style=\"background:#39FF14;\"></div>\n184:       <div class=\"swatch-info\"><div class=\"swatch-name\">Primary — Neon Green</div><div class=\"swatch-hex\">#39FF14</div></div>\n185:     </div>\n186:     <div class=\"color-swatch\">\n187:       <div class=\"swatch-block\" style=\"background:#1FCC00;\"></div>\n188:       <div class=\"swatch-info\"><div class=\"swatch-name\">Primary Dim</div><div class=\"swatch-hex\">#1FCC00</div></div>\n189:     </div>\n190:     <div class=\"color-swatch\">\n191:       <div class=\"swatch-block\" style=\"background:#080808; border-bottom:1px solid #242424;\"></div>\n192:       <div class=\"swatch-info\"><div class=\"swatch-name\">Neutral (BG)</div><div class=\"swatch-hex\">#080808</div></div>\n193:     </div>\n194:     <div class=\"color-swatch\">\n195:       <div class=\"swatch-block\" style=\"background:#111111; border-bottom:1px solid #242424;\"></div>\n196:       <div class=\"swatch-info\"><div class=\"swatch-name\">Surface 1</div><div class=\"swatch-hex\">#111111</div></div>\n197:     </div>\n198:     <div class=\"color-swatch\">\n199:       <div class=\"swatch-block\" style=\"background:#191919; border-bottom:1px solid #242424;\"></div>\n200:       <div class=\"swatch-info\"><div class=\"swatch-name\">Surface 2</div><div class=\"swatch-hex\">#191919</div></div>\n201:     </div>\n202:     <div class=\"color-swatch\">\n203:       <div class=\"swatch-block\" style=\"background:#242424; border-bottom:1px solid #3a3a3a;\"></div>\n204:       <div class=\"swatch-info\"><div class=\"swatch-name\">Border</div><div class=\"swatch-hex\">#242424</div></div>\n205:     </div>\n206:     <div class=\"color-swatch\">\n207:       <div class=\"swatch-block\" style=\"background:#C8C8C8;\"></div>\n208:       <div class=\"swatch-info\"><div class=\"swatch-name\">Text Hi</div><div class=\"swatch-hex\">#C8C8C8</div></div>\n209:     </div>\n210:     <div class=\"color-swatch\">\n211:       <div class=\"swatch-block\" style=\"background:#787878;\"></div>\n212:       <div class=\"swatch-info\"><div class=\"swatch-name\">Text Mid</div><div class=\"swatch-hex\">#787878</div></div>\n213:     </div>\n214:     <div class=\"color-swatch\">\n215:       <div class=\"swatch-block\" style=\"background:#FFFFFF;\"></div>\n216:       <div class=\"swatch-info\"><div class=\"swatch-name\">Secondary (White)</div><div class=\"swatch-hex\">#FFFFFF</div></div>\n217:     </div>\n218:   </div>\n219:   <div style=\"margin-bottom:48px;\">\n220:     <button class=\"dl-btn primary\" onclick=\"copyPalette()\">↓ Copy Palette JSON</button>\n221:   </div>\n222: \n223:   <!-- ── TYPOGRAPHY ── -->\n224:   <div class=\"circuit-rule\" style=\"max-width:none; padding:0; margin:0 0 32px;\"><div class=\"circuit-line\"><div class=\"circuit-pulse\" style=\"animation-delay:-1.8s;\"></div></div></div>\n225:   <div class=\"section-head\">Typography</div>\n226: \n227:   <div class=\"font-card\">\n228:     <div class=\"font-details\">\n229:       <div class=\"font-name\">Exo 2</div>\n230:       <div class=\"font-role\">Display · Headings · Labels · Buttons</div>\n231:       <div class=\"font-weights\">Weights: 400 / 600 / 700 / 900</div>\n232:     </div>\n233:     <div style=\"font-family:'Exo 2',sans-serif;\">\n234:       <div class=\"font-preview-text\" style=\"font-weight:900; color:#39FF14; text-shadow:0 0 8px rgba(57,255,20,0.4);\">AKCloud</div>\n235:       <div style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:13px; color:#787878; margin-top:4px; letter-spacing:0.1em; text-transform:uppercase;\">DISPLAY WEIGHT 900</div>\n236:     </div>\n237:     <div class=\"dl-group\">\n238:       <a class=\"dl-btn primary\" href=\"https://fonts.google.com/specimen/Exo+2\" target=\"_blank\" rel=\"noopener\">↗ Google Fonts</a>\n239:       <button class=\"dl-btn\" onclick=\"downloadGFont('Exo+2:wght@400;600;700;900', 'Exo2')\">↓ Download TTF</button>\n240:     </div>\n241:   </div>\n242: \n243:   <div class=\"font-card\">\n244:     <div class=\"font-details\">\n245:       <div class=\"font-name\">DM Sans</div>\n246:       <div class=\"font-role\">Body Copy · Descriptions · Form Fields</div>\n247:       <div class=\"font-weights\">Weights: 400 / 500 / 700</div>\n248:     </div>\n249:     <div>\n250:       <div class=\"font-preview-text\" style=\"font-family:'DM Sans',sans-serif; font-weight:400; color:#C8C8C8; font-size:22px;\">Sovereign cloud for founders.</div>\n251:       <div style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:13px; color:#787878; margin-top:4px; letter-spacing:0.1em; text-transform:uppercase;\">BODY WEIGHT 400</div>\n252:     </div>\n253:     <div class=\"dl-group\">\n254:       <a class=\"dl-btn primary\" href=\"https://fonts.google.com/specimen/DM+Sans\" target=\"_blank\" rel=\"noopener\">↗ Google Fonts</a>\n255:       <button class=\"dl-btn\" onclick=\"downloadGFont('DM+Sans:wght@400;500;700', 'DM-Sans')\">↓ Download TTF</button>\n256:     </div>\n257:   </div>\n258: \n259:   <div class=\"font-card\">\n260:     <div class=\"font-details\">\n261:       <div class=\"font-name\">JetBrains Mono</div>\n262:       <div class=\"font-role\">Technical Data · Code · System Labels</div>\n263:       <div class=\"font-weights\">Weights: 400 / 500 / 700</div>\n264:     </div>\n265:     <div>\n266:       <div class=\"font-preview-text\" style=\"font-family:'JetBrains Mono',monospace; font-weight:400; color:#39FF14; text-shadow:0 0 6px rgba(57,255,20,0.35); font-size:22px;\">&gt; sys.init()</div>\n267:       <div style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:13px; color:#787878; margin-top:4px; letter-spacing:0.1em; text-transform:uppercase;\">MONO WEIGHT 400</div>\n268:     </div>\n269:     <div class=\"dl-group\">\n270:       <a class=\"dl-btn primary\" href=\"https://fonts.google.com/specimen/JetBrains+Mono\" target=\"_blank\" rel=\"noopener\">↗ Google Fonts</a>\n271:       <button class=\"dl-btn\" onclick=\"downloadGFont('JetBrains+Mono:wght@400;500;700', 'JetBrains-Mono')\">↓ Download TTF</button>\n272:     </div>\n273:   </div>\n274: \n275:   <!-- ── ODOO INTEGRATION ── -->\n276:   <div class=\"circuit-rule\" style=\"max-width:none; padding:0; margin:0 0 32px;\"><div class=\"circuit-line\"><div class=\"circuit-pulse\" style=\"animation-delay:-0.8s;\"></div></div></div>\n277:   <div class=\"section-head\">Odoo Backend Connection</div>\n278:   <div style=\"background:#111; border:1px solid #242424; border-radius:8px; padding:28px 32px; margin-bottom:20px; position:relative;\">\n279:     <div style=\"position:absolute;top:-1px;left:-1px;width:36px;height:36px;border-top:2px solid #39FF14;border-left:2px solid #39FF14;border-top-left-radius:8px;box-shadow:0 0 6px #39FF14,0 0 14px rgba(57,255,20,0.55);pointer-events:none;\"></div>\n280:     <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px;\">\n281:       <div>\n282:         <label style=\"display:block;font-family:'Exo 2',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:#787878;margin-bottom:8px;\">Odoo Instance URL</label>\n283:         <input id=\"odoo-url\" type=\"url\" placeholder=\"https://odoo.yourdomain.com\" style=\"width:100%;background:#080808;border:1px solid #242424;border-radius:4px;padding:11px 13px;font-family:'JetBrains Mono',monospace;font-size:13px;color:#fff;outline:none;box-sizing:border-box;transition:border-color 0.15s,box-shadow 0.15s;\" onfocus=\"this.style.borderColor='#39FF14';this.style.boxShadow='0 0 6px #39FF14,0 0 12px rgba(57,255,20,0.25)'\" onblur=\"this.style.borderColor='#242424';this.style.boxShadow='none'\">\n284:       </div>\n285:       <div>\n286:         <label style=\"display:block;font-family:'Exo 2',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:#787878;margin-bottom:8px;\">Database Name</label>\n287:         <input id=\"odoo-db\" type=\"text\" placeholder=\"odoo_production\" style=\"width:100%;background:#080808;border:1px solid #242424;border-radius:4px;padding:11px 13px;font-family:'JetBrains Mono',monospace;font-size:13px;color:#fff;outline:none;box-sizing:border-box;transition:border-color 0.15s,box-shadow 0.15s;\" onfocus=\"this.style.borderColor='#39FF14';this.style.boxShadow='0 0 6px #39FF14,0 0 12px rgba(57,255,20,0.25)'\" onblur=\"this.style.borderColor='#242424';this.style.boxShadow='none'\">\n288:       </div>\n289:       <div>\n290:         <label style=\"display:block;font-family:'Exo 2',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:#787878;margin-bottom:8px;\">Admin Username / Email</label>\n291:         <input id=\"odoo-user\" type=\"email\" placeholder=\"admin@yourdomain.com\" style=\"width:100%;background:#080808;border:1px solid #242424;border-radius:4px;padding:11px 13px;font-family:'JetBrains Mono',monospace;font-size:13px;color:#fff;outline:none;box-sizing:border-box;transition:border-color 0.15s,box-shadow 0.15s;\" onfocus=\"this.style.borderColor='#39FF14';this.style.boxShadow='0 0 6px #39FF14,0 0 12px rgba(57,255,20,0.25)'\" onblur=\"this.style.borderColor='#242424';this.style.boxShadow='none'\">\n292:       </div>\n293:       <div>\n294:         <label style=\"display:block;font-family:'Exo 2',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:#787878;margin-bottom:8px;\">API Key <span style=\"font-weight:400;color:#3a3a3a;letter-spacing:0;\">(Settings → Technical → API Keys)</span></label>\n295:         <input id=\"odoo-key\" type=\"password\" placeholder=\"••••••••••••••••\" style=\"width:100%;background:#080808;border:1px solid #242424;border-radius:4px;padding:11px 13px;font-family:'JetBrains Mono',monospace;font-size:13px;color:#fff;outline:none;box-sizing:border-box;transition:border-color 0.15s,box-shadow 0.15s;\" onfocus=\"this.style.borderColor='#39FF14';this.style.boxShadow='0 0 6px #39FF14,0 0 12px rgba(57,255,20,0.25)'\" onblur=\"this.style.borderColor='#242424';this.style.boxShadow='none'\">\n296:       </div>\n297:     </div>\n298:     <div style=\"display:flex; gap:12px; align-items:center; flex-wrap:wrap;\">\n299:       <button onclick=\"odooSave()\" style=\"font-family:'Exo 2',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#080808;background:#39FF14;border:none;border-radius:4px;padding:11px 22px;cursor:pointer;box-shadow:0 0 8px #39FF14,0 0 20px rgba(57,255,20,0.4);transition:transform 0.15s;\" onmouseenter=\"this.style.transform='translateY(-1px)'\" onmouseleave=\"this.style.transform='none'\">Save Config</button>\n300:       <button onclick=\"odooTest()\" style=\"font-family:'Exo 2',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#C8C8C8;background:transparent;border:1px solid #242424;border-radius:4px;padding:10px 22px;cursor:pointer;transition:all 0.15s;\" onmouseenter=\"this.style.borderColor='#39FF14';this.style.color='#39FF14'\" onmouseleave=\"this.style.borderColor='#242424';this.style.color='#C8C8C8'\">Test Connection</button>\n301:       <div id=\"odoo-result\" style=\"font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:0.03em;min-height:18px;\"></div>\n302:     </div>\n303:   </div>\n304:   <div style=\"background:#0d0d0d; border:1px solid #1a1a1a; border-radius:6px; padding:16px 20px; margin-bottom:56px;\">\n305:     <div style=\"font-family:'Exo 2',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:#39FF14;margin-bottom:10px;\">Netlify Deployment Notes</div>\n306:     <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;\">\n307:       <div style=\"font-family:'JetBrains Mono',monospace;font-size:12px;line-height:1.65;color:#787878;\">\n308:         1. Enable CORS on Odoo in <code style=\"color:#C8C8C8;\">odoo.conf</code>:<br>\n309:         <code style=\"color:#39FF14;\">cors_headers = *</code><br>\n310:         Or use a reverse proxy with CORS headers.<br><br>\n311:         2. Odoo must be HTTPS — mixed content blocked.\n312:       </div>\n313:       <div style=\"font-family:'JetBrains Mono',monospace;font-size:12px;line-height:1.65;color:#787878;\">\n314:         3. For bookings: install <code style=\"color:#C8C8C8;\">appointment</code> module.<br>\n315:         Booking URL: <code style=\"color:#39FF14;\">{odoo_url}/web#action=appointment</code><br><br>\n316:         4. Credentials stored in localStorage — per-device. Re-enter on new browsers.\n317:       </div>\n318:     </div>\n319:   </div>\n320: \n321:   <!-- ── BOOKING LINK CONFIG ── -->\n322:   <div class=\"section-head\">Consultation Booking Link</div>\n323:   <div style=\"background:#111; border:1px solid #242424; border-radius:8px; padding:24px 28px; margin-bottom:56px; display:flex; gap:20px; align-items:flex-end; flex-wrap:wrap;\">\n324:     <div style=\"flex:1; min-width:260px;\">\n325:       <label style=\"display:block;font-family:'Exo 2',sans-serif;font-weight:700;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:#787878;margin-bottom:8px;\">Booking URL <span style=\"font-weight:400;color:#3a3a3a;\">(Odoo appointment or Calendly)</span></label>\n326:       <input id=\"booking-url\" type=\"url\" placeholder=\"https://odoo.yourdomain.com/web#action=appointment\" style=\"width:100%;background:#080808;border:1px solid #242424;border-radius:4px;padding:11px 13px;font-family:'JetBrains Mono',monospace;font-size:12px;color:#fff;outline:none;box-sizing:border-box;transition:border-color 0.15s,box-shadow 0.15s;\" onfocus=\"this.style.borderColor='#39FF14';this.style.boxShadow='0 0 6px #39FF14,0 0 12px rgba(57,255,20,0.25)'\" onblur=\"this.style.borderColor='#242424';this.style.boxShadow='none'\">\n327:     </div>\n328:     <button onclick=\"bookingSave()\" style=\"font-family:'Exo 2',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#080808;background:#39FF14;border:none;border-radius:4px;padding:11px 22px;cursor:pointer;box-shadow:0 0 8px #39FF14,0 0 20px rgba(57,255,20,0.4);white-space:nowrap;transition:transform 0.15s;\" onmouseenter=\"this.style.transform='translateY(-1px)'\" onmouseleave=\"this.style.transform='none'\">Save &amp; Apply</button>\n329:     <div id=\"booking-result\" style=\"width:100%;font-family:'JetBrains Mono',monospace;font-size:12px;min-height:14px;\"></div>\n330:   </div>\n331: \n332:   <!-- ── LAUNCH WAITLIST ── -->\n333:   <div class=\"circuit-rule\" style=\"max-width:none; padding:0; margin:0 0 32px;\"><div class=\"circuit-line\"><div class=\"circuit-pulse\" style=\"animation-delay:-2.4s;\"></div></div></div>\n334:   <div class=\"section-head\">Launch Waitlist <span id=\"wl-count\" style=\"font-weight:400; color:#39FF14; text-shadow:0 0 6px rgba(57,255,20,0.5);\"></span></div>\n335:   <div style=\"background:#111; border:1px solid #242424; border-radius:8px; overflow:hidden; margin-bottom:20px; position:relative;\">\n336:     <div style=\"position:absolute;top:-1px;left:-1px;width:36px;height:36px;border-top:2px solid #39FF14;border-left:2px solid #39FF14;border-top-left-radius:8px;box-shadow:0 0 6px #39FF14,0 0 14px rgba(57,255,20,0.55);pointer-events:none;\"></div>\n337:     <div class=\"waitlist-scroll\" id=\"wl-scroll\">\n338:       <table class=\"waitlist-table\">\n339:         <thead>\n340:           <tr>\n341:             <th style=\"width:36px;\">#</th>\n342:             <th>Email</th>\n343:             <th>Date &amp; Time</th>\n344:           </tr>\n345:         </thead>\n346:         <tbody id=\"wl-body\"></tbody>\n347:       </table>\n348:       <div class=\"waitlist-empty\" id=\"wl-empty\" style=\"display:none;\">no signups yet — emails captured by the \"Notify Me at Launch\" form appear here.</div>\n349:     </div>\n350:   </div>\n351:   <div style=\"display:flex; gap:12px; flex-wrap:wrap; margin-bottom:56px; align-items:center;\">\n352:     <button onclick=\"exportWaitlistCSV()\" style=\"font-family:'Exo 2',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#080808;background:#39FF14;border:none;border-radius:4px;padding:11px 22px;cursor:pointer;box-shadow:0 0 8px #39FF14,0 0 20px rgba(57,255,20,0.4);transition:transform 0.15s;\" onmouseenter=\"this.style.transform='translateY(-1px)'\" onmouseleave=\"this.style.transform='none'\">↓ Export CSV</button>\n353:     <button onclick=\"copyWaitlistEmails()\" style=\"font-family:'Exo 2',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#C8C8C8;background:transparent;border:1px solid #242424;border-radius:4px;padding:10px 22px;cursor:pointer;transition:all 0.15s;\" onmouseenter=\"this.style.borderColor='#39FF14';this.style.color='#39FF14'\" onmouseleave=\"this.style.borderColor='#242424';this.style.color='#C8C8C8'\">Copy Emails</button>\n354:     <button onclick=\"refreshWaitlist()\" style=\"font-family:'Exo 2',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#C8C8C8;background:transparent;border:1px solid #242424;border-radius:4px;padding:10px 22px;cursor:pointer;transition:all 0.15s;\" onmouseenter=\"this.style.borderColor='#39FF14';this.style.color='#39FF14'\" onmouseleave=\"this.style.borderColor='#242424';this.style.color='#C8C8C8'\">⟳ Refresh</button>\n355:     <div style=\"flex:1;\"></div>\n356:     <button onclick=\"clearWaitlist()\" style=\"font-family:'Exo 2',sans-serif;font-weight:700;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#787878;background:transparent;border:1px solid #242424;border-radius:4px;padding:10px 18px;cursor:pointer;transition:all 0.15s;\" onmouseenter=\"this.style.borderColor='#ff5555';this.style.color='#ff5555'\" onmouseleave=\"this.style.borderColor='#242424';this.style.color='#787878'\">Clear All</button>\n357:   </div>\n358: \n359:   <!-- ── USAGE GUIDE ── -->\n360:   <div style=\"margin-top:56px; padding:28px 32px; background:#111; border:1px solid #242424; border-radius:8px; position:relative;\">\n361:     <div style=\"position:absolute; top:-1px; left:-1px; width:40px; height:40px; border-top:2px solid #39FF14; border-left:2px solid #39FF14; border-top-left-radius:8px; box-shadow:0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55);\"></div>\n362:     <div style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#39FF14; text-shadow:0 0 6px rgba(57,255,20,0.5); margin-bottom:14px;\">Quick Reference</div>\n363:     <div style=\"display:grid; grid-template-columns:repeat(auto-fill, minmax(240px, 1fr)); gap:16px;\">\n364:       <div>\n365:         <div style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:13px; color:#fff; margin-bottom:6px;\">Brand Name</div>\n366:         <div style=\"font-family:'JetBrains Mono',monospace; font-size:12px; line-height:1.7; color:#C8C8C8;\">ANDIE → white, wt 900<br>KOBBIE → #39FF14, wt 900<br>TECH. → white, wt 900<br>Trailing period is part of mark</div>\n367:       </div>\n368:       <div>\n369:         <div style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:13px; color:#fff; margin-bottom:6px;\">Logo Minimum Sizes</div>\n370:         <div style=\"font-family:'JetBrains Mono',monospace; font-size:12px; line-height:1.7; color:#C8C8C8;\">Full logo: 120px wide min<br>AK Mark: 32px high min<br>Always on dark surfaces<br>Min bg: #191919</div>\n371:       </div>\n372:       <div>\n373:         <div style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:13px; color:#fff; margin-bottom:6px;\">Green Usage Rules</div>\n374:         <div style=\"font-family:'JetBrains Mono',monospace; font-size:12px; line-height:1.7; color:#C8C8C8;\">CTAs, active states, icons<br>Never as background fill<br>Always carries glow shadow<br>WCAG AA: 10.6:1 on dark</div>\n375:       </div>\n376:     </div>\n377:   </div>\n378: \n379: </div>\n380: \n381: <!-- TOAST -->\n382: <div class=\"toast\" id=\"toast\"></div>\n383: \n384: <script>\n385:   // ── SESSION & AUTH ──\n386:   function adminLogout() {\n387:     sessionStorage.removeItem('ak_ses');\n388:     window.location.replace('/');\n389:   }\n390: \n391:   // ── TOAST ──\n392:   function toast(msg, ok) {\n393:     const el = document.getElementById('toast');\n394:     el.textContent = msg;\n395:     el.style.color = ok === false ? '#ff5555' : '#39FF14';\n396:     el.style.borderColor = ok === false ? 'rgba(255,85,85,0.4)' : 'rgba(57,255,20,0.4)';\n397:     el.classList.add('show');\n398:     setTimeout(() => el.classList.remove('show'), 2800);\n399:   }\n400: \n401:   // ── PALETTE ──\n402:   const PALETTE = {\n403:     \"primary\": \"#39FF14\", \"primary-dim\": \"#1FCC00\",\n404:     \"primary-mute\": \"rgba(57,255,20,0.12)\", \"secondary\": \"#FFFFFF\",\n405:     \"neutral\": \"#080808\", \"surface-1\": \"#111111\", \"surface-2\": \"#191919\",\n406:     \"border\": \"#242424\", \"text-hi\": \"#C8C8C8\", \"text-mid\": \"#787878\", \"text-lo\": \"#3A3A3A\"\n407:   };\n408: \n409:   function copyPalette() {\n410:     navigator.clipboard.writeText(JSON.stringify(PALETTE, null, 2))\n411:       .then(() => toast('Palette JSON copied to clipboard'))\n412:       .catch(() => toast('Copy failed — try manually'));\n413:   }\n414: \n415:   function downloadGFont(spec, name) {\n416:     const url = `https://fonts.google.com/download?family=${encodeURIComponent(spec.replace(/\\+/g,' ').split(':')[0])}`;\n417:     const a = document.createElement('a');\n418:     a.href = url; a.target = '_blank'; a.rel = 'noopener';\n419:     document.body.appendChild(a); a.click(); document.body.removeChild(a);\n420:     toast(`Opening ${name} download page…`);\n421:   }\n422: \n423:   // ── ODOO CONFIG ──\n424:   function odooLoad() {\n425:     try { return JSON.parse(localStorage.getItem('ak_odoo') || '{}'); } catch { return {}; }\n426:   }\n427: \n428:   function odooSave() {\n429:     const cfg = {\n430:       url:  document.getElementById('odoo-url').value.trim().replace(/\\/$/, ''),\n431:       db:   document.getElementById('odoo-db').value.trim(),\n432:       user: document.getElementById('odoo-user').value.trim(),\n433:       key:  document.getElementById('odoo-key').value.trim(),\n434:     };\n435:     if (!cfg.url) { setOdooResult('Enter the Odoo URL first', false); return; }\n436:     localStorage.setItem('ak_odoo', JSON.stringify(cfg));\n437:     toast('Odoo config saved');\n438:     setOdooResult('Config saved — test the connection below', true);\n439:     updateOdooStatusDot(false); // dot stays grey until tested\n440:   }\n441: \n442:   function setOdooResult(msg, ok) {\n443:     const el = document.getElementById('odoo-result');\n444:     el.textContent = msg;\n445:     el.style.color = ok ? '#39FF14' : '#ff5555';\n446:   }\n447: \n448:   async function odooTest() {\n449:     const cfg = odooLoad();\n450:     if (!cfg.url || !cfg.db || !cfg.user || !cfg.key) {\n451:       setOdooResult('Save config first — all fields required', false); return;\n452:     }\n453:     setOdooResult('Testing connection…', true);\n454:     try {\n455:       const res = await fetch(`${cfg.url}/web/dataset/call_kw`, {\n456:         method: 'POST',\n457:         headers: { 'Content-Type': 'application/json' },\n458:         body: JSON.stringify({\n459:           jsonrpc: '2.0', method: 'call', id: 1,\n460:           params: {\n461:             model: 'res.users', method: 'search_read',\n462:             args: [[['login', '=', cfg.user]]],\n463:             kwargs: { fields: ['name'], limit: 1, context: {} }\n464:           }\n465:         }),\n466:         credentials: 'include',\n467:       });\n468:       // For API key auth we use basic auth header instead\n469:       const res2 = await fetch(`${cfg.url}/web/session/get_session_info`, {\n470:         method: 'POST',\n471:         headers: {\n472:           'Content-Type': 'application/json',\n473:           'Authorization': 'Basic ' + btoa(cfg.user + ':' + cfg.key),\n474:         },\n475:         body: JSON.stringify({ jsonrpc: '2.0', method: 'call', id: 1, params: {} }),\n476:       });\n477:       if (res2.ok) {\n478:         setOdooResult('✓ Connection successful', true);\n479:         updateOdooStatusDot(true);\n480:         toast('Odoo connected');\n481:       } else {\n482:         throw new Error('HTTP ' + res2.status);\n483:       }\n484:     } catch (e) {\n485:       // CORS errors look like network failures — still means Odoo responded\n486:       if (e.message === 'Failed to fetch') {\n487:         setOdooResult('CORS blocked — Odoo reached but needs cors_headers=* in odoo.conf', false);\n488:         toast('CORS issue — see notes below', false);\n489:       } else {\n490:         setOdooResult('Connection failed: ' + e.message, false);\n491:         toast('Connection failed', false);\n492:       }\n493:       updateOdooStatusDot(false);\n494:     }\n495:   }\n496: \n497:   function updateOdooStatusDot(live) {\n498:     const dot = document.getElementById('odoo-ind');\n499:     const lbl = document.getElementById('odoo-status-label');\n500:     const cfg = odooLoad();\n501:     if (live) {\n502:       dot.className = 'odoo-dot live';\n503:       lbl.style.color = '#39FF14';\n504:       lbl.textContent = 'Odoo · connected';\n505:     } else if (cfg.url) {\n506:       dot.className = 'odoo-dot off';\n507:       lbl.style.co