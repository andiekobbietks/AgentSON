    {
      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\AKcloud\\\\akcloud-deploy\\\\admin.html\", \"newString\": \"  async function bookingSave() {\\n    const url = document.getElementById('booking-url').value.trim();\\n    if (!url) { document.getElementById('booking-result').textContent = 'Enter a URL'; return; }\\n    localStorage.setItem('ak_booking_url', url);\\n    const user = localStorage.getItem('ak_admin_user') || '';\\n    const pass = localStorage.getItem('ak_admin_pass') || '';\\n    if (user && pass) {\\n      try {\\n        const res = await fetch('/api/save-config', {\\n          method: 'POST',\\n          headers: {\\n            'Content-Type': 'application/json',\\n            'Authorization': 'Basic ' + btoa(user + ':' + pass),\\n          },\\n          body: JSON.stringify({ booking_url: url }),\\n        });\\n        const data = await res.json();\\n        if (data.ok) {\\n          document.getElementById('booking-result').style.color = '#39FF14';\\n          document.getElementById('booking-result').textContent = '\\u2713 Saved globally \\u2014 all visitors will get this URL';\\n          toast('Booking URL saved globally');\\n          return;\\n        }\\n      } catch {}\\n    }\\n    document.getElementById('booking-result').style.color = '#39FF14';\\n    document.getElementById('booking-result').textContent = '\\u2713 Saved locally \\u2014 deploy to make global';\\n    toast('Booking URL saved locally');\\n  }\", \"oldString\": \"  function bookingSave() {\\n    const url = document.getElementById('booking-url').value.trim();\\n    if (!url) { document.getElementById('booking-result').textContent = 'Enter a URL'; return; }\\n    localStorage.setItem('ak_booking_url', url);\\n    document.getElementById('booking-result').style.color = '#39FF14';\\n    document.getElementById('booking-result').textContent = '\\u2713 Saved \\u2014 \\\"Book a Consultation\\\" now opens this URL';\\n    toast('Booking URL saved');\\n  }\"}",
