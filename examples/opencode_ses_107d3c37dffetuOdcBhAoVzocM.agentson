      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\AKcloud\\\\akcloud-deploy\\\\index.html\", \"newString\": \"  </div>\\n</section>\\n\\n<!-- CIRCUIT RULE -->\\n<div class=\\\"circuit-rule\\\"><div class=\\\"circuit-line\\\"><div class=\\\"circuit-pulse\\\" style=\\\"animation-delay:-3.0s;\\\"></div></div></div>\\n\\n<!-- EDUCATIONAL MATERIAL -->\\n<section id=\\\"edu\\\" style=\\\"position:relative; z-index:1; max-width:1180px; margin:0 auto; box-sizing:border-box; padding:96px 40px; scroll-margin-top:88px;\\\">\\n  <div class=\\\"section-eyebrow\\\">Educational Material</div>\\n  <h2 class=\\\"section-h2\\\" style=\\\"max-width:760px;\\\">Technical cheat sheets for founders and engineers who build.</h2>\\n  <p class=\\\"section-p\\\" style=\\\"max-width:680px;\\\">One-page references for the tools you actually use daily. No fluff, no tutorials \\u2014 just the commands, syntax and patterns you need to look up mid-build.</p>\\n  <div class=\\\"grid-3\\\" style=\\\"margin-top:48px;\\\">\\n    <div class=\\\"card\\\" style=\\\"cursor:pointer;\\\">\\n      <div style=\\\"font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:#39FF14; text-shadow:0 0 6px rgba(57,255,20,0.5); margin-bottom:16px;\\\">&gt; n8n</div>\\n      <h3 style=\\\"margin:0; font-family:'Exo 2',sans-serif; font-weight:600; font-size:19px; color:#fff;\\\">Workflow Automation</h3>\\n      <p style=\\\"margin:12px 0 0; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#C8C8C8;\\\">Triggers, nodes, expressions, Docker self-hosting, AI agents, error handling. From first workflow to production.</p>\\n    </div>\\n    <div class=\\\"card\\\" style=\\\"cursor:pointer;\\\">\\n      <div style=\\\"font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:#39FF14; text-shadow:0 0 6px rgba(57,255,20,0.5); margin-bottom:16px;\\\">&gt; odoo</div>\\n      <h3 style=\\\"margin:0; font-family:'Exo 2',sans-serif; fon