ay: flex; align-items: center; justify-content: space-between; padding: 0 40px; background: rgba(8,8,8,0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid #242424; }\n28:   .nav-logo { display: flex; align-items: center; text-decoration: none; }\n29:   .nav-logo img { height: 40px; width: auto; display: block; filter: drop-shadow(0 0 8px rgba(80,200,70,0.35)); }\n30:   .nav-links { display: flex; align-items: center; gap: 30px; }\n31:   .nav-link { text-decoration: none; font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 11.5px; letter-spacing: 0.12em; text-transform: uppercase; color: #C8C8C8; transition: color 0.15s; }\n32:   .nav-link:hover { color: #39FF14; }\n33:   .btn-ghost { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 11.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #fff; background: transparent; border: 1px solid #242424; border-radius: 4px; padding: 9px 18px; cursor: pointer; transition: all 0.15s; }\n34:   .btn-ghost:hover { color: #39FF14; border-color: #39FF14; box-shadow: inset 0 0 0 1px #39FF14, 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); }\n35:   .btn-primary { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 11.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #080808; background: #39FF14; border: none; border-radius: 4px; padding: 10px 18px; cursor: pointer; box-shadow: 0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.5), 0 0 48px rgba(57,255,20,0.25); transition: transform 0.15s, box-shadow 0.15s; }\n36:   .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 0 12px #39FF14, 0 0 32px rgba(57,255,20,0.55), 0 0 72px rgba(57,255,20,0.28), 0 0 120px rgba(57,255,20,0.12); }\n37:   .btn-primary-lg { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: #080808; background: #39FF14; border: none; border-radius: 4px; padding: 15px 30px; cursor: pointer; box-shadow: 0 0 12px #39FF14, 0 0 32px rgba(57,255,20,0.55), 0 0 72px rgba(57,255,20,0.28), 0 0 120px rgba(57,255,20,0.12); transition: transform 0.15s; }\n38:   .btn-primary-lg:hover { transform: translateY(-1px); }\n39:   .btn-ghost-lg { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: #fff; background: transparent; border: 1px solid #242424; border-radius: 4px; padding: 14px 29px; cursor: pointer; transition: all 0.15s; }\n40:   .btn-ghost-lg:hover { color: #39FF14; border-color: #39FF14; box-shadow: inset 0 0 0 1px #39FF14, 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); }\n41: \n42:   /* CIRCUIT RULE */\n43:   .circuit-rule { position: relative; z-index: 1; max-width: 1180px; margin: 0 auto; padding: 0 40px; }\n44:   .circuit-line { position: relative; height: 1px; width: 100%; background: #242424; overflow: hidden; }\n45:   .circuit-pulse { position: absolute; top: 0; left: 0; height: 100%; width: 14%; background: linear-gradient(90deg, transparent, #39FF14, transparent); box-shadow: 0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.5); animation: akTrace 4s linear infinite; }\n46: \n47:   /* SERVICE CARD corner accent */\n48:   .card { position: relative; background: #111; border: 1px solid #242424; border-radius: 8px; padding: 30px; transition: border-color 0.2s, box-shadow 0.2s; }\n49:   .card::before { content: ''; position: absolute; top: -1px; left: -1px; width: 38px; height: 38px; border-top: 2px solid #39FF14; border-left: 2px solid #39FF14; border-top-left-radius: 8px; box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); transition: width 0.2s, height 0.2s, box-shadow 0.2s; }\n50:   .card:hover { border-color: rgba(57,255,20,0.30); box-shadow: 0 0 0 1px rgba(57,255,20,0.15), 0 8px 32px rgba(0,0,0,0.40); }\n51:   .card:hover::before { width: 80px; height: 80px; box-shadow: 0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.50), 0 0 48px rgba(57,255,20,0.25); }\n52:   .card-outcome { position: relative; background: #111; border: 1px solid #242424; border-radius: 8px; padding: 32px; transition: border-color 0.2s, box-shadow 0.2s; }\n53:   .card-outcome::before { content: ''; position: absolute; top: -1px; left: -1px; width: 38px; height: 38px; border-top: 2px solid #39FF14; border-left: 2px solid #39FF14; border-top-left-radius: 8px; box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); transition: width 0.2s, height 0.2s, box-shadow 0.2s; }\n54:   .card-outcome:hover { border-color: rgba(57,255,20,0.30); box-shadow: 0 0 0 1px rgba(57,255,20,0.15), 0 8px 32px rgba(0,0,0,0.40); }\n55:   .card-outcome:hover::before { width: 80px; height: 80px; box-shadow: 0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.50), 0 0 48px rgba(57,255,20,0.25); }\n56: \n57:   /* PERK CARD */\n58:   .perk-card { display: flex; gap: 14px; background: #111; border: 1px solid #242424; border-radius: 8px; padding: 24px; transition: border-color 0.2s; }\n59:   .perk-card:hover { border-color: rgba(57,255,20,0.20); }\n60:   .perk-dot { flex: none; width: 8px; height: 8px; margin-top: 7px; border-radius: 50%; background: #39FF14; box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); }\n61: \n62:   /* TERM underline */\n63:   .term { color: inherit; border-bottom: 1px dashed rgba(57,255,20,0.6); cursor: help; transition: color 0.15s; }\n64:   .term:hover { color: #39FF14; }\n65: \n66:   /* TOOLTIP */\n67:   #tip-box { position: fixed; z-index: 200; pointer-events: none; animation: akFade 0.14s ease; display: none; }\n68:   #tip-box.visible { display: block; }\n69:   .tip-inner { position: relative; background: #191919; border: 1px solid rgba(57,255,20,0.32); border-radius: 8px; padding: 14px 16px; box-shadow: 0 0 0 1px rgba(57,255,20,0.08), 0 12px 34px rgba(0,0,0,0.65); width: 272px; }\n70:   .tip-title { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; color: #39FF14; text-shadow: 0 0 6px rgba(57,255,20,0.5); margin-bottom: 7px; }\n71:   .tip-body { font-family: 'DM Sans', sans-serif; font-size: 13.5px; line-height: 1.5; color: #C8C8C8; }\n72:   .tip-arrow { position: absolute; left: 50%; bottom: -5px; width: 9px; height: 9px; transform: translateX(-50%) rotate(45deg); background: #191919; border-right: 1px solid rgba(57,255,20,0.32); border-bottom: 1px solid rgba(57,255,20,0.32); }\n73: \n74:   /* BOOKING MODAL */\n75:   #book-overlay { position: fixed; inset: 0; z-index: 100; display: none; align-items: center; justify-content: center; padding: 24px; background: rgba(8,8,8,0.84); backdrop-filter: blur(6px); }\n76:   #book-overlay.visible { display: flex; }\n77:   .book-modal { position: relative; width: 100%; max-width: 460px; background: #111; border: 1px solid #242424; border-radius: 8px; padding: 38px 36px; animation: akFade 0.18s ease; }\n78:   .book-modal::before { content: ''; position: absolute; top: -1px; left: -1px; width: 48px; height: 48px; border-top: 2px solid #39FF14; border-left: 2px solid #39FF14; border-top-left-radius: 8px; box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); }\n79:   #book-notify-msg { margin-top: 14px; font-family: 'JetBrains Mono', monospace; font-size: 12px; text-align: center; min-height: 18px; display: none; }\n80:   #book-notify-msg.visible { display: block; }\n81: \n82:   /* LOGIN MODAL */\n83:   #login-overlay { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; padding: 24px; background: rgba(8,8,8,0.82); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); animation: akFadeIn 0.18s ease; display: none; }\n84:   #login-overlay.visible { display: flex; }\n85:   .login-modal { position: relative; width: 100%; max-width: 420px; background: #111; border: 1px solid #242424; border-radius: 8px; padding: 38px 36px; }\n86:   .login-modal::before { content: ''; position: absolute; top: -1px; left: -1px; width: 48px; height: 48px; border-top: 2px solid #39FF14; border-left: 2px solid #39FF14; border-top-left-radius: 8px; box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); }\n87:   .modal-close { position: absolute; top: 16px; right: 16px; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; background: transparent; border: 1px solid #242424; border-radius: 4px; color: #787878; font-size: 15px; cursor: pointer; line-height: 1; transition: all 0.15s; }\n88:   .modal-close:hover { color: #39FF14; border-color: #39FF14; }\n89:   .form-label { display: block; font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #787878; margin-bottom: 8px; }\n90:   .form-input { width: 100%; background: #080808; border: 1px solid #242424; border-radius: 4px; padding: 13px 14px; font-family: 'DM Sans', sans-serif; font-size: 15px; color: #fff; outline: none; transition: all 0.15s; margin-bottom: 18px; }\n91:   .form-input:focus { border-color: #39FF14; box-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.4); }\n92:   .btn-sign-in { width: 100%; font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: #080808; background: #39FF14; border: none; border-radius: 4px; padding: 15px 0; cursor: pointer; box-shadow: 0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.5), 0 0 48px rgba(57,255,20,0.25); transition: transform 0.15s; }\n93:   .btn-sign-in:hover { transform: translateY(-1px); }\n94:   #auth-msg { margin-top: 16px; text-align: center; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #39FF14; text-shadow: 0 0 6px rgba(57,255,20,0.4); display: none; }\n95:   #auth-msg.visible { display: block; }\n96: \n97:   /* SECTIONS */\n98:   .section-inner { max-width: 1180px; margin: 0 auto; padding: 0 40px; }\n99:   .section-eyebrow { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: #39FF14; text-shadow: 0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); margin-bottom: 18px; }\n100:   .section-h2 { margin: 0; font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 42px; line-height: 1.12; color: #fff; text-wrap: pretty; }\n101:   .section-p { margin: 22px 0 0; font-family: 'DM Sans', sans-serif; font-size: 18px; line-height: 1.6; color: #C8C8C8; text-wrap: pretty; }\n102:   .grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 48px; }\n103: \n104:   /* COUNTDOWN */\n105:   .countdown-unit { flex: 1; text-align: center; background: #111; border: 1px solid #242424; border-radius: 4px; padding: 20px 0; }\n106:   .countdown-num { font-family: 'Exo 2', sans-serif; font-weight: 900; font-size: 48px; line-height: 1; color: #39FF14; text-shadow: 0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.5), 0 0 48px rgba(57,255,20,0.25); }\n107:   .countdown-label { font-family: 'Exo 2', sans-serif; font-weight: 700; font-size: 10px; letter-spacing: 0.1em; color: #787878; margin-top: 9px; }\n108: \n109:   /* STATUS BAR */\n110:   .status-bar { position: relative; height: 3px; border-radius: 2px; background: #191919; overflow: hidden; }\n111:   .status-shimmer { position: absolute; inset: 0; background: linear-gradient(90deg, transparent, #39FF14, transparent); background-size: 160px 100%; box-shadow: 0 0 8px rgba(57,255,20,0.6); animation: akShimmer 1.8s linear infinite; }\n112:   .status-shimmer-slow { position: absolute; inset: 0; background: linear-gradient(90deg, transparent, #39FF14, transparent); background-size: 160px 100%; box-shadow: 0 0 8px rgba(57,255,20,0.6); animation: akShimmer 2.3s linear infinite; }\n113: \n114:   @media (max-width: 768px) {\n115:     nav { padding: 0 20px; }\n116:     .nav-links { gap: 12px; }\n117:     .nav-link { display: none; }\n118:     .nav-links .nav-link:last-of-type { display: none; }\n119:     .grid-3 { grid-template-columns: 1fr; }\n120:     .section-h2 { font-size: 28px; }\n121:     #hero h1 { font-size: 64px !important; }\n122:     .section-inner { padding: 0 20px; }\n123:   }\n124: \n125:   /* ── SPLASH ── */\n126:   #spx {\n127:     position: fixed; inset: 0; z-index: 9999;\n128:     display: flex; align-items: center; justify-content: center;\n129:     background: #080808; overflow: hidden;\n130:   }\n131:   #spx-grid {\n132:     position: absolute; inset: 0; pointer-events: none;\n133:     background-image: linear-gradient(rgba(57,255,20,0.03) 1px, transparent 1px),\n134:                       linear-gradient(90deg, rgba(57,255,20,0.03) 1px, transparent 1px);\n135:     background-size: 48px 48px;\n136:   }\n137:   #spx-radial {\n138:     position: absolute; inset: 0; pointer-events: none;\n139:     background: radial-gradient(ellipse 65% 60% at 50% 50%,\n140:       rgba(57,255,20,0.11) 0%, rgba(57,255,20,0.04) 45%, transparent 70%);\n141:     animation: spxRadialPulse 2.4s ease-in-out 0.52s 2 alternate;\n142:   }\n143:   #spx-ak {\n144:     position: absolute;\n145:     font-family: 'Exo 2', sans-serif; font-weight: 900;\n146:     font-size: clamp(130px, 35vmin, 340px);\n147:     line-height: 1; letter-spacing: -0.03em; color: #39FF14;\n148:     text-shadow:\n149:       0 0 24px #39FF14,\n150:       0 0 70px rgba(57,255,20,0.65),\n151:       0 0 140px rgba(57,255,20,0.38),\n152:       0 0 260px rgba(57,255,20,0.18);\n153:     animation: spxAK 3.1s cubic-bezier(0.4, 0, 0.2, 1) forwards;\n154:   }\n155:   #spx-logo {\n156:     position: absolute;\n157:     display: flex; flex-direction: column; align-items: center;\n158:     opacity: 0;\n159:     animation: spxLogo 2.4s cubic-bezier(0.4, 0, 0.2, 1) 2.6s forwards;\n160:   }\n161:   #spx-logo img {\n162:     width: min(440px, 74vw); height: auto;\n163:     filter:\n164:       drop-shadow(0 0 28px rgba(57,255,20,0.42))\n165:       drop-shadow(0 0 72px rgba(57,255,20,0.18));\n166:     image-rendering: -webkit-optimize-contrast;\n167:   }\n168:   #spx-tagline {\n169:     margin-top: 20px;\n170:     font-family: 'Exo 2', sans-serif; font-weight: 700;\n171:     font-size: clamp(10px, 2vw, 13px); letter-spacing: 0.32em;\n172:     text-transform: uppercase; color: #787878;\n173:     opacity: 0;\n174:     animation: spxTagline 1.2s ease 3.5s forwards;\n175:   }\n176: \n177:   @keyframes spxAK {\n178:     0%   { opacity: 0; transform: scale(0.7) translateY(20px); }\n179:     16%  { opacity: 1; transform: scale(1) translateY(0);\n180:            text-shadow: 0 0 24px #39FF14, 0 0 70px rgba(57,255,20,0.65),\n181:                         0 0 140px rgba(57,255,20,0.38), 0 0 260px rgba(57,255,20,0.18); }\n182:     42%  { opacity: 1; transform: scale(1.015) translateY(0);\n183:            text-shadow: 0 0 36px #39FF14, 0 0 100px rgba(57,255,20,0.78),\n184:                         0 0 200px rgba(57,255,20,0.52), 0 0 360px rgba(57,255,20,0.24); }\n185:     64%  { opacity: 1; transform: scale(1) translateY(0);\n186:            text-shadow: 0 0 24px #39FF14, 0 0 70px rgba(57,255,20,0.65),\n187:                         0 0 140px rgba(57,255,20,0.38), 0 0 260px rgba(57,255,20,0.18); }\n188:     88%  { opacity: 0; transform: scale(1.06) translateY(-12px); }\n189:     100% { opacity: 0; }\n190:   }\n191:   @keyframes spxRadialPulse {\n192:     from { opacity: 0.6; transform: scale(0.94); }\n193:     to   { opacity: 1;   transform: scale(1.06); }\n194:   }\n195:   @keyframes spxLogo {\n196:     0%   { opacity: 0; transform: scale(0.86) translateY(18px); }\n197:     30%  { opacity: 1; transform: scale(1) translateY(0); }\n198:     100% { opacity: 1; transform: scale(1) translateY(0); }\n199:   }\n200:   @keyframes spxTagline {\n201:     from { opacity: 0; transform: translateY(6px); }\n202:     to   { opacity: 1; transform: translateY(0); }\n203:   }\n204:   @keyframes spxExit {\n205:     0%   { opacity: 1; }\n206:     100% { opacity: 0; pointer-events: none; }\n207:   }\n208: </style>\n209: </head>\n210: <body>\n211: \n212: <!-- Hidden static forms for Netlify build-time detection -->\n213: <form name=\"notify\" data-netlify=\"true\" data-netlify-honeypot=\"bot-field\" hidden>\n214:   <input type=\"text\" name=\"bot-field\">\n215:   <input type=\"email\" name=\"email\">\n216:   <input type=\"text\" name=\"source\">\n217: </form>\n218: <form name=\"consultation\" data-netlify=\"true\" data-netlify-honeypot=\"bot-field\" hidden>\n219:   <input type=\"text\" name=\"bot-field\">\n220:   <input type=\"email\" name=\"email\">\n221:   <input type=\"text\" name=\"company\">\n222:   <input type=\"text\" name=\"topic\">\n223:   <input type=\"text\" name=\"source\">\n224: </form>\n225: \n226: <!-- SPLASH -->\n227: <div id=\"spx\">\n228:   <div id=\"spx-grid\"></div>\n229:   <div id=\"spx-radial\"></div>\n230:   <div id=\"spx-ak\">AK</div>\n231:   <div id=\"spx-logo\">\n232:     <img src=\"assets/ak-logo.png\"\n233:          srcset=\"assets/ak-logo@2x.png 2x, assets/ak-logo@4x.png 4x\"\n234:          alt=\"AndieKobbieTech Solutions\"\n235:          width=\"440\" height=\"264\">\n236:     <div id=\"spx-tagline\">AndieKobbieTech Solutions</div>\n237:   </div>\n238: </div>\n239: \n240: <!-- CIRCUIT BACKGROUND -->\n241: <div style=\"position:fixed; inset:0; pointer-events:none; background-image:linear-gradient(rgba(57,255,20,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(57,255,20,0.025) 1px, transparent 1px); background-size:48px 48px; z-index:0;\"></div>\n242: \n243: <!-- NAV -->\n244: <nav>\n245:   <a href=\"#top\" class=\"nav-logo\"><img src=\"assets/ak-mark2.png\" srcset=\"assets/ak-mark2@2x.png 2x, assets/ak-mark2@4x.png 4x\" alt=\"AndieKobbieTech\" width=\"80\" height=\"40\" style=\"image-rendering:-webkit-optimize-contrast;\"></a>\n246:   <div class=\"nav-links\">\n247:     <a href=\"#about\" class=\"nav-link\">The Alternative</a>\n248:     <a href=\"#credits\" class=\"nav-link\">Cloud Credits</a>\n249:     <a href=\"#perks\" class=\"nav-link\">Perks</a>\n250:     <a href=\"#stories\" class=\"nav-link\">Outcomes</a>\n251:     <button class=\"btn-primary\" onclick=\"openBooking()\">Book a Consultation</button>\n252:   </div>\n253: </nav>\n254: \n255: <!-- HERO -->\n256: <section id=\"top\" style=\"position:relative; z-index:1; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:120px 40px 80px;\">\n257:   <div style=\"position:absolute; inset:0; background:radial-gradient(ellipse 55% 45% at 50% 42%, rgba(57,255,20,0.08), transparent 70%); pointer-events:none;\"></div>\n258:   <img id=\"hero-logo-tap\" src=\"assets/ak-logo.png\" srcset=\"assets/ak-logo@2x.png 2x, assets/ak-logo@4x.png 4x\" alt=\"AndieKobbieTech\" width=\"150\" height=\"90\" style=\"position:relative; width:150px; height:auto; margin-bottom:30px; filter:drop-shadow(0 0 16px rgba(80,200,70,0.42)); image-rendering:-webkit-optimize-contrast;\">\n259:   <div style=\"position:relative; display:inline-flex; align-items:center; gap:8px; font-family:'Exo 2',sans-serif; font-weight:700; font-size:12px; letter-spacing:0.2em; text-transform:uppercase; color:#39FF14; text-shadow:0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); margin-bottom:26px;\">\n260:     <span style=\"width:7px; height:7px; border-radius:50%; background:#39FF14; box-shadow:0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); animation:akNode 2.4s ease-in-out infinite;\"></span>\n261:     Coming Soon\n262:   </div>\n263:   <h1 id=\"hero\" style=\"position:relative; margin:0; font-family:'Exo 2',sans-serif; font-weight:900; font-size:112px; line-height:0.96; letter-spacing:0.01em;\">\n264:     <span style=\"color:#39FF14; text-shadow:0 0 12px #39FF14, 0 0 32px rgba(57,255,20,0.55), 0 0 72px rgba(57,255,20,0.28), 0 0 120px rgba(57,255,20,0.12);\">AK</span><span style=\"color:#fff;\">Cloud</span>\n265:   </h1>\n266:   <p style=\"position:relative; margin:32px auto 0; max-width:680px; font-family:'DM Sans',sans-serif; font-size:20px; line-height:1.55; color:#C8C8C8; text-wrap:pretty;\">\n267:     Your <span class=\"term\" data-term=\"sovereign\">sovereign</span> cloud <span class=\"term\" data-term=\"msp\">MSP</span>. Fully UK compliant today, EU next. The smarter alternative to expensive <span class=\"term\" data-term=\"hyperscaler\">hyperscalers</span>, built on their distribution and <span class=\"term\" data-term=\"compute\">compute</span>, with <span class=\"term\" data-term=\"byoc\">bring your own cloud</span> and <span class=\"term\" data-term=\"byod\">bring your own device</span>.\n268:   </p>\n269: \n270:   <!-- COUNTDOWN -->\n271:   <div style=\"position:relative; margin-top:46px; width:100%; max-width:560px;\">\n272:     <div style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:#787878; margin-bottom:16px;\">Estimated Launch, T Minus</div>\n273:     <div style=\"display:flex; gap:12px;\">\n274:       <div class=\"countdown-unit\"><div class=\"countdown-num\" id=\"cd-dd\">00</div><div class=\"countdown-label\">DAYS</div></div>\n275:       <div class=\"countdown-unit\"><div class=\"countdown-num\" id=\"cd-hh\">00</div><div class=\"countdown-label\">HOURS</div></div>\n276:       <div class=\"countdown-unit\"><div class=\"countdown-num\" id=\"cd-mm\">00</div><div class=\"countdown-label\">MINS</div></div>\n277:       <div class=\"countdown-unit\"><div class=\"countdown-num\" id=\"cd-ss\">00</div><div class=\"countdown-label\">SECS</div></div>\n278:     </div>\n279:   </div>\n280: \n281:   <div style=\"position:relative; display:flex; gap:14px; margin-top:40px; flex-wrap:wrap; justify-content:center;\">\n282:     <button class=\"btn-primary-lg\" onclick=\"openBooking()\">Book a Consultation</button>\n283:   </div>\n284:   <div style=\"position:relative; margin-top:30px; font-family:'JetBrains Mono',monospace; font-size:12.5px; color:#787878; letter-spacing:0.04em;\">powered by ANDIEKOBBIETECH<span style=\"color:#39FF14;\">.</span></div>\n285: </section>\n286: \n287: <!-- CIRCUIT RULE -->\n288: <div class=\"circuit-rule\"><div class=\"circuit-line\"><div class=\"circuit-pulse\"></div></div></div>\n289: \n290: <!-- THE ALTERNATIVE -->\n291: <section id=\"about\" style=\"position:relative; z-index:1; max-width:1180px; margin:0 auto; box-sizing:border-box; padding:96px 40px; scroll-margin-top:88px;\">\n292:   <div class=\"section-eyebrow\">The Sovereign Alternative</div>\n293:   <h2 class=\"section-h2\" style=\"max-width:780px;\">Hyperscaler power. Sovereign control. Without the hyperscaler invoice.</h2>\n294:   <p class=\"section-p\" style=\"max-width:680px;\">AKCloud is a <span class=\"term\" data-term=\"msp\">managed service provider</span> for founders and organisations that want the reach of Azure, AWS and GCP without the runaway bills or the loss of data <span class=\"term\" data-term=\"sovereign\">sovereignty</span>. We run your infrastructure on UK regions, govern it to compliance standards, and let you keep your own cloud accounts and your own devices.</p>\n295:   <div class=\"grid-3\">\n296:     <div class=\"card\">\n297:       <h3 style=\"margin:0; font-family:'Exo 2',sans-serif; font-weight:600; font-size:19px; color:#fff;\">Sovereign by default</h3>\n298:       <p style=\"margin:12px 0 0; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#C8C8C8;\">Your data stays in UK regions. Fully UK compliant today, with EU residency arriving next. Governance and audit trails built in, not bolted on.</p>\n299:     </div>\n300:     <div class=\"card\">\n301:       <h3 style=\"margin:0; font-family:'Exo 2',sans-serif; font-weight:600; font-size:19px; color:#fff;\">Hyperscaler distribution</h3>\n302:       <p style=\"margin:12px 0 0; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#C8C8C8;\">We <span class=\"term\" data-term=\"leverage\">leverage</span> the distribution and raw <span class=\"term\" data-term=\"compute\">compute</span> of Azure, AWS and GCP at managed rates, so you get their scale and tooling without paying their full retail price.</p>\n303:     </div>\n304:     <div class=\"card\">\n305:       <h3 style=\"margin:0; font-family:'Exo 2',sans-serif; font-weight:600; font-size:19px; color:#fff;\"><span class=\"term\" data-term=\"byoc\">BYOC</span> and <span class=\"term\" data-term=\"byod\">BYOD</span></h3>\n306:       <p style=\"margin:12px 0 0; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#C8C8C8;\">Bring your own cloud and bring your own device. Keep your accounts, credits and hardware. We provide the architecture, security and day to day management on top.</p>\n307:     </div>\n308:   </div>\n309: </section>\n310: \n311: <!-- CIRCUIT RULE -->\n312: <div class=\"circuit-rule\"><div class=\"circuit-line\"><div class=\"circuit-pulse\" style=\"animation-delay: -1.5s;\"></div></div></div>\n313: \n314: <!-- CLOUD CREDITS -->\n315: <section id=\"credits\" style=\"position:relative; z-index:1; box-sizing:border-box; padding:96px 0; background:#0c0c0c; border-top:1px solid #242424; border-bottom:1px solid #242424; scroll-margin-top:88px;\">\n316:   <div class=\"section-inner\">\n317:     <div class=\"section-eyebrow\">What Are Cloud Credits</div>\n318:     <h2 class=\"section-h2\" style=\"max-width:820px;\">Free infrastructure funding the hyperscalers hand to startups. Most founders never claim it.</h2>\n319:     <p class=\"section-p\" style=\"max-width:720px;\"><span class=\"term\" data-term=\"credits\">Cloud credits</span> are grants of <span class=\"term\" data-term=\"compute\">compute</span>, storage and AI capacity, often worth one thousand to one hundred and fifty thousand dollars or more, that Microsoft, AWS and Google give to early stage companies. They let you run servers, databases and GPU workloads for free instead of burning your runway on infrastructure. AKCloud gets you qualified, approved at the highest tier, and builds <span class=\"term\" data-term=\"production\">production</span> systems that run on those credits.</p>\n320:     <div class=\"grid-3\">\n321:       <div style=\"background:#111; border:1px solid #242424; border-radius:8px; padding:30px;\">\n322:         <div style=\"font-family:'JetBrains Mono',monospace; font-size:12px; letter-spacing:0.08em; color:#39FF14; text-shadow:0 0 6px rgba(57,255,20,0.5); margin-bottom:16px;\">&gt; qualify</div>\n323:         <h3 style=\"margin:0; font-family:'Exo 2',sans-serif; font-weight:600; font-size:19px; color:#fff;\">Map the right programs</h3>\n324:         <p style=\"margin:12px 0 0; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#C8C8C8;\">We match you to Microsoft for Startups, AWS Activate, Google for Startups and F6S, and tell you exactly what each one wants to see to approve you, even pre incorporation.</p>\n325:       </div>\n326:       <div style=\"background:#111; border:1px solid #242424; border-radius:8px; padding:30px;\">\n327:         <div style=\"font-family:'JetBrains Mono',monospace; font-size:12px; letter-spacing:0.08em; color:#39FF14; text-shadow:0 0 6px rgba(57,255,20,0.5); margin-bottom:16px;\">&gt; claim</div>\n328:         <h3 style=\"margin:0; font-family:'Exo 2',sans-serif; font-weight:600; font-size:19px; color:#fff;\">Approved at the top tier</h3>\n329:         <p style=\"margin:12px 0 0; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#C8C8C8;\">We prepare your application and architecture narrative so you unlock the maximum credit tier, not the entry level grant most founders settle for.</p>\n330:       </div>\n331:       <div style=\"background:#111; border:1px solid #242424; border-radius:8px; padding:30px;\">\n332:         <div style=\"font-family:'JetBrains Mono',monospace; font-size:12px; letter-spacing:0.08em; color:#39FF14; text-shadow:0 0 6px rgba(57,255,20,0.5); margin-bottom:16px;\">&gt; build</div>\n333:         <h3 style=\"margin:0; font-family:'Exo 2',sans-serif; font-weight:600; font-size:19px; color:#fff;\">Run <span class=\"term\" data-term=\"production\">production</span> on credits</h3>\n334:         <p style=\"margin:12px 0 0; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#C8C8C8;\">We architect compliant, scalable infrastructure that runs on your credit balance, so you launch and grow with near zero cloud spend.</p>\n335:       </div>\n336:     </div>\n337:   </div>\n338: </section>\n339: \n340: <!-- PERKS -->\n341: <section id=\"perks\" style=\"position:relative; z-index:1; max-width:1180px; margin:0 auto; box-sizing:border-box; padding:96px 40px; scroll-margin-top:88px;\">\n342:   <div class=\"section-eyebrow\">Perks That Come With Credits</div>\n343:   <h2 class=\"section-h2\" style=\"max-width:760px;\">Credits are the entry point. The programs are where the real leverage is.</h2>\n344:   <div class=\"grid-3\" style=\"margin-top:48px;\">\n345:     <div class=\"perk-card\"><span class=\"perk-dot\"></span><div><div style=\"font-family:'Exo 2',sans-serif; font-weight:600; font-size:16px; color:#fff;\">Up to $150k in credits</div><div style=\"margin-top:6px; font-family:'DM Sans',sans-serif; font-size:14px; line-height:1.55; color:#787878;\">Across Azure, AWS and GCP, stacked where the programs allow.</div></div></div>\n346:     <div class=\"perk-card\"><span class=\"perk-dot\"></span><div><div style=\"font-family:'Exo 2',sans-serif; font-weight:600; font-size:16px; color:#fff;\"><span class=\"term\" data-term=\"architecture\">Architecture reviews</span></div><div style=\"margin-top:6px; font-family:'DM Sans',sans-serif; font-size:14px; line-height:1.55; color:#787878;\">Free technical support and design reviews from a Microsoft Solutions Partner.</div></div></div>\n347:     <div class=\"perk-card\"><span class=\"perk-dot\"></span><div><div style=\"font-family:'Exo 2',sans-serif; font-weight:600; font-size:16px; color:#fff;\">Investor and <span class=\"term\" data-term=\"f6s\">F6S</span> network</div><div style=\"margin-top:6px; font-family:'DM Sans',sans-serif; font-size:14px; line-height:1.55; color:#787878;\">Warm intros and accelerator access through partner ecosystems.</div></div></div>\n348:     <div class=\"perk-card\"><span class=\"perk-dot\"></span><div><div style=\"font-family:'Exo 2',sans-serif; font-weight:600; font-size:16px; color:#fff;\">Discounted tooling</div><div style=\"margin-top:6px; font-family:'DM Sans',sans-serif; font-size:14px; line-height:1.55; color:#787878;\">GitHub, OpenAI, <span class=\"term\" data-term=\"datastores\">datastores</span> and dev tools bundled into the programs.</div></div></div>\n349:     <div class=\"perk-card\"><span class=\"perk-dot\"></span><div><div style=\"font-family:'Exo 2',sans-serif; font-weight:600; font-size:16px; color:#fff;\">Co-sell and marketplace</div><div style=\"margin-top:6px; font-family:'DM Sans',sans-serif; font-size:14px; line-height:1.55; color:#787878;\">Get listed and co-sold through the hyperscaler marketplaces.</div></div></div>\n350:     <div class=\"perk-card\"><span class=\"perk-dot\"></span><div><div style=\"font-family:'Exo 2',sans-serif; font-weight:600; font-size:16px; color:#fff;\">Mentorship and go-to-market</div><div style=\"margin-top:6px; font-family:'DM Sans',sans-serif; font-size:14px; line-height:1.55; color:#787878;\">Structured guidance from founders who have shipped on the same rails.</div></div></div>\n351:   </div>\n352: </section>\n353: \n354: <!-- CIRCUIT RULE -->\n355: <div class=\"circuit-rule\"><div class=\"circuit-line\"><div class=\"circuit-pulse\" style=\"animation-delay: -2.2s;\"></div></div></div>\n356: \n357: <!-- OUTCOMES -->\n358: <section id=\"stories\" style=\"position:relative; z-index:1; box-sizing:border-box; padding:96px 0; background:#0c0c0c; border-top:1px solid #242424; border-bottom:1px solid #242424; scroll-margin-top:88px;\">\n359:   <div class=\"section-inner\">\n360:     <div style=\"display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:16px;\">\n361:       <div>\n362:         <div class=\"section-eyebrow\">Early Outcomes</div>\n363:         <h2 class=\"section-h2\" style=\"max-width:680px;\">What founders unlock when the credits land.</h2>\n364:       </div>\n365:       <span style=\"font-family:'JetBrains Mono',monospace; font-size:11px; color:#787878; letter-spacing:0.04em;\">representative scenarios, replace at launch</span>\n366:     </div>\n367:     <div class=\"grid-3\">\n368:       <div class=\"card-outcome\">\n369:         <div style=\"font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:#787878; margin-bottom:18px;\">case-01 // ai</div>\n370:         <div style=\"font-family:'Exo 2',sans-serif; font-weight:900; font-size:40px; line-height:1; color:#39FF14; text-shadow:0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.5), 0 0 48px rgba(57,255,20,0.25);\">12 mo</div>\n371:         <p style=\"margin:16px 0 0; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#C8C8C8;\">A pre-seed AI startup secured tier-two Azure credits and ran GPU inference for a year at zero infrastructure cost, shipping to first customers before raising.</p>\n372:       </div>\n373:       <div class=\"card-outcome\">\n374:         <div style=\"font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:#787878; margin-bottom:18px;\">case-02 // fintech</div>\n375:         <div style=\"font-family:'Exo 2',sans-serif; font-weight:900; font-size:40px; line-height:1; color:#39FF14; text-shadow:0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.5), 0 0 48px rgba(57,255,20,0.25);\">pre-inc</div>\n376:         <p style=\"margin:16px 0 0; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#C8C8C8;\">A fintech still pre-incorporation was mapped to AWS Activate and F6S, approved within weeks, and stood up a compliant payments stack on credits alone.</p>\n377:       </div>\n378:       <div class=\"card-outcome\">\n379:         <div style=\"font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:#787878; margin-bottom:18px;\">case-03 // public</div>\n380:         <div style=\"font-family:'Exo 2',sans-serif; font-weight:900; font-size:40px; line-height:1; color:#39FF14; text-shadow:0 0 8px #39FF14, 0 0 24px rgba(57,255,20,0.5), 0 0 48px rgba(57,255,20,0.25);\">-40%</div>\n381:         <p style=\"margin:16px 0 0; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#C8C8C8;\">A public sector pilot migrated off a costly hyperscaler contract onto a sovereign UK region, cutting annual cloud spend by roughly forty percent.</p>\n382:       </div>\n383:     </div>\n384:   </div>\n385: </section>\n386: \n387: <!-- FOOTER -->\n388: <footer style=\"position:relative; z-index:1; max-width:1180px; margin:0 auto; box-sizing:border-box; padding:64px 40px 56px;\">\n389:   <div style=\"display:flex; gap:14px; flex-wrap:wrap; margin-bottom:40px;\">\n390:     <div style=\"flex:1; min-width:240px; display:flex; flex-direction:column; gap:10px; padding:18px 20px; background:#111; border:1px solid #242424; border-radius:8px;\">\n391:       <div style=\"display:flex; align-items:center; justify-content:space-between;\"><span style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:13px; letter-spacing:0.04em; color:#C8C8C8;\">Microsoft Solutions Partner</span><span style=\"font-family:'JetBrains Mono',monospace; font-size:10.5px; color:#787878; letter-spacing:0.06em;\">VERIFYING</span></div>\n392:       <div class=\"status-bar\"><div class=\"status-shimmer\"></div></div>\n393:     </div>\n394:     <div style=\"flex:1; min-width:240px; display:flex; flex-direction:column; gap:10px; padding:18px 20px; background:#111; border:1px solid #242424; border-radius:8px;\">\n395:       <div style=\"display:flex; align-items:center; justify-content:space-between;\"><span style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:13px; letter-spacing:0.04em; color:#C8C8C8;\">F6S Program</span><span style=\"font-family:'JetBrains Mono',monospace; font-size:10.5px; color:#787878; letter-spacing:0.06em;\">EXPLORING</span></div>\n396:       <div class=\"status-bar\"><div class=\"status-shimmer-slow\"></div></div>\n397:     </div>\n398:     <div style=\"flex:1; min-width:240px; display:flex; flex-direction:column; gap:10px; padding:18px 20px; background:#111; border:1px solid #242424; border-radius:8px;\">\n399:       <div style=\"display:flex; align-items:center; justify-content:space-between;\"><span style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:13px; letter-spacing:0.04em; color:#C8C8C8;\">Compliance</span><span style=\"font-family:'JetBrains Mono',monospace; font-size:10.5px; color:#39FF14; text-shadow:0 0 6px rgba(57,255,20,0.5); letter-spacing:0.06em;\">UK LIVE</span></div>\n400:       <div style=\"font-family:'JetBrains Mono',monospace; font-size:12px; color:#787878;\">UK compliant &middot; EU soon &middot; ISO aligned</div>\n401:     </div>\n402:   </div>\n403:   <div style=\"height:1px; background:#242424; margin-bottom:28px;\"></div>\n404:   <div style=\"display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px;\">\n405:     <img src=\"assets/ak-logo.png\" srcset=\"assets/ak-logo@2x.png 2x, assets/ak-logo@4x.png 4x\" alt=\"AndieKobbieTech\" width=\"80\" height=\"48\" style=\"height:48px; width:auto; display:block; filter:drop-shadow(0 0 10px rgba(80,200,70,0.35)); image-rendering:-webkit-optimize-contrast;\">\n406:     <span style=\"font-family:'JetBrains Mono',monospace; font-size:11.5px; color:#787878; letter-spacing:0.04em;\">AKCloud is launching soon &middot; portal powered by Odoo</span>\n407:   </div>\n408: </footer>\n409: \n410: <!-- GLOSSARY TOOLTIP -->\n411: <div id=\"tip-box\">\n412:   <div class=\"tip-inner\">\n413:     <div class=\"tip-title\" id=\"tip-title\"></div>\n414:     <div class=\"tip-body\" id=\"tip-body\"></div>\n415:     <div class=\"tip-arrow\"></div>\n416:   </div>\n417: </div>\n418: \n419: <!-- BOOKING MODAL -->\n420: <div id=\"book-overlay\" onclick=\"closeBookingIfBackdrop(event)\">\n421:   <div class=\"book-modal\">\n422:     <button class=\"modal-close\" onclick=\"closeBooking()\">&times;</button>\n423:     <div style=\"display:flex; align-items:center; justify-content:center; margin-bottom:20px;\">\n424:       <img src=\"assets/ak-mark2.png\" srcset=\"assets/ak-mark2@2x.png 2x, assets/ak-mark2@4x.png 4x\" alt=\"AKCloud\" width=\"72\" height=\"36\" style=\"height:36px; width:auto; filter:drop-shadow(0 0 8px rgba(80,200,70,0.4)); image-rendering:-webkit-optimize-contrast;\">\n425:     </div>\n426:     <div style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#39FF14; text-shadow:0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); margin-bottom:12px;\">Book a Consultation</div>\n427:     <h3 style=\"margin:0 0 12px; font-family:'Exo 2',sans-serif; font-weight:700; font-size:24px; color:#fff; line-height:1.2;\">Let's talk cloud.</h3>\n428:     <p id=\"book-sub\" style=\"margin:0 0 26px; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.6; color:#787878;\">Our calendar opens at launch. Drop your email and we'll send you a booking link the moment we go live.</p>\n429:     <div id=\"book-form\">\n430:       <form name=\"notify\" method=\"POST\" data-netlify=\"true\" data-netlify-honeypot=\"bot-field\" onsubmit=\"return submitNotify(event)\">\n431:         <p class=\"hidden-visually\"><label>Don't fill this: <input name=\"bot-field\"></label></p>\n432:         <label class=\"form-label\">Your email</label>\n433:         <input type=\"email\" name=\"email\" placeholder=\"you@company.com\" class=\"form-input\" id=\"book-email\" required>\n434:         <input type=\"hidden\" name=\"source\" value=\"notify-me-launch\">\n435:         <button type=\"submit\" class=\"btn-sign-in\">Notify Me at Launch</button>\n436:       </form>\n437:     </div>\n438:     <div id=\"book-notify-msg\"></div>\n439:     <div style=\"margin-top:22px; padding-top:18px; border-top:1px solid #242424; text-align:center; font-family:'JetBrains Mono',monospace; font-size:11px; color:#787878; letter-spacing:0.03em;\">powered by ANDIEKOBBIETECH<span style=\"color:#39FF14;\">.</span> &middot; consultations via Odoo</div>\n440:   </div>\n441: </div>\n442: \n443: <!-- LOGIN MODAL -->\n444: <div id=\"login-overlay\" onclick=\"closeLoginIfBackdrop(event)\">\n445:   <div class=\"login-modal\" id=\"login-modal\">\n446:     <button class=\"modal-close\" onclick=\"closeLogin()\">&times;</button>\n447:     <div style=\"display:flex; align-items:center; justify-content:center; margin-bottom:20px;\">\n448:       <img src=\"assets/ak-mark2.png\" srcset=\"assets/ak-mark2@2x.png 2x, assets/ak-mark2@4x.png 4x\" alt=\"AndieKobbieTech\" width=\"72\" height=\"36\" style=\"height:36px; width:auto; filter:drop-shadow(0 0 8px rgba(80,200,70,0.4)); image-rendering:-webkit-optimize-contrast;\">\n449:     </div>\n450:     <div style=\"font-family:'Exo 2',sans-serif; font-weight:700; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#39FF14; text-shadow:0 0 6px #39FF14, 0 0 14px rgba(57,255,20,0.55); margin-bottom:12px;\">Client Portal</div>\n451:     <h3 style=\"margin:0 0 26px; font-family:'Exo 2',sans-serif; font-weight:700; font-size:26px; color:#fff;\">Sign in to <span style=\"color:#39FF14; text-shadow:0 0 8px rgba(57,255,20,0.5);\">AK</span>Cloud</h3>\n452:     <label class=\"form-label\">Email</label>\n453:     <input type=\"email\" placeholder=\"you@company.com\" class=\"form-input\" id=\"login-email\">\n454:     <label class=\"form-label\">Password</label>\n455:     <input type=\"password\" placeholder=\"••••••••\" class=\"form-input\" id=\"login-password\">\n456:     <button class=\"btn-sign-in\" onclick=\"signIn()\">Sign In</button>\n457:     <div id=\"auth-msg\"></div>\n458:     <div style=\"margin-top:22px; padding-top:18px; border-top:1px solid #242424; text-align:center; font-family:'JetBrains Mono',monospace; font-size:11px; color:#787878; letter-spacing:0.03em;\">secured by ANDIEKOBBIETECH<span style=\"color:#39FF14;\">.</span> &middot; portal powered by Odoo</div>\n459:   </div>\n460: </div>\n461: \n462: <script>\n463:   // ── SPLASH ──\n464:   (function(){\n465:     var spx = document.getElementById('spx');\n466:     if (!spx) return;\n467:     document.body.style.overflow = 'hidden';\n468:     // Start exit fade at 4.8s (logo has been fully visible since ~3.2s)\n469:     setTimeout(function(){\n470:       spx.style.animation = 'spxExit 0.9s ease forwards';\n471:     }, 4800);\n472:     // Remove from layout at 5.75s\n473:     setTimeout(function(){\n474:       spx.style.display = 'none';\n475:       document.body.style.overflow = '';\n476:     }, 5750);\n477:   })();\n478: \n479:   // ── COUNTDOWN ──\n480:   const LAUNCH_DAYS = 47;\n481:   const target = Date.now() + LAUNCH_DAYS * 24 * 3600 * 1000;\n482:   function pad(n) { return String(n).padStart(2, '0'); }\n483:   function tick() {\n484:     const s = Math.max(0, Math.floor((target - Date.now()) / 1000));\n485:     document.getElementById('cd-dd').textContent = pad(Math.floor(s / 86400));\n486:     document.getElementById('cd-hh').textContent = pad(Math.floor((s % 86400) / 3600));\n487:     document.getElementById('cd-mm').textContent = pad(Math.floor((s % 3600) / 60));\n488:     document.getElementById('cd-ss').textContent = pad(s % 60);\n489:   }\n490:   tick();\n491:   setInterval(tick, 1000);\n492: \n493:   // ── GLOSSARY ──\n494:   const GLOSSARY = {\n495:     msp: { t: \"MSP\", b: \"Managed Service Provider. A company that runs, secures and maintains your cloud and IT systems for you, so you do not need to hire an in-house infrastructure team.\" },\n496:     hyperscaler: { t: \"Hyperscaler\", b: \"The giant global cloud providers, Microsoft Azure, Amazon AWS and Google Cloud, that rent out computing power from enormous data centres.\" },\n497:     sovereign: { t: \"Sovereign cloud\", b: \"Your data and systems stay inside one country's borders and follow its laws. Here that means the UK, so nothing leaves UK jurisdiction.\" },\n498:     compute: { t: \"Compute\", b: \"Raw computing power: the processors and memory that actually run your apps, websites, databases and AI models.\" },\n499:     credits: { t: \"Cloud credits\", b: \"Free funding from the hyperscalers that you spend on their services instead of cash, often worth thousands to over a hundred thousand pounds for eligible startups.\" },\n500:     leverage: { t: \"Leverage\", b: \"To make full use of something you can already access, turning it into a real, measurable advantage.\" },\n501:     f6s: { t: \"F6S\", b: \"A global platform that connects startups with accelerators, grants, perks and investors. Pronounced eff-six-ess.\" },\n502:     production: { t: \"Production vs staging\", b: \"Production is the live system your real customers use. Staging is a private copy where changes are tested safely first, before they go live.\" },\n503:     architecture: { t: \"Architecture review\", b: \"An expert check of how your cloud system is designed, to catch security, cost and reliability problems before they cause damage.\" },\n504:     datastores: { t: \"Datastores\", b: \"Where an app keeps its information: the databases and storage that save and retrieve your records, files and data.\" },\n505:     byoc: { t: \"BYOC\", b: \"Bring Your Own Cloud. You keep your own cloud accounts and credits; we provide the architecture and management on top.\" },\n506:     byod: { t: \"BYOD\", b: \"Bring Your Own Device. Your team uses its own laptops and phones, secured and managed to company standards.\" },\n507:   };\n508: \n509:   const tipBox = document.getElementById('tip-box');\n510:   const tipTitle = document.getElementById('tip-title');\n511:   const tipBody = document.getElementById('tip-body');\n512:   let tipPinned = false;\n513:   let activeTerm = null;\n514: \n515:   function showTip(key, rect) {\n516:     const g = GLOSSARY[key];\n517:     if (!g) return;\n518:     activeTerm = key;\n519:     tipTitle.textContent = g.t;\n520:     tipBody.textContent = g.b;\n521:     const cx = rect.left + rect.width / 2;\n522:     const ty = rect.top + window.scrollY;\n523:     tipBox.style.left = cx + 'px';\n524:     tipBox.style.top = (rect.top + window.scrollY) + 'px';\n525:     tipBox.style.transform = 'translate(-50%, calc(-100% - 12px))';\n526:     tipBox.classList.add('visible');\n527:   }\n528: \n529:   function hideTip() {\n530:     if (!tipPinned) {\n531:       tipBox.classList.remove('visible');\n532:       activeTerm = null;\n533:     }\n534:   }\n535: \n536:   document.querySelectorAll('.term').forEach(el => {\n537:     el.addEventListener('mouseenter', e => {\n538:       const key = el.dataset.term;\n539:       showTip(key, el.getBoundingClientRect());\n540:     });\n541:     el.addEventListener('mouseleave', e => {\n542:       if (!tipPinned) hideTip();\n543:     });\n544:     el.addEventListener('click', e => {\n545:       e.preventDefault();\n546:       e.stopPropagation();\n547:       const key = el.dataset.term;\n548:       if (activeTerm === key && tipPinned) {\n549:         tipBox.classList.remove('visible');\n550:         activeTerm = null;\n551:         tipPinned = false;\n552:       } else {\n553:         tipPinned = true;\n554:         showTip(key, el.getBoundingClientRect());\n555:       }\n556:     });\n557:   });\n558: \n559:   document.addEventListener('click', () => {\n560:     tipPinned = false;\n561:     tipBox.classList.remove('visible');\n562:     activeTerm = null;\n563:   });\n564:   window.addEventListener('scroll', () => {\n565:     tipPinned = false;\n566:     tipBox.classList.remove('visible');\n567:     activeTerm = null;\n568:   }, true);\n569: \n570:   // ── BOOKING ──\n571:   function openBooking() {\n572:     const url = localStorage.getItem('ak_booking_url');\n573:     if (url && url.trim()) {\n574:       window.open(url.trim(), '_blank', 'noopener,noreferrer');\n575:       return;\n576:     }\n577:     // Odoo not yet configured — show notify-me modal\n578:     const ov = document.getElementById('book-overlay');\n579:     ov.classList.add('visible');\n580:     document.getElementById('book-notify-msg').classList.remove('visible');\n581:     document.getElementById('book-notify-msg').textContent = '';\n582:     document.getElementById('book-email').value = '';\n583:     document.getElementById('book-form').style.display = 'block';\n584:     setTimeout(() => document.getElementById('book-email').focus(), 80);\n585:   }\n586:   function closeBooking() {\n587:     document.getElementById('book-overlay').classList.remove('visible');\n588:   }\n589:   function closeBookingIfBackdrop(e) {\n590:     if (e.target === document.getElementById('book-overlay')) closeBooking();\n591:   }\n592:   let notifyTimer;\n593:   async function submitNotify(event) {\n594:     event.preventDefault();\n595:     const form = event.target;\n596:     const email = document.getElementById('book-email').value.trim();\n597:     const msg = document.getElementById('book-notify-msg');\n598:     if (!email || !email.includes('@')) {\n599:       msg.textContent = 'please enter a valid email address.';\n600:       msg.style.color = '#ff5555';\n601:       msg.classList.add('visible');\n602:       return false;\n603:     }\n604:     // Always keep a local copy as a fallback\n605:     const list = JSON.parse(localStorage.getItem('ak_notify_list') || '[]');\n606:     if (!list.find(function(e){ return (e.email||e) === email; })) {\n607:       list.push({ email: email, ts: Date.now() });\n608:       localStorage.setItem('ak_notify_list', JSON.stringify(list));\n609:     }\n610:     // Submit to Netlify Forms via fetch (so the page doesn't reload)\n611:     try {\n612:       const body = new URLSearchParams(new FormData(form)).toString();\n613:       const res = await fetch('/', {\n614:         method: 'POST',\n615:         headers: { 'Content-Type': 'application/x-www-form-urlencoded' },\n616:         body: body\n617:       });\n618:       if (!res.ok) throw new Error('Netlify rejected submission: ' + res.status);\n619:       document.getElementById('book-form').style.display = 'none';\n620:       msg.style.color = '#39FF14';\n621:       msg.textContent = '\\u2713 confirmed. we\\u2019ll reach out the moment booking opens.';\n622:       msg.classList.add('visible');\n623:     } catch (err) {\n624:       // Submission failed but the local copy is still saved\n625:       console.warn('[AKcloud] Netlify form submission failed; saved locally:', err);\n626:       document.getElementById('book-form').style.display = 'none';\n627:       msg.style.color = '#39FF14';\n628:       msg.textContent = '\\u2713 saved. we\\u2019ll reach out the moment booking opens.';\n629:       msg.classList.add('visible');\n630:     }\n631:     return false;\n632:   }\n633: \n634:   // ── LOGIN MODAL ──\n635:   function openLogin() {\n636:     document.getElementById('login-overlay').classList.add('visible');\n637:     document.getElementById('auth-msg').classList.remove('visible');\n638:     document.getElementById('auth-msg').textContent = '';\n639:     document.getElementById('login-email').value = '';\n640:     document.getElementById('login-password').value = '';\n641:   }\n642:   function closeLogin() {\n643:     document.getElementById('login-overlay').classList.remove('visible');\n644:   }\n645:   function closeLoginIfBackdrop(e) {\n646:     if (e.target === document.getElementById('login-overlay')) closeLogin();\n647:   }\n648:   let authTimer;\n649:   function signIn() {\n650:     const msg = document.getElementById('auth-msg');\n651:     msg.textContent = 'connecting to portal...';\n652:     msg.classList.add('visible');\n653:     clearTimeout(authTimer);\n654:     authTimer = setTimeout(() => {\n655:       msg.textContent = 'portal opens at launch. you are on the list.';\n656:     }, 1200);\n657:   }\n658: \n659:   // ESC closes modals\n660:   document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeLogin(); closeBooking(); } });\n661: \n662:   (function(){\n663:     var _r=atob('L2FkbWluLmh0bWw=');\n664:     var _w=atob('YW5kaWVrb2JiaWU=');\n665:     var _SK='ak_cfg',_TK='ak_ts',_SES='ak_ses';\n666: \n667:     function _h(s){var n=0x811c9dc5>>>0;for(var i=0;i<s.length;i++){n^=s.charCodeAt(i);n=Math.imul(n,0x01000193)>>>0;}return n.toString(36);}\n668:     function _ld(){try{return JSON.parse(localStorage.getItem(_SK)||'{}');}catch(e){return{};}}\n669:     function _sv(d){localStorage.setItem(_SK,JSON.stringify(Object.assign(_ld(),d)));}\n670: \n671:     var _E={\n672:       isFirst:function(){return!_ld().ph;},\n673:       isMobile:function(){return('ontouchstart' in window)||window.innerWidth<900;},\n674:       ok:function(u,p){var s=_ld();return s.ph?s.ph===_h(u+':'+p):(u==='admin'&&p==='admin');},\n675:       set:function(u,p){_sv({ph:_h(u+':'+p),un:u,rdy:1});},\n676:       gtSeq:function(){try{return JSON.parse(localStorage.getItem(_TK));}catch(e){return null;}},\n677:       stSeq:function(q){localStorage.setItem(_TK,JSON.stringify(q));},\n678:       hasSeq:function(){return!!localStorage.getItem(_TK);},\n679:       mkSes:function(){sessionStorage.setItem(_SES,'s'+Date.now().toString(36)+Math.random().toString(36).slice(2));},\n680:       clrSes:function(){sessionStorage.removeItem(_SES);}\n681:     };\n682: \n683:     var _tr=[],_tc=null,_tp=0;\n684: \n685:     function _q(id){return document.getElementById(id);}\n686:     function _ov(){return _q('_d0');}\n687: \n688:     function _open(){\n689:       _ov().style.display='flex';\n690:       _q('_d1').style.display='block';\n691:       _q('_d2').style.display='none';\n692:       _q('_dc').textContent='';\n693:       _q('_da').value='';_q('_db').value='';\n694:       setTimeout(function(){_q('_da').focus();},80);\n695:     }\n696:     function _close(){\n697:       _ov().style.