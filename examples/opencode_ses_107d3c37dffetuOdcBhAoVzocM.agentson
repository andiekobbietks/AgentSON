      "output": "<path>C:\\Users\\LLM-Test\\Documents\\AKcloud\\akcloud-deploy\\netlify\\functions\\get-waitlist.js</path>\n<type>file</type>\n<content>\n1: // netlify/functions/get-waitlist.js\n2: // ──────────────────────────────────────────────────────────────\n3: // Returns recent form submissions as JSON for the admin dashboard.\n4: //\n5: // Requires basic auth (set ADMIN_USER + ADMIN_PASS in Netlify env).\n6: // Auth is checked via the Authorization header — Netlify will return\n7: // 401 if missing/wrong.\n8: //\n9: // This complements admin.html's localStorage waitlist view by letting\n10: // the admin see ALL signups, not just the ones made on this browser.\n11: //\n12: // To use from admin.html, fetch('/api/get-waitlist') with credentials.\n13: \n14: const NETLIFY_API = 'https://api.netlify.com/api/v1';\n15: \n16: export default async (request) => {\n17:   // ── Auth ──\n18:   const auth = request.headers.get('authorization') || '';\n19:   const expected = 'Basic ' + btoa(\n20:     `${process.env.ADMIN_USER || ''}:${process.env.ADMIN_PASS || ''}`\n21:   );\n22:   if (!process.env.ADMIN_USER || auth !== expected) {\n23:     return new Response('Unauthorized', {\n24:       status: 401,\n25:       headers: { 'WWW-Authenticate': 'Basic realm=\"AKcloud admin\"' },\n26:     });\n27:   }\n28: \n29:   // ── Fetch submissions from Netlify Forms API ──\n30:   const siteId = process.env.NETLIFY_SITE_ID || '';\n31:   const token  = process.env.NETLIFY_API_TOKEN || '';\n32: \n33:   if (!siteId || !token) {\n34:     return new Response(JSON.stringify({\n35:       error: 'Missing NETLIFY_SITE_ID or NETLIFY_API_TOKEN env vars',\n36:     }), { status: 500, headers: { 'Content-Type': 'application/json' } });\n37:   }\n38: \n39:   try {\n40:     const url = `${NETLIFY_API}/sites/${siteId}/submissions/?per_page=100`;\n41:     const res = await fetch(url, {\n42:       headers: { 'Authorization': `Bearer ${token}` },\n43:     });\n44: \n45:     if (!res.ok) {\n46:       return new Response(JSON.stringify({\n47:         error: `Netlify API returned ${res.status}`,\n48:       }), { status: res.status, headers: { 'Content-Type': 'application/json' } });\n49:     }\n50: \n51:     const submissions = await res.json();\n52: \n53:     // Normalise into a clean shape\n54:     const cleaned = submissions\n55:       .filter(s => s.form_name === 'notify' || s.form_name === 'consultation')\n56:       .map(s => ({\n57:         id: s.id,\n58:         form: s.form_name,\n59:         email: s.data?.email || '',\n60:         company: s.data?.company || '',\n61:         topic: s.data?.topic || '',\n62:         source: s.data?.source || '',\n63:         created_at: s.created_at,\n64:         ip: s.client_ip,\n65:         user_agent: s.user_agent,\n66:       }));\n67: \n68:     return new Response(JSON.stringify({\n69:       count: cleaned.length,\n70:       submissions: cleaned,\n71:     }), {\n72:       status: 200,\n73:       headers: {\n74:         'Content-Type': 'application/json',\n75:         'Cache-Control': 'no-store',\n76:       },\n77:     });\n78:   } catch (err) {\n79:     return new Response(JSON.stringify({ error: err.message }), {\n80:       status: 500,\n81:       headers: { 'Content-Type': 'application/json' },\n82:     });\n83:   }\n84: };\n85: \n86: export const config = { path: '/.netlify/functions/get-waitlist' };\n\n(End of file - total 86 lines)\n</content>",
      "status": "success",
