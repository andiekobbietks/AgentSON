      "output": "<path>C:\\Users\\LLM-Test\\Documents\\AKcloud\\akcloud-deploy\\netlify\\functions\\submit-booking.js</path>\n<type>file</type>\n<content>\n1: // netlify/functions/submit-booking.js\n2: // ──────────────────────────────────────────────────────────────\n3: // Server-side proxy for Odoo booking submissions.\n4: //\n5: // Use case: instead of having the browser POST to your sovereign Odoo\n6: // directly (which exposes the API key), the browser POSTs here, and\n7: // this function talks to Odoo server-to-server using XML-RPC.\n8: //\n9: // Requires env vars (set in Netlify dashboard):\n10: //   ODOO_URL      — e.g. https://odoo.akcloud.example.com\n11: //   ODOO_DB       — database name\n12: //   ODOO_USER     — API user email\n13: //   ODOO_API_KEY  — generated in Odoo → Settings → Users → API Keys\n14: //\n15: // Browser usage:\n16: //   fetch('/api/submit-booking', {\n17: //     method: 'POST',\n18: //     headers: { 'Content-Type': 'application/json' },\n19: //     body: JSON.stringify({\n20: //       appointment_type_id: 1,\n21: //       datetime: '2026-07-15 10:00:00',\n22: //       name: 'John Smith',\n23: //       email: 'john@example.com',\n24: //       phone: '+44...',\n25: //     }),\n26: //   })\n27: //\n28: // Odoo XML-RPC docs:\n29: //   https://www.odoo.com/documentation/18.0/developer/reference/external_api.html\n30: \n31: export default async (request) => {\n32:   if (request.method !== 'POST') {\n33:     return new Response('Method not allowed', { status: 405 });\n34:   }\n35: \n36:   const { ODOO_URL, ODOO_DB, ODOO_USER, ODOO_API_KEY } = process.env;\n37:   if (!ODOO_URL || !ODOO_DB || !ODOO_USER || !ODOO_API_KEY) {\n38:     return new Response(JSON.stringify({\n39:       error: 'Odoo env vars not configured',\n40:     }), { status: 500, headers: { 'Content-Type': 'application/json' } });\n41:   }\n42: \n43:   let body;\n44:   try { body = await request.json(); }\n45:   catch { return new Response('Invalid JSON', { status: 400 }); }\n46: \n47:   const required = ['name', 'email', 'appointment_type_id', 'datetime'];\n48:   for (const field of required) {\n49:     if (!body[field]) {\n50:       return new Response(JSON.stringify({\n51:         error: `Missing required field: ${field}`,\n52:       }), { status: 400, headers: { 'Content-Type': 'application/json' } });\n53:     }\n54:   }\n55: \n56:   try {\n57:     // 1. Authenticate → get uid\n58:     const commonUrl = `${ODOO_URL}/xmlrpc/2/common`;\n59:     const authBody = XMLRPC.serialize('authenticate', [\n60:       ODOO_DB, ODOO_USER, ODOO_API_KEY, {},\n61:     ]);\n62:     const authRes = await fetch(commonUrl, {\n63:       method: 'POST',\n64:       headers: {\n65:         'Content-Type': 'text/xml',\n66:         'Content-Length': String(authBody.length),\n67:       },\n68:       body: authBody,\n69:     });\n70:     if (!authRes.ok) throw new Error(`Odoo auth HTTP ${authRes.status}`);\n71:     const uid = XMLRPC.parseUid(await authRes.text());\n72: \n73:     if (!uid) {\n74:       return new Response(JSON.stringify({\n75:         error: 'Odoo authentication failed — check ODOO_USER and ODOO_API_KEY',\n76:       }), { status: 401, headers: { 'Content-Type': 'application/json' } });\n77:     }\n78: \n79:     // 2. Find or create partner (contact)\n80:     const partnerId = await findOrCreatePartner(ODOO_URL, ODOO_DB, uid, ODOO_API_KEY, body);\n81: \n82:     // 3. Create calendar.event for the appointment\n83:     const eventId = await createAppointment(ODOO_URL, ODOO_DB, uid, ODOO_API_KEY, partnerId, body);\n84: \n85:     return new Response(JSON.stringify({\n86:       ok: true,\n87:       partner_id: partnerId,\n88:       event_id: eventId,\n89:       message: 'Booking confirmed via sovereign Odoo',\n90:     }), {\n91:       status: 200,\n92:       headers: { 'Content-Type': 'application/json' },\n93:     });\n94:   } catch (err) {\n95:     console.error('[submit-booking]', err);\n96:     return new Response(JSON.stringify({\n97:       error: err.message,\n98:     }), { status: 502, headers: { 'Content-Type': 'application/json' } });\n99:   }\n100: };\n101: \n102: // ── XML-RPC helpers (minimal handcrafted parser; avoid heavy deps) ──\n103: const XMLRPC = {\n104:   serialize(method, params) {\n105:     const esc = (s) => String(s).replace(/[<>&\"']/g, c => ({\n106:       '<': '&lt;', '>': '&gt;', '&': '&amp;', '\"': '&quot;', \"'\": '&apos;'\n107:     }[c]));\n108:     const paramXml = params.map(p => `<param>${valueToXml(p)}</param>`).join('');\n109:     return `<?xml version=\"1.0\"?>\n110:       <methodCall>\n111:         <methodName>${esc(method)}</methodName>\n112:         ${paramXml}\n113:       </methodCall>`;\n114:   },\n115:   parseUid(xml) {\n116:     const m = xml.match(/<int[^>]*>(\\d+)<\\/int>/);\n117:     return m ? parseInt(m[1], 10) : null;\n118:   },\n119:   parseIntArray(xml) {\n120:     const matches = [...xml.matchAll(/<int[^>]*>(\\d+)<\\/int>/g)];\n121:     return matches.map(m => parseInt(m[1], 10));\n122:   },\n123: };\n124: \n125: function valueToXml(value) {\n126:   if (value === null || value === undefined) return '<value><nil/></value>';\n127:   if (typeof value === 'number') {\n128:     if (Number.isInteger(value)) return `<value><int>${value}</int></value>`;\n129:     return `<value><double>${value}</double></value>`;\n130:   }\n131:   if (typeof value === 'boolean') return `<value><boolean>${value ? 1 : 0}</boolean></value>`;\n132:   if (Array.isArray(value)) {\n133:     return `<value><array><data>${value.map(v => `<value>${valueToXml(v)}</value>`).join('')}</data></array></value>`;\n134:   }\n135:   if (typeof value === 'object') {\n136:     const members = Object.entries(value)\n137:       .map(([k, v]) => `<member><name>${k}</name><value>${valueToXml(v)}</value></member>`)\n138:       .join('');\n139:     return `<value><struct>${members}</struct></value>`;\n140:   }\n141:   return `<value><string>${String(value).replace(/[<>&\"']/g, c => ({\n142:     '<': '&lt;', '>': '&gt;', '&': '&amp;', '\"': '&quot;', \"'\": '&apos;'\n143:   }[c]))}</string></value>`;\n144: }\n145: \n146: async function callOdooObject(url, db, uid, password, model, method, args, kwargs = {}) {\n147:   const body = XMLRPC.serialize('execute_kw', [db, uid, password, model, method, args, kwargs]);\n148:   const res = await fetch(`${url}/xmlrpc/2/object`, {\n149:     method: 'POST',\n150:     headers: { 'Content-Type': 'text/xml' },\n151:     body,\n152:   });\n153:   if (!res.ok) throw new Error(`Odoo execute_kw HTTP ${res.status}`);\n154:   return res.text();\n155: }\n156: \n157: async function findOrCreatePartner(url, db, uid, password, body) {\n158:   // Search by email\n159:   const searchXml = await callOdooObject(\n160:     url, db, uid, password,\n161:     'res.partner', 'search',\n162:     [[['email', '=', body.email]]]\n163:   );\n164:   const existing = XMLRPC.parseIntArray(searchXml);\n165: \n166:   if (existing.length > 0) return existing[0];\n167: \n168:   // Create\n169:   const createXml = await callOdooObject(\n170:     url, db, uid, password,\n171:     'res.partner', 'create',\n172:     [{\n173:       name: body.name,\n174:       email: body.email,\n175:       phone: body.phone || false,\n176:     }]\n177:   );\n178:   return XMLRPC.parseIntArray(createXml)[0];\n179: }\n180: \n181: async function createAppointment(url, db, uid, password, partnerId, body) {\n182:   const createXml = await callOdooObject(\n183:     url, db, uid, password,\n184:     'calendar.event', 'create',\n185:     [{\n186:       name: `${body.name} — ${body.topic || 'Consultation'}`,\n187:       partner_ids: [[6, 0, [partnerId]]],\n188:       start: body.datetime,\n189:       stop: addHour(body.datetime),\n190:       appointment_type_id: body.appointment_type_id,\n191:       description: body.notes || '',\n192:     }]\n193:   );\n194:   return XMLRPC.parseIntArray(createXml)[0];\n195: }\n196: \n197: function addHour(datetime) {\n198:   const d = new Date(datetime.replace(' ', 'T') + 'Z');\n199:   d.setUTCHours(d.getUTCHours() + 1);\n200:   return d.toISOString().replace('T', ' ').slice(0, 19);\n201: }\n202: \n203: export const config = { path: '/.netlify/functions/submit-booking' };\n\n(End of file - total 203 lines)\n</content>",
      "status": "success",
      "timestamp": 1782288408762
    },
