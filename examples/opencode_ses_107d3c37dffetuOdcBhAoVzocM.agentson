      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\AKcloud\\\\akcloud-deploy\\\\admin.html\", \"oldString\": \"  // \\u2500\\u2500 INIT: pre-fill saved values on page load \\u2500\\u2500\\n  document.addEventListener('DOMContentLoaded', () => {\\n    const cfg = odooLoad();\\n    if (cfg.url)  document.getElementById('odoo-url').value = cfg.url;\\n    if (cfg.db)   document.getElementById('odoo-db').value = cfg.db;\\n    if (cfg.user) document.getElementById('odoo-user').value = cfg.user;\\n    if (cfg.key)  document.getElementById('odoo-key').value = cfg.key;\\n    updateOdooStatusDot(false);\\n\\n    const bk = localStorage.getItem('ak_booking_url');\\n    if (bk) document.getElementById('booking-url').value = bk;\\n\\n    renderWaitlist(getWaitlist());\\n  });\", \"newString\": \"  // \\u2500\\u2500 INIT: pre-fill saved values on page load \\u2500\\u2500\\n  document.addEventListener('DOMContentLoaded', async () => {\\n    const cfg = odooLoad();\\n    if (cfg.url)  document.getElementById('odoo-url').value = cfg.url;\\n    if (cfg.db)   document.getElementById('odoo-db').value = cfg.db;\\n    if (cfg.user) document.getElementById('odoo-user').value = cfg.user;\\n    if (cfg.key)  document.getElementById('odoo-key').value = cfg.key;\\n    updateOdooStatusDot(false);\\n\\n    const bk = localStorage.getItem('ak_booking_url');\\n    if (bk) document.getElementById('booking-url').value = bk;\\n\\n    const list = await getWaitlist();\\n    renderWaitlist(list);\\n  });\"}",
