    {
      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\AKcloud\\\\akcloud-deploy\\\\index.html\", \"newString\": \"  const DEFAULT_BOOKING_URL = 'https://andiekobbie.odoo.com/appointment/discovery-consultation-more-1';\\n  let cachedBookingUrl = null;\\n\\n  async function getBookingUrl() {\\n    if (cachedBookingUrl) return cachedBookingUrl;\\n    const local = localStorage.getItem('ak_booking_url');\\n    if (local) { cachedBookingUrl = local; return local; }\\n    try {\\n      const res = await fetch('/api/get-config');\\n      const data = await res.json();\\n      if (data.booking_url) {\\n        cachedBookingUrl = data.booking_url;\\n        localStorage.setItem('ak_booking_url', data.booking_url);\\n        return data.booking_url;\\n      }\\n    } catch {}\\n    cachedBookingUrl = DEFAULT_BOOKING_URL;\\n    return DEFAULT_BOOKING_URL;\\n  }\\n\\n  async function openBooking() {\\n    const url = await getBookingUrl();\\n    if (url && url.trim()) {\\n      window.open(url.trim(), '_blank', 'noopener,noreferrer');\\n      return;\\n    }\", \"oldString\": \"  const DEFAULT_BOOKING_URL = 'https://andiekobbie.odoo.com/appointment/discovery-consultation-more-1';\\n  let cachedBookingUrl = null;\\n\\n  async function getBookingUrl() {\\n    if (cachedBookingUrl) return cachedBookingUrl;\\n    const local = localStorage.getItem('ak_booking_url');\\n    if (local) { cachedBookingUrl = local; return local; }\\n    try {\\n      const res = await fetch('config.json');\\n      const data = await res.json();\\n      if (data.booking_url) {\\n        cachedBookingUrl = data.booking_url;\\n        localStorage.setItem('ak_booking_url', data.booking_url);\\n        return data.booking_url;\\n      }\\n    } catch {}\\n    cachedBookingUrl = DEFAULT_BOOKING_URL;\\n    return DEFAULT_BOOKING_URL;\\n  }\\n\\n  async function openBooking() {\\n    const url = await getBookingUrl();\\n    if (url && url.trim()) {\\n      window.open(url.trim(), '_blank', 'noopener,noreferrer');\\n      return;\\n    }\"}",
      "output": "Edit applied successfully.",
