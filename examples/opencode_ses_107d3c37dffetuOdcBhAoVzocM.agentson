      "code": "{\"content\": \"import xmlrpc.client\\nimport ssl\\n\\nURL = \\\"https://andiekobbie.odoo.com\\\"\\nDB = \\\"andiekobbie\\\"\\nAPI_KEY = \\\"4a4b79c4fa6716a3f294cb7279b24105218906d5\\\"\\nUSERNAME = \\\"andiekobbietks@outlook.com\\\"\\n\\nssl_ctx = ssl.create_default_context()\\ncommon = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/common\\\", context=ssl_ctx)\\nmodels = xmlrpc.client.ServerProxy(f\\\"{URL}/xmlrpc/2/object\\\", context=ssl_ctx)\\n\\nuid = common.authenticate(DB, USERNAME, API_KEY, {})\\nprint(f\\\"Authenticated: uid={uid}\\\")\\n\\ndef execute(model, method, args=None, kwargs=None):\\n    a = args or []\\n    k = kwargs or {}\\n    return models.execute_kw(DB, uid, API_KEY, model, method, a, k)\\n\\n# 1. Check appointment type name\\nprint(\\\"\\\\n--- Appointment Type ---\\\")\\napt_ids = execute(\\\"appointment.type\\\", \\\"search\\\", [[[\\\"id\\\", \\\"=\\\", 27]]])\\nif apt_ids:\\n    apt = execute(\\\"appointment.type\\\", \\\"read\\\", [apt_ids, [\\\"name\\\", \\\"is_published\\\", \\\"website_published\\\"]])\\n    print(f\\\"  name={apt[0]['name']}, published={apt[0].get('website_published')}\\\")\\n\\n    # Force-write the name to ensure it's correct\\n    execute(\\\"appointment.type\\\", \\\"write\\\", [apt_ids, {\\\"name\\\": \\\"Discovery Consultation\\\"}])\\n    print(\\\"  -> Wrote name='Discovery Consultation'\\\")\\n\\n# 2. Tweak view 1117 arch to force QWeb recompilation\\nprint(\\\"\\\\n--- View 1117 arch tweak ---\\\")\\nview = execute(\\\"ir.ui.view\\\", \\\"read\\\", [[1117], [\\\"arch_db\\\"]])\\narch = view[0][\\\"arch_db\\\"]\\n\\n# Add a whitespace comment to force recompile, then remove it\\nimport re\\nif \\\"<!-- cache-bust -->\\\" not in arch:\\n    # Add a tiny comment at the top of the arch\\n    new_arch = \\\"<!-- cache-bust -->\\\" + arch\\n    execute(\\\"ir.ui.view\\\", \\\"write\\\", [[1117], {\\\"arch_db\\\": new_arch}])\\n    print(\\\"  Added <!-- cache-bust --> comment to arch\\\")\\nelse:\\n    # Remove it\\n    new_arch = arch.replace(\\\"<!-- cache-bust -->\\\", \\\"\\\", 1)\\n    execute(\\\"ir.ui.view\\\", \\\"write\\\", [[1117], {\\\"arch_db\\\": new_arch}])\\n    print(\\\"  Removed <!-- cache-bust --> comment from arch\\\")\\n\\n# 3. Force-write the arch again to trigger recompilation\\nview2 = execute(\\\"ir.ui.view\\\", \\\"read\\\", [[1117], [\\\"arch_db\\\"]])\\narch2 = view2[0][\\\"arch_db\\\"]\\nif \\\"<!-- cache-bust -->\\\" in arch2:\\n    clean_arch = arch2.replace(\\\"<!-- cache-bust -->\\\", \\\"\\\", 1)\\n    execute(\\\"ir.ui.view\\\", \\\"write\\\", [[1117], {\\\"arch_db\\\": clean_arch}])\\n    print(\\\"  Cleaned arch (final)\\\")\\n\\n# 4. Also check/update the invite record\\nprint(\\\"\\\\n--- Appointment Invite ---\\\")\\ninvite_ids = execute(\\\"appointment.invite\\\", \\\"search\\\", [[[\\\"url_code\\\", \\\"=\\\", \\\"27e80afd\\\"]]])\\nif invite_ids:\\n    invite = execute(\\\"appointment.invite\\\", \\\"read\\\", [invite_ids, [\\\"url_code\\\", \\\"staff_user_ids\\\"]])\\n    print(f\\\"  url_code={invite[0]['url_code']}, staff_user_ids={invite[0]['staff_user_ids']}\\\")\\n    if not invite[0]['staff_user_ids']:\\n        execute(\\\"appointment.invite\\\", \\\"write\\\", [invite_ids, {\\\"staff_user_ids\\\": [[6, 0, [2]]]}])\\n        print(\\\"  -> Set staff_user_ids=[2] (Andrea)\\\")\\n    else:\\n        print(\\\"  staff_user_ids already set\\\")\\n\\n# 5. Verify appointment type again\\nprint(\\\"\\\\n--- Final verify ---\\\")\\napt2 = execute(\\\"appointment.type\\\", \\\"read\\\", [[27], [\\\"name\\\", \\\"is_published\\\", \\\"website_published\\\", \\\"message_intro\\\"]])\\nprint(f\\\"  name='{apt2[0]['name']}'\\\")\\nprint(f\\\"  website_published={apt2[0].get('website_published')}\\\")\\n\\nprint(\\\"\\\\nDone! Cache should be busted. Check:\\\")\\nprint(\\\"  https://andiekobbie.odoo.com/appointment/discovery-consultation-1\\\")\\nprint(\\\"  https://andiekobbie.odoo.com/book/27e80afd\\\")\\n\", \"filePa