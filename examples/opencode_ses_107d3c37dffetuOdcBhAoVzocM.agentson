    {
      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\AKcloud\\\\akcloud-deploy\\\\admin.html\", \"oldString\": \"  function refreshWaitlist() {\\n    renderWaitlist(getWaitlist());\\n    toast('Waitlist refreshed');\\n  }\\n\\n  function clearWaitlist() {\\n    if (!confirm('Delete all ' + getWaitlist().length + ' waitlist entries? This cannot be undone.')) return;\\n    localStorage.removeItem('ak_notify_list');\\n    renderWaitlist([]);\\n    toast('Waitlist cleared');\\n  }\\n\\n  function exportWaitlistCSV() {\\n    const list = getWaitlist();\\n    if (!list.length) { toast('No emails to export', false); return; }\\n    const rows = [['#', 'Email', 'Date', 'Time (UTC)']];\\n    list.forEach(function(entry, i) {\\n      const email = typeof entry === 'string' ? entry : entry.email;\\n      const ts    = typeof entry === 'string' ? null  : entry.ts;\\n      const d     = ts ? new Date(ts) : null;\\n      rows.push([\\n        i + 1,\\n        email,\\n        d ? d.toISOString().slice(0, 10) : '',\\n        d ? d.toISOString().slice(11, 16) : ''\\n      ]);\\n    });\\n    const csv = rows.map(function(r){ return r.map(function(c){ return '\\\"' + String(c).replace(/\\\"/g,'\\\"\\\"') + '\\\"'; }).join(','); }).join('\\\\r\\\\n');\\n    const blob = new Blob([csv], { type: 'text/csv' });\\n    const url  = URL.createObjectURL(blob);\\n    const a    = document.createElement('a');\\n    a.href = url;\\n    a.download = 'akcloud-waitlist-' + new Date().toISOString().slice(0,10) + '.csv';\\n    document.body.appendChild(a); a.click(); document.body.removeChild(a);\\n    URL.revokeObjectURL(url);\\n    toast('CSV downloaded \\u2014 ' + list.length + ' email' + (list.length !== 1 ? 's' : ''));\\n  }\\n\\n  function copyWaitlistEmails() {\\n    const list = getWaitlist();\\n    if (!list.length) { toast('No emails to copy', false); return; }\\n    const emails = list.map(function(e){ return typeof e === 'string' ? e : e.email; }).join('\\\\n');\\n    navigator.clipboard.writeText(emails)\\n      .then(function(){ toast('Copied ' + list.length + ' email' + (list.length !== 1 ? 's' : '') + ' to clipboard'); })\\n      .catch(function(){ toast('Copy failed \\u2014 try Export CSV instead', false); });\\n  }\", \"newString\": \"  async function refreshWaitlist() {\\n    const list = await getWaitlist();\\n    renderWaitlist(list);\\n    toast('Waitlist refreshed');\\n  }\\n\\n  function clearWaitlist() {\\n    const list = getWaitlistLocal();\\n    if (!confirm('Delete all ' + list.length + ' local waitlist entries? This cannot be undone.')) return;\\n    localStorage.removeItem('ak_notify_list');\\n    renderWaitlist([]);\\n    toast('Local waitlist cleared');\\n  }\\n\\n  async function exportWaitlistCSV() {\\n    const list = await getWaitlist();\\n    if (!list.length) { toast('No emails to export', false); return; }\\n    const rows = [['#', 'Email', 'Date', 'Time (UTC)', 'Source']];\\n    list.forEach(function(entry, i) {\\n      const email = typeof entry === 'string' ? entry : entry.email;\\n      const ts    = typeof entry === 'string' ? null  : entry.ts;\\n      const d     = ts ? new Date(ts) : null;\\n      const src   = entry.source || 'local';\\n      rows.push([\\n        i + 1,\\n        email,\\n        d ? d.toISOString().slice(0, 10) : '',\\n        d ? d.toISOString().slice(11, 16) : '',\\n        src\\n      ]);\\n    });\\n    const csv = rows.map(function(r){ return r.map(function(c){ return '\\\"' + String(c).replace(/\\\"/g,'\\\"\\\"') + '\\\"'; }).join(','); }).join('\\\\r\\\\n');\\n    const blob = new Blob([csv], { type: 'text/csv' });\\n    const url  = URL.createObjectURL(blob);\\n    const a    = document.createElement('a');\\n    a.href = url;\\n    a.download = 'akcloud-waitlist-' + new Date().toISOString().slice(0,10) + '.csv';\\n    document.body.appendChild(a); a.click(); document.body.removeChild(a);\\n    URL.revokeObjectURL(url);\\n    toast('CSV downloaded \\u2014 ' + list.length + ' email' + (list.length !== 1 ? 's' : ''));\\n  }\\n\\n  async function copyWaitlistEmails() {\\n    const list = await getWaitlist();\\n    if (!list.length) { toast('No emails to copy', false); return; }\\n    const emails = list.map(function(e){ return typeof e === 'string' ? e : e.email; }).join('\\\\n');\\n    navigator.clipboard.writeText(emails)\\n      .then(function(){ toast('Copied ' + list.length + ' email' + (list.length !== 1 ? 's' : '') + ' to clipboard'); })\\n      .catch(function(){ toast('Copy failed \\u2014 try Export CSV instead', false); });\\n  }\"}",
