      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Documents\\\\AKcloud\\\\akcloud-deploy\\\\netlify\\\\functions\\\\notify-signup.js\"}",
      "output": "<path>C:\\Users\\LLM-Test\\Documents\\AKcloud\\akcloud-deploy\\netlify\\functions\\notify-signup.js</path>\n<type>file</type>\n<content>\n1: // netlify/functions/notify-signup.js\n2: // ──────────────────────────────────────────────────────────────\n3: // Receives form submissions from Netlify Forms and:\n4: //   1. Logs the entry\n5: //   2. Optionally sends an email via Resend\n6: //   3. Optionally posts to a Slack/Discord webhook\n7: //\n8: // Wire it up in Netlify dashboard:\n9: //   Site settings → Forms → Form notifications → Add notification → Webhook\n10: //   URL: https://akcloud.netlify.app/.netlify/functions/notify-signup\n11: //\n12: // Environment variables (set in Netlify UI):\n13: //   RESEND_API_KEY   — for email notifications (optional)\n14: //   NOTIFY_EMAIL     — destination email\n15: //   SLACK_WEBHOOK    — Slack/Discord incoming webhook URL (optional)\n16: //   SITE_NAME        — branding for messages (default: AKcloud)\n17: \n18: export default async (request) => {\n19:   // Only accept POST\n20:   if (request.method !== 'POST') {\n21:     return new Response('Method not allowed', { status: 405 });\n22:   }\n23: \n24:   let payload;\n25:   try {\n26:     payload = await request.json();\n27:   } catch (err) {\n28:     return new Response('Invalid JSON', { status: 400 });\n29:   }\n30: \n31:   // Netlify Forms wraps form data in { data: 'form=<urlencoded>', ... }\n32:   // For the webhook, payload.data is a URL-encoded string.\n33:   const params = new URLSearchParams(payload.data || '');\n34:   const formName = params.get('form-name') || params.get('form_name') || 'unknown';\n35:   const email = params.get('email') || '(no email)';\n36:   const company = params.get('company') || '';\n37:   const topic = params.get('topic') || '';\n38:   const source = params.get('source') || '';\n39: \n40:   const siteName = process.env.SITE_NAME || 'AKcloud';\n41: \n42:   const summary = {\n43:     received_at: new Date().toISOString(),\n44:     form: formName,\n45:     email,\n46:     company,\n47:     topic,\n48:     source,\n49:     ip: request.headers.get('x-forwarded-for') || 'unknown',\n50:     user_agent: request.headers.get('user-agent') || 'unknown',\n51:   };\n52: \n53:   // ── 1. Log to function output (visible in Netlify dashboard) ──\n54:   console.log(`[${siteName} notify-signup]`, JSON.stringify(summary));\n55: \n56:   // ── 2. Email notification via Resend (optional) ──\n57:   if (process.env.RESEND_API_KEY && process.env.NOTIFY_EMAIL) {\n58:     try {\n59:       const resendRes = await fetch('https://api.resend.com/emails', {\n60:         method: 'POST',\n61:         headers: {\n62:           'Authorization': `Bearer ${process.env.RESEND_API_KEY}`,\n63:           'Content-Type': 'application/json',\n64:         },\n65:         body: JSON.stringify({\n66:           from: `${siteName} <noreply@${siteName.toLowerCase()}.example.com>`,\n67:           to: [process.env.NOTIFY_EMAIL],\n68:           subject: `[${siteName}] New ${formName} signup: ${email}`,\n69:           html: `\n70:             <h2>New ${formName}</h2>\n71:             <table style=\"border-collapse:collapse;\">\n72:               <tr><td><b>Email</b></td><td style=\"padding-left:12px;\">${email}</td></tr>\n73:               ${company ? `<tr><td><b>Company</b></td><td style=\"padding-left:12px;\">${company}</td></tr>` : ''}\n74:               ${topic   ? `<tr><td><b>Topic</b></td><td style=\"padding-left:12px;\">${topic}</td></tr>` : ''}\n75:               ${source  ? `<tr><td><b>Source</b></td><td style=\"padding-left:12px;\">${source}</td></tr>` : ''}\n76:               <tr><td><b>Time</b></td><td style=\"padding-left:12px;\">${summary.received_at}</td></tr>\n77:               <tr><td><b>IP</b></td><td style=\"padding-left:12px;\">${summary.ip}</td></tr>\n78:             </table>\n79:           `,\n80:         }),\n81:       });\n82:       if (!resendRes.ok) {\n83:         const errText = await resendRes.text();\n84:         console.warn(`[notify-signup] Resend rejected: ${resendRes.status} ${errText}`);\n85:       } else {\n86:         console.log(`[notify-signup] Email sent to ${process.env.NOTIFY_EMAIL}`);\n87:       }\n88:     } catch (err) {\n89:       console.warn('[notify-signup] Resend error:', err.message);\n90:     }\n91:   }\n92: \n93:   // ── 3. Slack / Discord webhook (optional) ──\n94:   if (process.env.SLACK_WEBHOOK) {\n95:     try {\n96:       await fetch(process.env.SLACK_WEBHOOK, {\n97:         method: 'POST',\n98:         headers: { 'Content-Type': 'application/json' },\n99:         body: JSON.stringify({\n100:           text: `:incoming_envelope: New ${siteName} ${formName}\\n*${email}*${company ? ` from ${company}` : ''}`,\n101:         }),\n102:       });\n103:     } catch (err) {\n104:       console.warn('[notify-signup] Slack error:', err.message);\n105:     }\n106:   }\n107: \n108:   return new Response(JSON.stringify({ ok: true }), {\n109:     status: 200,\n110:     headers: { 'Content-Type': 'application/json' },\n111:   });\n112: };\n113: \n114: export const config = { path: '/.netlify/functions/notify-signup' };\n\n(End of file - total 114 lines)\n</content>",
      "status": "success",
      "timestamp": 1782288408062
