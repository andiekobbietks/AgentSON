      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\views\\HomeView.vue</path>\n<type>file</type>\n<content>\n1: <template>\n2:   <AppLayout>\n3:     <div class=\"max-w-[720px] mx-auto px-4 md:px-8 py-6\">\n4:       <header class=\"mb-5\">\n5:         <h1 class=\"text-[24px] font-bold leading-tight\">Home</h1>\n6:         <p class=\"text-[14px] text-muted-foreground mt-0.5\">Latest from across your Spaces.</p>\n7:       </header>\n8: \n9:       <div\n10:         v-if=\"isMock\"\n11:         class=\"mb-4 rounded-xl bg-primary-soft/60 border border-primary-soft p-3 flex items-start gap-2.5 text-[13px] text-primary-soft-foreground\"\n12:       >\n13:         <span class=\"mt-0.5 shrink-0\">✨</span>\n14:         <div>\n15:           <strong>UX prototype.</strong> Clickable design demo built with in-memory mock data.\n16:           Schema matches the real\n17:           <code class=\"font-mono text-[12px] bg-card/60 px-1 rounded\">frappe/lms</code>\n18:           +\n19:           <code class=\"font-mono text-[12px] bg-card/60 px-1 rounded\">frappe/gameplan</code>\n20:           DocTypes. See\n21:           <RouterLink to=\"/docs\" class=\"underline underline-offset-2\">/docs</RouterLink>.\n22:         </div>\n23:       </div>\n24: \n25:       <div v-if=\"loading\" class=\"flex justify-center py-12\">\n26:         <span class=\"text-muted-foreground text-[14px]\">Loading posts...</span>\n27:       </div>\n28: \n29:       <div\n30:         v-else-if=\"error\"\n31:         class=\"rounded-xl bg-red-50 border border-red-200 p-4 text-[13px] text-red-700\"\n32:       >\n33:         {{ error }}\n34:       </div>\n35: \n36:       <div v-else data-tour=\"feed\" class=\"flex flex-col gap-2\">\n37:         <PostCard v-for=\"p in posts\" :key=\"p.id\" :post=\"p\" />\n38:         <div v-if=\"hasMore\" class=\"flex justify-center pt-2 pb-4\">\n39:           <button\n40:             class=\"h-9 px-6 rounded-full bg-card border border-border text-[13px] font-semibold hover:bg-secondary transition-colors\"\n41:             :disabled=\"loadingMore\"\n42:             @click=\"loadMore\"\n43:           >\n44:             {{ loadingMore ? \"Loading...\" : \"Load more\" }}\n45:           </button>\n46:         </div>\n47:         <div\n48:           v-if=\"posts.length === 0 && !loading\"\n49:           class=\"py-20 text-center text-muted-foreground text-[14px]\"\n50:         >\n51:           No posts yet. Join a Space to get started.\n52:         </div>\n53:       </div>\n54:     </div>\n55:   </AppLayout>\n56: </template>\n57: \n58: <script setup lang=\"ts\">\n59: import { ref, onMounted } from \"vue\";\n60: import { RouterLink } from \"vue-router\";\n61: import AppLayout from \"@/components/AppLayout.vue\";\n62: import PostCard from \"@/components/PostCard.vue\";\n63: import { getDiscussionsAsync, getDiscussions } from \"@/data/store\";\n64: \n65: const isMock = typeof window !== \"undefined\" && !window.location.pathname.startsWith(\"/app\");\n66: const PAGE_SIZE = 20;\n67: \n68: const posts = ref(getDiscussions().slice(0, PAGE_SIZE));\n69: const loading = ref(isMock ? false : true);\n70: const loadingMore = ref(false);\n71: const error = ref(\"\");\n72: const offset = ref(0);\n73: const hasMore = ref(true);\n74: \n75: onMounted(async () => {\n76:   if (!isMock) {\n77:     try {\n78:       const result = await getDiscussionsAsync(undefined, PAGE_SIZE, 0);\n79:       posts.value = result.posts;\n80:       offset.value = PAGE_SIZE;\n81:       hasMore.value = result.total === -1 || result.total > PAGE_SIZE;\n82:     } catch (e) {\n83:       error.value = `Failed to load posts: ${(e as Error).message}`;\n84:     } finally {\n85:       loading.value = false;\n86:     }\n87:   }\n88: });\n89: \n90: async function loadMore() {\n91:   if (loadingMore.value) return;\n92:   loadingMore.value = true;\n93:   try {\n94:     const result = await getDiscussionsAsync(undefined, PAGE_SIZE, offset.value);\n95:     posts.value = [...posts.value, ...result.posts];\n96:     offset.value += result.posts.length;\n97:     if (result.total !== -1 && offset.value >= result.total) hasMore.value = false;\n98:     if (result.posts.length < PAGE_SIZE) hasMore.value = false;\n99:   } catch (e) {\n100:     error.value = `Failed to load more: ${(e as Error).message}`;\n101:   } finally {\n102:     loadingMore.value = false;\n103:   }\n104: }\n105: </script>\n\n(End of file - total 105 lines)\n</content>",
