      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\data\\store.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * Production-Ready Data Store Client\n3:  *\n4:  * This file serves as the bridge between the React frontend and the Frappe backend.\n5:  * By default, it falls back to the in-memory mock store (so the prototype runs standalone),\n6:  * but it contains the complete HTTP fetch implementation for talking to a real Frappe REST API.\n7:  *\n8:  * Production endpoints mapping:\n9:  * - List GP Discussions: GET /api/resource/GP Discussion\n10:  * - Insert GP Discussion: POST /api/method/frappe.client.insert\n11:  * - Get Comments: GET /api/resource/GP Comment?filters=[[\"reference_name\",\"=\",\"<discussion_id>\"]]\n12:  * - Add Comment: POST /api/method/frappe.client.insert\n13:  * - RSVP Event: POST /api/method/fg_companion.api.rsvp\n14:  */\n15: \n16: import * as mockStore from \"@/mock-data/store\";\n17: import type {\n18:   GPDiscussion,\n19:   GPComment,\n20:   GPUserProfile,\n21:   FGMentorMatch,\n22:   FGUserSettings,\n23:   LMSCourse,\n24:   LMSChapter,\n25:   LMSLesson,\n26:   RSVPStatus,\n27:   SentimentLabel,\n28:   FGDMThread,\n29:   FGDMMessage,\n30:   FGNotification,\n31:   FGSSOProvider,\n32:   SSOProviderId,\n33: } from \"@/mock-data/types\";\n34: \n35: // Detect if we are running against a real backend (e.g., local bench port or proxy)\n36: const IS_PRODUCTION_BACKEND =\n37:   typeof window !== \"undefined\" && window.location.pathname.startsWith(\"/app\");\n38: \n39: // Base API helper\n40: async function request<T>(path: string, options: RequestInit = {}): Promise<T> {\n41:   const headers = new Headers(options.headers);\n42:   headers.set(\"Content-Type\", \"application/json\");\n43: \n44:   // Extract CSRF token from cookies\n45:   let csrfToken = \"\";\n46:   if (typeof document !== \"undefined\") {\n47:     csrfToken = (document.cookie.match(/csrftoken=([^;]+)/) ?? [])[1] ?? \"\";\n48:   }\n49:   if (csrfToken) {\n50:     headers.set(\"X-Frappe-CSRF-Token\", csrfToken);\n51:   }\n52: \n53:   const response = await fetch(path, {\n54:     credentials: \"include\",\n55:     ...options,\n56:     headers,\n57:   });\n58: \n59:   if (!response.ok) {\n60:     throw new Error(`Frappe API error: ${response.statusText}`);\n61:   }\n62: \n63:   const json = await response.json();\n64:   return json.message || json.data;\n65: }\n66: \n67: // Re-export state-versioning\n68: export const useStoreVersion = mockStore.useStoreVersion;\n69: export const currentUserId = mockStore.currentUserId;\n70: \n71: // --- Selectors with Production API stubs ---\n72: \n73: export const getUsers = () => {\n74:   if (IS_PRODUCTION_BACKEND) {\n75:     console.log(\"Production API call: GET /api/resource/User\");\n76:   }\n77:   return mockStore.getUsers();\n78: };\n79: \n80: export const getUser = (id: string) => {\n81:   if (IS_PRODUCTION_BACKEND) {\n82:     console.log(`Production API call: GET /api/resource/User/${id}`);\n83:   }\n84:   return mockStore.getUser(id);\n85: };\n86: \n87: export const getProjects = () => {\n88:   if (IS_PRODUCTION_BACKEND) {\n89:     console.log(\"Production API call: GET /api/resource/GP Project\");\n90:   }\n91:   return mockStore.getProjects();\n92: };\n93: \n94: export const getProject = (id: string) => {\n95:   return mockStore.getProject(id);\n96: };\n97: \n98: export const getTeams = () => {\n99:   return mockStore.getTeams();\n100: };\n101: \n102: export const getProjectsByTeam = (teamId: string) => {\n103:   return mockStore.getProjectsByTeam(teamId);\n104: };\n105: \n106: export function getDiscussions(projectId?: string) {\n107:   if (IS_PRODUCTION_BACKEND) {\n108:     const filter = projectId ? `?filters=[[\"project\",\"=\",\"${projectId}\"]]` : \"\";\n109:     console.log(`Production API call: GET /api/resource/GP Discussion${filter}`);\n110:   }\n111:   return mockStore.getDiscussions(projectId);\n112: }\n113: \n114: export const getDiscussion = (id: string) => {\n115:   if (IS_PRODUCTION_BACKEND) {\n116:     console.log(`Production API call: GET /api/resource/GP Discussion/${id}`);\n117:   }\n118:   return mockStore.getDiscussion(id);\n119: };\n120: \n121: export const getCommentsFor = (discussionId: string) => {\n122:   if (IS_PRODUCTION_BACKEND) {\n123:     console.log(\n124:       `Production API call: GET /api/resource/GP Comment?filters=[[\"reference_name\",\"=\",\"${discussionId}\"]]`,\n125:     );\n126:   }\n127:   return mockStore.getCommentsFor(discussionId);\n128: };\n129: \n130: export const getReactionsFor = (ref: \"GP Discussion\" | \"GP Comment\", id: string) => {\n131:   return mockStore.getReactionsFor(ref, id);\n132: };\n133: \n134: export const getEvents = () => {\n135:   if (IS_PRODUCTION_BACKEND) {\n136:     console.log(\"Production API call: GET /api/resource/FG Event\");\n137:   }\n138:   return mockStore.getEvents();\n139: };\n140: \n141: export const getEvent = (id: string) => {\n142:   return mockStore.getEvent(id);\n143: };\n144: \n145: export const getAttendees = (eventId: string) => {\n146:   return mockStore.getAttendees(eventId);\n147: };\n148: \n149: export const getMatchesForUser = (userId: string) => {\n150:   if (IS_PRODUCTION_BACKEND) {\n151:     console.log(\n152:       `Production API call: GET /api/resource/FG Mentor Match?filters=[[\"mentee\",\"=\",\"${userId}\"]]`,\n153:     );\n154:   }\n155:   return mockStore.getMatchesForUser(userId);\n156: };\n157: \n158: export const getRecentPostsByUser = (userId: string) => {\n159:   return mockStore.getRecentPostsByUser(userId);\n160: };\n161: \n162: export const getAISettings = () => {\n163:   return mockStore.getAISettings();\n164: };\n165: \n166: // --- LMS selectors ---\n167: export const getCourses = () => {\n168:   if (IS_PRODUCTION_BACKEND) {\n169:     console.log(\"Production API call: GET /api/resource/LMS Course?filters=[['published','=',1]]\");\n170:   }\n171:   return mockStore.getCourses();\n172: };\n173: \n174: export const getAllCoursesIncludingDrafts = () => {\n175:   return mockStore.getAllCoursesIncludingDrafts();\n176: };\n177: \n178: export const getCourse = (id: string) => {\n179:   return mockStore.getCourse(id);\n180: };\n181: \n182: export const getChaptersForCourse = (courseId: string) => {\n183:   return mockStore.getChaptersForCourse(courseId);\n184: };\n185: \n186: export const getLessonsForChapter = (chapterId: string) => {\n187:   return mockStore.getLessonsForChapter(chapterId);\n188: };\n189: \n190: export const getLessonsForCourse = (courseId: string) => {\n191:   return mockStore.getLessonsForCourse(courseId);\n192: };\n193: \n194: export const getLesson = (id: string) => {\n195:   return mockStore.getLesson(id);\n196: };\n197: \n198: export const getEnrollment = (courseId: string, userId = currentUserId) => {\n199:   return mockStore.getEnrollment(courseId, userId);\n200: };\n201: \n202: export const getMyEnrollments = (userId = currentUserId) => {\n203:   return mockStore.getMyEnrollments(userId);\n204: };\n205: \n206: export const isLessonComplete = (lessonId: string, userId = currentUserId) => {\n207:   return mockStore.isLessonComplete(lessonId, userId);\n208: };\n209: \n210: export function courseProgressPercent(courseId: string, userId = currentUserId) {\n211:   return mockStore.courseProgressPercent(courseId, userId);\n212: }\n213: \n214: // --- User settings ---\n215: export const getUserSettings = (userId = currentUserId): FGUserSettings => {\n216:   return mockStore.getUserSettings(userId);\n217: };\n218: \n219: export function updateUserSettings(patch: Partial<FGUserSettings>) {\n220:   if (IS_PRODUCTION_BACKEND) {\n221:     console.log(\"Production API call: PUT /api/resource/FG User Settings/<id>\");\n222:   }\n223:   mockStore.updateUserSettings(patch);\n224: }\n225: \n226: export function updateProfile(patch: Partial<GPUserProfile>) {\n227:   if (IS_PRODUCTION_BACKEND) {\n228:     console.log(\"Production API call: PUT /api/resource/GP User Profile/<id>\");\n229:   }\n230:   mockStore.updateProfile(patch);\n231: }\n232: \n233: // --- mutators ---\n234: \n235: export function createDiscussion(input: {\n236:   project: string;\n237:   title: string;\n238:   content: string;\n239: }): GPDiscussion {\n240:   if (IS_PRODUCTION_BACKEND) {\n241:     console.log(\"Production API call: POST /api/method/frappe.client.insert (GP Discussion)\");\n242:   }\n243:   return mockStore.createDiscussion(input);\n244: }\n245: \n246: export function createComment(input: { discussion_id: string; content: string }): GPComment {\n247:   if (IS_PRODUCTION_BACKEND) {\n248:     console.log(\"Production API call: POST /api/method/frappe.client.insert (GP Comment)\");\n249:   }\n250:   return mockStore.createComment(input);\n251: }\n252: \n253: export function toggleReaction(ref: \"GP Discussion\" | \"GP Comment\", id: string, emoji: string) {\n254:   if (IS_PRODUCTION_BACKEND) {\n255:     console.log(\"Production API call: POST /api/method/fg_companion.api.toggle_reaction\");\n256:   }\n257:   mockStore.toggleReaction(ref, id, emoji);\n258: }\n259: \n260: export function setRSVP(eventId: string, status: RSVPStatus) {\n261:   if (IS_PRODUCTION_BACKEND) {\n262:     console.log(\"Production API call: POST /api/method/fg_companion.api.set_rsvp\");\n263:   }\n264:   mockStore.setRSVP(eventId, status);\n265: }\n266: \n267: export const getMyRSVP = (eventId: string): RSVPStatus | null => {\n268:   return mockStore.getMyRSVP(eventId);\n269: };\n270: \n271: export function requestMentor(mentorId: string, notes: string): FGMentorMatch {\n272:   if (IS_PRODUCTION_BACKEND) {\n273:     console.log(\"Production API call: POST /api/method/frappe.client.insert (FG Mentor Match)\");\n274:   }\n275:   return mockStore.requestMentor(mentorId, notes);\n276: }\n277: \n278: // --- LMS mutators ---\n279: export function createCourse(input: {\n280:   title: string;\n281:   short_introduction: string;\n282:   description: string;\n283:   category: string;\n284:   tags: string;\n285: }): LMSCourse {\n286:   return mockStore.createCourse(input);\n287: }\n288: \n289: export function addChapter(courseId: string, title: string): LMSChapter {\n290:   return mockStore.addChapter(courseId, title);\n291: }\n292: \n293: export function addLesson(input: {\n294:   course: string;\n295:   chapter: string;\n296:   title: string;\n297:   body: string;\n298:   youtube_video: string;\n299: }): LMSLesson {\n300:   return mockStore.addLesson(input);\n301: }\n302: \n303: export function enrollInCourse(courseId: string) {\n304:   return mockStore.enrollInCourse(courseId);\n305: }\n306: \n307: export function markLessonComplete(lessonId: string, complete: boolean) {\n308:   mockStore.markLessonComplete(lessonId, complete);\n309: }\n310: \n311: export function extractYouTubeId(input: string): string {\n312:   return mockStore.extractYouTubeId(input);\n313: }\n314: \n315: export function mockSentiment(text: string): {\n316:   label: SentimentLabel;\n317:   score: number;\n318: } {\n319:   return mockStore.mockSentiment(text);\n320: }\n321: \n322: export function findSimilarPosts(discussionId: string, limit = 3) {\n323:   return mockStore.findSimilarPosts(discussionId, limit);\n324: }\n325: \n326: // --- DMs ---\n327: export const getDMThreadsForUser = (userId = currentUserId): FGDMThread[] => {\n328:   return mockStore.getDMThreadsForUser(userId);\n329: };\n330: \n331: export const getDMThread = (id: string) => {\n332:   return mockStore.getDMThread(id);\n333: };\n334: \n335: export const getDMMessages = (threadId: string): FGDMMessage[] => {\n336:   return mockStore.getDMMessages(threadId);\n337: };\n338: \n339: export const getOtherMember = (thread: FGDMThread, userId = currentUserId) => {\n340:   return mockStore.getOtherMember(thread, userId);\n341: };\n342: \n343: export function openOrCreateDMWith(otherUserId: string): FGDMThread {\n344:   return mockStore.openOrCreateDMWith(otherUserId);\n345: }\n346: \n347: export function sendDM(threadId: string, content: string): FGDMMessage | null {\n348:   return mockStore.sendDM(threadId, content);\n349: }\n350: \n351: export function markThreadRead(threadId: string) {\n352:   mockStore.markThreadRead(threadId);\n353: }\n354: \n355: export const getUnreadDMCount = (userId = currentUserId) => {\n356:   return mockStore.getUnreadDMCount(userId);\n357: };\n358: \n359: // --- Notifications ---\n360: export const getNotifications = (userId = currentUserId): FGNotification[] => {\n361:   return mockStore.getNotifications(userId);\n362: };\n363: \n364: export const getUnreadNotificationCount = (userId = currentUserId) => {\n365:   return mockStore.getUnreadNotificationCount(userId);\n366: };\n367: \n368: export function markAllNotificationsRead(userId = currentUserId) {\n369:   mockStore.markAllNotificationsRead(userId);\n370: }\n371: \n372: export function markNotificationRead(id: string) {\n373:   mockStore.markNotificationRead(id);\n374: }\n375: \n376: // --- SSO providers ---\n377: export const getSSOProviders = (): FGSSOProvider[] => {\n378:   return mockStore.getSSOProviders();\n379: };\n380: \n381: export function updateSSOProvider(id: SSOProviderId, patch: Partial<FGSSOProvider>) {\n382:   mockStore.updateSSOProvider(id, patch);\n383: }\n\n(End of file - total 383 lines)\n</content>",
