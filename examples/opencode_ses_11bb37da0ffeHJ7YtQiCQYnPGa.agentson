      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\views\\\\EventsView.vue\", \"newString\": \"    </div>\\n\\n    <!-- New Event Modal -->\\n    <Teleport to=\\\"body\\\">\\n      <div\\n        v-if=\\\"showNewEvent\\\"\\n        class=\\\"fixed inset-0 z-50 bg-foreground/30 flex items-start justify-center pt-[10vh] px-4\\\"\\n        @click=\\\"showNewEvent = false\\\"\\n      >\\n        <div class=\\\"w-full max-w-[520px] bg-card rounded-2xl shadow-2xl overflow-hidden\\\" @click.stop>\\n          <header class=\\\"flex items-center justify-between px-6 py-4 border-b border-border\\\">\\n            <h2 class=\\\"text-[16px] font-semibold\\\">New event</h2>\\n            <button class=\\\"size-8 rounded-md flex items-center justify-center text-muted-foreground hover:bg-secondary\\\" @click=\\\"showNewEvent = false\\\">\\u2715</button>\\n          </header>\\n          <form class=\\\"px-6 py-5 flex flex-col gap-4\\\" @submit.prevent=\\\"createNewEvent\\\">\\n            <label class=\\\"flex flex-col gap-1.5\\\">\\n              <span class=\\\"text-[12px] font-semibold text-secondary-foreground\\\">Title</span>\\n              <input v-model=\\\"newEvent.title\\\" required placeholder=\\\"Event name\\\" class=\\\"h-10 px-3 rounded-md border border-border bg-background text-[14px] outline-none focus:ring-2 focus:ring-primary/30\\\" />\\n            </label>\\n            <label class=\\\"flex flex-col gap-1.5\\\">\\n              <span class=\\\"text-[12px] font-semibold text-secondary-foreground\\\">Description</span>\\n              <textarea v-model=\\\"newEvent.description\\\" rows=\\\"3\\\" placeholder=\\\"What's this event about?\\\" class=\\\"px-3 py-2 rounded-md border border-border bg-background text-[14px] outline-none focus:ring-2 focus:ring-primary/30 resize-none\\\" />\\n            </label>\\n            <div class=\\\"grid grid-cols-2 gap-3\\\">\\n              <label class=\\\"flex flex-col gap-1.5\\\">\\n                <span class=\\\"text-[12px] font-semibold text-secondary-foreground\\\">Date & time</span>\\n                <input v-model=\\\"newEvent.starts_on\\\" type=\\\"datetime-local\\\" required class=\\\"h-10 px-2 rounded-md border border-border bg-background text-[14px]\\\" />\\n              </label>\\n              <label class=\\\"flex flex-col gap-1.5\\\">\\n                <span class=\\\"text-[12px] font-semibold text-secondary-foreground\\\">Type</span>\\n                <select v-model=\\\"newEvent.event_type\\\" class=\\\"h-10 px-2 rounded-md border border-border bg-background text-[14px]\\\">\\n                  <option>In-Person Meetup</option>\\n                  <option>Webinar</option>\\n                  <option>Workshop</option>\\n                  <option>Drop-in Office Hours</option>\\n                  <option>Networking</option>\\n                </select>\\n              </label>\\n            </div>\\n            <div class=\\\"flex justify-end gap-2 pt-2\\\">\\n              <button type=\\\"button\\\" class=\\\"h-8 px-3 rounded-full text-[13px] font-semibold text-muted-foreground hover:bg-secondary\\\" @click=\\\"showNewEvent = false\\\">Cancel</button>\\n              <button type=\\\"submit\\\" class=\\\"h-8 px-5 rounded-full bg-primary text-primary-foreground text-[13px] font-semibold hover:opacity-90\\\">Create event</button>\\n            </div>\\n          </form>\\n        </div>\\n      </div>\\n    </Teleport>\\n  </AppLayout>\\n</template>\", \"oldString\": \"    </div>\\n  </AppLayout>\\n</template>\"}",
