      "code": "{\"command\": \"powershell -Command \\\"\\n$ErrorActionPreference = 'Stop'\\n$appsPath = 'C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\apps'\\n$fgPath = '\\\\$appsPath\\\\\\\\fg_firstgens_app'\\n\\n# Create directories\\nNew-Item -ItemType Directory -Path '$fgPath' -Force | Out-Null\\nNew-Item -ItemType Directory -Path '\\\\$fgPath\\\\\\\\fg_firstgens_app' -Force | Out-Null\\nNew-Item -ItemType Directory -Path '\\\\$fgPath\\\\\\\\fg_firstgens_app\\\\\\\\templates' -Force | Out-Null\\nNew-Item -ItemType Directory -Path '\\\\$fgPath\\\\\\\\fg_firstgens_app\\\\\\\\templates\\\\\\\\website' -Force | Out-Null\\nNew-Item -ItemType Directory -Path '\\\\$fgPath\\\\\\\\fg_firstgens_app\\\\\\\\fixtures' -Force | Out-Null\\nNew-Item -ItemType Directory -Path '\\\\$fgPath\\\\\\\\fg_firstgens_app\\\\\\\\www' -Force | Out-Null\\nNew-Item -ItemType Directory -Path '\\\\$fgPath\\\\\\\\fg_firstgens_app\\\\\\\\public\\\\\\\\css' -Force | Out-Null\\nNew-Item -ItemType Directory -Path '\\\\$fgPath\\\\\\\\fg_firstgens_app\\\\\\\\patches' -Force | Out-Null\\n\\n# Create __init__.py\\n@'\\n# FirstGens Custom App\\n__version__ = '0.0.1'\\n'@ | Out-File -FilePath '\\\\$fgPath\\\\__init__.py' -Encoding UTF8\\n\\n# Create __setup__.py\\n@'\\napp_name = 'fg_firstgens_app'\\napp_title = 'FirstGens Companion'\\napp_description = 'Community platform for first-generation students'\\napp_publisher = 'FirstGens'\\napp_color = '#3e654a'\\napp_icon = 'octicon octicon-users'\\napp_email = 'admin@firstgens.test'\\napp_license = 'MIT'\\n\\nwebsite_route_rules = [\\n    {'from_route': '/firstgens', 'to_route': 'firstgens'},\\n    {'from_route': '/firstgens/<path:app_path>', 'to_route': 'firstgens'},\\n]\\n'@ | Out-File -FilePath '\\\\$fgPath\\\\__setup__.py' -Encoding UTF8\\n\\n# Create hooks.py\\n@'\\nfrom frappe_deprecation_wrapper import deprecate\\n\\napp_name = 'fg_firstgens_app'\\napp_title = 'FirstGens Companion'\\napp_description = 'Community platform for first-generation students'\\napp_publisher = 'FirstGens'\\napp_email = 'admin@firstgens.test'\\napp_license = 'MIT'\\n\\nwebsite_route_rules = [\\n    {'from_route': '/firstgens', 'to_route': 'firstgens'},\\n    {'from_route': '/firstgens/<path:app_path>', 'to_route': 'firstgens'},\\n]\\n\\napp_context = {\\n    'firstgens_brand': {\\n        'primary': '#3e654a',\\n        'stone': '#f6ede0',\\n        'burnt_maroon': '#37272f',\\n        'clay': '#d17147',\\n        'yellow': '#ffba56',\\n    }\\n}\\n\\nwebsite_templates = [\\n    'templates/website/firstgens_home.html',\\n    'templates/website/firstgens_discussions.html',\\n    'templates/website/firstgens_courses.html',\\n    'templates/website/firstgens_tickets.html',\\n    'templates/website/firstgens_members.html',\\n]\\n'@ | Out-File -FilePath '\\\\$fgPath\\\\hooks.py' -Encoding UTF8\\n\\n# Create fg_firstgens_app\\\\__init__.py\\n@'\\nfrom .patches import *\\n'@ | Out-File -FilePath '\\\\$fgPath\\\\fg_firstgens_app\\\\__init__.py' -Encoding UTF8\\n\\n# Create fg_firstgens_app\\\\patches\\\\__init__.py\\n@'\\n# FirstGens patches\\n'@ | Out-File -FilePath '\\\\$fgPath\\\\fg_firstgens_app\\\\patches\\\\__init__.py' -Encoding UTF8\\n\\n# Create home template\\n$homeTemplate = @'\\n{% extends \\\"templates/website/layout.html\\\" %}\\n{% block page_content %}\\n<div class=\\\"container\\\">\\n    <div class=\\\"row\\\">\\n        <div class=\\\"col-md-12\\\">\\n            <h1 class=\\\"page-header\\\">Welcome to FirstGens</h1>\\n            <p class=\\\"lead\\\">A community platform for first-generation students</p>\\n        </div>\\n    </div>\\n\\n    <div class=\\\"row\\\">\\n        <div class=\\\"col-md-8\\\">\\n            <h2>Community Discussions</h2>\\n            <p>Join discussions about navigating university as a first-gen student</p>\\n            <a href=\\\"/firstgens/discussions\\\" class=\\\"btn btn-primary\\\">View Discussions</a>\\n        </div>\\n        <div class=\\\"col-md-4\\\">\\n            <h2>Learning Resources</h2>\\n            <p>Access courses and study guides</p>\\n            <a href=\\\"/firstgens/courses\\\" class=\\\"btn btn-success\\\">Browse Courses</a>\\n        </div>\\n    </div>\\n\\n    <div class=\\\"row mt-4\\\">\\n        <div class=\\\"col-md-6\\\">\\n            <h2>Support & Help</h2>\\n            <p>Get help and support from the community</p>\\n            <a href=\\\"/firstgens/tickets\\\" class=\\\"btn btn-info\\\">Submit a Ticket</a>\\n        </div>\\n        <div class=\\\"col-md-6\\\">\\n            <h2>Meet Other Students</h2>\\n            <p>Connect with fellow first-gen students</p>\\n            <a href=\\\"/firstgens/members\\\" class=\\\"btn btn-warning\\\">View Members</a>\\n        </div>\\n    </div>\\n</div>\\n'\\n$homeTemplate | Out-File -FilePath '\\\\$fgPath\\\\fg_firstgens_app\\\\templates\\\\website\\\\firstgens_home.html' -Encoding UTF8\\n\\n# Create discussion template\\n$discussionTemplate = @'\\n{% extends \\\"templates/website/layout.html\\\" %}\\n{% block page_content %}\\n<div class=\\\"container\\\">\\n    <div class=\\\"row\\\">\\n        <div class=\\\"col-md-12\\\">\\n            <h1 class=\\\"page-header\\\">Community Discussions</h1>\\n            <p class=\\\"lead\\\">Join conversations with other first-generation students</p>\\n        </div>\\n    </div>\\n\\n    <div class=\\\"row\\\">\\n        {% for discussion in discussions %}\\n        <div class=\\\"col-md-6 mb-4\\\">\\n            <div class=\\\"card\\\">\\n                <div class=\\\"card-body\\\">\\n                    <h3 class=\\\"card-title\\\">\\n                        <a href=\\\"/app/gp-discussion/{{ discussion.name }}\\\">{{ discussion.title }}</a>\\n                    </h3>\\n                    <h6 class=\\\"card-subtitle mb-2 text-muted\\\">\\n                        <strong>Project:</strong> {{ discussion.project }} | \\n                        <strong>Author:</strong> {{ discussion.owner }} | \\n                        <strong>Last Post:</strong> {{ discussion.last_post_at }}\\n                    </h6>\\n                    <p class=\\\"card-text\\\">{{ discussion.content[:200] }}...</p>\\n                    <div class=\\\"d-flex justify-content-between\\\">\\n                        <small class=\\\"text-muted\\\">Comments: {{ discussion.comments_count }}</small>\\n                        <small class=\\\"text-muted\\\">Participants: {{ discussion.participants_count }}</small>\\n                    </div>\\n                </div>\\n            </div>\\n        </div>\\n        {% endfor %}\\n    </div>\\n</div>\\n'\\n$discussionTemplate | Out-File -FilePath '\\\\$fgPath\\\\fg_firstgens_app\\\\templates\\\\website\\\\firstgens_discussions.html' -Encoding UTF8\\n\\n# Create courses template\\n$coursesTemplate = @'\\n{% extends \\\"templates/website/layout.html\\\" %}\\n{% block page_content %}\\n<div class=\\\"container\\\">\\n    <div class=\\\"row\\\">\\n        <div class=\\\"col-md-12\\\">\\n            <h1 class=\\\"page-header\\\">Learning Courses</h1>\\n            <p class=\\\"lead\\\">Courses designed specifically for first-generation students</p>\\n        </div>\\n    </div>\\n\\n    <div class=\\\"row\\\">\\n        {% for course in courses %}\\n        <div class=\\\"col-md-6 mb-4\\\">\\n            <div class=\\\"card\\\">\\n                <div class=\\\"card-body\\\">\\n                    <h3 class=\\\"card-title\\\">\\n                        <a href=\\\"/app/lms-course/{{ course.name }}\\\">{{ course.title }}</a>\\n                    </h3>\\n                    <h6 class=\\\"card-subtitle mb-2 text-muted\\\">\\n                        <strong>Instructor:</strong> {{ course.instructor }} | \\n                        <strong>Category:</strong> {{ course.category }}<br>\\n                        <strong>Status:</strong> {{ course.status }} | \\n                        <strong>Published:</strong> {% if course.published %}Yes{% else %}No{% endif %}\\n                    </h6>\\n                    <p class=\\\"card-text\\\">{{ course.short_introduction }}</p>\\n                    <div class=\\\"d-flex justify-content-between\\\">\\n                        <small class=\\\"text-muted\\\">Rating: {{ course.rating }}/5</small>\\n                        {% if course.paid_course %}\\n                        <small class=\\\"text-success font-weight-bold\\\">Paid Course</small>\\n                        {% endif %}\\n                    </div>\\n                </div>\\n            </div>\\n        </div>\\n        {% endfor %}\\n    </div>\\n</div>\\n'\\n$coursesTemplate | Out-File -FilePath '\\\\$fgPath\\\\fg_firstgens_app\\\\templates\\\\website\\\\firstgens_courses.html' -Encoding UTF8\\n\\n# Create tickets template\\n$ticketsTemplate = @'\\n{% extends \\\"templates/website/layout.html\\\" %}\\n{% block page_content %}\\n<div class=\\\"container\\\">\\n    <div class=\\\"row\\\">\\n        <div class=\\\"col-md-12\\\">\\n            <h1 class=\\\"page-header\\\">Support Tickets</h1>\\n            <p class=\\\"lead\\\">Get help and support from the community</p>\\n        </div>\\n    </div>\\n\\n    <div class=\\\"row\\\">\\n        {% for ticket in tickets %}\\n        <div class=\\\"col-md-6 mb-4\\\">\\n            <div class=\\\"card\\\">\\n                <div class=\\\"card-body\\\">\\n                    <h3 class=\\\"card-title\\\">\\n                        <a href=\\\"/app/hd-ticket/{{ ticket.name }}\\\">{{ ticket.subject }}</a>\\n                    </h3>\\n                    <h6 class=\\\"card-subtitle mb-2 text-muted\\\">\\n                        <strong>Status:</strong> {{ ticket.status }} | \\n                        <strong>Priority:</strong> {{ ticket.priority }} | \\n                        <strong>Type:</strong> {{ ticket.ticket_type }}<br>\\n                        <strong>Submitted by:</strong> {{ ticket.raised_by }}<br>\\n                        <strong>Date:</strong> {{ ticket.opening_date }}\\n                    </h6>\\n                    <p class=\\\"card-text\\\">{{ ticket.description[:200] }}...</p>\\n                    <div class=\\\"d-flex justify-content-between\\\">\\n                        <small class=\\\"text-muted\\\">{% if ticket.status == 'Open' %}Open{% else %}Resolved{% endif %}</small>\\n                        <small class=\\\"text-muted\\\">{% if ticket.status == 'Open' %}Awaiting response{% else %}Closed{% endif %}</small>\\n                    </div>\\n                </div>\\n            </div>\\n        </div>\\n        {% endfor %}\\n    </div>\\n</div>\\n'\\n$ticketsTemplate | Out-File -FilePath '\\\\$fgPath\\\\fg_firstgens_app\\\\templates\\\\website\\\\firstgens_tickets.html' -Encoding UTF8\\n\\n# Create members template\\n$membersTemplate = @'\\n{% extends \\\"templates/website/layout.html\\\" %}\\n{% block page_content %}\\n<div class=\\\"container\\\">\\n    <div class=\\\"row\\\">\\n        <div class=\\\"col-md-12\\\">\\n            <h1 class=\\\"page-header\\\">Community Members</h1>\\n            <p class=\\\"lead\\\">Meet fellow first-generation students</p>\\n        </div>\\n    </div>\\n\\n    <div class=\\\"row\\\">\\n        {% for user in users %}\\n        <div class=\\\"col-md-4 mb-4\\\">\\n            <div class=\\\"card\\\">\\n                <div class=\\\"card-body text-center\\\">\\n                    <h4 class=\\\"card-title\\\">{{ user.first_name }} {{ user.last_name }}</h4>\\n                    <h6 class=\\\"card-subtitle text-muted\\\">{{ user.email }}</h6>\\n                    <p class=\\\"card-text mt-3\\\">\\n                        {% if user.get('student_id') %}\\n                        <small class=\\\"badge badge-primary\\\">Student</small>\\n                        {% endif %}\\n                        {% if user.get('mentor_id') %}\\n                        <small class=\\\"badge badge-success\\\">Mentor</small>\\n                        {% endif %}\\n                    </p>\\n                    <a href=\\\"/profile/{{ user.name }}\\\" class=\\\"btn btn-outline-primary btn-sm\\\">View Profile</a>\\n                </div>\\n            </div>\\n        </div>\\n        {% endfor %}\\n    </div>\\n</div>\\n'\\n$membersTemplate | Out-File -FilePath '\\\\$fgPath\\\\fg_firstgens_app\\\\templates\\\\website\\\\firstgens_members.html' -Encoding UTF8\\n\\n# Copy to Frappe bench apps directory\\nCopy-Item -Path '\\\\$fgPath\\\\*' -Destination 'C:\\\\Users\\\\LLM-Test\\\\Documents\\\\frappe-bench\\\\apps\\\\fg_firstgens_app' -Recurse -Force\\n\\nWrite-Host \\\"=== FirstGens Custom Frappe App Created Successfully ===\\\"\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"App created at: C:\\\\Users\\\\LLM-Test\\\\Documents\\\\frappe-bench\\\\apps\\\\fg_firstgens_app\\\"\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"\\u2713 Custom hooks.py configuration\\\"\\nWrite-Host \\\"\\u2713 Website route rules for FirstGens sections\\\"\\nWrite-Host \\\"\\u2713 Custom website templates\\\"\\nWrite-Host \\\"\\u2713 App context and settings\\\"\\nWrite-Host \\\"\\u2713 FirstGens sections: /firstgens, /firstgens/discussions, /firstgens/courses, /firstgens/tickets, /firstgens/members\\\"\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"The custom Frappe app is ready to use!\\\" -ForegroundColor Green\\n\\\"@ | Out-File -FilePath \\\"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\app_setup.ps1\\\" -Encoding UTF8 -Append -Force\\n\\nWrite-Host \\\"Script saved and ready to run...\\\" -ForegroundColor Yellow\\n\\\" | Out-File -FilePath \\\"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\app_setup.ps1\\\" -Encoding UTF8 -Force\\n\\nWrite-Host \\\"PowerShell script created. Now let's try running it...\\\" -ForegroundColor Green\\n\\\" | Out-File -FilePath \\\"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\app_setup.ps1\\\" -Encoding UTF8 -Force\\n\\\" | Out-File -FilePath \\\"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\ap