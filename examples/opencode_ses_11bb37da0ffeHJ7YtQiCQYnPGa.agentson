    {
      "type": "action",
      "tool": "read",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\types.ts\"}",
      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\mock-data\\types.ts</path>\n<type>file</type>\n<content>\n1: // Types intentionally mirror real Frappe DocTypes from frappe/gameplan and\n2: // frappe/lms. Researched against the live `main` branch .json files — see\n3: // /docs/01_SCHEMA_MAPPING_TO_FRAPPE.md and /docs/04_FRAPPE_TRANSLATION.md.\n4: //\n5: // IMPORTANT NAMING NOTES:\n6: // - Field names below are snake_case to mirror Frappe exactly.\n7: // - Where Frappe stores a value via standard meta fields (`name`, `owner`,\n8: //   `creation`, `modified`), we keep convenience aliases here (`id`,\n9: //   `author_id`, `created_at`) and document the mapping. This is the ONLY\n10: //   place those aliases exist — every component reads through them.\n11: // - Child-table rows in Frappe also carry implicit `parent`, `parenttype`,\n12: //   `parentfield`, `idx`. We don't model those for the prototype.\n13: \n14: // ============================================================\n15: // frappe/gameplan\n16: // ============================================================\n17: \n18: /** DocType: `GP Team` */\n19: export interface GPTeam {\n20:   id: string;\n21:   title: string;\n22:   icon: string;\n23:   is_private: boolean;\n24:   archived_at: string | null;\n25:   archived_by: string | null;\n26: }\n27: \n28: /** DocType: `GP Project` (UI label: \"Space\") */\n29: export interface GPProject {\n30:   id: string;\n31:   title: string;\n32:   description: string;\n33:   status: \"Open\" | \"Completed\";\n34:   team: string;\n35:   progress: number;\n36:   icon: string;\n37:   readme: string;\n38:   tasks_count: number;\n39:   discussions_count: number;\n40:   archived_at: string | null;\n41:   archived_by: string | null;\n42:   is_private: boolean;\n43: }\n44: \n45: /** DocType: `GP Discussion` (UI label: \"Post\") */\n46: export interface GPDiscussion {\n47:   id: string;\n48:   project: string;\n49:   team: string;\n50:   status: string;\n51:   title: string;\n52:   slug: string;\n53:   content: string;\n54:   last_post_at: string;\n55:   last_post_by: string | null;\n56:   comments_count: number;\n57:   participants_count: number;\n58:   closed_at: string | null;\n59:   closed_by: string | null;\n60:   pinned_at: string | null;\n61:   pinned_by: string | null;\n62:   author_id: string;\n63:   created_at: string;\n64: }\n65: \n66: /** DocType: `GP Comment` */\n67: export interface GPComment {\n68:   id: string;\n69:   content: string;\n70:   reference_doctype: \"GP Discussion\";\n71:   reference_name: string;\n72:   deleted_at: string | null;\n73:   author_id: string;\n74:   created_at: string;\n75: }\n76: \n77: /** DocType: `GP Reaction` (istable=1). */\n78: export interface GPReaction {\n79:   id: string;\n80:   reference_doctype: \"GP Discussion\" | \"GP Comment\";\n81:   reference_name: string;\n82:   user: string;\n83:   emoji: string;\n84: }\n85: \n86: /** DocType: `GP User Profile` */\n87: export interface GPUserProfile {\n88:   user: string;\n89:   enabled: boolean;\n90:   full_name: string;\n91:   bio: string;\n92:   readme: string;\n93:   image: string;\n94:   cover_image: string;\n95:   image_background_color: string;\n96: }\n97: \n98: // ============================================================\n99: // frappe/lms — full prototype (mirrors real DocType field names)\n100: // ============================================================\n101: \n102: /** DocType: `LMS Course` */\n103: export interface LMSCourse {\n104:   id: string; // → `name`\n105:   title: string;\n106:   short_introduction: string;\n107:   description: string; // Text Editor — long form\n108:   image: string;\n109:   paid_course: boolean;\n110:   featured: boolean;\n111:   published: boolean;\n112:   enable_certification: boolean;\n113:   category: string;\n114:   tags: string; // comma separated, matches LMS\n115:   status: \"Draft\" | \"Approved\" | \"Under Review\";\n116:   author: string; // → Link `User` (instructor)\n117:   enrollments: number; // denormalised for cards\n118:   lessons: number; // denormalised\n119:   created_at: string;\n120: }\n121: \n122: /** DocType: `LMS Chapter` (parent: LMS Course) */\n123: export interface LMSChapter {\n124:   id: string; // → `name`\n125:   course: string; // → Link `LMS Course`\n126:   title: string;\n127:   description: string;\n128:   idx: number; // order\n129: }\n130: \n131: /**\n132:  * DocType: `LMS Lesson` (parent: LMS Chapter)\n133:  *\n134:  * In real LMS the body is a Markdown/HTML field with embedded shortcodes\n135:  * like `{{ YouTubeVideo(\"VIDEO_ID\") }}`. For the prototype we surface\n136:  * `youtube_video` as a first-class field — porting is a search/replace\n137:  * to the shortcode form. See /docs/04_FRAPPE_TRANSLATION.md.\n138:  */\n139: export interface LMSLesson {\n140:   id: string; // → `name`\n141:   chapter: string; // → Link `LMS Chapter`\n142:   course: string; // → Link `LMS Course` (denormalised)\n143:   title: string;\n144:   body: string; // Markdown/HTML\n145:   youtube_video: string; // 11-char YouTube ID (or \"\")\n146:   include_in_preview: boolean;\n147:   idx: number;\n148: }\n149: \n150: /** DocType: `LMS Enrollment` */\n151: export interface LMSEnrollment {\n152:   id: string;\n153:   member: string; // → Link `User`\n154:   course: string; // → Link `LMS Course`\n155:   member_type: \"Student\" | \"Mentor\";\n156:   progress: number; // 0..100\n157:   enrolled_on: string;\n158: }\n159: \n160: /** DocType: `LMS Course Progress` (per-lesson completion) */\n161: export interface LMSCourseProgress {\n162:   id: string;\n163:   member: string;\n164:   course: string;\n165:   lesson: string;\n166:   status: \"Complete\" | \"Incomplete\";\n167: }\n168: \n169: // ============================================================\n170: // fg_companion — NEW custom Frappe app (to be created)\n171: // ============================================================\n172: \n173: export type EventType =\n174:   | \"Webinar\"\n175:   | \"In-Person Meetup\"\n176:   | \"Workshop\"\n177:   | \"Drop-in Office Hours\"\n178:   | \"Networking\";\n179: \n180: export type LocationType = \"Online (BigBlueButton)\" | \"Online (External Link)\" | \"In Person\";\n181: \n182: /** DocType (new): `FG Event` */\n183: export interface FGEvent {\n184:   id: string;\n185:   title: string;\n186:   description: string;\n187:   space: string | null;\n188:   event_type: EventType;\n189:   starts_on: string;\n190:   ends_on: string;\n191:   location_type: LocationType;\n192:   bbb_meeting_id: string | null;\n193:   external_link: string | null;\n194:   physical_address: string | null;\n195:   rsvp_required: boolean;\n196:   capacity: number;\n197:   hosted_by: string;\n198: }\n199: \n200: export type RSVPStatus = \"Going\" | \"Maybe\" | \"Not Going\" | \"Attended\" | \"No Show\";\n201: \n202: /** DocType (new): `FG Event Attendee` */\n203: export interface FGEventAttendee {\n204:   id: string;\n205:   event: string;\n206:   user: string;\n207:   rsvp_status: RSVPStatus;\n208: }\n209: \n210: export type MentorMatchStatus = \"Requested\" | \"Active\" | \"Completed\" | \"Ended Early\";\n211: \n212: export type MatchedVia = \"Manual\" | \"Self-Requested\" | \"Algorithmic Suggestion\";\n213: \n214: /** DocType (new): `FG Mentor Match` */\n215: export interface FGMentorMatch {\n216:   id: string;\n217:   mentee: string;\n218:   mentor: string;\n219:   status: MentorMatchStatus;\n220:   matched_on: string;\n221:   matched_via: MatchedVia;\n222:   match_notes: string;\n223: }\n224: \n225: /** Single DocType (new): `FG AI Settings` */\n226: export interface FGAISettings {\n227:   enable_sentiment: boolean;\n228:   sentiment_alert_threshold: number;\n229:   enable_vector_search: boolean;\n230: }\n231: \n232: /**\n233:  * DocType (new): `FG User Settings`\n234:  *\n235:  * Mirrors the per-user Notification + Privacy panels in Circle.\n236:  * In Frappe these would be a mix of Notification Settings (core) and a\n237:  * small custom DocType for community-specific toggles.\n238:  */\n239: export interface FGUserSettings {\n240:   user: string;\n241:   email_on_mention: boolean;\n242:   email_on_reply: boolean;\n243:   email_weekly_digest: boolean;\n244:   push_on_dm: boolean;\n245:   push_on_mention: boolean;\n246:   show_in_member_directory: boolean;\n247:   allow_dm_from_anyone: boolean;\n248:   theme: \"system\" | \"light\" | \"dark\";\n249:   language: \"en\" | \"es\" | \"fr\";\n250:   timezone: string;\n251: }\n252: \n253: // — mocked AI output (computed, not stored) —\n254: export type SentimentLabel = \"Positive\" | \"Neutral\" | \"Negative\" | \"Needs Attention\";\n255: \n256: // ============================================================\n257: // fg_companion — DMs (mirrors Raven Channel / Raven Message)\n258: // ============================================================\n259: \n260: /** DocType (Raven): `Raven Channel` (1:1 DM variant) */\n261: export interface FGDMThread {\n262:   id: string;\n263:   member_a: string;\n264:   member_b: string;\n265:   last_message_at: string;\n266:   last_message_preview: string;\n267: }\n268: \n269: /** DocType (Raven): `Raven Message` */\n270: export interface FGDMMessage {\n271:   id: string;\n272:   thread: string;\n273:   sender: string;\n274:   content: string;\n275:   created_at: string;\n276:   read_by: string[];\n277: }\n278: \n279: /** DocType (Frappe core): `Notification Log` */\n280: export interface FGNotification {\n281:   id: string;\n282:   for_user: string;\n283:   subject: string;\n284:   type: \"Mention\" | \"Reply\" | \"DM\" | \"Event\" | \"System\" | \"Mentor\";\n285:   document_type: \"GP Discussion\" | \"FG DM Thread\" | \"FG Event\" | \"FG Mentor Match\" | \"\";\n286:   document_name: string;\n287:   read: boolean;\n288:   created_at: string;\n289: }\n290: \n291: // ============================================================\n292: // fg_companion — SSO providers (per-workspace)\n293: // ============================================================\n294: \n295: export type SSOProviderId = \"email\" | \"google\" | \"microsoft\" | \"github\" | \"discord\" | \"apple\";\n296: \n297: /**\n298:  * DocType (new): `FG SSO Provider`\n299:  *\n300:  * Port targets:\n301:  *  - Supabase: enable provider in Auth → Providers, then\n302:  *    supabase.auth.signInWithOAuth({ provider: <id> })\n303:  *  - Frappe: `Social Login Key` DocType (one row per provider) plus\n304:  *    the OAuth flow in `frappe.integrations.oauth2`.\n305:  */\n306: export interface FGSSOProvider {\n307:   id: SSOProviderId;\n308:   label: string;\n309:   enabled: boolean;\n310:   client_id_set: boolean;\n311:   notes: string;\n312: }\n\n(End of file - total 312 lines)\n</content>",
