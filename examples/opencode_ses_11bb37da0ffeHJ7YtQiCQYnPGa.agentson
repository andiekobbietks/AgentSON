 flex-col gap-1.5\">\n44:               <span class=\"text-[12px] font-semibold text-secondary-foreground\">Full name</span>\n45:               <input\n46:                 :defaultValue=\"me.full_name\"\n47:                 class=\"h-10 px-3 rounded-md border border-border bg-background text-[14px]\"\n48:                 @blur=\"\n49:                   (e) => {\n50:                     updateProfile({ full_name: (e.target as HTMLInputElement).value });\n51:                     flash();\n52:                   }\n53:                 \"\n54:               />\n55:             </label>\n56:             <label class=\"flex flex-col gap-1.5\">\n57:               <span class=\"text-[12px] font-semibold text-secondary-foreground\"\n58:                 >Headline / bio (1 line)</span\n59:               >\n60:               <input\n61:                 :defaultValue=\"me.bio\"\n62:                 class=\"h-10 px-3 rounded-md border border-border bg-background text-[14px]\"\n63:                 @blur=\"\n64:                   (e) => {\n65:                     updateProfile({ bio: (e.target as HTMLInputElement).value });\n66:                     flash();\n67:                   }\n68:                 \"\n69:               />\n70:             </label>\n71:             <label class=\"flex flex-col gap-1.5\">\n72:               <span class=\"text-[12px] font-semibold text-secondary-foreground\"\n73:                 >About (longer)</span\n74:               >\n75:               <textarea\n76:                 :defaultValue=\"me.readme\"\n77:                 rows=\"5\"\n78:                 class=\"px-3 py-2 rounded-md border border-border bg-background text-[14px] resize-none\"\n79:                 @blur=\"\n80:                   (e) => {\n81:                     updateProfile({ readme: (e.target as HTMLTextAreaElement).value });\n82:                     flash();\n83:                   }\n84:                 \"\n85:               />\n86:             </label>\n87:             <label class=\"flex flex-col gap-1.5\">\n88:               <span class=\"text-[12px] font-semibold text-secondary-foreground\"\n89:                 >Avatar background colour</span\n90:               >\n91:               <input\n92:                 type=\"color\"\n93:                 :defaultValue=\"me.image_background_color\"\n94:                 class=\"h-10 w-20 rounded-md border border-border bg-background\"\n95:                 @change=\"\n96:                   (e) => {\n97:                     updateProfile({ image_background_color: (e.target as HTMLInputElement).value });\n98:                     flash();\n99:                   }\n100:                 \"\n101:               />\n102:             </label>\n103:           </div>\n104: \n105:           <!-- Notifications -->\n106:           <div v-if=\"tab === 'notifications'\" class=\"flex flex-col gap-1\">\n107:             <h2 class=\"text-[16px] font-semibold mb-3\">Notifications</h2>\n108:             <div\n109:               class=\"text-[11px] uppercase tracking-wider font-semibold text-muted-foreground mt-3 mb-1\"\n110:             >\n111:               Email\n112:             </div>\n113:             <Toggle\n114:               label=\"When someone @mentions me\"\n115:               :value=\"settings.email_on_mention\"\n116:               @change=\"\n117:                 (v) => {\n118:                   updateUserSettings({ email_on_mention: v });\n119:                   flash();\n120:                 }\n121:               \"\n122:             />\n123:             <Toggle\n124:               label=\"When someone replies to my post\"\n125:               :value=\"settings.email_on_reply\"\n126:               @change=\"\n127:                 (v) => {\n128:                   updateUserSettings({ email_on_reply: v });\n129:                   flash();\n130:                 }\n131:               \"\n132:             />\n133:             <Toggle\n134:               label=\"Weekly community digest\"\n135:               :value