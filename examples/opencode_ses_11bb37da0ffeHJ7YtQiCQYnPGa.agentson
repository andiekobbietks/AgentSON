      "code": "{\"content\": \"#!/bin/bash\\nexport PATH=\\\"/home/andiekobbie/.local/bin:/usr/bin:/usr/local/bin:/bin:$PATH\\\"\\n\\ncat > /tmp/seed_final.py << 'PYEOF'\\nimport frappe\\nimport os\\nfrom passlib.hash import bcrypt\\n\\nos.chdir(\\\"/home/andiekobbie/frappe-bench/sites\\\")\\nfrappe.init(\\\"firstgens.localhost\\\")\\nfrappe.connect()\\n\\n# ============================================\\n# USERS - password goes in new_password\\n# ============================================\\nprint(\\\"=== Creating/Updating Users ===\\\")\\nusers = [\\n    {\\\"email\\\": \\\"alaya@firstgens.test\\\", \\\"first_name\\\": \\\"Alaya\\\", \\\"last_name\\\": \\\"Holloway\\\"},\\n    {\\\"email\\\": \\\"jordan@firstgens.test\\\", \\\"first_name\\\": \\\"Jordan\\\", \\\"last_name\\\": \\\"Okonkwo\\\"},\\n    {\\\"email\\\": \\\"priya@firstgens.test\\\", \\\"first_name\\\": \\\"Priya\\\", \\\"last_name\\\": \\\"Sharma\\\"},\\n    {\\\"email\\\": \\\"maya@firstgens.test\\\", \\\"first_name\\\": \\\"Maya\\\", \\\"last_name\\\": \\\"Chen\\\"},\\n    {\\\"email\\\": \\\"sam@firstgens.test\\\", \\\"first_name\\\": \\\"Sam\\\", \\\"last_name\\\": \\\"Adeyemi\\\"},\\n    {\\\"email\\\": \\\"rosa@firstgens.test\\\", \\\"first_name\\\": \\\"Rosa\\\", \\\"last_name\\\": \\\"Martinez\\\"},\\n    {\\\"email\\\": \\\"alex@firstgens.test\\\", \\\"first_name\\\": \\\"Alex\\\", \\\"last_name\\\": \\\"Thompson\\\"},\\n    {\\\"email\\\": \\\"fatima@firstgens.test\\\", \\\"first_name\\\": \\\"Fatima\\\", \\\"last_name\\\": \\\"Hassan\\\"},\\n]\\n\\nfor u in users:\\n    if not frappe.db.exists(\\\"User\\\", u[\\\"email\\\"]):\\n        try:\\n            frappe.db.sql(\\\"\\\"\\\"INSERT INTO `tabUser` (name, email, first_name, last_name, user_type, send_welcome_email, creation, modified, modified_by, owner)\\n                VALUES (%s, %s, %s, %s, 'Website User', 0, NOW(), NOW(), 'Administrator', 'Administrator')\\\"\\\"\\\",\\n                (u[\\\"email\\\"], u[\\\"email\\\"], u[\\\"first_name\\\"], u[\\\"last_name\\\"]))\\n            frappe.db.commit()\\n            print(f\\\"  Created user: {u['email']}\\\")\\n        except Exception as e:\\n            print(f\\\"  User create error {u['email']}: {e}\\\")\\n    \\n    # Set password\\n    try:\\n        pwd_hash = bcrypt.using(rounds=12).hash(\\\"firstgens123\\\")\\n        frappe.db.sql(\\\"UPDATE `tabUser` SET new_password = %s WHERE name = %s\\\", (pwd_hash, u[\\\"email\\\"]))\\n        frappe.db.commit()\\n        print(f\\\"  Password set: {u['email']}\\\")\\n    except Exception as e:\\n        print(f\\\"  Password error {u['email']}: {e}\\\")\\n\\n# ============================================\\n# LMS CATEGORIES - table is tabLMS Category\\n# ============================================\\nprint(\\\"\\\\n=== Creating LMS Categories ===\\\")\\ncategories = [\\\"Getting Started\\\", \\\"Academic Skills\\\", \\\"Career Development\\\"]\\nfor cat_name in categories:\\n    existing = frappe.db.get_value(\\\"LMS Category\\\", {\\\"name\\\": cat_name}, \\\"name\\\")\\n    if not existing:\\n        try:\\n            frappe.db.sql(\\\"\\\"\\\"INSERT INTO `tabLMS Category` (name, creation, modified, modified_by, owner, docstatus)\\n                VALUES (%s, NOW(), NOW(), 'Administrator', 'Administrator', 0)\\\"\\\"\\\",\\n                (cat_name,))\\n            frappe.db.commit()\\n            print(f\\\"  Created category: {cat_name}\\\")\\n        except Exception as e:\\n            print(f\\\"  Category error: {e}\\\")\\n\\n# ============================================\\n# HD TICKET PRIORITIES - need integer_value\\n# ============================================\\nprint(\\\"\\\\n=== Creating HD Priorities ===\\\")\\npriorities = [(\\\"Low\\\", 1), (\\\"Medium\\\", 2), (\\\"High\\\", 3), (\\\"Urgent\\\", 4)]\\nfor pname, idx in priorities:\\n    existing = frappe.db.get_value(\\\"HD Ticket Priority\\\", {\\\"name\\\": pname}, \\\"name\\\")\\n    if not existing:\\n        try:\\n            frappe.db.sql(\\\"\\\"\\\"INSERT INTO `tabHD Ticket Priority` (name, idx, integer_value, creation, modified, modified_by, owner, docstatus)\\n                VALUES (%s, %s, %s, NOW(), NOW(), 'Administrator', 'Administrator', 0)\\\"\\\"\\\",\\n                (pname, idx, idx))\\n            frappe.db.commit()\\n            print(f\\\"  Created priority: {pname}\\\")\\n        except Exception as e:\\n            print(f\\\"  Priority error: {e}\\\")\\n\\n# ============================================\\n# GP DISCUSSIONS - no author_id, use owner\\n# ============================================\\nprint(\\\"\\\\n=== Creating Discussions ===\\\")\\ndiscussions = [\\n    {\\\"title\\\": \\\"Welcome to FirstGens! Introduce yourself here\\\", \\\"project\\\": \\\"Welcome & Introductions\\\", \\\"owner\\\": \\\"alaya@firstgens.test\\\",\\n     \\\"content\\\": \\\"Hey everyone! I'm Alaya, the founder of FirstGens. I was the first in my family to go to university and I know how isolating it can feel.\\\"},\\n    {\\\"title\\\": \\\"How do you deal with imposter syndrome?\\\", \\\"project\\\": \\\"Mental Health & Wellbeing\\\", \\\"owner\\\": \\\"maya@firstgens.test\\\",\\n     \\\"content\\\": \\\"Does anyone else feel like they don't belong at uni? I got good grades but constantly feel like I'm going to be found out.\\\"},\\n    {\\\"title\\\": \\\"Best resources for essay writing?\\\", \\\"project\\\": \\\"Study Tips & Resources\\\", \\\"owner\\\": \\\"sam@firstgens.test\\\",\\n     \\\"content\\\": \\\"I'm in my first year and the jump from A-levels to uni essays is massive. Does anyone have good resources?\\\"},\\n    {\\\"title\\\": \\\"Networking events - how to actually do them?\\\", \\\"project\\\": \\\"Career Guidance\\\", \\\"owner\\\": \\\"priya@firstgens.test\\\",\\n     \\\"content\\\": \\\"I went to a careers fair last week and had no idea what to say to the employers. How do you network?\\\"},\\n    {\\\"title\\\": \\\"Managing finances as a first-gen student\\\", \\\"project\\\": \\\"Navigating University\\\", \\\"owner\\\": \\\"rosa@firstgens.test\\\",\\n     \\\"content\\\": \\\"First-gen students often don't have the financial safety net that others do. Happy to share what I've found.\\\"},\\n    {\\\"title\\\": \\\"Workshop recap: Building Your Support Network\\\", \\\"project\\\": \\\"Upcoming Events\\\", \\\"owner\\\": \\\"jordan@firstgens.test\\\",\\n     \\\"content\\\": \\\"Great turnout at yesterday's workshop! Key takeaways: build relationships with your personal tutor.\\\"},\\n]\\n\\nfor d in discussions:\\n    existing = frappe.db.get_value(\\\"GP Discussion\\\", {\\\"title\\\": d[\\\"title\\\"]}, \\\"name\\\")\\n    if not existing:\\n        try:\\n            disc = frappe.new_doc(\\\"GP Discussion\\\")\\n            disc.title = d[\\\"title\\\"]\\n            disc.content = d[\\\"content\\\"]\\n            disc.project = d[\\\"project\\\"]\\n            disc.flags.ignore_permissions = True\\n            disc.insert()\\n            frappe.db.commit()\\n            print(f\\\"  Created: {d['title'][:50]}...\\\")\\n        except Exception as e:\\n            print(f\\\"  Error '{d['title'][:30]}': {e}\\\")\\n\\n# ============================================\\n# LMS COURSES - title not course_title\\n# ============================================\\nprint(\\\"\\\\n=== Creating LMS Courses ===\\\")\\ncourses = [\\n    {\\\"title\\\": \\\"Navigating University: A First-Gen Guide\\\", \\\"short_introduction\\\": \\\"Everything you need to know about surviving and thriving at university as a first-generation student.\\\", \\\"published\\\": 1, \\\"enable_certification\\\": 1},\\n    {\\\"title\\\": \\\"Academic Writing for First-Gen Students\\\", \\\"short_introduction\\\": \\\"Master academic essay writing with techniques specifically designed for students new to university-level work.\\\", \\\"published\\\": 1, \\\"enable_certification\\\": 1},\\n    {\\\"title\\\": \\\"Career Planning from Day One\\\", \\\"short_introduction\\\": \\\"Start thinking about your career from your first week at university.\\\", \\\"published\\\": 1, \\\"enable_certification\\\": 0},\\n]\\n\\nfor c in courses:\\n    existing = frappe.db.get_value(\\\"LMS Course\\\", {\\\"title\\\": c[\\\"title\\\"]}, \\\"name\\\")\\n    if not existing:\\n        try:\\n            course = frappe.new_doc(\\\"LMS Course\\\")\\n            course.update(c)\\n            course.flags.ignore_permissions = True\\n            course.insert()\\n            frappe.db.commit()\\n            print(f\\\"  Created: {c['title']}\\\")\\n        except Exception as e:\\n            print(f\\\"  Error '{c['title'][:30]}': {e}\\\")\\n\\n# ============================================\\n# HD TICKETS - plain subject\\n# ============================================\\nprint(\\\"\\\\n=== Creating HD Tickets ===\\\")\\ntickets = [\\n    {\\\"subject\\\": \\\"Cannot access course materials on mobile\\\", \\\"description\\\": \\\"Hi, I'm trying to access the Navigating University course on my phone but the videos won't load.\\\", \\\"status\\\": \\\"Open\\\", \\\"priority\\\": \\\"Medium\\\", \\\"ticket_type\\\": \\\"Bug\\\"},\\n    {\\\"subject\\\": \\\"Request for additional mentoring sessions\\\", \\\"description\\\": \\\"I'd really like to request more mentoring sessions. The weekly sessions are great but I have a lot of questions.\\\", \\\"status\\\": \\\"Open\\\", \\\"priority\\\": \\\"Low\\\", \\\"ticket_type\\\": \\\"Feature\\\"},\\n    {\\\"subject\\\": \\\"How do I update my profile photo?\\\", \\\"description\\\": \\\"I can't find where to change my profile picture. The settings page doesn't seem to have the option.\\\", \\\"status\\\": \\\"Replied\\\", \\\"priority\\\": \\\"Low\\\", \\\"ticket_type\\\": \\\"Feature\\\"},\\n]\\n\\nfor t in tickets:\\n    existing = frappe.db.get_value(\\\"HD Ticket\\\", {\\\"subject\\\": t[\\\"subject\\\"]}, \\\"name\\\")\\n    if not existing:\\n        try:\\n            ticket = frappe.new_doc(\\\"HD Ticket\\\")\\n            ticket.update(t)\\n            ticket.flags.ignore_permissions = True\\n            ticket.insert()\\n            frappe.db.commit()\\n            print(f\\\"  Created: {t['subject'][:50]}\\\")\\n        except Exception as e:\\n            print(f\\\"  Error '{t['subject'][:30]}': {e}\\\")\\n\\n# ============================================\\n# FINAL VERIFICATION\\n# ============================================\\nprint(\\\"\\\\n=== FINAL COUNTS ===\\\")\\ntables = [\\\"User\\\", \\\"GP Team\\\", \\\"GP Project\\\", \\\"GP Discussion\\\", \\\"LMS Course\\\", \\\"HD Ticket\\\", \\\"HD Ticket Priority\\\", \\\"LMS Category\\\"]\\nfor t in tables:\\n    try:\\n        count = frappe.db.count(t)\\n        print(f\\\"  {t}: {count}\\\")\\n    except:\\n        print(f\\\"  {t}: ERROR\\\")\\n\\nprint(\\\"\\\\n=== SEED COMPLETE ===\\\")\\nfrappe.destroy()\\nPYEOF\\n\\ncp /tmp/seed_final.py /home/andiekobbie/frappe-bench/sites/seed_final.py\\n/home/andiekobbie/frappe-bench/env/bin/python /home/andiekobbie/frappe-bench/sites/seed_final.py 2>&1\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\seed_final.sh\"}",
