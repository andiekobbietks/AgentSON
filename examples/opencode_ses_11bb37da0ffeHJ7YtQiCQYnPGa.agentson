    {
      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\store.ts\", \"newString\": \"export function updateSSOProvider(id: SSOProviderId, patch: Partial<FGSSOProvider>) {\\n  const p = state.ssoProviders.find((x) => x.id === id);\\n  if (!p) return;\\n  Object.assign(p, patch);\\n  if (patch.enabled && !p.client_id_set && p.id !== \\\"email\\\") {\\n    p.client_id_set = true; // mocked: pretend admin pasted a client ID\\n  }\\n  emit();\\n}\\n\\n// ============================================================\\n// Polls\\n// ============================================================\\nexport const getPollForDiscussion = (discussionId: string): FGPoll | undefined =>\\n  state.polls.find((p) => p.discussion === discussionId);\\n\\nexport const getMyPollVote = (pollId: string): number | null =>\\n  state.pollVotes.find((v) => v.poll === pollId && v.user === currentUserId)?.option_index ?? null;\\n\\nexport function votePoll(pollId: string, optionIndex: number) {\\n  const poll = state.polls.find((p) => p.id === pollId);\\n  if (!poll || poll.is_closed) return;\\n\\n  // Remove existing vote if any\\n  const existing = state.pollVotes.findIndex((v) => v.poll === pollId && v.user === currentUserId);\\n  if (existing >= 0) {\\n    const oldVote = state.pollVotes[existing];\\n    poll.options[oldVote.option_index].votes--;\\n    state.pollVotes.splice(existing, 1);\\n  }\\n\\n  // Add new vote\\n  state.pollVotes.push({\\n    id: uid(\\\"pv\\\"),\\n    poll: pollId,\\n    user: currentUserId,\\n    option_index: optionIndex,\\n    created_at: new Date().toISOString(),\\n  });\\n  poll.options[optionIndex].votes++;\\n  emit();\\n}\\n\\nexport const totalPollVotes = (pollId: string): number => {\\n  const poll = state.polls.find((p) => p.id === pollId);\\n  return poll ? poll.options.reduce((sum, o) => sum + o.votes, 0) : 0;\\n};\", \"oldString\": \"export function updateSSOProvider(id: SSOProviderId, patch: Partial<FGSSOProvider>) {\\n  const p = state.ssoProviders.find((x) => x.id === id);\\n  if (!p) return;\\n  Object.assign(p, patch);\\n  if (patch.enabled && !p.client_id_set && p.id !== \\\"email\\\") {\\n    p.client_id_set = true; // mocked: pretend admin pasted a client ID\\n  }\\n  emit();\\n}\"}",
