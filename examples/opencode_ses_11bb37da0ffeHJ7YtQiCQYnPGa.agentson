      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\types.ts\", \"newString\": \"/** DocType (Frappe core): `Notification Log` */\\nexport interface FGNotification {\\n  id: string;\\n  for_user: string;\\n  subject: string;\\n  type: \\\"Mention\\\" | \\\"Reply\\\" | \\\"DM\\\" | \\\"Event\\\" | \\\"System\\\" | \\\"Mentor\\\";\\n  document_type: \\\"GP Discussion\\\" | \\\"FG DM Thread\\\" | \\\"FG Event\\\" | \\\"FG Mentor Match\\\" | \\\"HD Ticket\\\" | \\\"\\\";\\n  document_name: string;\\n  read: boolean;\\n  created_at: string;\\n}\\n\\n// \\u2014 mocked AI output (computed, not stored) \\u2014\\nexport type SentimentLabel = \\\"Positive\\\" | \\\"Neutral\\\" | \\\"Negative\\\" | \\\"Needs Attention\\\";\\n\\n// ============================================================\\n// frappe/erpnext \\u2014 Energy Points (gamification)\\n// ============================================================\\n\\n/** DocType: `Energy Point Rule` */\\nexport interface FGEnergyPointRule {\\n  id: string;\\n  name: string;\\n  reference_doctype: string;\\n  fieldname: string;\\n  points: number;\\n  rule: \\\"Every Time\\\" | \\\"Auto\\\";\\n  apply_once: boolean;\\n  disabled: boolean;\\n}\\n\\n/** DocType: `Energy Point Log` */\\nexport interface FGEnergyPointLog {\\n  id: string;\\n  user: string; // \\u2192 Link `User`\\n  type: \\\"Auto\\\" | \\\"Manual\\\" | \\\"Revert\\\";\\n  rule: string; // \\u2192 Link `Energy Point Rule`\\n  points: number;\\n  reason: string;\\n  reference_doctype: string;\\n  reference_name: string;\\n  created: string;\\n}\\n\\n/** DocType: `Energy Point Request` */\\nexport interface FGEnergyPointRequest {\\n  id: string;\\n  user: string;\\n  type: \\\"Review\\\" | \\\"Assign\\\";\\n  points: number;\\n  reason: string;\\n  status: \\\"Approved\\\" | \\\"Rejected\\\" | \\\"Pending\\\";\\n  requested_by: string;\\n  reference_doctype: string;\\n  reference_name: string;\\n}\\n\\n// ============================================================\\n// frappe/payments \\u2014 Billing / Subscription (Gherkin scenario 5)\\n// ============================================================\\n\\n/** DocType: `Subscription Plan` */\\nexport interface FGSubscriptionPlan {\\n  id: string;\\n  name: string;\\n  plan_name: string;\\n  price: number;\\n  currency: string;\\n  billing_interval: \\\"Daily\\\" | \\\"Weekly\\\" | \\\"Monthly\\\" | \\\"Yearly\\\";\\n  billing_interval_count: number;\\n  description: string;\\n}\\n\\n/** DocType: `Subscription Plan Detail` (child of Subscription) */\\nexport interface FGSubscriptionPlanDetail {\\n  plan: string; // \\u2192 Link `Subscription Plan`\\n  qty: number;\\n}\\n\\n/** DocType: `Subscription` (frappe/payments) */\\nexport interface FGSubscription {\\n  id: string;\\n  name: string;\\n  party_type: \\\"Customer\\\";\\n  party: string; // \\u2192 Link `Customer`\\n  party_name: string;\\n  status: \\\"Active\\\" | \\\"Cancelled\\\" | \\\"Past Due Date\\\" | \\\"Cancelled\\\" | \\\"Unpaid\\\" | \\\"Expired\\\" | \\\"Trial\\\" | \\\"New\\\" | \\\"Membership Hold\\\";\\n  start_date: string;\\n  end_date: string | null;\\n  trial_period_start: string | null;\\n  trial_period_end: string | null;\\n  current_invoice_start: string;\\n  current_invoice_end: string;\\n  days_until_due: number;\\n  generate_invoice_at: \\\"Beginning of the current billing period\\\" | \\\"End of the current billing period\\\" | \\\"After the current billing period ends\\\";\\n  plans: FGSubscriptionPlanDetail[];\\n  sales_invoice: string | null;\\n  cost_center: string;\\n  company: string;\\n}\\n\\n/** DocType: `Payment Plan` (simplified for prototype) */\\nexport interface FGPaymentPlan {\\n  id: string;\\n  plan_name: string;\\n  price: number;\\n  currency: string;\\n  billing_period: string;\\n  description: string;\\n  features: string[];\\n}\", \"oldString\": \"/** DocType (Frappe core): `Notification Log` */\\nexport interface FGNotification {\\n  id: string;\\n  for_user: string;\\n  subject: string;\\n  type: \\\"Mention\\\" | \\\"Reply\\\" | \\\"DM\\\" | \\\"Event\\\" | \\\"System\\\" | \\\"Mentor\\\";\\n  document_type: \\\"GP Discussion\\\" | \\\"FG DM Thread\\\" | \\\"FG Event\\\" | \\\"FG Mentor Match\\\" | \\\"\\\";\\n  document_name: string;\\n  read: boolean;\\n  created_at: string;\\n}\"}",
