    {
      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\store.ts\", \"newString\": \"export const totalPollVotes = (pollId: string): number => {\\n  const poll = state.polls.find((p) => p.id === pollId);\\n  return poll ? poll.options.reduce((sum, o) => sum + o.votes, 0) : 0;\\n};\\n\\n// ============================================================\\n// Gamification \\u2014 badges & energy points\\n// ============================================================\\nexport const getBadges = (): FGBadge[] => state.badges;\\n\\nexport const getBadgesForUser = (userId: string): { badge: FGBadge; awarded_at: string }[] =>\\n  state.badgeAwards\\n    .filter((a) => a.user === userId)\\n    .map((a) => {\\n      const badge = state.badges.find((b) => b.id === a.badge)!;\\n      return { badge, awarded_at: a.awarded_at };\\n    })\\n    .sort((a, b) => a.awarded_at.localeCompare(b.awarded_at));\\n\\nexport const getEnergyPoints = (userId: string): number =>\\n  state.energyPoints.find((e) => e.user === userId)?.points ?? 0;\\n\\nexport function awardBadgeIfNew(userId: string, badgeId: string) {\\n  const existing = state.badgeAwards.find((a) => a.user === userId && a.badge === badgeId);\\n  if (existing) return;\\n  state.badgeAwards.push({\\n    id: uid(\\\"ba\\\"),\\n    badge: badgeId,\\n    user: userId,\\n    awarded_at: new Date().toISOString(),\\n  });\\n  emit();\\n}\\n\\nexport function addEnergyPoints(userId: string, pts: number) {\\n  const ep = state.energyPoints.find((e) => e.user === userId);\\n  if (ep) ep.points += pts;\\n  else state.energyPoints.push({ user: userId, points: pts });\\n  emit();\\n}\", \"oldString\": \"export const totalPollVotes = (pollId: string): number => {\\n  const poll = state.polls.find((p) => p.id === pollId);\\n  return poll ? poll.options.reduce((sum, o) => sum + o.votes, 0) : 0;\\n};\"}",
