      "type": "action",
      "tool": "write",
      "code": "{\"content\": \"#!/bin/bash\\nexport PATH=\\\"/home/andiekobbie/.local/bin:/usr/bin:/usr/local/bin:/bin:$PATH\\\"\\ncd /home/andiekobbie/frappe-bench/apps/fg_companion\\n\\n# Create public folder for CSS\\nmkdir -p fg_companion/public/css\\n\\n# FirstGens Brand Theme CSS\\ncat > fg_companion/public/css/firstgens_theme.css << 'CSSEOF'\\n/*\\n * FirstGens Brand Theme\\n * Primary palette from firstgens.co.uk\\n * Green: #3e654a | Stone: #f6ede0 | Burnt Maroon: #37272f\\n * Clay: #d17147 | Yellow: #ffba56 | Khaki: #c1a167\\n * Blue: #8bc8d4 | Gray: #bfbfbf\\n */\\n\\n:root {\\n  --fg-green: #3e654a;\\n  --fg-green-light: #4a7d58;\\n  --fg-green-dark: #2d4a36;\\n  --fg-stone: #f6ede0;\\n  --fg-stone-dark: #e8dbc8;\\n  --fg-burnt-maroon: #37272f;\\n  --fg-clay: #d17147;\\n  --fg-clay-light: #e08a64;\\n  --fg-yellow: #ffba56;\\n  --fg-yellow-light: #ffc97a;\\n  --fg-khaki: #c1a167;\\n  --fg-camel: #da9e5d;\\n  --fg-blue: #8bc8d4;\\n  --fg-blue-light: #a5d8e1;\\n  --fg-gray: #bfbfbf;\\n  --fg-white: #ffffff;\\n  --fg-black: #000000;\\n}\\n\\n/* Frappe desk overrides */\\n:root {\\n  --primary: #3e654a !important;\\n  --primary-color: #3e654a !important;\\n  --btn-primary: #3e654a !important;\\n  --btn-primary-hover: #4a7d58 !important;\\n  --indicator-green: #3e654a !important;\\n  --sidebar-select-color: #3e654a !important;\\n}\\n\\n/* Frappe desk theming */\\n.frappe-control .control-value a,\\n.frappe-control .control-value {\\n  color: var(--fg-burnt-maroon);\\n}\\n\\n/* Primary buttons */\\n.btn-primary,\\n.btn-primary-dark {\\n  background-color: #3e654a !important;\\n  border-color: #3e654a !important;\\n  color: #fff !important;\\n}\\n\\n.btn-primary:hover,\\n.btn-primary:focus,\\n.btn-primary:active {\\n  background-color: #4a7d58 !important;\\n  border-color: #4a7d58 !important;\\n}\\n\\n.btn-primary-light {\\n  background-color: rgba(62, 101, 74, 0.1) !important;\\n  color: #3e654a !important;\\n  border-color: #3e654a !important;\\n}\\n\\n/* Navbar */\\n.navbar-brand,\\n.navbar .navbar-brand img {\\n  filter: none !important;\\n}\\n\\n/* Sidebar */\\n.layout-side-section {\\n  border-color: var(--fg-stone-dark) !important;\\n}\\n\\n/* Links */\\na {\\n  color: #3e654a;\\n}\\n\\na:hover {\\n  color: #4a7d58;\\n}\\n\\n/* Page head */\\n.page-head {\\n  border-bottom-color: var(--fg-stone-dark) !important;\\n}\\n\\n/* Indicator colors */\\n.indicator-pill[data-indicator=\\\"green\\\"] {\\n  --indicator-color: #3e654a;\\n}\\n\\n/* Form controls */\\n.form-control:focus {\\n  border-color: #3e654a;\\n  box-shadow: 0 0 0 0.125rem rgba(62, 101, 74, 0.25);\\n}\\n\\n/* Wiki sidebar */\\n.wiki-sidebar .sidebar-label {\\n  color: #3e654a;\\n}\\n\\n/* Helpdesk */\\n.hd-navbar {\\n  background-color: #3e654a !important;\\n}\\n\\n/* LMS */\\n.lms-header {\\n  background-color: #3e654a !important;\\n}\\n\\n/* Gameplan */\\n.gp-sidebar {\\n  border-color: var(--fg-stone-dark) !important;\\n}\\n\\n/* Cards */\\n.card {\\n  border-color: var(--fg-stone-dark) !important;\\n}\\n\\n.card-header {\\n  background-color: var(--fg-stone) !important;\\n  border-color: var(--fg-stone-dark) !important;\\n}\\n\\n/* Login page */\\n.for-login {\\n  background-color: var(--fg-stone) !important;\\n}\\n\\n.page-card {\\n  border-color: var(--fg-stone-dark) !important;\\n}\\n\\n.page-card .page-card-head {\\n  background-color: var(--fg-green) !important;\\n  color: #fff !important;\\n}\\nCSSEOF\\n\\n# Create hooks.py entry for the CSS\\ncat > fg_companion/hooks.py << 'HOOKEOF'\\napp_name = \\\"fg_companion\\\"\\napp_title = \\\"FirstGens Companion\\\"\\napp_publisher = \\\"FirstGens\\\"\\napp_description = \\\"Community mentoring events and support for first-generation students\\\"\\napp_version = \\\"0.0.1\\\"\\napp_color = \\\"#3e654a\\\"\\napp_icon = \\\"octicon octicon-file-directory\\\"\\napp_email = \\\"admin@firstgens.test\\\"\\napp_license = \\\"MIT\\\"\\n\\n# Include custom CSS in desk\\napp_include_css = \\\"/assets/fg_companion/css/firstgens_theme.css\\\"\\n\\n# Website route rules\\nwebsite_route_rules = [\\n    {\\n        \\\"from_route\\\": \\\"/firstgens/<path:app_path>\\\",\\n        \\\"to_route\\\": \\\"firstgens\\\",\\n    }\\n]\\nHOOKEOF\\n\\necho \\\"=== Created theme and hooks ===\\\"\\nls -la fg_companion/public/css/\\ncat fg_companion/hooks.py\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\brand_theme.sh\"}",
