sion: \\\"2\\\",\\n    question: \\\"Will you attend the welcome breakfast?\\\",\\n    options: [\\n      { text: \\\"Yes, I'll be there!\\\", votes: 12 },\\n      { text: \\\"Maybe, depends on my schedule\\\", votes: 5 },\\n      { text: \\\"Can't make it\\\", votes: 3 },\\n    ],\\n    created_by: \\\"rosa@firstgens.test\\\",\\n    created_at: daysAgo(2),\\n    is_anonymous: false,\\n    is_closed: false,\\n  },\\n];\\n\\nexport const seedPollVotes: FGPollVote[] = [\\n  { id: \\\"pv_1\\\", poll: \\\"poll_1\\\", user: \\\"maya@firstgens.test\\\", option_index: 2, created_at: daysAgo(2) },\\n  { id: \\\"pv_2\\\", poll: \\\"poll_1\\\", user: \\\"jordan@firstgens.test\\\", option_index: 1, created_at: daysAgo(2) },\\n  { id: \\\"pv_3\\\", poll: \\\"poll_2\\\", user: \\\"maya@firstgens.test\\\", option_index: 0, created_at: daysAgo(1) },\\n];\", \"oldString\": \"export const seedSSOProviders: FGSSOProvider[] = [\\n  {\\n    id: \\\"email\\\",\\n    label: \\\"Email & password\\\",\\n    enabled: true,\\n    client_id_set: true,\\n    notes: \\\"Built-in. Always available.\\\",\\n  },\\n  {\\n    id: \\\"google\\\",\\n    label: \\\"Google\\\",\\n    enabled: false,\\n    client_id_set: false,\\n    notes: \\\"Workspace + personal Google accounts.\\\",\\n  },\\n  {\\n    id: \\\"microsoft\\\",\\n    label: \\\"Microsoft / Teams\\\",\\n    enabled: false,\\n    client_id_set: false,\\n    notes: \\\"Azure AD / Entra ID \\u2014 supports MS Teams SSO.\\\",\\n  },\\n  {\\n    id: \\\"github\\\",\\n    label: \\\"GitHub\\\",\\n    enabled: false,\\n    client_id_set: false,\\n    notes: \\\"Good for STEM cohorts.\\\",\\n  },\\n  {\\n    id: \\\"discord\\\",\\n    label: \\\"Discord\\\",\\n    enabled: false,\\n    client_id_set: false,\\n    notes: \\\"Popular with student communities.\\\",\\n  },\\n  {\\n    id: \\\"apple\\\",\\n    label: \\\"Apple\\\",\\n    enabled: false,\\n    client_id_set: false,\\n    notes: \\\"Required if you ship a native iOS app.\\\",\\n  },\\n]