      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\store.ts\", \"newString\": \"export const getDMThreadsForUser = (userId = currentUserId): FGDMThread[] =>\\n  [...state.dmThreads]\\n    .filter((t) => t.dm_user_1 === userId || t.dm_user_2 === userId)\\n    .sort((a, b) => b.last_message_at.localeCompare(a.last_message_at));\\n\\nexport const getDMThread = (id: string) => state.dmThreads.find((t) => t.id === id);\\n\\nexport const getDMMessages = (threadId: string): FGDMMessage[] =>\\n  state.dmMessages\\n    .filter((m) => m.channel === threadId)\\n    .sort((a, b) => a.created_at.localeCompare(b.created_at));\\n\\nexport const getOtherMember = (thread: FGDMThread, userId = currentUserId) =>\\n  thread.dm_user_1 === userId ? thread.dm_user_2 : thread.dm_user_1;\\n\\nexport function openOrCreateDMWith(otherUserId: string): FGDMThread {\\n  if (otherUserId === currentUserId) {\\n    return state.dmThreads[0];\\n  }\\n  const existing = state.dmThreads.find(\\n    (t) =>\\n      (t.dm_user_1 === currentUserId && t.dm_user_2 === otherUserId) ||\\n      (t.dm_user_2 === currentUserId && t.dm_user_1 === otherUserId),\\n  );\\n  if (existing) return existing;\\n  const t: FGDMThread = {\\n    id: uid(\\\"dm\\\"),\\n    channel_type: \\\"DM\\\",\\n    is_direct_message: true,\\n    is_thread: false,\\n    is_self_message: false,\\n    dm_user_1: currentUserId,\\n    dm_user_2: otherUserId,\\n    workspace: \\\"\\\",\\n    last_message_at: new Date().toISOString(),\\n    last_message_preview: \\\"\\\",\\n  };\\n  state.dmThreads.unshift(t);\\n  emit();\\n  return t;\\n}\\n\\nexport function sendDM(threadId: string, content: string): FGDMMessage | null {\\n  const t = getDMThread(threadId);\\n  if (!t || !content.trim()) return null;\\n  const m: FGDMMessage = {\\n    id: uid(\\\"m\\\"),\\n    channel: threadId,\\n    sender: currentUserId,\\n    text: content.trim(),\\n    message_type: \\\"Text\\\",\\n    file: \\\"\\\",\\n    image_width: 0,\\n    image_height: 0,\\n    content: content.trim(),\\n    created_at: new Date().toISOString(),\\n    read_by: [currentUserId],\\n  };\\n  state.dmMessages.push(m);\\n  t.last_message_at = m.created_at;\\n  t.last_message_preview = m.content.slice(0, 80);\\n  emit();\\n  return m;\\n}\", \"oldString\": \"export const getDMThreadsForUser = (userId = currentUserId): FGDMThread[] =>\\n  [...state.dmThreads]\\n    .filter((t) => t.member_a === userId || t.member_b === userId)\\n    .sort((a, b) => b.last_message_at.localeCompare(a.last_message_at));\\n\\nexport const getDMThread = (id: string) => state.dmThreads.find((t) => t.id === id);\\n\\nexport const getDMMessages = (threadId: string): FGDMMessage[] =>\\n  state.dmMessages\\n    .filter((m) => m.thread === threadId)\\n    .sort((a, b) => a.created_at.localeCompare(b.created_at));\\n\\nexport const getOtherMember = (thread: FGDMThread, userId = currentUserId) =>\\n  thread.member_a === userId ? thread.member_b : thread.member_a;\\n\\nexport function openOrCreateDMWith(otherUserId: string): FGDMThread {\\n  if (otherUserId === currentUserId) {\\n    return state.dmThreads[0];\\n  }\\n  const existing = state.dmThreads.find(\\n    (t) =>\\n      (t.member_a === currentUserId && t.member_b === otherUserId) ||\\n      (t.member_b === currentUserId && t.member_a === otherUserId),\\n  );\\n  if (existing) return existing;\\n  const t: FGDMThread = {\\n    id: uid(\\\"dm\\\"),\\n    member_a: currentUserId,\\n    member_b: otherUserId,\\n    last_message_at: new Date().toISOString(),\\n    last_message_preview: \\\"\\\",\\n  };\\n  state.dmThreads.unshift(t);\\n  emit();\\n  return t;\\n}\\n\\nexport function sendDM(threadId: string, content: string): FGDMMessage | null {\\n  const t = getDMThread(threadId);\\n  if (!t || !content.trim()) return null;\\n  const m: FGDMMessage = {\\n    id: uid(\\\"m\\\"),\\n    thread: threadId,\\n    sender: currentUserId,\\n    content: content.trim(),\\n    created_at: new Date().toISOString(),\\n    read_by: [currentUserId],\\n  };\\n  state.dmMessages.push(m);\\n  t.last_message_at = m.created_at;\\n  t.last_message_preview = m.content.slice(0, 80);\\n  emit();\\n  return m;\\n}\"}",
