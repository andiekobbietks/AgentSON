      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\views\\\\MemberDetailView.vue\", \"newString\": \"        <section class=\\\"mt-6\\\">\\n          <h2 class=\\\"text-[14px] font-semibold text-muted-foreground uppercase tracking-wider mb-3\\\">\\n            Achievements\\n          </h2>\\n          <div v-if=\\\"badges.length === 0\\\" class=\\\"text-[13px] text-muted-foreground py-6 text-center border border-dashed border-border rounded-xl\\\">\\n            No badges yet \\u2014 keep contributing!\\n          </div>\\n          <div v-else class=\\\"flex flex-wrap gap-3\\\">\\n            <div\\n              v-for=\\\"b in badges\\\"\\n              :key=\\\"b.badge.id\\\"\\n              class=\\\"flex items-center gap-2 px-3 py-2 rounded-xl bg-card border border-border\\\"\\n              :title=\\\"`Awarded ${new Date(b.awarded_at).toLocaleDateString()}`\\\"\\n            >\\n              <span class=\\\"text-xl\\\">{{ b.badge.icon }}</span>\\n              <div>\\n                <div class=\\\"text-[13px] font-semibold\\\">{{ b.badge.name }}</div>\\n                <div class=\\\"text-[11px] text-muted-foreground\\\">{{ b.badge.description }}</div>\\n              </div>\\n            </div>\\n          </div>\\n          <div v-if=\\\"energyPoints > 0\\\" class=\\\"mt-3 text-[13px] text-muted-foreground\\\">\\n            \\u26a1 {{ energyPoints }} energy points\\n          </div>\\n        </section>\\n\\n        <section class=\\\"mt-6\\\">\\n          <h2 class=\\\"text-[14px] font-semibold text-muted-foreground uppercase tracking-wider mb-3\\\">\\n            Recent posts\\n          </h2>\", \"oldString\": \"        <section>\\n          <h2 class=\\\"text-[14px] font-semibold text-muted-foreground uppercase tracking-wider mb-3\\\">\\n            Recent posts\\n          </h2>\"}",
