      "code": "{\"content\": \"#!/bin/bash\\nexport PATH=\\\"/home/andiekobbie/.local/bin:/usr/bin:/usr/local/bin:/bin:$PATH\\\"\\n\\ncat > /tmp/seed_remaining.py << 'PYEOF'\\nimport frappe\\nimport os\\n\\nos.chdir(\\\"/home/andiekobbie/frappe-bench/sites\\\")\\nfrappe.init(\\\"firstgens.localhost\\\")\\nfrappe.connect()\\n\\n# ============================================\\n# GP DISCUSSIONS - direct SQL to bypass hook errors\\n# ============================================\\nprint(\\\"=== Creating Discussions (SQL) ===\\\")\\n\\n# Check if there's a naming series\\ntry:\\n    existing = frappe.db.sql(\\\"SELECT name FROM `tabGP Discussion` LIMIT 1\\\", as_list=True)\\n    print(f\\\"  Existing discussions: {existing}\\\")\\nexcept Exception as e:\\n    print(f\\\"  Error checking: {e}\\\")\\n\\ndiscussions = [\\n    (\\\"Welcome to FirstGens! Introduce yourself here\\\", \\\"Welcome & Introductions\\\", \\\"alaya@firstgens.test\\\",\\n     \\\"Hey everyone! I'm Alaya, the founder of FirstGens. I was the first in my family to go to university and I know how isolating it can feel.\\\"),\\n    (\\\"How do you deal with imposter syndrome?\\\", \\\"Mental Health & Wellbeing\\\", \\\"maya@firstgens.test\\\",\\n     \\\"Does anyone else feel like they don't belong at uni? I got good grades but constantly feel like I'm going to be found out.\\\"),\\n    (\\\"Best resources for essay writing?\\\", \\\"Study Tips & Resources\\\", \\\"sam@firstgens.test\\\",\\n     \\\"I'm in my first year and the jump from A-levels to uni essays is massive.\\\"),\\n    (\\\"Networking events - how to actually do them?\\\", \\\"Career Guidance\\\", \\\"priya@firstgens.test\\\",\\n     \\\"I went to a careers fair last week and had no idea what to say to the employers.\\\"),\\n    (\\\"Managing finances as a first-gen student\\\", \\\"Navigating University\\\", \\\"rosa@firstgens.test\\\",\\n     \\\"First-gen students often don't have the financial safety net that others do.\\\"),\\n    (\\\"Workshop recap: Building Your Support Network\\\", \\\"Upcoming Events\\\", \\\"jordan@firstgens.test\\\",\\n     \\\"Great turnout at yesterday's workshop! Key takeaways: build relationships with your personal tutor.\\\"),\\n]\\n\\n# Get max existing name number\\nmax_num = frappe.db.sql(\\\"SELECT IFNULL(MAX(CAST(SUBSTRING_INDEX(name, '-', -1) AS UNSIGNED)), 0) FROM `tabGP Discussion` WHERE name LIKE 'GP-DISC-%'\\\", as_list=True)[0][0]\\nnext_num = int(max_num) + 1 if max_num else 1\\n\\nfor title, project, owner, content in discussions:\\n    existing = frappe.db.get_value(\\\"GP Discussion\\\", {\\\"title\\\": title}, \\\"name\\\")\\n    if not existing:\\n        disc_name = f\\\"GP-DISC-{next_num:04d}\\\"\\n        next_num += 1\\n        try:\\n            frappe.db.sql(\\\"\\\"\\\"INSERT INTO `tabGP Discussion`\\n                (name, title, content, project, status, owner, creation, modified, modified_by, docstatus,\\n                 last_post_at, last_post_by, comments_count, participants_count, idx, slug)\\n                VALUES (%s, %s, %s, %s, 'Open', %s, NOW(), NOW(), 'Administrator', 0,\\n                 NOW(), %s, 0, 0, 1, %s)\\\"\\\"\\\",\\n                (disc_name, title, content, project, owner, owner, title.lower().replace(' ', '-').replace('!', '').replace('?', '').replace(':', '').replace(',', '')[:60]))\\n            frappe.db.commit()\\n            print(f\\\"  Created: {title[:50]}...\\\")\\n        except Exception as e:\\n            print(f\\\"  Error '{title[:30]}': {e}\\\")\\n    else:\\n        print(f\\\"  Already exists: {title[:50]}\\\")\\n\\n# ============================================\\n# LMS COURSES - add instructors & description\\n# ============================================\\nprint(\\\"\\\\n=== Creating LMS Courses (SQL) ===\\\")\\n\\n# Check LMS Course Instructor table\\ntry:\\n    rows = frappe.db.sql(\\\"SHOW COLUMNS FROM `tabCourse Instructor`\\\", as_list=True)\\n    print(f\\\"  Course Instructor columns: {[r[0] for r in rows]}\\\")\\nexcept Exception as e:\\n    print(f\\\"  Course Instructor table: {e}\\\")\\n\\ncourses = [\\n    (\\\"Navigating University: A First-Gen Guide\\\", \\\"Everything you need to know about surviving and thriving at university as a first-generation student.\\\",\\n     \\\"alaya@firstgens.test\\\", \\\"Getting Started\\\"),\\n    (\\\"Academic Writing for First-Gen Students\\\", \\\"Master academic essay writing with techniques specifically designed for students new to university-level work.\\\",\\n     \\\"jordan@firstgens.test\\\", \\\"Academic Skills\\\"),\\n    (\\\"Career Planning from Day One\\\", \\\"Start thinking about your career from your first week at university.\\\",\\n     \\\"priya@firstgens.test\\\", \\\"Career Development\\\"),\\n]\\n\\nmax_num = frappe.db.sql(\\\"SELECT IFNULL(MAX(CAST(SUBSTRING_INDEX(name, '-', -1) AS UNSIGNED)), 0) FROM `tabLMS Course` WHERE name LIKE 'LMC-%'\\\", as_list=True)[0][0]\\nnext_num = int(max_num) + 1 if max_num else 1\\n\\nfor title, intro, instructor, category in courses:\\n    existing = frappe.db.get_value(\\\"LMS Course\\\", {\\\"title\\\": title}, \\\"name\\\")\\n    if not existing:\\n        course_name = f\\\"LMC-{next_num:04d}\\\"\\n        next_num += 1\\n        try:\\n            frappe.db.sql(\\\"\\\"\\\"INSERT INTO `tabLMS Course`\\n                (name, title, short_introduction, description, category, instructor, published, enable_certification,\\n                 enrollment, creation, modified, modified_by, owner, docstatus, idx, published_on)\\n                VALUES (%s, %s, %s, %s, %s, %s, 1, 0, 0, NOW(), NOW(), 'Administrator', 'Administrator', 0, 1, CURDATE())\\\"\\\"\\\",\\n                (course_name, title, intro, intro, category, instructor))\\n            frappe.db.commit()\\n            print(f\\\"  Created: {title}\\\")\\n            \\n            # Create instructor record\\n            try:\\n                frappe.db.sql(\\\"\\\"\\\"INSERT INTO `tabCourse Instructor`\\n                    (name, parent, parentfield, parenttype, instructor, idx, creation, modified, modified_by, owner, docstatus)\\n                    VALUES (%s, %s, 'instructors', 'LMS Course', %s, 1, NOW(), NOW(), 'Administrator', 'Administrator', 0)\\\"\\\"\\\",\\n                    (f\\\"{course_name}-INST-0001\\\", course_name, instructor))\\n                frappe.db.commit()\\n                print(f\\\"    Added instructor: {instructor}\\\")\\n            except Exception as e:\\n                print(f\\\"    Instructor error: {e}\\\")\\n        except Exception as e:\\n            print(f\\\"  Error '{title[:30]}': {e}\\\")\\n\\n# ============================================\\n# HD TICKETS - direct SQL\\n# ============================================\\nprint(\\\"\\\\n=== Creating HD Tickets (SQL) ===\\\")\\ntickets = [\\n    (\\\"Cannot access course materials on mobile\\\", \\\"Hi, I'm trying to access the Navigating University course on my phone but the videos won't load.\\\", \\\"Open\\\", \\\"Medium\\\", \\\"Bug\\\"),\\n    (\\\"Request for additional mentoring sessions\\\", \\\"I'd really like to request more mentoring sessions. The weekly sessions are great but I have a lot of questions.\\\", \\\"Open\\\", \\\"Low\\\", \\\"Feature\\\"),\\n    (\\\"How do I update my profile photo?\\\", \\\"I can't find where to change my profile picture. The settings page doesn't seem to have the option.\\\", \\\"Replied\\\", \\\"Low\\\", \\\"Feature\\\"),\\n]\\n\\nmax_num = frappe.db.sql(\\\"SELECT IFNULL(MAX(CAST(SUBSTRING_INDEX(name, '-', -1) AS UNSIGNED)), 0) FROM `tabHD Ticket` WHERE name LIKE 'TKT-%'\\\", as_list=True)[0][0]\\nnext_num = int(max_num) + 1 if max_num else 1\\n\\nfor subject, desc, status, priority, ttype in tickets:\\n    existing = frappe.db.get_value(\\\"HD Ticket\\\", {\\\"subject\\\": subject}, \\\"name\\\")\\n    if not existing:\\n        ticket_name = f\\\"TKT-{next_num:04d}\\\"\\n        next_num += 1\\n        try:\\n            frappe.db.sql(\\\"\\\"\\\"INSERT INTO `tabHD Ticket`\\n                (name, subject, description, status, priority, ticket_type, owner, creation, modified, modified_by, docstatus, idx,\\n                 opening_date, via_customer_portal, content_type, is_merged)\\n                VALUES (%s, %s, %s, %s, %s, %s, 'Administrator', NOW(), NOW(), 'Administrator', 0, 1,\\n                 CURDATE(), 0, 'Text', 0)\\\"\\\"\\\",\\n                (ticket_name, subject, desc, status, priority, ttype))\\n            frappe.db.commit()\\n            print(f\\\"  Created: {subject[:50]}\\\")\\n        except Exception as e:\\n            print(f\\\"  Error '{subject[:30]}': {e}\\\")\\n\\n# ============================================\\n# FINAL VERIFICATION\\n# ============================================\\nprint(\\\"\\\\n=== FINAL COUNTS ===\\\")\\ntables = [(\\\"User\\\", \\\"User\\\"), (\\\"GP Team\\\", \\\"GP Team\\\"), (\\\"GP Project\\\", \\\"GP Project\\\"), \\n          (\\\"GP Discussion\\\", \\\"GP Discussion\\\"), (\\\"LMS Course\\\", \\\"LMS Course\\\"), \\n          (\\\"HD Ticket\\\", \\\"HD Ticket\\\"), (\\\"HD Ticket Priority\\\", \\\"HD Ticket Priority\\\"), \\n          (\\\"LMS Category\\\", \\\"LMS Category\\\")]\\nfor label, doctype in tables:\\n    try:\\n        count = frappe.db.count(doctype)\\n        print(f\\\"  {label}: {count}\\\")\\n    except:\\n        print(f\\\"  {label}: ERROR\\\")\\n\\n# Verify discussions\\nprint(\\\"\\\\n=== Discussions ===\\\")\\ndiscs = frappe.db.sql(\\\"SELECT name, title, project, owner FROM `tabGP Discussion`\\\", as_list=True)\\nfor d in discs:\\n    print(f\\\"  {d[0]} | {d[1][:40]} | {d[2]} | {d[3]}\\\")\\n\\n# Verify courses\\nprint(\\\"\\\\n=== Courses ===\\\")\\ncourses = frappe.db.sql(\\\"SELECT name, title, category FROM `tabLMS Course`\\\", as_list=True)\\nfor c in courses:\\n    print(f\\\"  {c[0]} | {c[1][:40]} | {c[2]}\\\")\\n\\n# Verify tickets\\nprint(\\\"\\\\n=== Tickets ===\\\")\\ntickets = frappe.db.sql(\\\"SELECT name, subject, status, priority FROM `tabHD Ticket`\\\", as_list=True)\\nfor t in tickets:\\n    print(f\\\"  {t[0]} | {t[1][:40]} | {t[2]} | {t[3]}\\\")\\n\\nprint(\\\"\\\\n=== ALL SEEDING COMPLETE ===\\\")\\nfrappe.destroy()\\nPYEOF\\n\\ncp /tmp/seed_remaining.py /home/andiekobbie/frappe-bench/sites/seed_remaining.py\\n/home/andiekobbie/frappe-bench/env/bin/python /home/andiekobbie/frappe-bench/sites/seed_remaining.py 2>&1\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\seed_remaining.sh\"}",
