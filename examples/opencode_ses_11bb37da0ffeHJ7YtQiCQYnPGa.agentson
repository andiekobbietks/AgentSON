    {
      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\store.ts\", \"newString\": \"export function markLessonComplete(lessonId: string, complete: boolean) {\\n  const lesson = getLesson(lessonId);\\n  if (!lesson) return;\\n  const idx = state.progress.findIndex((p) => p.lesson === lessonId && p.member === currentUserId);\\n  if (complete) {\\n    if (idx >= 0) state.progress[idx].status = \\\"Complete\\\";\\n    else\\n      state.progress.push({\\n        id: uid(\\\"prg\\\"),\\n        member: currentUserId,\\n        member_name: getUser(currentUserId)?.full_name ?? currentUserId,\\n        course: lesson.course,\\n        chapter: lesson.chapter,\\n        lesson: lessonId,\\n        status: \\\"Complete\\\",\\n        is_scorm_chapter: false,\\n      });\\n  } else if (idx >= 0) {\\n    state.progress.splice(idx, 1);\\n  }\\n  const enr = getEnrollment(lesson.course);\\n  if (enr) enr.progress = courseProgressPercent(lesson.course);\\n  emit();\\n}\", \"oldString\": \"export function markLessonComplete(lessonId: string, complete: boolean) {\\n  const lesson = getLesson(lessonId);\\n  if (!lesson) return;\\n  const idx = state.progress.findIndex((p) => p.lesson === lessonId && p.member === currentUserId);\\n  if (complete) {\\n    if (idx >= 0) state.progress[idx].status = \\\"Complete\\\";\\n    else\\n      state.progress.push({\\n        id: uid(\\\"prg\\\"),\\n        member: currentUserId,\\n        course: lesson.course,\\n        lesson: lessonId,\\n        status: \\\"Complete\\\",\\n      });\\n  } else if (idx >= 0) {\\n    state.progress.splice(idx, 1);\\n  }\\n  const enr = getEnrollment(lesson.course);\\n  if (enr) enr.progress = courseProgressPercent(lesson.course);\\n  emit();\\n}\"}",
