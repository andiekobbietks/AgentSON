      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\store.ts\", \"newString\": \"export function setRSVP(eventId: string, status: RSVPStatus) {\\n  const existing = state.attendees.find((a) => a.event === eventId && a.user === currentUserId);\\n  if (existing) existing.rsvp_status = status;\\n  else\\n    state.attendees.push({\\n      id: uid(\\\"a\\\"),\\n      event: eventId,\\n      user: currentUserId,\\n      rsvp_status: status,\\n    });\\n  emit();\\n}\\n\\nexport function createEvent(input: {\\n  title: string;\\n  description: string;\\n  starts_on: string;\\n  event_type: string;\\n}) {\\n  const evt = {\\n    id: uid(\\\"evt\\\"),\\n    title: input.title.trim(),\\n    description: input.description,\\n    space: null,\\n    event_type: input.event_type,\\n    starts_on: new Date(input.starts_on).toISOString(),\\n    ends_on: new Date(new Date(input.starts_on).getTime() + 3600000).toISOString(),\\n    location_type: \\\"Online (External Link)\\\" as const,\\n    bbb_meeting_id: null,\\n    external_link: null,\\n    physical_address: null,\\n    rsvp_required: false,\\n    capacity: 50,\\n    hosted_by: currentUserId,\\n  };\\n  state.events.push(evt);\\n  emit();\\n  return evt;\\n}\", \"oldString\": \"export function setRSVP(eventId: string, status: RSVPStatus) {\\n  const existing = state.attendees.find((a) => a.event === eventId && a.user === currentUserId);\\n  if (existing) existing.rsvp_status = status;\\n  else\\n    state.attendees.push({\\n      id: uid(\\\"a\\\"),\\n      event: eventId,\\n      user: currentUserId,\\n      rsvp_status: status,\\n    });\\n  emit();\\n}\"}",
