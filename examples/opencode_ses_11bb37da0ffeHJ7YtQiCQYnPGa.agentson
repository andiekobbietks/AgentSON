      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\styles.css</path>\n<type>file</type>\n<content>\n1: @import \"tailwindcss\";\n2: @import \"tw-animate-css\";\n3: \n4: @custom-variant dark (&:is(.dark *));\n5: \n6: /*\n7:  * Design system — high-fidelity Circle.so look.\n8:  *\n9:  * Light surfaces, single violet accent (community-swappable), Inter throughout,\n10:  * border-only cards (no shadow at rest), generous whitespace.\n11:  */\n12: \n13: @theme inline {\n14:   --font-sans: \"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n15:   --font-display: \"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n16: \n17:   --radius: 0.75rem;\n18:   --radius-sm: 0.375rem;   /* 6px — sidebar items */\n19:   --radius-md: 0.5rem;     /* 8px — inputs */\n20:   --radius-lg: 0.75rem;    /* 12px — cards */\n21:   --radius-xl: 1rem;       /* 16px — modals */\n22:   --radius-2xl: 1.25rem;\n23: \n24:   --color-background: var(--background);\n25:   --color-foreground: var(--foreground);\n26:   --color-surface: var(--surface);\n27:   --color-card: var(--card);\n28:   --color-card-foreground: var(--card-foreground);\n29:   --color-popover: var(--popover);\n30:   --color-popover-foreground: var(--popover-foreground);\n31:   --color-primary: var(--primary);\n32:   --color-primary-foreground: var(--primary-foreground);\n33:   --color-primary-soft: var(--primary-soft);\n34:   --color-primary-soft-foreground: var(--primary-soft-foreground);\n35:   --color-secondary: var(--secondary);\n36:   --color-secondary-foreground: var(--secondary-foreground);\n37:   --color-muted: var(--muted);\n38:   --color-muted-foreground: var(--muted-foreground);\n39:   --color-subtle: var(--subtle);\n40:   --color-accent: var(--accent);\n41:   --color-accent-foreground: var(--accent-foreground);\n42:   --color-destructive: var(--destructive);\n43:   --color-destructive-foreground: var(--destructive-foreground);\n44:   --color-border: var(--border);\n45:   --color-border-strong: var(--border-strong);\n46:   --color-input: var(--input);\n47:   --color-ring: var(--ring);\n48:   --color-flag: var(--flag);\n49:   --color-flag-foreground: var(--flag-foreground);\n50:   --color-success: var(--success);\n51:   --color-sidebar: var(--sidebar);\n52:   --color-sidebar-foreground: var(--sidebar-foreground);\n53:   --color-sidebar-border: var(--sidebar-border);\n54:   --color-sidebar-accent: var(--sidebar-accent);\n55: \n56:   --shadow-card: 0 1px 3px rgba(15, 23, 42, 0.06), 0 1px 2px rgba(15, 23, 42, 0.04);\n57:   --shadow-modal: 0 20px 60px rgba(15, 23, 42, 0.12);\n58:   --shadow-dropdown: 0 4px 16px rgba(15, 23, 42, 0.08);\n59: }\n60: \n61: :root {\n62:   /* frappe-ui base tokens (Light Mode) */\n63:   --surface-base: oklch(0.985 0.002 247);          /* #f9fafb — page background */\n64:   --surface-card: oklch(1 0 0);                    /* #ffffff — card background */\n65:   --surface-sidebar: oklch(1 0 0);                 /* #ffffff — sidebar */\n66:   --ink-base: oklch(0.18 0.02 250);                /* #111827 — primary text */\n67:   \n68:   /* frappe-ui gray surfaces */\n69:   --surface-gray-2: oklch(0.96 0.003 247);         /* #f3f4f6 gray-100 */\n70:   --surface-gray-3: oklch(0.91 0.005 247);         /* #e5e7eb gray-200 */\n71:   --surface-gray-9: oklch(0.27 0.02 250);          /* #374151 gray-700 */\n72:   --surface-gray-10: oklch(0.18 0.02 250);         /* #111827 gray-900 */\n73: \n74:   /* frappe-ui gray ink (typography) */\n75:   --ink-gray-4: oklch(0.7 0.02 250);               /* #9ca3af gray-400 */\n76:   --ink-gray-5: oklch(0.5 0.02 250);               /* #6b7280 gray-500 */\n77:   --ink-gray-8: oklch(0.27 0.02 250);              /* #374151 gray-700 */\n78:   --ink-gray-9: oklch(0.18 0.02 250);              /* #111827 gray-900 */\n79: \n80:   /* frappe-ui outlines (borders) */\n81:   --outline-gray-1: oklch(0.96 0.003 247);         /* #f3f4f6 border */\n82:   --outline-gray-2: oklch(0.91 0.005 247);         /* #e5e7eb border */\n83:   --outline-gray-4: oklch(0.84 0.008 247);         /* #d1d5db border */\n84: \n85:   /* frappe-ui red (destructive) */\n86:   --surface-red-2: oklch(0.95 0.02 25);            /* soft red */\n87:   --surface-red-3: oklch(0.9 0.05 25);\n88:   --ink-red: oklch(0.6 0.22 25);                   /* #ef4444 */\n89: \n90:   /* frappe-ui amber (AI flagged alerts) */\n91:   --surface-amber-2: oklch(0.97 0.05 80);          /* soft amber */\n92:   --ink-amber: oklch(0.55 0.13 70);                /* #d97706 */\n93: \n94:   /* Violet accent — community swappable */\n95:   --primary: oklch(0.51 0.21 290);                 /* #7c3aed violet-600 */\n96:   --primary-foreground: oklch(1 0 0);\n97:   --primary-soft: oklch(0.95 0.03 290);            /* #ede9fe violet-100 */\n98:   --primary-soft-foreground: oklch(0.41 0.2 290);  /* #5b21b6 violet-800 */\n99:   --ring: oklch(0.51 0.21 290);\n100:   --success: oklch(0.7 0.17 145);                  /* #22c55e */\n101: \n102:   /* Map standard theme names to our frappe-ui variables */\n103:   --background: var(--surface-base);\n104:   --surface: var(--surface-card);\n105:   --foreground: var(--ink-base);\n106:   --card: var(--surface-card);\n107:   --card-foreground: var(--ink-base);\n108:   --popover: var(--surface-card);\n109:   --popover-foreground: var(--ink-base);\n110:   --secondary: var(--surface-gray-2);\n111:   --secondary-foreground: var(--ink-gray-8);\n112:   --muted: var(--surface-gray-2);\n113:   --muted-foreground: var(--ink-gray-5);\n114:   --subtle: var(--surface-gray-3);\n115:   --accent: var(--primary-soft);\n116:   --accent-foreground: var(--primary-soft-foreground);\n117:   --destructive: var(--surface-red-2);\n118:   --destructive-foreground: var(--ink-red);\n119:   --border: var(--outline-gray-2);\n120:   --border-strong: var(--outline-gray-4);\n121:   --input: var(--surface-gray-2);\n122:   --flag: var(--surface-amber-2);\n123:   --flag-foreground: var(--ink-amber);\n124: \n125:   --sidebar: var(--surface-sidebar);\n126:   --sidebar-foreground: var(--ink-gray-8);\n127:   --sidebar-border: var(--outline-gray-2);\n128:   --sidebar-accent: var(--surface-gray-2);\n129: }\n130: \n131: .dark {\n132:   /* frappe-ui base tokens (Dark Mode) */\n133:   --surface-base: oklch(0.18 0.02 250);            /* Dark page background */\n134:   --surface-card: oklch(0.22 0.02 250);            /* Dark card background */\n135:   --surface-sidebar: oklch(0.22 0.02 250);\n136:   --ink-base: oklch(0.97 0.003 247);               /* Light primary text */\n137: \n138:   /* frappe-ui gray surfaces */\n139:   --surface-gray-2: oklch(0.28 0.02 250);\n140:   --surface-gray-3: oklch(0.32 0.02 250);\n141:   --surface-gray-9: oklch(0.85 0.02 250);\n142:   --surface-gray-10: oklch(0.97 0.003 247);\n143: \n144:   /* frappe-ui gray ink (typography) */\n145:   --ink-gray-4: oklch(0.55 0.02 250);\n146:   --ink-gray-5: oklch(0.7 0.02 250);\n147:   --ink-gray-8: oklch(0.9 0.02 250);\n148:   --ink-gray-9: oklch(0.97 0.003 247);\n149: \n150:   /* frappe-ui outlines (borders) */\n151:   --outline-gray-1: oklch(1 0 0 / 8%);\n152:   --outline-gray-2: oklch(1 0 0 / 12%);\n153:   --outline-gray-4: oklch(1 0 0 / 20%);\n154: \n155:   /* frappe-ui red (destructive) */\n156:   --surface-red-2: oklch(0.3 0.1 25);\n157:   --surface-red-3: oklch(0.35 0.12 25);\n158:   --ink-red: oklch(0.65 0.2 25);\n159: \n160:   /* frappe-ui amber (AI flagged alerts) */\n161:   --surface-amber-2: oklch(0.3 0.08 70);\n162:   --ink-amber: oklch(0.85 0.12 80);\n163: \n164:   /* Violet accent — dark mode */\n165:   --primary: oklch(0.65 0.2 290);\n166:   --primary-foreground: oklch(1 0 0);\n167:   --primary-soft: oklch(0.3 0.08 290);\n168:   --primary-soft-foreground: oklch(0.85 0.08 290);\n169:   --ring: oklch(0.65 0.2 290);\n170:   --success: oklch(0.7 0.17 145);\n171: }\n172: \n173: @layer base {\n174:   * {\n175:     border-color: var(--color-border);\n176:   }\n177:   html, body {\n178:     background-color: var(--color-background);\n179:     color: var(--color-foreground);\n180:     font-family: var(--font-sans);\n181:     -webkit-font-smoothing: antialiased;\n182:     -moz-osx-font-smoothing: grayscale;\n183:   }\n184:   h1, h2, h3, h4 {\n185:     letter-spacing: -0.01em;\n186:     font-weight: 700;\n187:   }\n188:   /* Circle-style scrollbar */\n189:   ::-webkit-scrollbar { width: 10px; height: 10px; }\n190:   ::-webkit-scrollbar-track { background: transparent; }\n191:   ::-webkit-scrollbar-thumb {\n192:     background: var(--color-border);\n193:     border-radius: 9999px;\n194:     border: 2px solid var(--color-background);\n195:   }\n196:   ::-webkit-scrollbar-thumb:hover { background: var(--color-border-strong); }\n197: }\n\n(End of file - total 197 lines)\n</content>",
