      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\start_frappe.ps1\", \"content\": \"$ErrorActionPreference = 'Stop'\\n\\n# Set the PATH\\n$env:PATH = \\\"/home/andiekobbie/.local/bin:/usr/bin:/usr/local/bin:/bin;$env:PATH\\\"\\n\\n# Change to frappe bench directory\\n$workdir = \\\"/home/andiekobbie/frappe-bench\\\"\\nSet-Location $workdir\\n\\n# Check if web.1 is running\\n$webProcess = Get-Process -Name \\\"web.1\\\" -ErrorAction SilentlyContinue\\n\\nif ($webProcess) {\\n    Write-Host \\\"Frappe server is already running\\\"\\n}\\nelse {\\n    Write-Host \\\"Starting Frappe server...\\\"\\n    # Start the server\\n    $proc = Start-Process -FilePath \\\"bench\\\" -ArgumentList \\\"start\\\" -NoNewWindow -PassThru\\n    \\n    # Wait a bit for the server to start\\n    Start-Sleep 3\\n    \\n    # Check if it's running\\n    if (Get-Process -Name \\\"web.1\\\" -ErrorAction SilentlyContinue) {\\n        Write-Host \\\"Frappe server started successfully!\\\"\\n    } else {\\n        Write-Host \\\"Failed to start Frappe server\\\"\\n    }\\n}\"}",
