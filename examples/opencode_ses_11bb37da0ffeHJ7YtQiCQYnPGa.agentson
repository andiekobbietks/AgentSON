    {
      "type": "action",
      "tool": "read",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\store.ts\"}",
      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\mock-data\\store.ts</path>\n<type>file</type>\n<content>\n1: import { ref, onMounted, onUnmounted } from \"vue\";\n2: import type {\n3:   GPDiscussion,\n4:   GPComment,\n5:   GPUserProfile,\n6:   FGMentorMatch,\n7:   FGUserSettings,\n8:   LMSCourse,\n9:   LMSChapter,\n10:   LMSLesson,\n11:   RSVPStatus,\n12:   SentimentLabel,\n13:   FGDMThread,\n14:   FGDMMessage,\n15:   FGNotification,\n16:   FGSSOProvider,\n17:   SSOProviderId,\n18: } from \"./types\";\n19: import {\n20:   CURRENT_USER_ID,\n21:   seedAISettings,\n22:   seedAttendees,\n23:   seedChapters,\n24:   seedComments,\n25:   seedCourses,\n26:   seedDiscussions,\n27:   seedEnrollments,\n28:   seedEvents,\n29:   seedLessons,\n30:   seedMatches,\n31:   seedProgress,\n32:   seedProjects,\n33:   seedReactions,\n34:   seedTeams,\n35:   seedUserSettings,\n36:   seedUsers,\n37:   seedDMThreads,\n38:   seedDMMessages,\n39:   seedNotifications,\n40:   seedSSOProviders,\n41: } from \"./seed\";\n42: \n43: const state = {\n44:   users: [...seedUsers],\n45:   teams: [...seedTeams],\n46:   projects: [...seedProjects],\n47:   discussions: [...seedDiscussions],\n48:   comments: [...seedComments],\n49:   reactions: [...seedReactions],\n50:   events: [...seedEvents],\n51:   attendees: [...seedAttendees],\n52:   matches: [...seedMatches],\n53:   courses: [...seedCourses],\n54:   chapters: [...seedChapters],\n55:   lessons: [...seedLessons],\n56:   enrollments: [...seedEnrollments],\n57:   progress: [...seedProgress],\n58:   aiSettings: { ...seedAISettings },\n59:   userSettings: [...seedUserSettings],\n60:   dmThreads: [...seedDMThreads],\n61:   dmMessages: [...seedDMMessages],\n62:   notifications: [...seedNotifications],\n63:   ssoProviders: [...seedSSOProviders],\n64: };\n65: \n66: const listeners = new Set<() => void>();\n67: let version = 0;\n68: function emit() {\n69:   version++;\n70:   listeners.forEach((l) => l());\n71: }\n72: function subscribe(l: () => void) {\n73:   listeners.add(l);\n74:   return () => listeners.delete(l);\n75: }\n76: export function useStoreVersion() {\n77:   const storeVersion = ref(version);\n78:   let unsubscribe: (() => void) | null = null;\n79:   onMounted(() => {\n80:     unsubscribe = subscribe(() => {\n81:       storeVersion.value = version;\n82:     });\n83:   });\n84:   onUnmounted(() => {\n85:     if (unsubscribe) unsubscribe();\n86:   });\n87:   return storeVersion;\n88: }\n89: \n90: export const currentUserId = CURRENT_USER_ID;\n91: \n92: // --- selectors ---\n93: export const getUsers = () => state.users;\n94: export const getUser = (id: string) => state.users.find((u) => u.user === id);\n95: export const getProjects = () => state.projects;\n96: export const getProject = (id: string) => state.projects.find((p) => p.id === id);\n97: export const getTeams = () => state.teams;\n98: export const getProjectsByTeam = (teamId: string) =>\n99:   state.projects.filter((p) => p.team === teamId);\n100: export function getDiscussions(projectId?: string) {\n101:   const list = projectId\n102:     ? state.discussions.filter((d) => d.project === projectId)\n103:     : state.discussions;\n104:   return [...list].sort((a, b) => {\n105:     if (!!a.pinned_at !== !!b.pinned_at) return a.pinned_at ? -1 : 1;\n106:     return b.last_post_at.localeCompare(a.last_post_at);\n107:   });\n108: }\n109: export const getDiscussion = (id: string) => state.discussions.find((d) => d.id === id);\n110: export const getCommentsFor = (discussionId: string) =>\n111:   state.comments\n112:     .filter((c) => c.reference_name === discussionId && !c.deleted_at)\n113:     .sort((a, b) => a.created_at.localeCompare(b.created_at));\n114: export const getReactionsFor = (ref: \"GP Discussion\" | \"GP Comment\", id: string) =>\n115:   state.reactions.filter((r) => r.reference_doctype === ref && r.reference_name === id);\n116: export const getEvents = () =>\n117:   [...state.events].sort((a, b) => a.starts_on.localeCompare(b.starts_on));\n118: export const getEvent = (id: string) => state.events.find((e) => e.id === id);\n119: export const getAttendees = (eventId: string) => state.attendees.filter((a) => a.event === eventId);\n120: export const getMatchesForUser = (userId: string) =>\n121:   state.matches.filter((m) => m.mentee === userId || m.mentor === userId);\n122: export const getRecentPostsByUser = (userId: string) =>\n123:   state.discussions\n124:     .filter((d) => d.author_id === userId)\n125:     .sort((a, b) => b.created_at.localeCompare(a.created_at));\n126: export const getAISettings = () => state.aiSettings;\n127: \n128: // --- LMS selectors ---\n129: export const getCourses = () => state.courses.filter((c) => c.published);\n130: export const getAllCoursesIncludingDrafts = () => state.courses;\n131: export const getCourse = (id: string) => state.courses.find((c) => c.id === id);\n132: export const getChaptersForCourse = (courseId: string) =>\n133:   state.chapters.filter((c) => c.course === courseId).sort((a, b) => a.idx - b.idx);\n134: export const getLessonsForChapter = (chapterId: string) =>\n135:   state.lessons.filter((l) => l.chapter === chapterId).sort((a, b) => a.idx - b.idx);\n136: export const getLessonsForCourse = (courseId: string) =>\n137:   state.lessons.filter((l) => l.course === courseId);\n138: export const getLesson = (id: string) => state.lessons.find((l) => l.id === id);\n139: export const getEnrollment = (courseId: string, userId = currentUserId) =>\n140:   state.enrollments.find((e) => e.course === courseId && e.member === userId);\n141: export const getMyEnrollments = (userId = currentUserId) =>\n142:   state.enrollments.filter((e) => e.member === userId);\n143: export const isLessonComplete = (lessonId: string, userId = currentUserId) =>\n144:   state.progress.some(\n145:     (p) => p.lesson === lessonId && p.member === userId && p.status === \"Complete\",\n146:   );\n147: export function courseProgressPercent(courseId: string, userId = currentUserId) {\n148:   const lessons = getLessonsForCourse(courseId);\n149:   if (lessons.length === 0) return 0;\n150:   const done = lessons.filter((l) => isLessonComplete(l.id, userId)).length;\n151:   return Math.round((done / lessons.length) * 100);\n152: }\n153: \n154: // --- User settings ---\n155: export const getUserSettings = (userId = currentUserId): FGUserSettings => {\n156:   let s = state.userSettings.find((x) => x.user === userId);\n157:   if (!s) {\n158:     s = {\n159:       user: userId,\n160:       email_on_mention: true,\n161:       email_on_reply: true,\n162:       email_weekly_digest: false,\n163:       push_on_dm: true,\n164:       push_on_mention: false,\n165:       show_in_member_directory: true,\n166:       allow_dm_from_anyone: true,\n167:       theme: \"system\",\n168:       language: \"en\",\n169:       timezone: \"Europe/London\",\n170:     };\n171:     state.userSettings.push(s);\n172:   }\n173:   return s;\n174: };\n175: export function updateUserSettings(patch: Partial<FGUserSettings>) {\n176:   const s = getUserSettings();\n177:   Object.assign(s, patch);\n178:   emit();\n179: }\n180: export function updateProfile(patch: Partial<GPUserProfile>) {\n181:   const u = getUser(currentUserId);\n182:   if (!u) return;\n183:   Object.assign(u, patch);\n184:   emit();\n185: }\n186: \n187: // --- mutators ---\n188: const uid = (p: string) => `${p}_${Math.random().toString(36).slice(2, 9)}`;\n189: const slugify = (s: string) =>\n190:   s\n191:     .toLowerCase()\n192:     .replace(/[^a-z0-9]+/g, \"-\")\n193:     .replace(/^-|-$/g, \"\")\n194:     .slice(0, 60);\n195: \n196: export function createDiscussion(input: {\n197:   project: string;\n198:   title: string;\n199:   content: string;\n200: }): GPDiscussion {\n201:   const project = getProject(input.project);\n202:   const d: GPDiscussion = {\n203:     id: uid(\"post\"),\n204:     project: input.project,\n205:     team: project?.team ?? \"Community\",\n206:     status: \"\",\n207:     title: input.title.trim(),\n208:     slug: slugify(input.title),\n209:     content: input.content,\n210:     last_post_at: new Date().toISOString(),\n211:     last_post_by: currentUserId,\n212:     comments_count: 0,\n213:     participants_count: 1,\n214:     closed_at: null,\n215:     closed_by: null,\n216:     pinned_at: null,\n217:     pinned_by: null,\n218:     author_id: currentUserId,\n219:     created_at: new Date().toISOString(),\n220:   };\n221:   state.discussions.unshift(d);\n222:   if (project) project.discussions_count++;\n223:   emit();\n224:   return d;\n225: }\n226: \n227: export function createComment(input: { discussion_id: string; content: string }): GPComment {\n228:   const c: GPComment = {\n229:     id: uid(\"c\"),\n230:     content: input.content,\n231:     reference_doctype: \"GP Discussion\",\n232:     reference_name: input.discussion_id,\n233:     deleted_at: null,\n234:     author_id: currentUserId,\n235:     created_at: new Date().toISOString(),\n236:   };\n237:   state.comments.push(c);\n238:   const d = getDiscussion(input.discussion_id);\n239:   if (d) {\n240:     d.comments_count++;\n241:     d.last_post_at = c.created_at;\n242:     d.last_post_by = currentUserId;\n243:   }\n244:   emit();\n245:   return c;\n246: }\n247: \n248: export function toggleReaction(ref: \"GP Discussion\" | \"GP Comment\", id: string, emoji: string) {\n249:   const idx = state.reactions.findIndex(\n250:     (r) =>\n251:       r.reference_doctype === ref &&\n252:       r.reference_name === id &&\n253:       r.user === currentUserId &&\n254:       r.emoji === emoji,\n255:   );\n256:   if (idx >= 0) state.reactions.splice(idx, 1);\n257:   else\n258:     state.reactions.push({\n259:       id: uid(\"r\"),\n260:       reference_doctype: ref,\n261:       reference_name: id,\n262:       user: currentUserId,\n263:       emoji,\n264:     });\n265:   emit();\n266: }\n267: \n268: export function setRSVP(eventId: string, status: RSVPStatus) {\n269:   const existing = state.attendees.find((a) => a.event === eventId && a.user === currentUserId);\n270:   if (existing) existing.rsvp_status = status;\n271:   else\n272:     state.attendees.push({\n273:       id: uid(\"a\"),\n274:       event: eventId,\n275:       user: currentUserId,\n276:       rsvp_status: status,\n277:     });\n278:   emit();\n279: }\n280: export const getMyRSVP = (eventId: string): RSVPStatus | null =>\n281:   state.attendees.find((a) => a.event === eventId && a.user === currentUserId)?.rsvp_status ?? null;\n282: \n283: export function requestMentor(mentorId: string, notes: string): FGMentorMatch {\n284:   const m: FGMentorMatch = {\n285:     id: uid(\"match\"),\n286:     mentee: currentUserId,\n287:     mentor: mentorId,\n288:     status: \"Requested\",\n289:     matched_on: new Date().toISOString(),\n290:     matched_via: \"Self-Requested\",\n291:     match_notes: notes,\n292:   };\n293:   state.matches.push(m);\n294:   emit();\n295:   return m;\n296: }\n297: \n298: // --- LMS mutators ---\n299: export function createCourse(input: {\n300:   title: string;\n301:   short_introduction: string;\n302:   description: string;\n303:   category: string;\n304:   tags: string;\n305: }): LMSCourse {\n306:   const c: LMSCourse = {\n307:     id: slugify(input.title) || uid(\"course\"),\n308:     title: input.title.trim(),\n309:     short_introduction: input.short_introduction,\n310:     description: input.description,\n311:     image: \"\",\n312:     paid_course: false,\n313:     featured: false,\n314:     published: true,\n315:     enable_certification: false,\n316:     category: input.category || \"General\",\n317:     tags: input.tags,\n318:     status: \"Approved\",\n319:     author: currentUserId,\n320:     enrollments: 0,\n321:     lessons: 0,\n322:     created_at: new Date().toISOString(),\n323:   };\n324:   state.courses.unshift(c);\n325:   // Auto-create a first chapter so the course has somewhere to add lessons.\n326:   const chapter: LMSChapter = {\n327:     id: uid(\"ch\"),\n328:     course: c.id,\n329:     title: \"Chapter 1\",\n330:     description: \"Your first chapter\",\n331:     idx: 1,\n332:   };\n333:   state.chapters.push(chapter);\n334:   emit();\n335:   return c;\n336: }\n337: \n338: export function addChapter(courseId: string, title: string): LMSChapter {\n339:   const existing = getChaptersForCourse(courseId);\n340:   const ch: LMSChapter = {\n341:     id: uid(\"ch\"),\n342:     course: courseId,\n343:     title,\n344:     description: \"\",\n345:     idx: existing.length + 1,\n346:   };\n347:   state.chapters.push(ch);\n348:   emit();\n349:   return ch;\n350: }\n351: \n352: export function addLesson(input: {\n353:   course: string;\n354:   chapter: string;\n355:   title: string;\n356:   body: string;\n357:   youtube_video: string;\n358: }): LMSLesson {\n359:   const siblings = getLessonsForChapter(input.chapter);\n360:   const l: LMSLesson = {\n361:     id: uid(\"ls\"),\n362:     chapter: input.chapter,\n363:     course: input.course,\n364:     title: input.title.trim(),\n365:     body: input.body,\n366:     youtube_video: extractYouTubeId(input.youtube_video),\n367:     include_in_preview: false,\n368:     idx: siblings.length + 1,\n369:   };\n370:   state.lessons.push(l);\n371:   const course = getCourse(input.course);\n372:   if (course) course.lessons = getLessonsForCourse(input.course).length;\n373:   emit();\n374:   return l;\n375: }\n376: \n377: export function enrollInCourse(courseId: string) {\n378:   if (getEnrollment(courseId)) return;\n379:   state.enrollments.push({\n380:     id: uid(\"enr\"),\n381:     member: currentUserId,\n382:     course: courseId,\n383:     member_type: \"Student\",\n384:     progress: 0,\n385:     enrolled_on: new Date().toISOString(),\n386:   });\n387:   const c = getCourse(courseId);\n388:   if (c) c.enrollments++;\n389:   emit();\n390: }\n391: \n392: export function markLessonComplete(lessonId: string, complete: boolean) {\n393:   const lesson = getLesson(lessonId);\n394:   if (!lesson) return;\n395:   const idx = state.progress.findIndex((p) => p.lesson === lessonId && p.member === currentUserId);\n396:   if (complete) {\n397:     if (idx >= 0) state.progress[idx].status = \"Complete\";\n398:     else\n399:       state.progress.push({\n400:         id: uid(\"prg\"),\n401:         member: currentUserId,\n402:         course: lesson.course,\n403:         lesson: lessonId,\n404:         status: \"Complete\",\n405:       });\n406:   } else if (idx >= 0) {\n407:     state.progress.splice(idx, 1);\n408:   }\n409:   const enr = getEnrollment(lesson.course);\n410:   if (enr) enr.progress = courseProgressPercent(lesson.course);\n411:   emit();\n412: }\n413: \n414: /** Accept full YouTube URLs OR raw IDs; return the 11-char ID or \"\". */\n415: export function extractYouTubeId(input: string): string {\n416:   if (!input) return \"\";\n417:   const trimmed = input.trim();\n418:   if (/^[a-zA-Z0-9_-]{11}$/.test(trimmed)) return trimmed;\n419:   const m = trimmed.match(\n420:     /(?:youtube\\.com\\/(?:watch\\?v=|embed\\/|shorts\\/)|youtu\\.be\\/)([a-zA-Z0-9_-]{11})/,\n421:   );\n422:   return m ? m[1] : \"\";\n423: }\n424: \n425: // --- mocked AI (keyword stubs — NOT real ML) ---\n426: const NEG = [\n427:   \"hopeless\",\n428:   \"drop out\",\n429:   \"dropping out\",\n430:   \"can't cope\",\n431:   \"cant cope\",\n432:   \"give up\",\n433:   \"alone\",\n434:   \"worthless\",\n435:   \"panic\",\n436:   \"overwhelmed\",\n437:   \"lost\",\n438:   \"don't belong\",\n439:   \"dont belong\",\n440: ];\n441: const SOFT_NEG = [\"tired\", \"stressed\", \"anxious\", \"scared\", \"struggling\"];\n442: const POS = [\"win\", \"proud\", \"grateful\", \"thank\", \"great\", \"love\", \"🎉\", \"💛\", \"happy\"];\n443: \n444: export function mockSentiment(text: string): {\n445:   label: SentimentLabel;\n446:   score: number;\n447: } {\n448:   const plain = text.replace(/<[^>]+>/g, \" \").toLowerCase();\n449:   let neg = 0,\n450:     pos = 0;\n451:   for (const k of NEG) if (plain.includes(k)) neg += 1;\n452:   for (const k of SOFT_NEG) if (plain.includes(k)) neg += 0.4;\n453:   for (const k of POS) if (plain.includes(k)) pos += 1;\n454:   const ai = getAISettings();\n455:   if (neg >= 1.4) {\n456:     const score = Math.min(0.6 + neg * 0.15, 0.98);\n457:     if (score >= ai.sentiment_alert_threshold) return { label: \"Needs Attention\", score };\n458:     return { label: \"Negative\", score };\n459:   }\n460:   if (pos > neg && pos >= 1) return { label: \"Positive\", score: 0.6 + pos * 0.1 };\n461:   if (neg > 0) return { label: \"Negative\", score: 0.4 + neg * 0.1 };\n462:   return { label: \"Neutral\", score: 0.5 };\n463: }\n464: \n465: export function findSimilarPosts(discussionId: string, limit = 3) {\n466:   const target = getDiscussion(discussionId);\n467:   if (!target) return [];\n468:   const tok = (s: string) =>\n469:     new Set(\n470:       s\n471:         .replace(/<[^>]+>/g, \" \")\n472:         .toLowerCase()\n473:         .split(/\\W+/)\n474:         .filter((w) => w.length > 4),\n475:     );\n476:   const t = tok(target.title + \" \" + target.content);\n477:   return state.discussions\n478:     .filter((d) => d.id !== discussionId && d.project === target.project)\n479:     .map((d) => {\n480:       const dt = tok(d.title + \" \" + d.content);\n481:       let overlap = 0;\n482:       dt.forEach((w) => t.has(w) && overlap++);\n483:       return { post: d, score: overlap };\n484:     })\n485:     .sort((a, b) => b.score - a.score)\n486:     .slice(0, limit)\n487:     .map((x) => x.post);\n488: }\n489: \n490: // ============================================================\n491: // DMs\n492: // ============================================================\n493: export const getDMThreadsForUser = (userId = currentUserId): FGDMThread[] =>\n494:   [...state.dmThreads]\n495:     .filter((t) => t.member_a === userId || t.member_b === userId)\n496:     .sort((a, b) => b.last_message_at.localeCompare(a.last_message_at));\n497: \n498: export const getDMThread = (id: string) => state.dmThreads.find((t) => t.id === id);\n499: \n500: export const getDMMessages = (threadId: string): FGDMMessage[] =>\n501:   state.dmMessages\n502:     .filter((m) => m.thread === threadId)\n503:     .sort((a, b) => a.created_at.localeCompare(b.created_at));\n504: \n505: export const getOtherMember = (thread: FGDMThread, userId = currentUserId) =>\n506:   thread.member_a === userId ? thread.member_b : thread.member_a;\n507: \n508: export function openOrCreateDMWith(otherUserId: string): FGDMThread {\n509:   if (otherUserId === currentUserId) {\n510:     return state.dmThreads[0];\n511:   }\n512:   const existing = state.dmThreads.find(\n513:     (t) =>\n514:       (t.member_a === currentUserId && t.member_b === otherUserId) ||\n515:       (t.member_b === currentUserId && t.member_a === otherUserId),\n516:   );\n517:   if (existing) return existing;\n518:   const t: FGDMThread = {\n519:     id: uid(\"dm\"),\n520:     member_a: currentUserId,\n521:     member_b: otherUserId,\n522:     last_message_at: new Date().toISOString(),\n523:     last_message_preview: \"\",\n524:   };\n525:   state.dmThreads.unshift(t);\n526:   emit();\n527:   return t;\n528: }\n529: \n530: export function sendDM(threadId: string, content: string): FGDMMessage | null {\n531:   const t = getDMThread(threadId);\n532:   if (!t || !content.trim()) return null;\n533:   const m: FGDMMessage = {\n534:     id: uid(\"m\"),\n535:     thread: threadId,\n536:     sender: currentUserId,\n537:     content: content.trim(),\n538:     created_at: new Date().toISOString(),\n539:     read_by: [currentUserId],\n540:   };\n541:   state.dmMessages.push(m);\n542:   t.last_message_at = m.created_at;\n543:   t.last_message_preview = m.content.slice(0, 80);\n544:   emit();\n545:   return m;\n546: }\n547: \n548: export function markThreadRead(threadId: string) {\n549:   let changed = false;\n550:   state.dmMessages.forEach((m) => {\n551:     if (m.thread === threadId && !m.read_by.includes(currentUserId)) {\n552:       m.read_by.push(currentUserId);\n553:       changed = true;\n554:     }\n555:   });\n556:   if (changed) emit();\n557: }\n558: \n559: export const getUnreadDMCount = (userId = currentUserId) =>\n560:   state.dmMessages.filter(\n561:     (m) =>\n562:       m.sender !== userId &&\n563:       !m.read_by.includes(userId) &&\n564:       state.dmThreads.some(\n565:         (t) => t.id === m.thread && (t.member_a === userId || t.member_b === userId),\n566:       ),\n567:   ).length;\n568: \n569: // ============================================================\n570: // Notifications\n571: // ============================================================\n572: export const getNotifications = (userId = currentUserId): FGNotification[] =>\n573:   state.notifications\n574:     .filter((n) => n.for_user === userId)\n575:     .sort((a, b) => b.created_at.localeCompare(a.created_at));\n576: \n577: export const getUnreadNotificationCount = (userId = currentUserId) =>\n578:   state.notifications.filter((n) => n.for_user === userId && !n.read).length;\n579: \n580: export function markAllNotificationsRead(userId = currentUserId) {\n581:   state.notifications.forEach((n) => {\n582:     if (n.for_user === userId) n.read = true;\n583:   });\n584:   emit();\n585: }\n586: \n587: export function markNotificationRead(id: string) {\n588:   const n = state.notifications.find((x) => x.id === id);\n589:   if (n && !n.read) {\n590:     n.read = true;\n591:     emit();\n592:   }\n593: }\n594: \n595: // ============================================================\n596: // SSO providers (admin settings)\n597: // ============================================================\n598: export const getSSOProviders = (): FGSSOProvider[] => state.ssoProviders;\n599: \n600: export function updateSSOProvider(id: SSOProviderId, patch: Partial<FGSSOProvider>) {\n601:   const p = state.ssoProviders.find((x) => x.id === id);\n602:   if (!p) return;\n603:   Object.assign(p, patch);\n604:   if (patch.enabled && !p.client_id_set && p.id !== \"email\") {\n605:     p.client_id_set = true; // mocked: pretend admin pasted a client ID\n606:   }\n607:   emit();\n608: }\n\n(End of file - total 608 lines)\n</content>",
