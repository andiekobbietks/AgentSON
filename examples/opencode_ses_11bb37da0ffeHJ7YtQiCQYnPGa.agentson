      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\types.ts\", \"newString\": \"/** DocType: `LMS Course` */\\nexport interface LMSCourse {\\n  id: string; // \\u2192 `name`\\n  title: string;\\n  short_introduction: string;\\n  description: string; // Text Editor \\u2014 long form\\n  image: string;\\n  card_gradient: \\\"Red\\\" | \\\"Blue\\\" | \\\"Green\\\" | \\\"Amber\\\" | \\\"Cyan\\\" | \\\"Orange\\\" | \\\"Pink\\\" | \\\"Purple\\\" | \\\"Teal\\\" | \\\"Violet\\\" | \\\"Yellow\\\" | \\\"Gray\\\";\\n  paid_course: boolean;\\n  paid_certificate: boolean;\\n  featured: boolean;\\n  published: boolean;\\n  published_on: string;\\n  upcoming: boolean;\\n  disable_self_learning: boolean;\\n  enable_certification: boolean;\\n  course_price: number;\\n  currency: string;\\n  amount_usd: number;\\n  category: string;\\n  tags: string; // comma separated, matches LMS\\n  status: \\\"In Progress\\\" | \\\"Under Review\\\" | \\\"Approved\\\";\\n  author: string; // \\u2192 Link `User` (instructor)\\n  instructors: string[]; // Table MultiSelect \\u2192 Course Instructor\\n  enrollments: number; // denormalised for cards\\n  lessons: number; // denormalised\\n  rating: string;\\n  created_at: string;\\n}\\n\\n/** DocType: `LMS Chapter` (parent: LMS Course) */\\nexport interface LMSChapter {\\n  id: string; // \\u2192 `name`\\n  course: string; // \\u2192 Link `LMS Course`\\n  title: string;\\n  description: string;\\n  idx: number; // order\\n}\\n\\n/**\\n * DocType: `LMS Lesson` (parent: LMS Chapter)\\n *\\n * In real LMS the body is a Markdown/HTML field with embedded shortcodes\\n * like `{{ YouTubeVideo(\\\"VIDEO_ID\\\") }}`. For the prototype we surface\\n * `youtube_video` as a first-class field \\u2014 porting is a search/replace\\n * to the shortcode form. See /docs/04_FRAPPE_TRANSLATION.md.\\n */\\nexport interface LMSLesson {\\n  id: string; // \\u2192 `name`\\n  chapter: string; // \\u2192 Link `LMS Chapter`\\n  course: string; // \\u2192 Link `LMS Course` (denormalised)\\n  title: string;\\n  body: string; // Markdown/HTML\\n  youtube_video: string; // 11-char YouTube ID (or \\\"\\\")\\n  include_in_preview: boolean;\\n  idx: number;\\n}\\n\\n/** DocType: `LMS Enrollment` */\\nexport interface LMSEnrollment {\\n  id: string;\\n  member: string; // \\u2192 Link `User`\\n  course: string; // \\u2192 Link `LMS Course`\\n  member_name: string;\\n  member_username: string;\\n  member_type: \\\"Student\\\" | \\\"Mentor\\\" | \\\"Staff\\\";\\n  role: \\\"Member\\\" | \\\"Admin\\\";\\n  progress: number; // 0..100\\n  current_lesson: string;\\n  enrolled_on: string;\\n  payment: string;\\n  certificate: string;\\n  purchased_certificate: boolean;\\n}\\n\\n/** DocType: `LMS Course Progress` (per-lesson completion) */\\nexport interface LMSCourseProgress {\\n  id: string;\\n  member: string;\\n  member_name: string;\\n  course: string;\\n  chapter: string;\\n  lesson: string;\\n  status: \\\"Complete\\\" | \\\"Partially Complete\\\" | \\\"Incomplete\\\";\\n  is_scorm_chapter: boolean;\\n}\\n\\n/** DocType: `LMS Certificate` */\\nexport interface LMSCertificate {\\n  id: string;\\n  member: string;\\n  member_name: string;\\n  course: string;\\n  course_title: string;\\n  issue_date: string;\\n  expiry_date: string | null;\\n  published: boolean;\\n}\", \"oldString\": \"/** DocType: `LMS Course` */\\nexport interface LMSCourse {\\n  id: string; // \\u2192 `name`\\n  title: string;\\n  short_introduction: string;\\n  description: string; // Text Editor \\u2014 long form\\n  image: string;\\n  paid_course: boolean;\\n  featured: boolean;\\n  published: boolean;\\n  enable_certification: boolean;\\n  category: string;\\n  tags: string; // comma separated, matches LMS\\n  status: \\\"Draft\\\" | \\\"Approved\\\" | \\\"Under Review\\\";\\n  author: string; // \\u2192 Link `User` (instructor)\\n  enrollments: number; // denormalised for cards\\n  lessons: number; // denormalised\\n  created_at: string;\\n}\\n\\n/** DocType: `LMS Chapter` (parent: LMS Course) */\\nexport interface LMSChapter {\\n  id: string; // \\u2192 `name`\\n  course: string; // \\u2192 Link `LMS Course`\\n  title: string;\\n  description: string;\\n  idx: number; // order\\n}\\n\\n/**\\n * DocType: `LMS Lesson` (parent: LMS Chapter)\\n *\\n * In real LMS the body is a Markdown/HTML field with embedded shortcodes\\n * like `{{ YouTubeVideo(\\\"VIDEO_ID\\\") }}`. For the prototype we surface\\n * `youtube_video` as a first-class field \\u2014 porting is a search/replace\\n * to the shortcode form. See /docs/04_FRAPPE_TRANSLATION.md.\\n */\\nexport interface LMSLesson {\\n  id: string; // \\u2192 `name`\\n  chapter: string; // \\u2192 Link `LMS Chapter`\\n  course: string; // \\u2192 Link `LMS Course` (denormalised)\\n  title: string;\\n  body: string; // Markdown/HTML\\n  youtube_video: string; // 11-char YouTube ID (or \\\"\\\")\\n  include_in_preview: boolean;\\n  idx: number;\\n}\\n\\n/** DocType: `LMS Enrollment` */\\nexport interface LMSEnrollment {\\n  id: string;\\n  member: string; // \\u2192 Link `User`\\n  course: string; // \\u2192 Link `LMS Course`\\n  member_type: \\\"Student\\\" | \\\"Mentor\\\";\\n  progress: number; // 0..100\\n  enrolled_on: string;\\n}\\n\\n/** DocType: `LMS Course Progress` (per-lesson completion) */\\nexport interface LMSCourseProgress {\\n  id: string;\\n  member: string;\\n  course: string;\\n  lesson: string;\\n  status: \\\"Complete\\\" | \\\"Incomplete\\\";\\n}\"}",
