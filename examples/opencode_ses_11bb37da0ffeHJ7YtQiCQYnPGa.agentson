      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\mock-data\\store.ts</path>\n<type>file</type>\n<content>\n1: import { ref, onMounted, onUnmounted } from \"vue\";\n2: import type {\n3:   GPDiscussion,\n4:   GPComment,\n5:   GPUserProfile,\n6:   FGMentorMatch,\n7:   FGUserSettings,\n8:   LMSCourse,\n9:   LMSChapter,\n10:   LMSLesson,\n11:   RSVPStatus,\n12:   SentimentLabel,\n13:   FGDMThread,\n14:   FGDMMessage,\n15:   FGNotification,\n16:   FGSSOProvider,\n17:   SSOProviderId,\n18:   FGPoll,\n19:   FGPollVote,\n20:   FGBadge,\n21:   FGBadgeAward,\n22: } from \"./types\";\n23: import {\n24:   CURRENT_USER_ID,\n25:   seedAISettings,\n26:   seedAttendees,\n27:   seedChapters,\n28:   seedComments,\n29:   seedCourses,\n30:   seedDiscussions,\n31:   seedEnrollments,\n32:   seedEvents,\n33:   seedLessons,\n34:   seedMatches,\n35:   seedProgress,\n36:   seedProjects,\n37:   seedReactions,\n38:   seedTeams,\n39:   seedUserSettings,\n40:   seedUsers,\n41:   seedDMThreads,\n42:   seedDMMessages,\n43:   seedNotifications,\n44:   seedSSOProviders,\n45:   seedPolls,\n46:   seedPollVotes,\n47:   seedBadges,\n48:   seedBadgeAwards,\n49:   seedEnergyPoints,\n50: } from \"./seed\";\n51: \n52: const state = {\n53:   users: [...seedUsers],\n54:   teams: [...seedTeams],\n55:   projects: [...seedProjects],\n56:   discussions: [...seedDiscussions],\n57:   comments: [...seedComments],\n58:   reactions: [...seedReactions],\n59:   events: [...seedEvents],\n60:   attendees: [...seedAttendees],\n61:   matches: [...seedMatches],\n62:   courses: [...seedCourses],\n63:   chapters: [...seedChapters],\n64:   lessons: [...seedLessons],\n65:   enrollments: [...seedEnrollments],\n66:   progress: [...seedProgress],\n67:   aiSettings: { ...seedAISettings },\n68:   userSettings: [...seedUserSettings],\n69:   dmThreads: [...seedDMThreads],\n70:   dmMessages: [...seedDMMessages],\n71:   notifications: [...seedNotifications],\n72:   ssoProviders: [...seedSSOProviders],\n73:   polls: [...seedPolls],\n74:   pollVotes: [...seedPollVotes],\n75:   badges: [...seedBadges],\n76:   badgeAwards: [...seedBadgeAwards],\n77:   energyPoints: [...seedEnergyPoints],\n78: };\n79: \n80: const listeners = new Set<() => void>();\n81: let version = 0;\n82: function emit() {\n83:   version++;\n84:   listeners.forEach((l) => l());\n85: }\n86: function subscribe(l: () => void) {\n87:   listeners.add(l);\n88:   return () => listeners.delete(l);\n89: }\n90: export function useStoreVersion() {\n91:   const storeVersion = ref(version);\n92:   let unsubscribe: (() => void) | null = null;\n93:   onMounted(() => {\n94:     unsubscribe = subscribe(() => {\n95:       storeVersion.value = version;\n96:     });\n97:   });\n98:   onUnmounted(() => {\n99:     if (unsubscribe) unsubscribe();\n100:   });\n101:   return storeVersion;\n102: }\n103: \n104: export const currentUserId = CURRENT_USER_ID;\n105: \n106: // --- selectors ---\n107: export const getUsers = () => state.users;\n108: export const getUser = (id: string) => state.users.find((u) => u.user === id);\n109: export const getProjects = () => state.projects;\n110: export const getProject = (id: string) => state.projects.find((p) => p.id === id);\n111: export const getTeams = () => state.teams;\n112: export const getProjectsByTeam = (teamId: string) =>\n113:   state.projects.filter((p) => p.team === teamId);\n114: export function getDiscussions(projectId?: string) {\n115:   const list = projectId\n116:     ? state.discussions.filter((d) => d.project === projectId)\n117:     : state.discussions;\n118:   return [...list].sort((a, b) => {\n119:     if (!!a.pinned_at !== !!b.pinned_at) return a.pinned_at ? -1 : 1;\n120:     return b.last_post_at.localeCompare(a.last_post_at);\n121:   });\n122: }\n123: export const getDiscussion = (id: string) => state.discussions.find((d) => d.id === id);\n124: export const getCommentsFor = (discussionId: string) =>\n125:   state.comments\n126:     .filter((c) => c.reference_name === discussionId && !c.deleted_at)\n127:     .sort((a, b) => a.created_at.localeCompare(b.created_at));\n128: export const getReactionsFor = (ref: \"GP Discussion\" | \"GP Comment\", id: string) =>\n129:   state.reactions.filter((r) => r.reference_doctype === ref && r.reference_name === id);\n130: export const getEvents = () =>\n131:   [...state.events].sort((a, b) => a.starts_on.localeCompare(b.starts_on));\n132: export const getEvent = (id: string) => state.events.find((e) => e.id === id);\n133: export const getAttendees = (eventId: string) => state.attendees.filter((a) => a.event === eventId);\n134: export const getMatchesForUser = (userId: string) =>\n135:   state.matches.filter((m) => m.mentee === userId || m.mentor === userId);\n136: export const getRecentPostsByUser = (userId: string) =>\n137:   state.discussions\n138:     .filter((d) => d.author_id === userId)\n139:     .sort((a, b) => b.created_at.localeCompare(a.created_at));\n140: export const getAISettings = () => state.aiSettings;\n141: \n142: // --- LMS selectors ---\n143: export const getCourses = () => state.courses.filter((c) => c.published);\n144: export const getAllCoursesIncludingDrafts = () => state.courses;\n145: export const getCourse = (id: string) => state.courses.find((c) => c.id === id);\n146: export const getChaptersForCourse = (courseId: string) =>\n147:   state.chapters.filter((c) => c.course === courseId).sort((a, b) => a.idx - b.idx);\n148: export const getLessonsForChapter = (chapterId: string) =>\n149:   state.lessons.filter((l) => l.chapter === chapterId).sort((a, b) => a.idx - b.idx);\n150: export const getLessonsForCourse = (courseId: string) =>\n151:   state.lessons.filter((l) => l.course === courseId);\n152: export const getLesson = (id: string) => state.lessons.find((l) => l.id === id);\n153: export const getEnrollment = (courseId: string, userId = currentUserId) =>\n154:   state.enrollments.find((e) => e.course === courseId && e.member === userId);\n155: export const getMyEnrollments = (userId = currentUserId) =>\n156:   state.enrollments.filter((e) => e.member === userId);\n157: export const isLessonComplete = (lessonId: string, userId = currentUserId) =>\n158:   state.progress.some(\n159:     (p) => p.lesson === lessonId && p.member === userId && p.status === \"Complete\",\n160:   );\n161: export function courseProgressPercent(courseId: string, userId = currentUserId) {\n162:   const lessons = getLessonsForCourse(courseId);\n163:   if (lessons.length === 0) return 0;\n164:   const done = lessons.filter((l) => isLessonComplete(l.id, userId)).length;\n165:   return Math.round((done / lessons.length) * 100);\n166: }\n167: \n168: // --- User settings ---\n169: export const getUserSettings = (userId = currentUserId): FGUserSettings => {\n170:   let s = state.userSettings.find((x) => x.user === userId);\n171:   if (!s) {\n172:     s = {\n173:       user: userId,\n174:       email_on_mention: true,\n175:       email_on_reply: true,\n176:       email_weekly_digest: false,\n177:       push_on_dm: true,\n178:       push_on_mention: false,\n179:       show_in_member_directory: true,\n180:       allow_dm_from_anyone: true,\n181:       theme: \"system\",\n182:       language: \"en\",\n183:       timezone: \"Europe/London\",\n184:     };\n185:     state.userSettings.push(s);\n186:   }\n187:   return s;\n188: };\n189: export function updateUserSettings(patch: Partial<FGUserSettings>) {\n190:   const s = getUserSettings();\n191:   Object.assign(s, patch);\n192:   emit();\n193: }\n194: export function updateProfile(patch: Partial<GPUserProfile>) {\n195:   const u = getUser(currentUserId);\n196:   if (!u) return;\n197:   Object.assign(u, patch);\n198:   emit();\n199: }\n200: \n201: // --- mutators ---\n202: const uid = (p: string) => `${p}_${Math.random().toString(36).slice(2, 9)}`;\n203: const slugify = (s: string) =>\n204:   s\n205:     .toLowerCase()\n206:     .replace(/[^a-z0-9]+/g, \"-\")\n207:     .replace(/^-|-$/g, \"\")\n208:     .slice(0, 60);\n209: \n210: export function createDiscussion(input: {\n211:   project: string;\n212:   title: string;\n213:   content: string;\n214: }): GPDiscussion {\n215:   const project = getProject(input.project);\n216:   const d: GPDiscussion = {\n217:     id: uid(\"post\"),\n218:     project: input.project,\n219:     team: project?.team ?? \"Community\",\n220:     status: \"\",\n221:     title: input.title.trim(),\n222:     slug: slugify(input.title),\n223:     content: input.content,\n224:     last_post_at: new Date().toISOString(),\n225:     last_post_by: currentUserId,\n226:     comments_count: 0,\n227:     participants_count: 1,\n228:     closed_at: null,\n229:     closed_by: null,\n230:     pinned_at: null,\n231:     pinned_by: null,\n232:     author_id: currentUserId,\n233:     created_at: new Date().toISOString(),\n234:   };\n235:   state.discussions.unshift(d);\n236:   if (project) project.discussions_count++;\n237:   emit();\n238:   return d;\n239: }\n240: \n241: export function createComment(input: { discussion_id: string; content: string }): GPComment {\n242:   const c: GPComment = {\n243:     id: uid(\"c\"),\n244:     content: input.content,\n245:     reference_doctype: \"GP Discussion\",\n246:     reference_name: input.discussion_id,\n247:     deleted_at: null,\n248:     author_id: currentUserId,\n249:     created_at: new Date().toISOString(),\n250:   };\n251:   state.comments.push(c);\n252:   const d = getDiscussion(input.discussion_id);\n253:   if (d) {\n254:     d.comments_count++;\n255:     d.last_post_at = c.created_at;\n256:     d.last_post_by = currentUserId;\n257:   }\n258:   emit();\n259:   return c;\n260: }\n261: \n262: export function toggleReaction(ref: \"GP Discussion\" | \"GP Comment\", id: string, emoji: string) {\n263:   const idx = state.reactions.findIndex(\n264:     (r) =>\n265:       r.reference_doctype === ref &&\n266:       r.reference_name === id &&\n267:       r.user === currentUserId &&\n268:       r.emoji === emoji,\n269:   );\n270:   if (idx >= 0) state.reactions.splice(idx, 1);\n271:   else\n272:     state.reactions.push({\n273:       id: uid(\"r\"),\n274:       reference_doctype: ref,\n275:       reference_name: id,\n276:       user: currentUserId,\n277:       emoji,\n278:     });\n279:   emit();\n280: }\n281: \n282: export function setRSVP(eventId: string, status: RSVPStatus) {\n283:   const existing = state.attendees.find((a) => a.event === eventId && a.user === currentUserId);\n284:   if (existing) existing.rsvp_status = status;\n285:   else\n286:     state.attendees.push({\n287:       id: uid(\"a\"),\n288:       event: eventId,\n289:       user: currentUserId,\n290:       rsvp_status: status,\n291:     });\n292:   emit();\n293: }\n294: \n295: export function createEvent(input: {\n296:   title: string;\n297:   description: string;\n298:   starts_on: string;\n299:   event_type: string;\n300: }) {\n301:   const evt = {\n302:     id: uid(\"evt\"),\n303:     title: input.title.trim(),\n304:     description: input.description,\n305:     space: null,\n306:     event_type: input.event_type,\n307:     starts_on: new Date(input.starts_on).toISOString(),\n308:     ends_on: new Date(new Date(input.starts_on).getTime() + 3600000).toISOString(),\n309:     location_type: \"Online (External Link)\" as const,\n310:     bbb_meeting_id: null,\n311:     external_link: null,\n312:     physical_address: null,\n313:     rsvp_required: false,\n314:     capacity: 50,\n315:     hosted_by: currentUserId,\n316:   };\n317:   state.events.push(evt);\n318:   emit();\n319:   return evt;\n320: }\n321: export const getMyRSVP = (eventId: string): RSVPStatus | null =>\n322:   state.attendees.find((a) => a.event === eventId && a.user === currentUserId)?.rsvp_status ?? null;\n323: \n324: export function requestMentor(mentorId: string, notes: string): FGMentorMatch {\n325:   const m: FGMentorMatch = {\n326:     id: uid(\"match\"),\n327:     mentee: currentUserId,\n328:     mentor: mentorId,\n329:     status: \"Requested\",\n330:     matched_on: new Date().toISOString(),\n331:     matched_via: \"Self-Requested\",\n332:     match_notes: notes,\n333:   };\n334:   state.matches.push(m);\n335:   emit();\n336:   return m;\n337: }\n338: \n339: // --- LMS mutators ---\n340: export function createCourse(input: {\n341:   title: string;\n342:   short_introduction: string;\n343:   description: string;\n344:   category: string;\n345:   tags: string;\n346: }): LMSCourse {\n347:   const c: LMSCourse = {\n348:     id: slugify(input.title) || uid(\"course\"),\n349:     title: input.title.trim(),\n350:     short_introduction: input.short_introduction,\n351:     description: input.description,\n352:     image: \"\",\n353:     paid_course: false,\n354:     featured: false,\n355:     published: true,\n356:     enable_certification: false,\n357:     category: input.category || \"General\",\n358:     tags: input.tags,\n359:     status: \"Approved\",\n360:     author: currentUserId,\n361:     enrollments: 0,\n362:     lessons: 0,\n363:     created_at: new Date().toISOString(),\n364:   };\n365:   state.courses.unshift(c);\n366:   // Auto-create a first chapter so the course has somewhere to add lessons.\n367:   const chapter: LMSChapter = {\n368:     id: uid(\"ch\"),\n369:     course: c.id,\n370:     title: \"Chapter 1\",\n371:     description: \"Your first chapter\",\n372:     idx: 1,\n373:   };\n374:   state.chapters.push(chapter);\n375:   emit();\n376:   return c;\n377: }\n378: \n379: export function addChapter(courseId: string, title: string): LMSChapter {\n380:   const existing = getChaptersForCourse(courseId);\n381:   const ch: LMSChapter = {\n382:     id: uid(\"ch\"),\n383:     course: courseId,\n384:     title,\n385:     description: \"\",\n386:     idx: existing.length + 1,\n387:   };\n388:   state.chapters.push(ch);\n389:   emit();\n390:   return ch;\n391: }\n392: \n393: export function addLesson(input: {\n394:   course: string;\n395:   chapter: string;\n396:   title: string;\n397:   body: string;\n398:   youtube_video: string;\n399: }): LMSLesson {\n400:   const siblings = getLessonsForChapter(input.chapter);\n401:   const l: LMSLesson = {\n402:     id: uid(\"ls\"),\n403:     chapter: input.chapter,\n404:     course: input.course,\n405:     title: input.title.trim(),\n406:     body: input.body,\n407:     youtube_video: extractYouTubeId(input.youtube_video),\n408:     include_in_preview: false,\n409:     idx: siblings.length + 1,\n410:   };\n411:   state.lessons.push(l);\n412:   const course = getCourse(input.course);\n413:   if (course) course.lessons = getLessonsForCourse(input.course).length;\n414:   emit();\n415:   return l;\n416: }\n417: \n418: export function enrollInCourse(courseId: string) {\n419:   if (getEnrollment(courseId)) return;\n420:   state.enrollments.push({\n421:     id: uid(\"enr\"),\n422:     member: currentUserId,\n423:     course: courseId,\n424:     member_type: \"Student\",\n425:     progress: 0,\n426:     enrolled_on: new Date().toISOString(),\n427:   });\n428:   const c = getCourse(courseId);\n429:   if (c) c.enrollments++;\n430:   emit();\n431: }\n432: \n433: export function markLessonComplete(lessonId: string, complete: boolean) {\n434:   const lesson = getLesson(lessonId);\n435:   if (!lesson) return;\n436:   const idx = state.progress.findIndex((p) => p.lesson === lessonId && p.member === currentUserId);\n437:   if (complete) {\n438:     if (idx >= 0) state.progress[idx].status = \"Complete\";\n439:     else\n440:       state.progress.push({\n441:         id: uid(\"prg\"),\n442:         member: currentUserId,\n443:         course: lesson.course,\n444:         lesson: lessonId,\n445:         status: \"Complete\",\n446:       });\n447:   } else if (idx >= 0) {\n448:     state.progress.splice(idx, 1);\n449:   }\n450:   const enr = getEnrollment(lesson.course);\n451:   if (enr) enr.progress = courseProgressPercent(lesson.course);\n452:   emit();\n453: }\n454: \n455: /** Accept full YouTube URLs OR raw IDs; return the 11-char ID or \"\". */\n456: export function extractYouTubeId(input: string): string {\n457:   if (!input) return \"\";\n458:   const trimmed = input.trim();\n459:   if (/^[a-zA-Z0-9_-]{11}$/.test(trimmed)) return trimmed;\n460:   const m = trimmed.match(\n461:     /(?:youtube\\.com\\/(?:watch\\?v=|embed\\/|shorts\\/)|youtu\\.be\\/)([a-zA-Z0-9_-]{11})/,\n462:   );\n463:   return m ? m[1] : \"\";\n464: }\n465: \n466: // --- mocked AI (keyword stubs — NOT real ML) ---\n467: const NEG = [\n468:   \"hopeless\",\n469:   \"drop out\",\n470:   \"dropping out\",\n471:   \"can't cope\",\n472:   \"cant cope\",\n473:   \"give up\",\n474:   \"alone\",\n475:   \"worthless\",\n476:   \"panic\",\n477:   \"overwhelmed\",\n478:   \"lost\",\n479:   \"don't belong\",\n480:   \"dont belong\",\n481: ];\n482: const SOFT_NEG = [\"tired\", \"stressed\", \"anxious\", \"scared\", \"struggling\"];\n483: const POS = [\"win\", \"proud\", \"grateful\", \"thank\", \"great\", \"love\", \"🎉\", \"💛\", \"happy\"];\n484: \n485: export function mockSentiment(text: string): {\n486:   label: SentimentLabel;\n487:   score: number;\n488: } {\n489:   const plain = text.replace(/<[^>]+>/g, \" \").toLowerCase();\n490:   let neg = 0,\n491:     pos = 0;\n492:   for (const k of NEG) if (plain.includes(k)) neg += 1;\n493:   for (const k of SOFT_NEG) if (plain.includes(k)) neg += 0.4;\n494:   for (const k of POS) if (plain.includes(k)) pos += 1;\n495:   const ai = getAISettings();\n496:   if (neg >= 1.4) {\n497:     const score = Math.min(0.6 + neg * 0.15, 0.98);\n498:     if (score >= ai.sentiment_alert_threshold) return { label: \"Needs Attention\", score };\n499:     return { label: \"Negative\", score };\n500:   }\n501:   if (pos > neg && pos >= 1) return { label: \"Positive\", score: 0.6 + pos * 0.1 };\n502:   if (neg > 0) return { label: \"Negative\", score: 0.4 + neg * 0.1 };\n503:   return { label: \"Neutral\", score: 0.5 };\n504: }\n505: \n506: export function findSimilarPosts(discussionId: string, limit = 3) {\n507:   const target = getDiscussion(discussionId);\n508:   if (!target) return [];\n509:   const tok = (s: string) =>\n510:     new Set(\n511:       s\n512:         .replace(/<[^>]+>/g, \" \")\n513:         .toLowerCase()\n514:         .split(/\\W+/)\n515:         .filter((w) => w.length > 4),\n516:     );\n517:   const t = tok(target.title + \" \" + target.content);\n518:   return state.discussions\n519:     .filter((d) => d.id !== discussionId && d.project === target.project)\n520:     .map((d) => {\n521:       const dt = tok(d.title + \" \" + d.content);\n522:       let overlap = 0;\n523:       dt.forEach((w) => t.has(w) && overlap++);\n524:       return { post: d, score: overlap };\n525:     })\n526:     .sort((a, b) => b.score - a.score)\n527:     .slice(0, limit)\n528:     .map((x) => x.post);\n529: }\n530: \n531: // ============================================================\n532: // DMs\n533: // ============================================================\n534: export const getDMThreadsForUser = (userId = currentUserId): FGDMThread[] =>\n535:   [...state.dmThreads]\n536:     .filter((t) => t.member_a === userId || t.member_b === userId)\n537:     .sort((a, b) => b.last_message_at.localeCompare(a.last_message_at));\n538: \n539: export const getDMThread = (id: string) => state.dmThreads.find((t) => t.id === id);\n540: \n541: export const getDMMessages = (threadId: string): FGDMMessage[] =>\n542:   state.dmMessages\n543:     .filter((m) => m.thread === threadId)\n544:     .sort((a, b) => a.created_at.localeCompare(b.created_at));\n545: \n546: export const getOtherMember = (thread: FGDMThread, userId = currentUserId) =>\n547:   thread.member_a === userId ? thread.member_b : thread.member_a;\n548: \n549: export function openOrCreateDMWith(otherUserId: string): FGDMThread {\n550:   if (otherUserId === currentUserId) {\n551:     return state.dmThreads[0];\n552:   }\n553:   const existing = state.dmThreads.find(\n554:     (t) =>\n555:       (t.member_a === currentUserId && t.member_b === otherUserId) ||\n556:       (t.member_b === currentUserId && t.member_a === otherUserId),\n557:   );\n558:   if (existing) return existing;\n559:   const t: FGDMThread = {\n560:     id: uid(\"dm\"),\n561:     member_a: currentUserId,\n562:     member_b: otherUserId,\n563:     last_message_at: new Date().toISOString(),\n564:     last_message_preview: \"\",\n565:   };\n566:   state.dmThreads.unshift(t);\n567:   emit();\n568:   return t;\n569: }\n570: \n571: export function sendDM(threadId: string, content: string): FGDMMessage | null {\n572:   const t = getDMThread(threadId);\n573:   if (!t || !content.trim()) return null;\n574:   const m: FGDMMessage = {\n575:     id: uid(\"m\"),\n576:     thread: threadId,\n577:     sender: currentUserId,\n578:     content: content.trim(),\n579:     created_at: new Date().toISOString(),\n580:     read_by: [currentUserId],\n581:   };\n582:   state.dmMessages.push(m);\n583:   t.last_message_at = m.created_at;\n584:   t.last_message_preview = m.content.slice(0, 80);\n585:   emit();\n586:   return m;\n587: }\n588: \n589: export function markThreadRead(threadId: string) {\n590:   let changed = false;\n591:   state.dmMessages.forEach((m) => {\n592:     if (m.thread === threadId && !m.read_by.includes(currentUserId)) {\n593:       m.read_by.push(currentUserId);\n594:       changed = true;\n595:     }\n596:   });\n597:   if (changed) emit();\n598: }\n599: \n600: export const getUnreadDMCount = (userId = currentUserId) =>\n601:   state.dmMessages.filter(\n602:     (m) =>\n603:       m.sender !== userId &&\n604:       !m.read_by.includes(userId) &&\n605:       state.dmThreads.some(\n606:         (t) => t.id === m.thread && (t.member_a === userId || t.member_b === userId),\n607:       ),\n608:   ).length;\n609: \n610: // ============================================================\n611: // Notifications\n612: // ============================================================\n613: export const getNotifications = (userId = currentUserId): FGNotification[] =>\n614:   state.notifications\n615:     .filter((n) => n.for_user === userId)\n616:     .sort((a, b) => b.created_at.localeCompare(a.created_at));\n617: \n618: export const getUnreadNotificationCount = (userId = currentUserId) =>\n619:   state.notifications.filter((n) => n.for_user === userId && !n.read).length;\n620: \n621: export function markAllNotificationsRead(userId = currentUserId) {\n622:   state.notifications.forEach((n) => {\n623:     if (n.for_user === userId) n.read = true;\n624:   });\n625:   emit();\n626: }\n627: \n628: export function markNotificationRead(id: string) {\n629:   const n = state.notifications.find((x) => x.id === id);\n630:   if (n && !n.read) {\n631:     n.read = true;\n632:     emit();\n633:   }\n634: }\n635: \n636: // ============================================================\n637: // SSO providers (admin settings)\n638: // ============================================================\n639: export const getSSOProviders = (): FGSSOProvider[] => state.ssoProviders;\n640: \n641: export function updateSSOProvider(id: SSOProviderId, patch: Partial<FGSSOProvider>) {\n642:   const p = state.ssoProviders.find((x) => x.id === id);\n643:   if (!p) return;\n644:   Object.assign(p, patch);\n645:   if (patch.enabled && !p.client_id_set && p.id !== \"email\") {\n646:     p.client_id_set = true; // mocked: pretend admin pasted a client ID\n647:   }\n648:   emit();\n649: }\n650: \n651: // ============================================================\n652: // Polls\n653: // ============================================================\n654: export const getPollForDiscussion = (discussionId: string): FGPoll | undefined =>\n655:   state.polls.find((p) => p.discussion === discussionId);\n656: \n657: export const getMyPollVote = (pollId: string): number | null =>\n658:   state.pollVotes.find((v) => v.poll === pollId && v.user === currentUserId)?.option_index ?? null;\n659: \n660: export function votePoll(pollId: string, optionIndex: number) {\n661:   const poll = state.polls.find((p) => p.id === pollId);\n662:   if (!poll || poll.is_closed) return;\n663: \n664:   // Remove existing vote if any\n665:   const existing = state.pollVotes.findIndex((v) => v.poll === pollId && v.user === currentUserId);\n666:   if (existing >= 0) {\n667:     const oldVote = state.pollVotes[existing];\n668:     poll.options[oldVote.option_index].votes--;\n669:     state.pollVotes.splice(existing, 1);\n670:   }\n671: \n672:   // Add new vote\n673:   state.pollVotes.push({\n674:     id: uid(\"pv\"),\n675:     poll: pollId,\n676:     user: currentUserId,\n677:     option_index: optionIndex,\n678:     created_at: new Date().toISOString(),\n679:   });\n680:   poll.options[optionIndex].votes++;\n681:   emit();\n682: }\n683: \n684: export const totalPollVotes = (pollId: string): number => {\n685:   const poll = state.polls.find((p) => p.id === pollId);\n686:   return poll ? poll.options.reduce((sum, o) => sum + o.votes, 0) : 0;\n687: };\n688: \n689: // ============================================================\n690: // Gamification — badges & energy points\n691: // ============================================================\n692: export const getBadges = (): FGBadge[] => state.badges;\n693: \n694: export const getBadgesForUser = (userId: string): { badge: FGBadge; awarded_at: string }[] =>\n695:   state.badgeAwards\n696:     .filter((a) => a.user === userId)\n697:     .map((a) => {\n698:       const badge = state.badges.find((b) => b.id === a.badge)!;\n699:       return { badge, awarded_at: a.awarded_at };\n700:     })\n701:     .sort((a, b) => a.awarded_at.localeCompare(b.awarded_at));\n702: \n703: export const getEnergyPoints = (userId: string): number =>\n704:   state.energyPoints.find((e) => e.user === userId)?.points ?? 0;\n705: \n706: export function awardBadgeIfNew(userId: string, badgeId: string) {\n707:   const existing = state.badgeAwards.find((a) => a.user === userId && a.badge === badgeId);\n708:   if (existing) return;\n709:   state.badgeAwards.push({\n710:     id: uid(\"ba\"),\n711:     badge: badgeId,\n712:     user: userId,\n713:     awarded_at: new Date().toISOString(),\n714:   });\n715:   emit();\n716: }\n717: \n718: export function addEnergyPoints(userId: string, pts: number) {\n719:   const ep = state.energyPoints.find((e) => e.user === userId);\n720:   if (ep) ep.points += pts;\n721:   else state.energyPoints.push({ user: userId, points: pts });\n722:   emit();\n723: }\n\n(End of file - total 723 lines)\n</content>",
