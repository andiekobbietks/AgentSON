      "output": "<task id=\"ses_11ba4d52dffel3RfCc4jj2VZVJ\" state=\"completed\">\n<task_result>\nHere are the complete contents of both files:\n\n## `seed.ts` (884 lines)\n\n```typescript\nimport type {\n  GPTeam,\n  GPProject,\n  GPDiscussion,\n  GPComment,\n  GPReaction,\n  GPUserProfile,\n  LMSCourse,\n  LMSChapter,\n  LMSLesson,\n  LMSEnrollment,\n  LMSCourseProgress,\n  FGEvent,\n  FGEventAttendee,\n  FGMentorMatch,\n  FGAISettings,\n  FGUserSettings,\n  FGDMThread,\n  FGDMMessage,\n  FGNotification,\n  FGSSOProvider,\n} from \"./types\";\n\nconst now = Date.now();\nconst daysAgo = (d: number) => new Date(now - d * 86400000).toISOString();\nconst daysAhead = (d: number) => new Date(now + d * 86400000).toISOString();\n\nexport const CURRENT_USER_ID = \"maya@firstgens.test\";\n\nexport const seedUsers: GPUserProfile[] = [\n  {\n    user: \"maya@firstgens.test\",\n    enabled: true,\n    full_name: \"Maya Okafor\",\n    bio: \"First-year sociology. First in my family to go to uni. Coffee + library = happy.\",\n    readme:\n      \"Hi! I'm Maya. I grew up in Peckham and I'm the first person in my family to study at university. I'm interested in social policy, housing and community organising. Outside of class you'll find me at the campus radio station or wandering around Borough Market pretending I can afford the cheese.\",\n    image: \"\",\n    cover_image: \"\",\n    image_background_color: \"#ede9fe\",\n  },\n  {\n    user: \"jordan@firstgens.test\",\n    enabled: true,\n    full_name: \"Jordan Reyes\",\n    bio: \"Third-year CS. Peer mentor. Ask me about imposter syndrome.\",\n    readme: \"Third-year CS student, peer mentor on the FirstGens programme.\",\n    image: \"\",\n    cover_image: \"\",\n    image_background_color: \"#dbeafe\",\n  },\n  {\n    user: \"sam@firstgens.test\",\n    enabled: true,\n    full_name: \"Sam Lindqvist\",\n    bio: \"Second-year economics. Loves study groups, hates 9am lectures.\",\n    readme: \"\",\n    image: \"\",\n    cover_image: \"\",\n    image_background_color: \"#fef3c7\",\n  },\n  {\n    user: \"priya@firstgens.test\",\n    enabled: true,\n    full_name: \"Priya Natarajan\",\n    bio: \"PhD candidate, mentor in the Mentor Lounge. Here to listen.\",\n    readme: \"\",\n    image: \"\",\n    cover_image: \"\",\n    image_background_color: \"#dcfce7\",\n  },\n  {\n    user: \"alex@firstgens.test\",\n    enabled: true,\n    full_name: \"Alex Chen\",\n    bio: \"Fourth-year biomedical sciences. Survived first year, you will too.\",\n    readme: \"\",\n    image: \"\",\n    cover_image: \"\",\n    image_background_color: \"#fce7f3\",\n  },\n  {\n    user: \"rosa@firstgens.test\",\n    enabled: true,\n    full_name: \"Dr. Rosa Hassan\",\n    bio: \"Programme coordinator. Space admin for First Year Support.\",\n    readme: \"\",\n    image: \"\",\n    cover_image: \"\",\n    image_background_color: \"#e0e7ff\",\n  },\n];\n\nexport const seedTeams: GPTeam[] = [\n  {\n    id: \"Community\",\n    title: \"Community\",\n    icon: \"🫶\",\n    is_private: false,\n    archived_at: null,\n    archived_by: null,\n  },\n  {\n    id: \"Academic Support\",\n    title: \"Academic Support\",\n    icon: \"🎓\",\n    is_private: false,\n    archived_at: null,\n    archived_by: null,\n  },\n];\n\nexport const seedProjects: GPProject[] = [\n  {\n    id: \"first-year-support\",\n    title: \"First Year Support\",\n    description:\n      \"A soft landing for first-gen students starting university. Questions welcome, no judgement.\",\n    status: \"Open\",\n    team: \"Community\",\n    progress: 0,\n    icon: \"🌱\",\n    readme: \"\",\n    tasks_count: 0,\n    discussions_count: 3,\n    archived_at: null,\n    archived_by: null,\n    is_private: false,\n  },\n  {\n    id: \"mentor-lounge\",\n    title: \"Mentor Lounge\",\n    description: \"Where mentees and mentors hang out, share wins, and ask the awkward questions.\",\n    status: \"Open\",\n    team: \"Community\",\n    progress: 0,\n    icon: \"🛋️\",\n    readme: \"\",\n    tasks_count: 0,\n    discussions_count: 2,\n    archived_at: null,\n    archived_by: null,\n    is_private: false,\n  },\n  {\n    id: \"study-skills\",\n    title: \"Study Skills\",\n    description:\n      \"Note-taking, exam prep, and how to actually read an academic paper without crying.\",\n    status: \"Open\",\n    team: \"Academic Support\",\n    progress: 0,\n    icon: \"📚\",\n    readme: \"\",\n    tasks_count: 0,\n    discussions_count: 1,\n    archived_at: null,\n    archived_by: null,\n    is_private: false,\n  },\n  {\n    id: \"money-matters\",\n    title: \"Money Matters\",\n    description: \"Bursaries, budgeting, part-time work. Talking about money is allowed here.\",\n    status: \"Open\",\n    team: \"Community\",\n    progress: 0,\n    icon: \"💸\",\n    readme: \"\",\n    tasks_count: 0,\n    discussions_count: 1,\n    archived_at: null,\n    archived_by: null,\n    is_private: false,\n  },\n];\n\nexport const seedDiscussions: GPDiscussion[] = [\n  {\n    id: \"1\",\n    project: \"first-year-support\",\n    team: \"Community\",\n    status: \"\",\n    title: \"Does anyone else feel like everyone knows what they're doing except them?\",\n    slug: \"does-anyone-else-feel-like-everyone-knows\",\n    content:\n      \"<p>I'm two weeks in and I swear every other student grew up knowing what a 'seminar' is. I keep nodding along. Is this normal? I feel completely lost and honestly a bit hopeless about whether I belong here at all.</p>\",\n    last_post_at: daysAgo(0),\n    last_post_by: \"alex@firstgens.test\",\n    comments_count: 2,\n    participants_count: 3,\n    closed_at: null,\n    closed_by: null,\n    pinned_at: null,\n    pinned_by: null,\n    author_id: \"maya@firstgens.test\",\n    created_at: daysAgo(1),\n  },\n  {\n    id: \"2\",\n    project: \"first-year-support\",\n    team: \"Community\",\n    status: \"\",\n    title: \"Free welcome breakfast on Friday — bring a friend\",\n    slug: \"free-welcome-breakfast-on-friday\",\n    content:\n      \"<p>Reminder that the welcome breakfast is this Friday at 9am in the Atrium. Free pastries, free coffee, and a few of us older students will be there to answer anything. No sign-up needed. 💛</p>\",\n    last_post_at: daysAgo(1),\n    last_post_by: \"sam@firstgens.test\",\n    comments_count: 1,\n    participants_count: 2,\n    closed_at: null,\n    closed_by: null,\n    pinned_at: daysAgo(2),\n    pinned_by: \"rosa@firstgens.test\",\n    author_id: \"rosa@firstgens.test\",\n    created_at: daysAgo(3),\n  },\n  {\n    id: \"3\",\n    project: \"first-year-support\",\n    team: \"Community\",\n    status: \"\",\n    title: \"Tip: office hours are not scary\",\n    slug: \"tip-office-hours-are-not-scary\",\n    content:\n      \"<p>Took me a whole term to figure this out — lecturers actually <em>want</em> you to come to office hours. You don't need a brilliant question. 'I'm a bit lost' is a fine opener.</p>\",\n    last_post_at: daysAgo(4),\n    last_post_by: \"alex@firstgens.test\",\n    comments_count: 0,\n    participants_count: 1,\n    closed_at: null,\n    closed_by: null,\n    pinned_at: null,\n    pinned_by: null,\n    author_id: \"alex@firstgens.test\",\n    created_at: daysAgo(4),\n  },\n  {\n    id: \"4\",\n    project: \"mentor-lounge\",\n    team: \"Community\",\n    status: \"\",\n    title: \"Mentors: how do you handle a mentee who goes quiet?\",\n    slug: \"mentors-mentee-quiet\",\n    content:\n      \"<p>My mentee hasn't replied in two weeks. I don't want to be pushy but I also don't want them to disappear. How do you all approach this?</p>\",\n    last_post_at: daysAgo(0),\n    last_post_by: \"priya@firstgens.test\",\n    comments_count: 1,\n    participants_count: 2,\n    closed_at: null,\n    closed_by: null,\n    pinned_at: null,\n    pinned_by: null,\n    author_id: \"jordan@firstgens.test\",\n    created_at: daysAgo(2),\n  },\n  {\n    id: \"5\",\n    project: \"mentor-lounge\",\n    team: \"Community\",\n    status: \"\",\n    title: \"Win of the week 🎉\",\n    slug: \"win-of-the-week\",\n    content:\n      \"<p>My mentee just submitted their first essay and got a 68. Last month they were ready to drop out. So proud.</p>\",\n    last_post_at: daysAgo(1),\n    last_post_by: \"priya@firstgens.test\",\n    comments_count: 0,\n    participants_count: 1,\n    closed_at: null,\n    closed_by: null,\n    pinned_at: null,\n    pinned_by: null,\n    author_id: \"priya@firstgens.test\",\n    created_at: daysAgo(1),\n  },\n  {\n    id: \"6\",\n    project: \"study-skills\",\n    team: \"Academic Support\",\n    status: \"\",\n    title: \"How do you actually take notes in a lecture?\",\n    slug: \"how-do-you-actually-take-notes\",\n    content:\n      \"<p>Pen and paper? Laptop? A weird Notion setup? I've tried all three and somehow my notes are useless by the time I get home.</p>\",\n    last_post_at: daysAgo(3),\n    last_post_by: \"sam@firstgens.test\",\n    comments_count: 0,\n    participants_count: 1,\n    closed_at: null,\n    closed_by: null,\n    pinned_at: null,\n    pinned_by: null,\n    author_id: \"sam@firstgens.test\",\n    created_at: daysAgo(3),\n  },\n  {\n    id: \"7\",\n    project: \"money-matters\",\n    team: \"Community\",\n    status: \"\",\n    title: \"Bursary application deadline next Tuesday — don't miss it\",\n    slug: \"bursary-application-deadline\",\n    content:\n      \"<p>The hardship bursary closes next Tuesday at 5pm. If money is tight, please apply — it's not means-tested very strictly and lots of first-gen students get it.</p>\",\n    last_post_at: daysAgo(1),\n    last_post_by: \"rosa@firstgens.test\",\n    comments_count: 0,\n    participants_count: 1,\n    closed_at: null,\n    closed_by: null,\n    pinned_at: daysAgo(1),\n    pinned_by: \"rosa@firstgens.test\",\n    author_id: \"rosa@firstgens.test\",\n    created_at: daysAgo(1),\n  },\n];\n\nexport const seedComments: GPComment[] = [\n  {\n    id: \"c_1\",\n    content:\n      \"<p>You are absolutely not alone. I felt exactly the same in my first term — turns out half my course were quietly panicking too. It does get easier, promise. 💛</p>\",\n    reference_doctype: \"GP Discussion\",\n    reference_name: \"1\",\n    deleted_at: null,\n    author_id: \"jordan@firstgens.test\",\n    created_at: daysAgo(0),\n  },\n  {\n    id: \"c_2\",\n    content:\n      \"<p>+1 to Jordan. Also — there's a drop-in chat with Dr. Hassan on Thursday, totally informal, might be worth a look.</p>\",\n    reference_doctype: \"GP Discussion\",\n    reference_name: \"1\",\n    deleted_at: null,\n    author_id: \"alex@firstgens.test\",\n    created_at: daysAgo(0),\n  },\n  {\n    id: \"c_3\",\n    content: \"<p>Will be there!</p>\",\n    reference_doctype: \"GP Discussion\",\n    reference_name: \"2\",\n    deleted_at: null,\n    author_id: \"sam@firstgens.test\",\n    created_at: daysAgo(1),\n  },\n  {\n    id: \"c_4\",\n    content:\n      '<p>Usually I send one low-pressure check-in (\"no need to reply, just thinking of you\") and then give it space. Most come back eventually.</p>',\n    reference_doctype: \"GP Discussion\",\n    reference_name: \"4\",\n    deleted_at: null,\n    author_id: \"priya@firstgens.test\",\n    created_at: daysAgo(0),\n  },\n];\n\nexport const seedReactions: GPReaction[] = [\n  {\n    id: \"r_1\",\n    reference_doctype: \"GP Discussion\",\n    reference_name: \"1\",\n    user: \"jordan@firstgens.test\",\n    emoji: \"💛\",\n  },\n  {\n    id: \"r_2\",\n    reference_doctype: \"GP Discussion\",\n    reference_name: \"1\",\n    user: \"alex@firstgens.test\",\n    emoji: \"💛\",\n  },\n  {\n    id: \"r_3\",\n    reference_doctype: \"GP Discussion\",\n    reference_name: \"1\",\n    user: \"rosa@firstgens.test\",\n    emoji: \"🤗\",\n  },\n  {\n    id: \"r_4\",\n    reference_doctype: \"GP Discussion\",\n    reference_name: \"2\",\n    user: \"maya@firstgens.test\",\n    emoji: \"🎉\",\n  },\n  {\n    id: \"r_5\",\n    reference_doctype: \"GP Discussion\",\n    reference_name: \"5\",\n    user: \"jordan@firstgens.test\",\n    emoji: \"🎉\",\n  },\n  {\n    id: \"r_6\",\n    reference_doctype: \"GP Discussion\",\n    reference_name: \"5\",\n    user: \"alex@firstgens.test\",\n    emoji: \"🎉\",\n  },\n];\n\n// ============================================================\n// LMS seed — fully demoable\n// ============================================================\n\nexport const seedCourses: LMSCourse[] = [\n  {\n    id: \"navigating-uni-first-gen\",\n    title: \"Navigating University as a First-Gen Student\",\n    short_introduction:\n      \"The unwritten rules nobody told you about office hours, reading lists, and asking for help.\",\n    description:\n      \"A friendly orientation for students who are the first in their family to attend university. We cover the hidden curriculum — the things everyone seems to already know but no-one taught you.\",\n    image: \"\",\n    paid_course: false,\n    featured: true,\n    published: true,\n    enable_certification: true,\n    category: \"Student Life\",\n    tags: \"first-gen, orientation, study skills\",\n    status: \"Approved\",\n    author: \"rosa@firstgens.test\",\n    enrollments: 318,\n    lessons: 3,\n    created_at: daysAgo(60),\n  },\n  {\n    id: \"academic-writing-101\",\n    title: \"Academic Writing 101\",\n    short_introduction:\n      \"How to structure an essay, cite sources, and not panic at the word 'argument'.\",\n    description:\n      \"Eight short lessons taking you from blank page to submitted essay, with worked examples.\",\n    image: \"\",\n    paid_course: false,\n    featured: true,\n    published: true,\n    enable_certification: false,\n    category: \"Writing\",\n    tags: \"writing, essays, citation\",\n    status: \"Approved\",\n    author: \"priya@firstgens.test\",\n    enrollments: 142,\n    lessons: 2,\n    created_at: daysAgo(40),\n  },\n  {\n    id: \"budgeting-student-loan\",\n    title: \"Budgeting on a Student Loan\",\n    short_introduction: \"Practical money basics. No jargon, no judgement.\",\n    description:\n      \"Working out what comes in, what goes out, and what to do when the numbers don't add up.\",\n    image: \"\",\n    paid_course: false,\n    featured: false,\n    published: true,\n    enable_certification: false,\n    category: \"Money\",\n    tags: \"money, budgeting, loans\",\n    status: \"Approved\",\n    author: \"rosa@firstgens.test\",\n    enrollments: 89,\n    lessons: 2,\n    created_at: daysAgo(20),\n  },\n];\n\nexport const seedChapters: LMSChapter[] = [\n  {\n    id: \"ch_nav_1\",\n    course: \"navigating-uni-first-gen\",\n    title: \"Before you arrive\",\n    description: \"Mindset, paperwork, packing.\",\n    idx: 1,\n  },\n  {\n    id: \"ch_nav_2\",\n    course: \"navigating-uni-first-gen\",\n    title: \"The hidden curriculum\",\n    description: \"Office hours, reading lists, jargon.\",\n    idx: 2,\n  },\n  {\n    id: \"ch_aw_1\",\n    course: \"academic-writing-101\",\n    title: \"Planning an essay\",\n    description: \"From question to outline.\",\n    idx: 1,\n  },\n  {\n    id: \"ch_bg_1\",\n    course: \"budgeting-student-loan\",\n    title: \"The basics\",\n    description: \"Money in, money out.\",\n    idx: 1,\n  },\n];\n\n// Hand-picked, real, embeddable public lectures / Khan-style overviews.\nexport const seedLessons: LMSLesson[] = [\n  {\n    id: \"ls_nav_1\",\n    chapter: \"ch_nav_1\",\n    course: \"navigating-uni-first-gen\",\n    title: \"Welcome — what 'first-gen' means here\",\n    body: \"<p>Welcome to the course. In this short intro Dr. Hassan explains who the course is for and how to get the most out of it. Watch the video, then jump to the next lesson.</p><p><strong>Reflection:</strong> write one sentence about why you signed up. You don't have to share it.</p>\",\n    youtube_video: \"ZXsQAXx_ao0\",\n    include_in_preview: true,\n    idx: 1,\n  },\n  {\n    id: \"ls_nav_2\",\n    chapter: \"ch_nav_2\",\n    course: \"navigating-uni-first-gen\",\n    title: \"Office hours, demystified\",\n    body: \"<p>Office hours are the single most underused resource at university. Here's what they are, how to book one, and what to say when you arrive.</p>\",\n    youtube_video: \"1eVMG9LcDxk\",\n    include_in_preview: false,\n    idx: 1,\n  },\n  {\n    id: \"ls_nav_3\",\n    chapter: \"ch_nav_2\",\n    course: \"navigating-uni-first-gen\",\n    title: \"Reading a reading list without crying\",\n    body: \"<p>Not every item on a reading list is meant to be read cover-to-cover. We break down which are core, which are supplementary, and how to skim with purpose.</p>\",\n    youtube_video: \"\",\n    include_in_preview: false,\n    idx: 2,\n  },\n  {\n    id: \"ls_aw_1\",\n    chapter: \"ch_aw_1\",\n    course: \"academic-writing-101\",\n    title: \"From question to outline\",\n    body: \"<p>Every good essay starts with breaking down the question. In this lesson we work through a real prompt together.</p>\",\n    youtube_video: \"vtIzMaLkCaM\",\n    include_in_preview: true,\n    idx: 1,\n  },\n  {\n    id: \"ls_aw_2\",\n    chapter: \"ch_aw_1\",\n    course: \"academic-writing-101\",\n    title: \"Building a paragraph that argues\",\n    body: \"<p>PEEL, TEAL, whatever you call it — the point is the same: claim, evidence, reasoning. Watch and then try the exercise.</p>\",\n    youtube_video: \"\",\n    include_in_preview: false,\n    idx: 2,\n  },\n  {\n    id: \"ls_bg_1\",\n    chapter: \"ch_bg_1\",\n    course: \"budgeting-student-loan\",\n    title: \"Where your money actually goes\",\n    body: \"<p>Track every spend for a week — yes, every coffee. The point isn't guilt, it's data.</p>\",\n    youtube_video: \"HQzoZfc3GwQ\",\n    include_in_preview: true,\n    idx: 1,\n  },\n  {\n    id: \"ls_bg_2\",\n    chapter: \"ch_bg_1\",\n    course: \"budgeting-student-loan\",\n    title: \"Making a 'survival budget'\",\n    body: \"<p>The minimum you need to keep the lights on. Anything above that is choice.</p>\",\n    youtube_video: \"\",\n    include_in_preview: false,\n    idx: 2,\n  },\n];\n\nexport const seedEnrollments: LMSEnrollment[] = [\n  {\n    id: \"enr_1\",\n    member: \"maya@firstgens.test\",\n    course: \"navigating-uni-first-gen\",\n    member_type: \"Student\",\n    progress: 33,\n    enrolled_on: daysAgo(7),\n  },\n];\n\nexport const seedProgress: LMSCourseProgress[] = [\n  {\n    id: \"prg_1\",\n    member: \"maya@firstgens.test\",\n    course: \"navigating-uni-first-gen\",\n    lesson: \"ls_nav_1\",\n    status: \"Complete\",\n  },\n];\n\nexport const seedEvents: FGEvent[] = [\n  {\n    id: \"event_1\",\n    title: \"Welcome Breakfast for First-Gen Students\",\n    description:\n      \"Coffee, pastries, and a chance to meet other students and mentors. No agenda, just hellos.\",\n    space: \"first-year-support\",\n    event_type: \"In-Person Meetup\",\n    starts_on: daysAhead(2),\n    ends_on: daysAhead(2),\n    location_type: \"In Person\",\n    bbb_meeting_id: null,\n    external_link: null,\n    physical_address: \"The Atrium, Student Union Building\",\n    rsvp_required: true,\n    capacity: 40,\n    hosted_by: \"rosa@firstgens.test\",\n  },\n  {\n    id: \"event_2\",\n    title: \"Office Hours: 'Help, I don't understand my reading list'\",\n    description: \"Drop-in session with Dr. Hassan. Bring a reading list, leave with a plan.\",\n    space: \"study-skills\",\n    event_type: \"Drop-in Office Hours\",\n    starts_on: daysAhead(5),\n    ends_on: daysAhead(5),\n    location_type: \"Online (BigBlueButton)\",\n    bbb_meeting_id: \"bbb-officehrs-2026-06\",\n    external_link: null,\n    physical_address: null,\n    rsvp_required: false,\n    capacity: 25,\n    hosted_by: \"rosa@firstgens.test\",\n  },\n  {\n    id: \"event_3\",\n    title: \"Webinar: Imposter Syndrome & You\",\n    description: \"Priya leads a frank conversation about that voice in your head. 45 mins + Q&A.\",\n    space: \"mentor-lounge\",\n    event_type: \"Webinar\",\n    starts_on: daysAhead(9),\n    ends_on: daysAhead(9),\n    location_type: \"Online (External Link)\",\n    bbb_meeting_id: null,\n    external_link: \"https://example.org/webinar/imposter\",\n    physical_address: null,\n    rsvp_required: true,\n    capacity: 100,\n    hosted_by: \"priya@firstgens.test\",\n  },\n];\n\nexport const seedAttendees: FGEventAttendee[] = [\n  { id: \"a_1\", event: \"event_1\", user: \"jordan@firstgens.test\", rsvp_status: \"Going\" },\n  { id: \"a_2\", event: \"event_1\", user: \"alex@firstgens.test\", rsvp_status: \"Going\" },\n  { id: \"a_3\", event: \"event_1\", user: \"sam@firstgens.test\", rsvp_status: \"Maybe\" },\n  { id: \"a_4\", event: \"event_3\", user: \"priya@firstgens.test\", rsvp_status: \"Going\" },\n  { id: \"a_5\", event: \"event_3\", user: \"jordan@firstgens.test\", rsvp_status: \"Going\" },\n];\n\nexport const seedMatches: FGMentorMatch[] = [\n  {\n    id: \"match_1\",\n    mentee: \"maya@firstgens.test\",\n    mentor: \"jordan@firstgens.test\",\n    status: \"Active\",\n    matched_on: daysAgo(20),\n    matched_via: \"Algorithmic Suggestion\",\n    match_notes: \"Both first-gen, overlapping interests in social sciences.\",\n  },\n  {\n    id: \"match_2\",\n    mentee: \"sam@firstgens.test\",\n    mentor: \"priya@firstgens.test\",\n    status: \"Requested\",\n    matched_on: daysAgo(2),\n    matched_via: \"Self-Requested\",\n    match_notes: \"Sam asked for a mentor with research experience.\",\n  },\n];\n\nexport const seedAISettings: FGAISettings = {\n  enable_sentiment: true,\n  sentiment_alert_threshold: 0.75,\n  enable_vector_search: true,\n};\n\nexport const seedUserSettings: FGUserSettings[] = [\n  {\n    user: \"maya@firstgens.test\",\n    email_on_mention: true,\n    email_on_reply: true,\n    email_weekly_digest: true,\n    push_on_dm: true,\n    push_on_mention: true,\n    show_in_member_directory: true,\n    allow_dm_from_anyone: true,\n    theme: \"system\",\n    language: \"en\",\n    timezone: \"Europe/London\",\n  },\n];\n\n// ============================================================\n// DMs — seeded conversations\n// ============================================================\n\nexport const seedDMThreads: FGDMThread[] = [\n  {\n    id: \"dm_maya_jordan\",\n    member_a: \"maya@firstgens.test\",\n    member_b: \"jordan@firstgens.test\",\n    last_message_at: daysAgo(0),\n    last_message_preview: \"thanks Jordan — that genuinely helps 💛\",\n  },\n  {\n    id: \"dm_maya_priya\",\n    member_a: \"maya@firstgens.test\",\n    member_b: \"priya@firstgens.test\",\n    last_message_at: daysAgo(2),\n    last_message_preview: \"Happy to chat about research — Thursday works.\",\n  },\n  {\n    id: \"dm_maya_rosa\",\n    member_a: \"maya@firstgens.test\",\n    member_b: \"rosa@firstgens.test\",\n    last_message_at: daysAgo(6),\n    last_message_preview: \"Bursary form attached — let me know if stuck.\",\n  },\n];\n\nexport const seedDMMessages: FGDMMessage[] = [\n  {\n    id: \"m_1\",\n    thread: \"dm_maya_jordan\",\n    sender: \"maya@firstgens.test\",\n    content: \"Hey! Saw you're a peer mentor — can I ask a daft question about seminars?\",\n    created_at: daysAgo(1),\n    read_by: [\"maya@firstgens.test\", \"jordan@firstgens.test\"],\n  },\n  {\n    id: \"m_2\",\n    thread: \"dm_maya_jordan\",\n    sender: \"jordan@firstgens.test\",\n    content: \"No daft questions here. Fire away.\",\n    created_at: daysAgo(1),\n    read_by: [\"maya@firstgens.test\", \"jordan@firstgens.test\"],\n  },\n  {\n    id: \"m_3\",\n    thread: \"dm_maya_jordan\",\n    sender: \"maya@firstgens.test\",\n    content: \"Am I supposed to have read all the reading before? Everyone seems to nod knowingly.\",\n    created_at: daysAgo(0),\n    read_by: [\"maya@firstgens.test\", \"jordan@firstgens.test\"],\n  },\n  {\n    id: \"m_4\",\n    thread: \"dm_maya_jordan\",\n    sender: \"jordan@firstgens.test\",\n    content: \"Skim the abstract + intro + conclusion. Honestly that's what most of us do week 1.\",\n    created_at: daysAgo(0),\n    read_by: [\"jordan@firstgens.test\"],\n  },\n  {\n    id: \"m_5\",\n    thread: \"dm_maya_jordan\",\n    sender: \"maya@firstgens.test\",\n    content: \"thanks Jordan — that genuinely helps 💛\",\n    created_at: daysAgo(0),\n    read_by: [\"maya@firstgens.test\"],\n  },\n  {\n    id: \"m_6\",\n    thread: \"dm_maya_priya\",\n    sender: \"priya@firstgens.test\",\n    content: \"Happy to chat about research — Thursday works.\",\n    created_at: daysAgo(2),\n    read_by: [\"priya@firstgens.test\"],\n  },\n  {\n    id: \"m_7\",\n    thread: \"dm_maya_rosa\",\n    sender: \"rosa@firstgens.test\",\n    content: \"Bursary form attached — let me know if stuck.\",\n    created_at: daysAgo(6),\n    read_by: [\"maya@firstgens.test\", \"rosa@firstgens.test\"],\n  },\n];\n\n// ============================================================\n// Notifications\n// ============================================================\n\nexport const seedNotifications: FGNotification[] = [\n  {\n    id: \"n_1\",\n    for_user: \"maya@firstgens.test\",\n    subject: \"Jordan replied to your DM\",\n    type: \"DM\",\n    document_type: \"FG DM Thread\",\n    document_name: \"dm_maya_jordan\",\n    read: false,\n    created_at: daysAgo(0),\n  },\n  {\n    id: \"n_2\",\n    for_user: \"maya@firstgens.test\",\n    subject: \"Alex commented on your post\",\n    type: \"Reply\",\n    document_type: \"GP Discussion\",\n    document_name: \"1\",\n    read: false,\n    created_at: daysAgo(0),\n  },\n  {\n    id: \"n_3\",\n    for_user: \"maya@firstgens.test\",\n    subject: \"Welcome Breakfast is in 2 days\",\n    type: \"Event\",\n    document_type: \"FG Event\",\n    document_name: \"event_1\",\n    read: false,\n    created_at: daysAgo(0),\n  },\n  {\n    id: \"n_4\",\n    for_user: \"maya@firstgens.test\",\n    subject: \"Your mentor match with Jordan is active\",\n    type: \"Mentor\",\n    document_type: \"FG Mentor Match\",\n    document_name: \"match_1\",\n    read: true,\n    created_at: daysAgo(20),\n  },\n];\n\n// ============================================================\n// SSO providers (admin-managed)\n// ============================================================\n\nexport const seedSSOProviders: FGSSOProvider[] = [\n  {\n    id: \"email\",\n    label: \"Email & password\",\n    enabled: true,\n    client_id_set: true,\n    notes: \"Built-in. Always available.\",\n  },\n  {\n    id: \"google\",\n    label: \"Google\",\n    enabled: false,\n    client_id_set: false,\n    notes: \"Workspace + personal Google accounts.\",\n  },\n  {\n    id: \"microsoft\",\n    label: \"Microsoft / Teams\",\n    enabled: false,\n    client_id_set: false,\n    notes: \"Azure AD / Entra ID — supports MS Teams SSO.\",\n  },\n  {\n    id: \"github\",\n    label: \"GitHub\",\n    enabled: false,\n    client_id_set: false,\n    notes: \"Good for STEM cohorts.\",\n  },\n  {\n    id: \"discord\",\n    label: \"Discord\",\n    enabled: false,\n    client_id_set: false,\n    notes: \"Popular with student communities.\",\n  },\n  {\n    id: \"apple\",\n    label: \"Apple\",\n    enabled: false,\n    client_id_set: false,\n    notes: \"Required if you ship a native iOS app.\",\n  },\n];\n```\n\n---\n\n## `types.ts` (312 lines)\n\n```typescript\n// Types intentionally mirror real Frappe DocTypes from frappe/gameplan and\n// frappe/lms. Researched against the live `main` branch .json files — see\n// /docs/01_SCHEMA_MAPPING_TO_FRAPPE.md and /docs/04_FRAPPE_TRANSLATION.md.\n//\n// IMPORTANT NAMING NOTES:\n// - Field names below are snake_case to mirror Frappe exactly.\n// - Where Frappe stores a value via standard meta fields (`name`, `owner`,\n//   `creation`, `modified`), we keep convenience aliases here (`id`,\n//   `author_id`, `created_at`) and document the mapping. This is the ONLY\n//   place those aliases exist — every component reads through them.\n// - Child-table rows in Frappe also carry implicit `parent`, `parenttype`,\n//   `parentfield`, `idx`. We don't model those for the prototype.\n\n// ============================================================\n// frappe/gameplan\n// ============================================================\n\n/** DocType: `GP Team` */\nexport interface GPTeam {\n  id: string;\n  title: string;\n  icon: string;\n  is_private: boolean;\n  archived_at: string | null;\n  archived_by: string | null;\n}\n\n/** DocType: `GP Project` (UI label: \"Space\") */\nexport interface GPProject {\n  id: string;\n  title: string;\n  description: string;\n  status: \"Open\" | \"Completed\";\n  team: string;\n  progress: number;\n  icon: string;\n  readme: string;\n  tasks_count: number;\n  discussions_count: number;\n  archived_at: string | null;\n  archived_by: string | null;\n  is_private: boolean;\n}\n\n/** DocType: `GP Discussion` (UI label: \"Post\") */\nexport interface GPDiscussion {\n  id: string;\n  project: string;\n  team: string;\n  status: string;\n  title: string;\n  slug: string;\n  content: string;\n  last_post_at: string;\n  last_post_by: string | null;\n  comments_count: number;\n  participants_count: number;\n  closed_at: string | null;\n  closed_by: string | null;\n  pinned_at: string | null;\n  pinned_by: string | null;\n  author_id: string;\n  created_at: string;\n}\n\n/** DocType: `GP Comment` */\nexport interface GPComment {\n  id: string;\n  content: string;\n  reference_doctype: \"GP Discussion\";\n  reference_name: string;\n  deleted_at: string | null;\n  author_id: string;\n  created_at: string;\n}\n\n/** DocType: `GP Reaction` (istable=1). */\nexport interface GPReaction {\n  id: string;\n  reference_doctype: \"GP Discussion\" | \"GP Comment\";\n  reference_name: string;\n  user: string;\n  emoji: string;\n}\n\n/** DocType: `GP User Profile` */\nexport interface GPUserProfile {\n  user: string;\n  enabled: boolean;\n  full_name: string;\n  bio: string;\n  readme: string;\n  image: string;\n  cover_image: string;\n  image_background_color: string;\n}\n\n// ============================================================\n// frappe/lms — full prototype (mirrors real DocType field names)\n// ============================================================\n\n/** DocType: `LMS Course` */\nexport interface LMSCourse {\n  id: string; // → `name`\n  title: string;\n  short_introduction: string;\n  description: string; // Text Editor — long form\n  image: string;\n  paid_course: boolean;\n  featured: boolean;\n  published: boolean;\n  enable_certification: boolean;\n  category: string;\n  tags: string; // comma separated, matches LMS\n  status: \"Draft\" | \"Approved\" | \"Under Review\";\n  author: string; // → Link `User` (instructor)\n  enrollments: number; // denormalised for cards\n  lessons: number; // denormalised\n  created_at: string;\n}\n\n/** DocType: `LMS Chapter` (parent: LMS Course) */\nexport interface LMSChapter {\n  id: string; // → `name`\n  course: string; // → Link `LMS Course`\n  title: string;\n  description: string;\n  idx: number; // order\n}\n\n/**\n * DocType: `LMS Lesson` (parent: LMS Chapter)\n *\n * In real LMS the body is a Markdown/HTML field with embedded shortcodes\n * like `{{ YouTubeVideo(\"VIDEO_ID\") }}`. For the prototype we surface\n * `youtube_video` as a first-class field — porting is a search/replace\n * to the shortcode form. See /docs/04_FRAPPE_TRANSLATION.md.\n */\nexport interface LMSLesson {\n  id: string; // → `name`\n  chapter: string; // → Link `LMS Chapter`\n  course: string; // → Link `LMS Course` (denormalised)\n  title: string;\n  body: string; // Markdown/HTML\n  youtube_video: string; // 11-char YouTube ID (or \"\")\n  include_in_preview: boolean;\n  idx: number;\n}\n\n/** DocType: `LMS Enrollment` */\nexport interface LMSEnrollment {\n  id: string;\n  member: string; // → Link `User`\n  course: string; // → Link `LMS Course`\n  member_type: \"Student\" | \"Mentor\";\n  progress: number; // 0..100\n  enrolled_on: string;\n}\n\n/** DocType: `LMS Course Progress` (per-lesson completion) */\nexport interface LMSCourseProgress {\n  id: string;\n  member: string;\n  course: string;\n  lesson: string;\n  status: \"Complete\" | \"Incomplete\";\n}\n\n// ============================================================\n// fg_companion — NEW custom Frappe app (to be created)\n// ============================================================\n\nexport type EventType =\n  | \"Webinar\"\n  | \"In-Person Meetup\"\n  | \"Workshop\"\n  | \"Drop-in Office Hours\"\n  | \"Networking\";\n\nexport type LocationType = \"Online (BigBlueButton)\" | \"Online (External Link)\" | \"In Person\";\n\n/** DocType (new): `FG Event` */\nexport interface FGEvent {\n  id: string;\n  title: string;\n  description: string;\n  space: string | null;\n  event_type: EventType;\n  starts_on: string;\n  ends_on: string;\n  location_type: LocationType;\n  bbb_meeting_id: string | null;\n  external_link: string | null;\n  physical_address: string | null;\n  rsvp_required: boolean;\n  capacity: number;\n  hosted_by: string;\n}\n\nexport type RSVPStatus = \"Going\" | \"Maybe\" | \"Not Going\" | \"Attended\" | \"No Show\";\n\n/** DocType (new): `FG Event Attendee` */\nexport interface FGEventAttendee {\n  id: string;\n  event: string;\n  user: string;\n  rsvp_status: RSVPStatus;\n}\n\nexport type MentorMatchStatus = \"Requested\" | \"Active\" | \"Completed\" | \"Ended Early\";\n\nexport type MatchedVia = \"Manual\" | \"Self-Requested\" | \"Algorithmic Suggestion\";\n\n/** DocType (new): `FG Mentor Match` */\nexport interface FGMentorMatch {\n  id: string;\n  mentee: string;\n  mentor: string;\n  status: MentorMatchStatus;\n  matched_on: string;\n  matched_via: MatchedVia;\n  match_notes: string;\n}\n\n/** Single DocType (new): `FG AI Settings` */\nexport interface FGAISettings {\n  enable_sentiment: boolean;\n  sentiment_alert_threshold: number;\n  enable_vector_search: boolean;\n}\n\n/**\n * DocType (new): `FG User Settings`\n *\n * Mirrors the per-user Notification + Privacy panels in Circle.\n * In Frappe these would be a mix of Notification Settings (core) and a\n * small custom DocType for community-specific toggles.\n */\nexport interface FGUserSettings {\n  user: string;\n  email_on_mention: boolean;\n  email_on_reply: boolean;\n  email_weekly_digest: boolean;\n  push_on_dm: boolean;\n  push_on_mention: boolean;\n  show_in_member_directory: boolean;\n  allow_dm_from_anyone: boolean;\n  theme: \"system\" | \"light\" | \"dark\";\n  language: \"en\" | \"es\" | \"fr\";\n  timezone: string;\n}\n\n// — mocked AI output (computed, not stored) —\nexport type SentimentLabel = \"Positive\" | \"Neutral\" | \"Negative\" | \"Needs Attention\";\n\n// ============================================================\n// fg_companion — DMs (mirrors Raven Channel / Raven Message)\n// ============================================================\n\n/** DocType (Raven): `Raven Channel` (1:1 DM variant) */\nexport interface FGDMThread {\n  id: string;\n  member_a: string;\n  member_b: string;\n  last_message_at: string;\n  last_message_preview: string;\n}\n\n/** DocType (Raven): `Raven Message` */\nexport interface FGDMMessage {\n  id: string;\n  thread: string;\n  sender: string;\n  content: string;\n  created_at: string;\n  read_by: string[];\n}\n\n/** DocType (Frappe core): `Notification Log` */\nexport interface FGNotification {\n  id: string;\n  for_user: string;\n  subject: string;\n  type: \"Mention\" | \"Reply\" | \"DM\" | \"Event\" | \"System\" | \"Mentor\";\n  document_type: \"GP Discussion\" | \"FG DM Thread\" | \"FG Event\" | \"FG Mentor Match\" | \"\";\n  document_name: string;\n  read: boolean;\n  created_at: string;\n}\n\n// ============================================================\n// fg_companion — SSO providers (per-workspace)\n// ============================================================\n\nexport type SSOProviderId = \"email\" | \"google\" | \"microsoft\" | \"github\" | \"discord\" | \"apple\";\n\n/**\n * DocType (new): `FG SSO Provider`\n *\n * Port targets:\n *  - Supabase: enable provider in Auth → Providers, then\n *    supabase.auth.signInWithOAuth({ provider: <id> })\n *  - Frappe: `Social Login Key` DocType (one row per provider) plus\n *    the OAuth flow in `frappe.integrations.oauth2`.\n */\nexport interface FGSSOProvider {\n  id: SSOProviderId;\n  label: string;\n  enabled: boolean;\n  client_id_set: boolean;\n  notes: string;\n}\n```\n</task_result>\n</task>",
      "status": "success",
