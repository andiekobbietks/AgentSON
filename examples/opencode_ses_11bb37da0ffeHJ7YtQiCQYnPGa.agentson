=> {\n188:                   updateUserSettings({ allow_dm_from_anyone: v });\n189:                   flash();\n190:                 }\n191:               \"\n192:             />\n193:           </div>\n194: \n195:           <!-- Appearance -->\n196:           <div v-if=\"tab === 'appearance'\" class=\"flex flex-col gap-4\">\n197:             <h2 class=\"text-[16px] font-semibold\">Appearance &amp; language</h2>\n198:             <label class=\"flex flex-col gap-1.5\">\n199:               <span class=\"text-[12px] font-semibold text-secondary-foreground\">Theme</span>\n200:               <select\n201:                 :value=\"settings.theme\"\n202:                 class=\"h-10 px-2 rounded-md border border-border bg-background text-[14px]\"\n203:                 @change=\"\n204:                   (e) => {\n205:                     updateUserSettings({\n206:                       theme: (e.target as HTMLSelectElement).value as 'system' | 'light' | 'dark',\n207:                     });\n208:                     flash();\n209:                   }\n210:                 \"\n211:               >\n212:                 <option value=\"system\">System</option>\n213:                 <option value=\"light\">Light</option>\n214:                 <option value=\"dark\">Dark</option>\n215:               </select>\n216:             </label>\n217:             <label class=\"flex flex-col gap-1.5\">\n218:               <span class=\"text-[12px] font-semibold text-secondary-foreground\">Language</span>\n219:               <select\n220:                 :value=\"settings.language\"\n221:                 class=\"h-10 px-2 rounded-md border border-border bg-background text-[14px]\"\n222:                 @change=\"\n223:                   (e) => {\n224:                     updateUserSettings({\n225:                       language: (e.target as HTMLSelectElement).value as 'en' | 'es' | 'fr',\n226:                     });\n227:                     flash();\n228:                   }\n229:                 \"\n230:               >\n231:                 <option value=\"en\">English</option>\n232:                 <option value=\"es\">Español</option>\n233:                 <option value=\"fr\">Français</option>\n234:               </select>\n235:             </label>\n236:             <div class=\"flex flex-col gap-1.5\">\n237:               <span class=\"text-[12px] font-semibold text-secondary-foreground\">Timezone</span>\n238:               <div\n239:                 class=\"h-10 px-3 rounded-md border border-border bg-background flex items-center gap-2 text-[13px] text-muted-foreground\"\n240:               >\n241:                 🌐 {{ settings.timezone }}\n242:               </div>\n243:             </div>\n244:           </div>\n245: \n246:           <!-- Sign-in & SSO -->\n247:           <div v-if=\"tab === 'signin'\" class=\"flex flex-col gap-4\">\n248:             <div>\n249:               <h2 class=\"text-[16px] font-semibold\">Sign-in methods</h2>\n250:               <p class=\"text-[12px] text-muted-foreground mt-1\">\n251:                 Choose how members sign in. Each provider maps to a Frappe\n252:                 <code class=\"font-mono\">Social Login Key</code> row.\n253:               </p>\n254:             </div>\n255:             <div class=\"rounded-xl border border-border bg-card divide-y divide-border\">\n256:               <div v-for=\"p in ssoProviders\" :key=\"p.id\" class=\"flex items-start gap-3 p-3.5\">\n257:                 <div\n258:                   class=\"size-9 rounded-lg bg-secondary flex items-center justify-center text-[15px]\"\n259:                 >\n260:                   {{ providerIcon(p.id) }}\n261:                 </div>\n262:                 <div class=\"flex-1 min-w-0\">\n263:                   <div class=\"flex items-center gap-2\">\n264:                     <div class=\"text-[14px] font-semibold\">{{ p.label }}</div>\n265:                     <span\n266:                       v-if=\"p.enabled\"\n267:                       class=\"text-[10px] uppercase tracking-wider font-bold text-success\"\n268:                       >Enabled</span\n269:                     >\n270:                   </div>\n271:                   <div class=\"text-[12px] text-muted-foreground mt-0.5\">{{ p.notes }}</div>\n272:                   <button\n273:                     v-if=\"p.enabled && p.id !== 'email'\"\n274:                     type=\"button\"\n275:                     class=\"mt-2 inline-flex h-7 px-3 rounded-md border border-border text-[12px] font-semibold hover:bg-secondary\"\n276:                     @click=\"alert(`In production this would launch the ${p.label} OAuth flow.`)\"\n277:                   >\n278:                     Test sign-in\n279:                   </button>\n280:                 </div>\n281:                 <button\n282:                   type=\"button\"\n283:                   role=\"switch\"\n284:                   :aria-checked=\"p.enabled\"\n285:                   :disabled=\"p.id === 'email'\"\n286:                   class=\"relative h-5 w-9 rounded-full transition-colors mt-1 disabled:opacity-50 disabled:cursor-not-allowed\"\n287:                   :class=\"p.enabled ? 'bg-primary' : 'bg-secondary'\"\n288:                   @click=\"\n289:                     () => {\n290:                       updateSSOProvider(p.id, { enabled: !p.enabled });\n291:                       flash();\n292:                     }\n293:                   \"\n294:                 >\n295:                   <span\n296:                     class=\"absolute top-0.5 size-4 rounded-full bg-card shadow transition-transform\"\n297:                     :class=\"p.enabled ? 'translate-x-[18px]' : 'translate-x-0.5'\"\n298:                   />\n299:                 </button>\n300:               </div>\n301:             </div>\n302:           </div>\n303:         </section>\n304:       </div>\n305:     </div>\n306:   </AppLayout>\n307: </template>\n308: \n309: <script setup lang=\"ts\">\n310: i