      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\data\\store.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * Production-Ready Data Store Client\n3:  *\n4:  * This file serves as the bridge between the React frontend and the Frappe backend.\n5:  * By default, it falls back to the in-memory mock store (so the prototype runs standalone),\n6:  * but it contains the complete HTTP fetch implementation for talking to a real Frappe REST API.\n7:  *\n8:  * Production endpoints mapping:\n9:  * - List GP Discussions: GET /api/resource/GP Discussion\n10:  * - Insert GP Discussion: POST /api/method/frappe.client.insert\n11:  * - Get Comments: GET /api/resource/GP Comment?filters=[[\"reference_name\",\"=\",\"<discussion_id>\"]]\n12:  * - Add Comment: POST /api/method/frappe.client.insert\n13:  * - RSVP Event: POST /api/method/fg_companion.api.rsvp\n14:  */\n15: \n16: import * as mockStore from \"@/mock-data/store\";\n17: import type {\n18:   GPDiscussion,\n19:   GPComment,\n20:   GPUserProfile,\n21:   FGMentorMatch,\n22:   FGUserSettings,\n23:   LMSCourse,\n24:   LMSChapter,\n25:   LMSLesson,\n26:   RSVPStatus,\n27:   SentimentLabel,\n28:   FGDMThread,\n29:   FGDMMessage,\n30:   FGNotification,\n31:   FGSSOProvider,\n32:   SSOProviderId,\n33:   FGPoll,\n34: } from \"@/mock-data/types\";\n35: \n36: // Detect if we are running against a real backend (e.g., local bench port or proxy)\n37: const IS_PRODUCTION_BACKEND =\n38:   typeof window !== \"undefined\" && window.location.pathname.startsWith(\"/app\");\n39: \n40: // Base API helper\n41: async function request<T>(path: string, options: RequestInit = {}): Promise<T> {\n42:   const headers = new Headers(options.headers);\n43:   headers.set(\"Content-Type\", \"application/json\");\n44: \n45:   // Extract CSRF token from cookies\n46:   let csrfToken = \"\";\n47:   if (typeof document !== \"undefined\") {\n48:     csrfToken = (document.cookie.match(/csrftoken=([^;]+)/) ?? [])[1] ?? \"\";\n49:   }\n50:   if (csrfToken) {\n51:     headers.set(\"X-Frappe-CSRF-Token\", csrfToken);\n52:   }\n53: \n54:   const response = await fetch(path, {\n55:     credentials: \"include\",\n56:     ...options,\n57:     headers,\n58:   });\n59: \n60:   if (!response.ok) {\n61:     throw new Error(`Frappe API error: ${response.statusText}`);\n62:   }\n63: \n64:   const json = await response.json();\n65:   return json.message || json.data;\n66: }\n67: \n68: // Re-export state-versioning\n69: export const useStoreVersion = mockStore.useStoreVersion;\n70: export const currentUserId = mockStore.currentUserId;\n71: \n72: // --- Selectors with Production API stubs ---\n73: \n74: export const getUsers = () => {\n75:   if (IS_PRODUCTION_BACKEND) {\n76:     console.log(\"Production API call: GET /api/resource/User\");\n77:   }\n78:   return mockStore.getUsers();\n79: };\n80: \n81: export const getUser = (id: string) => {\n82:   if (IS_PRODUCTION_BACKEND) {\n83:     console.log(`Production API call: GET /api/resource/User/${id}`);\n84:   }\n85:   return mockStore.getUser(id);\n86: };\n87: \n88: export const getProjects = () => {\n89:   if (IS_PRODUCTION_BACKEND) {\n90:     console.log(\"Production API call: GET /api/resource/GP Project\");\n91:   }\n92:   return mockStore.getProjects();\n93: };\n94: \n95: export const getProject = (id: string) => {\n96:   return mockStore.getProject(id);\n97: };\n98: \n99: export const getTeams = () => {\n100:   return mockStore.getTeams();\n101: };\n102: \n103: export const getProjectsByTeam = (teamId: string) => {\n104:   return mockStore.getProjectsByTeam(teamId);\n105: };\n106: \n107: export function getDiscussions(projectId?: string) {\n108:   if (IS_PRODUCTION_BACKEND) {\n109:     const filter = projectId ? `?filters=[[\"project\",\"=\",\"${projectId}\"]]` : \"\";\n110:     console.log(`Production API call: GET /api/resource/GP Discussion${filter}`);\n111:   }\n112:   return mockStore.getDiscussions(projectId);\n113: }\n114: \n115: export const getDiscussion = (id: string) => {\n116:   if (IS_PRODUCTION_BACKEND) {\n117:     console.log(`Production API call: GET /api/resource/GP Discussion/${id}`);\n118:   }\n119:   return mockStore.getDiscussion(id);\n120: };\n121: \n122: export const getCommentsFor = (discussionId: string) => {\n123:   if (IS_PRODUCTION_BACKEND) {\n124:     console.log(\n125:       `Production API call: GET /api/resource/GP Comment?filters=[[\"reference_name\",\"=\",\"${discussionId}\"]]`,\n126:     );\n127:   }\n128:   return mockStore.getCommentsFor(discussionId);\n129: };\n130: \n131: export const getReactionsFor = (ref: \"GP Discussion\" | \"GP Comment\", id: string) => {\n132:   return mockStore.getReactionsFor(ref, id);\n133: };\n134: \n135: export const getEvents = () => {\n136:   if (IS_PRODUCTION_BACKEND) {\n137:     console.log(\"Production API call: GET /api/resource/FG Event\");\n138:   }\n139:   return mockStore.getEvents();\n140: };\n141: \n142: export const getEvent = (id: string) => {\n143:   return mockStore.getEvent(id);\n144: };\n145: \n146: export const getAttendees = (eventId: string) => {\n147:   return mockStore.getAttendees(eventId);\n148: };\n149: \n150: export const getMatchesForUser = (userId: string) => {\n151:   if (IS_PRODUCTION_BACKEND) {\n152:     console.log(\n153:       `Production API call: GET /api/resource/FG Mentor Match?filters=[[\"mentee\",\"=\",\"${userId}\"]]`,\n154:     );\n155:   }\n156:   return mockStore.getMatchesForUser(userId);\n157: };\n158: \n159: export const getRecentPostsByUser = (userId: string) => {\n160:   return mockStore.getRecentPostsByUser(userId);\n161: };\n162: \n163: export const getAISettings = () => {\n164:   return mockStore.getAISettings();\n165: };\n166: \n167: // --- LMS selectors ---\n168: export const getCourses = () => {\n169:   if (IS_PRODUCTION_BACKEND) {\n170:     console.log(\"Production API call: GET /api/resource/LMS Course?filters=[['published','=',1]]\");\n171:   }\n172:   return mockStore.getCourses();\n173: };\n174: \n175: export const getAllCoursesIncludingDrafts = () => {\n176:   return mockStore.getAllCoursesIncludingDrafts();\n177: };\n178: \n179: export const getCourse = (id: string) => {\n180:   return mockStore.getCourse(id);\n181: };\n182: \n183: export const getChaptersForCourse = (courseId: string) => {\n184:   return mockStore.getChaptersForCourse(courseId);\n185: };\n186: \n187: export const getLessonsForChapter = (chapterId: string) => {\n188:   return mockStore.getLessonsForChapter(chapterId);\n189: };\n190: \n191: export const getLessonsForCourse = (courseId: string) => {\n192:   return mockStore.getLessonsForCourse(courseId);\n193: };\n194: \n195: export const getLesson = (id: string) => {\n196:   return mockStore.getLesson(id);\n197: };\n198: \n199: export const getEnrollment = (courseId: string, userId = currentUserId) => {\n200:   return mockStore.getEnrollment(courseId, userId);\n201: };\n202: \n203: export const getMyEnrollments = (userId = currentUserId) => {\n204:   return mockStore.getMyEnrollments(userId);\n205: };\n206: \n207: export const isLessonComplete = (lessonId: string, userId = currentUserId) => {\n208:   return mockStore.isLessonComplete(lessonId, userId);\n209: };\n210: \n211: export function courseProgressPercent(courseId: string, userId = currentUserId) {\n212:   return mockStore.courseProgressPercent(courseId, userId);\n213: }\n214: \n215: // --- User settings ---\n216: export const getUserSettings = (userId = currentUserId): FGUserSettings => {\n217:   return mockStore.getUserSettings(userId);\n218: };\n219: \n220: export function updateUserSettings(patch: Partial<FGUserSettings>) {\n221:   if (IS_PRODUCTION_BACKEND) {\n222:     console.log(\"Production API call: PUT /api/resource/FG User Settings/<id>\");\n223:   }\n224:   mockStore.updateUserSettings(patch);\n225: }\n226: \n227: export function updateProfile(patch: Partial<GPUserProfile>) {\n228:   if (IS_PRODUCTION_BACKEND) {\n229:     console.log(\"Production API call: PUT /api/resource/GP User Profile/<id>\");\n230:   }\n231:   mockStore.updateProfile(patch);\n232: }\n233: \n234: // --- mutators ---\n235: \n236: export function createDiscussion(input: {\n237:   project: string;\n238:   title: string;\n239:   content: string;\n240: }): GPDiscussion {\n241:   if (IS_PRODUCTION_BACKEND) {\n242:     console.log(\"Production API call: POST /api/method/frappe.client.insert (GP Discussion)\");\n243:   }\n244:   return mockStore.createDiscussion(input);\n245: }\n246: \n247: export function createComment(input: { discussion_id: string; content: string }): GPComment {\n248:   if (IS_PRODUCTION_BACKEND) {\n249:     console.log(\"Production API call: POST /api/method/frappe.client.insert (GP Comment)\");\n250:   }\n251:   return mockStore.createComment(input);\n252: }\n253: \n254: export function toggleReaction(ref: \"GP Discussion\" | \"GP Comment\", id: string, emoji: string) {\n255:   if (IS_PRODUCTION_BACKEND) {\n256:     console.log(\"Production API call: POST /api/method/fg_companion.api.toggle_reaction\");\n257:   }\n258:   mockStore.toggleReaction(ref, id, emoji);\n259: }\n260: \n261: export function setRSVP(eventId: string, status: RSVPStatus) {\n262:   if (IS_PRODUCTION_BACKEND) {\n263:     console.log(\"Production API call: POST /api/method/fg_companion.api.set_rsvp\");\n264:   }\n265:   mockStore.setRSVP(eventId, status);\n266: }\n267: \n268: export function createEvent(input: {\n269:   title: string;\n270:   description: string;\n271:   starts_on: string;\n272:   event_type: string;\n273: }) {\n274:   return mockStore.createEvent(input);\n275: }\n276: \n277: export const getMyRSVP = (eventId: string): RSVPStatus | null => {\n278:   return mockStore.getMyRSVP(eventId);\n279: };\n280: \n281: export function requestMentor(mentorId: string, notes: string): FGMentorMatch {\n282:   if (IS_PRODUCTION_BACKEND) {\n283:     console.log(\"Production API call: POST /api/method/frappe.client.insert (FG Mentor Match)\");\n284:   }\n285:   return mockStore.requestMentor(mentorId, notes);\n286: }\n287: \n288: // --- LMS mutators ---\n289: export function createCourse(input: {\n290:   title: string;\n291:   short_introduction: string;\n292:   description: string;\n293:   category: string;\n294:   tags: string;\n295: }): LMSCourse {\n296:   return mockStore.createCourse(input);\n297: }\n298: \n299: export function addChapter(courseId: string, title: string): LMSChapter {\n300:   return mockStore.addChapter(courseId, title);\n301: }\n302: \n303: export function addLesson(input: {\n304:   course: string;\n305:   chapter: string;\n306:   title: string;\n307:   body: string;\n308:   youtube_video: string;\n309: }): LMSLesson {\n310:   return mockStore.addLesson(input);\n311: }\n312: \n313: export function enrollInCourse(courseId: string) {\n314:   return mockStore.enrollInCourse(courseId);\n315: }\n316: \n317: export function markLessonComplete(lessonId: string, complete: boolean) {\n318:   mockStore.markLessonComplete(lessonId, complete);\n319: }\n320: \n321: export function extractYouTubeId(input: string): string {\n322:   return mockStore.extractYouTubeId(input);\n323: }\n324: \n325: export function mockSentiment(text: string): {\n326:   label: SentimentLabel;\n327:   score: number;\n328: } {\n329:   return mockStore.mockSentiment(text);\n330: }\n331: \n332: export function findSimilarPosts(discussionId: string, limit = 3) {\n333:   return mockStore.findSimilarPosts(discussionId, limit);\n334: }\n335: \n336: // --- DMs ---\n337: export const getDMThreadsForUser = (userId = currentUserId): FGDMThread[] => {\n338:   return mockStore.getDMThreadsForUser(userId);\n339: };\n340: \n341: export const getDMThread = (id: string) => {\n342:   return mockStore.getDMThread(id);\n343: };\n344: \n345: export const getDMMessages = (threadId: string): FGDMMessage[] => {\n346:   return mockStore.getDMMessages(threadId);\n347: };\n348: \n349: export const getOtherMember = (thread: FGDMThread, userId = currentUserId) => {\n350:   return mockStore.getOtherMember(thread, userId);\n351: };\n352: \n353: export function openOrCreateDMWith(otherUserId: string): FGDMThread {\n354:   return mockStore.openOrCreateDMWith(otherUserId);\n355: }\n356: \n357: export function sendDM(threadId: string, content: string): FGDMMessage | null {\n358:   return mockStore.sendDM(threadId, content);\n359: }\n360: \n361: export function markThreadRead(threadId: string) {\n362:   mockStore.markThreadRead(threadId);\n363: }\n364: \n365: export const getUnreadDMCount = (userId = currentUserId) => {\n366:   return mockStore.getUnreadDMCount(userId);\n367: };\n368: \n369: // --- Notifications ---\n370: export const getNotifications = (userId = currentUserId): FGNotification[] => {\n371:   return mockStore.getNotifications(userId);\n372: };\n373: \n374: export const getUnreadNotificationCount = (userId = currentUserId) => {\n375:   return mockStore.getUnreadNotificationCount(userId);\n376: };\n377: \n378: export function markAllNotificationsRead(userId = currentUserId) {\n379:   mockStore.markAllNotificationsRead(userId);\n380: }\n381: \n382: export function markNotificationRead(id: string) {\n383:   mockStore.markNotificationRead(id);\n384: }\n385: \n386: // --- SSO providers ---\n387: export const getSSOProviders = (): FGSSOProvider[] => {\n388:   return mockStore.getSSOProviders();\n389: };\n390: \n391: export function updateSSOProvider(id: SSOProviderId, patch: Partial<FGSSOProvider>) {\n392:   mockStore.updateSSOProvider(id, patch);\n393: }\n394: \n395: // --- Polls ---\n396: export const getPollForDiscussion = (discussionId: string) => mockStore.getPollForDiscussion(discussionId);\n397: export const getMyPollVote = (pollId: string) => mockStore.getMyPollVote(pollId);\n398: export function votePoll(pollId: string, optionIndex: number) {\n399:   mockStore.votePoll(pollId, optionIndex);\n400: }\n401: export const totalPollVotes = (pollId: string) => mockStore.totalPollVotes(pollId);\n402: \n403: // --- Gamification ---\n404: export const getBadges = () => mockStore.getBadges();\n405: export const getBadgesForUser = (userId: string) => mockStore.getBadgesForUser(userId);\n406: export const getEnergyPoints = (userId: string) => mockStore.getEnergyPoints(userId);\n407: export function awardBadgeIfNew(userId: string, badgeId: string) {\n408:   mockStore.awardBadgeIfNew(userId, badgeId);\n409: }\n410: export function addEnergyPoints(userId: string, pts: number) {\n411:   mockStore.addEnergyPoints(userId, pts);\n412: }\n\n(End of file - total 412 lines)\n</content>",
