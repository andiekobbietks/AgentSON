      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\types.ts\"}",
      "output": "<path>C:\\Users\\LLM-Test\\community-launchpad-proto\\src\\mock-data\\types.ts</path>\n<type>file</type>\n<content>\n1: // Types intentionally mirror real Frappe DocTypes from frappe/gameplan and\n2: // frappe/lms. Researched against the live `main` branch .json files — see\n3: // /docs/01_SCHEMA_MAPPING_TO_FRAPPE.md and /docs/04_FRAPPE_TRANSLATION.md.\n4: //\n5: // IMPORTANT NAMING NOTES:\n6: // - Field names below are snake_case to mirror Frappe exactly.\n7: // - Where Frappe stores a value via standard meta fields (`name`, `owner`,\n8: //   `creation`, `modified`), we keep convenience aliases here (`id`,\n9: //   `author_id`, `created_at`) and document the mapping. This is the ONLY\n10: //   place those aliases exist — every component reads through them.\n11: // - Child-table rows in Frappe also carry implicit `parent`, `parenttype`,\n12: //   `parentfield`, `idx`. We don't model those for the prototype.\n13: \n14: // ============================================================\n15: // frappe/gameplan\n16: // ============================================================\n17: \n18: /** DocType: `GP Team` */\n19: export interface GPTeam {\n20:   id: string;\n21:   title: string;\n22:   icon: string;\n23:   is_private: boolean;\n24:   archived_at: string | null;\n25:   archived_by: string | null;\n26: }\n27: \n28: /** DocType: `GP Project` (UI label: \"Space\") */\n29: export interface GPProject {\n30:   id: string;\n31:   title: string;\n32:   description: string;\n33:   status: \"Open\" | \"Completed\";\n34:   team: string;\n35:   progress: number;\n36:   icon: string;\n37:   readme: string;\n38:   tasks_count: number;\n39:   discussions_count: number;\n40:   archived_at: string | null;\n41:   archived_by: string | null;\n42:   is_private: boolean;\n43: }\n44: \n45: /** DocType: `GP Discussion` (UI label: \"Post\") */\n46: export interface GPDiscussion {\n47:   id: string;\n48:   project: string;\n49:   team: string;\n50:   status: string;\n51:   title: string;\n52:   slug: string;\n53:   content: string;\n54:   last_post_at: string;\n55:   last_post_type: \"GP Comment\" | \"GP Poll\";\n56:   last_post: string;\n57:   last_post_by: string | null;\n58:   comments_count: number;\n59:   participants_count: number;\n60:   closed_at: string | null;\n61:   closed_by: string | null;\n62:   pinned_at: string | null;\n63:   pin_scope: \"Global\" | \"Space\";\n64:   pinned_by: string | null;\n65:   author_id: string;\n66:   created_at: string;\n67: }\n68: \n69: /** DocType: `GP Comment` */\n70: export interface GPComment {\n71:   id: string;\n72:   content: string;\n73:   reference_doctype: \"GP Discussion\";\n74:   reference_name: string;\n75:   edited_at: string | null;\n76:   deleted_at: string | null;\n77:   author_id: string;\n78:   created_at: string;\n79: }\n80: \n81: /** DocType: `GP Reaction` (istable=1). */\n82: export interface GPReaction {\n83:   id: string;\n84:   reference_doctype: \"GP Discussion\" | \"GP Comment\";\n85:   reference_name: string;\n86:   user: string;\n87:   emoji: string;\n88: }\n89: \n90: /** DocType: `GP User Profile` */\n91: export interface GPUserProfile {\n92:   user: string;\n93:   enabled: boolean;\n94:   full_name: string;\n95:   bio: string;\n96:   readme: string;\n97:   image: string;\n98:   cover_image: string;\n99:   image_background_color: string;\n100: }\n101: \n102: // ============================================================\n103: // frappe/lms — full prototype (mirrors real DocType field names)\n104: // ============================================================\n105: \n106: /** DocType: `LMS Course` */\n107: export interface LMSCourse {\n108:   id: string; // → `name`\n109:   title: string;\n110:   short_introduction: string;\n111:   description: string; // Text Editor — long form\n112:   image: string;\n113:   card_gradient: \"Red\" | \"Blue\" | \"Green\" | \"Amber\" | \"Cyan\" | \"Orange\" | \"Pink\" | \"Purple\" | \"Teal\" | \"Violet\" | \"Yellow\" | \"Gray\";\n114:   paid_course: boolean;\n115:   paid_certificate: boolean;\n116:   featured: boolean;\n117:   published: boolean;\n118:   published_on: string;\n119:   upcoming: boolean;\n120:   disable_self_learning: boolean;\n121:   enable_certification: boolean;\n122:   course_price: number;\n123:   currency: string;\n124:   amount_usd: number;\n125:   category: string;\n126:   tags: string; // comma separated, matches LMS\n127:   status: \"In Progress\" | \"Under Review\" | \"Approved\";\n128:   author: string; // → Link `User` (instructor)\n129:   instructors: string[]; // Table MultiSelect → Course Instructor\n130:   enrollments: number; // denormalised for cards\n131:   lessons: number; // denormalised\n132:   rating: string;\n133:   created_at: string;\n134: }\n135: \n136: /** DocType: `LMS Chapter` (parent: LMS Course) */\n137: export interface LMSChapter {\n138:   id: string; // → `name`\n139:   course: string; // → Link `LMS Course`\n140:   title: string;\n141:   description: string;\n142:   idx: number; // order\n143: }\n144: \n145: /**\n146:  * DocType: `LMS Lesson` (parent: LMS Chapter)\n147:  *\n148:  * In real LMS the body is a Markdown/HTML field with embedded shortcodes\n149:  * like `{{ YouTubeVideo(\"VIDEO_ID\") }}`. For the prototype we surface\n150:  * `youtube_video` as a first-class field — porting is a search/replace\n151:  * to the shortcode form. See /docs/04_FRAPPE_TRANSLATION.md.\n152:  */\n153: export interface LMSLesson {\n154:   id: string; // → `name`\n155:   chapter: string; // → Link `LMS Chapter`\n156:   course: string; // → Link `LMS Course` (denormalised)\n157:   title: string;\n158:   body: string; // Markdown/HTML\n159:   youtube_video: string; // 11-char YouTube ID (or \"\")\n160:   include_in_preview: boolean;\n161:   idx: number;\n162: }\n163: \n164: /** DocType: `LMS Enrollment` */\n165: export interface LMSEnrollment {\n166:   id: string;\n167:   member: string; // → Link `User`\n168:   course: string; // → Link `LMS Course`\n169:   member_name: string;\n170:   member_username: string;\n171:   member_type: \"Student\" | \"Mentor\" | \"Staff\";\n172:   role: \"Member\" | \"Admin\";\n173:   progress: number; // 0..100\n174:   current_lesson: string;\n175:   enrolled_on: string;\n176:   payment: string;\n177:   certificate: string;\n178:   purchased_certificate: boolean;\n179: }\n180: \n181: /** DocType: `LMS Course Progress` (per-lesson completion) */\n182: export interface LMSCourseProgress {\n183:   id: string;\n184:   member: string;\n185:   member_name: string;\n186:   course: string;\n187:   chapter: string;\n188:   lesson: string;\n189:   status: \"Complete\" | \"Partially Complete\" | \"Incomplete\";\n190:   is_scorm_chapter: boolean;\n191: }\n192: \n193: /** DocType: `LMS Certificate` */\n194: export interface LMSCertificate {\n195:   id: string;\n196:   member: string;\n197:   member_name: string;\n198:   course: string;\n199:   course_title: string;\n200:   issue_date: string;\n201:   expiry_date: string | null;\n202:   published: boolean;\n203: }\n204: \n205: // ============================================================\n206: // fg_companion — NEW custom Frappe app (to be created)\n207: // ============================================================\n208: \n209: export type EventType =\n210:   | \"Webinar\"\n211:   | \"In-Person Meetup\"\n212:   | \"Workshop\"\n213:   | \"Drop-in Office Hours\"\n214:   | \"Networking\";\n215: \n216: export type LocationType = \"Online (BigBlueButton)\" | \"Online (External Link)\" | \"In Person\";\n217: \n218: /** DocType (new): `FG Event` */\n219: export interface FGEvent {\n220:   id: string;\n221:   title: string;\n222:   description: string;\n223:   space: string | null;\n224:   event_type: EventType;\n225:   starts_on: string;\n226:   ends_on: string;\n227:   location_type: LocationType;\n228:   bbb_meeting_id: string | null;\n229:   external_link: string | null;\n230:   physical_address: string | null;\n231:   rsvp_required: boolean;\n232:   capacity: number;\n233:   hosted_by: string;\n234: }\n235: \n236: export type RSVPStatus = \"Going\" | \"Maybe\" | \"Not Going\" | \"Attended\" | \"No Show\";\n237: \n238: /** DocType (new): `FG Event Attendee` */\n239: export interface FGEventAttendee {\n240:   id: string;\n241:   event: string;\n242:   user: string;\n243:   rsvp_status: RSVPStatus;\n244: }\n245: \n246: export type MentorMatchStatus = \"Requested\" | \"Active\" | \"Completed\" | \"Ended Early\";\n247: \n248: export type MatchedVia = \"Manual\" | \"Self-Requested\" | \"Algorithmic Suggestion\";\n249: \n250: /** DocType (new): `FG Mentor Match` */\n251: export interface FGMentorMatch {\n252:   id: string;\n253:   mentee: string;\n254:   mentor: string;\n255:   status: MentorMatchStatus;\n256:   matched_on: string;\n257:   matched_via: MatchedVia;\n258:   match_notes: string;\n259: }\n260: \n261: /** Single DocType (new): `FG AI Settings` */\n262: export interface FGAISettings {\n263:   enable_sentiment: boolean;\n264:   sentiment_alert_threshold: number;\n265:   enable_vector_search: boolean;\n266: }\n267: \n268: // ============================================================\n269: // fg_companion — Polls (mirrors custom fg_poll + fg_poll_vote)\n270: // ============================================================\n271: \n272: export type PollOption = {\n273:   text: string;\n274:   votes: number;\n275: };\n276: \n277: export interface FGPoll {\n278:   id: string;\n279:   discussion: string;\n280:   question: string;\n281:   options: PollOption[];\n282:   created_by: string;\n283:   created_at: string;\n284:   is_anonymous: boolean;\n285:   is_closed: boolean;\n286: }\n287: \n288: export interface FGPollVote {\n289:   id: string;\n290:   poll: string;\n291:   user: string;\n292:   option_index: number;\n293:   created_at: string;\n294: }\n295: \n296: // ============================================================\n297: // fg_companion — Gamification (EPS + badges)\n298: // ==============================