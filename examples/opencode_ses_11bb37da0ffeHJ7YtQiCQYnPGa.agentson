      "code": "{\"content\": \"#!/bin/bash\\nexport PATH=\\\"/home/andiekobbie/.local/bin:/usr/bin:/usr/local/bin:/bin:$PATH\\\"\\n\\necho \\\"=== Check MariaDB auth plugin ===\\\"\\nmariadb -u root -e \\\"SELECT user, host, plugin FROM mysql.user WHERE user IN ('root', 'firstgens');\\\"\\n\\necho \\\"=== Check if we can connect as root without password ===\\\"\\nmariadb -u root -e \\\"SELECT 1 as test;\\\"\\n\\necho \\\"=== Drop old DB and user ===\\\"\\nmariadb -u root -e \\\"DROP DATABASE IF EXISTS firstgens; DROP USER IF EXISTS 'firstgens'@'localhost'; FLUSH PRIVILEGES;\\\"\\n\\necho \\\"=== Recreate with password auth ===\\\"\\nmariadb -u root -e \\\"CREATE USER 'firstgens'@'localhost' IDENTIFIED BY 'firstgens123'; CREATE DATABASE firstgens; GRANT ALL PRIVILEGES ON firstgens.* TO 'firstgens'@'localhost'; FLUSH PRIVILEGES;\\\"\\n\\necho \\\"=== Test connection ===\\\"\\nmariadb -u firstgens -pfirstgens123 firstgens -e \\\"SELECT 1 as connected;\\\"\\necho \\\"DB connection OK\\\"\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\fix_mariadb.sh\"}",
