      "code": "{\"command\": \"wsl -d Ubuntu -e bash -c \\\"\\nexport PATH=\\\\\\\"/home/andiekobbie/.local/bin:/usr/bin:/usr/local/bin:/bin:\\\\$PATH\\\\\\\"\\ncd /home/andiekobbie/frappe-bench/apps\\nmkdir -p fg_firstgens_app\\nmkdir -p fg_firstgens_app/fg_firstgens_app\\nmkdir -p fg_firstgens_app/fg_firstgens_app/templates\\nmkdir -p fg_firstgens_app/fg_firstgens_app/templates/website\\nmkdir -p fg_firstgens_app/fg_firstgens_app/fixtures\\nmkdir -p fg_firstgens_app/fg_firstgens_app/www\\nmkdir -p fg_firstgens_app/fg_firstgens_app/public\\nmkdir -p fg_firstgens_app/fg_firstgens_app/patches\\n\\n# Create app config\\ncat > fg_firstgens_app/__init__.py << 'PYEOF'\\n# Version of this app\\n__version__ = '0.0.1'\\nPYEOF\\n\\n# Create app meta\\ncat > fg_firstgens_app/__setup__.py << 'PYEOF'\\nfrom frappe_deprecation_wrapper import deprecate\\n\\napp_name = \\\"fg_firstgens_app\\\"\\napp_title = \\\"FirstGens Companion\\\"\\napp_description = \\\"Community platform for first-generation students with mentoring, learning, and support features\\\"\\napp_publisher = \\\"FirstGens\\\"\\napp_color = \\\"#3e654a\\\"\\napp_icon = \\\"octicon octicon-users\\\"\\napp_email = \\\"admin@firstgens.test\\\"\\napp_license = \\\"MIT\\\"\\n\\nwebsite_route_rules = [\\n    {\\\"from_route\\\": \\\"/firstgens\\\", \\\"to_route\\\": \\\"firstgens\\\"},\\n    {\\\"from_route\\\": \\\"/firstgens/<path:app_path>\\\", \\\"to_route\\\": \\\"firstgens\\\"},\\n]\\n\\nPYEOF\\n\\n# Create hooks\\ncat > fg_firstgens_app/hooks.py << 'HOOKEOF'\\nfrom . import __version__ as app_version\\n\\napp_name = \\\"fg_firstgens_app\\\"\\napp_title = \\\"FirstGens Companion\\\"\\napp_publisher = \\\"FirstGens\\\"\\napp_description = \\\"Community platform for first-generation students with mentoring, learning, and support features\\\"\\napp_version = app_version\\napp_color = \\\"#3e654a\\\"\\napp_icon = \\\"octicon octicon-users\\\"\\napp_email = \\\"admin@firstgens.test\\\"\\napp_license = \\\"MIT\\\"\\n\\n# Website route rules\\nwebsite_route_rules = [\\n    {\\\"from_route\\\": \\\"/firstgens\\\", \\\"to_route\\\": \\\"firstgens\\\"},\\n    {\\\"from_route\\\": \\\"/firstgens/<path:app_path>\\\", \\\"to_route\\\": \\\"firstgens\\\"},\\n]\\n\\n# Custom website context\\n@deprecate\\napp_context = {\\n    \\\"firstgens_brand\\\": {\\n        \\\"primary\\\": \\\"#3e654a\\\",\\n        \\\"stone\\\": \\\"#f6ede0\\\",\\n        \\\"burnt_maroon\\\": \\\"#37272f\\\",\\n        \\\"clay\\\": \\\"#d17147\\\",\\n        \\\"yellow\\\": \\\"#ffba56\\\",\\n    }\\n}\\n\\n# Override the website user\\n@deprecate\\ndef get_website_user_doc(user):\\n    \\\"\\\"\\\"Override to add FirstGens specific user data\\\"\\\"\\\"\\n    user_doc = frappe.get_doc(\\\"User\\\", user)\\n    if user_doc.name.endswith(\\\"@firstgens.test\\\"):\\n        # Add FirstGens specific fields\\n        user_doc.flags.in_firstgens = True\\n    return user_doc\\n\\n# Custom website templates\\nwebsite_templates = [\\n    \\\"templates/website/firstgens_home.html\\\",\\n    \\\"templates/website/firstgens_discussions.html\\\",\\n    \\\"templates/website/firstgens_courses.html\\\",\\n    \\\"templates/website/firstgens_tickets.html\\\",\\n    \\\"templates/website/firstgens_members.html\\\",\\n]\\nHOOKEOF\\n\\n# Create website templates\\ncat > fg_firstgens_app/templates/website/firstgens_home.html << 'HTML'\\n{% extends \\\"templates/website/layout.html\\\" %}\\n{% block page_content %}\\n<div class=\\\"container\\\">\\n    <div class=\\\"row\\\">\\n        <div class=\\\"col-md-12\\\">\\n            <h1 class=\\\"page-header\\\">Welcome to FirstGens</h1>\\n            <p class=\\\"lead\\\">A community platform for first-generation students</p>\\n        </div>\\n    </div>\\n\\n    <div class=\\\"row\\\">\\n        <div class=\\\"col-md-8\\\">\\n            <h2>Community Discussions</h2>\\n            <p>Join discussions about navigating university as a first-gen student</p>\\n            <a href=\\\"/firstgens/discussions\\\" class=\\\"btn btn-primary\\\">View Discussions</a>\\n        </div>\\n        <div class=\\\"col-md-4\\\">\\n            <h2>Learning Resources</h2>\\n            <p>Access courses and study guides</p>\\n            <a href=\\\"/firstgens/courses\\\" class=\\\"btn btn-success\\\">Browse Courses</a>\\n        </div>\\n    </div>\\n\\n    <div class=\\\"row mt-4\\\">\\n        <div class=\\\"col-md-6\\\">\\n            <h2>Support & Help</h2>\\n            <p>Get help with university challenges</p>\\n            <a href=\\\"/firstgens/tickets\\\" class=\\\"btn btn-info\\\">Submit a Ticket</a>\\n        </div>\\n        <div class=\\\"col-md-6\\\">\\n            <h2>Meet Other Students</h2>\\n            <p>Connect with fellow first-gen students</p>\\n            <a href=\\\"/firstgens/members\\\" class=\\\"btn btn-warning\\\">View Members</a>\\n        </div>\\n    </div>\\n</div>\\nHTML\\n\\n# Create discussions template\\ncat > fg_firstgens_app/templates/website/firstgens_discussions.html << 'HTML'\\n{% extends \\\"templates/website/layout.html\\\" %}\\n{% block page_content %}\\n<div class=\\\"container\\\">\\n    <div class=\\\"row\\\">\\n        <div class=\\\"col-md-12\\\">\\n            <h1 class=\\\"page-header\\\">Community Discussions</h1>\\n            <p class=\\\"lead\\\">Join conversations with other first-generation students</p>\\n        </div>\\n    </div>\\n\\n    <div class=\\\"row\\\">\\n        {% for doc in discussions %}\\n        <div class=\\\"col-md-6 mb-4\\\">\\n            <div class=\\\"card\\\">\\n                <div class=\\\"card-body\\\">\\n                    <h3 class=\\\"card-title\\\">\\n                        <a href=\\\"/app/gp-discussion/{{ doc.name }}\\\">{{ doc.title }}</a>\\n                    </h3>\\n                    <h6 class=\\\"card-subtitle mb-2 text-muted\\\">\\n                        <strong>Project:</strong> {{ doc.project }} | \\n                        <strong>Author:</strong> {{ doc.owner }} | \\n                        <strong>Last Post:</strong> {{ doc.last_post_at }}\\n                    </h6>\\n                    <p class=\\\"card-text\\\">{{ doc.content[:200] }}...</p>\\n                    <div class=\\\"d-flex justify-content-between\\\">\\n                        <small class=\\\"text-muted\\\">Comments: {{ doc.comments_count }}</small>\\n                        <small class=\\\"text-muted\\\">Participants: {{ doc.participants_count }}</small>\\n                    </div>\\n                </div>\\n            </div>\\n        </div>\\n        {% endfor %}\\n    </div>\\n</div>\\nHTML\\n\\n# Create courses template\\ncat > fg_firstgens_app/templates/website/firstgens_courses.html << 'HTML'\\n{% extends \\\"templates/website/layout.html\\\" %}\\n{% block page_content %}\\n<div class=\\\"container\\\">\\n    <div class=\\\"row\\\">\\n        <div class=\\\"col-md-12\\\">\\n            <h1 class=\\\"page-header\\\">Learning Courses</h1>\\n            <p class=\\\"lead\\\">Courses designed specifically for first-generation students</p>\\n        </div>\\n    </div>\\n\\n    <div class=\\\"row\\\">\\n        {% for doc in courses %}\\n        <div class=\\\"col-md-6 mb-4\\\">\\n            <div class=\\\"card\\\">\\n                <div class=\\\"card-body\\\">\\n                    <h3 class=\\\"card-title\\\">\\n                        <a href=\\\"/app/lms-course/{{ doc.name }}\\\">{{ doc.title }}</a>\\n                    </h3>\\n                    <h6 class=\\\"card-subtitle mb-2 text-muted\\\">\\n                        <strong>Instructor:</strong> {{ doc.instructor }} | \\n                        <strong>Category:</strong> {{ doc.category }}<br>\\n                        <strong>Status:</strong> {{ doc.status }} | \\n                        <strong>Published:</strong> {% if doc.published %}Yes{% else %}No{% endif %}\\n                    </h6>\\n                    <p class=\\\"card-text\\\">{{ doc.short_introduction }}</p>\\n       