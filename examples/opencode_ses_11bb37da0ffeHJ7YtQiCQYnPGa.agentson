\\n    existing = frappe.db.get_value(\\\"GP Discussion\\\", {\\\"title\\\": title}, \\\"name\\\")\\n    if not existing:\\n        try:\\n            # Include name = 0 for auto-increment\\n            frappe.db.sql(\\\"\\\"\\\"INSERT INTO `tabGP Discussion`\\n                (name, title, content, project, status, owner, creation, modified, modified_by, docstatus,\\n                 last_post_at, last_post_by, comments_count, participants_count, idx, slug)\\n                VALUES (0, %s, %s, %s, 'Open', %s, NOW(), NOW(), 'Administrator', 0,\\n                 NOW(), %s, 0, 0, 1, %s)\\\"\\\"\\\",\\n                (title, content, project, owner, owner, \\n                 title.lower().replace(' ', '-').replace('!', '').replace('?', '').replace(':', '').replace(',', '')[:60]))\\n            frappe.db.commit()\\n            print(f\\\"  Created: {title[:50]}...\\\")\\n        except Exception as e:\\n            print(f\\\"  Error '{title[:30]}': {e}\\\")\\n    else:\\n        print(f\\\"  Already exists: {title[:50]}\\\")\\n\\n# ============================================\\n# HD TICKETS - also name = 0\\n# ============================================\\nprint(\\\"\\\\n=== Creating HD Tickets (name=0) ===\\\")\\ntickets = [\\n    (\\\"Cannot access course materials on mobile\\\", \\\"Hi, I'm trying to access the Navigating University course on my phone but the videos won't load.\\\", \\\"Open\\\", \\\"Medium\\\", \\\"Bug\\\"),\\n    (\\\"Request for additional mentoring sessions\\\", \\\"I'd really like to request more mentoring sessions. The weekly sessions are great but I have a lot of questions.\\\", \\\"Open\\\", \\\"Low\\\", \\\"Feature\\\"),\\n    (\\\"How do I update my profile photo?\\\", \\\"I can't find where to change my profile picture. The settings page doesn't seem to have the option.\\\", \\\"Replied\\\", \\\"Low\\\", \\\"Feature\\\"),\\n]\\n\\nfor subject, desc, status, priority, ttype in tickets:\\n    existing = frappe.db.get_value(\\\"HD Ticket\\\", {\\\"subject\\\": subject}, \\\"name\\\")\\n    if not existing:\\n        try:\\n            ticket = frappe.new_doc(\\\"HD Ticket\\\")\\n            ticket.subject = subject\\n            ticket.description = desc\\n            ticket.status = status\\n            ticket.priority = priority\\n            ticket.ticket_type = ttype\\n            ticket.flags.ignore_permissions = True\\n            ticket.insert()\\n            frappe.db.commit()\\n            print(f\\\"  Created: {subject[:50]}\\\")\\n        except Exception as e:\\n            print(f\\\"  Error '{subject[:30]}': {e}\\\")\\n\\nprint(\\\"\\\\n=== FINAL COUNTS ===\\\")\\nfor label, doctype in [(\\\"Users\\\", \\\"User\\\"), (\\\"Teams\\\", \\\"GP Team\\\"), (\\\"Projects\\\", \\\"GP Project\\\"), \\n          (\\\"Discussions\\\", \\\"GP Discussion\\\"), (\\\"Courses\\\", \\\"LMS Course\\\"), \\n          (\\\"Tickets\\\", \\\"HD Ticket\\\"), (\\\"Priorities\\\", \\\"HD Ticket Priority\\\"), \\n          (\\\"Categories\\\", \\\"LMS Category\\\")]:\\n    try:\\n        count = frappe.db.count(doctype)\\n        print(f\\\"  {label}: {count}\\\")\\n    except:\\n        print(f\\\"  {label}: ERROR\\\")\\n\\nprint(\\\"\\\\n=== Discussions ===\\\")\\nfor d in frappe.db.sql(\\\"SELECT name, title, project, owner FROM `tabGP Discussion`\\\", as_list=True):\\n    print(f\\\"  {d[0]} | {d[1][:40]} | {d[2]} | {d[3]}\\\")\\n\\nprint(\\\"\\\\n=== Tickets ===\\\")\\nfor t in frappe.db.sql(\\\"SELECT name, subject, status, priority FROM `tabHD Ticket`\\\", as_list=True):\\n    print(f\\\"  {t[0]} | {t[1][:40]} | {t[2]} | {t[3]}\\\")\\n\\nprint(\\\"\\\\n=== SEED COMPLETE ===\\\")\\nfrappe.destroy()\\nPYEOF\\n\\ncp /tmp/seed_v7.py /home/andiekobbie/frappe-bench/sites/seed_v7.py\\n/home/andiekobbie/frappe-bench/env/bin/python /home/andiekobbie/frappe-bench/sites/seed_v7.py 2>&1\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\AppData\\\\Local\\\\Temp\\\\opencode\\\\seed_v7.sh\"}",
