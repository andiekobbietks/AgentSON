      "type": "action",
      "tool": "edit",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\mock-data\\\\store.ts\", \"newString\": \"export function addEnergyPoints(userId: string, pts: number) {\\n  const ep = state.energyPoints.find((e) => e.user === userId);\\n  if (ep) ep.points += pts;\\n  else state.energyPoints.push({ user: userId, points: pts });\\n  emit();\\n}\\n\\n// ============================================================\\n// Tickets (frappe/helpdesk)\\n// ============================================================\\nexport const getTickets = (userId?: string): HDTicket[] =>\\n  userId\\n    ? state.tickets.filter((t) => t.raised_by === userId || t.assigned_to === userId)\\n    : [...state.tickets];\\n\\nexport const getTicket = (id: string) => state.tickets.find((t) => t.id === id);\\n\\nexport function createTicket(input: {\\n  subject: string;\\n  description: string;\\n  ticket_type: HDTicketType;\\n  priority: HDPriority;\\n}): HDTicket {\\n  const t: HDTicket = {\\n    id: uid(\\\"ticket\\\"),\\n    name: `HD-TICKET-${state.tickets.length + 1001}`,\\n    subject: input.subject.trim(),\\n    description: input.description,\\n    ticket_type: input.ticket_type,\\n    priority: input.priority,\\n    status: \\\"Open\\\",\\n    raised_by: currentUserId,\\n    assigned_to: \\\"\\\",\\n    team: \\\"\\\",\\n    project: \\\"\\\",\\n    contact: \\\"\\\",\\n    email: \\\"\\\",\\n    phone: \\\"\\\",\\n    via_customer_portal: false,\\n    first_responded_on: null,\\n    resolution_date: null,\\n    creation: new Date().toISOString(),\\n    modified: new Date().toISOString(),\\n  };\\n  state.tickets.push(t);\\n  emit();\\n  return t;\\n}\\n\\nexport function updateTicketStatus(id: string, status: HDTicketStatus) {\\n  const t = state.tickets.find((x) => x.id === id);\\n  if (!t) return;\\n  t.status = status;\\n  t.modified = new Date().toISOString();\\n  if (status === \\\"Resolved\\\") t.resolution_date = new Date().toISOString();\\n  emit();\\n}\\n\\n// ============================================================\\n// Subscriptions (frappe/payments)\\n// ============================================================\\nexport const getSubscriptionPlans = (): FGSubscriptionPlan[] => state.subscriptionPlans;\\nexport const getPaymentPlans = (): FGPaymentPlan[] => state.paymentPlans;\", \"oldString\": \"export function addEnergyPoints(userId: string, pts: number) {\\n  const ep = state.energyPoints.find((e) => e.user === userId);\\n  if (ep) ep.points += pts;\\n  else state.energyPoints.push({ user: userId, points: pts });\\n  emit();\\n}\"}",
