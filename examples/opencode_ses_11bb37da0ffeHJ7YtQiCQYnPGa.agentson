      "type": "action",
      "tool": "write",
      "code": "{\"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\community-launchpad-proto\\\\src\\\\components\\\\PollCard.vue\", \"content\": \"<template>\\n  <div class=\\\"rounded-xl border border-border bg-secondary/30 p-4 mt-2\\\">\\n    <div class=\\\"text-[14px] font-semibold mb-3\\\">\\ud83d\\udcca {{ poll.question }}</div>\\n    <div class=\\\"flex flex-col gap-2\\\">\\n      <button\\n        v-for=\\\"(opt, i) in poll.options\\\"\\n        :key=\\\"i\\\"\\n        type=\\\"button\\\"\\n        class=\\\"relative w-full text-left rounded-lg border overflow-hidden transition-colors\\\"\\n        :class=\\\"\\n          myVote === i\\n            ? 'border-primary bg-primary/10'\\n            : 'border-border hover:border-border-strong bg-card'\\n        \\\"\\n        :disabled=\\\"poll.is_closed\\\"\\n        @click=\\\"handleVote(i)\\\"\\n      >\\n        <div\\n          class=\\\"absolute inset-0 bg-primary/15 transition-all\\\"\\n          :style=\\\"{ width: `${total > 0 ? (opt.votes / total) * 100 : 0}%` }\\\"\\n        />\\n        <div class=\\\"relative flex items-center justify-between px-3 py-2\\\">\\n          <span class=\\\"text-[13px] font-medium\\\">\\n            <span v-if=\\\"myVote === i\\\" class=\\\"text-primary mr-1\\\">\\u2713</span>\\n            {{ opt.text }}\\n          </span>\\n          <span class=\\\"text-[12px] text-muted-foreground font-semibold\\\">\\n            {{ total > 0 ? Math.round((opt.votes / total) * 100) : 0 }}%\\n            <span class=\\\"text-[11px] font-normal\\\">({{ opt.votes }})</span>\\n          </span>\\n        </div>\\n      </button>\\n    </div>\\n    <div class=\\\"mt-2 text-[11px] text-muted-foreground\\\">\\n      {{ total }} vote{{ total !== 1 ? \\\"s\\\" : \\\"\\\" }}\\n      <span v-if=\\\"poll.is_closed\\\" class=\\\"ml-1 text-flag-foreground font-semibold\\\">\\u00b7 Closed</span>\\n    </div>\\n  </div>\\n</template>\\n\\n<script setup lang=\\\"ts\\\">\\nimport { computed } from \\\"vue\\\";\\nimport type { FGPoll } from \\\"@/mock-data/types\\\";\\nimport { getMyPollVote, votePoll, totalPollVotes } from \\\"@/data/store\\\";\\n\\nconst props = defineProps<{\\n  poll: FGPoll;\\n}>();\\n\\nconst myVote = computed(() => getMyPollVote(props.poll.id));\\nconst total = computed(() => totalPollVotes(props.poll.id));\\n\\nfunction handleVote(index: number) {\\n  if (props.poll.is_closed) return;\\n  votePoll(props.poll.id, index);\\n}\\n</script>\\n\"}",
