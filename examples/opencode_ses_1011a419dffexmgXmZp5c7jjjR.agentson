      "code": "{\"command\": \"$roots = @(\\\"$env:USERPROFILE\\\\Downloads\\\", \\\"$env:USERPROFILE\\\\Documents\\\", \\\"$env:USERPROFILE\\\\Desktop\\\")\\n\\nWrite-Host \\\"=== Files with 'one[- ]?pager' or 'onepager' in NAME ===\\\"\\nGet-ChildItem $roots -Recurse -File -ErrorAction SilentlyContinue |\\n  Where-Object { $_.Name -match \\\"(?i)one[-_ ]?pager|onepager|collaborator\\\" } |\\n  Where-Object { $_.FullName -notmatch \\\"node_modules|.next|out\\\\\\\\|VS Code|LAMPForge-PDE\\\" } |\\n  Select-Object Name, Length, LastWriteTime, FullName | Format-Table -AutoSize -Wrap\\n\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"=== Grepping AFJ-related JSON/MD/HTML for 'one pager' / 'one-pager' / 'collaborator' / 'team roster' ===\\\"\\n$patterns = '(?i)(one[-_ ]pager|onepager|collaborator(s)?\\\\s+(list|grid|table|roster|directory|at\\\\s*a\\\\s*glance)|team\\\\s+(roster|directory|grid)|at\\\\s*a\\\\s*glance|cheat\\\\s*sheet|directory)'\\nGet-ChildItem $roots -Recurse -File -Include \\\"*.json\\\",\\\"*.md\\\",\\\"*.txt\\\",\\\"*.html\\\" -ErrorAction SilentlyContinue |\\n  Where-Object { $_.FullName -notmatch \\\"node_modules|.next|out\\\\\\\\|VS Code|LAMPForge-PDE|extensions|chat\\\\b\\\" } |\\n  ForEach-Object {\\n    try {\\n      $raw = [System.IO.File]::ReadAllText($_.FullName)\\n      if ($raw -match 'AFJ' -and $raw -match $patterns) {\\n        $count = ([regex]::Matches($raw, $patterns)).Count\\n        Write-Host (\\\"  [{0,3} hits] {1}\\\" -f $count, $_.FullName)\\n      }\\n    } catch {}\\n  }\", \"description\": \"Search for collaborator one-pager\"}",
