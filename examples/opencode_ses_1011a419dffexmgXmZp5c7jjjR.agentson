      "tool": "bash",
      "code": "{\"command\": \"$json = \\\"$env:USERPROFILE\\\\Downloads\\\\StefaniaOkereke\\\\Legal Framework for AFJ Cardiff.json\\\"\\n$raw = Get-Content $json -Raw\\n\\n# Save a flattened readable version + extract merch/whatnot snippets\\n$dst = \\\"$env:USERPROFILE\\\\Downloads\\\\AFJ_Cardiff_All_Websites\\\"\\n$outTxt = Join-Path $dst \\\"Legal_Framework_for_AFJ_Cardiff_READABLE.txt\\\"\\n$outSnip = Join-Path $dst \\\"Legal_Framework_AFJ_MERCH_WHATNOT.txt\\\"\\n\\ntry {\\n  $obj = $raw | ConvertFrom-Json\\n  $lines = @()\\n  $lines += \\\"=== AI Studio Conversation: Legal Framework for AFJ Cardiff ===\\\"\\n  $lines += \\\"Source: C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\StefaniaOkereke\\\\Legal Framework for AFJ Cardiff.json\\\"\\n  $lines += \\\"Model: $($obj.runSettings.model)\\\"\\n  $lines += \\\"\\\"\\n\\n  if ($obj.systemInstruction) {\\n    $sys = $obj.systemInstruction\\n    if ($sys.PSObject.Properties['parts']) {\\n      $sysText = ($sys.parts | Where-Object { $_.text } | ForEach-Object { $_.text }) -join \\\"`n\\\"\\n      $lines += \\\"=== SYSTEM INSTRUCTION ===\\\"\\n      $lines += $sysText\\n      $lines += \\\"\\\"\\n    } elseif ($sys.PSObject.Properties['text']) {\\n      $lines += \\\"=== SYSTEM INSTRUCTION ===\\\"\\n      $lines += $sys.text\\n      $lines += \\\"\\\"\\n    }\\n  }\\n\\n  if ($obj.chunkedPrompt -and $obj.chunkedPrompt.chunks) {\\n    $chunks = $obj.chunkedPrompt.chunks\\n    $lines += \\\"=== CONVERSATION CHUNKS ($($chunks.Count) total) ===\\\"\\n    $i = 0\\n    foreach ($ch in $chunks) {\\n      $i++\\n      $role = if ($ch.PSObject.Properties['role']) { $ch.role } else { '?' }\\n      $text = ''\\n      if ($ch.PSObject.Properties['parts']) {\\n        $text = ($ch.parts | Where-Object { $_.text } | ForEach-Object { $_.text }) -join \\\"`n\\\"\\n      } elseif ($ch.PSObject.Properties['text']) {\\n        $text = $ch.text\\n      }\\n      $lines += \\\"\\\"\\n      $lines += \\\"--- #$i [$role] ---\\\"\\n      $lines += $text\\n    }\\n  }\\n  Set-Content -Path $outTxt -Value ($lines -join \\\"`n\\\") -Encoding UTF8\\n  Write-Host \\\"Wrote readable export: $outTxt ($((Get-Item $outTxt).Length) bytes)\\\"\\n\\n  # Extract snippets mentioning merch/whatnot/ecommerce\\n  $merchLines = @()\\n  $merchLines += \\\"=== Merch / Whatnot / E-commerce mentions from 'Legal Framework for AFJ Cardiff.json' ===\\\"\\n  $merchLines += \\\"Source: $json\\\"\\n  $merchLines += \\\"\\\"\\n\\n  $hits = Select-String -Path $json -Pattern \\\"merch|whatnot|Whatnot|shopify|Stripe|shop |e-?commerce|product line|product page|checkout\\\" -SimpleMatch:$false -CaseSensitive:$false -AllMatches\\n  Write-Host \\\"Found $($hits.Count) matching lines\\\"\\n\\n  # Build context snippets (300 chars before, full line, 300 after)\\n  $content = Get-Content $json\\n  $hitLines = @()\\n  foreach ($m in $hits) {\\n    $n = $m.LineNumber - 1\\n    $before = if ($n -ge 2) { ($content[($n-2)..($n-1)] -join \\\" \\\") } else { '' }\\n    $after  = if (($n+1) -lt $content.Count) { ($content[($n+1)..($n+2)] -join \\\" \\\") } else { '' }\\n    $snippet = \\\"L$($m.LineNumber): $($m.Line)\\\"\\n    if ($before) { $snippet = \\\"[\\u2026] $before \\\" + $snippet }\\n    if ($after)  { $snippet = $snippet + \\\" $after [\\u2026]\\\" }\\n    $hitLines += $snippet\\n  }\\n  $unique = $hitLines | Select-Object -Unique | Select-Object -First 80\\n  $merchLines += $unique\\n  Set-Content -Path $outSnip -Value ($merchLines -join \\\"`n`n\\\") -Encoding UTF8\\n  Write-Host \\\"Wrote merch snippet: $outSnip ($((Get-Item $outSnip).Length) bytes, $($unique.Count) hits)\\\"\\n} catch {\\n  Write-Host \\\"Error: $_\\\"\\n  Write-Host $_.Exception.StackTrace\\n}\", \"description\": \"Extract merch/whatnot context from AFJ Cardiff JSON\"}",
