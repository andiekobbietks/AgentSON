      "code": "{\"command\": \"$dst = \\\"$env:USERPROFILE\\\\Downloads\\\\AFJ_Cardiff_All_Websites\\\"\\n$candidates = @(\\n  \\\"afj-cardiff-vault.html\\\",\\n  \\\"afj-cardiff-vault (1).html\\\",\\n  \\\"afj-cardiff-vault (7).html\\\",\\n  \\\"afj-cardiff-vault (11).html\\\",\\n  \\\"afj-cardiff-vault-hardened.html\\\",\\n  \\\"afj_scrollytelling.html\\\",\\n  \\\"afj_scrollytelling - Copia.html\\\",\\n  \\\"afj_cardiff_devtools_to_convex_schema.html\\\"\\n)\\n\\nforeach ($name in $candidates) {\\n  $f = Join-Path $dst $name\\n  if (-not (Test-Path $f)) { continue }\\n  $raw = Get-Content $f -Raw\\n\\n  Write-Host \\\"=================== $name ===================\\\"\\n  Write-Host \\\"Size: $([Math]::Round($raw.Length/1KB, 1)) KB\\\"\\n\\n  # Title\\n  if ($raw -match '<title>([^<]+)</title>') { Write-Host \\\"Title: $($matches[1])\\\" }\\n\\n  # First <h1> or first content heading\\n  $h1 = [regex]::Match($raw, '<h1[^>]*>(.*?)</h1>')\\n  if ($h1.Success) { Write-Host \\\"H1: $($h1.Groups[1].Value -replace '<[^>]+>', '')\\\" }\\n\\n  # All section headings\\n  $headings = [regex]::Matches($raw, '<h[1-3][^>]*>(.*?)</h[1-3]>')\\n  if ($headings.Count -gt 0) {\\n    Write-Host \\\"Headings:\\\"\\n    foreach ($h in $headings | Select-Object -First 12) {\\n      $txt = $h.Groups[1].Value -replace '<[^>]+>', ''\\n      if ($txt.Length -gt 0 -and $txt.Length -lt 100) {\\n        Write-Host \\\"  - $txt\\\"\\n      }\\n    }\\n  }\\n\\n  # Look for shop/merch/product links\\n  $shopLinks = Select-String -Path $f -Pattern \\\"(?i)(merch|shop|cart|product|checkout|payment|stripe|sumup|buy)\\\" | Select-Object -First 5\\n  if ($shopLinks) {\\n    Write-Host \\\"Shop/merch hits:\\\"\\n    foreach ($s in $shopLinks) {\\n      Write-Host \\\"  L$($s.LineNumber): $($s.Line.Substring(0, [Math]::Min(140, $s.Line.Length)))\\\"\\n    }\\n  } else {\\n    Write-Host \\\"(no merch/shop/cart hits)\\\"\\n  }\\n  Write-Host \\\"\\\"\\n}\", \"description\": \"Inspect larger vault and s