\\n\\n  function activate(link) {\\n    links.forEach(l => l.classList.remove('active'));\\n    link.classList.add('active');\\n    currentHref = link.getAttribute('href');\\n    iframe.src = currentHref;\\n    currentTitle.textContent = link.getAttribute('data-name');\\n    iframe.style.display = 'block';\\n    empty.style.display = 'none';\\n  }\\n\\n  links.forEach(link => {\\n    link.addEventListener('click', (e) => {\\n      e.preventDefault();\\n      activate(link);\\n    });\\n  });\\n\\n  openNew.addEventListener('click', () => {\\n    if (currentHref) window.open(currentHref, '_blank');\\n  });\\n\\n  reloadBtn.addEventListener('click', () => {\\n    if (currentHref) iframe.src = currentHref;\\n  });\\n\\n  filter.addEventListener('input', () => {\\n    const q = filter.value.trim().toLowerCase();\\n    links.forEach(link => {\\n      const name = (link.getAttribute('data-name') || '').toLowerCase();\\n      const kw = (link.getAttribute('data-keywords') || '').toLowerCase();\\n      // Also let user filter by visible badge text\\n      const tags = Array.from(link.querySelectorAll('.badge')).map(b => b.textContent.toLowerCase()).join(' ');\\n      const match = !q || name.includes(q) || kw.includes(q) || tags.includes(q);\\n      link.classList.toggle('hidden', !match);\\n    });\\n  });\\n\\n  // Auto-load the most likely merch page on startup (the final Goods & Wear build)\\n  const first = Array.from(links).find(l => l.getAttribute('data-name') && l.getAttribute('data-name').includes('Built to Grow (final)'));\\n  if (first) activate(first);\\n</script>\\n</body>\\n</html>\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\AFJ_Cardiff_All_Websites\\\\index.html\"}",
