      "code": "{\"command\": \"$dst = \\\"$env:USERPROFILE\\\\Downloads\\\\AFJ_Cardiff_All_Websites\\\"\\n$files = Get-ChildItem $dst -Filter \\\"*.html\\\"\\n\\n# Build a scoring table: for each file, count merch-shop indicators\\n$results = foreach ($f in $files) {\\n  $content = Get-Content $f.FullName -Raw\\n  $size = $content.Length\\n  $hits = [ordered]@{\\n    Name       = $f.Name\\n    SizeKB     = [Math]::Round($size / 1KB, 1)\\n    \\\"Merch/Merchandise\\\" = ([regex]::Matches($content, \\\"(?i)merch\\\")).Count\\n    \\\"/merch path\\\"       = ([regex]::Matches($content, \\\"/merch\\\")).Count\\n    \\\"Add to cart\\\"       = ([regex]::Matches($content, \\\"(?i)add\\\\s*to\\\\s*cart\\\")).Count\\n    \\\"Stripe\\\"            = ([regex]::Matches($content, \\\"(?i)stripe\\\")).Count\\n    \\\"SumUp\\\"             = ([regex]::Matches($content, \\\"(?i)sumup\\\")).Count\\n    \\\"Shopify\\\"           = ([regex]::Matches($content, \\\"(?i)shopify\\\")).Count\\n    \\\"Shortcode\\\"         = ([regex]::Matches($content, \\\"(?i)shortcode\\\")).Count\\n    \\\"\\u00a3 price\\\"           = ([regex]::Matches($content, \\\"\\u00a3\\\\s?\\\\d\\\")).Count\\n    \\\"product-card\\\"      = ([regex]::Matches($content, \\\"(?i)product[-_]?card\\\")).Count\\n    \\\"Whatnot\\\"           = ([regex]::Matches($content, \\\"(?i)whatnot\\\")).Count\\n    \\\"Vanilla JS\\\"        = ([regex]::Matches($content, \\\"(?i)vanilla\\\")).Count\\n    \\\"checkout\\\"          = ([regex]::Matches($content, \\\"(?i)checkout\\\")).Count\\n  }\\n  $obj = New-Object PSObject -Property $hits\\n  # merch score = weighted sum\\n  $score = ($hits[\\\"Merch/Merchandise\\\"] * 3) + ($hits[\\\"/merch path\\\"] * 5) + ($hits[\\\"Add to cart\\\"] * 4) + ($hits[\\\"Stripe\\\"] * 2) + ($hits[\\\"SumUp\\\"] * 2) + ($hits[\\\"Shopify\\\"] * 3) + ($hits[\\\"Shortcode\\\"] * 2) + ($hits[\\\"\\u00a3 price\\\"] * 1) + ($hits[\\\"product-card\\\"] * 3) + ($hits[\\\"Whatnot\\\"] * 5) + ($hits[\\\"Vanilla JS\\\"] * 1) + ($hits[\\\"checkout\\\"] * 3)\\n  $obj | Add-Member -NotePropertyName \\\"Score\\\" -NotePropertyValue $score\\n  $obj\\n}\\n\\nWrite-Host \\\"=== HTML files ranked by merch-shop likelihood ===\\\"\\n$results | Sort-Object Score -Descending | Select-Object Name, SizeKB, Score, \\\"Merch/Merchandise\\\", \\\"/merch path\\\", \\\"Add to cart\\\", Stripe, SumUp, Shopify, Shortcode, \\\"\\u00a3 price\\\", \\\"product-card\\\", Whatnot, \\\"Vanilla JS\\\", checkout | Format-Table -AutoSize -Wrap\", \"description\": \"Score all HTML files for merch-shop indicators\"}",
