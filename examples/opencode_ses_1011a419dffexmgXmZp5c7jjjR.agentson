      "code": "{\"content\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\">\\n<head>\\n<meta charset=\\\"UTF-8\\\" />\\n<title>AFJ Cardiff \\u2014 All Websites Combined</title>\\n<style>\\n  * { box-sizing: border-box; }\\n  html, body { margin: 0; height: 100%; font-family: -apple-system, BlinkMacSystemFont, \\\"Segoe UI\\\", Roboto, Helvetica, Arial, sans-serif; color: #f4f4f5; background: #0b0b0f; }\\n  body { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }\\n  header {\\n    padding: 12px 20px;\\n    background: linear-gradient(90deg, #1e1b4b 0%, #4c1d95 100%);\\n    border-bottom: 1px solid #312e81;\\n    display: flex; align-items: center; justify-content: space-between; gap: 16px;\\n    flex-shrink: 0;\\n  }\\n  header h1 { margin: 0; font-size: 18px; font-weight: 700; letter-spacing: 0.3px; }\\n  header .meta { font-size: 12px; opacity: 0.75; }\\n  header .search { padding: 6px 10px; border-radius: 6px; border: 1px solid #4c1d95; background: #1e1b4b; color: #fff; font-size: 13px; min-width: 220px; }\\n  main { display: flex; flex: 1; min-height: 0; }\\n  nav {\\n    width: 360px; flex-shrink: 0;\\n    background: #111118;\\n    border-right: 1px solid #27272a;\\n    overflow-y: auto;\\n    padding: 12px 0;\\n  }\\n  nav .group-title {\\n    font-size: 11px; text-transform: uppercase; letter-spacing: 0.8px;\\n    color: #a78bfa; font-weight: 700; padding: 14px 16px 6px;\\n  }\\n  nav a {\\n    display: flex; align-items: center; gap: 6px;\\n    padding: 8px 16px; color: #d4d4d8; text-decoration: none;\\n    font-size: 13px; border-left: 3px solid transparent;\\n    transition: background 0.12s, border-color 0.12s;\\n    cursor: pointer; flex-wrap: wrap;\\n  }\\n  nav a:hover { background: #1f1f2e; color: #fff; }\\n  nav a.active { background: #1e1b4b; border-left-color: #a78bfa; color: #fff; }\\n  nav a .name { flex: 1; min-width: 0; }\\n  nav a .size { font-size: 11px; opacity: 0.5; width: 100%; }\\n  nav a .tags { display: flex; gap: 4px; flex-wrap: wrap; margin-right: 6px; }\\n\\n  /* Base badge style */\\n  .badge { font-size: 9px; padding: 2px 5px; border-radius: 3px; background: #4c1d95; color: #fff; font-weight: 600; letter-spacing: 0.3px; line-height: 1.4; white-space: nowrap; }\\n\\n  /* Type tags */\\n  .b-merch     { background: #be185d; }              /* AFJ Merch Shop */\\n  .b-shop      { background: #db2777; }              /* Generic shop */\\n  .b-vault     { background: #6d28d9; }              /* Vault */\\n  .b-story     { background: #d97706; }              /* Scrollytelling / story */\\n  .b-scroll    { background: #ea580c; }\\n  .b-gallery   { background: #0891b2; }              /* Post gallery / catalog */\\n  .b-receipt   { background: #52525b; }              /* Receipts */\\n  .b-dev       { background: #0e7490; }              /* Dev tools / schema */\\n  .b-schema    { background: #0f766e; }\\n  .b-portal    { background: #0d9488; }              /* Portals / walkthroughs */\\n  .b-walk      { background: #14b8a6; }\\n  .b-brief     { background: #6366f1; }              /* Briefing / handover */\\n  .b-blueprint { background: #4338ca; }\\n  .b-component { background: #f59e0b; color: #1f1f1f; } /* UI component */\\n  .b-event     { background: #e11d48; }              /* Event */\\n  .b-mentor    { background: #f43f5e; }\\n  .b-lms       { background: #10b981; }\\n  .b-chat      { background: #0284c7; }\\n  .b-community { background: #84cc16; color: #1f1f1f; }\\n  .b-summit    { background: #a3e635; color: #1f1f1f; }\\n  .b-ds        { background: #fb923c; color: #1f1f1f; } /* Design system */\\n  .b-archive   { background: #64748b; }\\n\\n  /* Topic tags */\\n  .b-afj       { background: #7c3aed; }\\n  .b-plam      { background: #8b5cf6; }\\n  .b-nost      { background: #c2410c; }\\n  .b-fg        { background: #059669; }\\n  .b-ak        { background: #1d4ed8; }\\n  .b-oss       { background: #0891b2; }\\n\\n  /* Status tags */\\n  .b-final     { background: #facc15; color: #1f1f1f; }\\n  .b-latest    { background: #22c55e; color: #052e16; }\\n  .b-new       { background: #16a34a; }\\n  .b-old       { background: #3f3f46; }\\n  .b-oldest    { background: #27272a; }\\n  .b-draft     { background: #71717a; }\\n  .b-backup    { background: #3f3f46; }\\n  .b-empty     { background: #27272a; opacity: 0.6; }\\n\\n  section.viewer { flex: 1; display: flex; flex-direction: column; min-width: 0; background: #0b0b0f; }\\n  .viewer-bar {\\n    padding: 10px 16px;\\n    background: #18181b; border-bottom: 1px solid #27272a;\\n    display: flex; align-items: center; gap: 12px; font-size: 13px;\\n    flex-shrink: 0;\\n  }\\n  .viewer-bar .title { font-weight: 600; }\\n  .viewer-bar .actions { margin-left: auto; display: flex; gap: 6px; }\\n  .viewer-bar button {\\n    padding: 5px 10px; border-radius: 5px;\\n    background: #27272a; color: #f4f4f5; border: 1px solid #3f3f46;\\n    cursor: pointer; font-size: 12px;\\n  }\\n  .viewer-bar button:hover { background: #3f3f46; }\\n  iframe { flex: 1; width: 100%; border: 0; background: #fff; }\\n  .empty { padding: 40px; text-align: center; color: #71717a; }\\n  .count { font-size: 11px; padding: 2px 6px; border-radius: 4px; background: #312e81; color: #c4b5fd; }\\n  /* Hide links that don't match the filter */\\n  nav a.hidden { display: none; }\\n</style>\\n</head>\\n<body>\\n<header>\\n  <div>\\n    <h1>AFJ Cardiff \\u2014 All Websites Combined</h1>\\n    <div class=\\\"meta\\\">45 sites \\u00b7 AFJ Cardiff \\\"Goods & Wear\\\" Merch Shop (5 builds) + Vault (13) + AI Studio e-commerce (22) + more \\u00b7 click any entry on the left</div>\\n  </div>\\n  <input id=\\\"filter\\\" class=\\\"search\\\" type=\\\"text\\\" placeholder=\\\"Filter by name, keyword, or tag (try 'merch', 'nostalgia', 'fg', 'final')\\u2026\\\" />\\n</header>\\n<main>\\n  <nav id=\\\"nav\\\">\\n\\n    <!-- ====== MERCH SHOP (Goods & Wear) ====== -->\\n    <div class=\\\"group-title\\\">AFJ Cardiff \\u2014 Merch Shop (Goods & Wear) <