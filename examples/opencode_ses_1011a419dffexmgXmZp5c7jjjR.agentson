      "code": "{\"command\": \"$dst = \\\"$env:USERPROFILE\\\\Downloads\\\\AFJ_Cardiff_All_Websites\\\"\\n$genFiles = Get-ChildItem $dst -Filter \\\"Generated File*.html\\\" | Sort-Object Name\\n\\nWrite-Host \\\"=== Inspecting EACH Generated File: title + ALL h1/h2/h3 + first 600 chars of body ===\\\"\\nforeach ($f in $genFiles) {\\n  $raw = Get-Content $f.FullName -Raw\\n  if (-not $raw) { continue }\\n\\n  Write-Host \\\"\\\"\\n  Write-Host \\\"==================== $($f.Name) ====================\\\"\\n  Write-Host \\\"Size: $([Math]::Round($raw.Length/1KB, 1)) KB\\\"\\n\\n  $title = ''\\n  if ($raw -match '<title>([^<]+)</title>') { $title = $matches[1] }\\n  Write-Host \\\"Title: $title\\\"\\n\\n  $headings = [regex]::Matches($raw, '<h([1-3])[^>]*>(.*?)</h\\\\1>')\\n  if ($headings.Count -gt 0) {\\n    Write-Host \\\"Headings:\\\"\\n    foreach ($h in $headings | Select-Object -First 10) {\\n      $txt = $h.Groups[2].Value -replace '<[^>]+>', '' -replace '\\\\s+', ' '\\n      $txt = $txt.Trim()\\n      if ($txt.Length -gt 0 -and $txt.Length -lt 150) {\\n        Write-Host \\\"  - $txt\\\"\\n      }\\n    }\\n  } else {\\n    Write-Host \\\"(no h1/h2/h3)\\\"\\n  }\\n\\n  # Extract body text (first 500 chars)\\n  $bodyMatch = [regex]::Match($raw, '<body[^>]*>(.*?)</body>', [System.Text.RegularExpressions.RegexOptions]::Singleline)\\n  if ($bodyMatch.Success) {\\n    $bodyText = ($bodyMatch.Groups[1].Value -replace '<script.*?</script>', ' ' -replace '<style.*?</style>', ' ' -replace '<[^>]+>', ' ' -replace '\\\\s+', ' ').Trim()\\n    if ($bodyText.Length -gt 0) {\\n      Write-Host \\\"Body preview: $($bodyText.Substring(0, [Math]::Min(400, $bodyText.Length)))\\\"\\n    }\\n  }\\n}\", \"description\": \"Read every Generated File content\"}",
