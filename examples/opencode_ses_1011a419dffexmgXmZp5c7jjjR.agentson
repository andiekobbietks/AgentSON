      "type": "action",
      "tool": "bash",
      "code": "{\"command\": \"$dst = \\\"$env:USERPROFILE\\\\Downloads\\\\AFJ_Cardiff_All_Websites\\\"\\n$files = Get-ChildItem $dst -Filter \\\"*.html\\\"\\n\\nWrite-Host \\\"=== Checking titles of ALL HTML files ===\\\"\\nforeach ($f in $files) {\\n  $raw = Get-Content $f.FullName -Raw -ErrorAction SilentlyContinue\\n  if ($raw) {\\n    $title = ''\\n    if ($raw -match '<title>([^<]+)</title>') { $title = $matches[1] }\\n    $h1 = ''\\n    if ($raw -match '<h1[^>]*>(.*?)</h1>') {\\n      $h1 = $matches[1] -replace '<[^>]+>', ''\\n    }\\n    Write-Host (\\\"{0,-55} | {1}\\\" -f $f.Name.Substring(0, [Math]::Min(55, $f.Name.Length)), ($title + ' :: ' + $h1).Trim(' :'))\\n  }\\n}\\n\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"=== Files containing 'Merch Shop' header ===\\\"\\nGet-ChildItem $dst -Filter \\\"*.html\\\" | ForEach-Object {\\n  $raw = Get-Content $_.FullName -Raw -ErrorAction SilentlyContinue\\n  if ($raw -and ($raw -match '(?i)merch\\\\s*shop|Merchandise|AFJ Merch')) {\\n    Write-Host \\\"HIT: $($_.Name)\\\"\\n    $hits = Select-String -Path $_.FullName -Pattern \\\"(?i)merch\\\\s*shop|merchandise\\\" | Select-Object -First 3\\n    foreach ($h in $hits) {\\n      Write-Host \\\"  L$($h.LineNumber): $($h.Line.Substring(0, [Math]::Min(150, $h.Line.Length)))\\\"\\n    }\\n  }\\n}\\n\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"=== Files containing 'add to cart' or 'add-to-cart' ===\\\"\\nGet-ChildItem $dst -Filter \\\"*.html\\\" | ForEach-Object {\\n  $raw = Get-Content $_.FullName -Raw -ErrorAction SilentlyContinue\\n  if ($raw -and ($raw -match '(?i)add[\\\\s\\\\-_]*to[\\\\s\\\\-_]*cart')) {\\n    $count = ([regex]::Matches($raw, '(?i)add[\\\\s\\\\-_]*to[\\\\s\\\\-_]*cart')).Count\\n    Write-Host \\\"HIT ($count): $($_.Name)\\\"\\n  }\\n}\\n\\nWrite-Host \\\"\\\"\\nWrite-Host \\\"=== Files with /merch URL or href links to merch ===\\\"\\nGet-ChildItem $dst -Filter \\\"*.html\\\" | ForEach-Object {\\n  $raw = Get-Content $_.FullName -Raw -ErrorAction SilentlyContinue\\n  if ($raw -and $raw -match '/merch') {\\n    $count = ([regex]::Matches($raw, '/merch')).Count\\n    Write-Host \\\"HIT ($count): $($_.Name)\\\"\\n  }\\n}\", \"description\": \"Search all HTML files for explicit merch shop markers\"}",
