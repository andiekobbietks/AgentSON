ools to convex schema\\\" data-keywords=\\\"devtools convex schema backend\\\" href=\\\"afj_cardiff_devtools_to_convex_schema.html\\\" target=\\\"viewer\\\">\\n      <span class=\\\"badge dev\\\">DEV</span> afj_cardiff_devtools_to_convex_schema\\n      <span class=\\\"size\\\">21 KB</span>\\n    </a>\\n\\n    <div class=\\\"group-title\\\">Receipts <span class=\\\"count\\\">1</span></div>\\n    <a data-name=\\\"AFJ Certified Receipt\\\" data-keywords=\\\"certified receipt proof\\\" href=\\\"AFJ_Certified_Receipt.html\\\" target=\\\"viewer\\\">\\n      AFJ_Certified_Receipt\\n      <span class=\\\"size\\\">1 KB</span>\\n    </a>\\n  </nav>\\n\\n  <section class=\\\"viewer\\\">\\n    <div class=\\\"viewer-bar\\\">\\n      <span class=\\\"title\\\" id=\\\"current-title\\\">Select a website from the left</span>\\n      <div class=\\\"actions\\\">\\n        <button id=\\\"open-new\\\" title=\\\"Open in a new tab\\\">\\u2197 Open in new tab</button>\\n        <button id=\\\"reload-btn\\\" title=\\\"Reload\\\">\\u27f3 Reload</button>\\n      </div>\\n    </div>\\n    <div class=\\\"empty\\\" id=\\\"empty-state\\\">\\n      <h2>AFJ Cardiff sites, all in one place</h2>\\n      <p>Pick any file from the sidebar to view it here.</p>\\n      <p style=\\\"margin-top:24px; opacity:0.6; font-size:13px;\\\">\\n        Likely merch / whatnot candidates are tagged <span class=\\\"badge merch\\\" style=\\\"background:#be185d;padding:2px 6px;border-radius:4px;font-size:11px;\\\">MERCH</span>.\\n      </p>\\n    </div>\\n    <iframe id=\\\"viewer\\\" name=\\\"viewer\\\" style=\\\"display:none;\\\"></iframe>\\n  </section>\\n</main>\\n\\n<script>\\n  const links = document.querySelectorAll('nav a');\\n  const iframe = document.getElementById('viewer');\\n  const empty = document.getElementById('empty-state');\\n  const currentTitle = document.getElementById('current-title');\\n  const openNew = document.getElementById('open-new');\\n  const reloadBtn = document.getElementById('reload-btn');\\n  const filter = document.getElementById('filter');\\n  let currentHref = null;\\n\\n  function activate(link) {\\n    links.forEach(l => l.classList.remove('active'));\\n    link.classList.add('active');\\n    currentHref = link.getAttribute('href');\\n    iframe.src = currentHref;\\n    currentTitle.textContent = link.getAttribute('data-name');\\n    iframe.style.display = 'block';\\n    empty.style.display = 'none';\\n  }\\n\\n  links.forEach(link => {\\n    link.addEventListener('click', (e) => {\\n      e.preventDefault();\\n      activate(link);\\n    });\\n  });\\n\\n  openNew.addEventListener('click', () => {\\n    if (currentHref) window.open(currentHref, '_blank');\\n  });\\n\\n  reloadBtn.addEventListener('click', () => {\\n    if (currentHref) iframe.src = currentHref;\\n  });\\n\\n  filter.addEventListener('input', () => {\\n    const q = filter.value.trim().toLowerCase();\\n    links.forEach(link => {\\n      const name = (link.getAttribute('data-name') || '').toLowerCase();\\n      const kw = (link.getAttribute('data-keywords') || '').toLowerCase();\\n      const match = !q || name.includes(q) || kw.includes(q);\\n      link.classList.toggle('hidden', !match);\\n    });\\n  });\\n\\n  // Auto-load the most likely merch page on startup\\n  const first = Array.from(links).find(l => l.getAttribute('data-keywords').includes('merch'));\\n  if (first) activate(first);\\n</script>\\n</body>\\n</html>\\n\", \"filePath\": \"C:\\\\Users\\\\LLM-Test\\\\Downloads\\\\AFJ_Cardiff_All_Websites\\\\index.html\"}",
