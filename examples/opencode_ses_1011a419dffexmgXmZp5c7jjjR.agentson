:         <button id=\"reload-btn\" title=\"Reload\">⟳ Reload</button>\n278:       </div>\n279:     </div>\n280:     <div class=\"empty\" id=\"empty-state\">\n281:       <h2>AFJ Cardiff sites, all in one place</h2>\n282:       <p>Pick any file from the sidebar to view it here.</p>\n283:       <p style=\"margin-top:24px; opacity:0.6; font-size:13px;\">\n284:         Likely merch / whatnot candidates are tagged <span class=\"badge merch\" style=\"background:#be185d;padding:2px 6px;border-radius:4px;font-size:11px;\">MERCH</span>.\n285:       </p>\n286:     </div>\n287:     <iframe id=\"viewer\" name=\"viewer\" style=\"display:none;\"></iframe>\n288:   </section>\n289: </main>\n290: \n291: <script>\n292:   const links = document.querySelectorAll('nav a');\n293:   const iframe = document.getElementById('viewer');\n294:   const empty = document.getElementById('empty-state');\n295:   const currentTitle = document.getElementById('current-title');\n296:   const openNew = document.getElementById('open-new');\n297:   const reloadBtn = document.getElementById('reload-btn');\n298:   const filter = document.getElementById('filter');\n299:   let currentHref = null;\n300: \n301:   function activate(link) {\n302:     links.forEach(l => l.classList.remove('active'));\n303:     link.classList.add('active');\n304:     currentHref = link.getAttribute('href');\n305:     iframe.src = currentHref;\n306:     currentTitle.textContent = link.getAttribute('data-name');\n307:     iframe.style.display = 'block';\n308:     empty.style.display = 'none';\n309:   }\n310: \n311:   links.forEach(link => {\n312:     link.addEventListener('click', (e) => {\n313:       e.preventDefault();\n314:       activate(link);\n315:     });\n316:   });\n317: \n318:   openNew.addEventListener('click', () => {\n319:     if (currentHref) window.open(currentHref, '_blank');\n320:   });\n321: \n322:   reloadBtn.addEventListener('click', () => {\n323:     if (currentHref) iframe.src = currentHref;\n324:   });\n325: \n326:   filter.addEventListener('input', () => {\n327:     const q = filter.value.trim().toLowerCase();\n328:     links.forEach(link => {\n329:       const name = (link.getAttribute('data-name') || '').toLowerCase();\n330:       const kw = (link.getAttribute('data-keywords') || '').toLowerCase();\n331:       const match = !q || name.includes(q) || kw.includes(q);\n332:       link.classList.toggle('hidden', !match);\n333:     });\n334:   });\n335: \n336:   // Auto-load the most likely merch page on startup\n337:   const first = Array.from(links).find(l => l.getAttribute('data-name') && l.getAttribute('data-name').includes('Built to Grow (final)'));\n338:   if (first) activate(first);\n339: </script>\n340: </body>\n341: </html>\n\n(End of file - total 341 lines)\n</content>",
