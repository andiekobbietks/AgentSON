gn: left; vertical-align: top; }\\n  .matrix th { background: #f5f5f4; font-weight: 700; text-transform: uppercase; font-size: 10px; letter-spacing: 0.4px; }\\n  .matrix td.name { font-weight: 700; }\\n\\n  footer.bot {\\n    margin-top: 28px; padding-top: 12px; border-top: 1px solid #e7e5e4;\\n    font-size: 10px; color: #78716c; line-height: 1.5;\\n  }\\n  .pill-print { display: inline-block; padding: 4px 10px; background: #1f1f1f; color: #fff; border-radius: 4px; font-size: 11px; cursor: pointer; border: 0; margin-bottom: 16px; }\\n  @media print {\\n    body { background: #fff; padding: 0; }\\n    .page { border: 0; box-shadow: none; padding: 12mm; max-width: none; }\\n    .pill-print { display: none; }\\n    .card { break-inside: avoid; }\\n  }\\n</style>\\n</head>\\n<body>\\n<button class=\\\"pill-print\\\" onclick=\\\"window.print()\\\">\\ud83d\\udda8 Print / Save as PDF</button>\\n\\n<div class=\\\"page\\\">\\n  <header class=\\\"top\\\">\\n    <div>\\n      <h1>AFJ Cardiff \\u2014 Collaborators At-A-Glance</h1>\\n      <div class=\\\"sub\\\">One-pager \\u00b7 core team, advisors, freelancers, media partners</div>\\n    </div>\\n    <div class=\\\"meta\\\">\\n      <div><strong>Organisation:</strong> AFJ Cardiff (Plamedi Santima-Akiso, Founder &amp; Creative Director)</div>\\n      <div><strong>Status date:</strong> 25 June 2026</div>\\n      <div><strong>Source:</strong> AI Studio \\\"Legal Framework for AFJ Cardiff\\\" conversation \\u00b7 18 Jun 2026</div>\\n    </div>\\n  </header>\\n\\n  <div class=\\\"legend\\\">\\n    <span class=\\\"l-core\\\">CORE TEAM</span>\\n    <span class=\\\"l-tech\\\">TECHNICAL</span>\\n    <span class=\\\"l-mkt\\\">MARKETING</span>\\n    <span class=\\\"l-video\\\">VIDEOGRAPHY</span>\\n    <span class=\\\"l-film\\\">FILMMAKER</span>\\n    <span class=\\\"l-agency\\\">AGENCY</span>\\n    <span class=\\\"l-vendor\\\">VENDOR</span>\\n  </div>\\n\\n  <h2 class=\\\"section\\\">Core Team</h2>\\n  <div class=\\\"grid\\\">\\n\\n    <div class=\\\"card founder\\\">\\n      <div class=\\\"who\\\"><div class=\\\"avatar\\\">PS</div><h3>Plamedi Santima-Akiso</h3></div>\\n      <div class=\\\"role\\\">Founder &amp; Creative Director</div>\\n      <div class=\\\"scope\\\">AFJ Cardiff founder. Creative direction, choreography, performer, primary stakeholder. Operates the @afj_cardiff, @afjcardiff socials.</div>\\n      <div class=\\\"status\\\">\\n        <span class=\\\"pill ok\\\">Active</span>\\n        <span class=\\\"pill info\\\">Trading as \\\"AFJ Cardiff\\\"</span>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"card tech\\\">\\n      <div class=\\\"who\\\"><div class=\\\"avatar\\\">AK</div><h3>Andrea \\\"Andie\\\" Kobbie</h3></div>\\n      <div class=\\\"role\\\">Technical Lead &amp; Governance Advisor</div>\\n      <div class=\\\"scope\\\">Builds &amp; runs vault, merch shop, AFJ Classroom. Drafts contracts, SOPs, IT governance (SumUp/Stripe with Consumer Rights Act disclaimers). AKCloud / Oracle OCI hosting.</div>\\n      <div class=\\\"status\\\">\\n        <span class=\\\"pill ok\\\">Active</span>\\n        <span class=\\\"pill info\\\">andiekobbietech</span>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"card mkt\\\">\\n      <div class=\\\"who\\\"><div class=\\\"avatar\\\">SF</div><h3>Sonia Fellah</h3></div>\\n      <div class=\\\"role\\\">Interim Marketer &amp; Social Media Lead</div>\\n      <div class=\\\"scope\\\">Joined April 2026. Instagram stories, Eventbrite banners, CapCut video edits (WCAG 2.3.1 photosensitive epilepsy warnings), Trello board, Content Output Tracker.</div>\\n      <div class=\\\"status\\\">\\n        <span class=\\\"pill ok\\\">Active</span>\\n        <span class=\\\"pill info\\\">Self-employed \\u00b7 barter (dance lessons \\u2194 marketing)</span>\\n      </div>\\n    </div>\\n  </div>\\n\\n  <h2 class=\\\"section\\\">Trusted Long-Term Collaborators</h2>\\n  <div class=\\\"grid\\\">\\n\\n    <div class=\\\"card video\\\">\\n      <div class=\\\"who\\\"><div class=\\\"avatar\\\">DM</div><h3>David Mac</div></div>\\n      <div class=\\\"role\\\">Lead Videographer</div>\\n      <div class=\\\"scope\\\">Long-term trusted videographer. Filmed almost the entirety of AFJ's historical catalogue. Reliable, minimal revisions, captures the AFJ \\\"DNA\\\".</div>\\n      <div class=\\\"status\\\">\\n        <span class=\\\"pill ok\\\">Active</span>\\n        <span class=\\\"pill info\\\">50% discount</span>\\n        <span class=\\\"pill warn\\\">Deed of Assignment pending</span>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"card film\\\">\\n      <div class=\\\"who\\\"><div class=\\\"avatar\\\">OM</div><h3>Onismo Muhlanga</h3></div>\\n      <div class=\\\"role\\\">Filmmaker \\u00b7 Urban Stamp (Newport)</div>\\n      <div class=\\\"scope\\\">Lead filmmaker for \\\"Movement is Memory and Storytelling\\\" R&amp;D documentary. Artistic Director of Urban Stamp. 7+ yrs experience, part of Urban Circle (20 yrs).</div>\\n      <div class=\\\"status\\\">\\n        <span class=\\\"pill ok\\\">Contract pending</span>\\n        <span class=\\\"pill warn\\\">Needed before 28 Jul funding decision</span>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"card agency\\\">\\n      <div class=\\\"who\\\"><div class=\\\"avatar\\\">WM</div><h3>Wolfget Media</h3></div>\\n      <div class=\\\"role\\\">Welsh content creation &amp; corporate videography agency</div>\\n      <div class=\\\"scope\\\">Early-days \\\"videography plug\\\". Shot first major AFJ promos incl. Angolan Afrohouse workshop 2022 highlight reel.</div>\\n      <div class=\\\"status\\\">\\n        <span class=\\\"pill ok\\\">Available</span>\\n        <span class=\\\"pill info\\\">South Wales</span>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"card film\\\">\\n      <div class=\\\"who\\\"><div class=\\\"avatar\\\">SA</div><h3>Sam</h3></div>\\n      <div class=\\\"role\\\">Filmmaker collaborator</div>\\n      <div class=\\\"scope\\\">Filmmaker collaborator on AFJ media projects.</div>\\n      <div class=\\\"status\\\">\\n        <span class=\\\"pill info\\\">Collaborator</span>\\n      </div>\\n    </div>\\n\\n  </div>\\n\\n  <h2 class=\\\"section\\\">Developer / Tech Stack</h2>\\n  <div class=\\\"grid\\\">\\n\\n    <div class=\\\"card tech\\\">\\n      <div class=\\\"who\\\"><div class=\\\"avatar\\\">DZ</div><h3>Dez</h3></div>\\n      <div class=\\\"role\\\">Developer (vault + CMS + database)</div>\\n      <div class=\\\"scope\\\">Built digital infrastructure (vault, CMS, database). Code, CMS, and database currently remain Dez's copyright \\u2014 Deed of Assignment needed for clean AFJ ownership.</div>\\n      <div class=\\\"status\\\">\\n        <span class=\\\"pill risk\\\">IP not assigned</span>\\n        <span class=\\\"pill warn\\\">Critical blocker for ACW funding</span>\\n      </div>\\n    </div>\\n\\n  </div>\\n\\n  <h2 class=\\\"section\\\">Roles Matrix \\u2014 Quick Lookup</h2>\\n  <table class=\\\"matrix\\\">\\n    <thead>\\n      <tr>\\n        <th>Name</th>\\n        <th>Role</th>\\n        <th>Relationship</th>\\n        <th>Status / Key Risk</th>\\n      </tr>\\n    </thead>\\n    <tbody>\\n      <tr><td class=\\\"name\\\">Plamedi Santima-Akiso</td><td>Founder &amp; Creative Director</td><td>Self (founder)</td><td><span class=\\\"pill ok\\\">Active</span></td></tr>\\n      <tr><td class=\\\"name\\\">Andie Kobbie</td><td>Technical Lead &amp; Governance Advisor</td><td>Independent consultant (Andie &amp; Kobbie Tech)</td><td><span class=\\\"pill ok\\\">Active \\u00b7 Advisor agreement pending</span></td></tr>\\n      <tr><td class=\\\"name\\\">Sonia Fellah</td><td>Interim Marketer &amp; Social Media Lead</td><td>Self-employed consultant (barter)</td><td><span class=\\\"pill ok\\\">Active \\u00b7 Consultancy v2 signed</span></td></tr>\\n      <tr><td class=\\\"name\\\">Dez</td><td>Developer (vault / CMS / DB)</td><td>Independent contractor</td><td><span class=\\\"pill risk\\\">IP assignment not signed</span></td></tr>\\n      <tr><td class=\\\"name\\\">David Mac</td><td>Lead Videographer</td><td>Long-term freelancer</td><td><span class=\\\"pill warn\\\">Archive footage IP needs assignment</span></td></tr>\\n      <tr><td class=\\\"name\\\">Onismo Muhlanga</td><td>Filmmaker \\u00b7 Urban Stamp</td><td>Production partner</td><td><span class=\\\"pill warn\\\">Contract needed by 28 Jul</span></td></tr>\\n      <tr><td class=\\\"name\\\">Wolfget Media</td><td>Welsh videography agency</td><td>Vendor</td><td><span class=\\\"pill info\\\">Available</span></td></tr>\\n      <tr><td class=\\\"name\\\">Sam</td><td>Filmmaker collaborator</td><td>Project-based</td><td><span class=\\\"pill info\\\">Collaborator</span></td></tr>\\n    </tbody>\\n  </table>\\n\\n  <h2 class=\\\"section\\\">Decision Map \\u2014 Who Signs What</h2>\\n  <table class=\\\"matrix\\\">\\n    <thead>\\n      <tr><th>Decision / Output</th><th>Owner</th><th>Approver</th></tr>\\n    </thead>\\n    <tbody>\\n      <tr><td>Creative direction &amp; brand</td><td>Plamedi</td><td>Plamedi</td></tr>\\n      <tr><td>Tech / vault / merch / site / IT governance</td><td>Andie</td><td>Plamedi</td></tr>\\n      <tr><td>Social media &amp; event marketing</td><td>Sonia</td><td>Plamedi</td></tr>\\n      <tr><td>Workshop / promo video</td><td>David (primary) / Wolfget</td><td>Plamedi</td></tr>\\n      <tr><td>\\\"Movement is Memory\\\" R&amp;D film</td><td>Onismo (Urban Stamp)</td><td>Plamedi</td></tr>\\n      <tr><td>Merch Shop + AFJ Classroom (hand-over)</td><td>Andie + Dez</td><td>Plamedi</td></tr>\\n      <tr><td>Funding applications (ACW etc.)</td><td>Plamedi</td><td>Plamedi</td></tr>\\n      <tr><td>Contracts / IP / SOPs</td><td>Andie (draft)</td><td>Plamedi</td></tr>\\n    </tbody>\\n  </table>\\n\\n  <footer class=\\\"bot\\\">\\n    <strong>Source:</strong> \\\"Legal Framework for AFJ Cardiff\\\" AI Studio conversation \\u00b7 18 Jun 2026 (632 KB readable export \\u00b7 873 AFJ \\u00b7 603 Plamedi mentions).\\n    <br><stro